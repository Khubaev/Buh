// Берёт таблицу товаров так же, как типовой ОбработкаПроведения АО.
//
Функция ТаблицаПоступленияТоваровИзПараметровПроведения(ПараметрыПроведения)
	
	Если ТипЗнч(ПараметрыПроведения) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ПараметрыПроведения.Свойство("СтруктураТаблицДокумента")
		И ТипЗнч(ПараметрыПроведения.СтруктураТаблицДокумента) = Тип("Структура")
		И ПараметрыПроведения.СтруктураТаблицДокумента.Свойство("ПоступлениеТоваровТаблица") Тогда
		Возврат ПараметрыПроведения.СтруктураТаблицДокумента.ПоступлениеТоваровТаблица;
	КонецЕсли;
	
	Если ПараметрыПроведения.Свойство("ПоступлениеТоваровТаблица") Тогда
		Возврат ПараметрыПроведения.ПоступлениеТоваровТаблица;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции
