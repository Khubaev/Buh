
#Область ОбработчикиСобытийФормы

&НаКлиенте
Процедура Расш3_ОбработкаВыбораДополнительно(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы <> "ОбщаяФорма.РедактированиеСчетаЗатрат" Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Расш3_ЗаполнитьВсеСтрокиУслуг Тогда
		Возврат;
	КонецЕсли;
	
	Расш3_ЗаполнитьВсеСтрокиУслуг = Ложь;
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьАналитикуУчетаВоВсехСтрокахУслугНаСервере(ВыбранноеЗначение);
	Элементы.Услуги.Обновить();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОтправитьНаРаспознавание(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Сначала запишите документ.'"));
		Возврат;
	КонецЕсли;
	
	РезультатПроверки = ПроверитьВозможностьОтправкиНаРаспознаваниеНаСервере();
	Если Не РезультатПроверки.Успех Тогда
		ПоказатьПредупреждение(, РезультатПроверки.ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	РезультатОтправки = ОтправитьНаРаспознаваниеНаСервере();
	Если РезультатОтправки.Успех Тогда
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Распознавание'"),
			,
			РезультатОтправки.ТекстСообщения,
			БиблиотекаКартинок.Информация32);
	Иначе
		ПоказатьПредупреждение(, РезультатОтправки.ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Расш3_СчетаЗатратДляВсех(Команда)
	
	ОткрытьФормуРедактированияСчетовЗатратДляВсех();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ПроверитьВозможностьОтправкиНаРаспознаваниеНаСервере()
	
	Результат = Новый Структура("Успех, ТекстСообщения", Истина, "");
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Результат.Успех = Ложь;
		Результат.ТекстСообщения = НСтр("ru = 'Сначала запишите документ.'");
		Возврат Результат;
	КонецЕсли;
	
	МассивФайлов = Расш3_РаспознаваниеВысота.ПолучитьСсылкиПрисоединенныхФайловОбъекта(Объект.Ссылка);
	
	Если МассивФайлов.Количество() = 0 Тогда
		Результат.Успех = Ложь;
		Результат.ТекстСообщения = НСтр("ru = 'К документу не прикреплены файлы.'");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ОтправитьНаРаспознаваниеНаСервере()
	
	Возврат Расш3_РаспознаваниеВысота.ОтправитьПрисоединенныеФайлыОбъектаНаРаспознавание(
		Объект.Ссылка,
		УникальныйИдентификатор);
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуРедактированияСчетовЗатратДляВсех()
	
	Если Не ТолькоПросмотр Тогда
		ЗаблокироватьДанныеФормыДляРедактирования();
	КонецЕсли;
	
	Расш3_ЗаполнитьВсеСтрокиУслуг = Истина;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТолькоПросмотр",       ТолькоПросмотр);
	ПараметрыФормы.Вставить("ДатаДокумента",        Объект.Дата);
	ПараметрыФормы.Вставить("Организация",          Объект.Организация);
	ПараметрыФормы.Вставить("НДСВключенВСтоимость", Объект.НДСВключенВСтоимость);
	ПараметрыФормы.Вставить("УчетАгентскогоНДС",    УчетАгентскогоНДС);
	ПараметрыФормы.Вставить("Контрагент",           Объект.Контрагент);
	ПараметрыФормы.Вставить("ДоговорКонтрагента",   Объект.ДоговорКонтрагента);
	ПараметрыФормы.Вставить("ФормаОткрытаИзШапки",  Истина);
	ПараметрыФормы.Вставить("КлючНазначенияИспользования", "ПоступлениеУслуг");
	
	Если Объект.Услуги.Количество() > 0 Тогда
		ДанныеСтроки = Объект.Услуги[0];
		ПараметрыФормы.Вставить("СчетУчетаНДС",         ДанныеСтроки.СчетУчетаНДС);
		ПараметрыФормы.Вставить("СпособУчетаНДС",       ДанныеСтроки.СпособУчетаНДС);
		ПараметрыФормы.Вставить("СуммаНДС",             ДанныеСтроки.СуммаНДС);
		ПараметрыФормы.Вставить("СчетЗатрат",           ДанныеСтроки.СчетЗатрат);
		ПараметрыФормы.Вставить("ПодразделениеЗатрат",  ДанныеСтроки.ПодразделениеЗатрат);
		ПараметрыФормы.Вставить("Субконто1",            ДанныеСтроки.Субконто1);
		ПараметрыФормы.Вставить("Субконто2",            ДанныеСтроки.Субконто2);
		ПараметрыФормы.Вставить("Субконто3",            ДанныеСтроки.Субконто3);
		ПараметрыФормы.Вставить("СчетЗатратНУ",         ДанныеСтроки.СчетЗатратНУ);
		ПараметрыФормы.Вставить("СубконтоНУ1",          ДанныеСтроки.СубконтоНУ1);
		ПараметрыФормы.Вставить("СубконтоНУ2",          ДанныеСтроки.СубконтоНУ2);
		ПараметрыФормы.Вставить("СубконтоНУ3",          ДанныеСтроки.СубконтоНУ3);
		ПараметрыФормы.Вставить("Номенклатура",         ДанныеСтроки.Номенклатура);
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.РедактированиеСчетаЗатрат", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
&Перед("УслугиАналитикаУчетаНачалоВыбора")
Процедура Расш3_УслугиАналитикаУчетаНачалоВыбораПеред(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Расш3_ЗаполнитьВсеСтрокиУслуг = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАналитикуУчетаВоВсехСтрокахУслугНаСервере(ВыбранноеЗначение)
	
	ПараметрыОбъекта = Неопределено;
	ЗаполнитьПараметрыОбъектаДляЗаполненияДобавленныхКолонок(ЭтотОбъект, ПараметрыОбъекта);
	
	ИменаПолейСумм = "Сумма, СуммаНДС, СуммаПоДокументу, СуммаНДСПоДокументу, СуммаОтклонение, СуммаНДСОтклонение";
	
	Для Каждого СтрокаУслуги Из Объект.Услуги Цикл
		
		ДанныеСтроки = Новый Структура("Сумма, СчетУчетаНДС, СуммаНДС, СпособУчетаНДС,
			|СчетЗатрат, Субконто1, Субконто2, Субконто3,
			|СчетЗатратНУ, СубконтоНУ1, СубконтоНУ2, СубконтоНУ3,
			|ПодразделениеЗатрат,
			|ВсегоПоДокументу, СуммаПоДокументу, СуммаНДСПоДокументу,
			|ВсегоОтклонение, СуммаОтклонение, СуммаНДСОтклонение,
			|НадписьПоДокументу, НадписьПоФакту, НадписьОтклонение,
			|Всего, АналитикаУчета, АналитикаУчетаЗаполнена");
		
		ЗаполнитьЗначенияСвойств(ДанныеСтроки, ВыбранноеЗначение);
		
		ДанныеСтроки.Сумма               = СтрокаУслуги.Сумма;
		ДанныеСтроки.СуммаНДС            = СтрокаУслуги.СуммаНДС;
		ДанныеСтроки.СуммаПоДокументу    = СтрокаУслуги.СуммаПоДокументу;
		ДанныеСтроки.СуммаНДСПоДокументу = СтрокаУслуги.СуммаНДСПоДокументу;
		ДанныеСтроки.СуммаОтклонение     = СтрокаУслуги.СуммаОтклонение;
		ДанныеСтроки.СуммаНДСОтклонение  = СтрокаУслуги.СуммаНДСОтклонение;
		
		ЗаполнитьДобавленныеКолонкиСтрокиТаблицыУслуги(ДанныеСтроки, ПараметрыОбъекта);
		
		ЗаполнитьЗначенияСвойств(СтрокаУслуги, ДанныеСтроки, , ИменаПолейСумм);
		
	КонецЦикла;
	
	Модифицированность = Истина;
	
КонецПроцедуры

#КонецОбласти
