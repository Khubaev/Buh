&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокФайлов.Очистить();
	
	Если Параметры.Свойство("ФайлыДляПередачи")
		И ТипЗнч(Параметры.ФайлыДляПередачи) = Тип("Массив") Тогда
		Для Каждого ПараметрыФайла Из Параметры.ФайлыДляПередачи Цикл
			Если ТипЗнч(ПараметрыФайла) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = СписокФайлов.Добавить();
			НоваяСтрока.ИдентификаторФайла = ЗначениеСтрокойИзСтруктуры(ПараметрыФайла, "ИдентификаторФайла");
			НоваяСтрока.ИмяФайла = ЗначениеСтрокойИзСтруктуры(ПараметрыФайла, "ИмяФайла");
			НоваяСтрока.РазмерКб = ЗначениеСтрокойИзСтруктуры(ПараметрыФайла, "РазмерКб");
			НоваяСтрока.Статус = ЗначениеСтрокойИзСтруктуры(ПараметрыФайла, "Статус");
			НоваяСтрока.АдресХранилища = ЗначениеСтрокойИзСтруктуры(ПараметрыФайла, "АдресХранилища");
			НоваяСтрока.Пометка = НужноОтметитьПоУмолчанию(НоваяСтрока.Статус);
		КонецЦикла;
	КонецЕсли;
	
	ОтправлятьДублиДокументов = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура РаспознатьДокументы(Команда)
	
	ИдентификаторыФайлов = Новый Массив;
	
	Для Каждого СтрокаФайла Из СписокФайлов Цикл
		Если Не СтрокаФайла.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ = КлючСтрокиФайла(СтрокаФайла);
		Если ЗначениеЗаполнено(Ключ) Тогда
			ИдентификаторыФайлов.Добавить(Ключ);
		КонецЕсли;
	КонецЦикла;
	
	Если ИдентификаторыФайлов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Отметьте хотя бы один файл для отправки.'"));
		Возврат;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ИдентификаторыФайлов", ИдентификаторыФайлов);
	Результат.Вставить("ОтправлятьДублиДокументов", ОтправлятьДублиДокументов);
	
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Функция КлючСтрокиФайла(СтрокаФайла)
	
	Если ЗначениеЗаполнено(СтрокаФайла.ИдентификаторФайла) Тогда
		Возврат Строка(СтрокаФайла.ИдентификаторФайла);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаФайла.АдресХранилища) Тогда
		Возврат Строка(СтрокаФайла.АдресХранилища);
	КонецЕсли;
	
	Возврат Строка(СтрокаФайла.ИмяФайла);
	
КонецФункции

&НаСервере
Функция НужноОтметитьПоУмолчанию(СтатусФайла)
	
	Статус = НРег(СокрЛП(Строка(СтатусФайла)));
	Если ПустаяСтрока(Статус) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Найти(Статус, НРег(НСтр("ru='Распознан'"))) > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Найти(Статус, НРег(НСтр("ru='Дубликат документа'"))) > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ЗначениеСтрокойИзСтруктуры(СтруктураПараметров, ИмяСвойства)
	
	Если Не СтруктураПараметров.Свойство(ИмяСвойства) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Строка(СтруктураПараметров[ИмяСвойства]);
	
КонецФункции
