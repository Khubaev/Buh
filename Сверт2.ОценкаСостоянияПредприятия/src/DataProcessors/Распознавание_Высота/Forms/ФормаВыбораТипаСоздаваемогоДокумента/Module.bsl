
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	СписокТипов = Неопределено;
	Если Параметры.Свойство("АдресСпискаТипов") И ЗначениеЗаполнено(Параметры.АдресСпискаТипов) Тогда
		СписокТипов = ПолучитьИзВременногоХранилища(Параметры.АдресСпискаТипов);
	КонецЕсли;
	
	Если СписокТипов = Неопределено Или СписокТипов.Количество() = 0 Тогда
		СписокТипов = ПолучитьСписокТиповСоздаваемыхДокументовЛокальноНаСервере();
	КонецЕсли;
	
	ЗаполнитьТаблицуТиповСоздаваемыхДокументовНаСервере(СписокТипов);
	
	Если Параметры.Свойство("СтрокиДокументов") Тогда
		СтрокиДокументовДляСоздания = Параметры.СтрокиДокументов;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ТипыСоздаваемыхДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Нет доступных типов документов для создания.'"));
		Закрыть();
		Возврат;
	КонецЕсли;
	
	ПерваяСтрока = ТипыСоздаваемыхДокументов[0];
	Элементы.ТипыСоздаваемыхДокументов.ТекущаяСтрока = ПерваяСтрока.ПолучитьИдентификатор();
	
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьСоздание(Команда)
	
	ТекущиеДанные = Элементы.ТипыСоздаваемыхДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите тип создаваемого документа.'"));
		Возврат;
	КонецЕсли;
	
	Результат = СформироватьРезультатВыбораНаСервере(ТекущиеДанные.ПолучитьИдентификатор());
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ТипыСоздаваемыхДокументовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПродолжитьСоздание(Неопределено);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуТиповСоздаваемыхДокументовНаСервере(СписокТипов)
	
	ТаблицаТипов = РеквизитФормыВЗначение("ТипыСоздаваемыхДокументов");
	ТаблицаТипов.Очистить();
	
	Для Каждого ЭлементТипа Из СписокТипов Цикл
		Если ТипЗнч(ЭлементТипа) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ТаблицаТипов.Добавить();
		НоваяСтрока.Представление = ЭлементТипа.Представление;
		НоваяСтрока.ТипДокумента = ЭлементТипа.ТипДокумента;
		НоваяСтрока.ВидОперацииИмя = ПолучитьИмяВидаОперацииИзЭлементаСпискаНаСервере(ЭлементТипа);
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ТаблицаТипов, "ТипыСоздаваемыхДокументов");
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокТиповСоздаваемыхДокументовЛокальноНаСервере()
	
	Список = Новый Массив;
	
	Если Метаданные.Документы.Найти("ПоступлениеТоваровУслуг") = Неопределено Тогда
		Возврат Список;
	КонецЕсли;
	
	Элемент = Новый Структура;
	Элемент.Вставить("Представление", НСтр("ru = 'Поступление товаров — Материалы в переработку'"));
	Элемент.Вставить("ТипДокумента", "ПоступлениеТоваровУслуг");
	Элемент.Вставить("ВидОперацииИмя", "ВПереработку");
	Список.Добавить(Элемент);
	
	Возврат Список;
	
КонецФункции

&НаСервере
Функция ПолучитьИмяВидаОперацииИзЭлементаСпискаНаСервере(ЭлементТипа)
	
	Если ЭлементТипа.Свойство("ВидОперацииИмя") И ЗначениеЗаполнено(ЭлементТипа.ВидОперацииИмя) Тогда
		Возврат ЭлементТипа.ВидОперацииИмя;
	КонецЕсли;
	
	Если ЭлементТипа.Свойство("ВидОперации") И ЗначениеЗаполнено(ЭлементТипа.ВидОперации) Тогда
		Попытка
			Возврат ЭлементТипа.ВидОперации.Метаданные().Имя;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат "ВПереработку";
	
КонецФункции

&НаСервере
Функция ПреобразоватьВидОперацииПоИмениНаСервере(ИмяВидаОперации)
	
	Если Не ЗначениеЗаполнено(ИмяВидаОперации) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Перечисления.ВидыОперацийПоступлениеТоваровУслуг[ИмяВидаОперации];
	Исключение
		Попытка
			Возврат ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеТоваровУслуг." + ИмяВидаОперации);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция СформироватьРезультатВыбораНаСервере(ИдентификаторСтроки)
	
	СтрокаТипа = ТипыСоздаваемыхДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если СтрокаТипа = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("ТипДокумента", СтрокаТипа.ТипДокумента);
	Результат.Вставить("ВидОперации", ПреобразоватьВидОперацииПоИмениНаСервере(СтрокаТипа.ВидОперацииИмя));
	Результат.Вставить("СтрокиДокументов", СтрокиДокументовДляСоздания);
	
	Возврат Результат;
	
КонецФункции
