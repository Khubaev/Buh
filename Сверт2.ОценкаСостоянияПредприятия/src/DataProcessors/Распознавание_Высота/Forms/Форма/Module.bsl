 
&НаКлиенте
Перем ИдентификаторЗагрузкиПросмотраPDF;

&НаКлиенте
Перем АдресХранилищаЗагрузкиPDF;

&НаКлиенте
Перем ИдЗагрузкиPDFОжидание;

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ОбъектыНазначения")
		И ТипЗнч(Параметры.ОбъектыНазначения) = Тип("Массив")
		И Параметры.ОбъектыНазначения.Количество() > 0 Тогда
		Документ = Параметры.ОбъектыНазначения[0];
	КонецЕсли;
	
	ЗаполнитьПараметрыAPIРаспознаванияНаСервере();
	
	Если Параметры.Свойство("ДополнительнаяОбработкаСсылка") Тогда
		СсылкаДополнительнойОбработки = Параметры.ДополнительнаяОбработкаСсылка;
	ИначеЕсли Параметры.Свойство("Ссылка") Тогда
		СсылкаДополнительнойОбработки = Параметры.Ссылка;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СсылкаДополнительнойОбработки) Тогда
		СсылкаДополнительнойОбработки = НайтиСсылкуДополнительнойОбработкиНаСервере();
	КонецЕсли;
	
	ЗагрузитьСтруктуруНастроекНаСервере();
	
	Если Параметры.Свойство("ЗагрузитьПрисоединенныеФайлы")
		И Параметры.ЗагрузитьПрисоединенныеФайлы = Истина
		И ЗначениеЗаполнено(Документ) Тогда
		
		СписокДокументов.Очистить();
		ЗагрузитьПрисоединенныеФайлыДокументаНаСервере(Документ);
		ЗагрузкаФайловИзДокумента = Истина;
		
		Если Параметры.Свойство("АвтоОтправитьНаРаспознавание")
			И Параметры.АвтоОтправитьНаРаспознавание = Истина Тогда
			АвтоОтправитьПослеОткрытия = Истина;
		КонецЕсли;
		
		ВосстановитьСоответствиеОтборуПослеЗагрузкиНаСервере();
		ОбновитьКодыСтатусовПоТекстуНаСервере();
		ОбновитьСчетчикиСтатусовНаСервере();
	Иначе
		ИнициализироватьРеестрДокументовНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ИдентификаторЗагрузкиПросмотраPDF = 0;
	
	ЗагрузитьНастройки();
	
	Если Не ЗагрузкаФайловИзДокументаНаСервере() Тогда
		ИнициализироватьРеестрДокументовНаСервере();
	Иначе
		ОбновитьСписокДокументовНаСервереПослеЗагрузкиИзДокумента();
	КонецЕсли;
	ВосстановитьДеталиДокументаПослеЗагрузкиНаСервере();
	ВосстановитьВыборСтрокиСпискаДокументовНаКлиенте();
	ОбновитьСписокДокументовНаКлиенте();
	ОбновитьПросмотрВыбранногоФайлаНаКлиенте();
	ПроверитьСтатусыЗаданий();
	
	Если АвтоОтправитьПослеОткрытия Тогда
		АвтоОтправитьПослеОткрытия = Ложь;
		ОтправитьВсеФайлыНаРаспознаваниеБезВыбора();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗакрытии(Отказ, ЗавершениеРаботы)
	
	СохранитьРеестрДокументовНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	СохранитьРеестрДокументовНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗакрытиеФормы_Настройки"
		И ТипЗнч(Параметр) = Тип("Структура")
		И Параметр.Свойство("СтруктураНастроек") Тогда
		
		СтруктураНастроек = Параметр.СтруктураНастроек;
		
		Если Параметр.Свойство("ОчиститьСписокДокументов") И Параметр.ОчиститьСписокДокументов = Истина Тогда
			СписокДокументов.Очистить();
			РезультатыФайловРаспознавания = "";
			ЗаданияРаспознавания.Очистить();
			СохранитьРеестрДокументовНаСервере();
			ОбновитьСписокДокументовНаКлиенте();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы
 
&НаКлиенте
Процедура Сформировать(Команда)
	
	Если Не ЗначениеЗаполнено(Документ) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите документ для печати.'"));
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент() Тогда
		СкачатьФайлПечатнойФормыВВебКлиенте();
	Иначе
		ОткрытьСформированныйДокументВТолстомКлиенте();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФайл(Команда)
	
	Если СписокДокументов.Количество() >= МаксимальноеКоличествоФайлов() Тогда
		ПоказатьПредупреждение(, СтрШаблон(
			НСтр("ru = 'Можно прикрепить не более %1 файлов.'"),
			МаксимальноеКоличествоФайлов()));
		Возврат;
	КонецЕсли;
	
	// ПараметрыЗагрузкиФайлов() есть не во всех версиях БСП — используем платформенные методы.
	Если ОбщегоНазначенияКлиентСервер.ЭтоВебКлиент() Тогда
		НачатьПомещениеФайла(
			Новый ОписаниеОповещения("ПослеПомещенияФайла", ЭтотОбъект),
			,
			,
			Истина,
			УникальныйИдентификатор);
	Иначе
		ДобавитьФайлыЧерезДиалогВыбора();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьФайл(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СписокДокументов.Удалить(ТекущиеДанные);
	СохранитьРеестрДокументовНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура РаспознатьДокументы(Команда)
	ОтправитьНаРаспознавание(Команда);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокДокументов(Команда)
	ОбновитьСписокДокументовНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументы(Команда)
	
	ОчиститьПросмотрФайлаНаКлиенте();
	
	СтрокиДляСоздания = ПолучитьОтмеченныеСтрокиДляСозданияНаСервере();
	ИдентификаторТекущейСтроки = Неопределено;
	ТекущиеДанныеСписка = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанныеСписка <> Неопределено Тогда
		ИдентификаторТекущейСтроки = ТекущиеДанныеСписка.ПолучитьИдентификатор();
	КонецЕсли;
	
	Если СтрокиДляСоздания.Количество() = 0 Тогда
		СтрокиДляСоздания = ПопробоватьВзятьТекущуюСтрокуДляСозданияНаСервере(ИдентификаторТекущейСтроки);
	КонецЕсли;
	Если СтрокиДляСоздания.Количество() = 0 Тогда
		СообщениеПользователю = ТекстПодсказкиВыбораДокументовДляСозданияНаСервере(ИдентификаторТекущейСтроки);
		ПоказатьПредупреждение(, СообщениеПользователю);
		Возврат;
	КонецЕсли;
	
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	
	ПодготовкаСоздания = ПодготовитьПараметрыСозданияДокументовНаСервере(СтрокиДляСоздания);
	Если Не ПодготовкаСоздания.Успех Тогда
		ПоказатьПредупреждение(, ПодготовкаСоздания.Сообщение);
		Возврат;
	КонецЕсли;
	
	ОткрытьМастерСозданияДокументов(ПодготовкаСоздания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораТипаСоздаваемогоДокумента(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Или ТипЗнч(Результат) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьМастерСозданияДокументов(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьМастерСозданияДокументов(ПараметрыСоздания)
	
	Если Не ПараметрыСоздания.Свойство("СтрокиДокументов") Тогда
		Возврат;
	КонецЕсли;
	
	СтрокиДляСоздания = ПараметрыСоздания.СтрокиДокументов;
	Если СтрокиДляСоздания.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("СтрокиДокументов", СтрокиДляСоздания);
	ПараметрыОткрытия.Вставить("АдресРезультатов", АдресРезультатовДляМастераНаСервере());
	ПараметрыОткрытия.Вставить("АдресНастроек", АдресНастроекДляМастераНаСервере());
	ПараметрыОткрытия.Вставить("АдресПодготовленныхДанных", ПодготовитьДанныеМастераСозданияНаСервере(СтрокиДляСоздания));
	ПараметрыОткрытия.Вставить("АдресФайловДляСоздания", ПодготовитьАдресаИсходныхФайловДляСозданияНаСервере(СтрокиДляСоздания));
	
	Если ПараметрыСоздания.Свойство("ТипДокумента") Тогда
		ПараметрыОткрытия.Вставить("ТипСоздаваемогоДокумента", ПараметрыСоздания.ТипДокумента);
	КонецЕсли;
	Если ПараметрыСоздания.Свойство("ВидОперации") Тогда
		ПараметрыОткрытия.Вставить("ВидОперацииСоздания", ПараметрыСоздания.ВидОперации);
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияФормыСозданияДокументов", ЭтотОбъект);
	ОчиститьПросмотрФайлаНаКлиенте();
	ОткрытьФорму(
		ИмяФормыСозданияДокументов(),
		ПараметрыОткрытия,
		ЭтаФорма,
		,
		,
		,
		Оповещение,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыСозданияДокументов(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("СозданныеДокументы") Тогда
		ПрименитьСозданныеДокументыНаСервере(Результат.СозданныеДокументы);
	КонецЕсли;
	
	ОбновитьСписокДокументовНаКлиенте();
	
КонецПроцедуры

&НаКлиенте
Процедура ВсеДокументыНажатие(Элемент)
	УстановитьФильтрСтатуса("");
КонецПроцедуры

&НаКлиенте
Процедура РаспознанныеНажатие(Элемент)
	УстановитьФильтрСтатуса("Распознан");
КонецПроцедуры

&НаКлиенте
Процедура НаРаспознаванииНажатие(Элемент)
	УстановитьФильтрСтатуса("НаРаспознавании");
КонецПроцедуры

&НаКлиенте
Процедура ОшибкиНажатие(Элемент)
	УстановитьФильтрСтатуса("Ошибка");
КонецПроцедуры

&НаКлиенте
Процедура СозданныеВ1СНажатие(Элемент)
	УстановитьФильтрСтатуса("СозданВ1С");
КонецПроцедуры

&НаКлиенте
Процедура СписокДокументовПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьДеталиВыбранногоДокументаНаСервере(КлючСтрокиДокументаНаКлиенте(ТекущиеДанные));
	ОбновитьПросмотрВыбранногоФайлаНаКлиенте(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПросмотрВыбранногоФайлаНаКлиенте(СтрокаДокумента = Неопределено)
	
	ОчиститьПросмотрФайлаНаКлиенте();
	
	Если СтрокаДокумента = Неопределено Тогда
		СтрокаДокумента = Элементы.СписокДокументов.ТекущиеДанные;
	КонецЕсли;
	
	Если СтрокаДокумента = Неопределено Тогда
		УстановитьТекстНадписиПросмотраФайла(НСтр("ru = 'Выберите файл в списке для просмотра'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаДокумента.АдресХранилища) Тогда
		УстановитьТекстНадписиПросмотраФайла(НСтр("ru = 'Файл недоступен для просмотра'"));
		Возврат;
	КонецЕсли;
	
	Расширение = РасширениеФайлаПоИмени(СтрокаДокумента.ИмяФайла);
	Если ЭтоРасширениеPDF(Расширение) Тогда
		Если ЭтоКлиентСерверныйРежимРаботыНаКлиенте() Тогда
			УстановитьТекстНадписиПросмотраФайла(СтрШаблон(
				НСтр("ru = 'В клиент-серверном режиме встроенный просмотр PDF отключён (ограничение платформы).%1Нажмите «Открыть исходный файл».'"),
				Символы.ПС));
		Иначе
			НачатьЗагрузкуPDFПросмотраНаКлиенте(СтрокаДокумента.АдресХранилища);
		КонецЕсли;
	ИначеЕсли ЭтоРасширениеExcel(Расширение) Тогда
		ТабДок = ЗагрузитьТабличныйДокументПросмотраНаСервере(СтрокаДокумента.АдресХранилища, Расширение);
		Если ТабДок <> Неопределено Тогда
			ТабличныйДокументПросмотра = ТабДок;
			Элементы.ПолеПросмотраТаблица.Видимость = Истина;
			Элементы.НадписьПросмотрФайла.Видимость = Ложь;
		Иначе
			УстановитьТекстНадписиПросмотраФайла(СтрШаблон(
				НСтр("ru = 'Не удалось отобразить Excel в форме.%1Нажмите «Открыть в Excel» для просмотра в программе.'"),
				Символы.ПС));
		КонецЕсли;
	Иначе
		УстановитьТекстНадписиПросмотраФайла(СтрШаблон(
			НСтр("ru = 'Встроенный просмотр: PDF и Excel (xls, xlsx).%1Для файла %2 нажмите «Открыть исходный файл».'"),
			Символы.ПС,
			Строка(СтрокаДокумента.ИмяФайла)));
	КонецЕсли;
	
	УстановитьЗаголовокКомандыОткрытияФайла(Расширение);
	Элементы.ОткрытьИсходныйФайл.Доступность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПросмотрФайлаНаКлиенте()
	
	Если ИдентификаторЗагрузкиПросмотраPDF = Неопределено Тогда
		ИдентификаторЗагрузкиПросмотраPDF = 0;
	КонецЕсли;
	
	ИдентификаторЗагрузкиПросмотраPDF = ИдентификаторЗагрузкиПросмотраPDF + 1;
	СброситьПолеPDFНаКлиенте();
	Элементы.ПолеПросмотраPDF.Видимость = Ложь;
	Элементы.ПолеПросмотраТаблица.Видимость = Ложь;
	Элементы.НадписьПросмотрФайла.Видимость = Истина;
	Элементы.ОткрытьИсходныйФайл.Доступность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьПолеPDFНаКлиенте()
	
	// Сброс реквизита снижает риск аварийного завершения «Файл документа изменен» в клиент-серверном режиме.
	Попытка
		ПолеПросмотраPDF = Вычислить("Новый ДокументPDF");
	Исключение
		Попытка
			ПолеПросмотраPDF = Вычислить("Новый PDFDocument");
		Исключение
		КонецПопытки;
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗаголовокКомандыОткрытияФайла(РасширениеФайла)
	
	Если ЭтоРасширениеExcel(РасширениеФайла) Тогда
		ЗаголовокКоманды = НСтр("ru = 'Открыть в Excel'");
	Иначе
		ЗаголовокКоманды = НСтр("ru = 'Открыть исходный файл'");
	КонецЕсли;
	
	Элементы.ОткрытьИсходныйФайл.Заголовок = ЗаголовокКоманды;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекстНадписиПросмотраФайла(Текст)
	
	Элементы.НадписьПросмотрФайла.Заголовок = Текст;
	Элементы.НадписьПросмотрФайла.Видимость = Истина;
	Элементы.ПолеПросмотраPDF.Видимость = Ложь;
	Элементы.ПолеПросмотраТаблица.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьДвоичныеДанныеФайлаДляПросмотраНаКлиенте(АдресХранилища)
	
	// В клиент-серверном режиме файл лежит во временном хранилище сервера — читаем только через серверный вызов.
	Если Не ЭтоКлиентСерверныйРежимРаботыНаКлиенте() Тогда
		Попытка
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресХранилища);
			Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
				Возврат ДвоичныеДанные;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат ПолучитьДвоичныеДанныеФайлаДляПросмотраНаСервере(АдресХранилища);
	
КонецФункции

&НаКлиенте
Функция ЭтоКлиентСерверныйРежимРаботыНаКлиенте()
	
	Возврат Не ОбщегоНазначенияКлиент.ИнформационнаяБазаФайловая();
	
КонецФункции

&НаКлиенте
Процедура НачатьЗагрузкуPDFПросмотраНаКлиенте(АдресХранилища)
	
	ИдентификаторЗагрузкиПросмотраPDF = ИдентификаторЗагрузкиПросмотраPDF + 1;
	ИдЗагрузкиPDFОжидание = ИдентификаторЗагрузкиПросмотраPDF;
	АдресХранилищаЗагрузкиPDF = Строка(АдресХранилища);
	
	// Отложенная загрузка: даёт платформе завершить скрытие поля и снизить риск «Файл документа изменен» в КС.
	ЗадержкаЗагрузки = ?(ЭтоКлиентСерверныйРежимРаботыНаКлиенте(), 0.3, 0.1);
	ПодключитьОбработчикОжидания("ЗагрузитьPDFПросмотраОтложенно", ЗадержкаЗагрузки, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьPDFПросмотраОтложенно() Экспорт
	
	ЗагрузитьPDFВПолеПросмотраНаКлиенте(АдресХранилищаЗагрузкиPDF, ИдЗагрузкиPDFОжидание);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьPDFВПолеПросмотраНаКлиенте(АдресХранилища, ИдЗагрузки)
	
	Если ИдЗагрузки <> ИдентификаторЗагрузкиПросмотраPDF Тогда
		Возврат;
	КонецЕсли;
	
	ДвоичныеДанные = ПолучитьДвоичныеДанныеФайлаДляПросмотраНаКлиенте(АдресХранилища);
	Если ДвоичныеДанные = Неопределено Тогда
		Если ИдЗагрузки = ИдентификаторЗагрузкиПросмотраPDF Тогда
			УстановитьТекстНадписиПросмотраФайла(НСтр("ru = 'Не удалось загрузить PDF-файл'"));
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Попытка
		// Синхронное чтение надёжнее ПрочитатьАсинх в клиент-серверном режиме (известная проблема платформы).
		ПолеПросмотраPDF.Прочитать(ДвоичныеДанные.ОткрытьПотокДляЧтения());
	Исключение
		Если ИдЗагрузки = ИдентификаторЗагрузкиПросмотраPDF Тогда
			УстановитьТекстНадписиПросмотраФайла(СтрШаблон(
				НСтр("ru = 'Не удалось отобразить PDF в форме.%1Нажмите «Открыть исходный файл».'"),
				Символы.ПС));
		КонецЕсли;
		Возврат;
	КонецПопытки;
	
	Если ИдЗагрузки <> ИдентификаторЗагрузкиПросмотраPDF Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ПолеПросмотраPDF.Видимость = Истина;
	Элементы.НадписьПросмотрФайла.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьИсходныйФайл(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите файл в списке.'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.АдресХранилища) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Файл недоступен для открытия.'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыФайла = ПолучитьПараметрыОткрытияИсходногоФайлаНаСервере(
		ТекущиеДанные.АдресХранилища,
		ТекущиеДанные.ИмяФайла);
	Если ПараметрыФайла = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Не удалось получить файл для открытия.'"));
		Возврат;
	КонецЕсли;
	
	ПолучитьФайл(ПараметрыФайла.Адрес, ПараметрыФайла.Имя, Истина);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция РасширениеФайлаПоИмени(ИмяФайла)
	
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат "";
	КонецЕсли;
	
	ПозицияТочки = СтрНайти(ИмяФайла, ".", НаправлениеПоиска.СКонца);
	Если ПозицияТочки = 0 Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат Сред(ИмяФайла, ПозицияТочки + 1);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоРасширениеPDF(РасширениеФайла)
	
	Возврат НРег(СокрЛП(РасширениеФайла)) = "pdf";
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоРасширениеExcel(РасширениеФайла)
	
	Расширение = НРег(СокрЛП(РасширениеФайла));
	Возврат Расширение = "xls"
		Или Расширение = "xlsx"
		Или Расширение = "xlsm";
	
КонецФункции

&НаКлиенте
Процедура СписокДокументовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Поле.Имя = "СписокДокументовДокумент1С" И ЗначениеЗаполнено(ТекущиеДанные.Документ1С) Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение(, ТекущиеДанные.Документ1С);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция КлючСтрокиДокументаНаКлиенте(СтрокаДокумента)
	
	Если ЗначениеЗаполнено(СтрокаДокумента.АдресРезультатаРаспознавания) Тогда
		Возврат СтрокаДокумента.АдресРезультатаРаспознавания;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДокумента.ИдентификаторФайла) Тогда
		Возврат Строка(СтрокаДокумента.ИдентификаторФайла);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДокумента.АдресХранилища) Тогда
		Возврат Строка(СтрокаДокумента.АдресХранилища);
	КонецЕсли;
	
	Возврат Строка(СтрокаДокумента.ИмяФайла);
	
КонецФункции

&НаКлиенте
Процедура УстановитьКодСтатусаСтрокиНаКлиенте(СтрокаДокумента, КодСтатуса)
	
	СтрокаДокумента.КодСтатуса = КодСтатуса;
	СтрокаДокумента.Статус = ПредставлениеСтатусаПоКодуНаКлиенте(КодСтатуса, СтрокаДокумента.Статус);
	
КонецПроцедуры

&НаКлиенте
Функция ПредставлениеСтатусаПоКодуНаКлиенте(КодСтатуса, ТекущийСтатус = "")
	
	Если КодСтатуса = "Новый" Тогда
		Возврат НСтр("ru = 'Новый'");
	ИначеЕсли КодСтатуса = "НаРаспознавании" Тогда
		Возврат НСтр("ru = 'На распознавании'");
	ИначеЕсли КодСтатуса = "Распознан" Тогда
		Возврат НСтр("ru = '[OK] Распознан'");
	ИначеЕсли КодСтатуса = "Ошибка" Тогда
		Возврат НСтр("ru = '[ERR] Ошибка'");
	ИначеЕсли КодСтатуса = "Дубликат" Тогда
		Возврат НСтр("ru = '[WARN] Дубликат документа'");
	ИначеЕсли КодСтатуса = "ГотовКСозданию" Тогда
		Возврат НСтр("ru = 'Готов к созданию'");
	ИначеЕсли КодСтатуса = "СозданВ1С" Тогда
		Возврат НСтр("ru = 'Создан в 1С'");
	КонецЕсли;
	
	Возврат ?(ЗначениеЗаполнено(ТекущийСтатус), ТекущийСтатус, КодСтатуса);
	
КонецФункции

&НаКлиенте
Процедура ОтправитьНаРаспознавание(Команда)
	
	ОчиститьПросмотрФайлаНаКлиенте();
	
	Если РаспознаваниеВыполняется Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(АдресAPIРаспознавания) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите адрес API распознавания.'"));
		Возврат;
	КонецЕсли;
	
	Если СписокДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Добавьте хотя бы один файл.'"));
		Возврат;
	КонецЕсли;
	
	НачатьПоказФормыОтправкиФайлов();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВсеФайлыНаРаспознаваниеБезВыбора()
	
	ОчиститьПросмотрФайлаНаКлиенте();
	
	Если РаспознаваниеВыполняется Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(АдресAPIРаспознавания) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите адрес API распознавания.'"));
		Возврат;
	КонецЕсли;
	
	Если СписокДокументов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Нет файлов для отправки.'"));
		Возврат;
	КонецЕсли;
	
	ИдентификаторыФайлов = Новый Массив;
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		ИдентификаторыФайлов.Добавить(КлючФайлаДляОтправки(СтрокаФайла));
	КонецЦикла;
	
	ПрименитьВыборФайловДляОтправки(ИдентификаторыФайлов, Ложь);
	РезультатРаспознавания = НСтр("ru = 'Отправка файлов на сервер распознавания...'");
	НачатьАсинхроннуюОтправкуНаРаспознавание(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПоказФормыОтправкиФайлов()
	
	ФайлыДляПередачи = Новый Массив;
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		СтруктураФайла = Новый Структура;
		СтруктураФайла.Вставить("ИдентификаторФайла", Строка(СтрокаФайла.ИдентификаторФайла));
		СтруктураФайла.Вставить("ИмяФайла", Строка(СтрокаФайла.ИмяФайла));
		СтруктураФайла.Вставить("РазмерКб", Строка(СтрокаФайла.РазмерКб));
		СтруктураФайла.Вставить("Статус", Строка(СтрокаФайла.Статус));
		СтруктураФайла.Вставить("АдресХранилища", Строка(СтрокаФайла.АдресХранилища));
		ФайлыДляПередачи.Добавить(СтруктураФайла);
	КонецЦикла;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ФайлыДляПередачи", ФайлыДляПередачи);
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияФормыОтправки", ЭтотОбъект);
	ПолноеИмяФормыОтправки = ИмяФормыОтправкиФайлов();
	
	ОткрытьФорму(
		ПолноеИмяФормыОтправки,
		ПараметрыОткрытия,
		ЭтаФорма,
		,
		,
		,
		Оповещение,
		РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыОтправки(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		РезультатРаспознавания = НСтр("ru='Отправка отменена пользователем.'");
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) <> Тип("Структура")
		Или Не РезультатВыбора.Свойство("ИдентификаторыФайлов")
		Или ТипЗнч(РезультатВыбора.ИдентификаторыФайлов) <> Тип("Массив")
		Или РезультатВыбора.ИдентификаторыФайлов.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru='Не выбрано ни одного файла для отправки.'"));
		Возврат;
	КонецЕсли;
	
	ОтправлятьДублиДокументов = Ложь;
	Если РезультатВыбора.Свойство("ОтправлятьДублиДокументов") Тогда
		ОтправлятьДублиДокументов = РезультатВыбора.ОтправлятьДублиДокументов;
	КонецЕсли;
	
	ПрименитьВыборФайловДляОтправки(РезультатВыбора.ИдентификаторыФайлов, ОтправлятьДублиДокументов);
	
	РезультатРаспознавания = НСтр("ru = 'Отправка файлов на сервер распознавания...'");
	НачатьАсинхроннуюОтправкуНаРаспознавание(ОтправлятьДублиДокументов);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьАсинхроннуюОтправкуНаРаспознавание(ОтправлятьДублиДокументов = Ложь)
	
	УстановитьСостояниеРаспознавания(Истина);
	
	Попытка
		ДанныеЗапуска = НачатьОтправкуРаспознаванияНаСервере(ОтправлятьДублиДокументов);
	Исключение
		УстановитьСостояниеРаспознавания(Ложь);
		Для Каждого СтрокаФайла Из СписокДокументов Цикл
			СтрокаФайла.Статус = НСтр("ru = 'Ошибка'");
		КонецЦикла;
		ТекстОшибки = ОписаниеОшибкиЗапускаРаспознавания();
		РезультатРаспознавания = ТекстОшибки;
		ПоказатьПредупреждениеНеПустое(ТекстОшибки);
		Возврат;
	КонецПопытки;
	
	// Вариант A: один запрос до финального результата (форма будет ждать ответ сервиса).
	УстановитьСостояниеРаспознавания(Ложь);
	
	Если ДанныеЗапуска.Свойство("ИдентификаторЗадания")
		И ЗначениеЗаполнено(ДанныеЗапуска.ИдентификаторЗадания) Тогда
		РезультатРаспознавания = НСтр("ru = 'Файлы поставлены в очередь распознавания. Ожидайте завершения...'");
		ПодключитьОпросСтатусовЗаданий();
		Возврат;
	КонецЕсли;
	
	ОбработатьРезультатРаспознавания(ДанныеЗапуска.РезультатОтправки);
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьФайлыСоСтатусомДубликатДокумента()
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Статус = НРег(СокрЛП(Строка(СтрокаФайла.Статус)));
		Если Найти(Статус, НРег(НСтр("ru='Дубликат документа'"))) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Функция ИмяФормыОтправкиФайлов()
	
	Возврат ИмяПодчиненнойФормыОбработки("ФормаОтправки");
	
КонецФункции

&НаКлиенте
Процедура ПрименитьВыборФайловДляОтправки(ИдентификаторыФайлов, ОтправлятьДублиДокументов)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		
		Ключ = КлючФайлаДляОтправки(СтрокаФайла);
		Выбран = ИдентификаторыФайлов.Найти(Ключ) <> Неопределено;
		Статус = НРег(СокрЛП(Строка(СтрокаФайла.Статус)));
		ЭтоДубликатДокумента = Найти(Статус, НРег(НСтр("ru='Дубликат документа'"))) > 0;
		
		Если Выбран Тогда
			Если ЭтоДубликатДокумента И Не ОтправлятьДублиДокументов Тогда
				СтрокаФайла.Статус = НСтр("ru='Дубликат документа (пропущен)'");
			Иначе
				СтрокаФайла.Статус = НСтр("ru='Готов к отправке'");
			КонецЕсли;
		ИначеЕсли ЭтоДубликатДокумента Тогда
			СтрокаФайла.Статус = НСтр("ru='Дубликат документа (пропущен)'");
		Иначе
			СтрокаФайла.Статус = НСтр("ru='Пропущен пользователем'");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция КлючФайлаДляОтправки(СтрокаФайла)
	
	Если ЗначениеЗаполнено(СтрокаФайла.ИдентификаторФайла) Тогда
		Возврат Строка(СтрокаФайла.ИдентификаторФайла);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаФайла.АдресХранилища) Тогда
		Возврат Строка(СтрокаФайла.АдресХранилища);
	КонецЕсли;
	
	Возврат Строка(СтрокаФайла.ИмяФайла);
	
КонецФункции

&НаКлиенте
Процедура ПроверитьРезультатРаспознавания()
	// Не используется в варианте A.
	
КонецПроцедуры

&НаКлиенте
Функция ОписаниеОшибкиЗапускаРаспознавания()
	
	Инфо = ИнформацияОбОшибке();
	ТекстОшибки = ПодробноеПредставлениеОшибки(Инфо);
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		Возврат ТекстОшибки;
	КонецЕсли;
	
	Возврат НСтр("ru = 'Ошибка при запуске распознавания.'");
	
КонецФункции

&НаКлиенте
Процедура ПоказатьПредупреждениеНеПустое(Текст)
	
	Если Не ЗначениеЗаполнено(Текст) Тогда
		Текст = НСтр("ru = 'Произошла ошибка (нет текста).'");
	КонецЕсли;
	
	ПоказатьПредупреждение(, Текст);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСостояниеРаспознавания(Выполняется)
	
	РаспознаваниеВыполняется = Выполняется;
	Если Элементы.Найти("РаспознатьДокументыКнопка") <> Неопределено Тогда
		Элементы.РаспознатьДокументыКнопка.Доступность = Не Выполняется;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Функция МаксимальноеКоличествоФайлов()
	Возврат 10;
КонецФункции

&НаКлиенте
Процедура ДобавитьФайлыЧерезДиалогВыбора()
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.МножественныйВыбор = Истина;
	Диалог.Заголовок = НСтр("ru = 'Выберите файлы для распознавания'");
	Диалог.Фильтр = НСтр("ru = 'Документы и изображения|*.pdf;*.jpg;*.jpeg;*.png;*.tif;*.tiff;*.bmp|Все файлы (*.*)|*.*'");
	
	Если Не Диалог.Выбрать() Тогда
		Возврат;
	КонецЕсли;
	
	МассивПутей = ВыбранныеПутиИзДиалога(Диалог);
	
	Для Каждого ПолныйПуть Из МассивПутей Цикл
		
		Если СписокДокументов.Количество() >= МаксимальноеКоличествоФайлов() Тогда
			ПоказатьПредупреждение(, СтрШаблон(
				НСтр("ru = 'Достигнут лимит: не более %1 файлов. Часть файлов не добавлена.'"),
				МаксимальноеКоличествоФайлов()));
			Прервать;
		КонецЕсли;
		
		ФайлНаДиске = Новый Файл(ПолныйПуть);
		Если Не ФайлНаДиске.Существует() Тогда
			Продолжить;
		КонецЕсли;
		
		АдресХранилища = ПоместитьФайлСДискаНаСервер(ПолныйПуть);
		Если Не ЗначениеЗаполнено(АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		ДобавитьСтрокуПрикрепленногоФайла(ФайлНаДиске.Имя, АдресХранилища, ФайлНаДиске.Размер());
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ВыбранныеПутиИзДиалога(Диалог)
	
	МассивПутей = Новый Массив;
	
	// У ДиалогВыбораФайла нет Количество() — список путей в ВыбранныеФайлы или ПолноеИмяФайла.
	Если Диалог.МножественныйВыбор Тогда
		ВыбранныеФайлы = Диалог.ВыбранныеФайлы;
		Если ТипЗнч(ВыбранныеФайлы) = Тип("Массив") Тогда
			Для Каждого Путь Из ВыбранныеФайлы Цикл
				Если ЗначениеЗаполнено(Путь) Тогда
					МассивПутей.Добавить(Путь);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Если МассивПутей.Количество() = 0 И ЗначениеЗаполнено(Диалог.ПолноеИмяФайла) Тогда
		МассивПутей.Добавить(Диалог.ПолноеИмяФайла);
	КонецЕсли;
	
	Возврат МассивПутей;
	
КонецФункции

&НаКлиенте
Процедура ПослеПомещенияФайла(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если Не Результат Или Не ЗначениеЗаполнено(Адрес) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяФайла = ИмяФайлаИзПолногоПути(ВыбранноеИмяФайла);
	ДобавитьСтрокуПрикрепленногоФайла(ИмяФайла, Адрес, 0);
	
КонецПроцедуры

&НаКлиенте
Функция ПоместитьФайлСДискаНаСервер(ПолныйПуть)
	
	// ПоместитьФайл: 2-й параметр — путь (строка). ПоместитьФайлы ожидает другой тип 2-го параметра.
	АдресХранилища = "";
	Если ПоместитьФайл(АдресХранилища, ПолныйПуть, , Ложь, УникальныйИдентификатор) Тогда
		Возврат АдресХранилища;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаКлиенте
Процедура ДобавитьСтрокуПрикрепленногоФайла(ИмяФайла, АдресХранилища, РазмерБайт)
	
	Если Не ЗначениеЗаполнено(АдресХранилища) Тогда
		Возврат;
	КонецЕсли;
	
	Если НайтиФайлВТаблице(ИмяФайла, АдресХранилища) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = СписокДокументов.Добавить();
	НоваяСтрока.ИмяФайла = ИмяФайла;
	НоваяСтрока.АдресХранилища = АдресХранилища;
	НоваяСтрока.ИдентификаторФайла = Строка(Новый УникальныйИдентификатор);
	
	Если РазмерБайт > 0 Тогда
		НоваяСтрока.РазмерКб = Окр(РазмерБайт / 1024, 3);
	КонецЕсли;
	
	НоваяСтрока.ДатаЗагрузки = ТекущаяДата();
	НоваяСтрока.ПредставлениеДокумента = ИмяФайла;
	НоваяСтрока.СоответствуетОтбору = Истина;
	УстановитьКодСтатусаСтрокиНаКлиенте(НоваяСтрока, "Новый");
	ОбновитьСчетчикиСтатусовНаСервере();
	ПрименитьОтборСпискаДокументов();
	СохранитьРеестрДокументовНаСервере();
	
КонецПроцедуры

&НаКлиенте
Функция ИмяФайлаИзПолногоПути(ПолныйПуть)
	
	ИмяФайла = ПолныйПуть;
	Позиция = СтрНайти(ИмяФайла, "\", НаправлениеПоиска.СКонца);
	Если Позиция = 0 Тогда
		Позиция = СтрНайти(ИмяФайла, "/", НаправлениеПоиска.СКонца);
	КонецЕсли;
	
	Если Позиция > 0 Тогда
		ИмяФайла = Сред(ИмяФайла, Позиция + 1);
	КонецЕсли;
	
	Возврат ИмяФайла;
	
КонецФункции

&НаКлиенте
Процедура УстановитьСтатусПрикрепленногоФайла(КлючФайла, Статус)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Если СтрокаФайла.ИдентификаторФайла = КлючФайла
			Или СтрокаФайла.АдресХранилища = КлючФайла
			Или СтрокаФайла.ИмяФайла = КлючФайла Тогда
			СтрокаФайла.Статус = Статус;
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция НайтиФайлВТаблице(ИмяФайла, АдресХранилища)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Если СтрокаФайла.АдресХранилища = АдресХранилища
			Или СтрокаФайла.ИмяФайла = ИмяФайла Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьРезультатРаспознавания(РезультатОтправки)
	
	Если РезультатОтправки = Неопределено Тогда
		РезультатРаспознавания = НСтр("ru = 'Не получен ответ сервера.'");
		Возврат;
	КонецЕсли;
	
	Если РезультатОтправки.Свойство("СтатусыФайлов") Тогда
		Для Каждого ЭлементСтатуса Из РезультатОтправки.СтатусыФайлов Цикл
			// "бейджи" статусов (текстовые маркеры)
			Статус = Строка(ЭлементСтатуса.Значение);
			Если НРег(СокрЛП(Статус)) = НРег(НСтр("ru='Распознан'")) Тогда
				Статус = "[OK] " + Статус;
		ИначеЕсли Лев(НРег(СокрЛП(Статус)), СтрДлина(НРег(НСтр("ru='Дубликат документа'")))) = НРег(НСтр("ru='Дубликат документа'")) Тогда
			Статус = "[WARN] " + Статус;
			ИначеЕсли НРег(СокрЛП(Статус)) = НРег(НСтр("ru='Отправка...'")) Тогда
				Статус = "[...] " + Статус;
			ИначеЕсли Не ПустаяСтрока(Статус) Тогда
				Статус = "[ERR] " + Статус;
			КонецЕсли;
			УстановитьСтатусПрикрепленногоФайла(ЭлементСтатуса.Ключ, Статус);
		КонецЦикла;
		ОбновитьКодыСтатусовПоТекстуНаСервере();
	КонецЕсли;
	
	Если РезультатОтправки.Свойство("РезультатыСохраненыНаСервере")
		И РезультатОтправки.РезультатыСохраненыНаСервере Тогда
		ПрименитьСохраненныеРезультатыРаспознаванияНаКлиенте(РезультатОтправки);
	ИначеЕсли РезультатОтправки.Свойство("РезультатыФайлов") Тогда
		// Устаревший путь: только обновление UI по ключам, без передачи соответствия на сервер.
		ПрименитьСохраненныеРезультатыРаспознаванияНаКлиенте(РезультатОтправки);
	КонецЕсли;
	
	Успех = Ложь;
	Если РезультатОтправки.Свойство("Успех") Тогда
		Успех = РезультатОтправки.Успех;
	КонецЕсли;
	
	Если Успех Тогда
		ТекстДляПользователя = ЗначениеПоляРезультатаОтправки(РезультатОтправки, "ТекстДляПользователя", "");
		Если ЗначениеЗаполнено(ТекстДляПользователя) Тогда
			РезультатРаспознавания = ТекстДляПользователя;
		Иначе
			РезультатРаспознавания = ЗначениеПоляРезультатаОтправки(РезультатОтправки, "ТелоОтвета", "");
		КонецЕсли;
		
		Если РезультатОтправки.Свойство("ТоварыРаспознавания") Тогда
			ДокументJSON = Неопределено;
			Если РезультатОтправки.Свойство("ДокументРаспознавания") Тогда
				ДокументJSON = РезультатОтправки.ДокументРаспознавания;
			КонецЕсли;
			ЗаполнитьРаспознанныеДанныеНаСервере(РезультатОтправки.ТоварыРаспознавания, ДокументJSON);
			
			КоличествоНеСопоставленных = КоличествоНесопоставленныхПозиции();
			Если КоличествоНеСопоставленных > 0 Тогда
				РезультатРаспознавания = РезультатРаспознавания + Символы.ПС + СтрШаблон(
					НСтр("ru='Требует ручного сопоставления: %1 поз.'"),
					Формат(КоличествоНеСопоставленных, "ЧГ=0"));
			КонецЕсли;
		КонецЕсли;
		
		КоличествоДублей = 0;
		Если РезультатОтправки.Свойство("ДублиДокументов") 
			И ТипЗнч(РезультатОтправки.ДублиДокументов) = Тип("Соответствие") Тогда
			КоличествоДублей = РезультатОтправки.ДублиДокументов.Количество();
		КонецЕсли;
		
		Если КоличествоДублей > 0 Тогда
			РезультатРаспознавания = РезультатРаспознавания + Символы.ПС + СтрШаблон(
				НСтр("ru='Найдены возможные дубли документов: %1 файл(ов).'"),
				Формат(КоличествоДублей, "ЧГ=0"));
			ПоказатьПредупреждение(, НСтр("ru='Часть файлов помечена как дубликаты документа. Проверьте статусы перед дальнейшей обработкой.'"));
		КонецЕсли;
		
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Распознавание'"),
			,
			СтрШаблон(
				НСтр("ru = 'Загружено строк: %1'"),
				РаспознаннаяНоменклатура.Количество()));
	Иначе
		ТекстОшибки = ЗначениеПоляРезультатаОтправки(РезультатОтправки, "ОписаниеОшибки", "");
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = НСтр("ru = 'Ошибка распознавания.'");
		КонецЕсли;
		ТелоОтвета = ЗначениеПоляРезультатаОтправки(РезультатОтправки, "ТелоОтвета", "");
		Если ЗначениеЗаполнено(ТелоОтвета) Тогда
			ТекстОшибки = ТекстОшибки + Символы.ПС + ТелоОтвета;
		КонецЕсли;
		РезультатРаспознавания = ТекстОшибки;
		ПоказатьПредупреждение(, ТекстОшибки);
	КонецЕсли;
	
	ОбновитьСчетчикиСтатусовНаСервере();
	ПрименитьОтборСпискаДокументов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьСохраненныеРезультатыРаспознаванияНаКлиенте(РезультатОтправки)
	
	Если РезультатОтправки.Свойство("КлючиРезультатовФайлов")
		И ТипЗнч(РезультатОтправки.КлючиРезультатовФайлов) = Тип("Массив") Тогда
		Для Каждого КлючФайла Из РезультатОтправки.КлючиРезультатовФайлов Цикл
			УстановитьАдресРезультатаПрикрепленногоФайла(КлючФайла, КлючФайла);
		КонецЦикла;
	ИначеЕсли РезультатОтправки.Свойство("РезультатыФайлов")
		И ТипЗнч(РезультатОтправки.РезультатыФайлов) = Тип("Соответствие") Тогда
		Для Каждого ЭлементРезультата Из РезультатОтправки.РезультатыФайлов Цикл
			УстановитьАдресРезультатаПрикрепленногоФайла(ЭлементРезультата.Ключ, ЭлементРезультата.Ключ);
		КонецЦикла;
	Иначе
		Возврат;
	КонецЕсли;
	
	ЗапуститьАвтопоказРезультата();
	ОбновитьПоляСтрокДокументовПоРезультатамНаСервере();
	
КонецПроцедуры

&НаКлиенте
Функция КоличествоНесопоставленныхПозиции()
	
	Счетчик = 0;
	
	Для Каждого СтрокаНоменклатуры Из РаспознаннаяНоменклатура Цикл
		Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Счетчик = Счетчик + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Счетчик;
	
КонецФункции

&НаКлиенте
Процедура ПоказатьСыройОтвет(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите файл в списке.'"));
		Возврат;
	КонецЕсли;
	
	Ключ = ТекущиеДанные.АдресРезультатаРаспознавания;
	Если Не ЗначениеЗаполнено(Ключ) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для этого файла нет результата.'"));
		Возврат;
	КонецЕсли;
	
	ПоказатьСыройОтветНаСервере(Ключ);
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьФизЛицо(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите файл в списке.'"));
		Возврат;
	КонецЕсли;
	
	Ключ = ТекущиеДанные.АдресРезультатаРаспознавания;
	Если Не ЗначениеЗаполнено(Ключ) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для этого файла нет результата распознавания.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		Результат = СоздатьФизЛицоПоПаспортуНаСервере(Ключ);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		РезультатРаспознавания = ТекстОшибки;
		ПоказатьПредупреждение(, ТекстОшибки);
		Возврат;
	КонецПопытки;
	
	Если Результат <> Неопределено И ТипЗнч(Результат) = Тип("Структура") Тогда
		Текст = ?(Результат.Свойство("Сообщение"), Результат.Сообщение, "");
		Если ЗначениеЗаполнено(Текст) Тогда
			РезультатРаспознавания = Текст;
			ПоказатьОповещениеПользователя(НСтр("ru='Физлицо'"), , Текст);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьФизЛицоПоПаспортуНаСервере(КлючФайла)
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	Результат.Вставить("ФизЛицо", Справочники.ФизическиеЛица.ПустаяСсылка());
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		Результат.Сообщение = НСтр("ru='Нет сохранённых результатов распознавания.'");
		Возврат Результат;
	КонецЕсли;
	
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Или ТипЗнч(СоответствиеРезультатов) <> Тип("Соответствие") Тогда
		Результат.Сообщение = НСтр("ru='Результаты недоступны.'");
		Возврат Результат;
	КонецЕсли;
	
	ДанныеФайла = СоответствиеРезультатов.Получить(КлючФайла);
	Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
		Результат.Сообщение = НСтр("ru='Результат для выбранного файла не найден.'");
		Возврат Результат;
	КонецЕсли;
	
	Паспорт = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
	Если Паспорт = Неопределено Или ТипЗнч(Паспорт) <> Тип("Структура") Тогда
		Результат.Сообщение = НСтр("ru='В результате нет паспортных данных.'");
		Возврат Результат;
	КонецЕсли;
	
	ФизЛицо = НайтиФизЛицоПоПаспорту(Паспорт);
	Если ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
		ФизЛицо = СоздатьЭлементФизЛица(Паспорт);
	КонецЕсли;
	
	Если ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка() Тогда
		Результат.Сообщение = НСтр("ru='Не удалось создать/найти физлицо.'");
		Возврат Результат;
	КонецЕсли;
	
	ЗаписатьРегистрФИОФизЛиц(ФизЛицо, Паспорт);
	ЗаписатьРегистрПаспортаФизЛиц(ФизЛицо, Паспорт);
	
	Результат.Успех = Истина;
	Результат.ФизЛицо = ФизЛицо;
	Результат.Сообщение = СтрШаблон(НСтр("ru='Физлицо создано/обновлено: %1'"), Строка(ФизЛицо));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция СоздатьЭлементФизЛица(Паспорт)
	
	Попытка
		Элемент = Справочники.ФизическиеЛица.СоздатьЭлемент();
	Исключение
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецПопытки;
	
	Фамилия = ?(Паспорт.Свойство("фамилия"), Паспорт.фамилия, "");
	Имя = ?(Паспорт.Свойство("имя"), Паспорт.имя, "");
	Отчество = ?(Паспорт.Свойство("отчество"), Паспорт.отчество, "");
	
	Наименование = СокрЛП(СтрЗаменить(Строка(Фамилия) + " " + Строка(Имя) + " " + Строка(Отчество), "  ", " "));
	Если ЗначениеЗаполнено(Наименование) Тогда
		Попытка
			Элемент.Наименование = Наименование;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Элемент.Записать();
		Возврат Элемент.Ссылка;
	Исключение
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция НайтиФизЛицоПоПаспорту(Паспорт)
	
	Серия = СокрЛП(?(Паспорт.Свойство("серия"), Строка(Паспорт.серия), ""));
	Номер = СокрЛП(?(Паспорт.Свойство("номер"), Строка(Паспорт.номер), ""));
	Если ПустаяСтрока(Серия) Или ПустаяСтрока(Номер) Тогда
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Паспорт.ФизЛицо КАК ФизЛицо
		|ИЗ
		|	РегистрСведений.УдалитьПаспортныеДанныеФизЛиц КАК Паспорт
		|ГДЕ
		|	Паспорт.ДокументСерия = &Серия
		|	И Паспорт.ДокументНомер = &Номер";
	Запрос.УстановитьПараметр("Серия", Серия);
	Запрос.УстановитьПараметр("Номер", Номер);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.ФизЛицо;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	
КонецФункции

&НаСервере
Процедура ЗаписатьРегистрФИОФизЛиц(ФизЛицо, Паспорт)
	
	Набор = РегистрыСведений.ФИОФизическихЛиц.СоздатьНаборЗаписей();
	Набор.Отбор.ФизическоеЛицо.Установить(ФизЛицо);
	Набор.Прочитать();
	
	Запись = Набор.Добавить();
	Запись.Период = ТекущаяДата();
	Запись.ФизическоеЛицо = ФизЛицо;
	
	Запись.Фамилия = ?(Паспорт.Свойство("фамилия"), Паспорт.фамилия, "");
	Запись.Имя = ?(Паспорт.Свойство("имя"), Паспорт.имя, "");
	Запись.Отчество = ?(Паспорт.Свойство("отчество"), Паспорт.отчество, "");
	
	// Инициалы (простая сборка)
	Попытка
		И1 = ?(ЗначениеЗаполнено(Запись.Имя), Лев(Запись.Имя, 1), "");
		И2 = ?(ЗначениеЗаполнено(Запись.Отчество), Лев(Запись.Отчество, 1), "");
		Запись.Инициалы = СокрЛП(И1 + ?(ПустаяСтрока(И2), "", ".") + И2 + ?(ПустаяСтрока(И2), "", "."));
	Исключение
	КонецПопытки;
	
	Попытка
		Набор.Записать();
	Исключение
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьРегистрПаспортаФизЛиц(ФизЛицо, Паспорт)
	
	Набор = РегистрыСведений.УдалитьПаспортныеДанныеФизЛиц.СоздатьНаборЗаписей();
	Набор.Отбор.ФизЛицо.Установить(ФизЛицо);
	Набор.Прочитать();
	
	Запись = Набор.Добавить();
	Запись.Период = ТекущаяДата();
	Запись.ФизЛицо = ФизЛицо;
	
	// Ресурсы регистра (по скрину)
	Попытка Запись.ДокументВид = ?(Паспорт.Свойство("документВид"), Паспорт.документВид, Неопределено); Исключение КонецПопытки;
	Попытка Запись.ДокументСерия = ?(Паспорт.Свойство("серия"), Паспорт.серия, ""); Исключение КонецПопытки;
	Попытка Запись.ДокументНомер = ?(Паспорт.Свойство("номер"), Паспорт.номер, ""); Исключение КонецПопытки;
	Попытка Запись.ДокументДатаВыдачи = ?(Паспорт.Свойство("датаВыдачи"), Паспорт.датаВыдачи, Неопределено); Исключение КонецПопытки;
	Попытка Запись.ДокументКемВыдан = ?(Паспорт.Свойство("кемВыдан"), Паспорт.кемВыдан, ""); Исключение КонецПопытки;
	Попытка Запись.ДокументКодПодразделения = ?(Паспорт.Свойство("кодПодразделения"), Паспорт.кодПодразделения, ""); Исключение КонецПопытки;
	Попытка Запись.ДатаРегистрацииПоМестуЖительства = ?(Паспорт.Свойство("датаРегистрацииПоМестуЖительства"), Паспорт.датаРегистрацииПоМестуЖительства, Неопределено); Исключение КонецПопытки;
	
	Попытка
		Набор.Записать();
	Исключение
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьСыройОтветНаСервере(КлючФайла)
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		РезультатРаспознавания = НСтр("ru = 'Нет сохранённых результатов.'");
		Возврат;
	КонецЕсли;
	
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Или ТипЗнч(СоответствиеРезультатов) <> Тип("Соответствие") Тогда
		РезультатРаспознавания = НСтр("ru = 'Результаты недоступны.'");
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = СоответствиеРезультатов.Получить(КлючФайла);
	Если ДанныеФайла = Неопределено Тогда
		РезультатРаспознавания = НСтр("ru = 'Результат для файла не найден.'");
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеФайла) = Тип("Структура") И ДанныеФайла.Свойство("ТелоОтвета") Тогда
		РезультатРаспознавания = Строка(ДанныеФайла.ТелоОтвета);
	Иначе
		РезультатРаспознавания = НСтр("ru = 'Нет сырого ответа.'");
	КонецЕсли;
	
КонецПроцедуры

// Кнопки фильтра списка файлов удалены: в этой версии платформы нет поддержки отбора у элемента таблицы.

&НаКлиенте
Процедура УстановитьАдресРезультатаПрикрепленногоФайла(КлючФайла, АдресРезультата)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Если СтрокаФайла.ИдентификаторФайла = КлючФайла
			Или СтрокаФайла.АдресХранилища = КлючФайла
			Или СтрокаФайла.ИмяФайла = КлючФайла Тогда
			СтрокаФайла.АдресРезультатаРаспознавания = АдресРезультата;
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьРезультатФайла(Команда)
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Выберите файл в списке.'"));
		Возврат;
	КонецЕсли;
	
	Адрес = ТекущиеДанные.АдресРезультатаРаспознавания;
	
	Если Не ЗначениеЗаполнено(Адрес) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для этого файла нет результата распознавания.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		ПоказатьРезультатФайлаПоКлючуНаСервере(Адрес);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		РезультатРаспознавания = ТекстОшибки;
		ПоказатьПредупреждение(, ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтслеживатьВыборФайла()
	
	ТекущиеДанные = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Адрес = ТекущиеДанные.АдресРезультатаРаспознавания;
	
	Если Не ЗначениеЗаполнено(Адрес) Тогда
		Возврат;
	КонецЕсли;
	
	Если Адрес = ПоследнийАдресПоказанногоРезультата Тогда
		Возврат;
	КонецЕсли;
	
	ПоследнийАдресПоказанногоРезультата = Адрес;
	Попытка
		ПоказатьРезультатФайлаПоКлючуНаСервере(Адрес);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		РезультатРаспознавания = ТекстОшибки;
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьРезультатыФайловРаспознаванияНаСервере(РезультатыФайлов)
	
	Если РезультатыФайлов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	// При повторной отправке мы отправляем только часть файлов. Нужно сохранять результаты ранее распознанных файлов.
	ТекущиеРезультаты = Неопределено;
	Если ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		ТекущиеРезультаты = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	КонецЕсли;
	
	Если ТекущиеРезультаты = Неопределено Или ТипЗнч(ТекущиеРезультаты) <> Тип("Соответствие") Тогда
		ТекущиеРезультаты = Новый Соответствие;
	КонецЕсли;
	
	Если ТипЗнч(РезультатыФайлов) = Тип("Соответствие") Тогда
		Для Каждого Пара Из РезультатыФайлов Цикл
			// Обновляем/добавляем результат по ключу файла (без несериализуемых типов).
			ТекущиеРезультаты.Вставить(Пара.Ключ, ПодготовитьДанныеФайлаРезультатаДляХранения(Пара.Значение));
		КонецЦикла;
	КонецЕсли;
	
	РезультатыФайловРаспознавания = ПоместитьВоВременноеХранилище(ТекущиеРезультаты, Новый УникальныйИдентификатор);
	СохранитьРеестрДокументовНаСервере();
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьДанныеФайлаРезультатаДляХранения(ДанныеФайла)
	
	Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
		Возврат ДанныеФайла;
	КонецЕсли;
	
	ИменаПолей = "Успех, ОписаниеОшибки, ТекстДляПользователя, Товары, Документ, Метаданные, ТелоОтвета, КодОтвета, Предупреждение";
	Результат = Новый Структура;
	
	Для Каждого ИмяПоля Из СтрРазделить(ИменаПолей, ",", Ложь) Цикл
		ИмяПоля = СокрЛП(ИмяПоля);
		Если ДанныеФайла.Свойство(ИмяПоля) Тогда
			Результат.Вставить(ИмяПоля, ДанныеФайла[ИмяПоля]);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ПоказатьРезультатФайлаПоКлючуНаСервере(КлючФайла)
	
	Если Не ЗначениеЗаполнено(КлючФайла) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		РезультатРаспознавания = НСтр("ru = 'Нет сохранённых результатов распознавания по файлам. Повторите распознавание.'");
		Возврат;
	КонецЕсли;
	
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Тогда
		РезультатРаспознавания = НСтр("ru = 'Результаты распознавания по файлам недоступны (пустое хранилище значения).'"); 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(СоответствиеРезультатов) <> Тип("Соответствие") Тогда
		РезультатРаспознавания = НСтр("ru = 'Результаты распознавания по файлам имеют неожиданный тип.'"); 
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = СоответствиеРезультатов.Получить(КлючФайла);
	Если ДанныеФайла = Неопределено Тогда
		РезультатРаспознавания = СтрШаблон(
			НСтр("ru = 'Для выбранного файла не найден результат. Ключ: %1. Доступно ключей: %2'"),
			КлючФайла,
			Формат(СоответствиеРезультатов.Количество(), "ЧГ=0"));
		Возврат;
	КонецЕсли;
	
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	КлючДеталейДокумента = КлючФайла;
	ПоказатьРезультатФайлаНаСервере(ДанныеФайла);
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	СохранитьРеестрДокументовНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьАвтопоказРезультата()
	
	Если АвтопоказРезультатаЗапущен Тогда
		Возврат;
	КонецЕсли;
	
	АвтопоказРезультатаЗапущен = Истина;
	ПодключитьОбработчикОжидания("ОтслеживатьВыборФайла", 1, Истина);
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьРезультатФайлаНаСервере(ДанныеФайла)
	
	Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
		РезультатРаспознавания = НСтр("ru = 'Результат файла не найден.'");
		Возврат;
	КонецЕсли;
	
	Товары = ?(ДанныеФайла.Свойство("Товары"), ДанныеФайла.Товары, Неопределено);
	ДокументJSON = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
	Текст = ?(ДанныеФайла.Свойство("ТекстДляПользователя"), ДанныеФайла.ТекстДляПользователя, "");
	ОписаниеОшибки = ?(ДанныеФайла.Свойство("ОписаниеОшибки"), ДанныеФайла.ОписаниеОшибки, "");
	ТелоОтвета = ?(ДанныеФайла.Свойство("ТелоОтвета"), ДанныеФайла.ТелоОтвета, "");
	УспехФайла = ?(ДанныеФайла.Свойство("Успех"), ДанныеФайла.Успех, Ложь);
	
	Если УспехФайла Тогда
		Если ЗначениеЗаполнено(Текст) Тогда
			РезультатРаспознавания = Текст;
		Иначе
			РезультатРаспознавания = НСтр("ru = 'Распознано.'");
		КонецЕсли;
	Иначе
		ТекстОшибки = ?(ПустаяСтрока(ОписаниеОшибки), НСтр("ru = 'Ошибка распознавания файла.'"), ОписаниеОшибки);
		Если ЗначениеЗаполнено(ТелоОтвета) Тогда
			ТекстОшибки = ТекстОшибки + Символы.ПС + ТелоОтвета;
		КонецЕсли;
		РезультатРаспознавания = ТекстОшибки;
	КонецЕсли;
	
	Если УспехФайла Тогда
		ПрименитьДанныеФайлаКФормеРаспознаванияНаСервере(ДанныеФайла);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ЗначениеПоляРезультатаОтправки(РезультатОтправки, ИмяПоля, ЗначениеПоУмолчанию)
	
	Если ТипЗнч(РезультатОтправки) <> Тип("Структура") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если РезультатОтправки.Свойство(ИмяПоля) Тогда
		Возврат РезультатОтправки[ИмяПоля];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

&НаСервере
Функция НачатьОтправкуРаспознаванияНаСервере(ОтправлятьДублиДокументов = Ложь)
	
	РезультатЗапуска = Новый Структура;
	РезультатЗапуска.Вставить("СинхронныйРежим", Ложь);
	РезультатЗапуска.Вставить("ИдентификаторЗадания", Неопределено);
	РезультатЗапуска.Вставить("АдресРезультата", "");
	РезультатЗапуска.Вставить("РезультатОтправки", Неопределено);
	
	// Вариант A: выполняем распознавание одним запросом до финального результата.
	// Если задан URL статуса — пробуем асинхронную постановку в очередь.
	ПараметрыОтправки = ПодготовитьПараметрыОтправкиРаспознавания(ОтправлятьДублиДокументов);
	
	ТаблицаКОтправке = ПолучитьИзВременногоХранилища(ПараметрыОтправки.АдресТаблицыФайлов);
	Если ТаблицаКОтправке = Неопределено Или ТаблицаКОтправке.Количество() = 0 Тогда
		ТекстОшибки = РезультатРаспознавания;
		Если ПустаяСтрока(ТекстОшибки) Тогда
			ТекстОшибки = НСтр("ru = 'Нет файлов для отправки на распознавание.'");
		КонецЕсли;
		РезультатЗапуска.СинхронныйРежим = Истина;
		РезультатЗапуска.РезультатОтправки = СоздатьРезультатОтправкиОшибки(ТекстОшибки);
		Возврат РезультатЗапуска;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресAPIСтатусаРаспознавания) Тогда
		РезультатОчереди = ПопробоватьПоставитьВОчередьРаспознавания(ПараметрыОтправки);
		Если РезультатОчереди <> Неопределено Тогда
			РезультатЗапуска.СинхронныйРежим = Ложь;
			РезультатЗапуска.ИдентификаторЗадания = РезультатОчереди.JobId;
			Возврат РезультатЗапуска;
		КонецЕсли;
	КонецЕсли;
	
	РезультатHTTP = ВыполнитьОтправкуРаспознаванияПоПараметрам(ПараметрыОтправки);
	
	Если РезультатHTTP <> Неопределено
		И РезультатHTTP.Свойство("РезультатыФайлов")
		И ТипЗнч(РезультатHTTP.РезультатыФайлов) = Тип("Соответствие") Тогда
		СохранитьРезультатыФайловРаспознаванияНаСервере(РезультатHTTP.РезультатыФайлов);
	КонецЕсли;
	
	РезультатЗапуска.СинхронныйРежим = Истина;
	РезультатЗапуска.РезультатОтправки = СформироватьРезультатОтправкиДляФормы(РезультатHTTP);
	РезультатЗапуска.АдресРезультата = "";
	
	Возврат РезультатЗапуска;
	
КонецФункции

// Точка входа фонового задания для внешней обработки.
// Делать именно в модуле формы — в некоторых конфигурациях платформа не видит методы фоновых заданий в модуле объекта внешней обработки.
&НаСервере
Процедура ВыполнитьОтправкуНаРаспознаваниеФон(ПараметрыФона) Экспорт
	
	ПараметрыОтправки = ПолучитьИзВременногоХранилища(ПараметрыФона.АдресПараметров);
	Если ПараметрыОтправки = Неопределено Тогда
		ПоместитьВоВременноеХранилище(
			СоздатьРезультатОтправкиОшибки(НСтр("ru = 'Не найдены параметры распознавания во временном хранилище.'")),
			ПараметрыФона.АдресРезультата);
		Возврат;
	КонецЕсли;
	
	РезультатHTTP = ВыполнитьОтправкуРаспознаванияПоПараметрам(ПараметрыОтправки);
	ПоместитьВоВременноеХранилище(РезультатHTTP, ПараметрыФона.АдресРезультата);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСостояниеРаспознаванияНаСервере()
	// Не используется в варианте A.
	Состояние = Новый Структура;
	Состояние.Вставить("Выполняется", Ложь);
	Состояние.Вставить("РезультатОтправки", Неопределено);
	Возврат Состояние;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПараметрыAPIРаспознаванияНаСервере()
	
	ПараметрыAPI = Обработки.Распознавание_Высота.Создать().ПолучитьПараметрыПодключенияAPIРаспознавания();
	
	Если ЗначениеЗаполнено(ПараметрыAPI.АдресAPI) Тогда
		АдресAPIРаспознавания = ПараметрыAPI.АдресAPI;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыAPI.ТокенAPI) Тогда
		ТокенAPIРаспознавания = ПараметрыAPI.ТокенAPI;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыAPI.АдресAPIСтатуса) Тогда
		АдресAPIСтатусаРаспознавания = ПараметрыAPI.АдресAPIСтатуса;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьПараметрыОтправкиРаспознавания(ОтправлятьДублиДокументов = Ложь)
	
	ПараметрыЗапроса = Новый Структура;
	Если ЗначениеЗаполнено(Документ) Тогда
		ПараметрыЗапроса.Вставить("document_id", XMLСтрока(Документ));
		ПараметрыЗапроса.Вставить("document", Строка(Документ));
	КонецЕсли;
	ПараметрыЗапроса.Вставить("nomenclature_search_algorithm", ПолучитьАлгоритмПоискаНоменклатуры());
	
	ПараметрыОтправки = Новый Структура;
	ПараметрыОтправки.Вставить("АдресAPI", АдресAPIРаспознавания);
	ПараметрыОтправки.Вставить("ТокенAPI", ТокенAPIРаспознавания);
	
	// Отправляем повторно только те файлы, которые ещё не распознаны.
	ТаблицаВсехФайлов = СписокДокументов.Выгрузить();
	ТаблицаКОтправке = ТаблицаВсехФайлов.Скопировать();
	ТаблицаКОтправке.Очистить();
	ОтпечаткиФайлов = Новый Соответствие;
	
	Для Каждого СтрокаФайла Из ТаблицаВсехФайлов Цикл
		Статус = "";
		Если ТаблицаВсехФайлов.Колонки.Найти("Статус") <> Неопределено Тогда
			Статус = СокрЛП(Строка(СтрокаФайла.Статус));
		КонецЕсли;
		
		Если Найти(НРег(Статус), НРег(НСтр("ru = 'Распознан'"))) > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Найти(НРег(Статус), НРег(НСтр("ru = 'Пропущен пользователем'"))) > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Найти(НРег(Статус), НРег(НСтр("ru = 'Дубликат документа (пропущен)'"))) > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Найти(НРег(Статус), НРег(НСтр("ru = 'Готов к отправке'"))) = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ЭтоДубликатДокумента = Найти(НРег(Статус), НРег(НСтр("ru = 'Дубликат документа'"))) > 0;
		Если ЭтоДубликатДокумента И Не ОтправлятьДублиДокументов Тогда
			ОбновитьСтатусФайлаПередОтправкой(
				СтрокаФайла.ИдентификаторФайла,
				СтрокаФайла.АдресХранилища,
				СтрокаФайла.ИмяФайла,
				НСтр("ru = 'Дубликат документа (пропущен)'"));
			Продолжить;
		КонецЕсли;
		
		ОтпечатокФайла = "";
		Если Не ОтправлятьДублиДокументов Тогда
			ОтпечатокФайла = СформироватьОтпечатокФайла(СтрокаФайла.АдресХранилища, СтрокаФайла.ИмяФайла);
			Если ЗначениеЗаполнено(ОтпечатокФайла) И ОтпечаткиФайлов.Получить(ОтпечатокФайла) <> Неопределено Тогда
				ОбновитьСтатусФайлаПередОтправкой(
					СтрокаФайла.ИдентификаторФайла,
					СтрокаФайла.АдресХранилища,
					СтрокаФайла.ИмяФайла,
					НСтр("ru = 'Дубликат в текущей отправке (пропущен)'"));
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОтпечатокФайла) Тогда
			ОтпечаткиФайлов.Вставить(ОтпечатокФайла, Истина);
		КонецЕсли;
		
		НоваяСтрока = ТаблицаКОтправке.Добавить();
		НоваяСтрока.ИмяФайла = СтрокаФайла.ИмяФайла;
		НоваяСтрока.АдресХранилища = СтрокаФайла.АдресХранилища;
		Если ТаблицаКОтправке.Колонки.Найти("ИдентификаторФайла") <> Неопределено
			И ТаблицаВсехФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
			НоваяСтрока.ИдентификаторФайла = СтрокаФайла.ИдентификаторФайла;
		КонецЕсли;
		
		Если ТаблицаКОтправке.Колонки.Найти("РазмерКб") <> Неопределено
			И ТаблицаВсехФайлов.Колонки.Найти("РазмерКб") <> Неопределено Тогда
			НоваяСтрока.РазмерКб = СтрокаФайла.РазмерКб;
		КонецЕсли;
		
		ОбновитьСтатусФайлаПередОтправкой(
			СтрокаФайла.ИдентификаторФайла,
			СтрокаФайла.АдресХранилища,
			СтрокаФайла.ИмяФайла,
			НСтр("ru = 'Готов к отправке'"),
			"НаРаспознавании");
	КонецЦикла;
	
	Если ТаблицаКОтправке.Количество() = 0 Тогда
		Если ОтправлятьДублиДокументов Тогда
			РезультатРаспознавания = НСтр("ru = 'Нет файлов для отправки: все файлы уже распознаны.'");
		Иначе
			РезультатРаспознавания = НСтр("ru = 'Новых файлов для отправки нет: все распознаны или отфильтрованы как дубликаты.'");
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыОтправки.Вставить("АдресТаблицыФайлов",
		ПоместитьВоВременноеХранилище(ТаблицаКОтправке, УникальныйИдентификатор));
	ПараметрыОтправки.Вставить("ПараметрыЗапроса", ПараметрыЗапроса);
	
	Возврат ПараметрыОтправки;
	
КонецФункции

&НаСервере
Процедура ОбновитьСтатусФайлаПередОтправкой(КлючИД, КлючАдрес, КлючИмя, НовыйСтатус, КодСтатуса = "")
	
	Для Каждого ФайлФормы Из СписокДокументов Цикл
		Если (ЗначениеЗаполнено(КлючИД) И ФайлФормы.ИдентификаторФайла = КлючИД)
			Или (ЗначениеЗаполнено(КлючАдрес) И ФайлФормы.АдресХранилища = КлючАдрес)
			Или (ЗначениеЗаполнено(КлючИмя) И ФайлФормы.ИмяФайла = КлючИмя) Тогда
			ФайлФормы.Статус = НовыйСтатус;
			Если ЗначениеЗаполнено(КодСтатуса) Тогда
				УстановитьКодСтатусаСтроки(ФайлФормы, КодСтатуса);
			КонецЕсли;
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция СформироватьОтпечатокФайла(АдресХранилища, ИмяФайла)
	
	Если Не ЗначениеЗаполнено(АдресХранилища) Тогда
		Возврат "";
	КонецЕсли;
	
	Данные = ПолучитьИзВременногоХранилища(АдресХранилища);
	Если Данные = Неопределено Тогда
		Возврат Строка(АдресХранилища);
	КонецЕсли;
	
	Base64 = Base64Строка(Данные);
	Префикс = Лев(Base64, 256);
	Суффикс = "";
	Если СтрДлина(Base64) > 64 Тогда
		Суффикс = Сред(Base64, СтрДлина(Base64) - 63);
	Иначе
		Суффикс = Base64;
	КонецЕсли;
	
	Возврат СтрШаблон("%1|%2|%3|%4", Строка(Данные.Размер()), Префикс, Суффикс, СокрЛП(НРег(ИмяФайла)));
	
КонецФункции

&НаСервере
Функция ТекстОшибкиРезультатаФайла(ДанныеФайла, РезультатФайла)
	
	ТекстОшибки = "";
	Если ДанныеФайла <> Неопределено И ТипЗнч(ДанныеФайла) = Тип("Структура") Тогда
		Если ДанныеФайла.Свойство("ОписаниеОшибки") Тогда
			ТекстОшибки = СокрЛП(Строка(ДанныеФайла.ОписаниеОшибки));
		КонецЕсли;
		Если ПустаяСтрока(ТекстОшибки) И ДанныеФайла.Свойство("ТекстДляПользователя") Тогда
			ТекстОшибки = СокрЛП(Строка(ДанныеФайла.ТекстДляПользователя));
		КонецЕсли;
	КонецЕсли;
	
	КодОтвета = 0;
	Если РезультатФайла <> Неопределено
		И ТипЗнч(РезультатФайла) = Тип("Структура")
		И РезультатФайла.Свойство("КодОтвета") Тогда
		КодОтвета = РезультатФайла.КодОтвета;
	ИначеЕсли ДанныеФайла <> Неопределено
		И ТипЗнч(ДанныеФайла) = Тип("Структура")
		И ДанныеФайла.Свойство("КодОтвета") Тогда
		КодОтвета = ДанныеФайла.КодОтвета;
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстОшибки) И КодОтвета > 0 Тогда
		ТекстОшибки = СтрШаблон(НСтр("ru = 'HTTP %1'"), Формат(КодОтвета, "ЧГ=0"));
	КонецЕсли;
	
	Если ПустаяСтрока(ТекстОшибки) Тогда
		ТекстОшибки = НСтр("ru = 'Ошибка распознавания.'");
	КонецЕсли;
	
	Возврат ТекстОшибки;
	
КонецФункции

&НаСервере
Функция СформироватьСводнуюОшибкуРаспознавания(СтатусыФайлов, РезультатыФайлов)
	
	Если СтатусыФайлов <> Неопределено И ТипЗнч(СтатусыФайлов) = Тип("Соответствие") Тогда
		Для Каждого ЭлементСтатуса Из СтатусыФайлов Цикл
			Текст = СокрЛП(Строка(ЭлементСтатуса.Значение));
			Если ЗначениеЗаполнено(Текст)
				И НРег(Текст) <> НРег(НСтр("ru = 'Распознан'"))
				И НРег(Текст) <> НРег(НСтр("ru = 'Ошибка'")) Тогда
				Возврат Текст;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если РезультатыФайлов <> Неопределено И ТипЗнч(РезультатыФайлов) = Тип("Соответствие") Тогда
		Для Каждого ЭлементРезультата Из РезультатыФайлов Цикл
			ДанныеФайла = ЭлементРезультата.Значение;
			Если ДанныеФайла <> Неопределено
				И ТипЗнч(ДанныеФайла) = Тип("Структура")
				И ДанныеФайла.Свойство("Успех")
				И Не ДанныеФайла.Успех Тогда
				Возврат ТекстОшибкиРезультатаФайла(ДанныеФайла, ДанныеФайла);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат НСтр("ru = 'Не удалось распознать ни один файл.'");
	
КонецФункции

&НаСервере
Функция ТелоОтветаПервойОшибкиРаспознавания(РезультатыФайлов)
	
	Если РезультатыФайлов = Неопределено Или ТипЗнч(РезультатыФайлов) <> Тип("Соответствие") Тогда
		Возврат "";
	КонецЕсли;
	
	Для Каждого ЭлементРезультата Из РезультатыФайлов Цикл
		ДанныеФайла = ЭлементРезультата.Значение;
		Если ДанныеФайла <> Неопределено
			И ТипЗнч(ДанныеФайла) = Тип("Структура")
			И ДанныеФайла.Свойство("Успех")
			И Не ДанныеФайла.Успех
			И ДанныеФайла.Свойство("ТелоОтвета") Тогда
			Возврат Строка(ДанныеФайла.ТелоОтвета);
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ВыполнитьОтправкуРаспознаванияПоПараметрам(ПараметрыОтправки)
	
	ТаблицаФайлов = ПолучитьИзВременногоХранилища(ПараметрыОтправки.АдресТаблицыФайлов);
	Значение = РеквизитФормыВЗначение("Объект");
	
	// Распознаём каждый файл отдельно, чтобы в UI были видны результаты по файлам.
	РезультатыФайлов = Новый Соответствие;
	СтатусыФайлов = Новый Соответствие;
	
	ЕстьУспешные = Ложь;
	ПервыйУспешныйРезультат = Неопределено;
	
	Если ТаблицаФайлов = Неопределено Или ТаблицаФайлов.Количество() = 0 Тогда
		Возврат СоздатьРезультатОтправкиОшибки(
			НСтр("ru = 'Нет файлов для отправки на распознавание.'"));
	КонецЕсли;
	
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаФайла.АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		ТаблицаОдинФайл = ТаблицаФайлов.Скопировать();
		ТаблицаОдинФайл.Очистить();
		
		СтрокаОдин = ТаблицаОдинФайл.Добавить();
		СтрокаОдин.ИмяФайла = СтрокаФайла.ИмяФайла;
		СтрокаОдин.АдресХранилища = СтрокаФайла.АдресХранилища;
		
		Если ТаблицаОдинФайл.Колонки.Найти("РазмерКб") <> Неопределено
			И ТаблицаФайлов.Колонки.Найти("РазмерКб") <> Неопределено Тогда
			СтрокаОдин.РазмерКб = СтрокаФайла.РазмерКб;
		КонецЕсли;
		
		РезультатФайла = Значение.ОтправитьФайлыНаРаспознавание(
			ПараметрыОтправки.АдресAPI,
			ПараметрыОтправки.ТокенAPI,
			ТаблицаОдинФайл,
			ПараметрыОтправки.ПараметрыЗапроса);
		
		АдресРезультатаФайла = "";
		Если РезультатФайла <> Неопределено И ТипЗнч(РезультатФайла) = Тип("Структура") Тогда
			ДанныеФайла = Новый Структура;
			ДанныеФайла.Вставить("Успех", ?(РезультатФайла.Свойство("Успех"), РезультатФайла.Успех, Ложь));
			ДанныеФайла.Вставить("ОписаниеОшибки", ?(РезультатФайла.Свойство("ОписаниеОшибки"), РезультатФайла.ОписаниеОшибки, ""));
			ДанныеФайла.Вставить("ТекстДляПользователя", ?(РезультатФайла.Свойство("ТекстДляПользователя"), РезультатФайла.ТекстДляПользователя, ""));
			ДанныеФайла.Вставить("Товары", ?(РезультатФайла.Свойство("ТоварыРаспознавания"), РезультатФайла.ТоварыРаспознавания, Неопределено));
			ДанныеФайла.Вставить("Документ", ?(РезультатФайла.Свойство("ДокументРаспознавания"), РезультатФайла.ДокументРаспознавания, Неопределено));
			ДанныеФайла.Вставить("Метаданные", ?(РезультатФайла.Свойство("МетаданныеОтвета"), РезультатФайла.МетаданныеОтвета, Новый Структура));
			ДанныеФайла.Вставить("ТелоОтвета", ?(РезультатФайла.Свойство("ТелоОтвета"), РезультатФайла.ТелоОтвета, ""));
			ДанныеФайла.Вставить("КодОтвета", ?(РезультатФайла.Свойство("КодОтвета"), РезультатФайла.КодОтвета, 0));
			
			// Чтобы в UI всегда был читаемый текст по ошибке.
			Если Не ДанныеФайла.Успех И ПустаяСтрока(ДанныеФайла.ТекстДляПользователя) Тогда
				ДанныеФайла.ТекстДляПользователя = ДанныеФайла.ОписаниеОшибки;
			КонецЕсли;
			
			КлючФайла = "";
			Если ТаблицаФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
				КлючФайла = СтрокаФайла.ИдентификаторФайла;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(КлючФайла) Тогда
				КлючФайла = СтрокаФайла.АдресХранилища;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(КлючФайла) Тогда
				КлючФайла = СтрокаФайла.ИмяФайла;
			КонецЕсли;
			
			// В фоне адреса временного хранилища могут быть недоступны форме, поэтому храним структуру прямо в результате.
			РезультатыФайлов.Вставить(КлючФайла, ДанныеФайла);
			
			Если ДанныеФайла.Успех Тогда
				СтатусыФайлов.Вставить(КлючФайла, НСтр("ru = 'Распознан'"));
				Если Не ЕстьУспешные Тогда
					ЕстьУспешные = Истина;
					ПервыйУспешныйРезультат = ДанныеФайла;
				КонецЕсли;
			Иначе
				СтатусыФайлов.Вставить(КлючФайла, ТекстОшибкиРезультатаФайла(ДанныеФайла, РезультатФайла));
			КонецЕсли;
		Иначе
			КлючФайла = "";
			Если ТаблицаФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
				КлючФайла = СтрокаФайла.ИдентификаторФайла;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(КлючФайла) Тогда
				КлючФайла = СтрокаФайла.АдресХранилища;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(КлючФайла) Тогда
				КлючФайла = СтрокаФайла.ИмяФайла;
			КонецЕсли;
			СтатусыФайлов.Вставить(КлючФайла, НСтр("ru = 'Ошибка'"));
		КонецЕсли;
		
	КонецЦикла;
	
	РезультатИтог = Новый Структура;
	РезультатИтог.Вставить("Успех", ЕстьУспешные);
	РезультатИтог.Вставить("ОписаниеОшибки", ?(ЕстьУспешные, "", СформироватьСводнуюОшибкуРаспознавания(СтатусыФайлов, РезультатыФайлов)));
	РезультатИтог.Вставить("ТелоОтвета", ТелоОтветаПервойОшибкиРаспознавания(РезультатыФайлов));
	РезультатИтог.Вставить("ТекстДляПользователя", "");
	РезультатИтог.Вставить("ТоварыРаспознавания", Неопределено);
	РезультатИтог.Вставить("ДокументРаспознавания", Неопределено);
	РезультатИтог.Вставить("РезультатыФайлов", РезультатыФайлов);
	РезультатИтог.Вставить("СтатусыФайлов", СтатусыФайлов);
	РезультатИтог.Вставить("ДублиДокументов", Новый Соответствие);
	
	ДублиДокументов = ОпределитьДублиДокументовПоРезультатам(РезультатыФайлов);
	РезультатИтог.ДублиДокументов = ДублиДокументов;
	
	Если ДублиДокументов.Количество() > 0 Тогда
		Для Каждого ПараДубля Из ДублиДокументов Цикл
			КлючФайла = ПараДубля.Ключ;
			ОписаниеДубля = Строка(ПараДубля.Значение);
			СтатусыФайлов.Вставить(КлючФайла, НСтр("ru='Дубликат документа'") + ": " + ОписаниеДубля);
			
			ДанныеФайла = РезультатыФайлов.Получить(КлючФайла);
			Если ДанныеФайла <> Неопределено И ТипЗнч(ДанныеФайла) = Тип("Структура") Тогда
				ДанныеФайла.Вставить("Предупреждение", НСтр("ru='Возможный дубликат документа'") + ": " + ОписаниеДубля);
				РезультатыФайлов.Вставить(КлючФайла, ДанныеФайла);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ПервыйУспешныйРезультат <> Неопределено Тогда
		РезультатИтог.ТекстДляПользователя = ПервыйУспешныйРезультат.ТекстДляПользователя;
		РезультатИтог.ТоварыРаспознавания = ПервыйУспешныйРезультат.Товары;
		РезультатИтог.ДокументРаспознавания = ПервыйУспешныйРезультат.Документ;
		РезультатИтог.ТелоОтвета = ПервыйУспешныйРезультат.ТелоОтвета;
	КонецЕсли;
	
	Возврат РезультатИтог;
	
КонецФункции

&НаСервере
Функция ОпределитьДублиДокументовПоРезультатам(РезультатыФайлов)
	
	Дубли = Новый Соответствие;
	Если РезультатыФайлов = Неопределено Или ТипЗнч(РезультатыФайлов) <> Тип("Соответствие") Тогда
		Возврат Дубли;
	КонецЕсли;
	
	ГруппыПоСигнатуре = Новый Соответствие;
	
	Для Каждого ПараРезультата Из РезультатыФайлов Цикл
		КлючФайла = ПараРезультата.Ключ;
		ДанныеФайла = ПараРезультата.Значение;
		
		Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не (ДанныеФайла.Свойство("Успех") И ДанныеФайла.Успех) Тогда
			Продолжить;
		КонецЕсли;
		
		Документ = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
		Если Документ = Неопределено Или ТипЗнч(Документ) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Сигнатура = СигнатураРаспознанногоДокумента(Документ);
		Если Не ЗначениеЗаполнено(Сигнатура.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		
		Группа = ГруппыПоСигнатуре.Получить(Сигнатура.Ключ);
		Если Группа = Неопределено Тогда
			Группа = Новый Массив;
		КонецЕсли;
		
		Группа.Добавить(Новый Структура("КлючФайла, Описание", КлючФайла, Сигнатура.Описание));
		ГруппыПоСигнатуре.Вставить(Сигнатура.Ключ, Группа);
	КонецЦикла;
	
	Для Каждого ПараГруппы Из ГруппыПоСигнатуре Цикл
		Группа = ПараГруппы.Значение;
		Если Группа.Количество() <= 1 Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого ЭлементГруппы Из Группа Цикл
			Дубли.Вставить(ЭлементГруппы.КлючФайла, ЭлементГруппы.Описание);
		КонецЦикла;
	КонецЦикла;
	
	Возврат Дубли;
	
КонецФункции

&НаСервере
Функция СигнатураРаспознанногоДокумента(ДокументJSON)
	
	Результат = Новый Структура("Ключ, Описание", "", "");
	Если ДокументJSON = Неопределено Или ТипЗнч(ДокументJSON) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	НомерДок = СокрЛП(Строка(?(ДокументJSON.Свойство("document_number"), ДокументJSON.document_number, "")));
	ДатаДок = СокрЛП(Строка(?(ДокументJSON.Свойство("document_date"), ДокументJSON.document_date, "")));
	ИННПоставщика = "";
	
	Если ДокументJSON.Свойство("shipper") И ТипЗнч(ДокументJSON.shipper) = Тип("Структура") Тогда
		ИННПоставщика = НормализоватьИНН(
			?(ДокументJSON.shipper.Свойство("inn"), ДокументJSON.shipper.inn,
				?(ДокументJSON.shipper.Свойство("tax_id"), ДокументJSON.shipper.tax_id, "")));
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(НомерДок) Или Не ЗначениеЗаполнено(ДатаДок) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Ключ = НРег(НомерДок) + "|" + НРег(ДатаДок) + "|" + ИННПоставщика;
	Результат.Описание = СтрШаблон("№%1 от %2, ИНН %3", НомерДок, ДатаДок, ?(ЗначениеЗаполнено(ИННПоставщика), ИННПоставщика, "-"));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция НормализоватьИНН(ЗначениеИНН)
	
	ИНН = СокрЛП(Строка(ЗначениеИНН));
	ИНН = СтрЗаменить(ИНН, " ", "");
	ИНН = СтрЗаменить(ИНН, "-", "");
	
	Возврат ИНН;
	
КонецФункции

&НаСервере
Функция ЗапуститьФоновоеЗаданиеРаспознавания(ПараметрыВыполнения)
	
	ПоследняяОшибка = "";
	
	Для Каждого ИмяМетода Из ИменаМетодовФоновогоРаспознавания() Цикл
		Попытка
			Возврат ФоновыеЗадания.Выполнить(
				ИмяМетода,
				ПараметрыВыполнения,
				,
				НСтр("ru = 'ТТН: распознавание документов'"));
		Исключение
			ПоследняяОшибка = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;
	КонецЦикла;
	
	Если ПустаяСтрока(ПоследняяОшибка) Тогда
		ПоследняяОшибка = НСтр("ru = 'Метод фонового задания не найден.'");
	КонецЕсли;
	
	ВызватьИсключение ПоследняяОшибка;
	
КонецФункции

&НаСервере
Функция ИменаМетодовФоновогоРаспознавания()
	
	ИменаМетодов = Новый Массив;
	ПрефиксМетода = ПрефиксИмениМетодовОбработкиНаСервере();
	
	Для Каждого ИмяОбработки Из ИменаВнешнейОбработкиДляФоновогоЗадания() Цикл
		ИменаМетодов.Добавить(ПрефиксМетода + ИмяОбработки + ".Форма.Форма.Форма.ВыполнитьОтправкуНаРаспознаваниеФон");
		ИменаМетодов.Добавить(ПрефиксМетода + ИмяОбработки + ".МодульОбъекта.ВыполнитьОтправкуНаРаспознаваниеФон");
		ИменаМетодов.Добавить(ПрефиксМетода + ИмяОбработки + ".ВыполнитьОтправкуНаРаспознаваниеФон");
	КонецЦикла;
	
	Возврат ИменаМетодов;
	
КонецФункции

&НаСервере
Функция ИменаВнешнейОбработкиДляФоновогоЗадания()
	
	Имена = Новый Массив;
	ДобавитьУникальноеИмяОбработки(Имена, РеквизитФормыВЗначение("Объект").Метаданные().Имя);
	ДобавитьУникальноеИмяОбработки(Имена, "Распознавание_Высота");
	// Не добавляем "ТТН" — часто приводит к ошибке поиска метода фонового задания.
	
	Если ЗначениеЗаполнено(СсылкаДополнительнойОбработки) Тогда
		Попытка
			ИмяОбъекта = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаДополнительнойОбработки, "ИмяОбъекта");
			ДобавитьУникальноеИмяОбработки(Имена, ИмяОбъекта);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат Имена;
	
КонецФункции

&НаСервере
Процедура ДобавитьУникальноеИмяОбработки(Имена, ИмяОбработки)
	
	Если Не ЗначениеЗаполнено(ИмяОбработки) Тогда
		Возврат;
	КонецЕсли;
	
	Если Имена.Найти(ИмяОбработки) = Неопределено Тогда
		Имена.Добавить(ИмяОбработки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция НайтиСсылкуДополнительнойОбработкиНаСервере()
	
	ИмяМетаданных = РеквизитФормыВЗначение("Объект").Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Доп.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ДополнительныеОтчетыИОбработки КАК Доп
		|ГДЕ
		|	НЕ Доп.ПометкаУдаления
		|	И (Доп.ИмяОбъекта = &ИмяОбъекта
		|		ИЛИ Доп.Наименование ПОДОБНО &ШаблонНаименования
		|		ИЛИ Доп.ИмяФайла ПОДОБНО &ШаблонИмениФайла)
		|УПОРЯДОЧИТЬ ПО
		|	ВЫБОР
		|		КОГДА Доп.ИмяОбъекта = &ИмяОбъекта ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ";
	
	Запрос.УстановитьПараметр("ИмяОбъекта", ИмяМетаданных);
	Запрос.УстановитьПараметр("ШаблонНаименования", "%" + ИмяМетаданных + "%");
	Запрос.УстановитьПараметр("ШаблонИмениФайла", "%" + ИмяМетаданных + "%");
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Справочники.ДополнительныеОтчетыИОбработки.ПустаяСсылка();
	
КонецФункции

&НаСервере
Функция СформироватьРезультатОтправкиИзХранилища(АдресРезультата)
	
	РезультатHTTP = ПолучитьИзВременногоХранилища(АдресРезультата);
	Возврат СформироватьРезультатОтправкиДляФормы(РезультатHTTP);
	
КонецФункции

&НаСервере
Функция СформироватьРезультатОтправкиДляФормы(РезультатHTTP)
	
	Если РезультатHTTP = Неопределено Тогда
		Возврат СоздатьРезультатОтправкиОшибки(НСтр("ru = 'Пустой результат распознавания.'"));
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", РезультатHTTP.Успех);
	Результат.Вставить("ТелоОтвета", ?(РезультатHTTP.Свойство("ТелоОтвета"), РезультатHTTP.ТелоОтвета, ""));
	Результат.Вставить("ТекстДляПользователя", ?(РезультатHTTP.Свойство("ТекстДляПользователя"), РезультатHTTP.ТекстДляПользователя, ""));
	Результат.Вставить("ТоварыРаспознавания", ?(РезультатHTTP.Свойство("ТоварыРаспознавания"), РезультатHTTP.ТоварыРаспознавания, Неопределено));
	Результат.Вставить("ДокументРаспознавания", ?(РезультатHTTP.Свойство("ДокументРаспознавания"), РезультатHTTP.ДокументРаспознавания, Неопределено));
	Результат.Вставить("ОписаниеОшибки", ?(РезультатHTTP.Свойство("ОписаниеОшибки"), РезультатHTTP.ОписаниеОшибки, ""));
	
	Если РезультатHTTP.Свойство("СтатусыФайлов") Тогда
		Результат.Вставить("СтатусыФайлов", РезультатHTTP.СтатусыФайлов);
	Иначе
		Результат.Вставить("СтатусыФайлов", СтатусыФайловПослеОтправки(РезультатHTTP.Успех));
	КонецЕсли;
	
	КлючиРезультатов = Новый Массив;
	Если РезультатHTTP.Свойство("РезультатыФайлов")
		И ТипЗнч(РезультатHTTP.РезультатыФайлов) = Тип("Соответствие") Тогда
		Для Каждого ЭлементРезультата Из РезультатHTTP.РезультатыФайлов Цикл
			КлючиРезультатов.Добавить(ЭлементРезультата.Ключ);
		КонецЦикла;
	КонецЕсли;
	Результат.Вставить("КлючиРезультатовФайлов", КлючиРезультатов);
	Результат.Вставить("РезультатыСохраненыНаСервере", КлючиРезультатов.Количество() > 0);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция СоздатьРезультатОтправкиОшибки(ОписаниеОшибки, ТелоОтвета = "")
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ОписаниеОшибки", ОписаниеОшибки);
	Результат.Вставить("ТелоОтвета", ТелоОтвета);
	Результат.Вставить("ТекстДляПользователя", "");
	Результат.Вставить("СтатусыФайлов", СтатусыФайловПослеОтправки(Ложь));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция СтатусыФайловПослеОтправки(Успех)
	
	СтатусыФайлов = Новый Соответствие;
	ТекстСтатуса = ?(Успех, НСтр("ru = 'Отправлен'"), НСтр("ru = 'Ошибка'"));
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		КлючФайла = "";
		Если СписокДокументов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
			КлючФайла = СтрокаФайла.ИдентификаторФайла;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(КлючФайла) Тогда
			КлючФайла = СтрокаФайла.АдресХранилища;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(КлючФайла) Тогда
			КлючФайла = СтрокаФайла.ИмяФайла;
		КонецЕсли;
		СтатусыФайлов.Вставить(КлючФайла, ТекстСтатуса);
	КонецЦикла;
	
	Возврат СтатусыФайлов;
	
КонецФункции

&НаСервере
Процедура ПрименитьРезультатРаспознаванияНаСервере(РезультатОтправки)
	
	Если РезультатОтправки = Неопределено Или Не РезультатОтправки.Успех Тогда
		Возврат;
	КонецЕсли;
	
	ДокументJSON = Неопределено;
	Если РезультатОтправки.Свойство("ДокументРаспознавания") Тогда
		ДокументJSON = РезультатОтправки.ДокументРаспознавания;
	КонецЕсли;
	
	Если РезультатОтправки.Свойство("ТоварыРаспознавания") Тогда
		ЗаполнитьРаспознанныеДанныеНаСервере(РезультатОтправки.ТоварыРаспознавания, ДокументJSON);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРаспознанныеДанныеНаСервере(ТоварыJSON, ДокументJSON = Неопределено)
	
	Значение = РеквизитФормыВЗначение("Объект");
	
	РаспознаннаяОрганизация = Справочники.Организации.ПустаяСсылка();
	РаспознанныйКонтрагент = Справочники.Контрагенты.ПустаяСсылка();
	
	Если ДокументJSON <> Неопределено Тогда
		РеквизитыШапки = Значение.ОпределитьОрганизациюИКонтрагентаПоДокументу(ДокументJSON, СтруктураНастроек);
		РаспознаннаяОрганизация = РеквизитыШапки.Организация;
		РаспознанныйКонтрагент = РеквизитыШапки.Контрагент;
		Если Не ЗначениеЗаполнено(РаспознанныйКонтрагент) Тогда
			ТекстПоставщика = ПоставщикИзJSON(ДокументJSON);
			РаспознанныйКонтрагент = Значение.НайтиКонтрагентаПоТекстуПоставщика(ТекстПоставщика, СтруктураНастроек);
		КонецЕсли;
	Иначе
		РеквизитыШапки = Значение.ОпределитьОрганизациюИКонтрагентаПоДокументу(Неопределено, СтруктураНастроек);
		РаспознаннаяОрганизация = РеквизитыШапки.Организация;
		РаспознанныйКонтрагент = РеквизитыШапки.Контрагент;
	КонецЕсли;
	
	КонтрагентИДСопоставления = Значение.КонтрагентИДДляСопоставленияНоменклатуры(ДокументJSON, РаспознанныйКонтрагент);
	
	Значение.ЗаполнитьСтрокиРаспознаннойНоменклатуры(
		ТоварыJSON,
		РаспознаннаяНоменклатура,
		ПолучитьАлгоритмПоискаНоменклатуры(),
		СтруктураНастроек,
		КонтрагентИДСопоставления);
	
КонецПроцедуры

&НаКлиенте
Процедура РаспознаннаяНоменклатураНоменклатураПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.РаспознаннаяНоменклатура.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекстОповещения = СохранитьРучноеСопоставлениеНоменклатурыНаСервере(ТекущиеДанные.ПолучитьИдентификатор());
	Если ЗначениеЗаполнено(ТекстОповещения) Тогда
		ПоказатьОповещениеПользователя(НСтр("ru = 'Сохранено'"), , ТекстОповещения);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СохранитьРучноеСопоставлениеНоменклатурыНаСервере(ИдентификаторСтроки)
	
	Значение = РеквизитФормыВЗначение("Объект");
	
	СтрокаНоменклатуры = РаспознаннаяНоменклатура.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если СтрокаНоменклатуры = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Наименование = Значение.ИзвлечьЧистоеНаименованиеРаспознавания(СтрокаНоменклатуры.Наименование);
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстОповещения = "";
	
	Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
		ТекстОповещения = Значение.ЗаписатьСоответствиеНоменклатуры(
			СтрокаНоменклатуры.Номенклатура,
			Наименование,
			КонтрагентИДСопоставления);
	ИначеЕсли Значение.ЗапоминатьУстановленныеВручнуюСоответствияНоменклатуры(СтруктураНастроек) Тогда
		ТекстОповещения = Значение.ЗаписатьСоответствиеНоменклатуры(
			СтрокаНоменклатуры.Номенклатура,
			Наименование,
			КонтрагентИДСопоставления);
	КонецЕсли;
	
	Способ = ?(ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура), "Сохранено", "Не найдено");
	СтрокаНоменклатуры.Наименование = Наименование + Значение.МаркерСпособаСопоставления(Способ);
	
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	СохранитьРеестрДокументовНаСервере();
	
	Возврат ТекстОповещения;
	
КонецФункции

&НаСервере
Функция ПолучитьАлгоритмПоискаНоменклатуры()
	
	АлгоритмПоУмолчанию = "Артикул,Наименование";
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_АлгоритмПоискаНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры) Тогда
		Возврат СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры;
	КонецЕсли;
	
	Возврат АлгоритмПоУмолчанию;
	
КонецФункции

&НаСервере
Функция СформироватьФайлНаСервере()
	
	КоллекцияПечатныхФорм = УправлениеПечатью.ПодготовитьКоллекциюПечатныхФорм("Распознавание_Высота");
	
	МассивОбъектов = Новый Массив;
	МассивОбъектов.Добавить(Документ);
	
	ОбъектыПечати = Новый СписокЗначений;
	ПараметрыВывода = Новый Структура;
	ПараметрыВывода.Вставить("ИдентификаторЗадания", УникальныйИдентификатор);
	
	Значение = РеквизитФормыВЗначение("Объект");
	Значение.СформироватьДокументWord(КоллекцияПечатныхФорм, МассивОбъектов, ОбъектыПечати, ПараметрыВывода);
	
	ОфисныеДокументы = КоллекцияПечатныхФорм[0].ОфисныеДокументы;
	Если ТипЗнч(ОфисныеДокументы) <> Тип("Соответствие") Или ОфисныеДокументы.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из ОфисныеДокументы Цикл
		Результат = Новый Структура;
		Результат.Вставить("АдресДокумента", КлючИЗначение.Ключ);
		Результат.Вставить("ИмяФайла", КлючИЗначение.Значение);
		Возврат Результат;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Процедура СкачатьФайлПечатнойФормыВВебКлиенте()
	
	Результат = СформироватьФайлНаСервере();
	Если Результат = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Не удалось сформировать печатную форму на сервере. Установите Word или LibreOffice на сервере 1С.'"));
		Возврат;
	КонецЕсли;
	
	ИмяФайла = Результат.ИмяФайла;
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		ИмяФайла = "ТТН.docx";
	КонецЕсли;
	
	ФайловаяСистемаКлиент.СохранитьФайл(
		Новый ОписаниеОповещения("ПослеСохраненияФайла", ЭтотОбъект),
		Результат.АдресДокумента,
		ИмяФайла,
		Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеСохраненияФайла(Результат, ДополнительныеПараметры) Экспорт
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСформированныйДокументВТолстомКлиенте()
	
	Результат = СформироватьФайлНаСервере();
	Если Результат = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Не удалось сформировать DOCX. Проверьте макет ПФ_DOC_Макет.'"));
		Возврат;
	КонецЕсли;
	
	ИмяФайла = Результат.ИмяФайла;
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		ИмяФайла = "ТТН.docx";
	КонецЕсли;
	
	ПутьКФайлу = ПутьКВременномуФайлуНаКлиенте(ИмяФайла);
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(Результат.АдресДокумента);
	ДвоичныеДанные.Записать(ПутьКФайлу);
	ЗапуститьПриложение(ПутьКФайлу);
	
КонецПроцедуры

&НаКлиенте
Функция ПутьКВременномуФайлуНаКлиенте(ИмяФайла)
	
	ИмяБезПути = ИмяФайла;
	ПозицияРазделителя = СтрНайти(ИмяБезПути, "\", НаправлениеПоиска.СКонца);
	Если ПозицияРазделителя = 0 Тогда
		ПозицияРазделителя = СтрНайти(ИмяБезПути, "/", НаправлениеПоиска.СКонца);
	КонецЕсли;
	Если ПозицияРазделителя > 0 Тогда
		ИмяБезПути = Сред(ИмяБезПути, ПозицияРазделителя + 1);
	КонецЕсли;
	
	ПозицияТочки = СтрНайти(ИмяБезПути, ".", НаправлениеПоиска.СКонца);
	Если ПозицияТочки > 0 Тогда
		ИмяБезРасширения = Лев(ИмяБезПути, ПозицияТочки - 1);
		Расширение = Сред(ИмяБезПути, ПозицияТочки);
	Иначе
		ИмяБезРасширения = ИмяБезПути;
		Расширение = ".docx";
	КонецЕсли;
	
	УникальныйПрефикс = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	ИмяБезПути = ИмяБезРасширения + "_" + УникальныйПрефикс + Расширение;
	
	Каталог = КаталогВременныхФайлов();
	Разделитель = ?(СтрЗаканчиваетсяНа(Каталог, "\") Или СтрЗаканчиваетсяНа(Каталог, "/"), "", "\");
	
	Возврат Каталог + Разделитель + ИмяБезПути;
	
КонецФункции

