Функция ИмяФормыВыбораТипаСоздаваемогоДокумента()
	
	Возврат ИмяПодчиненнойФормыОбработки("ФормаВыбораТипаСоздаваемогоДокумента");
	
КонецФункции

&НаСервере
Функция ПолучитьСписокТиповСоздаваемыхДокументовНаСервере()
	
	Значение = РеквизитФормыВЗначение("Объект");
	Возврат Значение.ПолучитьСписокТиповСоздаваемыхДокументов();
	
КонецФункции

&НаСервере
Функция ПодготовитьПараметрыСозданияДокументовНаСервере(СтрокиДляСоздания)
	
	Результат = Новый Структура;
	Результат.Вставить("СтрокиДокументов", СтрокиДляСоздания);
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Сообщение", "");
	
	Если Метаданные.Документы.Найти("ПоступлениеТоваровУслуг") = Неопределено Тогда
		Результат.Сообщение = НСтр("ru = 'В конфигурации не найден документ «Поступление товаров и услуг».'");
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Результат.Вставить("ТипДокумента", "ПоступлениеТоваровУслуг");
	Результат.Вставить("ВидОперации", ПреобразоватьВидОперацииПоИмениНаСервере("ВПереработку"));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПреобразоватьВидОперацииПоИмениНаСервере(ИмяВидаОперации)
	
	Если Не ЗначениеЗаполнено(ИмяВидаОперации) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Перечисления.ВидыОперацийПоступлениеТоваровУслуг[ИмяВидаОперации];
	Исключение
		Попытка
			Возврат ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеТоваровУслуг." + ИмяВидаОперации);
		Исключение
			Возврат Неопределено;
		КонецПопытки;
	КонецПопытки;
	
КонецФункции

&НаСервере
Процедура ЗагрузитьПрисоединенныеФайлыДокументаНаСервере(ДокументСсылка)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	МассивФайлов = ОбработкаОбъект.ПодготовитьПрисоединенныеФайлыДляРаспознавания(ДокументСсылка, УникальныйИдентификатор);
	
	Для Каждого ОписаниеФайла Из МассивФайлов Цикл
		ДобавитьСтрокуФайлаВСписокДокументовНаСервере(ОписаниеФайла);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуФайлаВСписокДокументовНаСервере(ОписаниеФайла)
	
	Если ОписаниеФайла = Неопределено
		Или ТипЗнч(ОписаниеФайла) <> Тип("Структура")
		Или Не ОписаниеФайла.Свойство("АдресХранилища")
		Или Не ЗначениеЗаполнено(ОписаниеФайла.АдресХранилища) Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = СписокДокументов.Добавить();
	НоваяСтрока.ИмяФайла = ?(ОписаниеФайла.Свойство("ИмяФайла"), ОписаниеФайла.ИмяФайла, "");
	НоваяСтрока.АдресХранилища = ОписаниеФайла.АдресХранилища;
	НоваяСтрока.ИдентификаторФайла = Строка(Новый УникальныйИдентификатор);
	
	РазмерБайт = 0;
	Если ОписаниеФайла.Свойство("РазмерБайт") Тогда
		РазмерБайт = ОписаниеФайла.РазмерБайт;
	КонецЕсли;
	Если РазмерБайт > 0 Тогда
		НоваяСтрока.РазмерКб = Окр(РазмерБайт / 1024, 3);
	КонецЕсли;
	
	НоваяСтрока.ДатаЗагрузки = ТекущаяДата();
	НоваяСтрока.ПредставлениеДокумента = НоваяСтрока.ИмяФайла;
	НоваяСтрока.СоответствуетОтбору = Истина;
	УстановитьКодСтатусаСтроки(НоваяСтрока, "Новый");
	
КонецПроцедуры

&НаСервере
Функция ЗагрузкаФайловИзДокументаНаСервере()
	Возврат ЗагрузкаФайловИзДокумента;
КонецФункции

&НаСервере
Процедура ОбновитьСписокДокументовНаСервереПослеЗагрузкиИзДокумента()
	ВосстановитьСоответствиеОтборуПослеЗагрузкиНаСервере();
	ОбновитьКодыСтатусовПоТекстуНаСервере();
	ОбновитьПоляСтрокДокументовПоРезультатамНаСервере();
	ОбновитьСчетчикиСтатусовНаСервере();
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьРеестрДокументовНаСервере()
	ЗагрузитьРеестрДокументовНаСервере();
	ВосстановитьСоответствиеОтборуПослеЗагрузкиНаСервере();
	ОбновитьКодыСтатусовПоТекстуНаСервере();
	ОбновитьПоляСтрокДокументовПоРезультатамНаСервере();
	ОбновитьСчетчикиСтатусовНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСтруктуруНастроекНаСервере()
	
	СтруктураНастроекИзХранилища = ХранилищеОбщихНастроек.Загрузить("Распознавание_Высота", "ОбщиеНастройки");
	Если ТипЗнч(СтруктураНастроекИзХранилища) = Тип("Структура") Тогда
		СтруктураНастроек = СтруктураНастроекИзХранилища;
	Иначе
		СтруктураНастроек = Новый Структура;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьСоответствиеОтборуПослеЗагрузкиНаСервере()
	
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		СтрокаДокумента.СоответствуетОтбору = Истина;
	КонецЦикла;
	
КонецПроцедуры

// Сохраняет список документов и результаты распознавания между сеансами работы.
&НаСервере
Процедура СохранитьРеестрДокументовНаСервере()
	
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	
	ДанныеРеестра = Новый Структура;
	ДанныеРеестра.Вставить("ДатаСохранения", ТекущаяДата());
	ДанныеРеестра.Вставить("СписокДокументов", РеквизитФормыВЗначение("СписокДокументов").Скопировать());
	ДанныеРеестра.Вставить("ЗаданияРаспознавания", РеквизитФормыВЗначение("ЗаданияРаспознавания").Скопировать());
	ДанныеРеестра.Вставить("КлючДеталейДокумента", КлючДеталейДокумента);
	
	ФайлыДвоичные = Новый Соответствие;
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		КлючФайла = КлючСтрокиДокумента(СтрокаДокумента);
		Если Не ЗначениеЗаполнено(СтрокаДокумента.АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(СтрокаДокумента.АдресХранилища);
			Если ТипЗнч(ДвоичныеДанные) = Тип("ДвоичныеДанные") Тогда
				ФайлыДвоичные.Вставить(КлючФайла, ДвоичныеДанные);
			КонецЕсли;
		Исключение
		КонецПопытки;
		
	КонецЦикла;
	ДанныеРеестра.Вставить("ФайлыДвоичные", ФайлыДвоичные);
	
	РезультатыФайлов = Неопределено;
	Если ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		РезультатыФайлов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	КонецЕсли;
	ДанныеРеестра.Вставить("РезультатыФайлов", РезультатыФайлов);
	
	Если ЗаписатьДанныеРеестраВХранилище(ДанныеРеестра) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеРеестра.Вставить("ФайлыДвоичные", Новый Соответствие);
	Если ЗаписатьДанныеРеестраВХранилище(ДанныеРеестра) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеРеестра.Вставить("РезультатыФайлов", ОблегчитьРезультатыФайловДляХранения(РезультатыФайлов));
	ЗаписатьДанныеРеестраВХранилище(ДанныеРеестра);
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьДанныеРеестраВХранилище(ДанныеРеестра)
	
	Попытка
		ХранилищеОбщихНастроек.Сохранить("Распознавание_Высота", "РеестрДокументов", ДанныеРеестра);
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция ОблегчитьРезультатыФайловДляХранения(РезультатыФайлов)
	
	Если РезультатыФайлов = Неопределено Или ТипЗнч(РезультатыФайлов) <> Тип("Соответствие") Тогда
		Возврат РезультатыФайлов;
	КонецЕсли;
	
	Облегченные = Новый Соответствие;
	
	Для Каждого ПараРезультата Из РезультатыФайлов Цикл
		
		ДанныеФайла = ПараРезультата.Значение;
		Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
			Облегченные.Вставить(ПараРезультата.Ключ, ДанныеФайла);
			Продолжить;
		КонецЕсли;
		
		Копия = Новый Структура;
		Для Каждого Поле Из ДанныеФайла Цикл
			Если Поле.Ключ = "ТелоОтвета" Тогда
				Продолжить;
			КонецЕсли;
			Если (Поле.Ключ = "Товары" Или Поле.Ключ = "Документ")
				И ДанныеФайла.Свойство("ТаблицаНоменклатурыФормы") Тогда
				Продолжить;
			КонецЕсли;
			Копия.Вставить(Поле.Ключ, Поле.Значение);
		КонецЦикла;
		
		Облегченные.Вставить(ПараРезультата.Ключ, Копия);
		
	КонецЦикла;
	
	Возврат Облегченные;
	
КонецФункции

// Восстанавливает список документов и результаты распознавания из хранилища настроек.
&НаСервере
Процедура ЗагрузитьРеестрДокументовНаСервере()
	
	ДанныеРеестра = ХранилищеОбщихНастроек.Загрузить("Распознавание_Высота", "РеестрДокументов");
	Если ТипЗнч(ДанныеРеестра) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если ДанныеРеестра.Свойство("СписокДокументов")
		И ТипЗнч(ДанныеРеестра.СписокДокументов) = Тип("ТаблицаЗначений") Тогда
		ЗначениеВРеквизитФормы(ДанныеРеестра.СписокДокументов, "СписокДокументов");
	КонецЕсли;
	
	ФайлыДвоичные = Неопределено;
	Если ДанныеРеестра.Свойство("ФайлыДвоичные") Тогда
		ФайлыДвоичные = ДанныеРеестра.ФайлыДвоичные;
	КонецЕсли;
	
	Если ТипЗнч(ФайлыДвоичные) = Тип("Соответствие") Тогда
		Для Каждого СтрокаДокумента Из СписокДокументов Цикл
			
			КлючФайла = КлючСтрокиДокумента(СтрокаДокумента);
			ДвоичныеДанные = ФайлыДвоичные.Получить(КлючФайла);
			
			Если ДвоичныеДанные <> Неопределено Тогда
				СтрокаДокумента.АдресХранилища = ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
			Иначе
				СтрокаДокумента.АдресХранилища = "";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(КлючФайла) Тогда
				СтрокаДокумента.АдресРезультатаРаспознавания = КлючФайла;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если ДанныеРеестра.Свойство("ЗаданияРаспознавания")
		И ТипЗнч(ДанныеРеестра.ЗаданияРаспознавания) = Тип("ТаблицаЗначений") Тогда
		ЗначениеВРеквизитФормы(ДанныеРеестра.ЗаданияРаспознавания, "ЗаданияРаспознавания");
	КонецЕсли;
	
	РезультатыФайлов = Неопределено;
	Если ДанныеРеестра.Свойство("РезультатыФайлов") Тогда
		РезультатыФайлов = ДанныеРеестра.РезультатыФайлов;
	КонецЕсли;
	
	Если РезультатыФайлов <> Неопределено И ТипЗнч(РезультатыФайлов) = Тип("Соответствие") Тогда
		РезультатыФайловРаспознавания = ПоместитьВоВременноеХранилище(РезультатыФайлов, УникальныйИдентификатор);
	КонецЕсли;
	
	Если ДанныеРеестра.Свойство("КлючДеталейДокумента") Тогда
		КлючДеталейДокумента = ДанныеРеестра.КлючДеталейДокумента;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере()
	
	Если Не ЗначениеЗаполнено(КлючДеталейДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		Возврат;
	КонецЕсли;
	
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла = СоответствиеРезультатов.Получить(КлючДеталейДокумента);
	Если ДанныеФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФайла.Вставить("ТаблицаНоменклатурыФормы", РеквизитФормыВЗначение("РаспознаннаяНоменклатура").Скопировать());
	ДанныеФайла.Вставить("Организация", РаспознаннаяОрганизация);
	ДанныеФайла.Вставить("Контрагент", РаспознанныйКонтрагент);
	ДанныеФайла.Вставить("КонтрагентИДСопоставления", КонтрагентИДСопоставления);
	
	РезультатыФайловРаспознавания = ПоместитьВоВременноеХранилище(СоответствиеРезультатов, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДвоичныеДанныеФайлаДляПросмотраНаСервере(АдресХранилища)
	
	Если Не ЗначениеЗаполнено(АдресХранилища) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресХранилища);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
	Если ТипЗнч(ДвоичныеДанные) <> Тип("ДвоичныеДанные") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДвоичныеДанные;
	
КонецФункции

&НаСервере
Функция ПолучитьПараметрыОткрытияИсходногоФайлаНаСервере(АдресХранилища, ИмяФайла)
	
	ДвоичныеДанные = ПолучитьДвоичныеДанныеФайлаДляПросмотраНаСервере(АдресХранилища);
	Если ДвоичныеДанные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Адрес", ПоместитьВоВременноеХранилище(ДвоичныеДанные, Новый УникальныйИдентификатор));
	Результат.Вставить("Имя", ?(ЗначениеЗаполнено(ИмяФайла), ИмяФайла, "document.pdf"));
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ЗагрузитьТабличныйДокументПросмотраНаСервере(АдресХранилища, РасширениеФайла)
	
	ДвоичныеДанные = ПолучитьДвоичныеДанныеФайлаДляПросмотраНаСервере(АдресХранилища);
	Если ДвоичныеДанные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Расширение = НРег(СокрЛП(РасширениеФайла));
	Если Не ЗначениеЗаполнено(Расширение) Тогда
		Расширение = "xlsx";
	КонецЕсли;
	
	ИмяВременногоФайла = "";
	ТабДок = Неопределено;
	
	Попытка
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("." + Расширение);
		ДвоичныеДанные.Записать(ИмяВременногоФайла);
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.Прочитать(ИмяВременногоФайла);
	Исключение
		ТабДок = Неопределено;
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ИмяВременногоФайла) Тогда
		Попытка
			УдалитьФайлы(ИмяВременногоФайла);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат ТабДок;
	
КонецФункции

&НаСервере
Процедура ПрименитьДанныеФайлаКФормеРаспознаванияНаСервере(ДанныеФайла)
	
	Если ДанныеФайла <> Неопределено
		И ДанныеФайла.Свойство("ТаблицаНоменклатурыФормы")
		И ТипЗнч(ДанныеФайла.ТаблицаНоменклатурыФормы) = Тип("ТаблицаЗначений")
		И ДанныеФайла.ТаблицаНоменклатурыФормы.Количество() > 0 Тогда
		
		ТаблицаНоменклатуры = ДанныеФайла.ТаблицаНоменклатурыФормы.Скопировать();
		ЗначениеОбработки = РеквизитФормыВЗначение("Объект");
		ЗначениеОбработки.ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры);
		ЗначениеВРеквизитФормы(ТаблицаНоменклатуры, "РаспознаннаяНоменклатура");
		
		Если ДанныеФайла.Свойство("Организация") Тогда
			РаспознаннаяОрганизация = ДанныеФайла.Организация;
		КонецЕсли;
		Если ДанныеФайла.Свойство("Контрагент") Тогда
			РаспознанныйКонтрагент = ДанныеФайла.Контрагент;
		КонецЕсли;
		Если ДанныеФайла.Свойство("КонтрагентИДСопоставления") Тогда
			КонтрагентИДСопоставления = ДанныеФайла.КонтрагентИДСопоставления;
		КонецЕсли;
		
		РезультатРаспознавания = ?(ДанныеФайла.Свойство("ТекстДляПользователя"), ДанныеФайла.ТекстДляПользователя, "");
		Возврат;
	КонецЕсли;
	
	ДокументJSON = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
	Товары = ?(ДанныеФайла.Свойство("Товары"), ДанныеФайла.Товары, Неопределено);
	ЗаполнитьРаспознанныеДанныеНаСервере(Товары, ДокументJSON);
	РезультатРаспознавания = ?(ДанныеФайла.Свойство("ТекстДляПользователя"), ДанныеФайла.ТекстДляПользователя, "");
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьДеталиДокументаПослеЗагрузкиНаСервере()
	
	Если СписокДокументов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КлючДляВосстановления = "";
	
	Если ЗначениеЗаполнено(КлючДеталейДокумента) Тогда
		КлючДляВосстановления = КлючДеталейДокумента;
	Иначе
		Для Каждого СтрокаДокумента Из СписокДокументов Цикл
			Код = СтрокаДокумента.КодСтатуса;
			Если Не ЗначениеЗаполнено(Код) Тогда
				Код = КодСтатусаПоТексту(СтрокаДокумента.Статус);
			КонецЕсли;
			Если Код = "Распознан" Или Код = "ГотовКСозданию" Или Код = "Дубликат" Тогда
				КлючДляВосстановления = КлючСтрокиДокумента(СтрокаДокумента);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючДляВосстановления) Тогда
		ЗаполнитьДеталиВыбранногоДокументаНаСервере(КлючДляВосстановления);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьВыборСтрокиСпискаДокументовНаКлиенте()
	
	Если Не ЗначениеЗаполнено(КлючДеталейДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаСписка Из СписокДокументов Цикл
		Если КлючСтрокиДокументаНаКлиенте(СтрокаСписка) = КлючДеталейДокумента Тогда
			Элементы.СписокДокументов.ТекущаяСтрока = СтрокаСписка.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьКодСтатусаСтроки(СтрокаДокумента, КодСтатуса)
	СтрокаДокумента.КодСтатуса = КодСтатуса;
	СтрокаДокумента.Статус = ПредставлениеСтатусаПоКоду(КодСтатуса, СтрокаДокумента.Статус);
	Если КодСтатуса = "Распознан" Или КодСтатуса = "ГотовКСозданию" Тогда
		СтрокаДокумента.Пометка = Истина;
	ИначеЕсли КодСтатуса = "СозданВ1С" Тогда
		СтрокаДокумента.Пометка = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПредставлениеСтатусаПоКоду(КодСтатуса, ТекущийСтатус = "")
	Если КодСтатуса = "Новый" Тогда
		Возврат НСтр("ru = 'Новый'");
	ИначеЕсли КодСтатуса = "НаРаспознавании" Тогда
		Возврат НСтр("ru = 'На распознавании'");
	ИначеЕсли КодСтатуса = "Распознан" Тогда
		Возврат НСтр("ru = '[OK] Распознан'");
	ИначеЕсли КодСтатуса = "Ошибка" Тогда
		Возврат НСтр("ru = '[ERR] Ошибка'");
	ИначеЕсли КодСтатуса = "Дубликат" Тогда
		Возврат НСтр("ru = '[WARN] Дубликат документа'");
	ИначеЕсли КодСтатуса = "ГотовКСозданию" Тогда
		Возврат НСтр("ru = 'Готов к созданию'");
	ИначеЕсли КодСтатуса = "СозданВ1С" Тогда
		Возврат НСтр("ru = 'Создан в 1С'");
	КонецЕсли;
	Возврат ?(ЗначениеЗаполнено(ТекущийСтатус), ТекущийСтатус, КодСтатуса);
КонецФункции

&НаСервере
Процедура ОбновитьКодыСтатусовПоТекстуНаСервере()
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		Если ЗначениеЗаполнено(СтрокаДокумента.КодСтатуса) Тогда
			Продолжить;
		КонецЕсли;
		СтрокаДокумента.КодСтатуса = КодСтатусаПоТексту(СтрокаДокумента.Статус);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Функция КодСтатусаПоТексту(ТекстСтатуса)
	Статус = НРег(СокрЛП(Строка(ТекстСтатуса)));
	Если Найти(Статус, НРег(НСтр("ru='создан в 1с'"))) > 0 Тогда
		Возврат "СозданВ1С";
	ИначеЕсли Найти(Статус, НРег(НСтр("ru='готов к созданию'"))) > 0 Тогда
		Возврат "ГотовКСозданию";
	ИначеЕсли Найти(Статус, НРег(НСтр("ru='дубликат'"))) > 0 Тогда
		Возврат "Дубликат";
	ИначеЕсли Найти(Статус, НРег(НСтр("ru='распознан'"))) > 0 Тогда
		Возврат "Распознан";
	ИначеЕсли Найти(Статус, НРег(НСтр("ru='на распознавании'"))) > 0
		Или Найти(Статус, НРег(НСтр("ru='отправка'"))) > 0
		Или Найти(Статус, НРег(НСтр("ru='готов к отправке'"))) > 0 Тогда
		Возврат "НаРаспознавании";
	ИначеЕсли Найти(Статус, НРег(НСтр("ru='ошибка'"))) > 0 Тогда
		Возврат "Ошибка";
	ИначеЕсли ПустаяСтрока(Статус) Тогда
		Возврат "Новый";
	КонецЕсли;
	Возврат "Новый";
КонецФункции

&НаСервере
Процедура ОбновитьПоляСтрокДокументовПоРезультатамНаСервере()
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		Возврат;
	КонецЕсли;
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Значение = РеквизитФормыВЗначение("Объект");
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		КлючФайла = КлючСтрокиДокумента(СтрокаДокумента);
		ДанныеФайла = СоответствиеРезультатов.Получить(КлючФайла);
		Если ДанныеФайла = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗаполнитьСтрокуДокументаПоРезультату(СтрокаДокумента, ДанныеФайла, Значение);
	КонецЦикла;
	ОбновитьСчетчикиСтатусовНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтрокуДокументаПоРезультату(СтрокаДокумента, ДанныеФайла, ЗначениеОбработки)
	Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	Успех = ?(ДанныеФайла.Свойство("Успех"), ДанныеФайла.Успех, Ложь);
	Если Успех Тогда
		Если СтрокаДокумента.КодСтатуса <> "СозданВ1С" И СтрокаДокумента.КодСтатуса <> "Дубликат" Тогда
			Проверка = ЗначениеОбработки.ПроверитьКорректностьРаспознавания(
				ДанныеФайла,
				СтруктураНастроек,
				ПолучитьАлгоритмПоискаНоменклатуры());
			Если Проверка.ПолностьюГотов Тогда
				УстановитьКодСтатусаСтроки(СтрокаДокумента, "Распознан");
			Иначе
				УстановитьКодСтатусаСтроки(СтрокаДокумента, "ГотовКСозданию");
			КонецЕсли;
		КонецЕсли;
	Иначе
		УстановитьКодСтатусаСтроки(СтрокаДокумента, "Ошибка");
	КонецЕсли;
	ДокументJSON = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
	Если ДокументJSON <> Неопределено И ТипЗнч(ДокументJSON) = Тип("Структура") Тогда
		СтрокаДокумента.ПредставлениеДокумента = ПредставлениеДокументаИзJSON(ДокументJSON, СтрокаДокумента.ИмяФайла);
		СтрокаДокумента.ДатаДокумента = ДатаДокументаИзJSON(ДокументJSON);
		СтрокаДокумента.Поставщик = ПоставщикИзJSON(ДокументJSON);
		СтрокаДокумента.СуммаДокумента = СуммаДокументаИзJSON(ДокументJSON);
	Иначе
		Если Не ЗначениеЗаполнено(СтрокаДокумента.ПредставлениеДокумента) Тогда
			СтрокаДокумента.ПредставлениеДокумента = СтрокаДокумента.ИмяФайла;
		КонецЕсли;
	КонецЕсли;
	Если ДанныеФайла.Свойство("Предупреждение") И ЗначениеЗаполнено(ДанныеФайла.Предупреждение) Тогда
		УстановитьКодСтатусаСтроки(СтрокаДокумента, "Дубликат");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция КоличествоНесопоставленныхВДанных(ДанныеФайла)
	Товары = ?(ДанныеФайла.Свойство("Товары"), ДанныеФайла.Товары, Неопределено);
	Если Товары = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	Значение = РеквизитФормыВЗначение("Объект");
	Возврат Значение.КоличествоНесопоставленныхПозицийНоменклатуры(Товары, ПолучитьАлгоритмПоискаНоменклатуры());
КонецФункции

&НаСервере
Функция ПредставлениеДокументаИзJSON(ДокументJSON, ИмяФайла)
	Номер = ?(ДокументJSON.Свойство("document_number"), СокрЛП(Строка(ДокументJSON.document_number)), "");
	Дата = ?(ДокументJSON.Свойство("document_date"), СокрЛП(Строка(ДокументJSON.document_date)), "");
	Если ЗначениеЗаполнено(Номер) И ЗначениеЗаполнено(Дата) Тогда
		Возврат СтрШаблон(НСтр("ru = '№%1 от %2'"), Номер, Дата);
	КонецЕсли;
	Возврат ИмяФайла;
КонецФункции

&НаСервере
Функция ДатаДокументаИзJSON(ДокументJSON)
	Если Не ДокументJSON.Свойство("document_date") Тогда
		Возврат '00010101';
	КонецЕсли;
	Попытка
		Возврат Дата(Строка(ДокументJSON.document_date));
	Исключение
		Возврат '00010101';
	КонецПопытки;
КонецФункции

&НаСервере
Функция ПоставщикИзJSON(ДокументJSON)
	Если ДокументJSON.Свойство("shipper") И ТипЗнч(ДокументJSON.shipper) = Тип("Структура") Тогда
		Если ДокументJSON.shipper.Свойство("name") Тогда
			Возврат Строка(ДокументJSON.shipper.name);
		КонецЕсли;
	КонецЕсли;
	Возврат "";
КонецФункции

&НаСервере
Функция СуммаДокументаИзJSON(ДокументJSON)
	Если ДокументJSON.Свойство("totals") И ТипЗнч(ДокументJSON.totals) = Тип("Структура") Тогда
		Если ДокументJSON.totals.Свойство("total_with_vat") Тогда
			Возврат Число(ДокументJSON.totals.total_with_vat);
		КонецЕсли;
	КонецЕсли;
	Сумма = 0;
	Если ДокументJSON.Свойство("items") И ТипЗнч(ДокументJSON.items) = Тип("Массив") Тогда
		Для Каждого СтрокаТовара Из ДокументJSON.items Цикл
			Если ТипЗнч(СтрокаТовара) = Тип("Структура") И СтрокаТовара.Свойство("total_with_vat") Тогда
				Сумма = Сумма + Число(СтрокаТовара.total_with_vat);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Сумма;
КонецФункции

&НаСервере
Функция КлючСтрокиДокумента(СтрокаДокумента)
	Если ЗначениеЗаполнено(СтрокаДокумента.АдресРезультатаРаспознавания) Тогда
		Возврат СтрокаДокумента.АдресРезультатаРаспознавания;
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаДокумента.ИдентификаторФайла) Тогда
		Возврат Строка(СтрокаДокумента.ИдентификаторФайла);
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаДокумента.АдресХранилища) Тогда
		Возврат Строка(СтрокаДокумента.АдресХранилища);
	КонецЕсли;
	Возврат Строка(СтрокаДокумента.ИмяФайла);
КонецФункции

&НаСервере
Процедура ОбновитьСчетчикиСтатусовНаСервере()
	Счетчик_ВсеДокументы = СписокДокументов.Количество();
	Счетчик_Распознан = 0;
	Счетчик_НаРаспознавании = 0;
	Счетчик_Ошибки = 0;
	Счетчик_СозданВ1С = 0;
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		Код = СтрокаДокумента.КодСтатуса;
		Если Не ЗначениеЗаполнено(Код) Тогда
			Код = КодСтатусаПоТексту(СтрокаДокумента.Статус);
		КонецЕсли;
		Если Код = "Распознан" Или Код = "ГотовКСозданию" Тогда
			Счетчик_Распознан = Счетчик_Распознан + 1;
		ИначеЕсли Код = "НаРаспознавании" Тогда
			Счетчик_НаРаспознавании = Счетчик_НаРаспознавании + 1;
		ИначеЕсли Код = "Ошибка" Тогда
			Счетчик_Ошибки = Счетчик_Ошибки + 1;
		ИначеЕсли Код = "СозданВ1С" Тогда
			Счетчик_СозданВ1С = Счетчик_СозданВ1С + 1;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура УстановитьАдресРезультатаПрикрепленногоФайлаНаСервере(КлючФайла, АдресРезультата)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Если СтрокаФайла.ИдентификаторФайла = КлючФайла
			Или СтрокаФайла.АдресХранилища = КлючФайла
			Или СтрокаФайла.ИмяФайла = КлючФайла Тогда
			СтрокаФайла.АдресРезультатаРаспознавания = АдресРезультата;
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСтатусПрикрепленногоФайлаНаСервере(КлючФайла, Статус)
	
	Для Каждого СтрокаФайла Из СписокДокументов Цикл
		Если КлючСтрокиДокумента(СтрокаФайла) = КлючФайла Тогда
			СтрокаФайла.Статус = Статус;
			СтрокаФайла.КодСтатуса = КодСтатусаПоТексту(Статус);
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьОтборСпискаДокументовНаСервере()
	// Отбор строк таблицы выполняется на клиенте (см. ПрименитьОтборСпискаДокументов).
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьОтборСпискаДокументов()
	
	ПрименитьОтборСпискаДокументовВнутренний(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьОтборСпискаДокументовВнутренний(СбросПериодовВыполнен)
	
	НаименованиеПоставщика = "";
	Если ЗначениеЗаполнено(Отбор_Поставщик) Тогда
		НаименованиеПоставщика = НаименованиеКонтрагентаДляОтбораНаСервере(Отбор_Поставщик);
	КонецЕсли;
	
	КлючевыеСлова = СокрЛП(Отбор_КлючевыеСлова);
	ВидимыхСтрок = 0;
	
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		Соответствует = Истина;
		Код = СтрокаДокумента.КодСтатуса;
		Если Не ЗначениеЗаполнено(Код) Тогда
			Код = КодСтатусаПоТекстуНаСервере(СтрокаДокумента.Статус);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекущийФильтрСтатуса) Тогда
			Если ТекущийФильтрСтатуса = "Распознан" Тогда
				Соответствует = (Код = "Распознан" Или Код = "ГотовКСозданию");
			Иначе
				Соответствует = (Код = ТекущийФильтрСтатуса);
			КонецЕсли;
		КонецЕсли;
		
		Если Соответствует И ЗначениеЗаполнено(НаименованиеПоставщика) Тогда
			Соответствует = (Найти(НРег(Строка(СтрокаДокумента.Поставщик)), НРег(НаименованиеПоставщика)) > 0);
		КонецЕсли;
		
		Если Соответствует И ЗначениеЗаполнено(КлючевыеСлова) Тогда
			ТекстПоиска = НРег(Строка(СтрокаДокумента.ПредставлениеДокумента) + " " + Строка(СтрокаДокумента.Поставщик) + " " + Строка(СтрокаДокумента.ИмяФайла));
			Соответствует = (Найти(ТекстПоиска, НРег(КлючевыеСлова)) > 0);
		КонецЕсли;
		
		Если Соответствует Тогда
			Соответствует = СтрокаПопадаетВПериод(СтрокаДокумента.ДатаЗагрузки, Отбор_ПериодЗагрузки);
		КонецЕсли;
		
		Если Соответствует Тогда
			Соответствует = СтрокаПопадаетВПериод(СтрокаДокумента.ДатаДокумента, Отбор_ПериодДокумента);
		КонецЕсли;
		
		СтрокаДокумента.СоответствуетОтбору = Соответствует;
		Если Соответствует Тогда
			ВидимыхСтрок = ВидимыхСтрок + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Если СписокДокументов.Количество() > 0
		И ВидимыхСтрок = 0
		И Не СбросПериодовВыполнен Тогда
		Отбор_ПериодДокумента = Новый СтандартныйПериод;
		Отбор_ПериодЗагрузки = Новый СтандартныйПериод;
		ПрименитьОтборСпискаДокументовВнутренний(Истина);
		Возврат;
	КонецЕсли;
	
	Элементы.СписокДокументов.ОтборСтрок = Новый ФиксированнаяСтруктура("СоответствуетОтбору", Истина);
	
КонецПроцедуры

&НаКлиенте
Функция СтрокаПопадаетВПериод(ДатаСтроки, Период)
	
	Если Период = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Период.ДатаНачала) И Не ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Строки без даты не отсекаются периодом — иначе после повторного входа список пустой.
	Если Не ЗначениеЗаполнено(ДатаСтроки) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Период.ДатаНачала) И ЗначениеЗаполнено(ДатаСтроки) И ДатаСтроки < Период.ДатаНачала Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Период.ДатаОкончания) И ЗначениеЗаполнено(ДатаСтроки) И ДатаСтроки > Период.ДатаОкончания Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция НаименованиеКонтрагентаДляОтбораНаСервере(Контрагент)
	
	Попытка
		Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Контрагент, "Наименование");
	Исключение
		Возврат Строка(Контрагент);
	КонецПопытки;
	
КонецФункции

&НаСервере
Функция КодСтатусаПоТекстуНаСервере(ТекстСтатуса)
	Возврат КодСтатусаПоТексту(ТекстСтатуса);
КонецФункции

&НаСервере
Процедура ЗаполнитьДеталиВыбранногоДокументаНаСервере(КлючФайла)
	
	Если Не ЗначениеЗаполнено(КлючФайла) Тогда
		Возврат;
	КонецЕсли;
	
	СохранитьСостояниеРаспознаванияТекущегоДокументаВРезультатыНаСервере();
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		Возврат;
	КонецЕсли;
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	ДанныеФайла = ?(СоответствиеРезультатов <> Неопределено, СоответствиеРезультатов.Получить(КлючФайла), Неопределено);
	Если ДанныеФайла = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	КлючДеталейДокумента = КлючФайла;
	ПрименитьДанныеФайлаКФормеРаспознаванияНаСервере(ДанныеФайла);
	
КонецПроцедуры

&НаСервере
Функция ПодготовитьДанныеМастераСозданияНаСервере(СтрокиДляСоздания)
	
	ДанныеПоФайлам = Новый Соответствие;
	Значение = РеквизитФормыВЗначение("Объект");
	АлгоритмПоиска = ПолучитьАлгоритмПоискаНоменклатуры();
	
	Для Каждого СтрокаПараметра Из СтрокиДляСоздания Цикл
		
		Если ТипЗнч(СтрокаПараметра) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		КлючФайла = ?(СтрокаПараметра.Свойство("КлючФайла"), СтрокаПараметра.КлючФайла, "");
		Если Не ЗначениеЗаполнено(КлючФайла) Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеДокумента = Новый Структура;
		ДанныеДокумента.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
		ДанныеДокумента.Вставить("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
		ДанныеДокумента.Вставить("ТаблицаНоменклатуры", Неопределено);
		
		ДанныеФайла = Неопределено;
		ДокументJSON = Неопределено;
		Товары = Неопределено;
		
		ДанныеФайла = ПолучитьДанныеФайлаРаспознаванияПоКлючуНаСервере(КлючФайла);
		Если ДанныеФайла <> Неопределено Тогда
			ДокументJSON = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
			Товары = ?(ДанныеФайла.Свойство("Товары"), ДанныеФайла.Товары, Неопределено);
		КонецЕсли;
		
		Если КлючФайла = КлючДеталейДокумента Тогда
			ДанныеДокумента.Организация = РаспознаннаяОрганизация;
			ДанныеДокумента.Контрагент = РаспознанныйКонтрагент;
			ДанныеДокумента.ТаблицаНоменклатуры = ПолучитьТаблицуНоменклатурыДляМастераСозданияНаСервере(
				ДанныеФайла,
				Товары,
				ДокументJSON,
				Значение,
				АлгоритмПоиска);
		Иначе
			Если ДанныеФайла <> Неопределено Тогда
				РеквизитыШапки = Значение.ОпределитьОрганизациюИКонтрагентаПоДокументу(ДокументJSON, СтруктураНастроек);
				ДанныеДокумента.Организация = РеквизитыШапки.Организация;
				ДанныеДокумента.Контрагент = РеквизитыШапки.Контрагент;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДанныеДокумента.Контрагент) Тогда
			ТекстПоставщика = ?(СтрокаПараметра.Свойство("Поставщик"), СтрокаПараметра.Поставщик, "");
			Если Не ЗначениеЗаполнено(ТекстПоставщика) Тогда
				ТекстПоставщика = ПоставщикСтрокиСпискаПоКлючуНаСервере(КлючФайла);
			КонецЕсли;
			ДанныеДокумента.Контрагент = Значение.НайтиКонтрагентаПоТекстуПоставщика(ТекстПоставщика, СтруктураНастроек);
		КонецЕсли;
		
		Если КлючФайла <> КлючДеталейДокумента И ДанныеФайла <> Неопределено Тогда
			КонтрагентИД = Значение.КонтрагентИДДляСопоставленияНоменклатуры(ДокументJSON, ДанныеДокумента.Контрагент);
			ДанныеДокумента.ТаблицаНоменклатуры = ПолучитьТаблицуНоменклатурыДляМастераСозданияНаСервере(
				ДанныеФайла,
				Товары,
				ДокументJSON,
				Значение,
				АлгоритмПоиска,
				КонтрагентИД);
		КонецЕсли;
		
		ДанныеПоФайлам.Вставить(КлючФайла, ДанныеДокумента);
		
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ДанныеПоФайлам, УникальныйИдентификатор);
	
КонецФункции

// Адреса исходных файлов (скан/PDF) для прикрепления к создаваемым документам.
&НаСервере
Функция ПодготовитьАдресаИсходныхФайловДляСозданияНаСервере(СтрокиДляСоздания)
	
	ФайлыПоКлючам = Новый Соответствие;
	
	Для Каждого СтрокаПараметра Из СтрокиДляСоздания Цикл
		
		Если ТипЗнч(СтрокаПараметра) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		КлючФайла = ?(СтрокаПараметра.Свойство("КлючФайла"), СтрокаПараметра.КлючФайла, "");
		Если Не ЗначениеЗаполнено(КлючФайла) Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеИсходногоФайла = ПолучитьДанныеИсходногоФайлаПоКлючуНаСервере(КлючФайла);
		Если ДанныеИсходногоФайла <> Неопределено Тогда
			ФайлыПоКлючам.Вставить(КлючФайла, ДанныеИсходногоФайла);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ФайлыПоКлючам, УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеИсходногоФайлаПоКлючуНаСервере(КлючФайла)
	
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		Если КлючСтрокиДокумента(СтрокаДокумента) <> КлючФайла Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаДокумента.АдресХранилища) Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		ДвоичныеДанные = ПолучитьДвоичныеДанныеФайлаДляПросмотраНаСервере(СтрокаДокумента.АдресХранилища);
		Если ДвоичныеДанные = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Результат = Новый Структура;
		Результат.Вставить("АдресХранилища", ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор));
		Результат.Вставить("ИмяФайла", ?(ЗначениеЗаполнено(СтрокаДокумента.ИмяФайла), СтрокаДокумента.ИмяФайла, "document.pdf"));
		Возврат Результат;
		
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ПолучитьТаблицуНоменклатурыДляМастераСозданияНаСервере(
	ДанныеФайла,
	Товары,
	ДокументJSON,
	ЗначениеОбработки,
	АлгоритмПоиска,
	КонтрагентИД = "")
	
	ТаблицаФормы = РеквизитФормыВЗначение("РаспознаннаяНоменклатура").Скопировать();
	Если ТаблицаФормы.Количество() > 0 Тогда
		ТаблицаНоменклатуры = ТаблицаФормы;
	Иначе
		ТаблицаСохраненная = ПолучитьСохраненнуюТаблицуНоменклатурыИзДанныхФайлаНаСервере(ДанныеФайла);
		Если ТаблицаСохраненная <> Неопределено Тогда
			ТаблицаНоменклатуры = ТаблицаСохраненная;
		Иначе
			ТаблицаНоменклатуры = ТаблицаФормы;
			ТаблицаНоменклатуры.Очистить();
			Если КонтрагентИД = "" Тогда
				КонтрагентИД = ЗначениеОбработки.КонтрагентИДДляСопоставленияНоменклатуры(ДокументJSON, РаспознанныйКонтрагент);
			КонецЕсли;
			ЗначениеОбработки.ЗаполнитьСтрокиРаспознаннойНоменклатуры(
				Товары,
				ТаблицаНоменклатуры,
				АлгоритмПоиска,
				СтруктураНастроек,
				КонтрагентИД);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТаблицаНоменклатуры;
	
КонецФункции

&НаСервере
Функция ПолучитьСохраненнуюТаблицуНоменклатурыИзДанныхФайлаНаСервере(ДанныеФайла)
	
	Если ДанныеФайла = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ДанныеФайла.Свойство("ТаблицаНоменклатурыФормы")
		И ТипЗнч(ДанныеФайла.ТаблицаНоменклатурыФормы) = Тип("ТаблицаЗначений")
		И ДанныеФайла.ТаблицаНоменклатурыФормы.Количество() > 0 Тогда
		ТаблицаНоменклатуры = ДанныеФайла.ТаблицаНоменклатурыФормы.Скопировать();
		ЗначениеОбработки = РеквизитФормыВЗначение("Объект");
		ЗначениеОбработки.ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры);
		Возврат ТаблицаНоменклатуры;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ПолучитьДанныеФайлаРаспознаванияПоКлючуНаСервере(КлючФайла)
	
	Если Не ЗначениеЗаполнено(РезультатыФайловРаспознавания) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СоответствиеРезультатов = ПолучитьИзВременногоХранилища(РезультатыФайловРаспознавания);
	Если СоответствиеРезультатов = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СоответствиеРезультатов.Получить(КлючФайла);
	
КонецФункции

&НаСервере
Функция ПоставщикСтрокиСпискаПоКлючуНаСервере(КлючФайла)
	
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		Если КлючСтрокиДокумента(СтрокаДокумента) = КлючФайла Тогда
			Возврат Строка(СтрокаДокумента.Поставщик);
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПолучитьОтмеченныеСтрокиДляСозданияНаСервере()
	Результат = Новый Массив;
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		Если Не СтрокаДокумента.Пометка Тогда
			Продолжить;
		КонецЕсли;
		Если Не СтрокаПодходитДляСозданияДокумента(СтрокаДокумента) Тогда
			Продолжить;
		КонецЕсли;
		СтруктураСтроки = Новый Структура;
		СтруктураСтроки.Вставить("КлючФайла", КлючСтрокиДокумента(СтрокаДокумента));
		СтруктураСтроки.Вставить("ИдентификаторФайла", Строка(СтрокаДокумента.ИдентификаторФайла));
		СтруктураСтроки.Вставить("ПредставлениеДокумента", Строка(СтрокаДокумента.ПредставлениеДокумента));
		СтруктураСтроки.Вставить("Поставщик", Строка(СтрокаДокумента.Поставщик));
		Результат.Добавить(СтруктураСтроки);
	КонецЦикла;
	Возврат Результат;
КонецФункции

&НаСервере
Функция СтрокаПодходитДляСозданияДокумента(СтрокаДокумента)
	
	Код = СтрокаДокумента.КодСтатуса;
	Если Не ЗначениеЗаполнено(Код) Тогда
		Код = КодСтатусаПоТексту(СтрокаДокумента.Статус);
	КонецЕсли;
	
	Если Код <> "Распознан" И Код <> "ГотовКСозданию" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаДокумента.Документ1С) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ТекстПодсказкиВыбораДокументовДляСоздания()
	
	Возврат НСтр("ru = 'В таблице документов отметьте флажком (первая колонка) строки со статусом «Распознан» или «Готов к созданию», затем нажмите «Создать документы».'");
	
КонецФункции

&НаСервере
Функция ПопробоватьВзятьТекущуюСтрокуДляСозданияНаСервере(ИдентификаторСтроки = Неопределено)
	
	Результат = Новый Массив;
	Если ИдентификаторСтроки = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтрокаДокумента = СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
	Если СтрокаДокумента = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не СтрокаПодходитДляСозданияДокумента(СтрокаДокумента) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СтрокаДокумента.Пометка = Истина;
	СтруктураСтроки = Новый Структура;
	СтруктураСтроки.Вставить("КлючФайла", КлючСтрокиДокумента(СтрокаДокумента));
	СтруктураСтроки.Вставить("ИдентификаторФайла", Строка(СтрокаДокумента.ИдентификаторФайла));
	СтруктураСтроки.Вставить("ПредставлениеДокумента", Строка(СтрокаДокумента.ПредставлениеДокумента));
	СтруктураСтроки.Вставить("Поставщик", Строка(СтрокаДокумента.Поставщик));
	Результат.Добавить(СтруктураСтроки);
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ТекстПодсказкиВыбораДокументовДляСозданияНаСервере(ИдентификаторСтроки = Неопределено)
	
	Если ИдентификаторСтроки <> Неопределено Тогда
		СтрокаДокумента = СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если СтрокаДокумента <> Неопределено И ЗначениеЗаполнено(СтрокаДокумента.Документ1С) Тогда
			Возврат СтрШаблон(
				НСтр("ru = 'По документу «%1» уже создан документ 1С. Повторное создание недоступно.'"),
				Строка(СтрокаДокумента.ПредставлениеДокумента));
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстПодсказкиВыбораДокументовДляСоздания();
	
КонецФункции

&НаСервере
Функция АдресРезультатовДляМастераНаСервере()
	Возврат РезультатыФайловРаспознавания;
КонецФункции

&НаСервере
Функция АдресНастроекДляМастераНаСервере()
	Возврат ПоместитьВоВременноеХранилище(СтруктураНастроек, УникальныйИдентификатор);
КонецФункции

&НаСервере
Процедура ПрименитьСозданныеДокументыНаСервере(СозданныеДокументы)
	Если ТипЗнч(СозданныеДокументы) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	Для Каждого Элемент Из СозданныеДокументы Цикл
		Если ТипЗнч(Элемент) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		КлючФайла = ?(Элемент.Свойство("КлючФайла"), Элемент.КлючФайла, "");
		ДокументСсылка = ?(Элемент.Свойство("Документ1С"), Элемент.Документ1С, Неопределено);
		Для Каждого СтрокаДокумента Из СписокДокументов Цикл
			Если КлючСтрокиДокумента(СтрокаДокумента) = КлючФайла Тогда
				СтрокаДокумента.Документ1С = ДокументСсылка;
				УстановитьКодСтатусаСтроки(СтрокаДокумента, "СозданВ1С");
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	ОбновитьСчетчикиСтатусовНаСервере();
	СохранитьРеестрДокументовНаСервере();
КонецПроцедуры

&НаСервере
Функция ПопробоватьПоставитьВОчередьРаспознавания(ПараметрыОтправки)
	ТаблицаФайлов = ПолучитьИзВременногоХранилища(ПараметрыОтправки.АдресТаблицыФайлов);
	Если ТаблицаФайлов = Неопределено Или ТаблицаФайлов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Значение = РеквизитФормыВЗначение("Объект");
	АдресAPI = ?(ЗначениеЗаполнено(АдресAPIСтатусаРаспознавания), АдресAPIСтатусаРаспознавания, ПараметрыОтправки.АдресAPI);
	РезультатОчереди = Значение.ПоставитьВОчередьРаспознавание(АдресAPI, ПараметрыОтправки.ТокенAPI, ТаблицаФайлов, ПараметрыОтправки.ПараметрыЗапроса);
	Если РезультатОчереди = Неопределено Или Не РезультатОчереди.Успех Тогда
		Возврат Неопределено;
	КонецЕсли;
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		ОбновитьСтатусФайлаПередОтправкой(
			?(ТаблицаФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено, СтрокаФайла.ИдентификаторФайла, ""),
			СтрокаФайла.АдресХранилища,
			СтрокаФайла.ИмяФайла,
			НСтр("ru = 'На распознавании'"),
			"НаРаспознавании");
		НоваяСтрока = ЗаданияРаспознавания.Добавить();
		НоваяСтрока.ИдентификаторЗадания = РезультатОчереди.JobId;
		НоваяСтрока.КлючФайла = КлючФайлаИзТаблицы(СтрокаФайла);
		НоваяСтрока.СтатусЗадания = "Выполняется";
		НоваяСтрока.ДатаОтправки = ТекущаяДата();
	КонецЦикла;
	СохранитьРеестрДокументовНаСервере();
	Возврат РезультатОчереди;
КонецФункции

&НаСервере
Функция КлючФайлаИзТаблицы(СтрокаФайла)
	Попытка
		Если ЗначениеЗаполнено(СтрокаФайла.ИдентификаторФайла) Тогда
			Возврат Строка(СтрокаФайла.ИдентификаторФайла);
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Строка(СтрокаФайла.АдресХранилища);
КонецФункции

&НаСервере
Функция ПроверитьСтатусыЗаданийНаСервере()
	ЕстьНезавершенные = Ложь;
	Если ЗаданияРаспознавания.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	Значение = РеквизитФормыВЗначение("Объект");
	АдресAPI = ?(ЗначениеЗаполнено(АдресAPIСтатусаРаспознавания), АдресAPIСтатусаРаспознавания, АдресAPIРаспознавания);
	Идентификаторы = Новый Соответствие;
	Для Каждого Задание Из ЗаданияРаспознавания Цикл
		Если Задание.СтатусЗадания = "Выполнено" Или Задание.СтатусЗадания = "Ошибка" Тогда
			Продолжить;
		КонецЕсли;
		Идентификаторы.Вставить(Задание.ИдентификаторЗадания, Истина);
	КонецЦикла;
	Для Каждого ПараИд Из Идентификаторы Цикл
		JobId = ПараИд.Ключ;
		Статус = Значение.ПолучитьСтатусРаспознавания(АдресAPI, ТокенAPIРаспознавания, JobId);
		Если Статус = Неопределено Тогда
			ЕстьНезавершенные = Истина;
			Продолжить;
		КонецЕсли;
		Если Статус.Свойство("Готово") И Статус.Готово Тогда
			ОбработатьЗавершениеЗаданияНаСервере(JobId, Статус);
		Иначе
			ЕстьНезавершенные = Истина;
		КонецЕсли;
	КонецЦикла;
	ОбновитьСчетчикиСтатусовНаСервере();
	Возврат ЕстьНезавершенные;
КонецФункции

&НаСервере
Процедура ОбработатьЗавершениеЗаданияНаСервере(JobId, Статус)
	Для Каждого Задание Из ЗаданияРаспознавания Цикл
		Если Задание.ИдентификаторЗадания <> JobId Тогда
			Продолжить;
		КонецЕсли;
		Если Статус.Успех Тогда
			Задание.СтатусЗадания = "Выполнено";
		Иначе
			Задание.СтатусЗадания = "Ошибка";
			Задание.ТекстОшибки = ?(Статус.Свойство("ОписаниеОшибки"), Статус.ОписаниеОшибки, "");
		КонецЕсли;
	КонецЦикла;
	Если Статус.Свойство("РезультатыФайлов") Тогда
		СохранитьРезультатыФайловРаспознаванияНаСервере(Статус.РезультатыФайлов);
		Для Каждого ЭлементРезультата Из Статус.РезультатыФайлов Цикл
			УстановитьАдресРезультатаПрикрепленногоФайлаНаСервере(ЭлементРезультата.Ключ, ЭлементРезультата.Ключ);
		КонецЦикла;
		ОбновитьПоляСтрокДокументовПоРезультатамНаСервере();
	КонецЕсли;
	Если Статус.Свойство("СтатусыФайлов") Тогда
		Для Каждого ЭлементСтатуса Из Статус.СтатусыФайлов Цикл
			УстановитьСтатусПрикрепленногоФайлаНаСервере(ЭлементСтатуса.Ключ, ЭлементСтатуса.Значение);
		КонецЦикла;
		ОбновитьКодыСтатусовПоТекстуНаСервере();
	КонецЕсли;
	СохранитьРеестрДокументовНаСервере();
КонецПроцедуры

