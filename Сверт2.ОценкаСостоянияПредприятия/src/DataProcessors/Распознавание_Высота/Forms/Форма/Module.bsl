		ЧастиИмени[ЧастиИмени.ВГраница()] = ИмяФормы;
		Возврат СтрСоединить(ЧастиИмени, ".");
	КонецЕсли;
	
	Возврат ПрефиксИмениФормОбработки() + ИмяФормы;
	
