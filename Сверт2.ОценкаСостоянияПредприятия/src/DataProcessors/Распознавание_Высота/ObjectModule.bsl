Функция РеквизитыУчастникаДокумента(Участник)
	
	Результат = Новый Структура("Наименование, ИНН, КПП", "", "", "");
	
	Если Участник = Неопределено Или ТипЗнч(Участник) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.Наименование = ТекстовоеПолеУчастника(Участник, "name");
	Если Не ЗначениеЗаполнено(Результат.Наименование) Тогда
		Результат.Наименование = ТекстовоеПолеУчастника(Участник, "full_name");
	КонецЕсли;
	
	Результат.ИНН = НормализоватьИННКПП(ТекстовоеПолеУчастника(Участник, "inn"));
	Если Не ЗначениеЗаполнено(Результат.ИНН) Тогда
		Результат.ИНН = НормализоватьИННКПП(ТекстовоеПолеУчастника(Участник, "tax_id"));
	КонецЕсли;
	
	Результат.КПП = НормализоватьИННКПП(ТекстовоеПолеУчастника(Участник, "kpp"));
	
	Возврат Результат;
	
