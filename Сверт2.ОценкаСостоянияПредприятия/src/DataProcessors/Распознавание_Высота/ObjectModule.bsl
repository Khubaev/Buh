Функция ПолучитьОписаниеКонфигурации() Экспорт
	
	Конфигурация = Новый Структура("Крат,Полн,Лок");
	
	Имя = Метаданные.Имя;
	Версия = Метаданные.Версия;
		
	МассивРелизов = ТТН_РазложитьСтрокуВМассивПодстрок(Версия,".");
	
	Если Найти(Имя,"УправлениеТорговлей") > 0
		
		//2022.03.26 ( Есть варианты Алко-торговли на базе 10 и 11 УТ
		Или Найти(Имя,"KT2000_Alcohol_Trade") > 0 Тогда
		// ) 2022.03.26
		
		//2021.09.13 ( УправлениеТорговлей_CRMПроф 1.1 - считаем за УТ10.3
		Если Имя = "УправлениеТорговлей_CRMПроф" Тогда
			Если МассивРелизов[0] = "1" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.3");
			КонецЕсли;
		// ) 2021.09.13
		
		//2022.03.21 ( УправлениеТорговлей_CRM_2 считаем за УТ 11
		ИначеЕсли Найти(Имя,"УправлениеТорговлей_CRM_2") > 0 Тогда
			Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.4");
		// ) 2022.03.21
		
		//Казахские УТ
		ИначеЕсли Найти(Имя,"УправлениеТорговлейДляКазахстана") > 0 Тогда
			
			Если МассивРелизов[0] = "2" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.3","KAZ");
			// 2023.05.05 ( Попробуем считать ее аналогом российской УТ11		
			ИначеЕсли МассивРелизов[0] = "3" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.5","KAZ");
			КонецЕсли;
			// ) 2023.05.05
			
		ИначеЕсли МассивРелизов[0] = "10" Тогда
			
			Если МассивРелизов[1] = "1" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.1");
			ИначеЕсли МассивРелизов[1] = "2" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.2");
			ИначеЕсли МассивРелизов[1] = "3" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.3");
			КонецЕсли;
			
		ИначеЕсли МассивРелизов[0] = "11" Тогда
			
			Если МассивРелизов[1] = "0" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.0");
			ИначеЕсли МассивРелизов[1] = "1" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.1");
			ИначеЕсли МассивРелизов[1] = "2" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.2");
			ИначеЕсли МассивРелизов[1] = "3" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.3");
			ИначеЕсли МассивРелизов[1] = "4" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.4");
			ИначеЕсли МассивРелизов[1] = "5" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.5");
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Найти(Имя,"УправлениеТорговымПредприятиемДляКазахстана") > 0 Тогда
			
			Если МассивРелизов[0] = "2" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УТ10","УТ10.3","KAZ");
			КонецЕсли;
		
	//2021.10.18 ( по утверждению разработчиков отраслевого решения их конфигурация с таким именем выполнена на основании УТ11,
	//будем надеяться, что при жестком сравнении строки наименования с заданной, пересечений с другими решениями не будет.
	ИначеЕсли Имя = "МониторингТранспорта" Или Имя = "МониторингТранспорта_CRM" Тогда
		
		//По релизам их разбивка пока непонятна, исходим из актуальной на текущий момент УТ11
		Конфигурация = Новый Структура("Крат,Полн,Лок","УТ11","УТ11.5");
		// ) 2021.10.18
		
	//2022.06.28 ( БИТСтоматология
	ИначеЕсли Имя = "БИТСтоматология" Тогда
		
		Конфигурация = Новый Структура("Крат,Полн,Лок","БИТСтоматология","БИТСтоматология");
	// ) 2022.06.28
	
	//2022.06.28 ( БИТ: Управление медицинским центром
	ИначеЕсли Найти(Имя,"БИТУправлениеМедицинскимЦентром") > 0 Тогда
		
		Конфигурация = Новый Структура("Крат,Полн,Лок","БИТУМЦ","БИТУМЦ");
	// ) 2022.06.28
		
	ИначеЕсли Найти(Имя,"УправлениеНебольшойФирмой") > 0
		Или Найти(Имя,"УправлениеНашейФирмой") > 0
		Или Найти(Имя,"УНФУправлениеПредприятиемОбщепита") > 0 Тогда
		
		Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ");
		
		//2022.09.18 ( Вышла УНФ 3.0, по идее логика заполнения счета-фактуры переехала из последних 1.6.
		//Пока определим как последние 1.6, при необходимости определим "персональный" идентификатор конфы
		Если МассивРелизов[0] = "3" Тогда
			Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1618");
		Иначе
		// ) 2022.09.18
		
			//2019.12.16 ( Теперь нужно дробить УНФ по версиям, в частности, в 1.6.18 по-новому заполняется счет-фактура на основании Приходной накладной
			Если МассивРелизов[1] = "6" Тогда
				Если МассивРелизов[2] < "18" Тогда
					Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1616");
				Иначе
					Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1618");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// ) 2019.12.16
		
		Если Имя = "УправлениеНебольшойФирмойДляКазахстана" Тогда
			Конфигурация.Лок = "KAZ";
		КонецЕсли;
		
	//2023.05.04 (	
	ИначеЕсли Найти(Имя,"УправлениеПредприятиемЖКХ") > 0 Тогда
		Конфигурация = Новый Структура("Крат,Полн,Лок","УПП","УПП");
	// ) 2023.05.04
		
	ИначеЕсли Найти(Имя,"УправлениеПредприятием") > 0 Тогда
		Конфигурация = Новый Структура("Крат,Полн,Лок","ERP","ERP");
		
	ИначеЕсли Найти(Имя,"ERPУправлениеСтроительнойОрганизацией") > 0 Тогда
		Конфигурация = Новый Структура("Крат,Полн,Лок","ERP","ERP");
		
	ИначеЕсли Найти(Имя,"EPM2_УправлениеПроектнойОрганизацией") > 0 Тогда
		Конфигурация = Новый Структура("Крат,Полн,Лок","ERP","ERP");
		
	ИначеЕсли Найти(Имя,"АгропромышленныйКомплекс") > 0 Тогда
		Конфигурация = Новый Структура("Крат,Полн,Лок","ERP","ERP");
		
	ИначеЕсли Найти(Имя,"ГорнодобывающаяПромышленность2") > 0 Тогда
