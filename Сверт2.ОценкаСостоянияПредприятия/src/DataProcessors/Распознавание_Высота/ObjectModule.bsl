				|ГДЕ
				|	НЕ Единицы.ПометкаУдаления
				|	И (Единицы.НаименованиеПолное = &Наименование
				|		ИЛИ Единицы.НаименованиеПолное ПОДОБНО &Шаблон)";
			Запрос.УстановитьПараметр("Наименование", НаименованиеПоиска);
			Запрос.УстановитьПараметр("Шаблон", "%" + НаименованиеПоиска + "%");
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				Возврат Выборка.Ссылка;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Единица = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию(НаименованиеПоиска, Истина);
		Если ЗначениеЗаполнено(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	
КонецФункции

// Поиск в классификаторе единиц измерения (ОКЕИ) только по коду.
//
Функция НайтиЕдиницуКлассификатораПоКоду(КодОКЕИ)
	
	ПустаяЕдиница = Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	КодНормализованный = НормализоватьКодОКЕИ(КодОКЕИ);
	
	Если Не ЗначениеЗаполнено(КодНормализованный) Тогда
		Возврат ПустаяЕдиница;
	КонецЕсли;
	
	КодБезВедущихНулей = УбратьВедущиеНули(КодНормализованный);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Единицы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК Единицы
		|ГДЕ
		|	НЕ Единицы.ПометкаУдаления
		|	И (Единицы.Код = &КодОКЕИ
		|		ИЛИ Единицы.Код = &КодБезВедущихНулей)";
	
	Запрос.УстановитьПараметр("КодОКЕИ", КодНормализованный);
	Запрос.УстановитьПараметр("КодБезВедущихНулей", КодБезВедущихНулей);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		Возврат ПустаяЕдиница;
	КонецПопытки;
	
	Попытка
		Единица = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(КодНормализованный);
		Если ЗначениеЗаполнено(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
		Если КодБезВедущихНулей <> КодНормализованный Тогда
			Единица = Справочники.КлассификаторЕдиницИзмерения.НайтиПоКоду(КодБезВедущихНулей);
			Если ЗначениеЗаполнено(Единица) Тогда
				Возврат Единица;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат ПустаяЕдиница;
	
КонецФункции

Функция НормализоватьКодОКЕИ(КодОКЕИ)
	
	Код = СокрЛП(Строка(КодОКЕИ));
	Код = СтрЗаменить(Код, " ", "");
	
	Если Не ЗначениеЗаполнено(Код) Тогда
		Возврат "";
	КонецЕсли;
	
	Пока СтрДлина(Код) < 3 Цикл
		Код = "0" + Код;
	КонецЦикла;
	
	Возврат Код;
	
КонецФункции

Функция УбратьВедущиеНули(Код)
	
	Результат = Код;
	Пока СтрДлина(Результат) > 1 И Лев(Результат, 1) = "0" Цикл
		Результат = Сред(Результат, 2);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КодОКЕИПоСинониму(НаименованиеЕИ)
	
	НормализованноеНаименование = НормализоватьНаименованиеЕдиницы(НаименованиеЕИ);
	Если Не ЗначениеЗаполнено(НормализованноеНаименование) Тогда
		Возврат "";
