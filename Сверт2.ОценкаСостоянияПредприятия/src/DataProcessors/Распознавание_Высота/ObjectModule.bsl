// Нечёткий поиск по значимым словам наименования (ПОДОБНО), если точное совпадение не найдено.
//
Функция НайтиВСправочникеПоНаименованиюНечетко(ИмяСправочника, Наименование)
	
	Наименование = СокрЛП(Строка(Наименование));
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Слова = ЗначимыеСловаНаименованияДляПоиска(Наименование);
	Если Слова.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Условия = Новый Массив;
	Для Индекс = 0 По Слова.Количество() - 1 Цикл
		ИмяПараметра = "Слово" + Формат(Индекс, "ЧГ=0");
		Шаблон = СтрШаблон(
			"(Спр.Наименование ПОДОБНО &%1 ИЛИ Спр.НаименованиеПолное ПОДОБНО &%1)",
			ИмяПараметра);
		Условия.Добавить(Шаблон);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Спр.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.%1 КАК Спр
		|ГДЕ
		|	НЕ Спр.ПометкаУдаления
		|	И (%2)",
		ИмяСправочника,
		СтрСоединить(Условия, " ИЛИ "));
	
	Для Индекс = 0 По Слова.Количество() - 1 Цикл
		ИмяПараметра = "Слово" + Формат(Индекс, "ЧГ=0");
		Запрос.УстановитьПараметр(ИмяПараметра, "%" + Слова[Индекс] + "%");
	КонецЦикла;
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		Запрос.Текст = СтрШаблон(
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Спр.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.%1 КАК Спр
			|ГДЕ
			|	НЕ Спр.ПометкаУдаления
			|	И (%2)",
			ИмяСправочника,
			СтрЗаменить(СтрСоединить(Условия, " ИЛИ "), "НаименованиеПолное", "Наименование"));
		Для Индекс = 0 По Слова.Количество() - 1 Цикл
			ИмяПараметра = "Слово" + Формат(Индекс, "ЧГ=0");
			Запрос.УстановитьПараметр(ИмяПараметра, "%" + Слова[Индекс] + "%");
		КонецЦикла;
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецПопытки;
	
	Возврат Неопределено;
	
КонецФункции

Функция ЗначимыеСловаНаименованияДляПоиска(Наименование)
	
	Результат = Новый Массив;
	Нормализованное = НРег(Наименование);
	Нормализованное = СтрЗаменить(Нормализованное, """", " ");
	Нормализованное = СтрЗаменить(Нормализованное, "«", " ");
	Нормализованное = СтрЗаменить(Нормализованное, "»", " ");
	Нормализованное = СтрЗаменить(Нормализованное, "'", " ");
	
	СтопСлова = "ооо,оао,зао,пао,ип,ао,компания,фирма,общество";
	МассивСлов = ТТН_РазложитьСтрокуВМассивПодстрок(Нормализованное, " ,.;:-", Ложь);
	
	Для Каждого Слово Из МассивСлов Цикл
		Слово = СокрЛП(Слово);
		Если СтрДлина(Слово) < 3 Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(СтопСлова, Слово) > 0 Тогда
			Продолжить;
		КонецЕсли;
		Результат.Добавить(Слово);
	КонецЦикла;
	
	Если Результат.Количество() = 0 Тогда
		Для Каждого Слово Из МассивСлов Цикл
			Слово = СокрЛП(Слово);
			Если СтрДлина(Слово) >= 3 Тогда
				Результат.Добавить(Слово);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПредставлениеЕдиницыИзмеренияИзРаспознавания(КодОКЕИ, НаименованиеЕИ)
	
	Если ЗначениеЗаполнено(КодОКЕИ) И ЗначениеЗаполнено(НаименованиеЕИ) Тогда
		Возврат СтрШаблон("%1 (%2)", НаименованиеЕИ, КодОКЕИ);
	ИначеЕсли ЗначениеЗаполнено(НаименованиеЕИ) Тогда
		Возврат НаименованиеЕИ;
	ИначеЕсли ЗначениеЗаполнено(КодОКЕИ) Тогда
		Возврат КодОКЕИ;
	КонецЕсли;
	
	Возврат "";
	
