Функция СведенияОВнешнейОбработке() Экспорт
	
	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке();
	ПараметрыРегистрации.Вставить("Версия", "0.1");
	ПараметрыРегистрации.Наименование = НСтр("ru = 'Распознавание_Высота'");
	ПараметрыРегистрации.Вид = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиДополнительнаяОбработка();
	//ПараметрыРегистрации.Назначение.Добавить("Документ.ПоступлениеТоваровУслуг");
	
	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	НоваяКоманда.Представление = НСтр("ru = 'Распознавание_Высота'");
	НоваяКоманда.Идентификатор = "Распознавание_Высота";
	//НоваяКоманда.Использование = ДополнительныеОтчетыИОбработкиКлиентСервер.;
		
	Возврат ПараметрыРегистрации;
	
КонецФункции

Процедура Печать(МассивОбъектов, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Распознавание_Высота") Тогда
		СформироватьДокументWord(КоллекцияПечатныхФорм, МассивОбъектов, ОбъектыПечати, ПараметрыВывода);
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьДокументWord(КоллекцияПечатныхФорм, МассивОбъектов, ОбъектыПечати = Неопределено, ПараметрыВывода = Неопределено) Экспорт
	ИмяФайла = ИмяФайлаПечатнойФормы(МассивОбъектов);
	ОписаниеПечатнойФормы = КоллекцияПечатныхФорм.Найти(ВРег("Распознавание_Высота"), "ИмяВРЕГ");
	Если ОписаниеПечатнойФормы <> Неопределено Тогда
		ОписаниеПечатнойФормы.ИмяФайлаПечатнойФормы = ИмяФайла + ".docx";
	КонецЕсли;
	
	Если МассивОбъектов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Ссылка = МассивОбъектов[0]; 
	
	ТипМакета = "DOCX"; // Эта переменная уже устарела, и необходимость ее использования отпадет в новых версиях БСП, однако пока (БСП 3.1.9.232) она все еще нужна.
	
	// Получаем структуру со сведениями о нашей печатной форме из коллекции печатных форм. В эту же структуру позже будет помещен сформированный нами документ Word.    
	ПечатнаяФорма = УправлениеПечатью.СведенияОПечатнойФорме(КоллекцияПечатныхФорм, "ТТН_Высота");
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ПечатнаяФорма.ТабличныйДокумент = ТабличныйДокумент;
	
	Если ОбъектыПечати = Неопределено Тогда
		ОбъектыПечати = Новый СписокЗначений;
	КонецЕсли;
	
	// Привязка к документу ДО формирования DOCX — иначе в веб-клиенте пустой список ПолучаемыеФайлы.
	ПривязатьОбъектПечатиКТабличномуДокументу(ПечатнаяФорма.ТабличныйДокумент, ОбъектыПечати, Ссылка);
	
	// Инициализируем макет документа Word на основании подготовленного заранее шаблона.
	ДвоичныеДанныеМакета = ПолучитьМакет("ПФ_DOC_Макет");
	Если ДвоичныеДанныеМакета = Неопределено Или ДвоичныеДанныеМакета.Размер() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Макет ПФ_DOC_Макет пуст. Добавьте DOCX-файл в макет обработки и пересоберите EPF.'");
	КонецЕсли;
	СсылкаНаМакет = УправлениеПечатью.ИнициализироватьМакетОфисногоДокумента(ДвоичныеДанныеМакета, ТипМакета, "Распознавание_Высота");
	
	// Инициализируем печатную форму Word (docx), используя сформированный на прошлом этапе макет.
	ПечатнаяФормаWord = УправлениеПечатью.ИнициализироватьПечатнуюФорму(ТипМакета, СсылкаНаМакет.НастройкиСтраницыМакета, СсылкаНаМакет);
	
	// Подготовим параметры нашей печатной формы.
	//СтруктураПараметров = ПолучитьТабличнуюЧастьДокумента(Ссылка);
	
	// Приступаем к заполнению нашего документа. Начинаем с объявления областей.
	СтруктураОбластей = Новый Структура;
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Заголовок", "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Данные", "СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Подвал", "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Заголовок",						"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ЗаголовокШапки",					"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Шапка",							"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ШапкаТаблицы",					"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ШапкаТаблицыПодвал",				"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "СтрокаТаблицы",					"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ШапкаТаблицыСНДС",				"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "СтрокаСНДС",						"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "СтрокаТовары",					"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "СтрокаТаблицаГрафика",			"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ИтоговаяСтрока",					"СтрокаТаблицы");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "Подвал",							"Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(СтруктураОбластей, "ИтогоТаблицы",					"Общая");
	
	
	ДанныеОбъекта = Новый Структура;
	
	ДанныеОбъекта.Вставить("НомерДокумента", ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Ссылка.Номер));	
	ДанныеОбъекта.Вставить("ДатаДокумента", Формат(Ссылка.Дата, "ДФ=dd.MM.yyyy"));
	ДанныеОбъекта.Вставить("Контрагент", Ссылка.Контрагент);	
	ДанныеОбъекта.Вставить("Организация", Ссылка.Организация);
	ДанныеОбъекта.Вставить("Склад", Ссылка.Склад);	


	ЕстьПрисоединенныеОбласти = Ложь;
	Если ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, "Заголовок", ДанныеОбъекта) Тогда
		ЕстьПрисоединенныеОбласти = Истина;
	КонецЕсли;
	Если ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, "ЗаголовокШапки", ДанныеОбъекта) Тогда
		ЕстьПрисоединенныеОбласти = Истина;
	КонецЕсли;
	Если ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, "Шапка", ДанныеОбъекта) Тогда
		ЕстьПрисоединенныеОбласти = Истина;
	КонецЕсли;
	Если ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, "ШапкаТаблицы", ДанныеОбъекта) Тогда
		ЕстьПрисоединенныеОбласти = Истина;
	КонецЕсли;
	
	//Товары = Ссылка.Товары;
	//Если Товары.Количество() = 0 Тогда 
	//	ВызватьИсключение "Табличная часть пустая добавьте номенклатуру в табличную часть";
	//КонецЕсли;
	//
	//НомерСтроки = 1;     
	////НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
	////ТабличнаяЧастьВторогоЛиста.НоменклатураПредставление,
	////ТабличнаяЧастьВторогоЛиста.ХарактеристикаПредставление,
	////,
	////,
	////ДопПараметрыПредставлениеНоменклатуры);
	//ВсегоНаименований = 0; 
	//СуммаНДС = 0;
	//СуммаСНДС = 0;
	//СрокПроизводства = 0;
	//Для Каждого СтрокаТовар из Товары Цикл 
	//	ДанныеСтроки = Новый Структура();
	//	ДанныеСтроки.Вставить("Номер",НомерСтроки);
	//	ДанныеСтроки.Вставить("Ед",СтрокаТовар.ЕдиницаИзмерения);
	//	ДанныеСтроки.Вставить("Номенклатура",СтрокаТовар.Номенклатура);
	//	ДанныеСтроки.Вставить("Количество",СтрокаТовар.Количество);
	//			
	//	Область = УправлениеПечатью.ОбластьМакета(СсылкаНаМакет,СтруктураОбластей.СтрокаТаблицы);
	//	УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФормаWord, Область, ДанныеСтроки, Ложь);
	//	НомерСтроки = НомерСтроки + 1;
	//КонецЦикла;
	//
	//	
	Если ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, "Подвал", ДанныеОбъекта) Тогда
		ЕстьПрисоединенныеОбласти = Истина;
	КонецЕсли;
	
	Если Не ЕстьПрисоединенныеОбласти Тогда
		ВызватьИсключение НСтр("ru = 'В DOCX-макете не найдены области Заголовок/Шапка/Подвал. Проверьте имена областей {v8 Область.<Имя>} в макете ПФ_DOC_Макет.'");
	КонецЕсли;
	
	АдресХранилищаОфисныйДокумент = УправлениеПечатью.СформироватьДокумент(ПечатнаяФормаWord);
	АдресХранилищаОфисныйДокумент = ИзвлечьАдресВременногоХранилища(АдресХранилищаОфисныйДокумент);
	
	Если Не ЗначениеЗаполнено(АдресХранилищаОфисныйДокумент) Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось сформировать заполненный DOCX. Проверьте настройку формирования офисных документов на сервере 1С: Microsoft Word/LibreOffice должен быть доступен серверному процессу 1С.'");
	КонецЕсли;
	
	// Копируем файл ДО ОчиститьСсылки — иначе адрес из СформироватьДокумент становится недействительным.
	АдресДляКлиента = ПоместитьОфисныйДокументВХранилищеПечати(АдресХранилищаОфисныйДокумент, ПараметрыВывода);
	
	// Очищаем ссылки — удаляются временные файлы офисного COM, адрес АдресДляКлиента уже в отдельном хранилище.
	УправлениеПечатью.ОчиститьСсылки(ПечатнаяФормаWord, Ложь);
	УправлениеПечатью.ОчиститьСсылки(СсылкаНаМакет);
	
	ОфисныеДокументы = Новый Соответствие;
	ОфисныеДокументы.Вставить(АдресДляКлиента, ИмяФайла + ".docx");
	ПечатнаяФорма.ОфисныеДокументы = ОфисныеДокументы;
	
КонецПроцедуры   


Функция КонтактныеЛица(Партнер)
	КонтактЛица = Новый Массив();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтактныеЛицаПартнеров.ДолжностьПоВизитке КАК ДолжностьПоВизитке,
		|	КонтактныеЛицаПартнеров.Наименование КАК Наименование,
		|	КонтактныеЛицаПартнеров.ДополнительнаяИнформация КАК ДополнительнаяИнформация
		|ИЗ
		|	Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|ГДЕ
		|	КонтактныеЛицаПартнеров.Владелец = &Владелец";
	
	Запрос.УстановитьПараметр("Владелец", Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		Если ЗначениеЗаполнено (Выборка.ДолжностьПоВизитке) И ЗначениеЗаполнено (Выборка.Наименование) Тогда
			СтруктураДолжности = Новый Структура();
			СтруктураДолжности.Вставить("ДолжностьПоВизитке",Выборка.ДолжностьПоВизитке);
			СтруктураДолжности.Вставить("Наименование",Выборка.Наименование);
			КонтактЛица.Добавить(СтруктураДолжности);
		КонецЕсли;
		
	КонецЦикла;
	Возврат КонтактЛица	
КонецФункции


#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Присоединяет область Word-макета, если такая область есть в DOCX.
//
Функция ПрисоединитьОбластьWordЕслиЕсть(ПечатнаяФормаWord, СсылкаНаМакет, СтруктураОбластей, ИмяОбласти, ДанныеОбласти)
	
	ОписаниеОбласти = Неопределено;
	Если Не СтруктураОбластей.Свойство(ИмяОбласти, ОписаниеОбласти) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Попытка
		Область = УправлениеПечатью.ОбластьМакета(СсылкаНаМакет, ОписаниеОбласти);
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
	Если Область = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УправлениеПечатью.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФормаWord, Область, ДанныеОбласти, Ложь);
	
	Возврат Истина;
	
КонецФункции

// Связывает табличный документ и объект печати именованной областью (требование БСП для веб-клиента).
//
Процедура ПривязатьОбъектПечатиКТабличномуДокументу(ТабличныйДокумент, ОбъектыПечати, Ссылка)
	
	НомерСтрокиНачало = 1;
	ТабличныйДокумент.Область(НомерСтрокиНачало, 1, НомерСтрокиНачало, 1).Текст = " ";
	
	ИмяОбласти = "Документ_" + Формат(ОбъектыПечати.Количество() + 1, "ЧГ=0");
	ТабличныйДокумент.Область(НомерСтрокиНачало, , НомерСтрокиНачало).Имя = ИмяОбласти;
	ОбъектыПечати.Добавить(Ссылка, ИмяОбласти);
	
КонецПроцедуры

// Извлекает адрес хранилища из результата СформироватьДокумент (строка или структура БСП).
//
Функция ИзвлечьАдресВременногоХранилища(РезультатФормирования)
	
	Если Не ЗначениеЗаполнено(РезультатФормирования) Тогда
		Возврат "";
	КонецЕсли;
	
	Если ТипЗнч(РезультатФормирования) = Тип("Структура") Тогда
		Если РезультатФормирования.Свойство("Адрес") Тогда
			Возврат РезультатФормирования.Адрес;
		ИначеЕсли РезультатФормирования.Свойство("АдресХранилища") Тогда
			Возврат РезультатФормирования.АдресХранилища;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатФормирования;
	
КонецФункции

// Помещает DOCX в хранилище, доступное форме «Печать документов» / веб-клиенту.
//
Функция ПоместитьОфисныйДокументВХранилищеПечати(АдресОфисногоДокумента, ПараметрыВывода)
	
	Если Не ЗначениеЗаполнено(АдресОфисногоДокумента) Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось получить файл печатной формы: адрес во временном хранилище пуст.'");
	КонецЕсли;
	
	ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресОфисногоДокумента);
	
	ИдентификаторХранилища = Неопределено;
	Если ПараметрыВывода <> Неопределено
		И ТипЗнч(ПараметрыВывода) = Тип("Структура")
		И ПараметрыВывода.Свойство("ИдентификаторЗадания") Тогда
		ИдентификаторХранилища = ПараметрыВывода.ИдентификаторЗадания;
	КонецЕсли;
	
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные, ИдентификаторХранилища);
	
КонецФункции

// Возвращает имя файла печатной формы без расширения.
//
//
Функция ИмяФайлаПечатнойФормы(МассивОбъектов)
	
	Если МассивОбъектов.Количество() = 0 Тогда
		Возврат НСтр("ru = 'ТТН'");
	КонецЕсли;
	
	Ссылка = МассивОбъектов[0];
	НомерНаПечать = "";
	
	Попытка
		НомерНаПечать = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Ссылка.Номер);
	Исключение
		НомерНаПечать = Строка(Ссылка.Номер);
	КонецПопытки;
	
	Если ЗначениеЗаполнено(НомерНаПечать) Тогда
		Возврат СтрШаблон(НСтр("ru = 'ТТН %1'"), НомерНаПечать);
	КонецЕсли;
	
	Возврат НСтр("ru = 'ТТН'");
	
КонецФункции

Функция ПолучитьТабличнуюЧастьДокумента(Ссылка)

	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	РеализацияТоваровУслуг.Номер КАК Номер,
	                      |	РеализацияТоваровУслуг.Дата КАК Дата,
	                      |	РеализацияТоваровУслуг.Склад КАК Склад,
	                      |	РеализацияТоваровУслуг.Контрагент КАК Контрагент,
	                      |	РеализацияТоваровУслуг.Организация КАК Организация
	                      |ИЗ
	                      |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	                      |ГДЕ
	                      |	РеализацияТоваровУслуг.Ссылка = &Ссылка
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ
	                      |	Товары.Номенклатура КАК Номенклатура,
	                      |	Товары.Количество КАК Количество,
	                      |	Товары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	                      |	Товары.НомерСтроки КАК НомерСтроки
	                      |ИЗ
	                      |	Документ.РеализацияТоваровУслуг.Товары КАК Товары
	                      |ГДЕ
	                      |	Товары.Ссылка = &Ссылка"); 
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	ВыборкаШапка = МассивРезультатов[0].Выбрать();
	ВыборкаШапка.Следующий();
	
	ПараметрыШапки = Новый Структура;
	ПараметрыШапки.Вставить("Номер", Неопределено);
	ПараметрыШапки.Вставить("Склад", Неопределено);
	ПараметрыШапки.Вставить("Контрагент", Неопределено);
	ПараметрыШапки.Вставить("Организация",Неопределено);
	ПараметрыШапки.Вставить("Дата", Неопределено);
	
	ЗаполнитьЗначенияСвойств(ПараметрыШапки, ВыборкаШапка);
	
	ТаблицаТоваров = МассивРезультатов[1].Выгрузить();
	МассивТоваров = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаТоваров);	

	Возврат Новый Структура("ПараметрыШапки, МассивТоваров", ПараметрыШапки, МассивТоваров);

КонецФункции

// Отправляет прикрепленные файлы на сервис распознавания по HTTP (POST, JSON).
// Тело запроса: {"files":[{"filename":"...","content":"<base64>"}, ...]}
// При необходимости адаптируйте СформироватьТелоЗапросаРаспознавания() под ваш API.
//
Функция ОтправитьФайлыНаРаспознавание(АдресAPI, ТокенAPI, ТаблицаФайлов, ПараметрыЗапроса = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТелоОтвета", "");
	Результат.Вставить("ОписаниеОшибки", "");
	
	Если Не ЗначениеЗаполнено(АдресAPI) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не указан адрес API распознавания.'");
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаФайлов = Неопределено Или ТаблицаФайлов.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Нет файлов для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ЗаписатьСобытиеРаспознавания(
		"Отправка",
		СтрШаблон(
			НСтр("ru = 'Старт отправки файлов: %1 шт., endpoint: %2'"),
			Формат(ТаблицаФайлов.Количество(), "ЧГ=0"),
			АдресAPI));
	
	Попытка
		ПараметрыHTTP = РазобратьАдресAPI(АдресAPI);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецПопытки;
	
	ТелоЗапроса = СформироватьТелоЗапросаРаспознавания(ТаблицаФайлов, Результат, ПараметрыЗапроса);
	Если Не ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(ПараметрыHTTP.Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	
	Если ЗначениеЗаполнено(ТокенAPI) Тогда
		Запрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенAPI);
	КонецЕсли;
	
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Попытка
		Ответ = ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, 600);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецПопытки;
	
	Результат.КодОтвета = Ответ.КодСостояния;
	Результат.ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
	РазборОтвета = РазобратьОтветРаспознавания(Результат.ТелоОтвета);
	Результат.Вставить("ТекстДляПользователя", РазборОтвета.ТекстДляПользователя);
	Результат.Вставить("ДокументРаспознавания", РазборОтвета.Документ);
	Результат.Вставить("ТоварыРаспознавания", РазборОтвета.Товары);
	Результат.Вставить("МетаданныеОтвета", РазборОтвета.Метаданные);
	
	КодОтветаУспешен = (Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300);
	Результат.Успех = КодОтветаУспешен И РазборОтвета.Успех;
	
	Если Не Результат.Успех И ЗначениеЗаполнено(РазборОтвета.Ошибка) Тогда
		Результат.ОписаниеОшибки = РазборОтвета.Ошибка;
	КонецЕсли;
	
	Если Не Результат.Успех И ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Сервер вернул код %1.'"),
			Формат(Ответ.КодСостояния, "ЧГ=0"));
	КонецЕсли;
	
	ЗаписатьСобытиеРаспознавания(
		"Ответ",
		СтрШаблон(
			НСтр("ru = 'Ответ сервера: HTTP %1, успех: %2'"),
			Формат(Ответ.КодСостояния, "ЧГ=0"),
			?(Результат.Успех, "Да", "Нет")),
		?(Результат.Успех, УровеньЖурналаРегистрации.Информация, УровеньЖурналаРегистрации.Ошибка));
	
	Возврат Результат;
	
КонецФункции

// Ставит файлы в очередь распознавания (двухфазная схема: submit -> status).
// Ожидаемый ответ: { job_id: "...", accepted: true } (поля могут отличаться).
//
Функция ПоставитьВОчередьРаспознавание(АдресAPI, ТокенAPI, ТаблицаФайлов, ПараметрыЗапроса = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТелоОтвета", "");
	Результат.Вставить("ОписаниеОшибки", "");
	Результат.Вставить("JobId", "");
	
	Если ТаблицаФайлов = Неопределено Или ТаблицаФайлов.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Нет файлов для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	Параметры = Новый Структура;
	Если ПараметрыЗапроса <> Неопределено И ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		Для Каждого Параметр Из ПараметрыЗапроса Цикл
			Параметры.Вставить(Параметр.Ключ, Параметр.Значение);
		КонецЦикла;
	КонецЕсли;
	Параметры.Вставить("action", "submit");
	
	ТелоЗапроса = СформироватьТелоЗапросаРаспознавания(ТаблицаФайлов, Результат, Параметры);
	Если Не ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	HTTP = ВыполнитьHTTPPostJSON(АдресAPI, ТокенAPI, ТелоЗапроса);
	Результат.КодОтвета = HTTP.КодОтвета;
	Результат.ТелоОтвета = HTTP.ТелоОтвета;
	Результат.ОписаниеОшибки = HTTP.ОписаниеОшибки;
	
	Если Не HTTP.Успех Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.JobId = ИзвлечьJobIdИзОтвета(HTTP.ТелоОтвета);
	Если Не ЗначениеЗаполнено(Результат.JobId) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Сервис не вернул job_id.'");
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Возврат Результат;
	
КонецФункции

// Получает статус очереди распознавания по job_id.
// Ожидаемый ответ: { done: true/false, files: [ { key, result: {...} } ] }
//
Функция ПолучитьСтатусРаспознавания(АдресAPI, ТокенAPI, JobId) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТелоОтвета", "");
	Результат.Вставить("ОписаниеОшибки", "");
	Результат.Вставить("Готово", Ложь);
	Результат.Вставить("СтатусыФайлов", Новый Соответствие);
	Результат.Вставить("РезультатыФайлов", Новый Соответствие);
	
	Если Не ЗначениеЗаполнено(JobId) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не задан job_id.'");
		Возврат Результат;
	КонецЕсли;
	
	Тело = Новый Структура;
	Тело.Вставить("action", "status");
	Тело.Вставить("job_id", JobId);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);
	ТелоЗапроса = ЗаписьJSON.Закрыть();
	
	HTTP = ВыполнитьHTTPPostJSON(АдресAPI, ТокенAPI, ТелоЗапроса);
	Результат.КодОтвета = HTTP.КодОтвета;
	Результат.ТелоОтвета = HTTP.ТелоОтвета;
	Результат.ОписаниеОшибки = HTTP.ОписаниеОшибки;
	
	Если Не HTTP.Успех Тогда
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Корень = ПрочитатьJSONИзСтроки(HTTP.ТелоОтвета);
	Исключение
		Результат.ОписаниеОшибки = НСтр("ru = 'Некорректный JSON статуса.'");
		Возврат Результат;
	КонецПопытки;
	
	Если ТипЗнч(Корень) = Тип("Массив") Тогда
		Если Корень.Количество() > 0 Тогда
			Корень = Корень[0];
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Корень) <> Тип("Структура") Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Неожиданный формат статуса.'");
		Возврат Результат;
	КонецЕсли;
	
	Если Корень.Свойство("done") Тогда
		Результат.Готово = Корень.done;
	ИначеЕсли Корень.Свойство("ready") Тогда
		Результат.Готово = Корень.ready;
	КонецЕсли;
	
	Если Корень.Свойство("files") И ТипЗнч(Корень.files) = Тип("Массив") Тогда
		Для Каждого Ф Из Корень.files Цикл
			Если ТипЗнч(Ф) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			
			Ключ = ?(Ф.Свойство("key"), Ф.key, ?(Ф.Свойство("id"), Ф.id, ""));
			Если Не ЗначениеЗаполнено(Ключ) И Ф.Свойство("filename") Тогда
				Ключ = Ф.filename;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(Ключ) Тогда
				Продолжить;
			КонецЕсли;
			
			Если Ф.Свойство("status") Тогда
				Результат.СтатусыФайлов.Вставить(Ключ, Строка(Ф.status));
			КонецЕсли;
			
			Если Ф.Свойство("result") Тогда
				// result может быть структурой или строкой JSON. Прогоняем через стандартный парсер распознавания.
				Если ТипЗнч(Ф.result) = Тип("Строка") Тогда
					ТелоРезультата = Ф.result;
				Иначе
					ЗаписьJSON = Новый ЗаписьJSON;
					ЗаписьJSON.УстановитьСтроку();
					ЗаписатьJSON(ЗаписьJSON, Ф.result);
					ТелоРезультата = ЗаписьJSON.Закрыть();
				КонецЕсли;
				
				Разбор = РазобратьОтветРаспознавания(ТелоРезультата);
				
				ДанныеФайла = Новый Структура;
				ДанныеФайла.Вставить("Успех", Разбор.Успех);
				ДанныеФайла.Вставить("ОписаниеОшибки", Разбор.Ошибка);
				ДанныеФайла.Вставить("ТекстДляПользователя", Разбор.ТекстДляПользователя);
				ДанныеФайла.Вставить("Товары", Разбор.Товары);
				ДанныеФайла.Вставить("Документ", Разбор.Документ);
				ДанныеФайла.Вставить("Метаданные", Разбор.Метаданные);
				ДанныеФайла.Вставить("ТелоОтвета", ТелоРезультата);
				
				Результат.РезультатыФайлов.Вставить(Ключ, ДанныеФайла);
				
				Если Результат.СтатусыФайлов.Получить(Ключ) = Неопределено Тогда
					Результат.СтатусыФайлов.Вставить(Ключ, ?(Разбор.Успех, НСтр("ru='Распознан'"), Разбор.Ошибка));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Возврат Результат;
	
КонецФункции

Функция ИзвлечьJobIdИзОтвета(ТелоОтвета)
	
	Если Не ЗначениеЗаполнено(ТелоОтвета) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		Корень = ПрочитатьJSONИзСтроки(ТелоОтвета);
	Исключение
		Возврат "";
	КонецПопытки;
	
	Если ТипЗнч(Корень) = Тип("Массив") Тогда
		Если Корень.Количество() > 0 Тогда
			Корень = Корень[0];
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Корень) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Если Корень.Свойство("job_id") Тогда
		Возврат Строка(Корень.job_id);
	ИначеЕсли Корень.Свойство("jobId") Тогда
		Возврат Строка(Корень.jobId);
	ИначеЕсли Корень.Свойство("id") Тогда
		Возврат Строка(Корень.id);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ВыполнитьHTTPPostJSON(АдресAPI, ТокенAPI, ТелоЗапроса)
	
	Результат = Новый Структура("Успех, КодОтвета, ТелоОтвета, ОписаниеОшибки", Ложь, 0, "", "");
	
	Попытка
		ПараметрыHTTP = РазобратьАдресAPI(АдресAPI);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Запрос = Новый HTTPЗапрос(ПараметрыHTTP.Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	Если ЗначениеЗаполнено(ТокенAPI) Тогда
		Запрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенAPI);
	КонецЕсли;
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Попытка
		Ответ = ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, 60);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.КодОтвета = Ответ.КодСостояния;
	Результат.ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	Результат.Успех = (Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300);
	
	Если Не Результат.Успех И ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru='Сервер вернул код %1.'"), Формат(Ответ.КодСостояния, "ЧГ=0"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Точка входа фонового задания распознавания (параметры во временном хранилище).
//
Процедура ВыполнитьОтправкуНаРаспознаваниеФон(ПараметрыФона) Экспорт
	
	Данные = ПолучитьИзВременногоХранилища(ПараметрыФона.АдресПараметров);
	ТаблицаФайлов = ПолучитьИзВременногоХранилища(Данные.АдресТаблицыФайлов);
	
	Если ПараметрыФона.Свойство("ДополнительнаяОбработкаСсылка")
		И ЗначениеЗаполнено(ПараметрыФона.ДополнительнаяОбработкаСсылка) Тогда
		ОбъектОбработки = ДополнительныеОтчетыИОбработки.ОбъектВнешнейОбработки(
			ПараметрыФона.ДополнительнаяОбработкаСсылка);
		РезультатHTTP = ОбъектОбработки.ОтправитьФайлыНаРаспознавание(
			Данные.АдресAPI,
			Данные.ТокенAPI,
			ТаблицаФайлов,
			Данные.ПараметрыЗапроса);
	Иначе
		РезультатHTTP = ОтправитьФайлыНаРаспознавание(
			Данные.АдресAPI,
			Данные.ТокенAPI,
			ТаблицаФайлов,
			Данные.ПараметрыЗапроса);
	КонецЕсли;
	
	ПоместитьВоВременноеХранилище(РезультатHTTP, ПараметрыФона.АдресРезультата);
	
КонецПроцедуры

// Разбирает URL API (https://host:port/path).
//
Функция РазобратьАдресAPI(АдресAPI)
	
	АдресСтрокой = СокрЛП(АдресAPI);
	
	Попытка
		СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресСтрокой);
		Хост = СтруктураURI.Хост;
		Если Не ЗначениеЗаполнено(Хост) И СтруктураURI.Свойство("ИмяСервера") Тогда
			Хост = СтруктураURI.ИмяСервера;
		КонецЕсли;
		Путь = "/";
		Если СтруктураURI.Свойство("ПутьНаСервере") И ЗначениеЗаполнено(СтруктураURI.ПутьНаСервере) Тогда
			Путь = СтруктураURI.ПутьНаСервере;
		ИначеЕсли СтруктураURI.Свойство("Путь") И ЗначениеЗаполнено(СтруктураURI.Путь) Тогда
			Путь = СтруктураURI.Путь;
		КонецЕсли;
		Схема = "http";
		Если СтруктураURI.Свойство("Схема") Тогда
			Схема = СтруктураURI.Схема;
		КонецЕсли;
		Защищенное = (НРег(Схема) = "https");
		Порт = 0;
		Если СтруктураURI.Свойство("Порт") И ЗначениеЗаполнено(СтруктураURI.Порт) Тогда
			Порт = Число(СтруктураURI.Порт);
		КонецЕсли;
		Если Порт = 0 Тогда
			Порт = ?(Защищенное, 443, 80);
		КонецЕсли;
	Исключение
		ВызватьИсключение НСтр("ru = 'Некорректный адрес API. Укажите полный URL, например https://api.example.com/v1/recognize'");
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(Хост) Тогда
		ВызватьИсключение НСтр("ru = 'В адресе API не определён хост.'");
	КонецЕсли;
	
	Возврат Новый Структура("Хост, Порт, Путь, Схема, ЗащищенноеСоединение", Хост, Порт, Путь, Схема, Защищенное);
	
КонецФункции

// Прокси из настроек 1С; при отсутствии — прямое подключение (без системного прокси Windows).
//
Функция ПолучитьПроксиДляHTTPРаспознавания(Схема)
	
	Попытка
		Прокси = ПолучениеФайловИзИнтернета.ПолучитьПрокси(Схема);
	Исключение
		Прокси = Новый ИнтернетПрокси(Ложь);
	КонецПопытки;
	
	// Неопределено заставляет платформу брать системный прокси ОС — частая причина «Couldn't resolve proxy name».
	Если Прокси = Неопределено Тогда
		Прокси = Новый ИнтернетПрокси(Ложь);
	КонецЕсли;
	
	Возврат Прокси;
	
КонецФункции

// Создаёт HTTP-соединение с учётом прокси из настроек 1С.
//
Функция СоздатьHTTPСоединениеДляРаспознавания(ПараметрыHTTP, Таймаут, Прокси = Неопределено)
	
	Схема = "https";
	Если ПараметрыHTTP.Свойство("Схема") И ЗначениеЗаполнено(ПараметрыHTTP.Схема) Тогда
		Схема = ПараметрыHTTP.Схема;
	ИначеЕсли ПараметрыHTTP.ЗащищенноеСоединение Тогда
		Схема = "https";
	Иначе
		Схема = "http";
	КонецЕсли;
	
	Если Прокси = Неопределено Тогда
		Прокси = ПолучитьПроксиДляHTTPРаспознавания(Схема);
	КонецЕсли;
	
	Возврат Новый HTTPСоединение(
		ПараметрыHTTP.Хост,
		ПараметрыHTTP.Порт,
		,
		,
		Прокси,
		Таймаут,
		ПараметрыHTTP.ЗащищенноеСоединение);
	
КонецФункции

// Отправляет HTTP-запрос; при ошибке разрешения прокси повторяет без прокси.
//
Функция ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, Таймаут)
	
	Попытка
		Соединение = СоздатьHTTPСоединениеДляРаспознавания(ПараметрыHTTP, Таймаут);
		Возврат Соединение.ОтправитьДляОбработки(Запрос);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Если ЭтоОшибкаРазрешенияПрокси(ТекстОшибки) Тогда
			Соединение = СоздатьHTTPСоединениеДляРаспознавания(
				ПараметрыHTTP,
				Таймаут,
				Новый ИнтернетПрокси(Ложь));
			Возврат Соединение.ОтправитьДляОбработки(Запрос);
		КонецЕсли;
		ВызватьИсключение;
	КонецПопытки;
	
КонецФункции

Функция ЭтоОшибкаРазрешенияПрокси(ТекстОшибки)
	
	ТекстВерхРег = ВРег(ТекстОшибки);
	Возврат СтрНайти(ТекстВерхРег, "PROXY") > 0
		Или СтрНайти(ТекстВерхРег, "ПРОКСИ") > 0;
	
КонецФункции

// Разбирает ответ n8n: обёртка success/data + JSON документа М-15 (в т.ч. в markdown ```json).
//
Функция РазобратьОтветРаспознавания(ТелоОтвета) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Ошибка", "");
	Результат.Вставить("Метаданные", Новый Структура);
	Результат.Вставить("Документ", Новый Структура);
	Результат.Вставить("Товары", Новый Массив);
	Результат.Вставить("ТекстДляПользователя", "");
	
	Если Не ЗначениеЗаполнено(ТелоОтвета) Тогда
		Результат.Ошибка = НСтр("ru = 'Пустой ответ сервера.'");
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Корень = ПрочитатьJSONИзСтроки(ТелоОтвета);
	Исключение
		Результат.Ошибка = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Результат.ТекстДляПользователя = ТелоОтвета;
		Возврат Результат;
	КонецПопытки;
	
	Если ТипЗнч(Корень) = Тип("Массив") Тогда
		Если Корень.Количество() = 0 Тогда
			Результат.Ошибка = НСтр("ru = 'Ответ сервера — пустой массив.'");
			Возврат Результат;
		КонецЕсли;
		Корень = Корень[0];
	КонецЕсли;
	
	Если ТипЗнч(Корень) <> Тип("Структура") Тогда
		Результат.Ошибка = НСтр("ru = 'Неожиданный формат ответа (ожидалась структура JSON).'");
		Результат.ТекстДляПользователя = ТелоОтвета;
		Возврат Результат;
	КонецЕсли;

	// n8n может вернуть обёртку вида: { "body": {...} } или { "json": {...} }
	// В этом случае пытаемся извлечь корень документа для дальнейшего разбора.
	Если Корень.Свойство("body") Тогда
		Попытка
			Если ТипЗнч(Корень.body) = Тип("Строка") Тогда
				Корень = ПрочитатьJSONИзСтроки(Корень.body);
			ИначеЕсли ТипЗнч(Корень.body) = Тип("Структура") Тогда
				Корень = Корень.body;
			КонецЕсли;
		Исключение
			// игнорируем, если body не парсится как JSON
		КонецПопытки;
	КонецЕсли;
	
	Если Корень.Свойство("json") Тогда
		Попытка
			Если ТипЗнч(Корень.json) = Тип("Строка") Тогда
				Корень = ПрочитатьJSONИзСтроки(Корень.json);
			ИначеЕсли ТипЗнч(Корень.json) = Тип("Структура") Тогда
				Корень = Корень.json;
			КонецЕсли;
		Исключение
			// игнорируем
		КонецПопытки;
	КонецЕсли;
	
	ЗаполнитьМетаданныеОтвета(Результат.Метаданные, Корень);
	
	Если Корень.Свойство("success") И Корень.success = Ложь Тогда
		Результат.Ошибка = ТекстОшибкиИзСтруктуры(Корень);
		Результат.ТекстДляПользователя = Результат.Ошибка;
		Возврат Результат;
	КонецЕсли;
	
	Документ = Неопределено;
	
	Если Корень.Свойство("data") Тогда
		Документ = ДанныеJSONИзПоляОтвета(Корень.data);
	ИначеЕсли Корень.Свойство("recognition") Тогда
		Документ = ДанныеJSONИзПоляОтвета(Корень.recognition);
	КонецЕсли;

	// fallback: иногда n8n возвращает сам документ без data/recognition,
	// либо кладёт документ в другое поле.
	Если Документ = Неопределено Тогда
		Если Корень.Свойство("document") Тогда
			Документ = ДанныеJSONИзПоляОтвета(Корень.document);
		ИначеЕсли Корень.Свойство("items") И ТипЗнч(Корень.items) = Тип("Массив") Тогда
			Документ = Корень;
		ИначеЕсли Корень.Свойство("shipper") Или Корень.Свойство("consignee") Тогда
			Документ = Корень;
		// паспортные данные (другой сценарий распознавания)
		ИначеЕсли Корень.Свойство("passport") Тогда
			Документ = Корень.passport;
		КонецЕсли;
	КонецЕсли;
	
	Если Документ = Неопределено Тогда
		Результат.Ошибка = НСтр("ru = 'В ответе нет поля data с данными распознавания.'");
		Результат.ТекстДляПользователя = ЗначениеВJSONСтроку(Корень);
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(Документ) <> Тип("Структура") Тогда
		Результат.Ошибка = НСтр("ru = 'Поле data не содержит структуру документа.'");
		Результат.ТекстДляПользователя = ЗначениеВJSONСтроку(Документ);
		Возврат Результат;
	КонецЕсли;
	
	Результат.Документ = Документ;
	
	Если Документ.Свойство("items") И ТипЗнч(Документ.items) = Тип("Массив") Тогда
		Результат.Товары = Документ.items;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Результат.ТекстДляПользователя = СформироватьКраткоеПредставлениеДокумента(Документ, Результат.Метаданные);
	
	Возврат Результат;
	
КонецФункции

// Возвращает текст результата для поля формы.
//
Функция ПредставлениеОтветаРаспознавания(ТелоОтвета) Экспорт
	
	Возврат РазобратьОтветРаспознавания(ТелоОтвета).ТекстДляПользователя;
	
КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Возврат ПрочитатьJSON(ЧтениеJSON);
	
КонецФункции

// Убирает обёртку ```json ... ``` из ответа AI.
//
Функция ОчиститьJSONОтMarkdown(СтрокаJSON)
	
	Текст = СокрЛП(СтрокаJSON);
	
	Если Не СтрНачинаетсяС(Текст, "```") Тогда
		Возврат Текст;
	КонецЕсли;
	
	ПозицияПеревода = СтрНайти(Текст, Символы.ПС);
	Если ПозицияПеревода > 0 Тогда
		Текст = Сред(Текст, ПозицияПеревода + 1);
	КонецЕсли;
	
	ПозицияКонца = СтрНайти(Текст, "```", НаправлениеПоиска.СКонца);
	Если ПозицияКонца > 0 Тогда
		Текст = Лев(Текст, ПозицияКонца - 1);
	КонецЕсли;
	
	Возврат СокрЛП(Текст);
	
КонецФункции

Функция ДанныеJSONИзПоляОтвета(Значение)
	
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Возврат ПрочитатьJSONИзСтроки(ОчиститьJSONОтMarkdown(Значение));
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Процедура ЗаполнитьМетаданныеОтвета(Метаданные, Корень)
	
	Если Корень.Свойство("success") Тогда
		Метаданные.Вставить("success", Корень.success);
	КонецЕсли;
	
	Если Корень.Свойство("source") Тогда
		Метаданные.Вставить("source", Корень.source);
	КонецЕсли;
	
	Если Корень.Свойство("filename") Тогда
		Метаданные.Вставить("filename", Корень.filename);
	КонецЕсли;
	
	Если Корень.Свойство("document_id") Тогда
		Метаданные.Вставить("document_id", Корень.document_id);
	КонецЕсли;
	
	Если Корень.Свойство("document") Тогда
		Метаданные.Вставить("document", Корень.document);
	КонецЕсли;
	
КонецПроцедуры

Функция ТекстОшибкиИзСтруктуры(Данные)
	
	Если Данные.Свойство("error") И ЗначениеЗаполнено(Данные.error) Тогда
		Возврат Данные.error;
	КонецЕсли;
	
	Если Данные.Свойство("message") И ЗначениеЗаполнено(Данные.message) Тогда
		Возврат Данные.message;
	КонецЕсли;
	
	Возврат НСтр("ru = 'Сервер вернул success = false.'");
	
КонецФункции

Функция СформироватьКраткоеПредставлениеДокумента(Документ, Метаданные)
	
	Строки = Новый Массив;
	
	// Сценарий: распознан паспорт (passport:{...})
	Если ТипЗнч(Документ) = Тип("Структура")
		И (Документ.Свойство("фамилия") Или Документ.Свойство("серия") Или Документ.Свойство("номер")
			Или Документ.Свойство("датаРождения") Или Документ.Свойство("датаРожденияТекст")
			Или Документ.Свойство("датаВыдачи") Или Документ.Свойство("кемВыдан")) Тогда
		Возврат СформироватьКраткоеПредставлениеПаспорта(Документ, Метаданные);
	КонецЕсли;
	
	Если Метаданные.Свойство("document") И ЗначениеЗаполнено(Метаданные.document) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru = 'Документ 1С: %1'"), Метаданные.document));
	КонецЕсли;
	
	Если Метаданные.Свойство("filename") Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru = 'Файл: %1'"), Метаданные.filename));
	КонецЕсли;
	
	Если Документ.Свойство("document_type") Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru = 'Тип формы: %1'"), Документ.document_type));
	КонецЕсли;
	
	Если Документ.Свойство("document_number") И Документ.Свойство("document_date") Тогда
		Строки.Добавить(СтрШаблон(
			НСтр("ru = 'Накладная №%1 от %2'"),
			Документ.document_number,
			Документ.document_date));
	КонецЕсли;
	
	Если Документ.Свойство("shipper") И ТипЗнч(Документ.shipper) = Тип("Структура") Тогда
		Если Документ.shipper.Свойство("name") Тогда
			Строки.Добавить(СтрШаблон(НСтр("ru = 'Поставщик: %1'"), Документ.shipper.name));
		КонецЕсли;
	КонецЕсли;
	
	Если Документ.Свойство("consignee") И ТипЗнч(Документ.consignee) = Тип("Структура") Тогда
		Если Документ.consignee.Свойство("name") Тогда
			Строки.Добавить(СтрШаблон(НСтр("ru = 'Получатель: %1'"), Документ.consignee.name));
		КонецЕсли;
	КонецЕсли;
	
	КоличествоСтрок = 0;
	Если Документ.Свойство("items") И ТипЗнч(Документ.items) = Тип("Массив") Тогда
		КоличествоСтрок = Документ.items.Количество();
		Строки.Добавить(СтрШаблон(НСтр("ru = 'Строк товаров: %1'"), Формат(КоличествоСтрок, "ЧГ=0")));
	КонецЕсли;
	
	Если Документ.Свойство("totals") И ТипЗнч(Документ.totals) = Тип("Структура") Тогда
		Если Документ.totals.Свойство("total_with_vat") Тогда
			Строки.Добавить(СтрШаблон(
				НСтр("ru = 'Итого с НДС: %1'"),
				Формат(Документ.totals.total_with_vat, "ЧДЦ=2; ЧРД=.; ЧГ=3,0")));
		КонецЕсли;
	КонецЕсли;
	
	Строки.Добавить("");
	Строки.Добавить(НСтр("ru = '--- Строки ---'"));
	
	Если КоличествоСтрок > 0 Тогда
		Для Каждого СтрокаТовара Из Документ.items Цикл
			Если ТипЗнч(СтрокаТовара) <> Тип("Структура") Тогда
				Продолжить;
			КонецЕсли;
			Номер = ?(СтрокаТовара.Свойство("row_number"), СтрокаТовара.row_number, "");
			Наименование = ?(СтрокаТовара.Свойство("material_name"), СтрокаТовара.material_name, "");
			Количество = ?(СтрокаТовара.Свойство("quantity_released"), СтрокаТовара.quantity_released, 0);
			Сумма = ?(СтрокаТовара.Свойство("total_with_vat"), СтрокаТовара.total_with_vat, 0);
			Строки.Добавить(СтрШаблон(
				"%1 | %2 | %3 | %4",
				Номер,
				Наименование,
				Формат(Количество, "ЧДЦ=3; ЧРД=.; ЧГ=0"),
				Формат(Сумма, "ЧДЦ=2; ЧРД=.; ЧГ=0")));
		КонецЦикла;
	КонецЕсли;
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция СформироватьКраткоеПредставлениеПаспорта(Паспорт, Метаданные)
	
	Строки = Новый Массив;
	
	Если Метаданные <> Неопределено И ТипЗнч(Метаданные) = Тип("Структура") Тогда
		Если Метаданные.Свойство("filename") Тогда
			Строки.Добавить(СтрШаблон(НСтр("ru = 'Файл: %1'"), Метаданные.filename));
		КонецЕсли;
	КонецЕсли;
	
	Фамилия = ?(Паспорт.Свойство("фамилия") И ЗначениеЗаполнено(Паспорт.фамилия), Паспорт.фамилия, "");
	Имя = ?(Паспорт.Свойство("имя") И ЗначениеЗаполнено(Паспорт.имя), Паспорт.имя, "");
	Отчество = ?(Паспорт.Свойство("отчество") И ЗначениеЗаполнено(Паспорт.отчество), Паспорт.отчество, "");
	Пол = ?(Паспорт.Свойство("пол") И ЗначениеЗаполнено(Паспорт.пол), Паспорт.пол, "");
	
	ФИО = СокрЛП(СтрЗаменить(Фамилия + " " + Имя + " " + Отчество, "  ", " "));
	Если ЗначениеЗаполнено(ФИО) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='ФИО: %1'"), ФИО));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Пол) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='Пол: %1'"), Пол));
	КонецЕсли;
	
	ДатаРождТекст = ?(Паспорт.Свойство("датаРожденияТекст") И ЗначениеЗаполнено(Паспорт.датаРожденияТекст), Паспорт.датаРожденияТекст, "");
	Если ПустаяСтрока(ДатаРождТекст) И Паспорт.Свойство("датаРождения") И ЗначениеЗаполнено(Паспорт.датаРождения) Тогда
		ДатаРождТекст = Строка(Паспорт.датаРождения);
	КонецЕсли;
	Если ЗначениеЗаполнено(ДатаРождТекст) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='Дата рождения: %1'"), ДатаРождТекст));
	КонецЕсли;
	
	МестоРожд = ?(Паспорт.Свойство("местоРождения") И ЗначениеЗаполнено(Паспорт.местоРождения), Паспорт.местоРождения, "");
	Если ЗначениеЗаполнено(МестоРожд) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='Место рождения: %1'"), МестоРожд));
	КонецЕсли;
	
	Серия = ?(Паспорт.Свойство("серия") И ЗначениеЗаполнено(Паспорт.серия), Паспорт.серия, "");
	Номер = ?(Паспорт.Свойство("номер") И ЗначениеЗаполнено(Паспорт.номер), Паспорт.номер, "");
	Если ЗначениеЗаполнено(Серия) Или ЗначениеЗаполнено(Номер) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='Паспорт: %1 %2'"), Серия, Номер));
	КонецЕсли;
	
	КодПодразделения = ?(Паспорт.Свойство("кодПодразделения") И ЗначениеЗаполнено(Паспорт.кодПодразделения), Паспорт.кодПодразделения, "");
	Если ЗначениеЗаполнено(КодПодразделения) Тогда
		Строки.Добавить(СтрШаблон(НСтр("ru='Код подразделения: %1'"), КодПодразделения));
	КонецЕсли;
	
	КемВыдан = ?(Паспорт.Свойство("кемВыдан") И ЗначениеЗаполнено(Паспорт.кемВыдан), Паспорт.кемВыдан, "");
	ДатаВыдачиТекст = ?(Паспорт.Свойство("датаВыдачиТекст") И ЗначениеЗаполнено(Паспорт.датаВыдачиТекст), Паспорт.датаВыдачиТекст, "");
	Если ПустаяСтрока(ДатаВыдачиТекст) И Паспорт.Свойство("датаВыдачи") И ЗначениеЗаполнено(Паспорт.датаВыдачи) Тогда
		ДатаВыдачиТекст = Строка(Паспорт.датаВыдачи);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КемВыдан) Или ЗначениеЗаполнено(ДатаВыдачиТекст) Тогда
		Строки.Добавить(НСтр("ru='Выдан:'"));
		Если ЗначениеЗаполнено(ДатаВыдачиТекст) Тогда
			Строки.Добавить(СтрШаблон(НСтр("ru='  Дата: %1'"), ДатаВыдачиТекст));
		КонецЕсли;
		Если ЗначениеЗаполнено(КемВыдан) Тогда
			Строки.Добавить(СтрШаблон(НСтр("ru='  Кем: %1'"), КемВыдан));
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрСоединить(Строки, Символы.ПС);
	
КонецФункции

Функция ЗначениеВJSONСтроку(Значение)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Значение);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция СформироватьТелоЗапросаРаспознавания(ТаблицаФайлов, РезультатОтправки, ПараметрыЗапроса = Неопределено)
	
	МассивФайлов = Новый Массив;
	
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаФайла.АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(СтрокаФайла.АдресХранилища);
		Если ДвоичныеДанные = Неопределено Тогда
			РезультатОтправки.ОписаниеОшибки = СтрШаблон(
				НСтр("ru = 'Не удалось прочитать файл ""%1"" из временного хранилища.'"),
				СтрокаФайла.ИмяФайла);
			Возврат "";
		КонецЕсли;
		
		ОписаниеФайла = Новый Структура;
		// ключ для сопоставления результата с файлом в 1С
		Если ТаблицаФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
			ОписаниеФайла.Вставить("key", СтрокаФайла.ИдентификаторФайла);
		ИначеЕсли ТаблицаФайлов.Колонки.Найти("АдресХранилища") <> Неопределено Тогда
			ОписаниеФайла.Вставить("key", СтрокаФайла.АдресХранилища);
		КонецЕсли;
		ОписаниеФайла.Вставить("filename", СтрокаФайла.ИмяФайла);
		ОписаниеФайла.Вставить("content", Base64Строка(ДвоичныеДанные));
		МассивФайлов.Добавить(ОписаниеФайла);
		
	КонецЦикла;
	
	Если МассивФайлов.Количество() = 0 Тогда
		РезультатОтправки.ОписаниеОшибки = НСтр("ru = 'Нет доступных для отправки файлов.'");
		Возврат "";
	КонецЕсли;
	
	Тело = Новый Структура;
	Тело.Вставить("files", МассивФайлов);
	Тело.Вставить("source", "1c_ttn");
	
	Если ПараметрыЗапроса <> Неопределено
		И ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		
		Для Каждого Параметр Из ПараметрыЗапроса Цикл
			Тело.Вставить(Параметр.Ключ, Параметр.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

// Заполняет таблицу формы распознанной номенклатуры (колонки заданы в Form.xml).
// Номенклатура намеренно не сопоставляется автоматически — пользователь выбирает вручную
// или оставляет пустой для автосоздания при формировании документа.
//
Процедура ЗаполнитьСтрокиРаспознаннойНоменклатуры(
	ТоварыJSON,
	ТаблицаНоменклатуры,
	АлгоритмПоискаНоменклатуры = "Артикул,Наименование",
	СтруктураНастроек = Неопределено,
	КонтрагентИД = "") Экспорт
	
	ТаблицаНоменклатуры.Очистить();
	СчетчикСтрок = 0;
	
	Если ТоварыJSON = Неопределено Или ТипЗнч(ТоварыJSON) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаТовара Из ТоварыJSON Цикл
		
		Если ТипЗнч(СтрокаТовара) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Наименование = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "material_name", "")));
		Если Не ЗначениеЗаполнено(Наименование) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаНоменклатуры.Добавить();
		НоваяСтрока.Наименование = Наименование + МаркерСпособаСопоставления("Не найдено");
		НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
		СчетчикСтрок = СчетчикСтрок + 1;
		
		НоваяСтрока.Количество = ЧислоПоляРаспознавания(СтрокаТовара, "quantity_released", 0);
		
		ДанныеЕдиницы = ИзвлечьДанныеЕдиницыИзмеренияИзСтрокиТовара(СтрокаТовара);
		НоваяСтрока.ЕдиницаИзмерения = ДанныеЕдиницы.Представление;
		НоваяСтрока.ЕдиницаИзмеренияСсылка = НайтиЕдиницуИзмеренияДляСтроки(
			НоваяСтрока.Номенклатура,
			ДанныеЕдиницы.КодОКЕИ,
			ДанныеЕдиницы.НаименованиеЕИ);
		НоваяСтрока.Цена = ЧислоПоляРаспознавания(СтрокаТовара, "price_rub", 0);
		
		Сумма = ЧислоПоляРаспознавания(СтрокаТовара, "amount_without_vat", 0);
		Если Сумма = 0 Тогда
			Сумма = ЧислоПоляРаспознавания(СтрокаТовара, "total_with_vat", 0);
		КонецЕсли;
		НоваяСтрока.Сумма = Сумма;
		УстановитьКолонкуТаблицыНоменклатуры(
			ТаблицаНоменклатуры,
			НоваяСтрока,
			"СуммаНДС",
			ЧислоПоляРаспознавания(СтрокаТовара, "vat_amount", 0));
		
	КонецЦикла;
	
	ЗаписатьСобытиеРаспознавания(
		"СопоставлениеНоменклатуры",
		СтрШаблон(
			НСтр("ru = 'Загружено позиций: %1; автосопоставление отключено'"),
			Формат(СчетчикСтрок, "ЧГ=0")));
	
КонецПроцедуры

Процедура УстановитьКолонкуТаблицыНоменклатуры(ТаблицаНоменклатуры, СтрокаТаблицы, ИмяКолонки, Значение)
	
	Если ТипЗнч(ТаблицаНоменклатуры) = Тип("ТаблицаЗначений")
		И ТаблицаНоменклатуры.Колонки.Найти(ИмяКолонки) = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		СтрокаТаблицы[ИмяКолонки] = Значение;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция НайтиНоменклатуруПоДаннымРаспознавания(
	Наименование,
	СтрокаТовара,
	АлгоритмПоискаНоменклатуры = "Артикул,Наименование",
	СтруктураНастроек = Неопределено,
	КонтрагентИД = "",
	СвязьНоменклатуры = Неопределено)
	
	Алгоритм = НРег(СокрЛП(АлгоритмПоискаНоменклатуры));
	Артикул = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "good_code", "")));
	Если Не ЗначениеЗаполнено(Артикул) Тогда
		Артикул = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "recognizedGoodCode", "")));
	КонецЕсли;
	
	Результат = Новый Структура("Номенклатура, Способ", Справочники.Номенклатура.ПустаяСсылка(), "Не найдено");
	
	Если ИспользоватьСохраненныеСоответствияНоменклатуры(СтруктураНастроек) Тогда
		Номенклатура = НайтиНоменклатуруПоСохраненномуСоответствию(Наименование, КонтрагентИД, СвязьНоменклатуры);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Сохранено";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если Алгоритм = НРег("Артикул") Тогда
		Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Артикул";
			Возврат Результат;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоНаименованию(Наименование);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Наименование";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	Если Алгоритм = НРег("Наименование,Артикул") Тогда
		Номенклатура = НайтиНоменклатуруПоНаименованию(Наименование);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Наименование";
			Возврат Результат;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Артикул";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	// По умолчанию и для "Артикул,Наименование".
	Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Результат.Номенклатура = Номенклатура;
		Результат.Способ = "Артикул";
		Возврат Результат;
	КонецЕсли;
	
	Номенклатура = НайтиНоменклатуруПоНаименованию(Наименование);
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Результат.Номенклатура = Номенклатура;
		Результат.Способ = "Наименование";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция МаркерСпособаСопоставления(Способ) Экспорт
	
	Если Способ = "Сохранено" Тогда
		Возврат " [сохр]";
	ИначеЕсли Способ = "Артикул" Тогда
		Возврат " [арт]";
	ИначеЕсли Способ = "Наименование" Тогда
		Возврат " [наим]";
	ИначеЕсли Способ = "Создано" Тогда
		Возврат " [созд]";
	КонецЕсли;
	
	Возврат " [не сопоставлено]";
	
КонецФункции

// Повторно сопоставляет строки без номенклатуры (улучшенный поиск).
//
Процедура ПересопоставитьНесопоставленныеСтрокиНоменклатуры(
	ТаблицаНоменклатуры,
	АлгоритмПоискаНоменклатуры = "Артикул,Наименование",
	СтруктураНастроек = Неопределено,
	КонтрагентИД = "") Экспорт
	
	Если ТаблицаНоменклатуры = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры);
	
	СвязьНоменклатуры = Неопределено;
	Если ИспользоватьСохраненныеСоответствияНоменклатуры(СтруктураНастроек) Тогда
		СвязьНоменклатуры = ПолучитьТаблицуСвязьНоменклатуры();
	КонецЕсли;
	
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		Наименование = ОчиститьНаименованиеОтМаркераСопоставления(Строка(СтрокаНоменклатуры.Наименование));
		Если Не ЗначениеЗаполнено(Наименование) Тогда
			Продолжить;
		КонецЕсли;
		
		РезультатСопоставления = НайтиНоменклатуруПоДаннымРаспознавания(
			Наименование,
			Новый Структура,
			АлгоритмПоискаНоменклатуры,
			СтруктураНастроек,
			КонтрагентИД,
			СвязьНоменклатуры);
		
		Если ЗначениеЗаполнено(РезультатСопоставления.Номенклатура) Тогда
			СтрокаНоменклатуры.Номенклатура = РезультатСопоставления.Номенклатура;
			СтрокаНоменклатуры.Наименование = Наименование + МаркерСпособаСопоставления(РезультатСопоставления.Способ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ОчиститьНаименованиеОтМаркераСопоставления(ТекстНаименования)
	
	Результат = СокрЛП(ТекстНаименования);
	Маркеры = Новый Массив;
	Маркеры.Добавить(МаркерСпособаСопоставления("Сохранено"));
	Маркеры.Добавить(МаркерСпособаСопоставления("Артикул"));
	Маркеры.Добавить(МаркерСпособаСопоставления("Наименование"));
	Маркеры.Добавить(МаркерСпособаСопоставления("Создано"));
	Маркеры.Добавить(МаркерСпособаСопоставления("Не найдено"));
	
	Для Каждого Маркер Из Маркеры Цикл
		Если ЗначениеЗаполнено(Маркер) И Прав(Результат, СтрДлина(Маркер)) = Маркер Тогда
			Результат = СокрЛП(Лев(Результат, СтрДлина(Результат) - СтрДлина(Маркер)));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// --- Сохранённые соответствия номенклатуры (текст распознавания → справочник) ---

Функция ИмяОбъектаХранилищаСопоставленийНоменклатуры() Экспорт
	
	Возврат "Распознавание_Высота";
	
КонецФункции

Функция ИмяКлючаСвязьНоменклатуры() Экспорт
	
	Возврат "СвязьНоменклатуры";
	
КонецФункции

Функция ПолучитьТаблицуСвязьНоменклатуры() Экспорт
	
	СвязьНоменклатуры = ХранилищеОбщихНастроек.Загрузить(
		ИмяОбъектаХранилищаСопоставленийНоменклатуры(),
		ИмяКлючаСвязьНоменклатуры());
	
	Если ТипЗнч(СвязьНоменклатуры) <> Тип("ТаблицаЗначений") Тогда
		СвязьНоменклатуры = НоваяТаблицаСвязьНоменклатуры();
	Иначе
		ДополнитьКолонкиТаблицыСвязьНоменклатуры(СвязьНоменклатуры);
	КонецЕсли;
	
	УдалитьНедействительныеСоответствияИзСвязьНоменклатуры(СвязьНоменклатуры, Истина);
	
	Возврат СвязьНоменклатуры;
	
КонецФункции

Процедура СохранитьТаблицуСвязьНоменклатуры(СвязьНоменклатуры) Экспорт
	
	ХранилищеОбщихНастроек.Сохранить(
		ИмяОбъектаХранилищаСопоставленийНоменклатуры(),
		ИмяКлючаСвязьНоменклатуры(),
		СвязьНоменклатуры);
	
КонецПроцедуры

Функция ЗапоминатьУстановленныеВручнуюСоответствияНоменклатуры(СтруктураНастроек = Неопределено) Экспорт
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия") Тогда
		Возврат СтруктураНастроек.Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ИспользоватьСохраненныеСоответствияНоменклатуры(СтруктураНастроек = Неопределено) Экспорт
	
	Возврат ЗапоминатьУстановленныеВручнуюСоответствияНоменклатуры(СтруктураНастроек);
	
КонецФункции

Функция КонтрагентИДДляСопоставленияНоменклатуры(ДокументJSON, КонтрагентСсылка = Неопределено) Экспорт
	
	Если ДокументJSON <> Неопределено
		И ТипЗнч(ДокументJSON) = Тип("Структура")
		И ДокументJSON.Свойство("shipper")
		И ТипЗнч(ДокументJSON.shipper) = Тип("Структура") Тогда
		
		ИНН = ТекстовоеПолеУчастника(ДокументJSON.shipper, "inn");
		Если Не ЗначениеЗаполнено(ИНН) Тогда
			ИНН = ТекстовоеПолеУчастника(ДокументJSON.shipper, "tax_id");
		КонецЕсли;
		
		ИНН = НормализоватьИННКПП(ИНН);
		Если ЗначениеЗаполнено(ИНН) Тогда
			Возврат ИНН;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
		Попытка
			ИНН = СокрЛП(Строка(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КонтрагентСсылка, "ИНН")));
			Если ЗначениеЗаполнено(ИНН) Тогда
				Возврат НормализоватьИННКПП(ИНН);
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ИзвлечьЧистоеНаименованиеРаспознавания(НаименованиеСМаркером) Экспорт
	
	Наименование = СокрЛП(Строка(НаименованиеСМаркером));
	Маркеры = Новый Массив;
	Маркеры.Добавить(" [не сопоставлено]");
	Маркеры.Добавить(" [сохр]");
	Маркеры.Добавить(" [наим]");
	Маркеры.Добавить(" [арт]");
	Маркеры.Добавить(" [созд]");
	
	Для Каждого Маркер Из Маркеры Цикл
		Если СтрДлина(Наименование) >= СтрДлина(Маркер)
			И Прав(Наименование, СтрДлина(Маркер)) = Маркер Тогда
			Наименование = Лев(Наименование, СтрДлина(Наименование) - СтрДлина(Маркер));
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СокрЛП(Наименование);
	
КонецФункции

Функция ЗаписатьСоответствиеНоменклатуры(НоменклатураСсылка, Наименование, КонтрагентИД, ХарактеристикаСсылка = Неопределено) Экспорт
	
	СвязьНоменклатуры = ПолучитьТаблицуСвязьНоменклатуры();
	Наименование = СокрЛП(Строка(Наименование));
	КонтрагентИД = СокрЛП(Строка(КонтрагентИД));
	
	СтруктураПоиска = Новый Структура("Наименование, КонтрагентИД", Наименование, КонтрагентИД);
	НайденныеСтроки = СвязьНоменклатуры.НайтиСтроки(СтруктураПоиска);
	ТекстОповещения = "";
	
	Если ЗначениеЗаполнено(НоменклатураСсылка) Тогда
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = СвязьНоменклатуры.Добавить();
			ТекстОповещения = НСтр("ru = 'Связь номенклатуры добавлена'");
		Иначе
			НоваяСтрока = НайденныеСтроки[0];
			ТекстОповещения = НСтр("ru = 'Связь номенклатуры обновлена'");
		КонецЕсли;
		
		НоваяСтрока.Ссылка = НоменклатураСсылка;
		НоваяСтрока.Наименование = Наименование;
		НоваяСтрока.КонтрагентИД = КонтрагентИД;
		НоваяСтрока.Характеристика = ХарактеристикаСсылка;
	Иначе
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				СвязьНоменклатуры.Удалить(НайденнаяСтрока);
			КонецЦикла;
			ТекстОповещения = НСтр("ru = 'Связь номенклатуры очищена'");
		КонецЕсли;
	КонецЕсли;
	
	СохранитьТаблицуСвязьНоменклатуры(СвязьНоменклатуры);
	
	Возврат ТекстОповещения;
	
КонецФункции

Функция НайтиНоменклатуруПоСохраненномуСоответствию(Наименование, КонтрагентИД, СвязьНоменклатуры = Неопределено)
	
	Если СвязьНоменклатуры = Неопределено Тогда
		СвязьНоменклатуры = ПолучитьТаблицуСвязьНоменклатуры();
	КонецЕсли;
	
	Если СвязьНоменклатуры.Количество() = 0 Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Наименование = СокрЛП(Строка(Наименование));
	КонтрагентИД = СокрЛП(Строка(КонтрагентИД));
	
	СтруктураПоиска = Новый Структура("Наименование, КонтрагентИД", Наименование, КонтрагентИД);
	НайденныеСтроки = СвязьНоменклатуры.НайтиСтроки(СтруктураПоиска);
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		Номенклатура = НайденныеСтроки[0].Ссылка;
		Если ЗначениеЗаполнено(Номенклатура) И ОбъектНеНайден(Номенклатура) Тогда
			УдалитьСтрокиСвязьНоменклатуры(СвязьНоменклатуры, НайденныеСтроки, Истина);
		ИначеЕсли ЗначениеЗаполнено(Номенклатура) Тогда
			Возврат Номенклатура;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтрагентИД) Тогда
		СтруктураПоиска.КонтрагентИД = "";
		НайденныеСтроки = СвязьНоменклатуры.НайтиСтроки(СтруктураПоиска);
		Если НайденныеСтроки.Количество() > 0 Тогда
			Номенклатура = НайденныеСтроки[0].Ссылка;
			Если ЗначениеЗаполнено(Номенклатура) И ОбъектНеНайден(Номенклатура) Тогда
				УдалитьСтрокиСвязьНоменклатуры(СвязьНоменклатуры, НайденныеСтроки, Истина);
			ИначеЕсли ЗначениеЗаполнено(Номенклатура) Тогда
				Возврат Номенклатура;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

// Удаляет из таблицы связей строки с несуществующими ссылками на номенклатуру.
//
Функция УдалитьНедействительныеСоответствияИзСвязьНоменклатуры(СвязьНоменклатуры, СохранитьНаДиске = Истина) Экспорт
	
	Если СвязьНоменклатуры = Неопределено Или ТипЗнч(СвязьНоменклатуры) <> Тип("ТаблицаЗначений") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СтрокиКУдалению = Новый Массив;
	Для Каждого СтрокаСвязи Из СвязьНоменклатуры Цикл
		Если ЗначениеЗаполнено(СтрокаСвязи.Ссылка) И ОбъектНеНайден(СтрокаСвязи.Ссылка) Тогда
			СтрокиКУдалению.Добавить(СтрокаСвязи);
		КонецЕсли;
	КонецЦикла;
	
	Если СтрокиКУдалению.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УдалитьСтрокиСвязьНоменклатуры(СвязьНоменклатуры, СтрокиКУдалению, СохранитьНаДиске);
	
	ЗаписатьСобытиеРаспознавания(
		"СопоставлениеНоменклатуры",
		СтрШаблон(
			НСтр("ru = 'Удалены недействительные связи номенклатуры: %1'"),
			Формат(СтрокиКУдалению.Количество(), "ЧГ=0")));
	
	Возврат Истина;
	
КонецФункции

Процедура УдалитьСтрокиСвязьНоменклатуры(СвязьНоменклатуры, СтрокиКУдалению, СохранитьНаДиске = Истина)
	
	Если СвязьНоменклатуры = Неопределено Или СтрокиКУдалению = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаСвязи Из СтрокиКУдалению Цикл
		Попытка
			СвязьНоменклатуры.Удалить(СтрокаСвязи);
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	Если СохранитьНаДиске Тогда
		СохранитьТаблицуСвязьНоменклатуры(СвязьНоменклатуры);
	КонецЕсли;
	
КонецПроцедуры

// Очищает в таблице строки с удалённой из базы номенклатурой.
//
Процедура ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры) Экспорт
	
	Если ТаблицаНоменклатуры = Неопределено Или ТипЗнч(ТаблицаНоменклатуры) <> Тип("ТаблицаЗначений") Тогда
		Возврат;
	КонецЕсли;
	
	Если ТаблицаНоменклатуры.Колонки.Найти("Номенклатура") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПустаяНоменклатура = Справочники.Номенклатура.ПустаяСсылка();
	СчетчикОчищено = 0;
	
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ОбъектНеНайден(СтрокаНоменклатуры.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		Наименование = ОчиститьНаименованиеОтМаркераСопоставления(Строка(СтрокаНоменклатуры.Наименование));
		СтрокаНоменклатуры.Номенклатура = ПустаяНоменклатура;
		
		Если ТаблицаНоменклатуры.Колонки.Найти("ЕдиницаИзмеренияСсылка") <> Неопределено Тогда
			СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка = Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Наименование) Тогда
			СтрокаНоменклатуры.Наименование = Наименование + МаркерСпособаСопоставления("Не найдено");
		КонецЕсли;
		
		СчетчикОчищено = СчетчикОчищено + 1;
	КонецЦикла;
	
	Если СчетчикОчищено > 0 Тогда
		ЗаписатьСобытиеРаспознавания(
			"СопоставлениеНоменклатуры",
			СтрШаблон(
				НСтр("ru = 'Очищены недействительные ссылки номенклатуры в строках: %1'"),
				Формат(СчетчикОчищено, "ЧГ=0")));
	КонецЕсли;
	
КонецПроцедуры

Функция НоваяТаблицаСвязьНоменклатуры()
	
	СвязьНоменклатуры = Новый ТаблицаЗначений;
	СвязьНоменклатуры.Колонки.Добавить("Ссылка");
	СвязьНоменклатуры.Колонки.Добавить("Наименование");
	СвязьНоменклатуры.Колонки.Добавить("КонтрагентИД");
	СвязьНоменклатуры.Колонки.Добавить("Характеристика");
	
	Возврат СвязьНоменклатуры;
	
КонецФункции

Процедура ДополнитьКолонкиТаблицыСвязьНоменклатуры(СвязьНоменклатуры)
	
	Если СвязьНоменклатуры.Колонки.Найти("Характеристика") = Неопределено Тогда
		СвязьНоменклатуры.Колонки.Добавить("Характеристика");
	КонецЕсли;
	
КонецПроцедуры

// Определяет организацию и контрагента по JSON документа М-15 (shipper / consignee).
// Учитывает настройки Entera: организация по умолчанию, алгоритм поиска контрагента.
//
Функция ОпределитьОрганизациюИКонтрагентаПоДокументу(ДокументJSON, СтруктураНастроек = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Организация", Справочники.Организации.ПустаяСсылка());
	Результат.Вставить("Контрагент", Справочники.Контрагенты.ПустаяСсылка());
	
	Если ДокументJSON = Неопределено Или ТипЗнч(ДокументJSON) <> Тип("Структура") Тогда
		ПрименитьОрганизациюПоУмолчаниюИзНастроек(Результат, СтруктураНастроек);
		Возврат Результат;
	КонецЕсли;
	
	// Для поступления (входящий): shipper — контрагент, consignee — организация.
	Если ДокументJSON.Свойство("shipper") Тогда
		РеквизитыПоставщика = РеквизитыУчастникаДокумента(ДокументJSON.shipper);
		Результат.Контрагент = НайтиКонтрагентаПоРеквизитамУчастника(РеквизитыПоставщика, СтруктураНастроек);
	КонецЕсли;
	
	Если ДокументJSON.Свойство("consignee") Тогда
		РеквизитыПолучателя = РеквизитыУчастникаДокумента(ДокументJSON.consignee);
		Результат.Организация = НайтиОрганизациюПоРеквизитамУчастника(РеквизитыПолучателя);
	КонецЕсли;
	
	ПрименитьОрганизациюПоУмолчаниюИзНастроек(Результат, СтруктураНастроек);
	
	Возврат Результат;
	
КонецФункции

Процедура ПрименитьОрганизациюПоУмолчаниюИзНастроек(Результат, СтруктураНастроек)
	
	Если СтруктураНастроек = Неопределено Или ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	// Как в Entera: для входящих документов организация из настроек имеет приоритет.
	Если СтруктураНастроек.Свойство("ЗаполнениеШапки_ОрганизацияПоУмолчанию")
		И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию) Тогда
		Результат.Организация = СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию;
	КонецЕсли;
	
КонецПроцедуры

Функция АлгоритмПоискаКонтрагентаИзНастроек(СтруктураНастроек)
	
	АлгоритмПоУмолчанию = "ИНН,Наименование";
	
	Если СтруктураНастроек <> Неопределено
		И ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("ЗаполнениеШапки_АлгоритмПоискаКонтрагента")
		И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента) Тогда
		Возврат СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента;
	КонецЕсли;
	
	Возврат АлгоритмПоУмолчанию;
	
КонецФункции

Функция НайтиКонтрагентаПоРеквизитамУчастника(РеквизитыУчастника, СтруктураНастроек)
	
	Если РеквизитыУчастника = Неопределено Или ТипЗнч(РеквизитыУчастника) <> Тип("Структура") Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	Алгоритм = АлгоритмПоискаКонтрагентаИзНастроек(СтруктураНастроек);
	Ссылка = Неопределено;
	
	Если Алгоритм = "Наименование,ИНН" Тогда
		Ссылка = НайтиВСправочникеПоНаименованию("Контрагенты", РеквизитыУчастника.Наименование);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ссылка) И ЗначениеЗаполнено(РеквизитыУчастника.ИНН) Тогда
		Если Алгоритм = "ИНН+КПП" И ЗначениеЗаполнено(РеквизитыУчастника.КПП) Тогда
			Ссылка = НайтиВСправочникеПоИННКПП("Контрагенты", РеквизитыУчастника.ИНН, РеквизитыУчастника.КПП);
		Иначе
			Ссылка = НайтиВСправочникеПоИНН("Контрагенты", РеквизитыУчастника.ИНН);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ссылка) И Алгоритм = "ИНН,Наименование" Тогда
		Ссылка = НайтиВСправочникеПоНаименованию("Контрагенты", РеквизитыУчастника.Наименование);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ссылка) И ЗначениеЗаполнено(РеквизитыУчастника.Наименование) Тогда
		Ссылка = НайтиВСправочникеПоНаименованиюНечетко("Контрагенты", РеквизитыУчастника.Наименование);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

// Ищет контрагента по тексту поставщика из распознанного документа (наименование из OCR).
//
Функция НайтиКонтрагентаПоТекстуПоставщика(ТекстПоставщика, СтруктураНастроек = Неопределено) Экспорт
	
	ТекстПоставщика = СокрЛП(Строка(ТекстПоставщика));
	Если Не ЗначениеЗаполнено(ТекстПоставщика) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;
	
	РеквизитыУчастника = Новый Структура;
	РеквизитыУчастника.Вставить("Наименование", ТекстПоставщика);
	РеквизитыУчастника.Вставить("ИНН", "");
	РеквизитыУчастника.Вставить("КПП", "");
	
	Ссылка = НайтиКонтрагентаПоРеквизитамУчастника(РеквизитыУчастника, СтруктураНастроек);
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Ссылка = НайтиВСправочникеПоНаименованиюНечетко("Контрагенты", ТекстПоставщика);
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
КонецФункции

Функция НайтиОрганизациюПоРеквизитамУчастника(РеквизитыУчастника)
	
	Если РеквизитыУчастника = Неопределено Или ТипЗнч(РеквизитыУчастника) <> Тип("Структура") Тогда
		Возврат Справочники.Организации.ПустаяСсылка();
	КонецЕсли;
	
	Ссылка = Неопределено;
	
	Если ЗначениеЗаполнено(РеквизитыУчастника.ИНН) Тогда
		Если ЗначениеЗаполнено(РеквизитыУчастника.КПП) Тогда
			Ссылка = НайтиВСправочникеПоИННКПП("Организации", РеквизитыУчастника.ИНН, РеквизитыУчастника.КПП);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Ссылка) Тогда
			Ссылка = НайтиВСправочникеПоИНН("Организации", РеквизитыУчастника.ИНН);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Ссылка = НайтиВСправочникеПоНаименованию("Организации", РеквизитыУчастника.Наименование);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ссылка;
	КонецЕсли;
	
	Возврат Справочники.Организации.ПустаяСсылка();
	
КонецФункции

// Ищет номенклатуру по точному совпадению наименования.
//
Функция НайтиНоменклатуруПоНаименованию(Наименование) Экспорт
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И (Номенклатура.Наименование = &Наименование
		|		ИЛИ Номенклатура.НаименованиеПолное = &Наименование)";
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		// НаименованиеПолное может отсутствовать в метаданных — ищем только по Наименование.
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	НЕ Номенклатура.ПометкаУдаления
			|	И Номенклатура.Наименование = &Наименование";
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецПопытки;
	
	// Мягкий fallback: ищем по вхождению наименования.
	Попытка
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	НЕ Номенклатура.ПометкаУдаления
			|	И Номенклатура.Наименование ПОДОБНО &Шаблон";
		Запрос.УстановитьПараметр("Шаблон", "%" + Наименование + "%");
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Номенклатура = НайтиНоменклатуруПоВхождениюНаименованияВТекстРаспознавания(Наименование);
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Возврат Номенклатура;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

// Ищет номенклатуру, если её краткое наименование содержится в длинном тексте распознавания.
//
Функция НайтиНоменклатуруПоВхождениюНаименованияВТекстРаспознавания(ТекстРаспознавания) Экспорт
	
	ТекстНорм = НРег(СокрЛП(ТекстРаспознавания));
	Если Не ЗначениеЗаполнено(ТекстНорм) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	ШаблонПоиска = ПервоеЗначимоеСловоДляПоискаНоменклатуры(ТекстНорм);
	Если Не ЗначениеЗаполнено(ШаблонПоиска) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 100
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Наименование ПОДОБНО &Шаблон";
	Запрос.УстановитьПараметр("Шаблон", "%" + ШаблонПоиска + "%");
	
	ЛучшаяСсылка = Справочники.Номенклатура.ПустаяСсылка();
	МаксимальнаяДлина = 0;
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ИмяНоменклатуры = НРег(СокрЛП(Выборка.Наименование));
			Если Не ЗначениеЗаполнено(ИмяНоменклатуры) Тогда
				Продолжить;
			КонецЕсли;
			Если СтрНайти(ТекстНорм, ИмяНоменклатуры) > 0 Тогда
				ДлинаИмени = СтрДлина(ИмяНоменклатуры);
				Если ДлинаИмени > МаксимальнаяДлина Тогда
					МаксимальнаяДлина = ДлинаИмени;
					ЛучшаяСсылка = Выборка.Ссылка;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Если ЗначениеЗаполнено(ЛучшаяСсылка) Тогда
		Возврат ЛучшаяСсылка;
	КонецЕсли;
	
	ФрагментРазмера = ИзвлечьФрагментРазмераИзНаименования(ТекстНорм);
	Если Не ЗначениеЗаполнено(ФрагментРазмера) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Шаблон", "%" + ФрагментРазмера + "%");
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			ИмяНоменклатуры = НРег(СокрЛП(Выборка.Наименование));
			Если СтрНайти(ИмяНоменклатуры, ФрагментРазмера) > 0 Тогда
				Возврат Выборка.Ссылка;
			КонецЕсли;
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция ПервоеЗначимоеСловоДляПоискаНоменклатуры(ТекстНорм)
	
	Части = СтрРазделить(ТекстНорм, " ", Ложь);
	Для Каждого Часть Из Части Цикл
		Слово = СокрЛП(Часть);
		Если СтрДлина(Слово) >= 3 Тогда
			Возврат Слово;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Функция ИзвлечьФрагментРазмераИзНаименования(ТекстНорм)
	
	Для НомерСимвола = 1 По СтрДлина(ТекстНорм) - 2 Цикл
		Фрагмент = Сред(ТекстНорм, НомерСимвола, 3);
		Если Найти("0123456789", Лев(Фрагмент, 1)) = 0 Тогда
			Продолжить;
		КонецЕсли;
		ПозицияХ = Найти(Сред(ТекстНорм, НомерСимвола), "х");
		Если ПозицияХ = 0 Тогда
			ПозицияХ = Найти(Сред(ТекстНорм, НомерСимвола), "x");
		КонецЕсли;
		Если ПозицияХ = 0 Тогда
			Продолжить;
		КонецЕсли;
		Начало = НомерСимвола;
		Пока Начало > 1 И Найти("0123456789", Сред(ТекстНорм, Начало - 1, 1)) > 0 Цикл
			Начало = Начало - 1;
		КонецЦикла;
		Конец = НомерСимвола + ПозицияХ;
		Пока Конец < СтрДлина(ТекстНорм) И Найти("0123456789", Сред(ТекстНорм, Конец + 1, 1)) > 0 Цикл
			Конец = Конец + 1;
		КонецЦикла;
		Возврат Сред(ТекстНорм, Начало, Конец - Начало + 1);
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Функция НайтиНоменклатуруПоАртикулу(Артикул)
	
	Артикул = НормализоватьАртикул(Артикул);
	Если Не ЗначениеЗаполнено(Артикул) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И Номенклатура.Артикул = &Артикул";
	
	Запрос.УстановитьПараметр("Артикул", Артикул);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецПопытки;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция НормализоватьАртикул(Артикул)
	
	Результат = СокрЛП(Строка(Артикул));
	Результат = СтрЗаменить(Результат, " ", "");
	Результат = СтрЗаменить(Результат, Символы.Таб, "");
	
	Возврат Результат;
	
КонецФункции

// Ищет единицу измерения в классификаторе ОКЕИ только по коду.
//
Функция НайтиЕдиницуИзмеренияДляСтроки(Номенклатура, КодОКЕИ, НаименованиеЕИ = "") Экспорт
	
	Единица = НайтиЕдиницуКлассификатораПоКоду(КодОКЕИ);
	
	Если ЗначениеЗаполнено(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	КодПоСинониму = КодОКЕИПоСинониму(НаименованиеЕИ);
	Если ЗначениеЗаполнено(КодПоСинониму) Тогда
		Единица = НайтиЕдиницуКлассификатораПоКоду(КодПоСинониму);
		Если ЗначениеЗаполнено(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
	КонецЕсли;
	
	Единица = НайтиЕдиницуКлассификатораПоНаименованию(НаименованиеЕИ);
	Если ЗначениеЗаполнено(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	// Если по ОКЕИ не нашли — единица хранения номенклатуры.
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Попытка
			ЕдиницаНоменклатуры = Номенклатура.ЕдиницаИзмерения;
			Если ЗначениеЗаполнено(ЕдиницаНоменклатуры) Тогда
				Возврат ЕдиницаНоменклатуры;
			КонецЕсли;
		Исключение
			Попытка
				ЕдиницаНоменклатуры = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ЕдиницаИзмерения");
				Если ЗначениеЗаполнено(ЕдиницаНоменклатуры) Тогда
					Возврат ЕдиницаНоменклатуры;
				КонецЕсли;
			Исключение
			КонецПопытки;
		КонецПопытки;
	КонецЕсли;
	
	Возврат ЕдиницаИзмеренияПоУмолчаниюРаспознавания();
	
КонецФункции

Функция НайтиЕдиницуКлассификатораПоНаименованию(НаименованиеЕИ)
	
	НаименованиеПоиска = СокрЛП(Строка(НаименованиеЕИ));
	НаименованиеНорм = НормализоватьНаименованиеЕдиницы(НаименованиеЕИ);
	Если Не ЗначениеЗаполнено(НаименованиеПоиска) И Не ЗначениеЗаполнено(НаименованиеНорм) Тогда
		Возврат Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Единицы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК Единицы
		|ГДЕ
		|	НЕ Единицы.ПометкаУдаления
		|	И (Единицы.Наименование = &Наименование
		|		ИЛИ Единицы.МеждународноеСокращение = &Наименование)";
	Запрос.УстановитьПараметр("Наименование", НаименованиеПоиска);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если ЗначениеЗаполнено(НаименованиеНорм) И НаименованиеНорм <> НРег(НаименованиеПоиска) Тогда
		Запрос.УстановитьПараметр("Наименование", НаименованиеНорм);
		Попытка
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				Возврат Выборка.Ссылка;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Единицы.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.КлассификаторЕдиницИзмерения КАК Единицы
			|ГДЕ
			|	НЕ Единицы.ПометкаУдаления
			|	И Единицы.Наименование ПОДОБНО &Шаблон";
		Запрос.УстановитьПараметр("Шаблон", "%" + НаименованиеПоиска + "%");
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если РеквизитСуществует("Справочники", "КлассификаторЕдиницИзмерения", "НаименованиеПолное") Тогда
		Попытка
			Запрос.Текст =
				"ВЫБРАТЬ ПЕРВЫЕ 1
