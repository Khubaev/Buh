	Словарь = СловарьСинонимовЕдиницИзмерения();
	КодПоСинониму = Словарь.Получить(НормализованноеНаименование);
	Если КодПоСинониму <> Неопределено И ЗначениеЗаполнено(КодПоСинониму) Тогда
		Возврат КодПоСинониму;
