// Отправляет все прикреплённые к объекту файлы на распознавание без открытия формы обработки.
//
Функция ОтправитьПрисоединенныеФайлыОбъектаНаРаспознавание(ВладелецФайла, ИдентификаторФормы = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ТекстСообщения", "");
	Результат.Вставить("КоличествоУспешных", 0);
	Результат.Вставить("КоличествоОшибок", 0);
	Результат.Вставить("РезультатыФайлов", Новый Массив);
	Результат.Вставить("JobId", "");
	
	Если Не ЗначениеЗаполнено(ВладелецФайла) Тогда
		Результат.ТекстСообщения = НСтр("ru = 'Не указан объект для отправки файлов.'");
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыAPI = ПолучитьПараметрыПодключенияAPIРаспознавания();
	Если Не ЗначениеЗаполнено(ПараметрыAPI.АдресAPI) Тогда
		Результат.ТекстСообщения = НСтр(
			"ru = 'Не указан адрес API распознавания. Откройте обработку «Распознавание_Высота» и укажите настройки подключения.'");
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторХранилища = ИдентификаторФормы;
	Если ИдентификаторХранилища = Неопределено Тогда
		ИдентификаторХранилища = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	МассивФайлов = ПодготовитьПрисоединенныеФайлыДляРаспознавания(ВладелецФайла, ИдентификаторХранилища);
	Если МассивФайлов.Количество() = 0 Тогда
		Результат.ТекстСообщения = НСтр("ru = 'К объекту не прикреплены файлы для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаФайлов = ТаблицаФайловДляРаспознаванияИзМассива(МассивФайлов);
	Если ТаблицаФайлов.Количество() = 0 Тогда
		Результат.ТекстСообщения = НСтр("ru = 'Не удалось подготовить файлы для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыЗапроса = СформироватьПараметрыЗапросаРаспознаванияДляОбъекта(ВладелецФайла);
	
	Если ЗначениеЗаполнено(ПараметрыAPI.АдресAPIСтатуса) Тогда
		РезультатОчереди = ПоставитьВОчередьРаспознавание(
			ПараметрыAPI.АдресAPIСтатуса,
			ПараметрыAPI.ТокенAPI,
			ТаблицаФайлов,
			ПараметрыЗапроса);
		Если РезультатОчереди.Успех Тогда
			Результат.Успех = Истина;
			Результат.JobId = РезультатОчереди.JobId;
			Результат.КоличествоУспешных = ТаблицаФайлов.Количество();
			Результат.ТекстСообщения = СтрШаблон(
				НСтр("ru = 'Файлы (%1 шт.) поставлены в очередь распознавания.'"),
				Формат(ТаблицаФайлов.Количество(), "ЧГ=0"));
			Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
				ОписаниеРезультата = Новый Структура;
				ОписаниеРезультата.Вставить("ИмяФайла", СтрокаФайла.ИмяФайла);
				ОписаниеРезультата.Вставить("Успех", Истина);
				ОписаниеРезультата.Вставить("ТекстСообщения", НСтр("ru = 'Поставлен в очередь'"));
				Результат.РезультатыФайлов.Добавить(ОписаниеРезультата);
			КонецЦикла;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Успешных = 0;
	Ошибок = 0;
	ТекстыОшибок = Новый Массив;
	
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		
		ТаблицаОдинФайл = ТаблицаФайлов.Скопировать();
		ТаблицаОдинФайл.Очистить();
		НоваяСтрока = ТаблицаОдинФайл.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаФайла);
		
		РезультатФайла = ОтправитьФайлыНаРаспознавание(
			ПараметрыAPI.АдресAPI,
			ПараметрыAPI.ТокенAPI,
			ТаблицаОдинФайл,
			ПараметрыЗапроса);
		
		ОписаниеРезультата = Новый Структура;
		ОписаниеРезультата.Вставить("ИмяФайла", СтрокаФайла.ИмяФайла);
		
		Если РезультатФайла <> Неопределено
			И РезультатФайла.Свойство("Успех")
			И РезультатФайла.Успех Тогда
			Успешных = Успешных + 1;
			ОписаниеРезультата.Вставить("Успех", Истина);
			Текст = "";
			Если РезультатФайла.Свойство("ТекстДляПользователя") Тогда
				Текст = СокрЛП(Строка(РезультатФайла.ТекстДляПользователя));
			КонецЕсли;
			Если ПустаяСтрока(Текст) Тогда
				Текст = НСтр("ru = 'Успешно отправлен'");
			КонецЕсли;
			ОписаниеРезультата.Вставить("ТекстСообщения", Текст);
		Иначе
			Ошибок = Ошибок + 1;
			ОписаниеРезультата.Вставить("Успех", Ложь);
			ТекстОшибки = "";
			Если РезультатФайла <> Неопределено Тогда
				Если РезультатФайла.Свойство("ОписаниеОшибки") Тогда
					ТекстОшибки = СокрЛП(Строка(РезультатФайла.ОписаниеОшибки));
				КонецЕсли;
				Если ПустаяСтрока(ТекстОшибки) И РезультатФайла.Свойство("ТекстДляПользователя") Тогда
					ТекстОшибки = СокрЛП(Строка(РезультатФайла.ТекстДляПользователя));
				КонецЕсли;
			КонецЕсли;
			Если ПустаяСтрока(ТекстОшибки) Тогда
				ТекстОшибки = НСтр("ru = 'Ошибка отправки файла.'");
			КонецЕсли;
			ОписаниеРезультата.Вставить("ТекстСообщения", ТекстОшибки);
			ТекстыОшибок.Добавить(СтрШаблон("%1: %2", СтрокаФайла.ИмяФайла, ТекстОшибки));
		КонецЕсли;
		
		Результат.РезультатыФайлов.Добавить(ОписаниеРезультата);
		
	КонецЦикла;
	
	Результат.КоличествоУспешных = Успешных;
	Результат.КоличествоОшибок = Ошибок;
	Результат.Успех = (Ошибок = 0 И Успешных > 0);
	
	Если Успешных > 0 И Ошибок = 0 Тогда
		Результат.ТекстСообщения = СтрШаблон(
			НСтр("ru = 'На распознавание отправлено файлов: %1.'"),
			Формат(Успешных, "ЧГ=0"));
	ИначеЕсли Успешных > 0 И Ошибок > 0 Тогда
		Результат.ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Отправлено: %1, с ошибкой: %2.'"),
			Формат(Успешных, "ЧГ=0"),
			Формат(Ошибок, "ЧГ=0"));
	Иначе
		Результат.ТекстСообщения = СтрСоединить(ТекстыОшибок, Символы.ПС);
		Если ПустаяСтрока(Результат.ТекстСообщения) Тогда
			Результат.ТекстСообщения = НСтр("ru = 'Не удалось отправить файлы на распознавание.'");
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьПараметрыAPIИзСохраненныхДанныхФормы(Результат, СохраненныеДанные)
	
	Если ТипЗнч(СохраненныеДанные) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если СохраненныеДанные.Свойство("АдресAPIРаспознавания")
		И Не ЗначениеЗаполнено(Результат.АдресAPI) Тогда
		Результат.АдресAPI = СокрЛП(Строка(СохраненныеДанные.АдресAPIРаспознавания));
	КонецЕсли;
	
	Если СохраненныеДанные.Свойство("ТокенAPIРаспознавания")
		И Не ЗначениеЗаполнено(Результат.ТокенAPI) Тогда
		Результат.ТокенAPI = СокрЛП(Строка(СохраненныеДанные.ТокенAPIРаспознавания));
	КонецЕсли;
	
	Если СохраненныеДанные.Свойство("АдресAPIСтатусаРаспознавания")
		И Не ЗначениеЗаполнено(Результат.АдресAPIСтатуса) Тогда
		Результат.АдресAPIСтатуса = СокрЛП(Строка(СохраненныеДанные.АдресAPIСтатусаРаспознавания));
	КонецЕсли;
	
КонецПроцедуры

Функция ТаблицаФайловДляРаспознаванияИзМассива(МассивФайлов)
	
	ТаблицаФайлов = Новый ТаблицаЗначений;
	ТаблицаФайлов.Колонки.Добавить("ИмяФайла");
	ТаблицаФайлов.Колонки.Добавить("АдресХранилища");
	ТаблицаФайлов.Колонки.Добавить("РазмерКб", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	
	Для Каждого ОписаниеФайла Из МассивФайлов Цикл
		
		Если ТипЗнч(ОписаниеФайла) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ОписаниеФайла.Свойство("АдресХранилища")
			Или Не ЗначениеЗаполнено(ОписаниеФайла.АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаФайлов.Добавить();
		НоваяСтрока.ИмяФайла = ?(ОписаниеФайла.Свойство("ИмяФайла"), ОписаниеФайла.ИмяФайла, "");
		НоваяСтрока.АдресХранилища = ОписаниеФайла.АдресХранилища;
		
		Если ОписаниеФайла.Свойство("РазмерБайт") И ОписаниеФайла.РазмерБайт > 0 Тогда
			НоваяСтрока.РазмерКб = Окр(ОписаниеФайла.РазмерБайт / 1024, 3);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТаблицаФайлов;
	
КонецФункции

Функция СформироватьПараметрыЗапросаРаспознаванияДляОбъекта(ВладелецФайла)
	
	ПараметрыЗапроса = Новый Структура;
	
	Если ЗначениеЗаполнено(ВладелецФайла) Тогда
		ПараметрыЗапроса.Вставить("document_id", XMLСтрока(ВладелецФайла));
		ПараметрыЗапроса.Вставить("document", Строка(ВладелецФайла));
	КонецЕсли;
	
	Алгоритм = "Артикул,Наименование";
	СтруктураНастроек = ХранилищеОбщихНастроек.Загрузить("Распознавание_Высота", "ОбщиеНастройки");
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_АлгоритмПоискаНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры) Тогда
		Алгоритм = СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры;
	КонецЕсли;
	ПараметрыЗапроса.Вставить("nomenclature_search_algorithm", Алгоритм);
	
	Возврат ПараметрыЗапроса;
	
КонецФункции

// Прикрепляет исходный файл распознавания (PDF/Excel) к созданному документу 1С.
//
Процедура ПрисоединитьИсходныйФайлКДокументу(ДокументСсылка, ПараметрыИсходногоФайла, СтруктураНастроек = Неопределено) Экспорт
	
	Если Не НужноПрисоединятьИсходныйФайлПриСоздании(СтруктураНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументСсылка)
		Или ПараметрыИсходногоФайла = Неопределено
		Или ТипЗнч(ПараметрыИсходногоФайла) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	АдресХранилища = "";
	ИмяФайла = "";
	Если ПараметрыИсходногоФайла.Свойство("АдресХранилища") Тогда
		АдресХранилища = ПараметрыИсходногоФайла.АдресХранилища;
	КонецЕсли;
	Если ПараметрыИсходногоФайла.Свойство("ИмяФайла") Тогда
		ИмяФайла = ПараметрыИсходногоФайла.ИмяФайла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(АдресХранилища) Или Не ЭтоАдресВременногоХранилища(АдресХранилища) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		ИмяФайла = "document.pdf";
	КонецЕсли;
	
	Попытка
		ПараметрыФайла = Новый Структура;
		ПараметрыФайла.Вставить("Автор", Пользователи.АвторизованныйПользователь());
		ПараметрыФайла.Вставить("ВладелецФайлов", ДокументСсылка);
		ПараметрыФайла.Вставить("ИмяБезРасширения", ИмяФайла);
		ПараметрыФайла.Вставить("РасширениеБезТочки", "");
		ПараметрыФайла.Вставить("ВремяИзмененияУниверсальное", ТекущаяУниверсальнаяДата());
		
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресХранилища);
		
		ЗаписатьСобытиеРаспознавания(
			"Создание",
			СтрШаблон(НСтр("ru = 'К документу %1 прикреплён файл %2'"), ДокументСсылка, ИмяФайла),
			УровеньЖурналаРегистрации.Информация);
	Исключение
		ЗаписатьСобытиеРаспознавания(
			"Ошибка",
			СтрШаблон(
				НСтр("ru = 'Не удалось прикрепить файл %1 к документу %2: %3'"),
				ИмяФайла,
				ДокументСсылка,
				КраткоеПредставлениеОшибки(ИнформацияОбОшибке())),
			УровеньЖурналаРегистрации.Предупреждение);
	КонецПопытки;
	
КонецПроцедуры

Функция НужноПрисоединятьИсходныйФайлПриСоздании(СтруктураНастроек)
	
	Если СтруктураНастроек = Неопределено Или ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("СозданиеДокумента_ПрисоединятьФайлСканаДокумента") Тогда
		Возврат СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗаполнитьНомерИДатуВходящегоДокументаПоступления(ДокументОбъект, ДокументJSON)
	
	Если ДокументJSON = Неопределено Или ТипЗнч(ДокументJSON) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	Если ДокументJSON.Свойство("document_date") И ЗначениеЗаполнено(ДокументJSON.document_date) Тогда
		Попытка
			ДокументОбъект.Дата = Дата(Строка(ДокументJSON.document_date));
			Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ДатаВходящегоДокумента", ДокументОбъект.Метаданные()) Тогда
				ДокументОбъект.ДатаВходящегоДокумента = Дата(Строка(ДокументJSON.document_date));
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ДокументJSON.Свойство("document_number") И ЗначениеЗаполнено(ДокументJSON.document_number) Тогда
		НомерНакладной = СокрЛП(Строка(ДокументJSON.document_number));
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("НомерВходящегоДокумента", ДокументОбъект.Метаданные()) Тогда
			ДокументОбъект.НомерВходящегоДокумента = НомерНакладной;
		Иначе
			ДокументОбъект.Номер = НомерНакладной;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьДоговорКонтрагентаДокументаПоступления(ДокументОбъект)
	
	Если Не ОбщегоНазначения.ЕстьРеквизитОбъекта("ДоговорКонтрагента", ДокументОбъект.Метаданные()) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДокументОбъект.Контрагент) Или Не ЗначениеЗаполнено(ДокументОбъект.Организация) Тогда
		Возврат;
	КонецЕсли;
	
	СписокВидовДоговоров = Новый Массив;
	Если РеквизитСуществует("Перечисления", "ВидыДоговоровКонтрагентов", "СПоставщиком") Тогда
		СписокВидовДоговоров.Добавить(Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком);
	КонецЕсли;
	
	Попытка
		ЗаполнениеДокументов.ПриИзмененииЗначенияКонтрагента(ДокументОбъект, СписокВидовДоговоров);
	Исключение
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(ДокументОбъект.ДоговорКонтрагента) Тогда
		ДокументОбъект.ДоговорКонтрагента = НайтиПервыйДоговорКонтрагента(ДокументОбъект.Организация, ДокументОбъект.Контрагент);
	КонецЕсли;
	
КонецПроцедуры

// Заполняет валюту документа и курс взаиморасчетов при создании поступления.
//
Процедура ЗаполнитьВалютуДокументаПоступления(ДокументОбъект, СтруктураНастроек = Неопределено)
	
	Если Не РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "ВалютаДокумента") Тогда
		Возврат;
	КонецЕсли;
	
	ВалютаУчета = ПолучитьВалютуУчетаПоУмолчанию(СтруктураНастроек);
	ВалютаДокумента = Справочники.Валюты.ПустаяСсылка();
	
	Попытка
		Если ЗначениеЗаполнено(ДокументОбъект.ВалютаДокумента) Тогда
			ВалютаДокумента = ДокументОбъект.ВалютаДокумента;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(ВалютаДокумента) И ЗначениеЗаполнено(ДокументОбъект.ДоговорКонтрагента) Тогда
		ВалютаДокумента = ПолучитьВалютуИзДоговораКонтрагента(ДокументОбъект.ДоговорКонтрагента, СтруктураНастроек);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВалютаДокумента) Тогда
		ВалютаДокумента = ВалютаУчета;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВалютаДокумента) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ДокументОбъект.ВалютаДокумента = ВалютаДокумента;
	Исключение
	КонецПопытки;
	
	ЗаполнитьКурсИКратностьВзаиморасчетовПоступления(ДокументОбъект, ВалютаДокумента, ВалютаУчета);
	
КонецПроцедуры

Процедура ЗаполнитьКурсИКратностьВзаиморасчетовПоступления(ДокументОбъект, ВалютаДокумента, ВалютаУчета)
	
	Курс = 1;
	Кратность = 1;
	
	Если ЗначениеЗаполнено(ВалютаУчета) И ВалютаДокумента <> ВалютаУчета Тогда
		Попытка
			СтруктураКурса = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаДокумента, ДокументОбъект.Дата);
			Курс = СтруктураКурса.Курс;
			Кратность = СтруктураКурса.Кратность;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "КурсВзаиморасчетов") Тогда
		Попытка
			Если Не ЗначениеЗаполнено(ДокументОбъект.КурсВзаиморасчетов) Тогда
				ДокументОбъект.КурсВзаиморасчетов = Курс;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "КратностьВзаиморасчетов") Тогда
		Попытка
			Если Не ЗначениеЗаполнено(ДокументОбъект.КратностьВзаиморасчетов) Тогда
				ДокументОбъект.КратностьВзаиморасчетов = Кратность;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьВалютуУчетаПоУмолчанию(СтруктураНастроек = Неопределено)
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("СведенияОКонфигурации")
		И ТипЗнч(СтруктураНастроек.СведенияОКонфигурации) = Тип("Структура")
		И СтруктураНастроек.СведенияОКонфигурации.Свойство("ВалютаУчета")
		И ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета) Тогда
		Возврат СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета;
	КонецЕсли;
	
	Если Метаданные.Константы.Найти("ВалютаРегламентированногоУчета") <> Неопределено Тогда
		Попытка
			Возврат Константы.ВалютаРегламентированногоУчета.Получить();
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Метаданные.Константы.Найти("ВалютаУчета") <> Неопределено Тогда
		Попытка
			Возврат Константы.ВалютаУчета.Получить();
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Возврат Справочники.Валюты.ПустаяСсылка();
	
КонецФункции

Функция ПолучитьВалютуИзДоговораКонтрагента(ДоговорКонтрагента, СтруктураНастроек = Неопределено)
	
	Если Не ЗначениеЗаполнено(ДоговорКонтрагента) Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	ИмяРеквизитаВалюты = "";
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("СведенияОКонфигурации")
		И ТипЗнч(СтруктураНастроек.СведенияОКонфигурации) = Тип("Структура")
		И СтруктураНастроек.СведенияОКонфигурации.Свойство("Договор_ИмяРеквизитаВалюта")
		И ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Договор_ИмяРеквизитаВалюта) Тогда
		ИмяРеквизитаВалюты = СтруктураНастроек.СведенияОКонфигурации.Договор_ИмяРеквизитаВалюта;
	ИначеЕсли РеквизитСуществует("Справочники", "ДоговорыКонтрагентов", "ВалютаВзаиморасчетов") Тогда
		ИмяРеквизитаВалюты = "ВалютаВзаиморасчетов";
	ИначеЕсли РеквизитСуществует("Справочники", "ДоговорыКонтрагентов", "ВалютаРасчетов") Тогда
		ИмяРеквизитаВалюты = "ВалютаРасчетов";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИмяРеквизитаВалюты) Тогда
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецЕсли;
	
	Попытка
		Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДоговорКонтрагента, ИмяРеквизитаВалюты);
	Исключение
		Возврат Справочники.Валюты.ПустаяСсылка();
	КонецПопытки;
	
КонецФункции

Функция НайтиПервыйДоговорКонтрагента(Организация, Контрагент)
	
	Если Метаданные.Справочники.Найти("ДоговорыКонтрагентов") = Неопределено Тогда
		Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Договоры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Владелец = &Контрагент
	|	И Договоры.Организация = &Организация
	|	И НЕ Договоры.ПометкаУдаления
	|	И НЕ Договоры.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	Договоры.Наименование";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	
КонецФункции

Процедура ЗаполнитьРеквизитыДокументаПоступленияИзНастроек(ДокументОбъект, СтруктураНастроек)
	
	Если СтруктураНастроек <> Неопределено И ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
		
		Если СтруктураНастроек.Свойство("ЗаполнениеШапки_СкладПоУмолчанию")
			И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_СкладПоУмолчанию) Тогда
			Попытка
				ДокументОбъект.Склад = СтруктураНастроек.ЗаполнениеШапки_СкладПоУмолчанию;
			Исключение
			КонецПопытки;
		КонецЕсли;
		
		Если СтруктураНастроек.Свойство("ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию")
			И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию) Тогда
			Попытка
				ДокументОбъект.ПодразделениеОрганизации = СтруктураНастроек.ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию;
			Исключение
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаполнитьКомментарийСозданногоДокументаПоступления(ДокументОбъект, СтруктураНастроек);
	ЗаполнитьСпособЗачетаАвансовДокументаПоступления(ДокументОбъект, СтруктураНастроек);
	
КонецПроцедуры

// Заполняет комментарий созданного документа поступления.
//
Процедура ЗаполнитьКомментарийСозданногоДокументаПоступления(ДокументОбъект, СтруктураНастроек = Неопределено)
	
	Если Не РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "Комментарий") Тогда
		Возврат;
	КонецЕсли;
	
	Комментарий = ПолучитьКомментарийСозданногоДокумента(СтруктураНастроек);
	Если Не ЗначениеЗаполнено(Комментарий) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ДокументОбъект.Комментарий = Комментарий;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция ПолучитьКомментарийСозданногоДокумента(СтруктураНастроек = Неопределено)
	
	КомментарийПоУмолчанию = НСтр("ru = 'Документ Загружен из сервиса ВЫСОТА_Распознавание'");
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("ЗаполнениеШапки_КомментарийСозданногоДокумента")
		И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_КомментарийСозданногоДокумента) Тогда
		
		КомментарийИзНастроек = СокрЛП(Строка(СтруктураНастроек.ЗаполнениеШапки_КомментарийСозданногоДокумента));
		Если ЭтоУстаревшийКомментарийEntera(КомментарийИзНастроек) Тогда
			Возврат КомментарийПоУмолчанию;
		КонецЕсли;
		
		Возврат КомментарийИзНастроек;
	КонецЕсли;
	
	Возврат КомментарийПоУмолчанию;
	
КонецФункции

Функция ЭтоУстаревшийКомментарийEntera(Комментарий)
	
	ТекстНорм = НРег(СокрЛП(Комментарий));
	Если Не ЗначениеЗаполнено(ТекстНорм) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Найти(ТекстНорм, "entera") > 0;
	
КонецФункции

// Заполняет обязательный реквизит «Способ зачета авансов» при создании поступления.
//
Процедура ЗаполнитьСпособЗачетаАвансовДокументаПоступления(ДокументОбъект, СтруктураНастроек = Неопределено)
	
	Если Не РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "СпособЗачетаАвансов") Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		Если ЗначениеЗаполнено(ДокументОбъект.СпособЗачетаАвансов) Тогда
			Возврат;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	СпособЗачетаАвансов = ПолучитьСпособЗачетаАвансовПоУмолчанию(СтруктураНастроек);
	Если СпособЗачетаАвансов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ДокументОбъект.СпособЗачетаАвансов = СпособЗачетаАвансов;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция ПолучитьСпособЗачетаАвансовПоУмолчанию(СтруктураНастроек = Неопределено)
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию")
		И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию) Тогда
		Возврат СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию;
	КонецЕсли;
	
	Если РеквизитСуществует("Перечисления", "СпособыЗачетаАвансов", "Автоматически") Тогда
		Попытка
			Возврат Перечисления.СпособыЗачетаАвансов.Автоматически;
		Исключение
			Попытка
				Возврат ПредопределенноеЗначение("Перечисление.СпособыЗачетаАвансов.Автоматически");
			Исключение
			КонецПопытки;
		КонецПопытки;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ЗаписатьСобытиеРаспознавания(Этап, Сообщение, Уровень = Неопределено)
	
	Если Уровень = Неопределено Тогда
		Уровень = УровеньЖурналаРегистрации.Информация;
	КонецЕсли;
	
	ЗаписьЖурналаРегистрации(
		"Распознавание_Высота.Распознавание",
		Уровень,
		,
		,
		СтрШаблон("%1: %2", Этап, Сообщение));
	
КонецПроцедуры

#Область ПодсистемаНастроек

Функция ОбъектНеНайден(Ссылка) Экспорт
	
	//Комментарий для аудитора: проверка значения может быть выполнена для недоступного пользователю объекта, установим привилегированный режим,
	//разрешение на его использование присутствует в списке запрашиваемых разрешений для публикуемого расширения
	УстановитьПривилегированныйРежим(Истина);
	
	Если Ссылка = Неопределено Или Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Попытка
		Если Ссылка.Пустая() Тогда
			Возврат Ложь;
		Иначе
			Объект = Ссылка.ПолучитьОбъект();
			Возврат Объект = Неопределено;
		КонецЕсли;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции
Функция ТТН_РазложитьСтрокуВМассивПодстрок(Знач Строка, Знач Разделитель = ",", Знач ПропускатьПустыеСтроки = Неопределено, СокращатьНепечатаемыеСимволы = Ложь) Экспорт
	
	Результат = Новый Массив;
	
	// Для обеспечения обратной совместимости.
	Если ПропускатьПустыеСтроки = Неопределено Тогда
		ПропускатьПустыеСтроки = ?(Разделитель = " ", Истина, Ложь);
		Если ПустаяСтрока(Строка) Тогда 
			Если Разделитель = " " Тогда
				Результат.Добавить("");
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	//
	
	Позиция = Найти(Строка, Разделитель);
	Пока Позиция > 0 Цикл
		Подстрока = Лев(Строка, Позиция - 1);
		Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Подстрока) Тогда
			Если СокращатьНепечатаемыеСимволы Тогда
				Результат.Добавить(СокрЛП(Подстрока));
			Иначе
				Результат.Добавить(Подстрока);
			КонецЕсли;
		КонецЕсли;
		Строка = Сред(Строка, Позиция + СтрДлина(Разделитель));
		Позиция = Найти(Строка, Разделитель);
	КонецЦикла;
	
	Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Строка) Тогда
		Если СокращатьНепечатаемыеСимволы Тогда
			Результат.Добавить(СокрЛП(Строка));
		Иначе
			Результат.Добавить(Строка);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 
Функция РеквизитСуществует(РазделМетаданных, ОбъектМетаданных, ИмяРеквизита = Неопределено, ИмяТабЧасти = Неопределено) Экспорт
	
	Существует = Ложь;
		
	Если Метаданные[РазделМетаданных].Найти(ОбъектМетаданных) <> Неопределено Тогда
		Если ИмяРеквизита = Неопределено И ИмяТабЧасти = Неопределено Тогда
			Существует = Истина;
		Иначе	
			Если ИмяТабЧасти = Неопределено Тогда
				Если РазделМетаданных = "Перечисления" Тогда
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].ЗначенияПеречисления.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				Иначе
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				КонецЕсли;
			Иначе
				ТабличнаяЧасть = Метаданные[РазделМетаданных][ОбъектМетаданных].ТабличныеЧасти.Найти(ИмяТабЧасти);
				Если ТабличнаяЧасть <> Неопределено И ТабличнаяЧасть.Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
					Существует = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Существует;
КонецФункции
Процедура ЗаполнитьДеревоНастроек(ДеревоНастроек, ЗагружаемаяСтруктураНастроек = Неопределено) Экспорт
	
	ИзбранныеНастройки = ХранилищеОбщихНастроек.Загрузить("Распознавание_Высота","ИзбранныеНастройки");
	Если ИзбранныеНастройки = Неопределено Тогда
		ИзбранныеНастройки = Новый Структура;
	КонецЕсли;
	
	Если ЗагружаемаяСтруктураНастроек = Неопределено Тогда
		СтруктураНастроек = ХранилищеОбщихНастроек.Загрузить("Распознавание_Высота","ОбщиеНастройки");
		Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
			СтруктураНастроек = Новый Структура;
		КонецЕсли;
	Иначе
		СтруктураНастроек = ЗагружаемаяСтруктураНастроек;
	КонецЕсли;
	
	//В процессе развития модуля некоторые настройки при восстановлении нужно привести к новому значению ключа настройки
	ПреобразоватьТипыЗначенийСохраненныхРанееНастроек(СтруктураНастроек);
	
	Иерархия = Новый Соответствие;
	Иерархия.Вставить("",ДеревоНастроек);
	
	Макет = ПолучитьМакет("ШаблонНастроек");
	Область = Макет.ПолучитьОбласть("НастройкиОбщие");
	
	ДоступныеТипыДокументов = ПолучитьСписокЗаполняемыхДокументов();
	Конф = ПолучитьОписаниеКонфигурации();
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		НастройкаИД					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		НастройкаНаименование		=	ПолучитьТекстЯчейкиОбласти(Область,Сч,2);
		ЭтоГруппа					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,3);
		ТекГруппа					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,4);
		ТекТип						=	ПолучитьТекстЯчейкиОбласти(Область,Сч,5);
		ЗначениеПоУмолчанию			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,7);
		Описание					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,8);
		ОтображатьНастройку			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,9);
		СтартовыйПомощник			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,10);
		
		Если ОтображатьНастройку = "0" Тогда
			Продолжить;
		КонецЕсли;
				
		Если ЭтоГруппа = "Истина" Тогда
			
			НоваяСтрока = Иерархия[ТекГруппа].Строки.Добавить();
			НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
			НоваяСтрока.НастройкаИД	= НастройкаИД;
			НоваяСтрока.НастройкаНаименование = НастройкаНаименование;
			НоваяСтрока.Описание = Описание;

			Иерархия.Вставить(НастройкаИД,НоваяСтрока);
		Иначе
			
			НоваяСтрока = Иерархия[ТекГруппа].Строки.Добавить();
			НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
			НоваяСтрока.НастройкаИД				=	НастройкаИД;
			НоваяСтрока.НастройкаНаименование	=	НастройкаНаименование;
			НоваяСтрока.Описание				=	Описание;
			
			Если Лев(ТекТип,14) = "_ВыборИзСписка" Тогда
				НоваяСтрока.ОписаниеТипа	=	Новый ОписаниеТипов("Строка");
				НоваяСтрока.СписокВыбора = ЗначениеВСтрокуВнутр(ПолучитьСписокЗначенийИзМакета(Макет,ТекТип));
				
			ИначеЕсли ТекТип = "Метаданные.Справочники" Тогда
				НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СписокЗначений");
				
				СписокМетаданных = Новый СписокЗначений;
				СписокМетаданных.Добавить("","<Пустое значение>");
				
				Для Каждого ЭлМетаданных Из Метаданные.Справочники Цикл
					СписокМетаданных.Добавить(ЭлМетаданных.Имя,ЭлМетаданных.Синоним);
				КонецЦикла;	
				
				НоваяСтрока.СписокВыбора = ЗначениеВСтрокуВнутр(СписокМетаданных);
				
			ИначеЕсли ТекТип = "СчетУчета" Тогда				
				НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов(ПланыСчетов.ТипВсеСсылки().Типы());
				
			ИначеЕсли ТекТип = "ТипДокумента" Тогда				
				НоваяСтрока.ОписаниеТипа	=	Новый ОписаниеТипов("Строка");
				НоваяСтрока.СписокВыбора = ЗначениеВСтрокуВнутр(ДоступныеТипыДокументов);
				
			ИначеЕсли ТекТип = "ОрганизацияСсылка" Тогда
				Если РеквизитСуществует("Справочники","Организации") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Организации");
				ИначеЕсли РеквизитСуществует("Справочники","Фирмы") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Фирмы");
				ИначеЕсли РеквизитСуществует("Справочники","Салоны") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Салоны");
				КонецЕсли;
				
			//2022.03.04 ( Теперь есть отдельная настройка по умолчанию ПодразделениеОрганизации	
			ИначеЕсли ТекТип = "ПодразделениеОрганизацииСсылка" Тогда
				
				//2020.09.15 ( В БП30 добавили справочник СтруктураПредприятия, но функционал у него не связан с ПодразделенияОрганизаций
				//определяем используемый тип в зависимости от конфигурации, если не определили - используем исходный вариант
				ОписаниеТипаПодразделение = Неопределено;
				
				//2021.04.01 ( Новая вводная: даем выбор подразделений из найденных типов (Для Управления Холдингом)
				Если Найти(Метаданные.Имя,"УправлениеХолдингом") > 0 Тогда
					
					МассивТипов = Новый Массив;
					
					Если РеквизитСуществует("Справочники","ПодразделенияОрганизаций") Тогда
						МассивТипов.Добавить(Тип("СправочникСсылка.ПодразделенияОрганизаций"));
					КонецЕсли;
					
					Если РеквизитСуществует("Справочники","СтруктураПредприятия") Тогда
						МассивТипов.Добавить(Тип("СправочникСсылка.СтруктураПредприятия"));
					КонецЕсли;
					
					ОписаниеТипаПодразделение = Новый ОписаниеТипов(МассивТипов);					
				// ) 2021.04.01
				
				ИначеЕсли Конф.Крат = "БП30" Или Найти(Метаданные.Имя,"Бухгалтерия") > 0 Тогда
					Если РеквизитСуществует("Справочники","ПодразделенияОрганизаций") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций");
					КонецЕсли;
					
				ИначеЕсли Конф.Крат = "ERP" И РеквизитСуществует("Справочники","ПодразделенияОрганизаций") Тогда
					ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций");
					
				КонецЕсли;
				
				Если ОписаниеТипаПодразделение = Неопределено Тогда
				// ) 2020.09.15
				
					//2023.05.23 ( Условие перемещено на самый верх, так как в УНФ 3.0.3 добавили справочник СтруктураПредприятия
					Если РеквизитСуществует("Справочники","СтруктурныеЕдиницы") Тогда //УНФ
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы");	
					// ) 2023.05.23
					
					ИначеЕсли РеквизитСуществует("Справочники","СтруктураПредприятия") Тогда //УТ11
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
						
					ИначеЕсли РеквизитСуществует("Справочники","ПодразделенияОрганизаций") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций");
						
					ИначеЕсли РеквизитСуществует("Справочники","ПодразделенияКомпании") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияКомпании");
						
					КонецЕсли;
					
				КонецЕсли;
				
				НоваяСтрока.ОписаниеТипа = ОписаниеТипаПодразделение;
				
			ИначеЕсли ТекТип = "ПодразделениеСсылка" Тогда
				
				//2020.09.15 ( В БП30 добавили справочник СтруктураПредприятия, но функционал у него не связан с ПодразделенияОрганизаций
				//определяем используемый тип в зависимости от конфигурации, если не определили - используем исходный вариант
				ОписаниеТипаПодразделение = Неопределено;
				
				//2021.04.01 ( Новая вводная: даем выбор подразделений из найденных типов (Для Управления Холдингом)
				Если Найти(Метаданные.Имя,"УправлениеХолдингом") > 0 Тогда
					
					МассивТипов = Новый Массив;
					
					Если РеквизитСуществует("Справочники","Подразделения") Тогда
						МассивТипов.Добавить(Тип("СправочникСсылка.Подразделения"));
					КонецЕсли;
					
					Если РеквизитСуществует("Справочники","СтруктураПредприятия") Тогда
						МассивТипов.Добавить(Тип("СправочникСсылка.СтруктураПредприятия"));
					КонецЕсли;
					
					ОписаниеТипаПодразделение = Новый ОписаниеТипов(МассивТипов);					
				// ) 2021.04.01
				
				ИначеЕсли Конф.Крат = "БП30" Или Найти(Метаданные.Имя,"Бухгалтерия") > 0 Тогда
					Если РеквизитСуществует("Справочники","Подразделения") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.Подразделения");
					КонецЕсли;
				КонецЕсли;
				
				Если ОписаниеТипаПодразделение = Неопределено Тогда
				// ) 2020.09.15
				
					//2023.05.23 ( Условие перемещено на самый верх, так как в УНФ 3.0.3 добавили справочник СтруктураПредприятия
					Если РеквизитСуществует("Справочники","СтруктурныеЕдиницы") Тогда //УНФ
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы");	
					// ) 2023.05.23
				
					ИначеЕсли РеквизитСуществует("Справочники","СтруктураПредприятия") Тогда //УТ11
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
						
					ИначеЕсли РеквизитСуществует("Справочники","ПодразделенияКомпании") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияКомпании");
						
					ИначеЕсли РеквизитСуществует("Справочники","Подразделения") Тогда
						ОписаниеТипаПодразделение = Новый ОписаниеТипов("СправочникСсылка.Подразделения");
						
					КонецЕсли;
					
				КонецЕсли;
				
				НоваяСтрока.ОписаниеТипа = ОписаниеТипаПодразделение;
				
			ИначеЕсли ТекТип = "БанковскийСчетОрганизацииСсылка" Тогда
				Если РеквизитСуществует("Справочники","БанковскиеСчетаОрганизаций") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчетаОрганизаций");
				ИначеЕсли РеквизитСуществует("Справочники","БанковскиеСчета") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.БанковскиеСчета");
				КонецЕсли;
			
			ИначеЕсли ТекТип = "КассаККМСсылка" Тогда
				Если РеквизитСуществует("Справочники","КассыККМ") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.КассыККМ");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "СкладСсылка" Тогда
				Если РеквизитСуществует("Справочники","Склады") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Склады");
				ИначеЕсли РеквизитСуществует("Справочники","СкладыКомпании") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.СкладыКомпании");
				ИначеЕсли РеквизитСуществует("Справочники","СтруктурныеЕдиницы") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.СтруктурныеЕдиницы");
				ИначеЕсли РеквизитСуществует("Справочники","ЦМО") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ЦМО");
				ИначеЕсли РеквизитСуществует("Справочники","МестаХранения") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.МестаХранения");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "НоменклатураСсылка" Тогда
				НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
				
			ИначеЕсли ТекТип = "СписокГрупп_НоменклатураСсылка" Тогда
				МассивТипов = Новый Массив;
				МассивТипов.Добавить(Тип("СправочникСсылка.Номенклатура"));
				МассивТипов.Добавить(Тип("СписокЗначений"));
				НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов(МассивТипов);
			
			ИначеЕсли ТекТип = "ВидНоменклатурыСсылка" Тогда
				Если РеквизитСуществует("Справочники","ВидыНоменклатуры") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВидыНоменклатуры");
					
				//Автосалон, КомбинатПитания, УправлениеРестораном: в конфигурации Вид - перечисление, Тип - справочник,
				//пользователь задает Тип номенклатуры (справочник), а вид номенклатуры (перечисление) берем из него
				ИначеЕсли РеквизитСуществует("Перечисления","ВидыНоменклатуры") И РеквизитСуществует("Справочники","ТипыНоменклатуры") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ТипыНоменклатуры");
					
				//Моя бухгалтерия Беларусь
				ИначеЕсли РеквизитСуществует("Перечисления","ВидыТМЦ") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("ПеречислениеСсылка.ВидыТМЦ");
					
				//БГУ	
				ИначеЕсли РеквизитСуществует("Перечисления","ТипыНоменклатуры") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("ПеречислениеСсылка.ТипыНоменклатуры");
					
				//ДАЛИОНУправлениеМагазином	
				ИначеЕсли РеквизитСуществует("Справочники","КатегорииТоваров") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.КатегорииТоваров");
				
				КонецЕсли;
				
			//E1C-193: виды/типы цен
			ИначеЕсли ТекТип = "ВидТипЦеныСсылка" Тогда
				Если РеквизитСуществует("Справочники","ТипыЦенНоменклатуры") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ТипыЦенНоменклатуры");
				ИначеЕсли РеквизитСуществует("Справочники","ВидыЦенНоменклатуры") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВидыЦенНоменклатуры");
				ИначеЕсли РеквизитСуществует("Справочники","ВидыЦен") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВидыЦен");
				ИначеЕсли Конф.Крат = "Автосалон" Или Конф.Крат = "КомбинатПитания" Или Конф.Крат = "УправлениеРестораном" Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ТипыЦен");
				ИначеЕсли Конф.Имя = "МояБухгалтерия" Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ТипыЦен");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "НоменклатурнаяГруппаСсылка" Тогда
				Если РеквизитСуществует("Справочники","НоменклатурныеГруппы") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.НоменклатурныеГруппы");
				КонецЕсли;
				
			//E1C-235: Подотчетное лицо для Авансового отчета
			ИначеЕсли ТекТип = "ПодотчетноеЛицоСсылка" Тогда
				//В УНФ это справочник Сотрудники
				Если Конф.Крат = "УНФ" Тогда
					Если РеквизитСуществует("Справочники","Сотрудники") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
					КонецЕсли;
				Иначе
					//В БП - Физлицо
					Если РеквизитСуществует("Справочники","ФизическиеЛица") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица");
					КонецЕсли;
				КонецЕсли;
				
			ИначеЕсли ТекТип = "СтатьяДвиженияДенежныхСредствСсылка" Тогда
				Если РеквизитСуществует("Справочники","СтатьиДвиженияДенежныхСредств") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.СтатьиДвиженияДенежныхСредств");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "СтатьяЗатратСсылка" Тогда
				Если РеквизитСуществует("Справочники","СтатьиЗатрат") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.СтатьиЗатрат");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "СпособУчетаНДС" Тогда
				Если РеквизитСуществует("Перечисления","СпособыУчетаНДС") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("ПеречислениеСсылка.СпособыУчетаНДС");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "СпособЗачетаАвансов" Тогда
				Если РеквизитСуществует("Перечисления","СпособыЗачетаАвансов") Тогда
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("ПеречислениеСсылка.СпособыЗачетаАвансов");
				КонецЕсли;
				
			ИначеЕсли ТекТип = "УзелОбмена" Тогда
				НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов(ПланыОбмена.ТипВсеСсылки().Типы());
				
			ИначеЕсли ТекТип = "ВнешняяОбработка" Тогда
				
				НоваяСтрока.Значение = Неопределено;
				
				Если Конф.Крат = "Автосалон" Или Конф.Крат = "КомбинатПитания" Или Конф.Крат = "УправлениеРестораном" Тогда
					Если РеквизитСуществует("Справочники","ВнешниеПечатныеФормы") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВнешниеПечатныеФормы");
					КонецЕсли;
				Иначе
				
					// 2020.05.28 ( Персонально для клиента, у которого в УТ10.3 добавлены оба справочника >_<
					Если РеквизитСуществует("Справочники","ВнешниеОбработки")
						И РеквизитСуществует("Справочники","ДополнительныеОтчетыИОбработки") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВнешниеОбработки");
					// ) 2020.05.28
					
					ИначеЕсли РеквизитСуществует("Справочники","ДополнительныеОтчетыИОбработки") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ДополнительныеОтчетыИОбработки");
					ИначеЕсли РеквизитСуществует("Справочники","ВнешниеОбработки") Тогда
						НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов("СправочникСсылка.ВнешниеОбработки");
					КонецЕсли;
				КонецЕсли;
				
			Иначе
				Попытка
					НоваяСтрока.ОписаниеТипа = Новый ОписаниеТипов(ТекТип);
				Исключение
					//Не обрабатываем исключение
				КонецПопытки;
				
			КонецЕсли;
			
			//Костыль для сохранения значения в табличной части для ОФ
			НоваяСтрока.ОписаниеТипаСтрокой = ЗначениеВСтрокуВнутр(НоваяСтрока.ОписаниеТипа);
			
			СохраненноеЗначение = Неопределено;
			ЕстьСохраненноеСвойство = СтруктураНастроек.Свойство(НоваяСтрока.НастройкаИД,СохраненноеЗначение);
						
			//Проверяем и заполняем значение настройки
			Если ЕстьСохраненноеСвойство И СохраненноеЗначение <> Неопределено Тогда
				
				ЭтоСправочник = Справочники.ТипВсеСсылки().СодержитТип(ТипЗнч(СохраненноеЗначение)) = Истина;
				Если Не ЭтоСправочник Или (ЭтоСправочник И Не ОбъектНеНайден(СохраненноеЗначение)) Тогда
					НоваяСтрока.Значение = СохраненноеЗначение;
				КонецЕсли;
				
			ИначеЕсли ЕстьСохраненноеСвойство И ТекТип = "Число" Тогда
				НоваяСтрока.Значение = СохраненноеЗначение;
				
			Иначе
				НоваяСтрока.Значение = ЗначениеПоУмолчанию;
				
			КонецЕсли;
			
			//Если мы знаем тип настройки, приведем устанавливаемое значение к этому типу
			Если ЗначениеЗаполнено(НоваяСтрока.ОписаниеТипа) Тогда
				НоваяСтрока.Значение = НоваяСтрока.ОписаниеТипа.ПривестиЗначение(НоваяСтрока.Значение);
			КонецЕсли;
			
			НоваяСтрока.СтартовыйПомощник = СтартовыйПомощник = "1";
			
		КонецЕсли;
		
		//Всегда отображаем группы настроек, настройки стартового помощника и выбранные пользователем избранные настройки,
		//для обычного интерфейса при переданном параметре ТолькоИзбранное формируем дерево только из Избранных настроек
		Если НоваяСтрока.ЭтоГруппа
			Или НоваяСтрока.СтартовыйПомощник
			Или ИзбранныеНастройки.Свойство(НоваяСтрока.НастройкаИД) Тогда
			
			НоваяСтрока.Избранное = 1;
			НоваяСтрока.ОтображатьВсегда = Истина;
			
		Иначе
			НоваяСтрока.Избранное = 0;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТекстЯчейкиОбласти(Область,Строка,Колонка) Экспорт
	Возврат Строка(Область.ПолучитьОбласть("R"+Формат(Строка,"ЧГ=0")+"C"+Формат(Колонка,"ЧГ=0")).ТекущаяОбласть.Текст);
КонецФункции

Функция ПолучитьСписокЗначенийИзМакета(Макет,ИмяСписка)
	
	СписокЗначений = Новый СписокЗначений;
	
	Область = Макет.ПолучитьОбласть(ИмяСписка);
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		
		ОтображатьНастройку = ПолучитьТекстЯчейкиОбласти(Область,Сч,9);
	
		Если ОтображатьНастройку = "0" Тогда
			Продолжить;
		КонецЕсли;
		
		СписокЗначений.Добавить(ПолучитьТекстЯчейкиОбласти(Область,Сч,1),ПолучитьТекстЯчейкиОбласти(Область,Сч,2));
	КонецЦикла;		
	
	Возврат СписокЗначений;
	
КонецФункции


Процедура ПреобразоватьТипыЗначенийСохраненныхРанееНастроек(СтруктураНастроек)
	
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
		
	//E1C-395: Изменился тип существующей настройки СозданиеДокумента_КонтрольДубликатовДокументов, раньше был Булево,
	//теперь - строка из списка вариантов присоединения. Преобразуем в СтруктуреНастроек сохраненное значение в новое
	Если СтруктураНастроек.Свойство("СозданиеДокумента_КонтрольДубликатовДокументов")
		И ТипЗнч(СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов) = Тип("Булево") Тогда
		Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = Истина Тогда
			СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Контрагент, Номер, Дата документа";
		Иначе
			СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Нет";
		КонецЕсли;
		
	//E1C-497: Теперь настройка "Сворачивать данные табличной части в одну строку"
	//подразумевает вместо исходного Булево три различных варианта, Преобразуем хранимое значение
	ИначеЕсли СтруктураНастроек.Свойство("ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку")
		И ТипЗнч(СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку) = Тип("Булево") Тогда
		Если СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку = Истина Тогда
			СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку = "Да, оставляя количество = 1";
		Иначе
			СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку = "Нет";
		КонецЕсли;
			
	КонецЕсли;
		
КонецПроцедуры
