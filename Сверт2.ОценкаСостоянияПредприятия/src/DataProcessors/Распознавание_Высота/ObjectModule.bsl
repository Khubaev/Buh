Функция ЗначениеПоляРаспознавания(СтруктураСтроки, ИмяПоля, ЗначениеПоУмолчанию)
	
	Если СтруктураСтроки = Неопределено Или ТипЗнч(СтруктураСтроки) <> Тип("Структура") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Если СтруктураСтроки.Свойство(ИмяПоля) Тогда
		Возврат СтруктураСтроки[ИмяПоля];
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

Функция ЗначениеПоляРаспознаванияПоСписку(СтруктураСтроки, ИменаПолей, ЗначениеПоУмолчанию = "")
	
	Если ТипЗнч(ИменаПолей) <> Тип("Массив") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;
	
	Для Каждого ИмяПоля Из ИменаПолей Цикл
		Значение = ЗначениеПоляРаспознавания(СтруктураСтроки, ИмяПоля, "");
		Если ЗначениеЗаполнено(Значение) Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

// Извлекает код и наименование единицы измерения из строки распознавания (поддерживает разные имена полей API).
//
Функция ИзвлечьДанныеЕдиницыИзмеренияИзСтрокиТовара(СтрокаТовара) Экспорт
	
	Результат = Новый Структура("КодОКЕИ, НаименованиеЕИ, Представление", "", "", "");
	
	Если СтрокаТовара = Неопределено Или ТипЗнч(СтрокаТовара) <> Тип("Структура") Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИменаКода = Новый Массив;
	ИменаКода.Добавить("uom_code");
	ИменаКода.Добавить("unitCode");
	ИменаКода.Добавить("recognizedUnitCode");
	ИменаКода.Добавить("unit_code");
	ИменаКода.Добавить("measure_unit_code");
	ИменаКода.Добавить("unit_of_measure_code");
	ИменаКода.Добавить("okei_code");
	ИменаКода.Добавить("ЕдиницаИзмеренияКод");
	ИменаКода.Добавить("КодЕдиницыИзмерения");
	
	ИменаНаименования = Новый Массив;
	ИменаНаименования.Добавить("uom_name");
	ИменаНаименования.Добавить("unitName");
	ИменаНаименования.Добавить("userUnitName");
	ИменаНаименования.Добавить("recognizedUnit");
	ИменаНаименования.Добавить("unit_name");
	ИменаНаименования.Добавить("uom");
	ИменаНаименования.Добавить("unit");
	ИменаНаименования.Добавить("unit_of_measure");
	ИменаНаименования.Добавить("measure_unit");
	ИменаНаименования.Добавить("measure_unit_name");
	ИменаНаименования.Добавить("ЕдиницаИзмерения");
	ИменаНаименования.Добавить("Ед");
	ИменаНаименования.Добавить("ед");
	
	Результат.КодОКЕИ = СокрЛП(Строка(ЗначениеПоляРаспознаванияПоСписку(СтрокаТовара, ИменаКода)));
	Результат.НаименованиеЕИ = СокрЛП(Строка(ЗначениеПоляРаспознаванияПоСписку(СтрокаТовара, ИменаНаименования)));
	
	Если СтрокаТовара.Свойство("unit") И ТипЗнч(СтрокаТовара.unit) = Тип("Структура") Тогда
		Если Не ЗначениеЗаполнено(Результат.КодОКЕИ) Тогда
			Результат.КодОКЕИ = СокрЛП(Строка(ЗначениеПоляРаспознаванияПоСписку(
				СтрокаТовара.unit,
				Новый Массив("code", "unitCode", "uom_code"))));
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Результат.НаименованиеЕИ) Тогда
			Результат.НаименованиеЕИ = СокрЛП(Строка(ЗначениеПоляРаспознаванияПоСписку(
				СтрокаТовара.unit,
				Новый Массив("name", "unitName", "uom_name"))));
		КонецЕсли;
	КонецЕсли;
	
	Результат.Представление = ПредставлениеЕдиницыИзмеренияИзРаспознавания(Результат.КодОКЕИ, Результат.НаименованиеЕИ);
	
	Возврат Результат;
	
КонецФункции

Функция ЕдиницаИзмеренияПоУмолчаниюРаспознавания() Экспорт
	
	Попытка
		Единица = Справочники.КлассификаторЕдиницИзмерения.ПолучитьЕдиницуИзмеренияПоУмолчанию();
		Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Единица = НайтиЕдиницуКлассификатораПоКоду("796");
	Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	Единица = НайтиЕдиницуКлассификатораПоНаименованию("шт");
	Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	Единица = НайтиЕдиницуКлассификатораПоНаименованию("штука");
	Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	Попытка
		Единица = Справочники.КлассификаторЕдиницИзмерения.НайтиПоНаименованию("шт", Истина);
		Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Единицы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.КлассификаторЕдиницИзмерения КАК Единицы
		|ГДЕ
		|	НЕ Единицы.ПометкаУдаления
		|	И (Единицы.Код = ""796""
		|		ИЛИ Единицы.Наименование = ""шт""
		|		ИЛИ Единицы.Наименование = ""Штука""
		|		ИЛИ Единицы.МеждународноеСокращение = ""PCE"")";
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	
КонецФункции

// Преобразует значение колонки «ЕдиницаИзмеренияСсылка» (строка или ссылка) в ссылку классификатора.
//
Функция ЕдиницаИзмеренияИзЗначенияКолонки(ЗначениеЕдиницы)
	
	ПустаяЕдиница = Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	
	Если Не ЗначениеЗаполнено(ЗначениеЕдиницы) Или ЗначениеЕдиницы = Неопределено Тогда
		Возврат ПустаяЕдиница;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(ЗначениеЕдиницы);
	
	Если ТипЗначения = Тип("Строка") Тогда
		ТекстЕдиницы = СокрЛП(ЗначениеЕдиницы);
		Если Не ЗначениеЗаполнено(ТекстЕдиницы) Тогда
			Возврат ПустаяЕдиница;
		КонецЕсли;
		
		Единица = НайтиЕдиницуИзмеренияДляСтроки(Справочники.Номенклатура.ПустаяСсылка(), ТекстЕдиницы, ТекстЕдиницы);
		Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
		
		Попытка
			УникальныйИдентификатор = Новый УникальныйИдентификатор(ТекстЕдиницы);
			Единица = Справочники.КлассификаторЕдиницИзмерения.ПолучитьСсылку(УникальныйИдентификатор);
			Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
				Возврат Единица;
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Возврат ПустаяЕдиница;
	КонецЕсли;
	
	Если Справочники.ТипВсеСсылки().СодержитТип(ТипЗначения) Тогда
		Единица = ЗначениеЕдиницы;
		Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПустаяЕдиница;
	
КонецФункции

// Определяет единицу измерения для автосоздания номенклатуры.
//
Функция ЕдиницаИзмеренияДляСозданияНоменклатуры(ДанныеСтроки)
	
	ПустаяЕдиница = Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	Единица = ПустаяЕдиница;
	
	Если ДанныеСтроки <> Неопределено И ТипЗнч(ДанныеСтроки) = Тип("Структура") Тогда
		
		Если ДанныеСтроки.Свойство("ЕдиницаИзмеренияСсылка") И ЗначениеЗаполнено(ДанныеСтроки.ЕдиницаИзмеренияСсылка) Тогда
			Единица = ЕдиницаИзмеренияИзЗначенияКолонки(ДанныеСтроки.ЕдиницаИзмеренияСсылка);
			Если ЗначениеЗаполнено(Единица) Тогда
				Возврат Единица;
			КонецЕсли;
		КонецЕсли;
		
		КодОКЕИ = "";
		НаименованиеЕИ = "";
		Если ДанныеСтроки.Свойство("КодОКЕИ") Тогда
			КодОКЕИ = ДанныеСтроки.КодОКЕИ;
		КонецЕсли;
		Если ДанныеСтроки.Свойство("НаименованиеЕИ") Тогда
			НаименованиеЕИ = ДанныеСтроки.НаименованиеЕИ;
		КонецЕсли;
		
		Единица = НайтиЕдиницуИзмеренияДляСтроки(Справочники.Номенклатура.ПустаяСсылка(), КодОКЕИ, НаименованиеЕИ);
		Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
			Возврат Единица;
		КонецЕсли;
		
	КонецЕсли;
	
	Единица = ЕдиницаИзмеренияПоУмолчаниюРаспознавания();
	Если ЗначениеЗаполнено(Единица) И Не ОбъектНеНайден(Единица) Тогда
		Возврат Единица;
	КонецЕсли;
	
	Возврат ПустаяЕдиница;
	
КонецФункции

Процедура УстановитьЕдиницуИзмеренияОбъектаНоменклатуры(НоменклатураОбъект, ЕдиницаИзмерения)
	
	Если НоменклатураОбъект = Неопределено
		Или Не ЗначениеЗаполнено(ЕдиницаИзмерения)
		Или ОбъектНеНайден(ЕдиницаИзмерения) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		НоменклатураОбъект.ЕдиницаИзмерения = ЕдиницаИзмерения;
	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция ВидНоменклатурыСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга)
	
	ПустойВид = Справочники.ВидыНоменклатуры.ПустаяСсылка();
	
	Если Не РеквизитСуществует("Справочники", "ВидыНоменклатуры")
		Или Не РеквизитСуществует("Справочники", "Номенклатура", "ВидНоменклатуры") Тогда
		Возврат ПустойВид;
	КонецЕсли;
	
	ИмяВида = ?(ЭтоУслуга, "Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга", "Номенклатура_ВидНоменклатурыПоУмолчаниюТовар");
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство(ИмяВида)
		И ЗначениеЗаполнено(СтруктураНастроек[ИмяВида]) Тогда
		Возврат СтруктураНастроек[ИмяВида];
	КонецЕсли;
	
	Возврат ПустойВид;
	
КонецФункции

Функция ЧислоПоляРаспознавания(СтруктураСтроки, ИмяПоля, ЗначениеПоУмолчанию)
	
	Значение = ЗначениеПоляРаспознавания(СтруктураСтроки, ИмяПоля, ЗначениеПоУмолчанию);
	
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Значение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Значение) Тогда
		Возврат Число(СтрЗаменить(Строка(Значение), ",", "."));
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

// Проверяет готовность распознанного документа к созданию в 1С (по логике Entera: шапка + сопоставление ТЧ).
//
Функция ПроверитьКорректностьРаспознавания(ДанныеФайла, СтруктураНастроек, АлгоритмПоискаНоменклатуры = "Артикул,Наименование") Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("УспехРаспознавания", Ложь);
	Результат.Вставить("ОрганизацияЗаполнена", Ложь);
	Результат.Вставить("КонтрагентЗаполнен", Ложь);
	Результат.Вставить("НесопоставленныхПозиций", 0);
	Результат.Вставить("ПолностьюГотов", Ложь);
	Результат.Вставить("ГотовКСозданию", Ложь);
	Результат.Вставить("ОписаниеПроблем", "");
	
	Если ДанныеФайла = Неопределено Или ТипЗнч(ДанныеФайла) <> Тип("Структура") Тогда
		Результат.ОписаниеПроблем = НСтр("ru = 'Нет данных распознавания.'");
		Возврат Результат;
	КонецЕсли;
	
	Результат.УспехРаспознавания = ?(ДанныеФайла.Свойство("Успех"), ДанныеФайла.Успех, Ложь);
	Если Не Результат.УспехРаспознавания Тогда
		Результат.ОписаниеПроблем = НСтр("ru = 'Распознавание завершилось с ошибкой.'");
		Возврат Результат;
	КонецЕсли;
	
	ДокументJSON = ?(ДанныеФайла.Свойство("Документ"), ДанныеФайла.Документ, Неопределено);
	РеквизитыШапки = ОпределитьОрганизациюИКонтрагентаПоДокументу(ДокументJSON, СтруктураНастроек);
	Результат.ОрганизацияЗаполнена = ЗначениеЗаполнено(РеквизитыШапки.Организация);
	Результат.КонтрагентЗаполнен = ЗначениеЗаполнено(РеквизитыШапки.Контрагент);
	
	Товары = ?(ДанныеФайла.Свойство("Товары"), ДанныеФайла.Товары, Неопределено);
	Результат.НесопоставленныхПозиций = КоличествоНесопоставленныхПозицийНоменклатуры(Товары, АлгоритмПоискаНоменклатуры);
	
	Проблемы = Новый Массив;
	Если Не Результат.ОрганизацияЗаполнена Тогда
		Проблемы.Добавить(НСтр("ru = 'не указана организация'"));
	КонецЕсли;
	Если Не Результат.КонтрагентЗаполнен Тогда
		Проблемы.Добавить(НСтр("ru = 'не указан контрагент'"));
	КонецЕсли;
	Если Результат.НесопоставленныхПозиций > 0 Тогда
		Проблемы.Добавить(СтрШаблон(
			НСтр("ru = 'не сопоставлено позиций: %1'"),
			Формат(Результат.НесопоставленныхПозиций, "ЧГ=0")));
	КонецЕсли;
	
	Результат.ГотовКСозданию = Результат.ОрганизацияЗаполнена
		И Результат.КонтрагентЗаполнен
		И (Товары <> Неопределено);
	Результат.ПолностьюГотов = Результат.ГотовКСозданию И Результат.НесопоставленныхПозиций = 0;
	
	Если Проблемы.Количество() > 0 Тогда
		Результат.ОписаниеПроблем = СтрСоединить(Проблемы, "; ");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КоличествоНесопоставленныхПозицийНоменклатуры(ТоварыJSON, АлгоритмПоискаНоменклатуры)
	
	Если ТоварыJSON = Неопределено Или ТипЗнч(ТоварыJSON) <> Тип("Массив") Тогда
		Возврат 0;
	КонецЕсли;
	
	ТаблицаНоменклатуры = Новый ТаблицаЗначений;
	ТаблицаНоменклатуры.Колонки.Добавить("Наименование");
	ТаблицаНоменклатуры.Колонки.Добавить("Номенклатура");
	ТаблицаНоменклатуры.Колонки.Добавить("Количество");
	ТаблицаНоменклатуры.Колонки.Добавить("ЕдиницаИзмерения");
	ТаблицаНоменклатуры.Колонки.Добавить("ЕдиницаИзмеренияСсылка");
	ТаблицаНоменклатуры.Колонки.Добавить("Цена");
	ТаблицаНоменклатуры.Колонки.Добавить("Сумма");
	ТаблицаНоменклатуры.Колонки.Добавить("СуммаНДС");
	ТаблицаНоменклатуры.Колонки.Добавить("СпособСопоставления");
	
	ЗаполнитьСтрокиРаспознаннойНоменклатуры(ТоварыJSON, ТаблицаНоменклатуры, АлгоритмПоискаНоменклатуры);
	
	Счетчик = 0;
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Счетчик = Счетчик + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Счетчик;
	
КонецФункции

// --- Автосоздание номенклатуры по настройкам Entera ---

Функция ПолучитьТоварыРаспознаванияИзДокумента(ДокументJSON, ТоварыJSON = Неопределено) Экспорт
	
	Если ТоварыJSON <> Неопределено И ТипЗнч(ТоварыJSON) = Тип("Массив") Тогда
		Возврат ТоварыJSON;
	КонецЕсли;
	
	Если ДокументJSON <> Неопределено
		И ТипЗнч(ДокументJSON) = Тип("Структура")
		И ДокументJSON.Свойство("items")
		И ТипЗнч(ДокументJSON.items) = Тип("Массив") Тогда
		Возврат ДокументJSON.items;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция НеСоздаватьНоменклатуруЕслиЕстьСовпадениеПоНаименованию(СтруктураНастроек = Неопределено)
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_НеСоздаватьЕслиЕстьПолноеСовпадениеПоНаименованию") Тогда
		Возврат СтруктураНастроек.Номенклатура_НеСоздаватьЕслиЕстьПолноеСовпадениеПоНаименованию = Истина;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ЗаполнятьАртикулыСоздаваемойНоменклатуры(СтруктураНастроек = Неопределено)
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_ЗаполнятьАртикулы") Тогда
		Возврат СтруктураНастроек.Номенклатура_ЗаполнятьАртикулы = Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ТипНоменклатурыПоУмолчаниюИзНастроек(СтруктураНастроек = Неопределено)
	
	ТипПоУмолчанию = "Товар";
	
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_ТипНоменклатурыТоварУслуга")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ТипНоменклатурыТоварУслуга) Тогда
		ТипПоУмолчанию = СокрЛП(Строка(СтруктураНастроек.Номенклатура_ТипНоменклатурыТоварУслуга));
	КонецЕсли;
	
	Возврат ТипПоУмолчанию;
	
КонецФункции

Функция ЭтоУслугаПоТипуНоменклатуры(ТипНоменклатуры)
	
	ТипНормализованный = НРег(СокрЛП(Строка(ТипНоменклатуры)));
	Возврат ТипНормализованный = "услуга"
		Или ТипНормализованный = "агентскиеуслуги";
	
КонецФункции

Функция ГруппаСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга)
	
	ПустаяГруппа = Справочники.Номенклатура.ПустаяСсылка();
	
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат ПустаяГруппа;
	КонецЕсли;
	
	Если ЭтоУслуга
		И СтруктураНастроек.Свойство("Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги) Тогда
		Возврат СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги;
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("Номенклатура_ГруппаСоздаваемойНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатуры) Тогда
		Возврат СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатуры;
	КонецЕсли;
	
	Возврат ПустаяГруппа;
	
КонецФункции

Функция НоменклатурнаяГруппаСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга)
	
	ПустаяГруппа = Неопределено;
	Если РеквизитСуществует("Справочники", "НоменклатурныеГруппы") Тогда
		ПустаяГруппа = Справочники.НоменклатурныеГруппы.ПустаяСсылка();
	КонецЕсли;
	
	Если ТипЗнч(СтруктураНастроек) <> Тип("Структура") Тогда
		Возврат ПустаяГруппа;
	КонецЕсли;
	
	Если ЭтоУслуга
		И СтруктураНастроек.Свойство("Номенклатура_НоменклатурнаяГруппаУслуга")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга) Тогда
		Возврат СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга;
	КонецЕсли;
	
	Если СтруктураНастроек.Свойство("Номенклатура_НоменклатурнаяГруппаТовар")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар) Тогда
		Возврат СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар;
	КонецЕсли;
	
	Возврат ПустаяГруппа;
	
КонецФункции

Функция АвтосозданиеНоменклатурыДоступно(СтруктураНастроек = Неопределено)
	
	ЭтоУслуга = ЭтоУслугаПоТипуНоменклатуры(ТипНоменклатурыПоУмолчаниюИзНастроек(СтруктураНастроек));
	Группа = ГруппаСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга);
	
	Возврат ЗначениеЗаполнено(Группа);
	
КонецФункции

Функция НайтиНоменклатуруПоТочномуНаименованию(Наименование) Экспорт
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		Возврат Справочники.Номенклатура.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	НЕ Номенклатура.ПометкаУдаления
		|	И НЕ Номенклатура.ЭтоГруппа
		|	И (Номенклатура.Наименование = &Наименование
		|		ИЛИ Номенклатура.НаименованиеПолное = &Наименование)";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	
	Попытка
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	Исключение
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	Номенклатура.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	НЕ Номенклатура.ПометкаУдаления
			|	И НЕ Номенклатура.ЭтоГруппа
			|	И Номенклатура.Наименование = &Наименование";
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Возврат Выборка.Ссылка;
		КонецЕсли;
	КонецПопытки;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

// Ищет существующую номенклатуру перед автосозданием, чтобы не создавать дубликаты.
//
Функция НайтиНоменклатуруПередАвтосозданием(
	Наименование,
	СтрокаТовараJSON,
	СтруктураНастроек = Неопределено,
	КонтрагентИД = "",
	АлгоритмПоискаНоменклатуры = "Артикул,Наименование")
	
	Результат = Новый Структура("Номенклатура, Способ", Справочники.Номенклатура.ПустаяСсылка(), "");
	Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
	
	Если ИспользоватьСохраненныеСоответствияНоменклатуры(СтруктураНастроек) Тогда
		Номенклатура = НайтиНоменклатуруПоСохраненномуСоответствию(Наименование, КонтрагентИД);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Сохранено";
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	Если Не НеСоздаватьНоменклатуруЕслиЕстьСовпадениеПоНаименованию(СтруктураНастроек) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Алгоритм = НРег(СокрЛП(АлгоритмПоискаНоменклатуры));
	Артикул = АртикулИзСтрокиТовараJSON(СтрокаТовараJSON);
	КраткоеНаименование = КраткоеНаименованиеНоменклатуры(Наименование);
	
	Если Алгоритм = НРег("Артикул") Тогда
		Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Артикул";
			Возврат Результат;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(Наименование);
		Если Не ЗначениеЗаполнено(Номенклатура) И КраткоеНаименование <> Наименование Тогда
			Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(КраткоеНаименование);
		КонецЕсли;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Наименование";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	Если Алгоритм = НРег("Наименование,Артикул") Тогда
		Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(Наименование);
		Если Не ЗначениеЗаполнено(Номенклатура) И КраткоеНаименование <> Наименование Тогда
			Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(КраткоеНаименование);
		КонецЕсли;
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Наименование";
			Возврат Результат;
		КонецЕсли;
		
		Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			Результат.Номенклатура = Номенклатура;
			Результат.Способ = "Артикул";
		КонецЕсли;
		Возврат Результат;
	КонецЕсли;
	
	// По умолчанию и для "Артикул,Наименование".
	Номенклатура = НайтиНоменклатуруПоАртикулу(Артикул);
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Результат.Номенклатура = Номенклатура;
		Результат.Способ = "Артикул";
		Возврат Результат;
	КонецЕсли;
	
	Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(Наименование);
	Если Не ЗначениеЗаполнено(Номенклатура) И КраткоеНаименование <> Наименование Тогда
		Номенклатура = НайтиНоменклатуруПоТочномуНаименованию(КраткоеНаименование);
	КонецЕсли;
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		Результат.Номенклатура = Номенклатура;
		Результат.Способ = "Наименование";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КраткоеНаименованиеНоменклатуры(Наименование)
	
	Результат = СокрЛП(Строка(Наименование));
	Если СтрДлина(Результат) > 100 Тогда
		Результат = Лев(Результат, 100);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НайтиСтрокуТовараJSONПоНаименованию(ТоварыJSON, Наименование)
	
	Если ТоварыJSON = Неопределено Или ТипЗнч(ТоварыJSON) <> Тип("Массив") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Для Каждого СтрокаТовара Из ТоварыJSON Цикл
		Если ТипЗнч(СтрокаТовара) <> Тип("Структура") Тогда
			Продолжить;
		КонецЕсли;
		
		НаименованиеТовара = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "material_name", "")));
		Если НаименованиеТовара = Наименование Тогда
			Возврат СтрокаТовара;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция АртикулИзСтрокиТовараJSON(СтрокаТовара)
	
	Если СтрокаТовара = Неопределено Или ТипЗнч(СтрокаТовара) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Артикул = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "good_code", "")));
	Если Не ЗначениеЗаполнено(Артикул) Тогда
		Артикул = СокрЛП(Строка(ЗначениеПоляРаспознавания(СтрокаТовара, "recognizedGoodCode", "")));
	КонецЕсли;
	
	Возврат Артикул;
	
КонецФункции

Функция СоздатьЭлементНоменклатурыПоДаннымРаспознавания(
	Наименование,
	ДанныеСтроки,
	СтруктураНастроек,
	ЭтоУслуга,
	ОписаниеОшибки)
	
	ОписаниеОшибки = "";
	ПустаяНоменклатура = Справочники.Номенклатура.ПустаяСсылка();
	Группа = ГруппаСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга);
	
	Если Не ЗначениеЗаполнено(Группа) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не задана группа для автоматически создаваемой номенклатуры в настройках.'");
		Возврат ПустаяНоменклатура;
	КонецЕсли;
	
	Попытка
		ЭтоГруппа = Группа.ЭтоГруппа;
	Исключение
		ЭтоГруппа = Ложь;
	КонецПопытки;
	
	Если Не ЭтоГруппа Тогда
		ОписаниеОшибки = НСтр("ru = 'В настройках указана не группа номенклатуры для автосоздания.'");
		Возврат ПустаяНоменклатура;
	КонецЕсли;
	
	НоменклатураОбъект = Справочники.Номенклатура.СоздатьЭлемент();
	ЕдиницаИзмерения = ЕдиницаИзмеренияДляСозданияНоменклатуры(ДанныеСтроки);
	ВидНоменклатуры = ВидНоменклатурыСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга);
	НоменклатурнаяГруппа = НоменклатурнаяГруппаСоздаваемойНоменклатуры(СтруктураНастроек, ЭтоУслуга);
	
	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("Наименование", КраткоеНаименованиеНоменклатуры(Наименование));
	СтруктураЗаполнения.Вставить("НаименованиеПолное", Наименование);
	СтруктураЗаполнения.Вставить("Родитель", Группа);
	СтруктураЗаполнения.Вставить("Услуга", ЭтоУслуга);
	
	Если ЗначениеЗаполнено(ЕдиницаИзмерения) Тогда
		СтруктураЗаполнения.Вставить("ЕдиницаИзмерения", ЕдиницаИзмерения);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		СтруктураЗаполнения.Вставить("ВидНоменклатуры", ВидНоменклатуры);
		Попытка
			УслугаВида = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидНоменклатуры, "Услуга");
			СтруктураЗаполнения.Вставить("Услуга", УслугаВида);
			ЭтоУслуга = УслугаВида;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(НоменклатурнаяГруппа) Тогда
		СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа", НоменклатурнаяГруппа);
	КонецЕсли;
	
	Если ЗаполнятьАртикулыСоздаваемойНоменклатуры(СтруктураНастроек)
		И ДанныеСтроки <> Неопределено
		И ТипЗнч(ДанныеСтроки) = Тип("Структура")
		И ДанныеСтроки.Свойство("Артикул")
		И ЗначениеЗаполнено(ДанныеСтроки.Артикул) Тогда
		СтруктураЗаполнения.Вставить("Артикул", Лев(СокрЛП(Строка(ДанныеСтроки.Артикул)), 50));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		НоменклатураОбъект.ВидНоменклатуры = ВидНоменклатуры;
	КонецЕсли;
	
	НоменклатураОбъект.Заполнить(СтруктураЗаполнения);
	ЗаполнитьЗначенияСвойств(НоменклатураОбъект, СтруктураЗаполнения);
	
	Если Не ЗначениеЗаполнено(НоменклатураОбъект.Родитель) Тогда
		НоменклатураОбъект.Родитель = Группа;
	КонецЕсли;
	
	Попытка
		ЭтоУслуга = НоменклатураОбъект.Услуга;
	Исключение
	КонецПопытки;
	
	ЕдиницаВОбъекте = Справочники.КлассификаторЕдиницИзмерения.ПустаяСсылка();
	Попытка
		ЕдиницаВОбъекте = НоменклатураОбъект.ЕдиницаИзмерения;
	Исключение
	КонецПопытки;
	
	Если Не ЭтоУслуга И Не ЗначениеЗаполнено(ЕдиницаВОбъекте) Тогда
		Если Не ЗначениеЗаполнено(ЕдиницаИзмерения) Тогда
			ЕдиницаИзмерения = ЕдиницаИзмеренияПоУмолчаниюРаспознавания();
		КонецЕсли;
		УстановитьЕдиницуИзмеренияОбъектаНоменклатуры(НоменклатураОбъект, ЕдиницаИзмерения);
		Попытка
			ЕдиницаВОбъекте = НоменклатураОбъект.ЕдиницаИзмерения;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если Не ЭтоУслуга И Не ЗначениеЗаполнено(ЕдиницаВОбъекте) Тогда
		ОписаниеОшибки = НСтр("ru = 'Не удалось определить единицу измерения. Загрузите классификатор ОКЕИ (шт, код 796) в справочник «Классификатор единиц измерения».'");
		Возврат ПустаяНоменклатура;
	КонецЕсли;
	
	Попытка
		НоменклатураОбъект.Записать();
		Возврат НоменклатураОбъект.Ссылка;
	Исключение
		ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Ошибка записи номенклатуры ""%1"": %2'"),
			Наименование,
			КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат ПустаяНоменклатура;
	КонецПопытки;
	
КонецФункции

// Создаёт номенклатуру для несопоставленных строк таблицы перед созданием документа.
// Перед созданием выполняется поиск существующей номенклатуры в справочнике.
// Пустая ссылка в колонке «Номенклатура» означает намеренный отказ от ручного сопоставления.
//
Функция СоздатьНоменклатуруДляНесопоставленныхСтрок(
	ТаблицаНоменклатуры,
	СтруктураНастроек = Неопределено,
	КонтрагентИД = "",
	ТоварыJSON = Неопределено,
	АлгоритмПоискаНоменклатуры = "Артикул,Наименование") Экспорт
	
	Результат = Новый Структура("Успех, ОписаниеОшибки, СозданоПозиций", Истина, "", 0);
	
	Если ТаблицаНоменклатуры = Неопределено Или ТаблицаНоменклатуры.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры);
	
	Если КоличествоНесопоставленныхПозицийВТаблице(ТаблицаНоменклатуры) = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ЭтоУслуга = ЭтоУслугаПоТипуНоменклатуры(ТипНоменклатурыПоУмолчаниюИзНастроек(СтруктураНастроек));
	СозданныеПоНаименованию = Новый Соответствие;
	ОшибкиСоздания = Новый Массив;
	СчетчикСоздано = 0;
	
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		
		Наименование = ОчиститьНаименованиеОтМаркераСопоставления(Строка(СтрокаНоменклатуры.Наименование));
		Если Не ЗначениеЗаполнено(Наименование) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаТовараJSON = НайтиСтрокуТовараJSONПоНаименованию(ТоварыJSON, Наименование);
		Номенклатура = СозданныеПоНаименованию.Получить(Наименование);
		Способ = "Создано";
		
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			
			РезультатПоиска = НайтиНоменклатуруПередАвтосозданием(
				Наименование,
				СтрокаТовараJSON,
				СтруктураНастроек,
				КонтрагентИД,
				АлгоритмПоискаНоменклатуры);
			
			Если ЗначениеЗаполнено(РезультатПоиска.Номенклатура) Тогда
				Номенклатура = РезультатПоиска.Номенклатура;
				Способ = ?(ЗначениеЗаполнено(РезультатПоиска.Способ), РезультатПоиска.Способ, "Наименование");
				СозданныеПоНаименованию.Вставить(Наименование, Номенклатура);
			КонецЕсли;
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			
			Если Не АвтосозданиеНоменклатурыДоступно(СтруктураНастроек) Тогда
				Продолжить;
			КонецЕсли;
			
			ДанныеСтроки = Новый Структура;
			ДанныеЕдиницы = ИзвлечьДанныеЕдиницыИзмеренияИзСтрокиТовара(СтрокаТовараJSON);
			ДанныеСтроки.Вставить("ЕдиницаИзмеренияСсылка", СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
			ДанныеСтроки.Вставить("Артикул", АртикулИзСтрокиТовараJSON(СтрокаТовараJSON));
			ДанныеСтроки.Вставить("КодОКЕИ", ДанныеЕдиницы.КодОКЕИ);
			ДанныеСтроки.Вставить("НаименованиеЕИ", ?(ЗначениеЗаполнено(ДанныеЕдиницы.НаименованиеЕИ),
				ДанныеЕдиницы.НаименованиеЕИ,
				СокрЛП(Строка(СтрокаНоменклатуры.ЕдиницаИзмерения))));
			
			ТекстОшибки = "";
			Номенклатура = СоздатьЭлементНоменклатурыПоДаннымРаспознавания(
				Наименование,
				ДанныеСтроки,
				СтруктураНастроек,
				ЭтоУслуга,
				ТекстОшибки);
			
			Если Не ЗначениеЗаполнено(Номенклатура) Тогда
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					ОшибкиСоздания.Добавить(ТекстОшибки);
				КонецЕсли;
				Продолжить;
			КонецЕсли;
			
			СчетчикСоздано = СчетчикСоздано + 1;
			Способ = "Создано";
			
			Если ЗапоминатьУстановленныеВручнуюСоответствияНоменклатуры(СтруктураНастроек) Тогда
				ЗаписатьСоответствиеНоменклатуры(Номенклатура, Наименование, КонтрагентИД);
			КонецЕсли;
			
			СозданныеПоНаименованию.Вставить(Наименование, Номенклатура);
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Номенклатура) Тогда
			СтрокаНоменклатуры.Номенклатура = Номенклатура;
			СтрокаНоменклатуры.Наименование = Наименование + МаркерСпособаСопоставления(Способ);
			ДанныеЕдиницыСтроки = ИзвлечьДанныеЕдиницыИзмеренияИзСтрокиТовара(СтрокаТовараJSON);
			Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.ЕдиницаИзмерения) И ЗначениеЗаполнено(ДанныеЕдиницыСтроки.Представление) Тогда
				СтрокаНоменклатуры.ЕдиницаИзмерения = ДанныеЕдиницыСтроки.Представление;
			КонецЕсли;
			ЕдиницаСсылка = ЕдиницаИзмеренияИзЗначенияКолонки(СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
			Если Не ЗначениеЗаполнено(ЕдиницаСсылка) Тогда
				ЕдиницаСсылка = НайтиЕдиницуИзмеренияДляСтроки(
					Номенклатура,
					ДанныеЕдиницыСтроки.КодОКЕИ,
					?(ЗначениеЗаполнено(ДанныеЕдиницыСтроки.НаименованиеЕИ),
						ДанныеЕдиницыСтроки.НаименованиеЕИ,
						СокрЛП(Строка(СтрокаНоменклатуры.ЕдиницаИзмерения))));
			КонецЕсли;
			Если ЗначениеЗаполнено(ЕдиницаСсылка) Тогда
				СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка = ЕдиницаСсылка;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.СозданоПозиций = СчетчикСоздано;
	
	Несопоставленных = КоличествоНесопоставленныхПозицийВТаблице(ТаблицаНоменклатуры);
	Если Несопоставленных > 0 Тогда
		Результат.Успех = Ложь;
		Проблемы = Новый Массив;
		Проблемы.Добавить(СтрШаблон(
			НСтр("ru = 'не сопоставлено позиций: %1'"),
			Формат(Несопоставленных, "ЧГ=0")));
		Если ОшибкиСоздания.Количество() > 0 Тогда
			Проблемы.Добавить(СтрСоединить(ОшибкиСоздания, "; "));
		ИначеЕсли Не АвтосозданиеНоменклатурыДоступно(СтруктураНастроек) Тогда
			Проблемы.Добавить(НСтр("ru = 'укажите группу для автосоздаваемой номенклатуры в настройках'"));
		КонецЕсли;
		Результат.ОписаниеОшибки = СтрСоединить(Проблемы, "; ");
	ИначеЕсли ОшибкиСоздания.Количество() > 0 Тогда
		Результат.Успех = Ложь;
		Результат.ОписаниеОшибки = СтрСоединить(ОшибкиСоздания, "; ");
	КонецЕсли;
	
	Если СчетчикСоздано > 0 Тогда
		ЗаписатьСобытиеРаспознавания(
			"АвтосозданиеНоменклатуры",
			СтрШаблон(НСтр("ru = 'Создано элементов номенклатуры: %1'"), Формат(СчетчикСоздано, "ЧГ=0")));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Проверяет готовность к созданию по данным формы (ручной ввод учитывается).
//
Функция ПроверитьГотовностьДанныхФормыКСозданию(Организация, Контрагент, ТаблицаНоменклатуры) Экспорт
	
	ОчиститьНедействительнуюНоменклатуруВТаблице(ТаблицаНоменклатуры);
	
	Результат = Новый Структура;
	Результат.Вставить("ОрганизацияЗаполнена", ЗначениеЗаполнено(Организация));
	Результат.Вставить("КонтрагентЗаполнен", ЗначениеЗаполнено(Контрагент));
	Результат.Вставить("НесопоставленныхПозиций", КоличествоНесопоставленныхПозицийВТаблице(ТаблицаНоменклатуры));
	Результат.Вставить("ГотовКСозданию", Ложь);
	Результат.Вставить("ОписаниеПроблем", "");
	
	Проблемы = Новый Массив;
	Если Не Результат.ОрганизацияЗаполнена Тогда
		Проблемы.Добавить(НСтр("ru = 'не указана организация'"));
	КонецЕсли;
	Если Не Результат.КонтрагентЗаполнен Тогда
		Проблемы.Добавить(НСтр("ru = 'не указан контрагент'"));
	КонецЕсли;
	Если ТаблицаНоменклатуры = Неопределено Или ТаблицаНоменклатуры.Количество() = 0 Тогда
		Проблемы.Добавить(НСтр("ru = 'нет строк номенклатуры'"));
	КонецЕсли;
	Если Результат.НесопоставленныхПозиций > 0 Тогда
		Проблемы.Добавить(СтрШаблон(
			НСтр("ru = 'не сопоставлено позиций: %1'"),
			Формат(Результат.НесопоставленныхПозиций, "ЧГ=0")));
	КонецЕсли;
	
	Результат.ГотовКСозданию = Результат.ОрганизацияЗаполнена
		И Результат.КонтрагентЗаполнен
		И ТаблицаНоменклатуры <> Неопределено
		И ТаблицаНоменклатуры.Количество() > 0
		И Результат.НесопоставленныхПозиций = 0;
	
	Если Проблемы.Количество() > 0 Тогда
		Результат.ОписаниеПроблем = СтрСоединить(Проблемы, "; ");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КоличествоНесопоставленныхПозицийВТаблице(ТаблицаНоменклатуры)
	
	Если ТаблицаНоменклатуры = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Счетчик = 0;
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура)
			Или ОбъектНеНайден(СтрокаНоменклатуры.Номенклатура) Тогда
			Счетчик = Счетчик + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Счетчик;
	
КонецФункции

// Создаёт документ ПоступлениеТоваровУслуг по данным распознавания.
//
Функция СоздатьПоступлениеПоДаннымРаспознавания(Организация, Контрагент, ДокументJSON, ТаблицаНоменклатуры, СтруктураНастроек = Неопределено, ВидОперации = Неопределено, ПараметрыИсходногоФайла = Неопределено) Экспорт
	
	Результат = Новый Структура("Успех, Ссылка, ОписаниеОшибки", Ложь, Документы.ПоступлениеТоваровУслуг.ПустаяСсылка(), "");
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не указана организация.'");
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Контрагент) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не указан контрагент (поставщик).'");
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаНоменклатуры = Неопределено Или ТаблицаНоменклатуры.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Нет строк номенклатуры для создания документа.'");
		Возврат Результат;
	КонецЕсли;
	
	АлгоритмПоиска = "Артикул,Наименование";
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура")
		И СтруктураНастроек.Свойство("Номенклатура_АлгоритмПоискаНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры) Тогда
		АлгоритмПоиска = СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры;
	КонецЕсли;
	
	КонтрагентИД = КонтрагентИДДляСопоставленияНоменклатуры(ДокументJSON, Контрагент);
	ПодготовкаНоменклатуры = СоздатьНоменклатуруДляНесопоставленныхСтрок(
		ТаблицаНоменклатуры,
		СтруктураНастроек,
		КонтрагентИД,
		ПолучитьТоварыРаспознаванияИзДокумента(ДокументJSON),
		АлгоритмПоиска);
	
	Если Не ПодготовкаНоменклатуры.Успех Тогда
		Результат.ОписаниеОшибки = ПодготовкаНоменклатуры.ОписаниеОшибки;
		Возврат Результат;
	КонецЕсли;
	
	ДокументОбъект = Документы.ПоступлениеТоваровУслуг.СоздатьДокумент();
	ДокументОбъект.Дата = ТекущаяДата();
	ДокументОбъект.Организация = Организация;
	ДокументОбъект.Контрагент = Контрагент;
	
	Если ВидОперации = Неопределено Тогда
		Попытка
			ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку;
		Исключение
			Попытка
				ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку");
			Исключение
			КонецПопытки;
		КонецПопытки;
	КонецЕсли;
	
	Если ВидОперации <> Неопределено Тогда
		ДокументОбъект.ВидОперации = ВидОперации;
	КонецЕсли;
	
	ЗаполнитьРеквизитыДокументаПоступленияИзНастроек(ДокументОбъект, СтруктураНастроек);
	ЗаполнитьДоговорКонтрагентаДокументаПоступления(ДокументОбъект);
	ЗаполнитьВалютуДокументаПоступления(ДокументОбъект, СтруктураНастроек);
	ЗаполнитьНомерИДатуВходящегоДокументаПоступления(ДокументОбъект, ДокументJSON);
	
	Для Каждого СтрокаНоменклатуры Из ТаблицаНоменклатуры Цикл
		Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура) Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ДокументОбъект.Товары.Добавить();
		НоваяСтрока.Номенклатура = СтрокаНоменклатуры.Номенклатура;
		НоваяСтрока.Количество = ?(ЗначениеЗаполнено(СтрокаНоменклатуры.Количество), СтрокаНоменклатуры.Количество, 0);
		
		ЕдиницаСтроки = ЕдиницаИзмеренияИзЗначенияКолонки(СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
		Если Не ЗначениеЗаполнено(ЕдиницаСтроки) Тогда
			ЕдиницаСтроки = НайтиЕдиницуИзмеренияДляСтроки(
				СтрокаНоменклатуры.Номенклатура,
				"",
				СокрЛП(Строка(СтрокаНоменклатуры.ЕдиницаИзмерения)));
		КонецЕсли;
		Если ЗначениеЗаполнено(ЕдиницаСтроки) Тогда
			НоваяСтрока.ЕдиницаИзмерения = ЕдиницаСтроки;
			Если РеквизитСуществует("Документы", "ПоступлениеТоваровУслуг", "Коэффициент", "Товары") Тогда
				Попытка
					НоваяСтрока.Коэффициент = 1;
				Исключение
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.Цена) Тогда
			НоваяСтрока.Цена = СтрокаНоменклатуры.Цена;
		КонецЕсли;
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.Сумма) Тогда
			НоваяСтрока.Сумма = СтрокаНоменклатуры.Сумма;
		ИначеЕсли ЗначениеЗаполнено(НоваяСтрока.Цена) И ЗначениеЗаполнено(НоваяСтрока.Количество) Тогда
			НоваяСтрока.Сумма = Окр(НоваяСтрока.Цена * НоваяСтрока.Количество, 2);
		КонецЕсли;
	КонецЦикла;
	
	Если ДокументОбъект.Товары.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не удалось заполнить табличную часть: номенклатура не сопоставлена.'");
		Возврат Результат;
	КонецЕсли;
	
	ДокументОбъект.ДополнительныеСвойства.Вставить("ЗаполнитьСчетаУчетаПередЗаписью", Истина);
	
	Попытка
		ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
		Результат.Успех = Истина;
		Результат.Ссылка = ДокументОбъект.Ссылка;
		ПрисоединитьИсходныйФайлКДокументу(Результат.Ссылка, ПараметрыИсходногоФайла, СтруктураНастроек);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Создаёт документ 1С по данным распознавания и выбранному типу.
//
Функция СоздатьДокументПоДаннымРаспознавания(ТипДокумента, ВидОперации, Организация, Контрагент, ДокументJSON, ТаблицаНоменклатуры, СтруктураНастроек = Неопределено, ПараметрыИсходногоФайла = Неопределено) Экспорт
	
	Если ТипДокумента = "ПоступлениеТоваровУслуг" Тогда
		Возврат СоздатьПоступлениеПоДаннымРаспознавания(
			Организация,
			Контрагент,
			ДокументJSON,
			ТаблицаНоменклатуры,
			СтруктураНастроек,
			ВидОперации,
			ПараметрыИсходногоФайла);
	КонецЕсли;
	
	Результат = Новый Структура("Успех, Ссылка, ОписаниеОшибки", Ложь, Неопределено, "");
	Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Создание документа типа ""%1"" не поддерживается.'"), ТипДокумента);
	Возврат Результат;
	
КонецФункции

// Возвращает список типов документов, доступных для создания из распознанных данных.
//
Функция ПолучитьСписокТиповСоздаваемыхДокументов() Экспорт
	
	Список = Новый Массив;
	
	Если Метаданные.Документы.Найти("ПоступлениеТоваровУслуг") = Неопределено Тогда
		Возврат Список;
	КонецЕсли;
	
	ВидОперации = Неопределено;
	Попытка
		ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку;
	Исключение
		Попытка
			ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку");
		Исключение
		КонецПопытки;
	КонецПопытки;
	
	Элемент = Новый Структура;
	Элемент.Вставить("Представление", НСтр("ru = 'Поступление товаров — Материалы в переработку'"));
	Элемент.Вставить("ТипДокумента", "ПоступлениеТоваровУслуг");
	Элемент.Вставить("ВидОперацииИмя", "ВПереработку");
	Если ВидОперации <> Неопределено Тогда
		Элемент.Вставить("ВидОперации", ВидОперации);
	КонецЕсли;
	Список.Добавить(Элемент);
	
	Возврат Список;
	
КонецФункции

// Возвращает ссылки на файлы, прикреплённые к объекту (документу и т.п.).
//
Функция ПолучитьСсылкиПрисоединенныхФайловОбъекта(ВладелецФайла) Экспорт
	
	Результат = Новый Массив;
	
	Если Не ЗначениеЗаполнено(ВладелецФайла) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяСправочника = "";
	Попытка
		ИмяСправочника = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла)
		//РаботаСФайлами.ИИмяСправочникаХраненияФайлов(ВладелецФайла);
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Если ПустаяСтрока(ИмяСправочника) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(
		"ВЫБРАТЬ
		|	Файлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.%1 КАК Файлы
		|ГДЕ
		|	Файлы.ВладелецФайла = &Владелец
		|	И НЕ Файлы.ПометкаУдаления",
		ИмяСправочника);
	Запрос.УстановитьПараметр("Владелец", ВладелецФайла);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Помещает прикреплённые к объекту файлы во временное хранилище для отправки на распознавание.
// Возвращает массив структур: ИмяФайла, АдресХранилища, РазмерБайт.
//
Функция ПодготовитьПрисоединенныеФайлыДляРаспознавания(ВладелецФайла, ИдентификаторФормы) Экспорт
	
	Результат = Новый Массив;
	МассивСсылок = ПолучитьСсылкиПрисоединенныхФайловОбъекта(ВладелецФайла);
	
	Для Каждого СсылкаНаФайл Из МассивСсылок Цикл
		
		Попытка
			ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(СсылкаНаФайл);
		Исключение
			Продолжить;
		КонецПопытки;
		
		Если ДвоичныеДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяФайла = ИмяПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл);
		АдресХранилища = ПоместитьВоВременноеХранилище(ДвоичныеДанные, ИдентификаторФормы);
		
		ОписаниеФайла = Новый Структура;
		ОписаниеФайла.Вставить("ИмяФайла", ИмяФайла);
		ОписаниеФайла.Вставить("АдресХранилища", АдресХранилища);
		ОписаниеФайла.Вставить("РазмерБайт", ДвоичныеДанные.Размер());
		Результат.Добавить(ОписаниеФайла);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает полное имя присоединённого файла.
Функция ИмяПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл)
	
	Попытка
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(СсылкаНаФайл);
		ИмяФайла = СокрЛП(ДанныеФайла.ИмяБезРасширения);
		Если ЗначениеЗаполнено(ДанныеФайла.Расширение) Тогда
			ИмяФайла = ИмяФайла + "." + СокрЛП(ДанныеФайла.Расширение);
		КонецЕсли;
		Если ЗначениеЗаполнено(ИмяФайла) Тогда
			Возврат ИмяФайла;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Строка(СсылкаНаФайл);
	
КонецФункции

// Возвращает адрес и токен API.
// Временно используются вшитые значения для проверки — см. ВшитыеПараметрыAPIРаспознавания().
//
Функция ПолучитьПараметрыПодключенияAPIРаспознавания() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("АдресAPI", "");
	Результат.Вставить("АдресAPIСтатуса", "");
	Результат.Вставить("ТокенAPI", "");
	
	Если ИспользоватьВшитыеПараметрыAPIРаспознавания() Тогда
		Результат.АдресAPI = ВшитыйАдресAPIРаспознавания();
		Результат.ТокенAPI = ВшитыйТокенAPIРаспознавания();
		Результат.АдресAPIСтатуса = ВшитыйАдресAPIСтатусаРаспознавания();
		Возврат Результат;
	КонецЕсли;
	
	КлючОбъекта = "Обработка.Распознавание_Высота.Форма.Форма";
	
	ЗаполнитьПараметрыAPIИзСохраненныхДанныхФормы(Результат, ХранилищеОбщихНастроек.Загрузить(КлючОбъекта));
	
	Если Не ЗначениеЗаполнено(Результат.АдресAPI) Тогда
		ЗаполнитьПараметрыAPIИзСохраненныхДанныхФормы(Результат, ХранилищеСистемныхНастроек.Загрузить(КлючОбъекта));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

