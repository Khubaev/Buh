&НаСервере
Функция ПолучитьПоказателиJSON()
    // Здесь — реальный расчёт из ваших регистров
    // Для примера задаём вручную  
	
	
    ДанныеПоРегистру = ПолучитьДанныеПоОтчету();
    Данные = Новый Структура;
    Данные.Вставить("org", "Курорт УТЕС");
    Данные.Вставить("period", "1 кв. 2026 г.");
    
    // Ликвидность
    Данные.Вставить("current_ratio", ДанныеПоРегистру.Получить("59"));
    Данные.Вставить("quick_ratio", ДанныеПоРегистру.Получить("62"));
    Данные.Вставить("absolute_ratio", ДанныеПоРегистру.Получить("67"));
    
    // Рентабельность (в процентах)
    Данные.Вставить("operating", ДанныеПоРегистру.Получить("173"));
    Данные.Вставить("ros", ДанныеПоРегистру.Получить("176"));
    Данные.Вставить("roe", ДанныеПоРегистру.Получить("179"));
    Данные.Вставить("roa", ДанныеПоРегистру.Получить("182"));
    Данные.Вставить("rca", ДанныеПоРегистру.Получить("185"));
    Данные.Вставить("rnca", ДанныеПоРегистру.Получить("188"));
    Данные.Вставить("fixed_assets", ДанныеПоРегистру.Получить("191"));
    
    // Гостиничные (если применимо — можно не передавать)
    Данные.Вставить("occupancy", ДанныеПоРегистру.Получить("195"));
    Данные.Вставить("alos", ДанныеПоРегистру.Получить("196"));
    Данные.Вставить("revpag", ДанныеПоРегистру.Получить("197"));
    Данные.Вставить("adr", ДанныеПоРегистру.Получить("198"));
    
    // Сериализуем в JSON
    Запись = Новый ЗаписьJSON;
    ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, "", Истина);
    Запись.УстановитьСтроку(ПараметрыЗаписиJSON);
    ЗаписатьJSON(Запись, Данные);
    
    Возврат Запись.Закрыть();
КонецФункции

Функция ПолучитьДанныеПоОтчету()
	
	ПоказателиРасчетов = Новый Соответствие();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоказателиДляОтчетаСрезПоследних.Оценка КАК Оценка,
		|	ПоказателиДляОтчетаСрезПоследних.Показатель КАК Показатель,
		|	ПоказателиДляОтчетаСрезПоследних.Показатель.Код КАК ПоказательКод
		|ИЗ
		|	РегистрСведений.ПоказателиДляОтчета.СрезПоследних(, ) КАК ПоказателиДляОтчетаСрезПоследних";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПоказателиРасчетов.Вставить(Выборка.ПоказательКод,Выборка.Оценка);
	КонецЦикла;
	
   Возврат ПоказателиРасчетов;
КонецФункции


