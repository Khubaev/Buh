
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	HTML = ПолучитьHTML();

КонецПроцедуры
 &НаСервере
Функция ПолучитьHTML()
	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("ОценкаКачества");
	Возврат Макет.ПолучитьТекст();
КонецФункции 


&НаКлиенте
Процедура Обновить(Команда)
   СобратьДашбордHTML();

КонецПроцедуры     
 &НаКлиенте
Процедура Сбросить(Команда)
    ДатаОт = '00010101';
    ДатаДо = '00010101';
    СобратьДашбордHTML();
КонецПроцедуры       
&НаКлиенте
Процедура Применить(Команда)
    СобратьДашбордHTML();
КонецПроцедуры
&НаСервере   
 &НаСервере
Процедура СобратьДашбордHTML()

	// Формируем строку фильтра для PostgREST
    ФильтрСтрока = "";
    ОписаниеПериода = "за всё время";
    
    Если ЗначениеЗаполнено(ДатаОт) И ЗначениеЗаполнено(ДатаДо) Тогда
        ФильтрСтрока = "&created_at=gte." + ФорматДатыISO(НачалоДня(ДатаОт))
                     + "&created_at=lte." + ФорматДатыISO(КонецДня(ДатаДо));
        ОписаниеПериода = "с " + Формат(ДатаОт, "ДЛФ=D") + " по " + Формат(ДатаДо, "ДЛФ=D");
    ИначеЕсли ЗначениеЗаполнено(ДатаОт) Тогда
        ФильтрСтрока = "&created_at=gte." + ФорматДатыISO(НачалоДня(ДатаОт));
        ОписаниеПериода = "с " + Формат(ДатаОт, "ДЛФ=D");
    ИначеЕсли ЗначениеЗаполнено(ДатаДо) Тогда
        ФильтрСтрока = "&created_at=lte." + ФорматДатыISO(КонецДня(ДатаДо));
        ОписаниеПериода = "по " + Формат(ДатаДо, "ДЛФ=D");
    КонецЕсли;
    
    Попытка
        Опросы = ЗапроситьSupabase("survey_responses",
            "select=service_quality,cost_rating,cleaning_quality,reception_quality,"
            + "food_quality,service_zone_quality,service_comment,cost_comment,"
            + "cleaning_comment,reception_comment,food_comment,service_zone_comment,created_at"
            + "&order=created_at.desc"
            + ФильтрСтрока);
        
        Комнаты = ЗапроситьSupabase("room_numbers", "select=id,name&order=id.asc");
    Исключение
		//СодержимоеОтчётаHTML = ПостроитьШаблонСОшибкой(ОписаниеОшибки());
        Возврат;
    КонецПопытки;
    
    // ── Средние оценки ──────────────────────────────
    Поля = Новый Массив;
    Поля.Добавить("service_quality");
    Поля.Добавить("cost_rating");
    Поля.Добавить("cleaning_quality");
    Поля.Добавить("reception_quality");
    Поля.Добавить("food_quality");
    Поля.Добавить("service_zone_quality");
    
    Суммы = Новый Соответствие;
    Счётчики = Новый Соответствие;
    Для Каждого П Из Поля Цикл
        Суммы.Вставить(П, 0);
        Счётчики.Вставить(П, 0);
    КонецЦикла;
    
    Для Каждого Стр Из Опросы Цикл
        Для Каждого П Из Поля Цикл
            Значен = Стр[П];
            Если Значен <> Неопределено И Значен <> Null Тогда
                Суммы[П] = Суммы[П] + Значен;
                Счётчики[П] = Счётчики[П] + 1;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
    Средние = Новый Соответствие;
    Для Каждого П Из Поля Цикл
        Если Счётчики[П] > 0 Тогда
            Средние.Вставить(П, Формат(Суммы[П] / Счётчики[П], "ЧДЦ=1; ЧРД=,"));
        Иначе
            Средние.Вставить(П, "—");
        КонецЕсли;
    КонецЦикла;
    
    // ── Список комнат ───────────────────────────────
    БлокКомнат = "";
    Для Каждого К Из Комнаты Цикл
        Имя = ?(К["name"] <> Неопределено И К["name"] <> Null,
                Строка(К["name"]), "№" + К["id"]);
        БлокКомнат = БлокКомнат
            + "<li><span>" + ЭкранироватьHTML(Имя)
            + "</span><span class=""badge"">id " + К["id"] + "</span></li>";
    КонецЦикла;
    Если ПустаяСтрока(БлокКомнат) Тогда
        БлокКомнат = "<li class=""empty-row"">Нет записей</li>";
    КонецЕсли;
    
    // ── Негативные отзывы ───────────────────────────
    БлокНегатива = СобратьНегатив(Опросы);
    
    // ── Подстановка в шаблон ────────────────────────
    Шаблон = РеквизитФормыВЗначение("Объект").ПолучитьМакет("ОценкаКачества").ПолучитьТекст();;
    Шаблон = СтрЗаменить(Шаблон, "%statusText%",   "Обновлено: " + Формат(ТекущаяДатаСеанса(), "ДЛФ=DT"));
    Шаблон = СтрЗаменить(Шаблон, "%periodText%",   ОписаниеПериода);
    Шаблон = СтрЗаменить(Шаблон, "%totalCount%",   Строка(Опросы.Количество()));
    Шаблон = СтрЗаменить(Шаблон, "%avgService%",   Средние["service_quality"]);
    Шаблон = СтрЗаменить(Шаблон, "%avgCost%",      Средние["cost_rating"]);
    Шаблон = СтрЗаменить(Шаблон, "%avgCleaning%",  Средние["cleaning_quality"]);
    Шаблон = СтрЗаменить(Шаблон, "%avgReception%", Средние["reception_quality"]);
    Шаблон = СтрЗаменить(Шаблон, "%avgFood%",      Средние["food_quality"]);
    Шаблон = СтрЗаменить(Шаблон, "%avgZone%",      Средние["service_zone_quality"]);
    Шаблон = СтрЗаменить(Шаблон, "%roomsList%",    БлокКомнат);
    Шаблон = СтрЗаменить(Шаблон, "%negativeBlock%", БлокНегатива);
    
    HTML = Шаблон;
КонецПроцедуры

