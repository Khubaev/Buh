  &НаСервере
Функция ЭкранироватьHTML(Знач Текст)
    Текст = СтрЗаменить(Текст, "&", "&amp;");
    Текст = СтрЗаменить(Текст, "<", "&lt;");
    Текст = СтрЗаменить(Текст, ">", "&gt;");
    Возврат Текст;
КонецФункции
 &НаСервере
Функция СобратьНегатив(Опросы)
    Категории = Новый Соответствие;
    Категории.Вставить("service_quality", Новый Структура("Метка, Поле", "Сервис", "service_comment"));
    Категории.Вставить("cost_rating", Новый Структура("Метка, Поле", "Цена", "cost_comment"));
    Категории.Вставить("cleaning_quality", Новый Структура("Метка, Поле", "Уборка", "cleaning_comment"));
    Категории.Вставить("reception_quality", Новый Структура("Метка, Поле", "Ресепшн", "reception_comment"));
    Категории.Вставить("food_quality", Новый Структура("Метка, Поле", "Еда", "food_comment"));
    Категории.Вставить("service_zone_quality", Новый Структура("Метка, Поле", "Зона", "service_zone_comment"));
    
    Результат = "";
    Для Каждого Стр Из Опросы Цикл
        Дата = Стр["created_at"];
        Для Каждого Кат Из Категории Цикл
            Оценка = Стр[Кат.Ключ];
            Комм = Стр[Кат.Значение.Поле];
            Если Оценка <> Неопределено И Оценка <= 2 И Комм <> Неопределено И НЕ ПустаяСтрока(Комм) Тогда
                Результат = Результат
                    + "<div class=""negative-item"">"
                    + "<div class=""meta""><span> " + Дата + "</span>"
                    + "<span> " + Кат.Значение.Метка + "</span>"
                    + "<span>⚠️ оценка " + Оценка + "</span></div>"
                    + "<div class=""comment"">" + ЭкранироватьHTML(Комм) + "</div></div>";
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
    Если ПустаяСтрока(Результат) Тогда
        Возврат "<p class=""negative-empty"">Нет текстовых отзывов к низким оценкам.</p>";
    КонецЕсли;
    Возврат Результат;
КонецФункции
&НаСервере
Функция ЗапроситьSupabase(Знач Таблица, Знач СтрокаЗапроса = "")
    
    SUPABASE_URL = "hzjngpmkwqnhcqrlgyww.supabase.co";
    SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh6am5ncG1rd3FuaGNxcmxneXd3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzNDc1NjksImV4cCI6MjA4ODkyMzU2OX0.QY0chrj6VmLOxmkqWbBPZ9zp-rMe7SdZfQiEcMSfSXA"; // ваш anon key
    
    Адрес = "/rest/v1/" + Таблица + ?(ПустаяСтрока(СтрокаЗапроса), "", "?" + СтрокаЗапроса);
    
    ЗащищённоеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
    Соединение = Новый HTTPСоединение(SUPABASE_URL, 443, , , , 30, ЗащищённоеСоединение);
    
    Запрос = Новый HTTPЗапрос(Адрес);
    Запрос.Заголовки.Вставить("apikey", SUPABASE_KEY);
    Запрос.Заголовки.Вставить("Authorization", "Bearer " + SUPABASE_KEY);
    Запрос.Заголовки.Вставить("Accept", "application/json");
    
    Ответ = Соединение.Получить(Запрос);
    Если Ответ.КодСостояния <> 200 Тогда
        ВызватьИсключение СтрШаблон("Supabase %1: %2", Ответ.КодСостояния, Ответ.ПолучитьТелоКакСтроку());
    КонецЕсли;
    
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(Ответ.ПолучитьТелоКакСтроку());
    Возврат ПрочитатьJSON(ЧтениеJSON, Ложь);
КонецФункции


