
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Начальные = НачальныеПараметрыФормыНаСервере();
	Организация = Начальные.Организация;
	ДатаОтчета = Начальные.ДатаОтчета;
	ТаблицаПоказателей.Очистить();
	ТаблицаПоказателейAI.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура Рассчитать(Команда)
	
	РассчитатьПоказатели();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьОСВ(Команда)
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите организацию.'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("НачалоПериода", НачалоМесяца(ДатаОтчета));
	ПараметрыФормы.Вставить("КонецПериода", КонецДня(ДатаОтчета));
	ПараметрыФормы.Вставить("Организация", Организация);
	
	ОткрытьФорму("Отчет.ОборотноСальдоваяВедомость.Форма.ФормаОтчета", ПараметрыФормы, ЭтотОбъект, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьОСВ(Команда)
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите организацию.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		ДанныеОСВ = СформироватьИВыгрузитьОСВНаСервере();
	Исключение
		ПоказатьПредупреждение(, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	Сообщить(СтрШаблон(
		НСтр("ru = 'ОСВ выгружена в ТаблицаЗначений: %1 строк.'"),
		ДанныеОСВ.ТаблицаЗначений.Количество()));
	ДанныеОСВ.ТабличныйДокумент.Показать(НСтр("ru = 'Оборотно-сальдовая ведомость'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьОСВПоСчету7614(Команда)
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите организацию.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		ДанныеОСВ = СформироватьИВыгрузитьОСВПоСчетуНаСервере();
	Исключение
		ПоказатьПредупреждение(, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	КоличествоДокументов = 0;
	Для Каждого СтрокаСотрудника Из ДанныеОСВ.СотрудникиДокументы Цикл
		КоличествоДокументов = КоличествоДокументов + СтрокаСотрудника.Документы.Количество();
	КонецЦикла;
	
	Сообщить(СтрШаблон(
		НСтр("ru = 'ОСВ по сч. 76.14: %1 строк в ТаблицаЗначений, %2 сотрудников, %3 документов (ссылки).'"),
		ДанныеОСВ.ТаблицаЗначений.Количество(),
		ДанныеОСВ.СотрудникиДокументы.Количество(),
		КоличествоДокументов));
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьРекомендацииAI(Команда)
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Укажите организацию.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		JSONПоказателей = РассчитатьПоказателиJSONПоОСВНаСервере();
	Исключение
		ПоказатьПредупреждение(,КраткоеПредставлениеОшибки(),,);
		Возврат;
	КонецПопытки;
	
	ЗаполнитьТаблицуПоказателейAI(JSONПоказателей);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТаблицуПоказателейAI(Знач ТекстJSON)
	
	ТаблицаПоказателейAI.Очистить();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СокрЛП(ТекстJSON));
	
	Попытка
		ДанныеJSON = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		ПоказатьПредупреждение(, СтрШаблон(
			НСтр("ru = 'AI вернул невалидный JSON: %1'"),
			КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
		Возврат;
	КонецПопытки;
	
	Метрики = ПолучитьСвойствоJSONФормы(ДанныеJSON, "metrics");
	Если Метрики = Неопределено Или ТипЗнч(Метрики) <> Тип("Массив") Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'В JSON отсутствует массив metrics.'"));
		Возврат;
	КонецЕсли;
	
	Для Каждого Метрика Из Метрики Цикл
		
		СтрокаТаблицы = ТаблицаПоказателейAI.Добавить();
		СтрокаТаблицы.Показатель = Строка(ПолучитьСвойствоJSONФормы(Метрика, "name"));
		СтрокаТаблицы.Значение = ЧислоJSONПоказателя(ПолучитьСвойствоJSONФормы(Метрика, "value"));
		СтрокаТаблицы.Комментарий = Строка(ПолучитьСвойствоJSONФормы(Метрика, "comment"));
		
	КонецЦикла;
	
	Сообщить(СтрШаблон(
		НСтр("ru = 'Показатели по ОСВ рассчитаны: %1 строк.'"),
		ТаблицаПоказателейAI.Количество()));
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьСвойствоJSONФормы(Знач ОбъектJSON, Знач ИмяСвойства)
	
	Если ОбъектJSON = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(ОбъектJSON) = Тип("Структура") Тогда
		Если ОбъектJSON.Свойство(ИмяСвойства) Тогда
			Возврат ОбъектJSON[ИмяСвойства];
		КонецЕсли;
	ИначеЕсли ТипЗнч(ОбъектJSON) = Тип("Соответствие") Тогда
		Возврат ОбъектJSON.Получить(ИмяСвойства);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Функция ЧислоJSONПоказателя(Знач Значение)
	
	Если Значение = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Окр(Значение, 2);
	КонецЕсли;
	
	Попытка
		Возврат Окр(Число(СокрЛП(Строка(Значение))), 2);
	Исключение
		Возврат 0;
	КонецПопытки;
	
КонецФункции

