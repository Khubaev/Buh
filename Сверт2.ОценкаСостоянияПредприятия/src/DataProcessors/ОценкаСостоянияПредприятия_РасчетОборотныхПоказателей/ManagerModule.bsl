// Формирует JSON по таблице значений ОСВ для проверки или отдельной отправки в LLM.
//
// Параметры:
//  ТаблицаОСВ - ТаблицаЗначений - результат типового отчета ОСВ;
//  Организация - СправочникСсылка.Организации;
//  НачалоПериода - Дата;
//  КонецПериода - Дата.
//
// Возвращаемое значение:
//  Строка - JSON с периодом и строками ОСВ.
//
Функция СформироватьJSONОСВДляLLM(Знач ТаблицаОСВ, Знач Организация, Знач НачалоПериода, Знач КонецПериода) Экспорт
	
	Данные = Новый Структура;
	Данные.Вставить("организация", Строка(Организация));
	Данные.Вставить("валюта", "RUB");
	Данные.Вставить("период", Новый Структура(
		"начало, конец",
		Формат(НачалоПериода, "ДЛФ=D"),
		Формат(КонецПериода, "ДЛФ=D")));
	Данные.Вставить("строки_осв", ПодготовитьСтрокиОСВДляJSON(ТаблицаОСВ));
	
	Возврат ЗаписатьJSONВСтроку(Данные);
	
