Функция СуммаВнеоборотныхАктивовНаГранице(ГраницаОстатков, Организация)
	
	ОсновныеСредства = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("01", ","))
		- СуммаКредитОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("02", ","));
	ПрочиеВнеоборотные = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("03,07,08", ","))
		+ Макс(СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("04", ","))
			- СуммаКредитОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("05", ",")), 0);
	ДолгосрочныеФВ = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("58.04", ","));
	Возврат ОсновныеСредства + ПрочиеВнеоборотные + ДолгосрочныеФВ;
	
