// Формирует отчет «Оборотно-сальдовая ведомость по счету» типовым механизмом СКД.
Функция СформироватьОСВПоСчетуТиповымМеханизмом(
	Знач НачалоПериода,
	Знач КонецПериода,
	Знач Организация,
	Знач КодСчета,
	Знач ДетализацияПоДокументу,
	Знач ВыводитьЗаголовок = Ложь)
	
	Счет = СчетПоКоду(КодСчета);
	Если Не ЗначениеЗаполнено(Счет) Тогда
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Счет %1 не найден в плане счетов «Хозрасчетный».'"), КодСчета);
	КонецЕсли;
	
	ПараметрыОтчета = Отчеты.ОборотноСальдоваяВедомостьПоСчету.ПустыеПараметрыКомпоновкиОтчета();
	ПараметрыОтчета.Организация = Организация;
	ПараметрыОтчета.НачалоПериода = НачалоДня(НачалоПериода);
	ПараметрыОтчета.КонецПериода = КонецДня(КонецПериода);
	ПараметрыОтчета.Счет = Счет;
	ПараметрыОтчета.ВыводитьЗаголовок = ВыводитьЗаголовок;
	ПараметрыОтчета.ВыводитьПодвал = Ложь;
	ПараметрыОтчета.ВыводитьЕдиницуИзмерения = Ложь;
	ПараметрыОтчета.ПоСубсчетам = Истина;
	
	// Для 76.14 детализация в отчете — по всем субконто (сотрудник + билеты), как в типовой ОСВ.
	ДетализацияПоВсемСубконто = (СокрЛП(КодСчета) = "76.14");
	
	Если ДетализацияПоВсемСубконто Тогда
		Если ДетализацияПоДокументу Тогда
			ПараметрыОтчета.Периодичность = БухгалтерскиеОтчетыКлиентСервер.Периодичность().Регистратор;
		Иначе
			ПараметрыОтчета.Периодичность = БухгалтерскиеОтчетыКлиентСервер.Периодичность().Период;
		КонецЕсли;
	ИначеЕсли ДетализацияПоДокументу Тогда
		ПараметрыОтчета.Периодичность = БухгалтерскиеОтчетыКлиентСервер.Периодичность().Регистратор;
	Иначе
		ПараметрыОтчета.Периодичность = БухгалтерскиеОтчетыКлиентСервер.Периодичность().Период;
	КонецЕсли;
	
	ЗаполнитьГруппировкуОСВПоСчету(ПараметрыОтчета, Счет, ДетализацияПоВсемСубконто);
	УстановитьПоказателиБУОСВПоСчету(ПараметрыОтчета, Счет);
	
	БухгалтерскиеОтчеты.ПодготовитьСхемуКомпоновкиДанных(ПараметрыОтчета);
	
	РезультатФормирования = БухгалтерскиеОтчетыВызовСервера.ПодготовитьОтчет(ПараметрыОтчета);
	Если Не РезультатФормирования.Выполнено Тогда
		ВызватьИсключение РезультатФормирования.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	Возврат РезультатФормирования;
	
КонецФункции

// Формирует типовую ОСВ по счету и выгружает строки в ТаблицаЗначений
// со ссылочными типами из данных расшифровки СКД.
//
// Параметры:
//  НачалоПериода - Дата;
//  КонецПериода - Дата;
//  Организация - СправочникСсылка.Организации;
//  КодСчета - Строка;
//  ДетализацияПоДокументу - Булево.
//
// Возвращаемое значение:
//  ТаблицаЗначений - колонки: Сотрудник, Билет, Документ, суммы БУ.
//
Функция СформироватьОСВПоСчетуВТаблицуЗначенийТиповымМеханизмом(
	Знач НачалоПериода,
	Знач КонецПериода,
	Знач Организация,
	Знач КодСчета,
	Знач ДетализацияПоДокументу) Экспорт
	
	РезультатФормирования = СформироватьОСВПоСчетуТиповымМеханизмом(
		НачалоПериода,
		КонецПериода,
		Организация,
		КодСчета,
		ДетализацияПоДокументу);
	
	Возврат ВыгрузитьОСВПоСчетуИзТиповогоОтчета(РезультатФормирования, ДетализацияПоДокументу);
	
КонецФункции

// Заполняет таблицу группировок отчета по счету (как на форме типового отчета).
//
// Параметры:
//  ВключатьВсеСубконто - Булево - если Истина, включаются все субконто счета (детализация по билетам и т.п.).
//
Процедура ЗаполнитьГруппировкуОСВПоСчету(ПараметрыОтчета, Счет, ВключатьВсеСубконто = Ложь)
	
	ПараметрыОтчета.Группировка.Очистить();
	ДанныеСчета = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Счет);
	
	ЕстьУчетПоПодразделениям = БухгалтерскийУчетПереопределяемый.ИспользоватьПодразделения()
		И ДанныеСчета.Свойство("УчетПоПодразделениям")
		И ДанныеСчета.УчетПоПодразделениям;
	
	Если ЕстьУчетПоПодразделениям Тогда
		НоваяСтрока = ПараметрыОтчета.Группировка.Добавить();
		НоваяСтрока.Поле = "Подразделение";
		НоваяСтрока.Использование = Истина;
		НоваяСтрока.Представление = НСтр("ru = 'Подразделение'");
		НоваяСтрока.ТипГруппировки = 0;
	КонецЕсли;
	
	Использование = Истина;
	НеиспользуемаяАналитика = ПланыСчетов.Хозрасчетный.НеиспользуемаяАналитика();
	
	Для Индекс = 1 По ДанныеСчета.КоличествоСубконто Цикл
		
		ВидСубконто = ДанныеСчета["ВидСубконто" + Индекс];
		Если НеиспользуемаяАналитика.Найти(ВидСубконто) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ПараметрыОтчета.Группировка.Добавить();
		НоваяСтрока.Поле = "Субконто" + Индекс;
		НоваяСтрока.Использование = ВключатьВсеСубконто Или Использование;
		НоваяСтрока.Представление = ДанныеСчета["ВидСубконто" + Индекс + "Наименование"];
		НоваяСтрока.ТипГруппировки = 0;
		Если Не ВключатьВсеСубконто Тогда
			Использование = Ложь;
		КонецЕсли;
		
		Если ДанныеСчета.Валютный Тогда
			НоваяСтрока = ПараметрыОтчета.Группировка.Добавить();
			НоваяСтрока.Поле = "Валюта";
			НоваяСтрока.Использование = Ложь;
			НоваяСтрока.Представление = НСтр("ru = 'Валюта'");
			НоваяСтрока.ТипГруппировки = 0;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Выгружает типовую ОСВ по счету в таблицу значений ТОЛЬКО из ДанныеРасшифровки СКД.
// Табличный документ не читается: ссылки и суммы берутся из элементов расшифровки.
//
// Параметры:
//  РезультатФормирования - Структура - результат БухгалтерскиеОтчетыВызовСервера.ПодготовитьОтчет();
//  ДетализацияПоДокументу - Булево - если Истина, берутся только строки с заполненным регистратором.
//
// Возвращаемое значение:
//  ТаблицаЗначений - строки с типизированными ссылками и суммами.
//
Функция ВыгрузитьОСВПоСчетуИзТиповогоОтчета(Знач РезультатФормирования, Знач ДетализацияПоДокументу = Истина) Экспорт
	
	Таблица = СоздатьТаблицуОСВПоСчету();
	
	ПолныеДанныеРасшифровки = ПолучитьПолныеДанныеРасшифровкиОтчета(РезультатФормирования.ДанныеРасшифровки);
	ДанныеРасшифровки = ПолныеДанныеРасшифровки.ДанныеРасшифровки;
	Если ДанныеРасшифровки = Неопределено Тогда
		Возврат Таблица;
	КонецЕсли;
	
	ТабличныйДокумент = РезультатФормирования.Результат;
	Если ТабличныйДокумент <> Неопределено Тогда
		ВыгрузитьСтрокиОСВИзТабличногоДокумента(Таблица, ТабличныйДокумент, ДанныеРасшифровки, ДетализацияПоДокументу);
	КонецЕсли;
	
	Если Таблица.Количество() = 0 Тогда
		ВыгрузитьСтрокиОСВИзЭлементовРасшифровки(Таблица, ДанныеРасшифровки, ДетализацияПоДокументу);
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции

// Собирает строки ОСВ из идентификаторов расшифровки ячеек табличного документа.
// Используется только свойство Расшифровка ячейки — текст не разбирается.
Процедура ВыгрузитьСтрокиОСВИзТабличногоДокумента(
	Таблица,
	ТабличныйДокумент,
	ДанныеРасшифровки,
	ДетализацияПоДокументу)
	
	ОбъединенныеСтроки = Новый Соответствие;
	
	Для НомерСтроки = 1 По ТабличныйДокумент.ВысотаТаблицы Цикл
		
		ПоляСтроки = СобратьПоляРасшифровкиСтрокиОСВ(ДанныеРасшифровки, ТабличныйДокумент, НомерСтроки);
		ОбъединитьПоляРасшифровкиОСВПоКлючу(ОбъединенныеСтроки, ПоляСтроки);
		
	КонецЦикла;
	
	ЗаписатьОбъединенныеСтрокиОСВВТаблицу(Таблица, ОбъединенныеСтроки, ДетализацияПоДокументу);
	
КонецПроцедуры

// Собирает строки ОСВ из идентификаторов ДанныеРасшифровки.Элементы (запасной путь).
// При обходе коллекции возвращаются идентификаторы, а не сами элементы.
Процедура ВыгрузитьСтрокиОСВИзЭлементовРасшифровки(
	Таблица,
	ДанныеРасшифровки,
	ДетализацияПоДокументу)
	
	ОбъединенныеСтроки = Новый Соответствие;
	
	Для Каждого ИдентификаторРасшифровки Из ДанныеРасшифровки.Элементы Цикл
		
		ПоляИзЭлемента = ПоляРасшифровкиОСВПоИдентификатору(ДанныеРасшифровки, ИдентификаторРасшифровки);
		ОбъединитьПоляРасшифровкиОСВПоКлючу(ОбъединенныеСтроки, ПоляИзЭлемента);
		
	КонецЦикла;
	
	ЗаписатьОбъединенныеСтрокиОСВВТаблицу(Таблица, ОбъединенныеСтроки, ДетализацияПоДокументу);
	
КонецПроцедуры

// Объединяет поля расшифровки в общий набор строк по ключу аналитики.
Процедура ОбъединитьПоляРасшифровкиОСВПоКлючу(ОбъединенныеСтроки, ПоляСтроки)
	
	Если ПоляСтроки = Неопределено Или ПоляСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Не СтрокаРасшифровкиИмеетАналитикуОСВ(ПоляСтроки) Тогда
		Возврат;
	КонецЕсли;
	
	КлючСтроки = КлючСтрокиОСВИзПолейРасшифровки(ПоляСтроки);
	ОбъединенныеПоля = ОбъединенныеСтроки.Получить(КлючСтроки);
	Если ОбъединенныеПоля = Неопределено Тогда
		ОбъединенныеПоля = Новый Соответствие;
		ОбъединенныеСтроки.Вставить(КлючСтроки, ОбъединенныеПоля);
	КонецЕсли;
	
	ОбъединитьПоляРасшифровкиОСВ(ОбъединенныеПоля, ПоляСтроки);
	
КонецПроцедуры

// Записывает объединенные строки расшифровки в таблицу значений ОСВ.
Процедура ЗаписатьОбъединенныеСтрокиОСВВТаблицу(Таблица, ОбъединенныеСтроки, ДетализацияПоДокументу)
	
	Для Каждого КлючИЗначение Из ОбъединенныеСтроки Цикл
		
		ПоляСтрокиРасшифровки = КлючИЗначение.Значение;
		Если Не СтрокаОСВПодходитДляВыгрузки(ПоляСтрокиРасшифровки, ДетализацияПоДокументу) Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьСтрокуОСВИзПолейРасшифровки(Таблица.Добавить(), ПоляСтрокиРасшифровки);
		
	КонецЦикла;
	
КонецПроцедуры

// Проверяет, что в полях расшифровки есть хотя бы одно измерение аналитики ОСВ.
Функция СтрокаРасшифровкиИмеетАналитикуОСВ(ПоляРасшифровки)
	
	ИменаАналитики = "Подразделение,Субконто1,Субконто2,Субконто3";
	Для Каждого ИмяПоля Из СтрРазделить(ИменаАналитики, ",") Цикл
		Если ЗначениеЗаполнено(ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, СокрЛП(ИмяПоля))) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из ПоляРасшифровки Цикл
		Если КлючИЗначение.Ключ = "Счет"
			Или КлючИЗначение.Ключ = "Показатель"
			Или СтрНачинаетсяС(КлючИЗначение.Ключ, "БУ")
			Или СтрНачинаетсяС(КлючИЗначение.Ключ, "Сальдо")
			Или СтрНачинаетсяС(КлючИЗначение.Ключ, "Оборот") Тогда
			Продолжить;
		КонецЕсли;
		Если ЭтоСсылочноеЗначениеАналитикиОСВ(КлючИЗначение.Значение) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Определяет, что значение является ссылочной аналитикой (не документом-регистратором).
Функция ЭтоСсылочноеЗначениеАналитикиОСВ(Знач Значение)
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТипЗначения = ТипЗнч(Значение);
	Возврат Справочники.ТипВсеСсылки().СодержитТип(ТипЗначения)
		Или ПланыСчетов.ТипВсеСсылки().СодержитТип(ТипЗначения);
	
КонецФункции

// Объединяет поля расшифровки: заполненные значения не перезаписываются.
Процедура ОбъединитьПоляРасшифровкиОСВ(Приемник, Источник)
	
	Для Каждого КлючИЗначение Из Источник Цикл
		Если Приемник.Получить(КлючИЗначение.Ключ) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(КлючИЗначение.Значение) = Тип("Число") Тогда
			Приемник.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
		ИначеЕсли ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда
			Приемник.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Собирает поля расшифровки типовой ОСВ по идентификатору (прямой обход элемента и родителей).
Функция ПоляРасшифровкиОСВПоИдентификатору(ДанныеРасшифровки, ИдентификаторРасшифровки)
	
	Результат = Новый Соответствие;
	ЭлементРасшифровки = ЭлементРасшифровкиПоИдентификатору(ДанныеРасшифровки, ИдентификаторРасшифровки);
	ДобавитьПоляЭлементаРасшифровки(ЭлементРасшифровки, Результат);
	Возврат Результат;
	
КонецФункции

// Возвращает элемент расшифровки по идентификатору.
Функция ЭлементРасшифровкиПоИдентификатору(ДанныеРасшифровки, ИдентификаторРасшифровки)
	
	ЭлементРасшифровки = ДанныеРасшифровки.Элементы.Получить(ИдентификаторРасшифровки);
	Если ЭлементРасшифровки = Неопределено Тогда
		Попытка
			ЭлементРасшифровки = ДанныеРасшифровки.Элементы[ИдентификаторРасшифровки];
		Исключение
			ЭлементРасшифровки = Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Возврат ЭлементРасшифровки;
	
КонецФункции

// Добавляет поле в соответствие расшифровки (полное и краткое имя).
Процедура ВставитьПолеРасшифровкиОСВ(ПоляРасшифровки, ИмяПоля, ЗначениеПоля)
	
	Если ПоляРасшифровки.Получить(ИмяПоля) = Неопределено Тогда
		ПоляРасшифровки.Вставить(ИмяПоля, ЗначениеПоля);
	КонецЕсли;
	
	КраткоеИмя = КраткоеИмяПоляРасшифровкиОСВ(ИмяПоля);
	Если КраткоеИмя <> ИмяПоля И ПоляРасшифровки.Получить(КраткоеИмя) = Неопределено Тогда
		ПоляРасшифровки.Вставить(КраткоеИмя, ЗначениеПоля);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает краткое имя поля СКД (после последней точки).
Функция КраткоеИмяПоляРасшифровкиОСВ(Знач ИмяПоля)
	
	ПозицияТочки = СтрНайти(ИмяПоля, ".", НаправлениеПоиска.СКонца);
	Если ПозицияТочки > 0 Тогда
		Возврат Сред(ИмяПоля, ПозицияТочки + 1);
	КонецЕсли;
	
	Возврат ИмяПоля;
	
КонецФункции

// Возвращает имя поля из элемента расшифровки СКД.
Функция ИмяПоляРасшифровкиОСВ(ПолеРасшифровки)
	
	Если ТипЗнч(ПолеРасшифровки) = Тип("ЗначениеПоляРасшифровкиКомпоновкиДанных") Тогда
		Возврат Строка(ПолеРасшифровки.Поле);
	ИначеЕсли ТипЗнч(ПолеРасшифровки) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
		Возврат Строка(ПолеРасшифровки.ЛевоеЗначение);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Возвращает значение поля из элемента расшифровки СКД.
Функция ЗначениеПоляРасшифровкиОСВ(ПолеРасшифровки)
	
	Если ТипЗнч(ПолеРасшифровки) = Тип("ЗначениеПоляРасшифровкиКомпоновкиДанных") Тогда
		Возврат ПолеРасшифровки.Значение;
	ИначеЕсли ТипЗнч(ПолеРасшифровки) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
		Возврат ПолеРасшифровки.ПравоеЗначение;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Возвращает значение из соответствия полей расшифровки по одному из возможных имен.
Функция ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, ИменаПолей)
	
	Для Каждого ИмяПоля Из СтрРазделить(ИменаПолей, ",") Цикл
		ИмяПоля = СокрЛП(ИмяПоля);
		ЗначениеПоля = ПоляРасшифровки.Получить(ИмяПоля);
		Если ЗначениеПоля <> Неопределено Тогда
			Возврат ЗначениеПоля;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из ПоляРасшифровки Цикл
		Для Каждого ИмяПоля Из СтрРазделить(ИменаПолей, ",") Цикл
			ИмяПоля = СокрЛП(ИмяПоля);
			Если СтрЗаканчиваетсяНа(КлючИЗначение.Ключ, ИмяПоля) Тогда
				Возврат КлючИЗначение.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// Проверяет, что строка расшифровки подходит для выгрузки в таблицу значений.
Функция СтрокаОСВПодходитДляВыгрузки(ПоляРасшифровки, ДетализацияПоДокументу)
	
	Если Не СтрокаРасшифровкиИмеетАналитикуОСВ(ПоляРасшифровки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ДетализацияПоДокументу Тогда
		Документ = ДокументИзПолейРасшифровкиОСВ(ПоляРасшифровки);
		Если Не ЗначениеЗаполнено(Документ) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Возвращает ссылку на документ из полей расшифровки ОСВ.
Функция ДокументИзПолейРасшифровкиОСВ(ПоляРасшифровки)
	
	Регистратор = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Регистратор");
	Если ЗначениеЗаполнено(Регистратор) Тогда
		Возврат Регистратор;
	КонецЕсли;
	
	Период = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Период");
	Если ЗначениеЗаполнено(Период) И ЭтоСсылкаНаДокумент(Период) Тогда
		Возврат Период;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Определяет, что значение является ссылкой на документ (а не датой периода).
Функция ЭтоСсылкаНаДокумент(Знач Значение)
	
	Возврат Документы.ТипВсеСсылки().СодержитТип(ТипЗнч(Значение));
	
КонецФункции

// Заполняет строку таблицы ОСВ из полей расшифровки типового отчета.
Процедура ЗаполнитьСтрокуОСВИзПолейРасшифровки(СтрокаОСВ, ПоляРасшифровки)
	
	СтрокаОСВ.Счет = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Счет");
	СтрокаОСВ.Подразделение = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Подразделение");
	Субконто1 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто1");
	Субконто2 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто2");
	Субконто3 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто3");
	Документ = ДокументИзПолейРасшифровкиОСВ(ПоляРасшифровки);
	
	СтрокаОСВ.Субконто1 = Субконто1;
	СтрокаОСВ.Субконто2 = Субконто2;
	СтрокаОСВ.Субконто3 = Субконто3;
	СтрокаОСВ.Уровень = ОпределитьУровеньСтрокиОСВ(Субконто1, Субконто2, Документ);
	СтрокаОСВ.Сотрудник = СсылкаСотрудникаИзСубконто(Субконто1);
	СтрокаОСВ.Билет = СсылкаБилетаИзСубконто(Субконто2);
	СтрокаОСВ.Документ = Документ;
	СтрокаОСВ.СальдоНачалоДт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУНачальныйОстатокДт,СальдоНаНачалоПериода.БУНачальныйОстатокДт");
	СтрокаОСВ.СальдоНачалоКт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУНачальныйОстатокКт,СальдоНаНачалоПериода.БУНачальныйОстатокКт");
	СтрокаОСВ.ОборотДт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУОборотДт,ОборотыЗаПериод.БУОборотДт");
	СтрокаОСВ.ОборотКт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУОборотКт,ОборотыЗаПериод.БУОборотКт");
	СтрокаОСВ.СальдоКонецДт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУКонечныйОстатокДт,СальдоНаКонецПериода.БУКонечныйОстатокДт");
	СтрокаОСВ.СальдоКонецКт = ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, "БУКонечныйОстатокКт,СальдоНаКонецПериода.БУКонечныйОстатокКт");
	
КонецПроцедуры

// Возвращает числовое значение показателя из полей расшифровки.
Функция ЧислоПоляРасшифровкиОСВ(ПоляРасшифровки, ИмяПоказателя)
	
	ЗначениеПоля = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, ИмяПоказателя);
	Если ЗначениеПоля = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(ЗначениеПоля) = Тип("Число") Тогда
		Возврат ЗначениеПоля;
	КонецЕсли;
	
	Возврат ЧислоИзТекстаЯчейкиОтчета(Строка(ЗначениеПоля));
	
КонецФункции

// Возвращает структуру: сотрудники счета и список ссылок на документы по каждому (типовой отчет).
//
// Параметры:
//  НачалоПериода - Дата;
//  КонецПериода - Дата;
//  Организация - СправочникСсылка.Организации;
//  КодСчета - Строка - код счета (по умолчанию 76.14).
//
// Возвращаемое значение:
//  Массив из Структура("Сотрудник, Документы"):
//    Документы - Массив из Структура("Документ, Билет, ОборотДт, ОборотКт").
//
Функция ПолучитьСтруктуруСотрудникиДокументыПоСчету(
	Знач НачалоПериода,
	Знач КонецПериода,
	Знач Организация,
	Знач КодСчета = "76.14") Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ВызватьИсключение НСтр("ru = 'Для формирования ОСВ по счету укажите организацию.'");
	КонецЕсли;
	
	ТаблицаОСВ = СформироватьОСВПоСчетуВТаблицуЗначенийТиповымМеханизмом(
		НачалоПериода,
		КонецПериода,
		Организация,
		КодСчета,
		Истина);
	Возврат ПостроитьСотрудникиДокументыИзТаблицыОСВ(ТаблицаОСВ);
	
КонецФункции

// Строит структуру «сотрудник -> документы» из таблицы значений типового отчета.
Функция ПостроитьСотрудникиДокументыИзТаблицыОСВ(Знач ТаблицаОСВ)
	
	СоответствиеСотрудников = Новый Соответствие;
	ИмяКолонкиСотрудник = ИмяПервойСуществующейКолонки(ТаблицаОСВ, "Сотрудник,Субконто1");
	ИмяКолонкиБилет = ИмяПервойСуществующейКолонки(ТаблицаОСВ, "Билет,Субконто2");
	ИмяКолонкиДокумент = ИмяПервойСуществующейКолонки(ТаблицаОСВ, "Документ,Регистратор");
	ИмяКолонкиОборотДт = ИмяПервойСуществующейКолонки(ТаблицаОСВ, "ОборотДт,БУОборотДт,ОборотыЗаПериод.БУОборотДт");
	ИмяКолонкиОборотКт = ИмяПервойСуществующейКолонки(ТаблицаОСВ, "ОборотКт,БУОборотКт,ОборотыЗаПериод.БУОборотКт");
	
	Если ПустаяСтрока(ИмяКолонкиСотрудник) Или ПустаяСтрока(ИмяКолонкиДокумент) Тогда
		Возврат Новый Массив;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из ТаблицаОСВ Цикл
		
		Сотрудник = СтрокаТаблицы[ИмяКолонкиСотрудник];
		Документ = СтрокаТаблицы[ИмяКолонкиДокумент];
		Билет = ?(ПустаяСтрока(ИмяКолонкиБилет), Неопределено, СтрокаТаблицы[ИмяКолонкиБилет]);
		ОборотДт = ?(ПустаяСтрока(ИмяКолонкиОборотДт), 0, СтрокаТаблицы[ИмяКолонкиОборотДт]);
		ОборотКт = ?(ПустаяСтрока(ИмяКолонкиОборотКт), 0, СтрокаТаблицы[ИмяКолонкиОборотКт]);
		
		Если Не ЗначениеЗаполнено(Сотрудник) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Документ) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаСотрудника = СоответствиеСотрудников.Получить(Сотрудник);
		Если СтрокаСотрудника = Неопределено Тогда
			СтрокаСотрудника = Новый Структура(
				"Сотрудник, Документы",
				Сотрудник,
				Новый Массив);
			СоответствиеСотрудников.Вставить(Сотрудник, СтрокаСотрудника);
		КонецЕсли;
		
		Если Не ДокументУжеВСписке(СтрокаСотрудника.Документы, Документ, Билет) Тогда
			СтрокаСотрудника.Документы.Добавить(Новый Структура(
				"Документ, Билет, ОборотДт, ОборотКт",
				Документ,
				Билет,
				ОборотДт,
				ОборотКт));
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Массив;
	Для Каждого ЭлементСоответствия Из СоответствиеСотрудников Цикл
		Результат.Добавить(ЭлементСоответствия.Значение);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает имя первой найденной колонки из списка возможных имен.
Функция ИмяПервойСуществующейКолонки(Знач Таблица, Знач ИменаКолонок)
	
	Для Каждого ИмяКолонки Из СтрРазделить(ИменаКолонок, ",") Цикл
		ИмяКолонки = СокрЛП(ИмяКолонки);
		Если Таблица.Колонки.Найти(ИмяКолонки) <> Неопределено Тогда
			Возврат ИмяКолонки;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Возвращает параметры отчета и объект расшифровки из временного хранилища.
Функция ПолучитьПолныеДанныеРасшифровкиОтчета(Знач АдресДанныхРасшифровки)
	
	Результат = Новый Структура("ПараметрыОтчета, ДанныеРасшифровки", Неопределено, Неопределено);
	
	Если Не ЗначениеЗаполнено(АдресДанныхРасшифровки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТипЗнч(АдресДанныхРасшифровки) = Тип("ДанныеРасшифровкиКомпоновкиДанных") Тогда
		Результат.ДанныеРасшифровки = АдресДанныхРасшифровки;
		Возврат Результат;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(АдресДанныхРасшифровки) Тогда
		ДанныеИзХранилища = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровки);
		Если ТипЗнч(ДанныеИзХранилища) = Тип("Структура") Тогда
			Если ДанныеИзХранилища.Свойство("ДанныеРасшифровки") Тогда
				Результат.ДанныеРасшифровки = ДанныеИзХранилища.ДанныеРасшифровки;
			КонецЕсли;
			Если ДанныеИзХранилища.Свойство("Объект") Тогда
				Результат.ПараметрыОтчета = ДанныеИзХранилища.Объект;
			КонецЕсли;
		ИначеЕсли ТипЗнч(ДанныеИзХранилища) = Тип("ДанныеРасшифровкиКомпоновкиДанных") Тогда
			Результат.ДанныеРасшифровки = ДанныеИзХранилища;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает компоновщик настроек из параметров типового отчета.
Функция КомпоновщикНастроекИзПараметровОтчета(Знач ПараметрыОтчета)
	
	Если ПараметрыОтчета = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СхемаКомпоновкиДанных = Неопределено;
	Если ПараметрыОтчета.Свойство("СхемаКомпоновкиДанных") Тогда
		СхемаКомпоновкиДанных = ПараметрыОтчета.СхемаКомпоновкиДанных;
		Если ТипЗнч(СхемаКомпоновкиДанных) = Тип("Строка")
			И ЭтоАдресВременногоХранилища(СхемаКомпоновкиДанных) Тогда
			СхемаКомпоновкиДанных = ПолучитьИзВременногоХранилища(СхемаКомпоновкиДанных);
		КонецЕсли;
	КонецЕсли;
	
	Если СхемаКомпоновкиДанных = Неопределено
		Или Не ПараметрыОтчета.Свойство("НастройкиКомпоновкиДанных") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(
		Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновкиДанных));
	КомпоновщикНастроек.ЗагрузитьНастройки(ПараметрыОтчета.НастройкиКомпоновкиДанных);
	Возврат КомпоновщикНастроек;
	
КонецФункции

// Собирает все поля расшифровки по ячейкам строки типовой ОСВ.
Функция СобратьПоляРасшифровкиСтрокиОСВ(ДанныеРасшифровки, ТабличныйДокумент, НомерСтроки)
	
	ПоляСтроки = Новый Соответствие;
	ОбработанныеРасшифровки = Новый Соответствие;
	
	Для НомерКолонки = 1 По ТабличныйДокумент.ШиринаТаблицы Цикл
		
		ОбластьЯчейки = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
		Если ТипЗнч(ОбластьЯчейки.Расшифровка) <> Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОбработанныеРасшифровки.Получить(ОбластьЯчейки.Расшифровка) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОбработанныеРасшифровки.Вставить(ОбластьЯчейки.Расшифровка, Истина);
		
		ПоляИзЯчейки = ПоляРасшифровкиОСВПоИдентификатору(ДанныеРасшифровки, ОбластьЯчейки.Расшифровка);
		ОбъединитьПоляРасшифровкиОСВ(ПоляСтроки, ПоляИзЯчейки);
		
	КонецЦикла;
	
	Возврат ПоляСтроки;
	
КонецФункции

// Возвращает уникальный ключ строки ОСВ для исключения дублей.
Функция КлючСтрокиОСВИзПолейРасшифровки(ПоляРасшифровки)
	
	Подразделение = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Подразделение");
	Субконто1 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто1");
	Субконто2 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто2");
	Субконто3 = ЗначениеПоляРасшифровкиПоИменам(ПоляРасшифровки, "Субконто3");
	Документ = ДокументИзПолейРасшифровкиОСВ(ПоляРасшифровки);
	
	Возврат Строка(Подразделение) + "|" + Строка(Субконто1) + "|" + Строка(Субконто2)
		+ "|" + Строка(Субконто3) + "|" + Строка(Документ);
	
КонецФункции

// Возвращает объект данных расшифровки из адреса временного хранилища типового отчета.
Функция ПолучитьОбъектДанныхРасшифровкиОтчета(Знач АдресДанныхРасшифровки)
	
	Если Не ЗначениеЗаполнено(АдресДанныхРасшифровки) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ТипЗнч(АдресДанныхРасшифровки) = Тип("ДанныеРасшифровкиКомпоновкиДанных") Тогда
		Возврат АдресДанныхРасшифровки;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(АдресДанныхРасшифровки) Тогда
		ДанныеИзХранилища = ПолучитьИзВременногоХранилища(АдресДанныхРасшифровки);
		Если ТипЗнч(ДанныеИзХранилища) = Тип("ДанныеРасшифровкиКомпоновкиДанных") Тогда
			Возврат ДанныеИзХранилища;
		ИначеЕсли ТипЗнч(ДанныеИзХранилища) = Тип("Структура")
			И ДанныеИзХранилища.Свойство("ДанныеРасшифровки") Тогда
			Возврат ДанныеИзХранилища.ДанныеРасшифровки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

// Возвращает соответствие полей расшифровки для отчета ОСВ по счету.
Функция СоответствиеПолейРасшифровкиОСВПоСчету()
	
	СоответствиеПолей = Новый Соответствие;
	СоответствиеПолей.Вставить("Счет");
	СоответствиеПолей.Вставить("Подразделение");
	СоответствиеПолей.Вставить("Субконто1");
	СоответствиеПолей.Вставить("Субконто2");
	СоответствиеПолей.Вставить("Регистратор");
	СоответствиеПолей.Вставить("Период");
	СоответствиеПолей.Вставить("БУНачальныйОстатокДт");
	СоответствиеПолей.Вставить("БУНачальныйОстатокКт");
	СоответствиеПолей.Вставить("БУОборотДт");
	СоответствиеПолей.Вставить("БУОборотКт");
	СоответствиеПолей.Вставить("БУКонечныйОстатокДт");
	СоответствиеПолей.Вставить("БУКонечныйОстатокКт");
	Возврат СоответствиеПолей;
	
КонецФункции

// Находит идентификатор расшифровки в любой ячейке строки отчета.
Функция НайтиРасшифровкуСтрокиОтчета(Знач ТабличныйДокумент, Знач НомерСтроки)
	
	Для НомерКолонки = 1 По ТабличныйДокумент.ШиринаТаблицы Цикл
		ОбластьЯчейки = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
		Если ТипЗнч(ОбластьЯчейки.Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
			Возврат ОбластьЯчейки.Расшифровка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

// Собирает все поля расшифровки по ячейкам строки отчета.
Функция СобратьВсеПоляРасшифровкиСтроки(Знач ДанныеРасшифровки, Знач ТабличныйДокумент, Знач НомерСтроки)
	
	ПоляСтроки = Новый Соответствие;
	ОбработанныеРасшифровки = Новый Соответствие;
	
	Для НомерКолонки = 1 По ТабличныйДокумент.ШиринаТаблицы Цикл
		
		ОбластьЯчейки = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
		Если ТипЗнч(ОбластьЯчейки.Расшифровка) <> Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОбработанныеРасшифровки.Получить(ОбластьЯчейки.Расшифровка) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОбработанныеРасшифровки.Вставить(ОбластьЯчейки.Расшифровка, Истина);
		
		ЭлементРасшифровки = ДанныеРасшифровки.Элементы.Получить(ОбластьЯчейки.Расшифровка);
		ДобавитьПоляЭлементаРасшифровки(ЭлементРасшифровки, ПоляСтроки);
		
	КонецЦикла;
	
	Возврат ПоляСтроки;
	
КонецФункции

// Рекурсивно добавляет поля элемента расшифровки и его родителей (как в БухгалтерскиеОтчетыРасшифровка).
Процедура ДобавитьПоляЭлементаРасшифровки(Знач ЭлементРасшифровки, ПоляСтроки)
	
	Если ЭлементРасшифровки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ЭлементРасшифровки) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда
		Для Каждого ПолеРасшифровки Из ЭлементРасшифровки.ПолучитьПоля() Цикл
			ВставитьПолеРасшифровкиОСВ(ПоляСтроки, Строка(ПолеРасшифровки.Поле), ПолеРасшифровки.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого Родитель Из ЭлементРасшифровки.ПолучитьРодителей() Цикл
		ДобавитьПоляЭлементаРасшифровки(Родитель, ПоляСтроки);
	КонецЦикла;
	
КонецПроцедуры

// Заполняет суммы строки ОСВ из расшифровки и ячеек табличного документа.
Процедура ЗаполнитьСуммыСтрокиОСВ(
	СтрокаОСВ,
	ТабличныйДокумент,
	ДанныеРасшифровки,
	ПоляСтрокиРасшифровки,
	НомерСтроки,
	НомерПервойКолонкиСумм)
	
	СтрокаОСВ.СальдоНачалоДт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм,
		"БУНачальныйОстатокДт",
		"СальдоНаНачалоПериода.БУНачальныйОстатокДт");
	СтрокаОСВ.СальдоНачалоКт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм + 1,
		"БУНачальныйОстатокКт",
		"СальдоНаНачалоПериода.БУНачальныйОстатокКт");
	СтрокаОСВ.ОборотДт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм + 2,
		"БУОборотДт",
		"ОборотыЗаПериод.БУОборотДт");
	СтрокаОСВ.ОборотКт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм + 3,
		"БУОборотКт",
		"ОборотыЗаПериод.БУОборотКт");
	СтрокаОСВ.СальдоКонецДт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм + 4,
		"БУКонечныйОстатокДт",
		"СальдоНаКонецПериода.БУКонечныйОстатокДт");
	СтрокаОСВ.СальдоКонецКт = ЗначениеПоказателяОСВ(
		ПоляСтрокиРасшифровки,
		ТабличныйДокумент,
		ДанныеРасшифровки,
		НомерСтроки,
		НомерПервойКолонкиСумм + 5,
		"БУКонечныйОстатокКт",
		"СальдоНаКонецПериода.БУКонечныйОстатокКт");
	
КонецПроцедуры

// Возвращает значение показателя из расшифровки или из ячейки отчета.
Функция ЗначениеПоказателяОСВ(
	ПоляСтрокиРасшифровки,
	ТабличныйДокумент,
	ДанныеРасшифровки,
	НомерСтроки,
	НомерКолонки,
	ИмяПоляКраткое,
	ИмяПоляПолное)
	
	ЗначениеПоказателя = ЧислоИзПоляРасшифровки(ПоляСтрокиРасшифровки, ИмяПоляКраткое);
	Если ЗначениеПоказателя <> 0 Тогда
		Возврат ЗначениеПоказателя;
	КонецЕсли;
	
	ЗначениеПоказателя = ЧислоИзПоляРасшифровки(ПоляСтрокиРасшифровки, ИмяПоляПолное);
	Если ЗначениеПоказателя <> 0 Тогда
		Возврат ЗначениеПоказателя;
	КонецЕсли;
	
	Если НомерКолонки > ТабличныйДокумент.ШиринаТаблицы Тогда
		Возврат 0;
	КонецЕсли;
	
	ОбластьЯчейки = ТабличныйДокумент.Область(НомерСтроки, НомерКолонки, НомерСтроки, НомерКолонки);
	Возврат ЧислоИзЯчейкиОтчетаСРасшифровкой(ОбластьЯчейки, ДанныеРасшифровки);
	
КонецФункции

// Извлекает числовое значение из поля расшифровки.
Функция ЧислоИзПоляРасшифровки(Знач ПоляСтрокиРасшифровки, Знач ИмяПоля)
	
	Если ПоляСтрокиРасшифровки = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	ЗначениеПоля = ЗначениеПоляРасшифровкиПоИменам(ПоляСтрокиРасшифровки, ИмяПоля);
	Если ТипЗнч(ЗначениеПоля) = Тип("Число") Тогда
		Возврат ЗначениеПоля;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

// Извлекает число из ячейки отчета: сначала из расшифровки ячейки, затем из текста.
Функция ЧислоИзЯчейкиОтчетаСРасшифровкой(Знач ОбластьЯчейки, Знач ДанныеРасшифровки)
	
	Если ТипЗнч(ОбластьЯчейки.Расшифровка) = Тип("ИдентификаторРасшифровкиКомпоновкиДанных") Тогда
		ЭлементРасшифровки = ДанныеРасшифровки.Элементы.Получить(ОбластьЯчейки.Расшифровка);
		Если ТипЗнч(ЭлементРасшифровки) = Тип("ЭлементРасшифровкиКомпоновкиДанныхПоля") Тогда
			Для Каждого ПолеРасшифровки Из ЭлементРасшифровки.ПолучитьПоля() Цикл
				Если ТипЗнч(ПолеРасшифровки.Значение) = Тип("Число") Тогда
					Возврат ПолеРасшифровки.Значение;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЧислоИзТекстаЯчейкиОтчета(ОбластьЯчейки.Текст);
	
КонецФункции

// Определяет номер первой колонки с суммами в типовой ОСВ по счету.
Функция ОпределитьНомерПервойКолонкиСуммОСВ(Знач ТабличныйДокумент)
	
	МаксимальнаяСтрокаПоиска = Мин(15, ТабличныйДокумент.ВысотаТаблицы);
	
	Для НомерСтроки = 1 По МаксимальнаяСтрокаПоиска Цикл
		Для НомерКолонки = 2 По ТабличныйДокумент.ШиринаТаблицы Цикл
			ТекстЯчейки = ВРег(СокрЛП(ТабличныйДокумент.Область(НомерСтроки, НомерКолонки).Текст));
			Если СтрНайти(ТекстЯчейки, "ДЕБЕТ") > 0
				Или СтрНайти(ТекстЯчейки, "САЛЬДО") > 0
				Или СтрНайти(ТекстЯчейки, "ОБОРОТ") > 0 Тогда
				Возврат НомерКолонки;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат 2;
	
КонецФункции

// Определяет уровень детализации строки ОСВ по счету 76.14.
Функция ОпределитьУровеньСтрокиОСВ(Знач Субконто1, Знач Субконто2, Знач Регистратор)
	
	Если ЗначениеЗаполнено(Регистратор) Тогда
		Возврат 2;
	ИначеЕсли ЗначениеЗаполнено(Субконто2) Тогда
		Возврат 1;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

// Возвращает ссылку на физлицо из значения субконто счета 76.14.
Функция СсылкаСотрудникаИзСубконто(Знач ЗначениеСубконто)
	
	Если Не ЗначениеЗаполнено(ЗначениеСубконто) Тогда
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;
	
	Если ТипЗнч(ЗначениеСубконто) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Возврат ЗначениеСубконто;
	КонецЕсли;
	
	Если ТипЗнч(ЗначениеСубконто) = Тип("СправочникСсылка.Сотрудники") Тогда
		ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЗначениеСубконто, "ФизическоеЛицо");
		Если ТипЗнч(ФизическоеЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			Возврат ФизическоеЛицо;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	
КонецФункции

// Возвращает ссылку на билет из значения субконто.
Функция СсылкаБилетаИзСубконто(Знач ЗначениеСубконто)
	
	Если ТипЗнч(ЗначениеСубконто) = Тип("СправочникСсылка.Билеты") Тогда
		Возврат ЗначениеСубконто;
	КонецЕсли;
	
	Возврат Справочники.Билеты.ПустаяСсылка();
	
КонецФункции

// Преобразует текст ячейки табличного документа отчета в число.
Функция ЧислоИзТекстаЯчейкиОтчета(Знач ТекстЯчейки)
	
	ТекстЯчейки = СокрЛП(ТекстЯчейки);
	Если ПустаяСтрока(ТекстЯчейки) Или ТекстЯчейки = "-" Тогда
		Возврат 0;
	КонецЕсли;
	
	Попытка
		Возврат Число(СтрЗаменить(СтрЗаменить(ТекстЯчейки, " ", ""), ",", "."));
	Исключение
		Возврат 0;
	КонецПопытки;
	
КонецФункции

// Создает пустую таблицу значений ОСВ по счету с типизированными колонками.
Функция СоздатьТаблицуОСВПоСчету()
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Уровень", Новый ОписаниеТипов("Число"));
	Таблица.Колонки.Добавить("Счет", Новый ОписаниеТипов("ПланСчетовСсылка.Хозрасчетный"));
	Таблица.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	Таблица.Колонки.Добавить("Субконто1");
	Таблица.Колонки.Добавить("Субконто2");
	Таблица.Колонки.Добавить("Субконто3");
	Таблица.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	Таблица.Колонки.Добавить("Билет", Новый ОписаниеТипов("СправочникСсылка.Билеты"));
	Таблица.Колонки.Добавить("Документ");
	КвалификаторСуммы = Новый КвалификаторыЧисла(15, 2);
	Таблица.Колонки.Добавить("СальдоНачалоДт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Таблица.Колонки.Добавить("СальдоНачалоКт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Таблица.Колонки.Добавить("ОборотДт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Таблица.Колонки.Добавить("ОборотКт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Таблица.Колонки.Добавить("СальдоКонецДт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Таблица.Колонки.Добавить("СальдоКонецКт", Новый ОписаниеТипов("Число", КвалификаторСуммы));
	Возврат Таблица;
	
КонецФункции

// Проверяет, что пара документ/билет еще не добавлена в список сотрудника.
Функция ДокументУжеВСписке(Знач СписокДокументов, Знач Документ, Знач Билет)
	
	Для Каждого Элемент Из СписокДокументов Цикл
		Если Элемент.Документ = Документ И Элемент.Билет = Билет Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Устанавливает показатели БУ для ОСВ по счету в соответствии со свойствами счета.
Процедура УстановитьПоказателиБУОСВПоСчету(ПараметрыОтчета, Счет)
	
	ДанныеСчета = БухгалтерскийУчетВызовСервераПовтИсп.ПолучитьСвойстваСчета(Счет);
	
	Если ПараметрыОтчета.Свойство("ПоказательБУ") Тогда
		ПараметрыОтчета.ПоказательБУ = Истина;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательНУ") Тогда
		ПараметрыОтчета.ПоказательНУ = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательПР") Тогда
		ПараметрыОтчета.ПоказательПР = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательВР") Тогда
		ПараметрыОтчета.ПоказательВР = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательКонтроль") Тогда
		ПараметрыОтчета.ПоказательКонтроль = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательВалютнаяСумма") Тогда
		ПараметрыОтчета.ПоказательВалютнаяСумма = ДанныеСчета.Валютный;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательКоличество") Тогда
		ПараметрыОтчета.ПоказательКоличество = ДанныеСчета.Количественный;
	КонецЕсли;
	
КонецПроцедуры

Функция СформироватьОСВТиповымМеханизмом(Знач НачалоПериода, Знач КонецПериода, Знач Организация)
	
	ПараметрыОтчета = Отчеты.ОборотноСальдоваяВедомость.ПустыеПараметрыКомпоновкиОтчета();
	ПараметрыОтчета.Организация = Организация;
	ПараметрыОтчета.НачалоПериода = НачалоДня(НачалоПериода);
	ПараметрыОтчета.КонецПериода = КонецДня(КонецПериода);
	ПараметрыОтчета.ВыводитьЗаголовок = Истина;
	ПараметрыОтчета.ВыводитьПодвал = Ложь;
	ПараметрыОтчета.ВыводитьЕдиницуИзмерения = Ложь;
	Если ПараметрыОтчета.Свойство("ПоСубсчетам") Тогда
		ПараметрыОтчета.ПоСубсчетам = Истина;
	КонецЕсли;
	
	Если ПараметрыОтчета.Свойство("ПоказательБУ") Тогда
		ПараметрыОтчета.ПоказательБУ = Истина;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательНУ") Тогда
		ПараметрыОтчета.ПоказательНУ = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательПР") Тогда
		ПараметрыОтчета.ПоказательПР = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательВР") Тогда
		ПараметрыОтчета.ПоказательВР = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательКонтроль") Тогда
		ПараметрыОтчета.ПоказательКонтроль = Ложь;
	КонецЕсли;
	Если ПараметрыОтчета.Свойство("ПоказательВалютнаяСумма") Тогда
		ПараметрыОтчета.ПоказательВалютнаяСумма = Ложь;
	КонецЕсли;
	
	БухгалтерскиеОтчеты.ПодготовитьСхемуКомпоновкиДанных(ПараметрыОтчета);
	
	РезультатФормирования = БухгалтерскиеОтчетыВызовСервера.ПодготовитьОтчет(ПараметрыОтчета);
	Если Не РезультатФормирования.Выполнено Тогда
		ВызватьИсключение РезультатФормирования.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	Возврат РезультатФормирования;
	
КонецФункции

Функция ТабличныйДокументВТаблицуЗначений(ТабличныйДокумент)
	
	Результат = Новый ТаблицаЗначений;
	
	Если ТабличныйДокумент = Неопределено Или ТабличныйДокумент.ВысотаТаблицы = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	КоличествоКолонок = ТабличныйДокумент.ШиринаТаблицы;
	Для НомерКолонки = 1 По КоличествоКолонок Цикл
		Результат.Колонки.Добавить("Колонка" + Формат(НомерКолонки, "ЧГ=0"), Новый ОписаниеТипов("Строка"));
	КонецЦикла;
	
	Для НомерСтроки = 1 По ТабличныйДокумент.ВысотаТаблицы Цикл
		СтрокаТаблицы = Результат.Добавить();
		Для НомерКолонки = 1 По КоличествоКолонок Цикл
			СтрокаТаблицы["Колонка" + Формат(НомерКолонки, "ЧГ=0")] =
				СокрЛП(Строка(ТабличныйДокумент.Область(НомерСтроки, НомерКолонки).Текст));
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Преобразует строки ОСВ в структуру, удобную для анализа LLM.
Функция ПодготовитьСтрокиОСВДляJSON(Знач ТаблицаОСВ)
	
	СтрокиОСВ = Новый Массив;
	
	Если ТаблицаОСВ = Неопределено Тогда
		Возврат СтрокиОСВ;
	КонецЕсли;
	
	КолонкиОСВ = КолонкиОСВДляJSON(ТаблицаОСВ);
	
	Для Каждого СтрокаОСВ Из ТаблицаОСВ Цикл
		
		Счет = СокрЛП(Строка(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.Счет, 1)));
		Если Не ЭтоСчетОСВ(Счет) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокиОСВ.Добавить(Новый Структура(
			"счет, сальдо_начало, обороты, сальдо_конец",
			Счет,
			Новый Структура(
				"дебет, кредит",
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.СальдоНачалоДт, 2)),
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.СальдоНачалоКт, 3))),
			Новый Структура(
				"дебет, кредит",
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.ОборотДт, 4)),
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.ОборотКт, 5))),
			Новый Структура(
				"дебет, кредит",
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.СальдоКонецДт, 6)),
				ЧислоОСВДляJSON(ЗначениеКолонкиОСВ(ТаблицаОСВ, СтрокаОСВ, КолонкиОСВ.СальдоКонецКт, 7)))));
		
	КонецЦикла;
	
	Возврат СтрокиОСВ;
	
КонецФункции

// Возвращает имена колонок ОСВ; для табличного документа используется позиционный fallback.
Функция КолонкиОСВДляJSON(Знач ТаблицаОСВ)
	
	Возврат Новый Структура(
		"Счет, СальдоНачалоДт, СальдоНачалоКт, ОборотДт, ОборотКт, СальдоКонецДт, СальдоКонецКт",
		ИмяКолонкиОСВ(ТаблицаОСВ, "счет"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "сальдо,нач,деб"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "сальдо,нач,кред"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "оборот,деб"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "оборот,кред"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "сальдо,кон,деб"),
		ИмяКолонкиОСВ(ТаблицаОСВ, "сальдо,кон,кред"));
	
КонецФункции

// Находит колонку по фрагментам имени.
Функция ИмяКолонкиОСВ(Знач ТаблицаОСВ, Знач ФрагментыИмени)
	
	Фрагменты = СтрРазделить(ФрагментыИмени, ",");
	
	Для Каждого Колонка Из ТаблицаОСВ.Колонки Цикл
		
		ИмяКолонки = НРег(Колонка.Имя);
		КолонкаПодходит = Истина;
		
		Для Каждого Фрагмент Из Фрагменты Цикл
			Если СтрНайти(ИмяКолонки, НРег(СокрЛП(Фрагмент))) = 0 Тогда
				КолонкаПодходит = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если КолонкаПодходит Тогда
			Возврат Колонка.Имя;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Получает значение колонки по имени или по позиции в таблице.
Функция ЗначениеКолонкиОСВ(Знач ТаблицаОСВ, Знач СтрокаОСВ, Знач ИмяКолонки, Знач НомерКолонки)
	
	Если Не ПустаяСтрока(ИмяКолонки) Тогда
		Возврат СтрокаОСВ[ИмяКолонки];
	КонецЕсли;
	
	ИмяПозиционнойКолонки = "Колонка" + Формат(НомерКолонки, "ЧГ=0");
	Если ТаблицаОСВ.Колонки.Найти(ИмяПозиционнойКолонки) <> Неопределено Тогда
		Возврат СтрокаОСВ[ИмяПозиционнойКолонки];
	КонецЕсли;
	
	Если ТаблицаОСВ.Колонки.Количество() >= НомерКолонки Тогда
		Возврат СтрокаОСВ[ТаблицаОСВ.Колонки[НомерКолонки - 1].Имя];
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Определяет, что строка похожа на строку счета ОСВ, а не на заголовок отчета.
Функция ЭтоСчетОСВ(Знач Счет)
	
	Если ПустаяСтрока(Счет) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СчетНРег = НРег(Счет);
	Если СчетНРег = "счет" Или СтрНайти(СчетНРег, "оборотно") > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПервыйСимвол = Лев(Счет, 1);
	Возврат СтрНайти("0123456789", ПервыйСимвол) > 0;
	
КонецФункции

// Приводит строковое представление суммы ОСВ к числу для JSON.
Функция ЧислоОСВДляJSON(Знач Значение)
	
	Если Значение = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Если ТипЗнч(Значение) = Тип("Число") Тогда
		Возврат Окр(Значение, 2);
	КонецЕсли;
	
	СтрокаЧисла = СокрЛП(Строка(Значение));
	Если ПустаяСтрока(СтрокаЧисла) Тогда
		Возврат 0;
	КонецЕсли;
	
	СтрокаЧисла = СтрЗаменить(СтрокаЧисла, """", "");
	СтрокаЧисла = СтрЗаменить(СтрокаЧисла, " ", "");
	СтрокаЧисла = СтрЗаменить(СтрокаЧисла, Символ(160), "");
	СтрокаЧисла = СтрЗаменить(СтрокаЧисла, Символы.НПП, "");
	
	Если СтрНайти(СтрокаЧисла, ",") > 0 И СтрНайти(СтрокаЧисла, ".") = 0 Тогда
		СтрокаЧисла = СтрЗаменить(СтрокаЧисла, ",", ".");
	КонецЕсли;
	
	Попытка
		Возврат Окр(Число(СтрокаЧисла), 2);
	Исключение
		Возврат 0;
	КонецПопытки;
	
КонецФункции

// Рассчитывает показатели по подготовленным строкам ОСВ (только листовые счета — без двойного учета).
Функция РассчитатьПоказателиПоСтрокамОСВ(Знач СтрокиОСВ, Знач Организация, Знач ДатаОтчета)
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИмяПоказателя", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(20, 2)));
	
	ЛистовыеСтроки = ЛистовыеСтрокиОСВ(СтрокиОСВ);
	
	ДенежныеСредства = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "50,51,52,57");
	ВысоколиквидныеЦБ = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "58.01,58.02");
	КраткосрочныеФВ = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "55,58") - СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "58.04");
	КраткосрочнаяДЗ = СуммаЧистыйДебетКонецПоГруппе(ЛистовыеСтроки, "60,62,68,69,71,73,76");
	ЗапасыИПрочиеОборотныеАктивы = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "10,11,19,20,21,23,40,41,42,43,44,45,97");
	ОборотныеАктивы = ДенежныеСредства + КраткосрочныеФВ + КраткосрочнаяДЗ + ЗапасыИПрочиеОборотныеАктивы;
	
	КраткосрочныеОбязательства = СуммаЧистыйКредитКонецПоГруппе(ЛистовыеСтроки, "60,62,66,76");
	ТекущиеОбязательства = СуммаЧистыйКредитКонецПоГруппе(ЛистовыеСтроки, "60,62,66,67,68,69,70,71,73,76,96");
	
	// Выручка, прибыль, чистая прибыль — обороты с начала года (из регистра; при нуле — из ОСВ).
	ТЗРегистр = РассчитатьПоказатели(Организация, ДатаОтчета);
	Выручка = ЗначениеПоказателяИзТаблицы(ТЗРегистр, "Выручка");
	Прибыль = ЗначениеПоказателяИзТаблицы(ТЗРегистр, "Прибыль");
	ЧистаяПрибыль = ЗначениеПоказателяИзТаблицы(ТЗРегистр, "ЧистаяПрибыль");
	
	Если Выручка = 0 Тогда
		Выручка = СуммаОборотКтПоГруппе(ЛистовыеСтроки, "90.01");
		Если Выручка = 0 Тогда
			Выручка = СуммаОборотКтПоГруппе(ЛистовыеСтроки, "90");
		КонецЕсли;
	КонецЕсли;
	
	Если Прибыль = 0 Тогда
		Прибыль = СуммаОборотКтМинусДтПоГруппе(ЛистовыеСтроки, "90")
			+ СуммаОборотКтМинусДтПоГруппе(ЛистовыеСтроки, "91");
		ЧистаяПрибыль = Прибыль - СуммаОборотДтПоГруппе(ЛистовыеСтроки, "68.04");
	КонецЕсли;
	
	СобственныйКапитал = СуммаСальдоКонецКтПоГруппе(ЛистовыеСтроки, "80,82,83,84")
		- СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "81");
	
	ОсновныеСредстваНетто = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "01")
		- СуммаСальдоКонецКтПоГруппе(ЛистовыеСтроки, "02");
	ПрочиеВнеоборотные = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "03,07,08")
		+ Макс(СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "04") - СуммаСальдоКонецКтПоГруппе(ЛистовыеСтроки, "05"), 0);
	ДолгосрочныеФВ = СуммаСальдоКонецДтПоГруппе(ЛистовыеСтроки, "58.04");
	ВнеоборотныеАктивы = ОсновныеСредстваНетто + ПрочиеВнеоборотные + ДолгосрочныеФВ;
	
	ВнеоборотныеНаНачалоГода = СуммаВнеоборотныхАктивовНаНачалоОСВ(СтрокиОСВ);
	СреднегодоваяСтоимостьВнеоборотныхАктивов = (ВнеоборотныеНаНачалоГода + ВнеоборотныеАктивы) / 2;
	СтоимостьАктивов = ВнеоборотныеАктивы + ОборотныеАктивы;
	СтоимостьОборотныхСредств = ОборотныеАктивы;
	
	ДобавитьСтрокуПоказателя(Результат, "ДенежныеСредства", НСтр("ru = 'Денежные средства'"), ДенежныеСредства);
	ДобавитьСтрокуПоказателя(Результат, "ВысоколиквидныеЦенныеБумаги", НСтр("ru = 'Высоколиквидные ценные бумаги (58.01, 58.02)'"), ВысоколиквидныеЦБ);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочныеФинансовыеВложения", НСтр("ru = 'Краткосрочные финансовые вложения (55, 58 за вычетом 58.04)'"), КраткосрочныеФВ);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочнаяДебиторскаяЗадолженность", НСтр("ru = 'Краткосрочная дебиторская задолженность (чистый дебет по 60,62,68,69,71,73,76)'"), КраткосрочнаяДЗ);
	ДобавитьСтрокуПоказателя(Результат, "ЗапасыИПрочиеОборотныеАктивы", НСтр("ru = 'Запасы, НДС, прочие оборотные активы (10-45, 19, 97)'"), ЗапасыИПрочиеОборотныеАктивы);
	ДобавитьСтрокуПоказателя(Результат, "ОборотныеАктивы", НСтр("ru = 'Оборотные активы (итого по методике раздела II)'"), ОборотныеАктивы);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочныеОбязательства", НСтр("ru = 'Краткосрочные обязательства (60,62,66,76 — чистый кредит)'"), КраткосрочныеОбязательства);
	ДобавитьСтрокуПоказателя(Результат, "ТекущиеОбязательства", НСтр("ru = 'Текущие обязательства (60,62,66,67,68,69,70,71,73,76,96 — чистый кредит)'"), ТекущиеОбязательства);
	ДобавитьСтрокуПоказателя(Результат, "Выручка", НСтр("ru = 'Выручка (Кт оборот 90.01 с начала года)'"), Выручка);
	ДобавитьСтрокуПоказателя(Результат, "Прибыль", НСтр("ru = 'Прибыль (финансовый результат по сч. 90 и 91 с начала года, до налога на прибыль)'"), Прибыль);
	ДобавитьСтрокуПоказателя(Результат, "ЧистаяПрибыль", НСтр("ru = 'Чистая прибыль (прибыль минус Дт оборот 68.04, если счет используется)'"), ЧистаяПрибыль);
	ДобавитьСтрокуПоказателя(Результат, "СобственныйКапитал", НСтр("ru = 'Собственный капитал (80,82,83,84 — 81)'"), СобственныйКапитал);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьАктивов", НСтр("ru = 'Стоимость активов (внеоборотные + оборотные активы)'"), СтоимостьАктивов);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьОборотныхСредств", НСтр("ru = 'Стоимость оборотных средств (оборотные активы, раздел II)'"), СтоимостьОборотныхСредств);
	ДобавитьСтрокуПоказателя(Результат, "СреднегодоваяСтоимостьВнеоборотныхАктивов", НСтр("ru = 'Среднегодовая стоимость внеоборотных активов (среднее: на начало года и на дату отчета)'"), СреднегодоваяСтоимостьВнеоборотныхАктивов);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьОсновныхСредств", НСтр("ru = 'Стоимость основных средств (01 Дт − 02 Кт, упрощенно)'"), ОсновныеСредстваНетто);
	
	Возврат Результат;
	
КонецФункции

// Сериализует таблицу показателей в JSON metrics для формы.
Функция ТаблицаПоказателейВJSONМетрик(Знач ТаблицаПоказателей)
	
	Метрики = Новый Массив;
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		Метрики.Добавить(Новый Структура(
			"name, value, comment",
			КраткоеИмяПоказателяДляJSON(СтрокаПоказателя.ИмяПоказателя),
			Окр(СтрокаПоказателя.Сумма, 2),
			""));
	КонецЦикла;
	
	Возврат ЗаписатьJSONВСтроку(Новый Структура("metrics", Метрики));
	
КонецФункции

// Краткое имя показателя для колонки «Показатель» в форме AI.
Функция КраткоеИмяПоказателяДляJSON(Знач ИмяПоказателя)
	
	СоответствиеИмен = Новый Соответствие;
	СоответствиеИмен.Вставить("ДенежныеСредства", "Денежные средства");
	СоответствиеИмен.Вставить("ВысоколиквидныеЦенныеБумаги", "Высоколиквидные ценные бумаги");
	СоответствиеИмен.Вставить("КраткосрочныеФинансовыеВложения", "Краткосрочные финансовые вложения");
	СоответствиеИмен.Вставить("КраткосрочнаяДебиторскаяЗадолженность", "Краткосрочная дебиторская задолженность");
	СоответствиеИмен.Вставить("ЗапасыИПрочиеОборотныеАктивы", "Запасы, НДС, прочие оборотные активы");
	СоответствиеИмен.Вставить("ОборотныеАктивы", "Оборотные активы");
	СоответствиеИмен.Вставить("КраткосрочныеОбязательства", "Краткосрочные обязательства");
	СоответствиеИмен.Вставить("ТекущиеОбязательства", "Текущие обязательства");
	СоответствиеИмен.Вставить("Выручка", "Выручка");
	СоответствиеИмен.Вставить("Прибыль", "Прибыль");
	СоответствиеИмен.Вставить("ЧистаяПрибыль", "Чистая прибыль");
	СоответствиеИмен.Вставить("СобственныйКапитал", "Собственный капитал");
	СоответствиеИмен.Вставить("СтоимостьАктивов", "Стоимость активов");
	СоответствиеИмен.Вставить("СтоимостьОборотныхСредств", "Стоимость оборотных средств");
	СоответствиеИмен.Вставить("СреднегодоваяСтоимостьВнеоборотныхАктивов", "Среднегодовая стоимость внеоборотных активов");
	СоответствиеИмен.Вставить("СтоимостьОсновныхСредств", "Стоимость основных средств");
	
	ИмяJSON = СоответствиеИмен.Получить(ИмяПоказателя);
	Если ИмяJSON = Неопределено Тогда
		Возврат ИмяПоказателя;
	КонецЕсли;
	
	Возврат ИмяJSON;
	
КонецФункции

Функция ЗначениеПоказателяИзТаблицы(Знач ТаблицаПоказателей, Знач ИмяПоказателя)
	
	Для Каждого СтрокаПоказателя Из ТаблицаПоказателей Цикл
		Если СтрокаПоказателя.ИмяПоказателя = ИмяПоказателя Тогда
			Возврат СтрокаПоказателя.Сумма;
		КонецЕсли;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

// Оставляет только листовые счета ОСВ (без родительских строк с субсчетами).
Функция ЛистовыеСтрокиОСВ(Знач СтрокиОСВ)
	
	КодыСчетов = Новый Массив;
	Для Каждого СтрокаОСВ Из СтрокиОСВ Цикл
		КодыСчетов.Добавить(НормализоватьКодСчетаОСВ(СтрокаОСВ.счет));
	КонецЦикла;
	
	Листовые = Новый Массив;
	Для Каждого СтрокаОСВ Из СтрокиОСВ Цикл
		КодСчета = НормализоватьКодСчетаОСВ(СтрокаОСВ.счет);
		Если ЭтоЛистовойСчетОСВ(КодСчета, КодыСчетов) Тогда
			Листовые.Добавить(СтрокаОСВ);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Листовые;
	
КонецФункции

Функция ЭтоЛистовойСчетОСВ(Знач КодСчета, Знач КодыСчетов)
	
	Для Каждого ДругойКод Из КодыСчетов Цикл
		Если СчетЯвляетсяПотомкомОСВ(ДругойКод, КодСчета) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция СчетЯвляетсяПотомкомОСВ(Знач КодПотомка, Знач КодРодителя)
	
	Если КодПотомка = КодРодителя Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат СтрНачинаетсяС(КодПотомка, КодРодителя + ".");
	
КонецФункции

Функция НормализоватьКодСчетаОСВ(Знач Счет)
	
	Счет = СокрЛП(Строка(Счет));
	ПозицияПробела = СтрНайти(Счет, " ");
	Если ПозицияПробела > 0 Тогда
		Счет = Лев(Счет, ПозицияПробела - 1);
	КонецЕсли;
	
	Возврат Счет;
	
КонецФункции

Функция СчетВходитВГруппуОСВ(Знач КодСчета, Знач КодыГруппы)
	
	Для Каждого КодГруппы Из КодыГруппы Цикл
		КодГруппы = СокрЛП(КодГруппы);
		Если ПустаяСтрока(КодГруппы) Тогда
			Продолжить;
		КонецЕсли;
		Если КодСчета = КодГруппы Или СчетЯвляетсяПотомкомОСВ(КодСчета, КодГруппы) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

