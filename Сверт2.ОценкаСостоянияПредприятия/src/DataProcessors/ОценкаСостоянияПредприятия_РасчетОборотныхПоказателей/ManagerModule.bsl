		КодСчета = НормализоватьКодСчетаОСВ(СтрокаОСВ.счет);
		Если СчетВходитВГруппуОСВ(КодСчета, КодыГруппы) Тогда
			СуммаИтого = СуммаИтого + СтрокаОСВ.сальдо_конец.дебет;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СуммаИтого;
	
