// Внеоборотные активы на начало периода ОСВ (сальдо_начало) по листовым счетам.
Функция СуммаВнеоборотныхАктивовНаНачалоОСВ(Знач СтрокиОСВ)
	
	ЛистовыеСтроки = ЛистовыеСтрокиОСВ(СтрокиОСВ);
	ОсновныеСредства = 0;
	ПрочиеВнеоборотные = 0;
	ДолгосрочныеФВ = 0;
	
	Для Каждого СтрокаОСВ Из ЛистовыеСтроки Цикл
		КодСчета = НормализоватьКодСчетаОСВ(СтрокаОСВ.счет);
		Если СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("01", ",")) Тогда
			ОсновныеСредства = ОсновныеСредства + СтрокаОСВ.сальдо_начало.дебет;
		ИначеЕсли СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("02", ",")) Тогда
			ОсновныеСредства = ОсновныеСредства - СтрокаОСВ.сальдо_начало.кредит;
		ИначеЕсли СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("03,07,08", ",")) Тогда
			ПрочиеВнеоборотные = ПрочиеВнеоборотные + СтрокаОСВ.сальдо_начало.дебет;
		ИначеЕсли СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("04", ",")) Тогда
			ПрочиеВнеоборотные = ПрочиеВнеоборотные + СтрокаОСВ.сальдо_начало.дебет;
		ИначеЕсли СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("05", ",")) Тогда
			ПрочиеВнеоборотные = ПрочиеВнеоборотные - СтрокаОСВ.сальдо_начало.кредит;
		ИначеЕсли СчетВходитВГруппуОСВ(КодСчета, СтрРазделить("58.04", ",")) Тогда
			ДолгосрочныеФВ = ДолгосрочныеФВ + СтрокаОСВ.сальдо_начало.дебет;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОсновныеСредства + Макс(ПрочиеВнеоборотные, 0) + ДолгосрочныеФВ;
	
КонецФункции

