#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Начальные значения организации и даты отчета для открытия формы обработки.
//
Функция НачальныеПараметрыФормы() Экспорт
	
	Параметры = Новый Структура("Организация, ДатаОтчета");
	Параметры.Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	Параметры.ДатаОтчета = КонецМесяца(ТекущаяДатаСеанса());
	Возврат Параметры;
	
КонецФункции
                   		
// Рассчитывает показатели для оценки ликвидности, активов, капитала и финансового результата по данным
// регистра бухгалтерии "Хозрасчетный" и плана счетов "Хозрасчетный".
// Методика ориентирована на типовой план счетов; обороты выручки и прибыли — с начала года по дату отчета.
//
// Параметры:
//  Организация - СправочникСсылка.Организации - организация отчета;
//  ДатаОтчета - Дата - дата, на которую берутся остатки (обычно конец месяца/квартала).
//
// Возвращаемое значение:
//  ТаблицаЗначений - колонки: ИмяПоказателя (Строка), Представление (Строка), Сумма (Число).
//
Функция РассчитатьПоказатели(Знач Организация, Знач ДатаОтчета) Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИмяПоказателя", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	Результат.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(20, 2)));
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ГраницаОстатков = Новый Граница(КонецДня(ДатаОтчета), ВидГраницы.Включая);
	НачалоГодаОтчета = НачалоГода(ДатаОтчета);
	ГраницаОстатковНаНачалоГода = Новый Граница(КонецДня(НачалоГодаОтчета - 1), ВидГраницы.Включая);
	
	// --- Денежные средства: касса, расчетные, валютные, переводы в пути, цифровой рубль (без депозитов 55 — они в фин. вложениях).
	ДенежныеСредства = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("50,51,52,57", ","));
	
	// --- Высоколиквидные ценные бумаги (типовые субсчета 58.01, 58.02; при отсутствии — 0 по субсчету).
	ВысоколиквидныеЦБ = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("58.01,58.02", ","));
	
	// --- Краткосрочные финансовые вложения: депозиты до востребования (55), прочие фин. вложения (58), исключая явно долгосрочный субсчет 58.04 при наличии.
	КраткосрочныеФВ = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("55,58", ","));
	СуммаДолгосрочные58 = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("58.04", ","));
	КраткосрочныеФВ = КраткосрочныеФВ - СуммаДолгосрочные58;
	
	// --- Краткосрочная дебиторская задолженность: чистый дебет по расчетным счетам.
	КодыДЗ = СтрРазделить("60,62,68,69,71,73,76", ",");
	КраткосрочнаяДЗ = СуммаЧистыйДебетПоКодам(ГраницаОстатков, Организация, КодыДЗ);
	
	// --- Запасы, НДС к вычету, расходы будущих периодов (краткосрочная часть) — для итога по разделу II.
	ЗапасыИПрочиеОборотныеАктивы = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация,
		СтрРазделить("10,11,19,20,21,23,40,41,42,43,44,45,97", ","));
	
	// --- Оборотные активы (раздел II баланса в упрощенном виде: без внебаланса; ФВ и ДС выше не дублируются в запасах).
	ОборотныеАктивы = ДенежныеСредства + КраткосрочныеФВ + КраткосрочнаяДЗ + ЗапасыИПрочиеОборотныеАктивы;
	
	// --- Краткосрочные обязательства (узкая интерпретация: кредиторская и краткосрочные займы/расчеты по поставщикам и покупателям).
	КодыКрОбяз = СтрРазделить("60,62,66,76", ",");
	КраткосрочныеОбязательства = СуммаЧистыйКредитПоКодам(ГраницаОстатков, Организация, КодыКрОбяз);
	
	// --- Текущие обязательства (шире: налоги, персонал, прочие обязательства, оценочные, краткосрочная часть по 67).
	КодыТекОбяз = СтрРазделить("60,62,66,67,68,69,70,71,73,76,96", ",");
	ТекущиеОбязательства = СуммаЧистыйКредитПоКодам(ГраницаОстатков, Организация, КодыТекОбяз);
	
	// --- Выручка: кредитовый оборот по 90.01 с начала года по дату отчета (НУ/БУ — бухгалтерский учет).
	Выручка = СуммаКредитовыйОборотПоСчетуЗаПериод(НачалоГодаОтчета, ДатаОтчета, Организация, "90.01");
	Если Выручка = 0 Тогда
		Выручка = СуммаКредитовыйОборотПоСчетуЗаПериод(НачалоГодаОтчета, ДатаОтчета, Организация, "90");
	КонецЕсли;
	
	// --- Финансовый результат по счетам 90 и 91 за период (Кт минус Дт оборотов) — прибыль до налогообложения в упрощенной форме.
	ФинансовыйРезультат90и91 = СуммаОборотКтМинусДтПоСчетуЗаПериод(НачалоГодаОтчета, ДатаОтчета, Организация, "90")
		+ СуммаОборотКтМинусДтПоСчетуЗаПериод(НачалоГодаОтчета, ДатаОтчета, Организация, "91");
	Прибыль = ФинансовыйРезультат90и91;
	
	// --- Налог на прибыль (оценка для чистой прибыли): дебет оборот по 68.04, если субсчет есть в плане.
	НалогНаПрибыльДт = СуммаДебетовыйОборотПоСчетуЗаПериод(НачалоГодаОтчета, ДатаОтчета, Организация, "68.04");
	ЧистаяПрибыль = Прибыль - НалогНаПрибыльДт;
	
	// --- Собственный капитал (раздел III): 80, 81 (уменьшает), 82, 83, 84.
	СобственныйКапитал = СуммаЧистыйКредитПоКодам(ГраницаОстатков, Организация, СтрРазделить("80,82,83,84", ","))
		- СуммаЧистыйДебетПоКодам(ГраницаОстатков, Организация, СтрРазделить("81", ","));
	
	// --- Внеоборотные активы (упрощенно на дату): 01-02, 03, 04-05, 07, 08, долгосрочные фин. вложения 58.04.
	ВнеоборотныеАктивы = СуммаВнеоборотныхАктивовНаГранице(ГраницаОстатков, Организация);
	ОсновныеСредстваНетто = СуммаДебетОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("01", ","))
		- СуммаКредитОстатковПоКодам(ГраницаОстатков, Организация, СтрРазделить("02", ","));
	
	ВнеоборотныеНаНачалоГода = СуммаВнеоборотныхАктивовНаГранице(ГраницаОстатковНаНачалоГода, Организация);
	СреднегодоваяСтоимостьВнеоборотныхАктивов = (ВнеоборотныеНаНачалоГода + ВнеоборотныеАктивы) / 2;
	
	// --- Стоимость активов (баланс, актив): внеоборотные + оборотные.
	СтоимостьАктивов = ВнеоборотныеАктивы + ОборотныеАктивы;
	
	// --- Стоимость оборотных средств: здесь трактуем как стоимость оборотных активов (раздел II), без дублирования с строкой «Оборотные активы» в комментарии к показателю.
	СтоимостьОборотныхСредств = ОборотныеАктивы;
	
	ДобавитьСтрокуПоказателя(Результат, "ДенежныеСредства", НСтр("ru = 'Денежные средства'"), ДенежныеСредства);
	ДобавитьСтрокуПоказателя(Результат, "ВысоколиквидныеЦенныеБумаги", НСтр("ru = 'Высоколиквидные ценные бумаги (58.01, 58.02)'"), ВысоколиквидныеЦБ);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочныеФинансовыеВложения", НСтр("ru = 'Краткосрочные финансовые вложения (55, 58 за вычетом 58.04)'"), КраткосрочныеФВ);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочнаяДебиторскаяЗадолженность", НСтр("ru = 'Краткосрочная дебиторская задолженность (чистый дебет по 60,62,68,69,71,73,76)'"), КраткосрочнаяДЗ);
	ДобавитьСтрокуПоказателя(Результат, "ЗапасыИПрочиеОборотныеАктивы", НСтр("ru = 'Запасы, НДС, прочие оборотные активы (10-45, 19, 97)'"), ЗапасыИПрочиеОборотныеАктивы);
	ДобавитьСтрокуПоказателя(Результат, "ОборотныеАктивы", НСтр("ru = 'Оборотные активы (итого по методике раздела II)'"), ОборотныеАктивы);
	ДобавитьСтрокуПоказателя(Результат, "КраткосрочныеОбязательства", НСтр("ru = 'Краткосрочные обязательства (60,62,66,76 — чистый кредит)'"), КраткосрочныеОбязательства);
	ДобавитьСтрокуПоказателя(Результат, "ТекущиеОбязательства", НСтр("ru = 'Текущие обязательства (60,62,66,67,68,69,70,71,73,76,96 — чистый кредит)'"), ТекущиеОбязательства);
	
	ДобавитьСтрокуПоказателя(Результат, "Выручка", НСтр("ru = 'Выручка (Кт оборот 90.01 с начала года)'"), Выручка);
	ДобавитьСтрокуПоказателя(Результат, "Прибыль", НСтр("ru = 'Прибыль (финансовый результат по сч. 90 и 91 с начала года, до налога на прибыль)'"), Прибыль);
	ДобавитьСтрокуПоказателя(Результат, "ЧистаяПрибыль", НСтр("ru = 'Чистая прибыль (прибыль минус Дт оборот 68.04, если счет используется)'"), ЧистаяПрибыль);
	ДобавитьСтрокуПоказателя(Результат, "СобственныйКапитал", НСтр("ru = 'Собственный капитал (80,82,83,84 — 81)'"), СобственныйКапитал);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьАктивов", НСтр("ru = 'Стоимость активов (внеоборотные + оборотные активы)'"), СтоимостьАктивов);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьОборотныхСредств", НСтр("ru = 'Стоимость оборотных средств (оборотные активы, раздел II)'"), СтоимостьОборотныхСредств);
	ДобавитьСтрокуПоказателя(Результат, "СреднегодоваяСтоимостьВнеоборотныхАктивов", НСтр("ru = 'Среднегодовая стоимость внеоборотных активов (среднее: на начало года и на дату отчета)'"), СреднегодоваяСтоимостьВнеоборотныхАктивов);
	ДобавитьСтрокуПоказателя(Результат, "СтоимостьОсновныхСредств", НСтр("ru = 'Стоимость основных средств (01 Дт − 02 Кт, упрощенно)'"), ОсновныеСредстваНетто);
	
	Возврат Результат;
	
КонецФункции

// Рассчитывает показатели по типовой ОСВ (с начала года) без обращения к LLM.
// Обороты выручки и прибыли — только по оборотам листовых счетов; сальдо 90/91 не используются.
//
// Параметры:
//  Организация - СправочникСсылка.Организации;
//  ДатаОтчета - Дата - дата отчета (конец периода ОСВ).
//
// Возвращаемое значение:
//  ТаблицаЗначений - как у РассчитатьПоказатели.
//
Функция РассчитатьПоказателиПоОСВ(Знач Организация, Знач ДатаОтчета) Экспорт
	
	НачалоПериодаОСВ = НачалоГода(ДатаОтчета);
	КонецПериодаОСВ = КонецДня(ДатаОтчета);
	ТаблицаОСВ = ВыгрузитьОСВВТаблицуЗначений(НачалоПериодаОСВ, КонецПериодаОСВ, Организация);
	СтрокиОСВ = ПодготовитьСтрокиОСВДляJSON(ТаблицаОСВ);
	
	Если СтрокиОСВ.Количество() = 0 Тогда
		Возврат РассчитатьПоказатели(Организация, ДатаОтчета);
	КонецЕсли;
	
	Возврат РассчитатьПоказателиПоСтрокамОСВ(СтрокиОСВ, Организация, ДатаОтчета);
	
КонецФункции

// Возвращает JSON с массивом metrics для таблицы формы (расчет на сервере по ОСВ).
//
Функция РассчитатьПоказателиJSONПоОСВ(Знач Организация, Знач ДатаОтчета) Экспорт
	
	ТаблицаПоказателей = РассчитатьПоказателиПоОСВ(Организация, ДатаОтчета);
	Возврат ТаблицаПоказателейВJSONМетрик(ТаблицаПоказателей);
	
КонецФункции

// Запрашивает у Timeweb AI Agent расчет показателей по данным ОСВ.
//
// Параметры:
//  Организация - СправочникСсылка.Организации - организация отчета;
//  ДатаОтчета - Дата - дата отчета;
//  ТаблицаПоказателей - ТаблицаЗначений - таблица показателей формы (оставлена для совместимости);
//  ТокенДоступа - Строка - Bearer token;
//  ИдентификаторАгента - Строка - agent_access_id;
//  ИсточникПрокси - Строка - заголовок x-proxy-source (если пусто, используется "1c-buhgalteriya");
//  ИмяМодели - Строка - имя модели (опционально);
//  СистемныйПромпт - Строка - системный промпт расчета JSON (опционально).
//
// Возвращаемое значение:
//  Строка - JSON с рассчитанными показателями.
//
Функция ПолучитьРекомендацииHTMLTimeweb(
	Знач Организация,
	Знач ДатаОтчета,
	Знач ТаблицаПоказателей,
	Знач ТокенДоступа,
	Знач ИдентификаторАгента,
	Знач ИсточникПрокси = "",
	Знач ИмяМодели = "",
	Знач СистемныйПромпт = "") Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ВызватьИсключение НСтр("ru = 'Не указана организация.'");
	КонецЕсли;
	
	// Расчет на сервере по типовой ОСВ (без LLM). Параметры Timeweb сохранены для совместимости вызова.
	Возврат РассчитатьПоказателиJSONПоОСВ(Организация, ДатаОтчета);
	
КонецФункции

// Выгружает данные отчета "Оборотно-сальдовая ведомость" в таблицу значений.
//
// Параметры:
//  НачалоПериода - Дата - начало периода ОСВ;
//  КонецПериода - Дата - конец периода ОСВ;
//  Организация - СправочникСсылка.Организации - организация (опционально).
//
// Возвращаемое значение:
//  ТаблицаЗначений - результат ОСВ в виде коллекции строк СКД.
//
Функция ВыгрузитьОСВВТаблицуЗначений(Знач НачалоПериода, Знач КонецПериода, Знач Организация = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ВызватьИсключение НСтр("ru = 'Для выгрузки ОСВ укажите организацию.'");
	КонецЕсли;
	
	РезультатФормирования = СформироватьОСВТиповымМеханизмом(НачалоПериода, КонецПериода, Организация);
	Возврат ТабличныйДокументВТаблицуЗначений(РезультатФормирования.Результат);
	
КонецФункции

// Формирует типовую ОСВ и возвращает результат в двух представлениях.
//
// Параметры:
//  НачалоПериода - Дата;
//  КонецПериода - Дата;
//  Организация - СправочникСсылка.Организации.
//
// Возвращаемое значение:
//  Структура:
//   * ТабличныйДокумент - ТабличныйДокумент - результат типового отчета;
//   * ТаблицаЗначений - ТаблицаЗначений - строки сформированного отчета;
//   * JSONДляLLM - Строка - ОСВ в JSON для передачи модели.
//
Функция СформироватьИВыгрузитьОСВ(Знач НачалоПериода, Знач КонецПериода, Знач Организация = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ВызватьИсключение НСтр("ru = 'Для формирования ОСВ укажите организацию.'");
	КонецЕсли;
	
	РезультатФормирования = СформироватьОСВТиповымМеханизмом(НачалоПериода, КонецПериода, Организация);
	ТаблицаОСВ = ТабличныйДокументВТаблицуЗначений(РезультатФормирования.Результат);
	
	Возврат Новый Структура(
		"ТабличныйДокумент, ТаблицаЗначений, JSONДляLLM",
		РезультатФормирования.Результат,
		ТаблицаОСВ,
		СформироватьJSONОСВДляLLM(ТаблицаОСВ, Организация, НачалоПериода, КонецПериода));
	
КонецФункции

// Формирует типовую ОСВ и возвращает табличный документ результата.
//
// Параметры:
//  НачалоПериода - Дата;
//  КонецПериода - Дата;
//  Организация - СправочникСсылка.Организации.
//
// Возвращаемое значение:
//  ТабличныйДокумент - результат типового отчета ОСВ.
//
Функция СформироватьОСВТабличныйДокумент(Знач НачалоПериода, Знач КонецПериода, Знач Организация = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ВызватьИсключение НСтр("ru = 'Для формирования ОСВ укажите организацию.'");
	КонецЕсли;
	
	РезультатФормирования = СформироватьОСВТиповымМеханизмом(НачалоПериода, КонецПериода, Организация);
	Возврат РезультатФормирования.Результат;
	
КонецФункции

