&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
	Параметры.Свойство("ПрефиксИмениФорм",ПрефиксИмениФорм);
	Параметры.Свойство("СтруктураНастроек",СтруктураНастроек);
	Параметры.Свойство("НовыйМаркер",НовыйМаркер);
	
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СвязьНоменклатуры","Связь номенклатуры");
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СвязьКонтрагентов","Связь контрагентов");
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СвязьОрганизаций","Связь организаций");
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СвязьЕдиницыИзмерения","Связь единицы измерения");
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СловаМаркеры","Слова-маркеры");
	Элементы.ТаблицаСоответствий.СписокВыбора.Добавить("СловаМаркерыТипНоменклатуры","Маркер услуга/товар");
	
	//Установим ограничение типа для Характеристик номенклатуры
	Если Метаданные.Справочники.Найти("ХарактеристикиНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ХарактеристикиНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элементы.СвязьНоменклатурыХарактеристика.ОграничениеТипа = ОписаниеТипов;
	КонецЕсли;
	
	//E1C-145: проблема: если обработку подключить в расширение, то нужно тащить туда же
	//все справочники для корректного назначения типа элементам. Обойдемся, просто назначив все типы при создании формы
	Элементы.СвязьОрганизацийСсылка.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Организации");
	Элементы.СвязьКонтрагентовСсылка.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
	Элементы.СвязьНоменклатурыСсылка.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	Элементы.СловаМаркерыНоменклатура.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
	
	Элементы.СловаМаркерыТипНоменклатурыТипНоменклатуры.СписокВыбора.Добавить("Товар");
	Элементы.СловаМаркерыТипНоменклатурыТипНоменклатуры.СписокВыбора.Добавить("Услуга");
	//Пока не включаем
	Если Ложь Тогда
		Если СтруктураНастроек.ТипДокумента_ВыбиратьУслугиДляДопРасходов = Истина Тогда
			Элементы.СловаМаркерыТипНоменклатурыТипНоменклатуры.СписокВыбора.Добавить("Расходы");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ЗначениеЗаполнено(НовыйМаркер) Тогда
		ТаблицаСоответствий = "СловаМаркеры";
		ТаблицаСоответствийПриИзменении(Неопределено);
		
		НоваяСтрока = СловаМаркеры.Добавить();
		НоваяСтрока.Маркер = НовыйМаркер.Маркер;
		НоваяСтрока.Номенклатура = НовыйМаркер.Номенклатура;
		
		Модифицированность = Истина;
		
	Иначе
		ТаблицаСоответствий = Элементы.ТаблицаСоответствий.СписокВыбора[0].Значение;
		ТаблицаСоответствийПриИзменении(Неопределено);
	КонецЕсли;
	
	//Отображаем колонку Характеристика, если они используются при работе
	Если СтруктураНастроек.Свойство("ЗаполнениеТЧ_ИспользоватьХарактеристики")
		И СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьХарактеристики = Истина Тогда
		Элементы.СвязьНоменклатурыХарактеристика.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗагрузкаВнешнейТаблицы" Тогда
		Если Параметр <> Неопределено Тогда
			ЗагрузитьТаблицуНаСервере(Параметр.АдресВХ,Параметр.ДопПараметры.ОчищатьТаблицу);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Модифицированность = Истина Тогда
		
		Если мДанныеСохранены <> Истина Тогда
			
			Отказ = Истина;
		
			ДопПараметры = Новый Структура;
		
			ТекстВопроса = "Есть несохраненные изменения, сохранить?";
			Кнопки = РежимДиалогаВопрос.ДаНетОтмена;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьЗакрытиеФормы",ДопПараметры,ТекстВопроса,Кнопки);
					
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьЗакрытиеФормы(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаписатьТаблицуСоответствийНаСервере();
		
	ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда
		//Пользователь отказался от закрытия формы, а мы еще раньше отменили закрытие Отказ = Истина;
		Возврат;
		
	КонецЕсли;
	
	мДанныеСохранены = Истина;
	ЭтаФорма.Закрыть();
	
КонецПроцедуры


&НаКлиенте
Процедура ТаблицаСоответствийПриИзменении(Элемент)
	
	Для Каждого ЭлементСписка Из Элементы.ТаблицаСоответствий.СписокВыбора Цикл
		Элементы[ЭлементСписка.Значение].Видимость = Ложь;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ТаблицаСоответствий) Тогда
		ТаблицаСоответствий = Элементы.ТаблицаСоответствий.СписокВыбора[0].Значение;
	КонецЕсли;
	
	Элементы[ТаблицаСоответствий].Видимость = Истина;
	ЗаполнитьНаСервере();
	
КонецПроцедуры

