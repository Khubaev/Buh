	ФормаОбновлений = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ФормаОбновлений",ПараметрыОткрытия,ЭтаФорма);
	ФормаОбновлений.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;
