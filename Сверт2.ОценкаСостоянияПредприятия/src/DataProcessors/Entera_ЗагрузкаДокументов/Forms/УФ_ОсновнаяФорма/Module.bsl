			СтруктураДополнительныхДанных = ЗначениеИзСтрокиВнутр(СтрокаТаблицы.СтруктураДополнительныхДанных);
			ЗаполнитьЗначенияСвойств(СтрокаТаблицы,СтруктураДополнительныхДанных);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры


&НаСервере
Процедура ПересчитатьИтогиПоСтатусамДокументов()
	Счетчик_ВсеДокументы = Объект.СписокДокументов.Количество();
	Счетчик_Загружен = Объект.СписокДокументов.Итог("Счетчик_Загружен");
	Счетчик_Проверен = Объект.СписокДокументов.Итог("Счетчик_Проверен");
	Счетчик_Распознан = Объект.СписокДокументов.Итог("Счетчик_Распознан");
	Счетчик_ОтправленныеВЭДО = Объект.СписокДокументов.Итог("Счетчик_ОтправленныеВЭДО");
	Счетчик_ТипыДокументов = Объект.СписокДокументов.Итог("ДокументТип_СоответствуетОтбору");
	
	Счетчик_НаРаспознавании = ЗаданияРаспознавания_Таблица.Итог("КоличествоФайлов");	
КонецПроцедуры


// ================= Создание документов по данным портала ===================

&НаКлиенте
Процедура СоздатьДокументы(Команда)
	
	СтрокиДокументов = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	
	Если СтрокиДокументов.Количество() = 0 Тогда
		ПоказатьОповещениеПользователя("Выберите документы",,"Не выбрано ни одной строки для создания документов");
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
		Если ЗначениеЗаполнено(СтрокаДокумента.Документ1с) Тогда
			ОтмеченыСтрокиСДокументами = Истина;
		КонецЕсли;
		
		//теперь проверяем, что везде определено направление документа в табличной части
		Если Не ЗначениеЗаполнено(СтрокаДокумента.НаправлениеСоздаваемогоДокумента) Тогда
			ИдентификаторСтрокиБезНаправления = СтрокаДокумента.ПолучитьИдентификатор();
		КонецЕсли;
		
		//E1C-160: Статус чека "Ожидание ОФД" - "IN_PROCESSING"
		//По Вашему чеку ещё не поступили данные из ОФД. Пожалуйста, дождитесь, когда его статус изменится на "Распознан", обычно на это уходит около 15 минут.
		Если СтрокаДокумента.ДокументСтатусЧека = "IN_PROCESSING" Тогда
			СтрокаДокумента.Пометка = Ложь;
			СообщитьСообщение("<" + СтрокаДокумента.ПредставлениеДокумента + ">: по Вашему чеку ещё не поступили данные из ОФД. Пожалуйста, дождитесь, когда его статус изменится на <Распознан>, обычно на это уходит около 15 минут.");
			
		ИначеЕсли СтрокаДокумента.ДокументСтатусЧека = "NOT_CHECKED" Тогда
			СтрокаДокумента.Пометка = Ложь;
			СообщитьСообщение("<" + СтрокаДокумента.ПредставлениеДокумента + ">: Чек проверяется. Пожалуйста, дождитесь, когда его статус изменится на <Распознан>, обычно на это уходит около 15 минут.");
			
		ИначеЕсли СтрокаДокумента.ДокументСтатусЧека = "WITHOUT_DATA" Тогда
			СтрокаДокумента.Пометка = Ложь;
			СообщитьСообщение("<" + СтрокаДокумента.ПредставлениеДокумента + ">: по чеку отсутствуют данные в ОФД. Документ в 1С создать невозможно.");
			
		КонецЕсли;
	КонецЦикла;
	
	Если ИдентификаторСтрокиБезНаправления <> Неопределено Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Необходимо заполнить направление для всех строк создаваемых документов";
		Сообщение.Поле = "Объект.СписокДокументов[" + ИдентификаторСтрокиБезНаправления + "].НаправлениеСоздаваемогоДокумента";
		Сообщение.Сообщить();
		
		Возврат;
		
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ОтмеченыСтрокиСДокументами",ОтмеченыСтрокиСДокументами);
	ДопПараметры.Вставить("АвтоопределениеТипа",Истина);
	
	Если СтруктураНастроек.ТипДокумента_ВыбиратьПередСозданием Тогда
		ДопПараметры.Вставить("АвтоопределениеТипа",Ложь);
		
		//Предлагаем пользователю выбрать тип документа		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,СписокВыбора","ПродолжитьСозданиеДокументов_Тип",ДопПараметры,ТипыСоздаваемыхДокументов);
		
		_ЗФ_ОбработатьАсинхронныйВызов("ВыборИзМеню",ПараметрыВызова);
		
	Иначе
		//+++ нужно определить тип уже на этом этапе?
		ТипДокумента = Новый Структура("Представление");
		ПродолжитьСозданиеДокументов_Тип(ТипДокумента,ДопПараметры);
		
	КонецЕсли;
			
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_Тип(Результат,ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
		
	Иначе
		ДопПараметры = Новый Структура();
		ДопПараметры.Вставить("АвтоопределениеТипа",ДополнительныеПараметры.АвтоопределениеТипа);
		ДопПараметры.Вставить("СправочникТоварныхПозиций","Номенклатура");
		
		//+++ Тип документа определять на этом этапе, чтобы исключить создание номенклатуры при заполнении документа без ТЧ с товарами?
		//Как быть, если отмечено несколько документов с разными "конечными" типами?
		
		Если ДополнительныеПараметры.АвтоопределениеТипа <> Истина Тогда
			
			ВыбранныйТип = Результат.Значение;
			Если Лев(ВыбранныйТип,7) = "Энтера_" Тогда
				//Разбираем "несуществующий" тип на "реальный" тип документа и его вид операции
				МассивПолей = Энтера_РазложитьСтрокуВМассивПодстрок(ВыбранныйТип,"_");
				
				ДопПараметры.Вставить("ТипСоздаваемогоДокумента",МассивПолей[1]);
				
				ВидОперацииПринудительно = ПредопределенноеЗначение(МассивПолей[2]);
				ДопПараметры.Вставить("ВидОперацииПринудительно",ВидОперацииПринудительно);
				
				//Если передали имя справочника, переопределяющего метаданные для обработки товарных позиций - используем его,
				//в противном случае используем исходный справочник Номенклатура
				Если МассивПолей.Количество() = 4 Тогда
					ДопПараметры.Вставить("СправочникТоварныхПозиций",МассивПолей[3]);
				КонецЕсли;
			Иначе
				ДопПараметры.Вставить("ТипСоздаваемогоДокумента",Результат.Значение);
			КонецЕсли;
		КонецЕсли;
		
		ДопПараметры.Вставить("ПредставлениеСоздаваемогоДокумента",Результат.Представление);
		
		Если ДополнительныеПараметры.ОтмеченыСтрокиСДокументами = Истина Тогда
			
			ТекстВопроса = "Отмечены строки (возможно скрытые установленным фильтром)
				|с ранее созданными в 1С документами, создать документы заново?
				|
				|Да - будут созданы новые документы для всех выбранных строк 
				|Нет - будут созданы новые документы только для строк без созданных документов
				|Отмена - отменить создание документов";
			Кнопки = РежимДиалогаВопрос.ДаНетОтмена;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеДокументов_ДублиВСписке",ДопПараметры,ТекстВопроса,Кнопки);
			
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		Иначе
			ПродолжитьСозданиеДокументов_ДублиВСписке(КодВозвратаДиалога.Да,ДопПараметры);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_ДублиВСписке(Результат,ДопПараметры) Экспорт
		
	ДопПараметры.Вставить("Результат_СуществующиеДокументы",Результат);
	
	//Описание задачи: Если одновременно загрузить одинаковые документы, то при создании сразу всех будут созданы дубликаты. 
	//Нужно на стадии создания вести контроль дубликатов, если были выделены документы одного типа с одинаковыми номерами,
	//датами и суммами то выдавать сообщение о возможном дубликате с указанием документов и предложением снять галочки с дубликатов
	
	Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов <> "Нет" Тогда
		РезультатПроверки = ПроверитьЗагружаемыеДокументы_ДублиВСпискеДокументов();
	
		Если Не РезультатПроверки.Успешно Тогда
			
			СообщитьСообщение(РезультатПроверки.ТекстОшибки);
			ДопПараметры.Вставить("ИдентификаторыСтрок",РезультатПроверки.ИдентификаторыСтрок);
			
			//В ответе есть идентификаторы строк, можно снять с них флажки или вывести сообщение к одной из них
			ТекстВопроса = "Снять отметку у строк одинаковых документов?";
			Кнопки = РежимДиалогаВопрос.ДаНет;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеДокументов_СнятьОтметкиДублиВСписке",ДопПараметры,ТекстВопроса,Кнопки);
			
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
			
			Возврат;
			
		ИначеЕсли ЗначениеЗаполнено(РезультатПроверки.ТекстОшибки) Тогда
			СообщитьСообщение(РезультатПроверки.ТекстОшибки);
			
		КонецЕсли;
	КонецЕсли;
	
	//продолжаем выполнение, пробрасываем результат ответа пользователя дальше
	ПродолжитьСозданиеДокументов_СуществующиеДокументы(ДопПараметры);
	
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_СнятьОтметкиДублиВСписке(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Для Каждого ИдентификаторСтроки Из ДопПараметры.ИдентификаторыСтрок Цикл
			СтрокаТаблицы = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки.Значение);
			СтрокаТаблицы.Пометка = Ложь;
		КонецЦикла;
		
		ПродолжитьСозданиеДокументов_СуществующиеДокументы(ДопПараметры);
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_СуществующиеДокументы(ДопПараметры) Экспорт
	
	Результат = ДопПараметры.Результат_СуществующиеДокументы;
	
	//На сервер это значение передавать нельзя
	ДопПараметры.Удалить("Результат_СуществующиеДокументы");
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		УстановитьСнятьФлажкиВТаблице(Ложь,Ложь,,Истина);
	Иначе
		ДопПараметры.Вставить("УдалитьСвязьСуществующихДокументов",Истина);
	КонецЕсли;
	
	//2019.01.28 (EN-187: Контроль дубликатов документов
	Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов <> "Нет" Тогда
		РезультатПроверки = ПроверитьЗагружаемыеДокументыНаДубли(ДопПараметры);
	
		Если Не РезультатПроверки.Успешно Тогда
			//Покажем в отдельной форме найденные дубликаты для подтверждения пользователем и установки связи с документами портала
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("АдресВХ",РезультатПроверки.АдресВХ);
			ПараметрыОткрытия.Вставить("ДопПараметры",ДопПараметры);
			ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
			
			ФормаКонтроляДубликатов = ПолучитьФорму(ПрефиксИмениФорм + "УФ_Дубликаты", ПараметрыОткрытия, ЭтаФорма);

			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("Источник","УФ_Дубликаты");
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,Форма","ОбработатьЗакрытиеФормы_СинхронноАсинхронно",ДопПараметры,ФормаКонтроляДубликатов);
			
			_ЗФ_ОбработатьАсинхронныйВызов("ОткрытьФормуМодально",ПараметрыВызова);
			
		ИначеЕсли ЗначениеЗаполнено(РезультатПроверки.ТекстОшибки) Тогда
			СообщитьСообщение(РезультатПроверки.ТекстОшибки);
			ПродолжитьСозданиеДокументов_ПослеСопоставленияДубликатов(Неопределено,ДопПараметры);
			
		Иначе
			ПродолжитьСозданиеДокументов_ПослеСопоставленияДубликатов(Неопределено,ДопПараметры);
			
		КонецЕсли;
	Иначе
		ПродолжитьСозданиеДокументов_ПослеСопоставленияДубликатов(Неопределено,ДопПараметры);
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_ПослеСопоставленияДубликатов(Результат,ДопПараметры) Экспорт
	
	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Свойство("СписокСвязываемыхДокументов") Тогда
		
		//Передали список документов, которые необходимо связать и показать связанные в списке
		Если Результат.СписокСвязываемыхДокументов.Количество() > 0 Тогда
			РезультатУстановкиСсылок = УстановитьСсылкиДубликатов(Результат.СписокСвязываемыхДокументов);
			Если Не РезультатУстановкиСсылок.Успешно Тогда
				СообщитьСообщение(РезультатУстановкиСсылок.ТекстОшибки);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	//В результате проверки на дубли может оказаться, что все пометки в строках сняты, если так - не продолжаем
	ОтмеченныеСтроки = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	Если ОтмеченныеСтроки.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	// ) 2019.01.28
	
	//Снимаем флажки у связанных документов: из комплекта должен быть выбран только один
	Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
		РезультатОбработкиСвязанныхДокументов = СнятьФлагСозданияУСвязанныхДокументов();
		Если РезультатОбработкиСвязанныхДокументов.Успешно Тогда
			ПоказатьОповещениеПользователя("Поиск комплектов",,"у основных связанных документов снята пометка создания");
		КонецЕсли;
	КонецЕсли;
	
	//Типы создаваемых документов на этом этапе уже известны, заполним их в ДанныхПортала
	ЗаполнитьТипыСоздаваемыхДокументовВДанныхПортала(ДопПараметры);
	
	//Кейс для чека/авансового отчета: создавать один документ из нескольких сканов чеков.
	//Настройка удалена, всегда предлагаем объединять авансовые отчеты
				
	// 2019.10.31 ( Исходная логика предполагает, что объединяются только документы с типом RECEIPT. Теперь принято решение
	//объединять документы с любыми типами. Старый механизм на всякий случай оставляю, чтобы не переделывать
	ОбъединятьЛюбыеТипы = Истина;
	
	Если ОбъединятьЛюбыеТипы
		И СтруктураНастроек.ТипДокумента_ВыбиратьПередСозданием
		И ДопПараметры.ТипСоздаваемогоДокумента = "АвансовыйОтчет" Тогда
		СтрокиДокументов = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));	
		ТекстВопроса = "Объединить выделенные документы в один документ Авансовый отчет?";
	Иначе
	// ) 2019.10.31
		
		СтрокиДокументов = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка,ДокументТип",Истина,"RECEIPT"));	
		ТекстВопроса = "Объединить создаваемые документы с типом Чек в один документ?";
	КонецЕсли;

	Если СтрокиДокументов.Количество() > 1 Тогда
		Кнопки = РежимДиалогаВопрос.ДаНетОтмена;
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеДокументов_ОбъединениеДокументов",ДопПараметры,ТекстВопроса,Кнопки);
		
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		
	Иначе
		ПродолжитьСозданиеДокументов_ОбъединениеДокументов(КодВозвратаДиалога.Нет,ДопПараметры);
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция УстановитьСсылкиДубликатов(СписокСвязываемыхДокументов)
	
	Результат = Новый Структура("Успешно,ТекстОшибки",Истина);
	ТекстОшибки = "";
		
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Для Каждого ЭлементСписка Из СписокСвязываемыхДокументов Цикл
		
		УстановитьСсылкуДокументаПоИдентификатору(ЭлементСписка.ДубликатСсылка,ЭлементСписка.ДокументИД);
			
		//Записываем установленное сопоставление
		ЗаписатьСвязьСДокументомПортала(ЭлементСписка.ДокументИД,Отбор_Пространство,ЭлементСписка.ДубликатСсылка,,ТекстОшибки);
		
		//Установим ссылку на существующие документы в данных с портала	
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(ЭлементСписка.ДокументИД,"id");
		
		Если ДанныеДокументаПортала <> Неопределено Тогда
			ДанныеДокументаПортала.ДокументСсылка = ЭлементСписка.ДубликатСсылка;
		КонецЕсли;
		
		//Данные для обработки событий в МК
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
		ПараметрыМК.Вставить("ДокументИД",ЭлементСписка.ДокументИД);
		ПараметрыМК.Вставить("ДокументСсылка",ЭлементСписка.ДубликатСсылка);
		ПараметрыМК.Вставить("ДанныеДокумента",ДанныеДокументаПортала);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("ТекстОшибки","");
		
		//Прикрепим скан с портала к найденному дубликату
		Если ЭтоАдресВременногоХранилища(ЭлементСписка.АдресВХ) Тогда
			
			ОписаниеСобытия = "Прикрепление файла " + ЭлементСписка.ИмяФайла + " к найденному дубликату " + ЭлементСписка.ДубликатСсылка;
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Дубликаты",ОписаниеСобытия,"Дубликаты");
			
			ДанныеСкана = Новый Структура("АдресВХ,ИмяФайла,ДокументТип",ЭлементСписка.АдресВХ,ЭлементСписка.ИмяФайла,ДанныеДокументаПортала.type);
			
			//Функция принимает на вход массив сканов
			МассивФайлов = Новый Массив;
			МассивФайлов.Добавить(ДанныеСкана);
			
			ПараметрыМК.Вставить("МассивФайлов",МассивФайлов);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			РеквизитОбъект = РеквизитФормыВЗначение("Объект");
			РезультатОбработки = РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Дубликаты_ПередПрисоединениемФайлов",ПараметрыМК);
			ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
			
			ЗаполнитьВСпискеДокументовДополнительныеДанные();
			
			Если ЗначениеЗаполнено(РезультатОбработки.ТекстОшибки) Тогда
				ДополнитьТекстОшибки(ТекстОшибки,РезультатОбработки.ТекстОшибки);
			КонецЕсли;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
				
				ПрисоединитьФайлы_СканыДокумента(ЭлементСписка.ДубликатСсылка,МассивФайлов,ТекстОшибки);
				
			КонецЕсли;
		КонецЕсли;
		
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		РезультатОбработки = РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Дубликаты_УстановкаСсылки",ПараметрыМК);
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		
		Если ЗначениеЗаполнено(ПараметрыМК.ТекстОшибки) Тогда
			ДополнитьТекстОшибки(ТекстОшибки,ПараметрыМК.ТекстОшибки);
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
	Результат.ТекстОшибки = ТекстОшибки;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_ОбъединениеДокументов(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	Иначе 
		//установить/очистить признак объединения загружаемых документов
		ОбъединятьДокументы = Результат = КодВозвратаДиалога.Да;
	КонецЕсли;
	
	ДопПараметры.Вставить("ОбъединятьДокументы",ОбъединятьДокументы);
	
	//Пока это последний клиентский метод перед уходом на сервер для создания документов
	//если это необходимо - получим сканы документов и поместим в хранилище
	Если СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина Тогда
		
		РезультатЗаполненияСкана = ЗаполнитьАдресХранилищаСканаДокумента();
		
		Если ЗначениеЗаполнено(РезультатЗаполненияСкана.ТекстОшибки) Тогда
			СообщитьСообщение(РезультатЗаполненияСкана.ТекстОшибки);
		КонецЕсли;
		
		Если РезультатЗаполненияСкана.ТребуетсяПовтор Тогда
			ТекстВопроса =  "Для некоторых документов еще не готова скан копия. Обычно требуется до 3 минут для ее создания.
							|Продолжить создание документов без прикрепления скана?";
			Кнопки = РежимДиалогаВопрос.ДаНет;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеДокументов_ВсеСканыПолучены",ДопПараметры,ТекстВопроса,Кнопки);
			
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
			
		Иначе
			ПродолжитьСозданиеДокументов_ВсеСканыПолучены(КодВозвратаДиалога.Да,ДопПараметры);
			
		КонецЕсли;
		
	Иначе
		ПродолжитьСозданиеДокументов_ВсеСканыПолучены(КодВозвратаДиалога.Да,ДопПараметры);
		
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеДокументов_ВсеСканыПолучены(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗаполнения = ЗаполнитьНеНайденныеЭлементыСправочниковНаСервере(ДопПараметры);
		
	Если РезультатЗаполнения.Успешно Тогда
		
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
		ПараметрыОткрытия.Вставить("ПрефиксИмениФорм",ПрефиксИмениФорм);
		ПараметрыОткрытия.Вставить("ДопПараметры",ДопПараметры);
		ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыОткрытия.Вставить("ИспользуетсяМК",ИспользуетсяМК);
		
		//Форму больше не открываем, исключаем создание объектов по оповещению между формами
		//переносим в обработчик ОбработатьЗакрытиеФормы_СинхронноАсинхронно
		ФормаСопоставления = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ЗагружаемыеОбъекты", ПараметрыОткрытия, ЭтаФорма);
		
		ДополнительныеПараметры = Новый Структура;
		ДополнительныеПараметры.Вставить("Источник","УФ_ЗагружаемыеОбъекты");
		ДополнительныеПараметры.Вставить("ДопПараметры",ДопПараметры);
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,Форма","ОбработатьЗакрытиеФормы_СинхронноАсинхронно",ДополнительныеПараметры,ФормаСопоставления);
		
		_ЗФ_ОбработатьАсинхронныйВызов("ОткрытьФормуМодально",ПараметрыВызова);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверитьЗагружаемыеДокументы_ДублиВСпискеДокументов()
	
	РезультатПроверки = Новый Структура("Успешно,ТекстОшибки,ИдентификаторыСтрок",Истина,,Новый СписокЗначений);
	
	//Поскольку представление документа у нас формируется из Тип + Номер + Дата, то для одинаковых документов они будут одинаковые
	ВнешняяТаблица = Объект.СписокДокументов.Выгрузить(,"Пометка,ПредставлениеДокумента,СуммаДокумента,НомерСтроки");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВнешняяТаблица.ПредставлениеДокумента КАК ПредставлениеДокумента,
	               |	ВнешняяТаблица.СуммаДокумента КАК СуммаДокумента,
	               |	ВнешняяТаблица.Пометка КАК Пометка,
	               |	ВнешняяТаблица.НомерСтроки КАК НомерСтроки
	               |ПОМЕСТИТЬ ВТ_Таблица
	               |ИЗ
	               |	&ВнешняяТаблица КАК ВнешняяТаблица
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВЫРАЗИТЬ(ВТ_Таблица.ПредставлениеДокумента КАК СТРОКА(100)) КАК ПредставлениеДокумента,
	               |	ВТ_Таблица.СуммаДокумента КАК СуммаДокумента,
	               |	ВТ_Таблица.НомерСтроки КАК НомерСтроки
	               |ПОМЕСТИТЬ ВТ_ТаблицаСОтбором
	               |ИЗ
	               |	ВТ_Таблица КАК ВТ_Таблица
	               |ГДЕ
	               |	ВТ_Таблица.Пометка = ИСТИНА
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ТаблицаСОтбором.ПредставлениеДокумента КАК ПредставлениеДокумента,
	               |	ВТ_ТаблицаСОтбором.СуммаДокумента КАК СуммаДокумента,
	               |	МИНИМУМ(ВТ_ТаблицаСОтбором.НомерСтроки) КАК НомерСтроки,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ТаблицаСОтбором.НомерСтроки) КАК Счетчик
	               |ИЗ
	               |	ВТ_ТаблицаСОтбором КАК ВТ_ТаблицаСОтбором
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ВТ_ТаблицаСОтбором.СуммаДокумента,
	               |	ВТ_ТаблицаСОтбором.ПредставлениеДокумента
	               |
	               |ИМЕЮЩИЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ТаблицаСОтбором.НомерСтроки) > 1";
	Запрос.УстановитьПараметр("ВнешняяТаблица",ВнешняяТаблица);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		
		РезультатПроверки.Успешно = Ложь;
		ТекстОшибки = "";
		СтрокиДублей = Новый Массив;
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СтрокиДублей = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка,ПредставлениеДокумента",Истина,Выборка.ПредставлениеДокумента));
			
			Для Каждого СтрокаДубля Из СтрокиДублей Цикл
				Если СтрокаДубля.НомерСтроки <> Выборка.НомерСтроки Тогда
					РезультатПроверки.ИдентификаторыСтрок.Добавить(СтрокаДубля.ПолучитьИдентификатор(),СтрокаДубля.ПредставлениеДокумента);
				КонецЕсли;
			КонецЦикла;
			
			ДополнитьТекстОшибки(ТекстОшибки,СтрокаДубля.ПредставлениеДокумента);
		КонецЦикла;
		
		РезультатПроверки.ТекстОшибки = "В списке отмечены одинаковые документы: " + Символы.ПС + ТекстОшибки;
	КонецЕсли;
	
	Возврат РезультатПроверки;
КонецФункции
&НаСервере
Функция ПроверитьЗагружаемыеДокументыНаДубли(ДопПараметры)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Результат = РеквизитОбъект.ПроверитьЗагружаемыеДокументыНаДубли(АдресХранилищаДанныхПортала,СтруктураНастроек,ДопПараметры);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
	
	Возврат Результат;
КонецФункции
&НаСервере
