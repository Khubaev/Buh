&НаКлиенте
Процедура УстановитьОтборСтрокСпискаДокументов() Экспорт
	
	//E1C-185: В веб-клиенте ОтборСтрок табличной части не выполняется по нескольким ключам, определим для каждой строки ее соответствие отбору
	//и установим флаг Документ_СоответствуетОтбору, по которому уже выполним отбор. Исходный вариант пока оставляю
	НовыйВариант = Истина;
	
	Если НовыйВариант Тогда
		
		Для Каждого СтрокаТаблицы Из Объект.СписокДокументов Цикл
			СтатусСоответствуетОтбору = Не ЗначениеЗаполнено(БыстрыйФильтр_Статус) Или СтрокаТаблицы.ДокументСтатус = БыстрыйФильтр_Статус;
			ПространствоСоответствуетОтбору = Не ЗначениеЗаполнено(Отбор_Пространство) Или СтрокаТаблицы.ПространствоИД = Отбор_Пространство;
			ТипСоответствуетОтбору = СтрокаТаблицы.ДокументТип_СоответствуетОтбору = 1;
			
			СтрокаТаблицы.Документ_СоответствуетОтбору = СтатусСоответствуетОтбору И ПространствоСоответствуетОтбору И ТипСоответствуетОтбору;
			
			//Также показываем задания распознавания
			Если ЗначениеЗаполнено(СтрокаТаблицы.recognitionTaskId) Тогда
				СтрокаТаблицы.Документ_СоответствуетОтбору = Истина;
			КонецЕсли;
		КонецЦикла;
		
		СтруктураОтбора = Новый Структура("Документ_СоответствуетОтбору",Истина);
		
	Иначе
	
		СтруктураОтбора = Новый Структура("ДокументТип_СоответствуетОтбору",1);
		
		Если БыстрыйФильтр_Статус <> Неопределено Тогда
			СтруктураОтбора.Вставить("ДокументСтатус",БыстрыйФильтр_Статус);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Отбор_Пространство) Тогда
			СтруктураОтбора.Вставить("ПространствоИД",Отбор_Пространство);
		КонецЕсли;
		
	КонецЕсли;
	
	//2020.02.21 ( Отобразить в интерфейсе установленный в данный момент фильтр
	Элементы.Загруженные.ЦветТекста = ?(БыстрыйФильтр_Статус = "UPLOADED",WebЦвета.Черный,WebЦвета.СветлоГрифельноСерый);
	Элементы.ГотовыеДокументы.ЦветТекста = ?(БыстрыйФильтр_Статус = "VERIFIED",WebЦвета.Черный,WebЦвета.СветлоГрифельноСерый);
	Элементы.НаРаспознавании.ЦветТекста = ?(БыстрыйФильтр_Статус = "RECOGNIZING",WebЦвета.Черный,WebЦвета.СветлоГрифельноСерый);
	Элементы.Распознанные.ЦветТекста = ?(БыстрыйФильтр_Статус = "RECOGNIZED",WebЦвета.Черный,WebЦвета.СветлоГрифельноСерый);
	Элементы.ОтправленныеВЭДО.ЦветТекста = ?(БыстрыйФильтр_Статус = "EDI_SEND",WebЦвета.Черный,WebЦвета.СветлоГрифельноСерый);
	// ) 2020.02.21
	
	Элементы.СписокДокументов.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбора);
	
КонецПроцедуры

&НаКлиенте
Процедура БыстрыйФильтр_ЗаполнитьТипыДокументов()
	
	Если ТипЗнч(СправочникиПортала) = Тип("Структура")
		И СправочникиПортала.Свойство("ТипДокумента") Тогда
		
		Для Каждого ТипДокумента Из СправочникиПортала.ТипДокумента Цикл
			БыстрыйФильтр_ТипыДокументов.Добавить(ТипДокумента.Ключ,ТипДокумента.Значение);
		КонецЦикла;
		
		Попытка КартинкаЗакрыть = БиблиотекаКартинок.Закрыть; Исключение; КартинкаЗакрыть = Новый Картинка; КонецПопытки;
		
		БыстрыйФильтр_ТипыДокументов.Добавить("ОчиститьОтбор","Очистить отбор",,КартинкаЗакрыть);
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура БыстрыйФильтр_ТипыДокументовНажатие(Элемент)
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ЭлементФормы",Элементы.БыстрыйФильтр_ТипыДокументов);
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,СписокВыбора","БыстрыйФильтр_ОбработатьВыборТипаДокумента",ДопПараметры,БыстрыйФильтр_ТипыДокументов);
	
	_ЗФ_ОбработатьАсинхронныйВызов("ВыборИзМеню",ПараметрыВызова);
	
КонецПроцедуры
&НаКлиенте
Процедура БыстрыйФильтр_ОбработатьВыборТипаДокумента(Результат,ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		Если Результат.Значение = "ОчиститьОтбор" Тогда
			
			Для Каждого ЭлементСписка Из БыстрыйФильтр_ТипыДокументов Цикл
				ЭлементСписка.Пометка = Ложь;
			КонецЦикла;
			
		Иначе
			Результат.Пометка = Не Результат.Пометка;
			
		КонецЕсли; 
		
		БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам();
		УстановитьОтборСтрокСпискаДокументов();
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам()
	
	ТекстОтбора = "";
	ЕстьОтборПоТипу = Ложь;
	
	Для Каждого ТипДокумента Из БыстрыйФильтр_ТипыДокументов Цикл
		Если ТипДокумента.Пометка Тогда
			ТекстОтбора = ТекстОтбора + ?(ТекстОтбора <> "",", ","") + ТипДокумента.Представление;
			ЕстьОтборПоТипу = Истина;
		КонецЕсли;
	КонецЦикла;
		
	БыстрыйФильтр_УстановленныйОтбор = ТекстОтбора;
	
	//Определим в таблице документов флаг соответствия отмеченным типам документов
	Для Каждого СтрокаДокумента Из Объект.СписокДокументов Цикл
		
		//Строки с заданиями распознавания отображаем всегда
		Если ЗначениеЗаполнено(СтрокаДокумента.recognitionTaskId) Тогда
			СтрокаДокумента.ДокументТип_СоответствуетОтбору = 1;
			Продолжить;
		КонецЕсли;
		
		Если ЕстьОтборПоТипу Тогда
			
			//Проверяем строку на соответствие типу
			СтрокаДокумента.ДокументТип_СоответствуетОтбору = 0;
			СоответствующийТип = БыстрыйФильтр_ТипыДокументов.НайтиПоЗначению(СтрокаДокумента.ДокументТип);
			
			Если СоответствующийТип <> Неопределено И СоответствующийТип.Пометка Тогда
				СтрокаДокумента.ДокументТип_СоответствуетОтбору = 1;
			КонецЕсли;
			
		Иначе
			//Все соответствуют отбору
			СтрокаДокумента.ДокументТип_СоответствуетОтбору = 1;
			
		КонецЕсли;
	КонецЦикла;
	
	Счетчик_ТипыДокументов = Объект.СписокДокументов.Итог("ДокументТип_СоответствуетОтбору");
	
КонецПроцедуры


&НаКлиенте
Процедура СписокДокументовПриАктивизацииСтроки(Элемент)
	
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	//По этому идентификатору будет подсвечиваться parent/children документы, связанные с документом в текущей строке
	Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
		ТекущаяСтрока_ДокументИД = ?(ТекСтрока = Неопределено Или ТекСтрока.ДокументИД = "", Неопределено, ТекСтрока.ДокументИД);
	Иначе
		ТекущаяСтрока_ДокументИД = Неопределено;
	КонецЕсли;
	
	//E1C-133: скачивание файлов документов с портала в формате XML ФНС доступно только для УПД, СФ и ТОРГ12
	Если ТекСтрока <> Неопределено Тогда
		Если ТекСтрока.ДокументТип = "UTD" Или ТекСтрока.ДокументТип = "VAT_INVOICE" Или ТекСтрока.ДокументТип = "TORG12" Тогда
			Элементы.СписокДокументов_СкачатьФНСXML.Доступность = Истина;
		Иначе
			Элементы.СписокДокументов_СкачатьФНСXML.Доступность = Ложь;
		КонецЕсли;
		
		//E1C-450: Очистка связи недоступна для исходящих ЭДО-документов
		Если ТекСтрока.ДокументСтатус = "EDI_SEND" Тогда
			Элементы.СписокДокументов_ОчиститьСвязь.Доступность = Ложь;
		Иначе
			Элементы.СписокДокументов_ОчиститьСвязь.Доступность = Истина;
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Процедура СписокДокументовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если Поле = Элементы.СписокДокументовurl
		И ЗначениеЗаполнено(ТекСтрока.url) Тогда
		
		//2019.04.11 ( бухи с IE по умолчанию тоже хотят смотреть Энтеру в Хроме
		ЭтаФорма._ЗФ_Команда_ПерейтиПоСсылке(ТекСтрока.url);
		// ) 2019.04.11
		
	ИначеЕсли Поле = Элементы.СписокДокументовДиадок_url
		И ЗначениеЗаполнено(ТекСтрока.Диадок_url) Тогда
		
		ЭтаФорма._ЗФ_Команда_ПерейтиПоСсылке(ТекСтрока.Диадок_url);
		
	ИначеЕсли Поле = Элементы.СписокДокументовПредставлениеДокумента Тогда
		
		//Задания распознавания не обрабатываем
		Если ЗначениеЗаполнено(ТекСтрока.recognitionTaskId) Тогда
			Возврат;
		КонецЕсли;
		
		//Во Фреш этот функционал не используется
		Если ЭтоФреш Тогда
			Возврат;
		КонецЕсли;
		
		//Получим файл на локальную машину и откроем штатным просмотрщиком pdf
		Если ЗначениеЗаполнено(ТекСтрока.АдресХранилищаСканаДокумента) Тогда
			//Печатная форма уже получена ранее
			АдресХранилищаСканаДокумента = ТекСтрока.АдресХранилищаСканаДокумента;
		Иначе
			
			//Получаем печатную форму PDF
			РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(ТекСтрока.ДокументИД,ТекСтрока.ПредставлениеДокумента);
			Если РезультатЗапроса.Успешно Тогда
				Если РезультатЗапроса.ТребуетсяПовтор Тогда
					СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
				Иначе
					АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
					ТекСтрока.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
					ТекСтрока.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
				КонецЕсли;
			Иначе
				СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЭтоАдресВременногоХранилища(АдресХранилищаСканаДокумента) Тогда
			//Открываем полученный скан системным просмотрщиком
			ЭтаФорма._ЗФ_Команда_ПоказатьФайлСкана(АдресХранилищаСканаДокумента,ТекСтрока.ИмяФайлаСканаДокумента);
		КонецЕсли;
		
	ИначеЕсли Поле = Элементы.СписокДокументовДокумент1с
		И ЗначениеЗаполнено(ТекСтрока.Документ1с) Тогда
				
		ПараметрыВызова = Новый Структура("Обработчик,Значение","Заглушка_ОписаниеОповещения",ТекСтрока.Документ1с);
		_ЗФ_ОбработатьАсинхронныйВызов("ПоказатьЗначение",ПараметрыВызова);
		
	ИначеЕсли Поле = Элементы.СписокДокументовЗамечанияРаспознавания Тогда
		Если ЗначениеЗаполнено(ТекСтрока.ТекстЗамечанийРаспознавания) Тогда
			ПоказатьПредупреждение(,ТекСтрока.ТекстЗамечанийРаспознавания);
		Иначе
			ПоказатьОповещениеПользователя("",,"Замечаний не зафиксировано");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура СписокДокументовПередНачаломИзменения(Элемент, Отказ)
	
	// 2019.05.14 ( EN-438: теперь задания на распознавание нужно отображать и в списке документов, таким строкам флаг не устанавливаем
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекСтрока.recognitionTaskId)
		И (Элемент.ТекущийЭлемент = Элементы.СписокДокументовНаправлениеСоздаваемогоДокумента
		Или Элемент.ТекущийЭлемент = Элементы.СписокДокументовПометка) Тогда
		Отказ = Истина;
	КонецЕсли;
	// ) 2019.05.14
	
	//Странный баг: после установки флажка перестает работать сортировка/изменение порядка строк.
	//На новой внешней обработке проблему удалось полностью воспроизвести, установив программный отбор строк табличного поля.
	//Вызов процедуры установки отбора внутри этого обработчика события результата не дал, в обработчике ожидания срабатывает.
	ПодключитьОбработчикОжидания("УстановитьОтборСтрокСпискаДокументов",0.1,Истина);
	
КонецПроцедуры
&НаКлиенте
Процедура СписокДокументовДокумент1сПриИзменении(Элемент)
		
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		ТекстОшибки = "";
		ЗаписатьСвязьСДокументомПортала(ТекСтрока.ДокументИД,ТекСтрока.ПространствоИД,ТекСтрока.Документ1с,Неопределено,ТекстОшибки);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекстОшибки) Тогда
		СообщитьСообщение(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СписокДокументов_ОчиститьСвязь(Команда)
	
	ДопПараметры = Новый Структура;
	ТекстВопроса = "Ссылки на документы в выбранных строках будут удалены
				   |из столбца <Документ в 1С>, продолжить?";
	Кнопки = РежимДиалогаВопрос.ДаНет;
	
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_СписокДокументов_ОчиститьСвязь",ДопПараметры,ТекстВопроса,Кнопки);
	_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);

КонецПроцедуры
&НаКлиенте
Процедура Продолжить_СписокДокументов_ОчиститьСвязь(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
	
		Для Каждого ВыделеннаяСтрока Из Элементы.СписокДокументов.ВыделенныеСтроки Цикл
		
			ТекСтрока = Объект.СписокДокументов.НайтиПоИдентификатору(ВыделеннаяСтрока);
				
			Если ЗначениеЗаполнено(ТекСтрока.recognitionTaskId) Тогда
				Продолжить;
				
			ИначеЕсли ЗначениеЗаполнено(ТекСтрока.Документ1с) Тогда
				ТекстОшибки = "";
				ЗаписатьСвязьСДокументомПортала(ТекСтрока.ДокументИД,ТекСтрока.ПространствоИД,Неопределено,ТекСтрока.Документ1с,ТекстОшибки);
				
				Если ЗначениеЗаполнено(ТекстОшибки) Тогда
					СообщитьСообщение(ТекстОшибки);
				Иначе
					ТекСтрока.Документ1с = Неопределено;
					
					ТекСтрока.ДокументСтатус = "RECOGNIZED";
					ТекСтрока.ПредставлениеСтатуса = "Распознан";
					
					ТекСтрока.Счетчик_Загружен = 0;
					ТекСтрока.Счетчик_Проверен = 0;
					ТекСтрока.Счетчик_Распознан = 1;
				КонецЕсли;
				
				ПересчитатьИтогиПоСтатусамДокументов();
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура КнопкаБалансНажатие(Команда)
	
	ДанныеБаланса = ОбновитьТекстКнопкиБаланс(Истина);
	
	//Используем форму списка обновлений, там в принципе есть все, что нужно: поле HTML-документа
	ПараметрыОткрытия = Новый Структура;
