&НаСервере
Функция КодироватьСтрокуПараметровНаСервере(КодируемаяСтрока)
	//2021.06.29 ( Выполняем кодирование строки, экранируем от синтаксического контроля старых версий платформ
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	СпособКодирования = РеквизитОбъект._ЗФ_ПолучитьСпособКодированияСтроки();
	Если СпособКодирования <> Неопределено Тогда
		Результат = КодироватьСтроку(КодируемаяСтрока,СпособКодирования);
	Иначе
		Результат = КодируемаяСтрока;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции
&НаСервере
Функция РаскодироватьСтрокуПараметровНаСервере(КодируемаяСтрока)
	//2021.06.29 ( Выполняем кодирование строки, экранируем от синтаксического контроля старых версий платформ
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	СпособКодирования = РеквизитОбъект._ЗФ_ПолучитьСпособКодированияСтроки();
	Если СпособКодирования <> Неопределено Тогда
		Результат = РаскодироватьСтроку(КодируемаяСтрока,СпособКодирования);
	Иначе
		Результат = КодируемаяСтрока;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции
&НаСервереБезКонтекста
Функция Энтера_РазложитьСтрокуВМассивПодстрок(Знач Строка, Знач Разделитель = ",", Знач ПропускатьПустыеСтроки = Неопределено, СокращатьНепечатаемыеСимволы = Ложь) Экспорт
	
	Результат = Новый Массив;
	
	// Для обеспечения обратной совместимости.
	Если ПропускатьПустыеСтроки = Неопределено Тогда
		ПропускатьПустыеСтроки = ?(Разделитель = " ", Истина, Ложь);
		Если ПустаяСтрока(Строка) Тогда 
			Если Разделитель = " " Тогда
				Результат.Добавить("");
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	//
	
	Позиция = Найти(Строка, Разделитель);
	Пока Позиция > 0 Цикл
		Подстрока = Лев(Строка, Позиция - 1);
		Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Подстрока) Тогда
			Если СокращатьНепечатаемыеСимволы Тогда
				Результат.Добавить(СокрЛП(Подстрока));
			Иначе
				Результат.Добавить(Подстрока);
			КонецЕсли;
		КонецЕсли;
		Строка = Сред(Строка, Позиция + СтрДлина(Разделитель));
		Позиция = Найти(Строка, Разделитель);
	КонецЦикла;
	
	Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Строка) Тогда
		Если СокращатьНепечатаемыеСимволы Тогда
			Результат.Добавить(СокрЛП(Строка));
		Иначе
			Результат.Добавить(Строка);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 
&НаСервереБезКонтекста
Функция РеквизитСуществует(РазделМетаданных, ОбъектМетаданных, ИмяРеквизита = Неопределено, ИмяТабЧасти = Неопределено) Экспорт
	
	Существует = Ложь;
		
	Если Метаданные[РазделМетаданных].Найти(ОбъектМетаданных) <> Неопределено Тогда
		Если ИмяРеквизита = Неопределено И ИмяТабЧасти = Неопределено Тогда
			Существует = Истина;
		Иначе	
			Если ИмяТабЧасти = Неопределено Тогда
				Если РазделМетаданных = "Перечисления" Тогда
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].ЗначенияПеречисления.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				Иначе
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				КонецЕсли;
			Иначе
				ТабличнаяЧасть = Метаданные[РазделМетаданных][ОбъектМетаданных].ТабличныеЧасти.Найти(ИмяТабЧасти);
				Если ТабличнаяЧасть <> Неопределено И ТабличнаяЧасть.Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
					Существует = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Существует;
КонецФункции
&НаКлиентеНаСервереБезКонтекста
Процедура ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки)
	ОбщийТекстОшибки = Строка(ОбщийТекстОшибки) + ТекстОшибки + Символы.ПС;
КонецПроцедуры
&НаКлиентеНаСервереБезКонтекста
Функция КраткоеОписаниеОшибки(ТекстОшибки) Экспорт
	
	КонецСлужебнойИнформации = Найти(ТекстОшибки,"}: ");
	Если КонецСлужебнойИнформации > 0 Тогда
		ТекстОшибки = Сред(ТекстОшибки,КонецСлужебнойИнформации + 3);
	КонецЕсли;				
	
	Возврат ТекстОшибки;
	
КонецФункции
&НаКлиентеНаСервереБезКонтекста
Функция СформироватьПредставлениеРазмераФайла(РазмерДанных) Экспорт
	
	Результат = "";
	
	Если РазмерДанных > 1048576 Тогда
		Результат = "" + Окр(РазмерДанных/1048576,1) + "МБ";
	ИначеЕсли РазмерДанных > 1024 Тогда
		Результат = "" + Окр(РазмерДанных/1024,1) + "КБ";
	ИначеЕсли РазмерДанных = 0 Тогда
		Результат = "0Б";
	Иначе
		Результат = Строка(РазмерДанных) + "Б";
	КонецЕсли;			
	
	Возврат Результат;
	
КонецФункции
&НаСервере
Процедура ДобавитьКнопкуНаФорму(Форма,ИмяКоманды,ИмяКнопки,Синоним,ИмяДействия,ГруппаРодитель = Неопределено, Картинка = Неопределено, Пометка = Ложь) Экспорт
	
	// Добавляем новую команду обработки выбора вида операции.
	Если Команды.Найти(ИмяКоманды) = Неопределено Тогда
		
		Команда = Команды.Добавить(ИмяКоманды);
		Команда.Действие = ИмяДействия;
		
		Если Картинка <> Неопределено Тогда
			Команда.Картинка = Картинка;
		КонецЕсли;
	
	
		Если ГруппаРодитель = Неопределено Тогда
			НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"));
		Иначе    
			НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), ГруппаРодитель);
		КонецЕсли;
		
		НоваяКнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
		НоваяКнопка.ИмяКоманды = ИмяКоманды;
		НоваяКнопка.Заголовок = Синоним;
		НоваяКнопка.Пометка = Пометка;
		
	КонецЕсли;

КонецПроцедуры
&НаСервере
Процедура ЗаписатьСобытиеВПротокол(СтруктураНастроек,Уровень,Событие,Описание,Состояние) Экспорт
	
	Если СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Нет" Тогда
		Возврат;
		
		//Уровень значимости события
		//2 - Ошибки
		//1 - Ошибки+Запросы
		//0 - Полный		
		
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Ошибки" Тогда
		ФиксируемыйУровень = 2;
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Ошибки+Запросы" Тогда
		ФиксируемыйУровень = 1;
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Полный" Тогда
		ФиксируемыйУровень = 0;
	Иначе
		//такого не бывает, но если вдруг бывает - выходим
		Возврат;
	КонецЕсли;
	
	Если ФиксируемыйУровень <= Уровень Тогда
			
		НоваяСтрока = Объект.ПротоколРаботы.Добавить();
		НоваяСтрока.Дата = ТекущаяДата();
		НоваяСтрока.Событие = Событие;
		НоваяСтрока.Описание = Описание;
		НоваяСтрока.Состояние = Состояние;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиентеНаСервереБезКонтекста
Процедура СообщитьСообщение(Текст,Поле = Неопределено,ИдентификаторНазначения = Неопределено) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = Текст;
	СообщениеПользователю.Поле = Поле;
	
	Если ТипЗнч(ИдентификаторНазначения) = Тип("УникальныйИдентификатор") Тогда
		СообщениеПользователю.ИдентификаторНазначения = ИдентификаторНазначения;
	КонецЕсли;
	
	СообщениеПользователю.Сообщить();
	
КонецПроцедуры
&НаКлиенте
Функция ЗаполнитьСтруктуруПодключения() Экспорт
	
	СтруктураПодключения = Новый Структура;
	
	СтруктураПодключения.Вставить("Адрес","app.entera.pro");
	СтруктураПодключения.Вставить("АдресСервераАвторизации","id.entera.pro");
	СтруктураПодключения.Вставить("Протокол","https://");
	СтруктураПодключения.Вставить("Порт",Неопределено);
	СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT=");
	
	#Если Не ВебКлиент Тогда
	СтруктураПодключения.Вставить("SSL",Новый ЗащищенноеСоединениеOpenSSL);
	#КонецЕсли
	
	//Отладка	
	Если Отладка_ТестовыйРежим = 1 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-staging1.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-staging1.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	ИначеЕсли Отладка_ТестовыйРежим = 2 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-test2.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-test2.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	ИначеЕсли Отладка_ТестовыйРежим = 7 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-test7.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-test7.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	КонецЕсли;
	
	//напомним в интерфейсе, что мы сейчас работаем на тестовом портале
	Элементы.Обновить.ЦветФона = Отладка_ПолучитьЦветКнопки(Отладка_ТестовыйРежим);
		
	Возврат СтруктураПодключения;
	
КонецФункции


