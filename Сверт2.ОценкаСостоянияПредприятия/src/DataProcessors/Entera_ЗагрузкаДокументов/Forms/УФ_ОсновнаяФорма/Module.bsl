	ПараметрыОткрытия.Вставить("ЭтоФреш",ЭтоФреш);
	ПараметрыОткрытия.Вставить("ЭтоРасширениеКонфигурации",ЭтоРасширениеКонфигурации);
	ПараметрыОткрытия.Вставить("ДанныеБаланса",ДанныеБаланса);
