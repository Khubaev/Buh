// ================= Модуль кастомизации ===================

&НаКлиенте
Процедура УстановитьВидимость_ИспользуетсяМодульКастомизации()
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
		ИспользуетсяМК = СтруктураНастроек.Свойство("АдресХранилищаДвоичныхДанныхМодуляКастомизации") И ЭтоАдресВременногоХранилища(СтруктураНастроек.АдресХранилищаДвоичныхДанныхМодуляКастомизации);
		Элементы.ДекорацияМодульКастомизации.Видимость = ИспользуетсяМК;
	КонецЕсли;
	
	//2019.11.11 ( обработка клиентских событий в МК
	Если ИспользуетсяМК Тогда
		МодульМК = _3Ф_ПодключитьВнешнююОбработку(СтруктураНастроек.АдресХранилищаДвоичныхДанныхМодуляКастомизации);
		Если МодульМК <> Неопределено Тогда
			ПараметрыОткрытияФормыМК = Новый Структура;
			Попытка
				МодульМК_Клиент = ПолучитьФорму("ВнешняяОбработка.Entera_МК.Форма.УФ_Форма",ПараметрыОткрытияФормыМК,ЭтаФорма);
			Исключение
				МодульМК_Клиент = Неопределено;
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
				ОписаниеОбработчика = "Ошибка при подключении формы-обработчика клиентских событий" + Символы.ПС + ТекстОшибки;
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"Ошибка");
			КонецПопытки;
		КонецЕсли;
	Иначе
		//Сбрасываем клиентский МК
		МодульМК_Клиент = Неопределено;
	КонецЕсли;
	// ) 2019.11.11
	
	
	//E1C-149: Обработчик события МК: ОсновнаяФорма_ПослеПодключенияМК
	Если МодульМК_Клиент <> Неопределено Тогда
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("ОсновнаяФорма",ЭтаФорма);
		ПараметрыМК.Вставить("ТекстОшибки","");
		
		МодульКастомизации_ОбработатьСобытиеФормы_Клиент("ОсновнаяФорма_ПослеПодключенияМК_НаКлиенте",ПараметрыМК);
		ТекстОшибки = ПараметрыМК.ТекстОшибки;
		
		МодульКастомизации_ОбработатьСобытиеФормы_Сервер("ОсновнаяФорма_ПослеПодключенияМК_НаСервере",ТекстОшибки);
		
		Если ЗначениеЗаполнено(ТекстОшибки) Тогда
			СообщитьСообщение(ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МодульКастомизации_ОбработатьСобытиеФормы_Клиент(ИмяСобытия,ПараметрыМК) Экспорт
	
	//Комментарий для аудитора: Для Фреш не выполняется подключение дополнительной внешней обработки "Модуль кастомизации",
	//реквизит ЭтоФреш определяется в процедуре ПриСозданииНаСервере этой формы
	Если ЭтоФреш Тогда
		Возврат;
	КонецЕсли;
	
	Если МодульМК_Клиент <> Неопределено Тогда
		
		//До 5 версии МК могут возникать ошибки при вызове клиентской процедуры обработчика,
		//проверим наличие реквизита Версия у формы МК, если там значение 5 и старше - продолжаем
		СтруктураВерсии = Новый Структура("ВерсияМодуля");
		ЗаполнитьЗначенияСвойств(СтруктураВерсии,МодульМК_Клиент);
		Если СтруктураВерсии.ВерсияМодуля = Неопределено
			Или СтруктураВерсии.ВерсияМодуля.Версия < 5 Тогда
			Возврат;
		КонецЕсли;
		
		ОписаниеОбработчика = ИмяСобытия + ": передача клиентского события для обработки в МК";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"ВыполнениеМК_Клиент");
		
		Попытка
			МодульМК_Клиент.ОбработатьКлиентскоеСобытиеОсновногоМодуля(ИмяСобытия,ПараметрыМК);
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			Если ПараметрыМК.Свойство("ТекстОшибки") Тогда
				ПараметрыМК.ТекстОшибки = ТекстОшибки;
			КонецЕсли;
			
			ОписаниеОбработчика = ИмяСобытия + ": при обработке клиентского события в МК возникла ошибка" + Символы.ПС + ТекстОшибки;
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"Ошибка");
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура МодульКастомизации_ОбработатьСобытиеФормы_Сервер(ИмяСобытия,ТекстОшибки) Экспорт
	
	//Комментарий для аудитора: Для Фреш не выполняется подключение дополнительной внешней обработки "Модуль кастомизации",
	//реквизит ЭтоФреш определяется в процедуре ПриСозданииНаСервере этой формы
	Если ЭтоФреш Тогда
		Возврат;
	КонецЕсли;
		
	//Чтобы не было ошибки передачи недопустимого значения ФормаКлиентскогоПриложения между Клиентом и Сервером,
	//серверные и клиентские обработчики событий основной формы в МК передаются раздельно в серверной и клиентской процедурах
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ОсновнаяФорма",ЭтаФорма);
	ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
	
	ОписаниеОбработчика = ИмяСобытия + ": передача серверного события основной формы для обработки в МК";
	ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"ВыполнениеМК_Сервер");
	
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	Попытка
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие(ИмяСобытия,ПараметрыМК);
	Исключение
		ПараметрыМК.ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
	
	Если ЗначениеЗаполнено(ПараметрыМК.ТекстОшибки) Тогда
		ОписаниеОбработчика = ИмяСобытия + ": при обработке серверного события формы в МК возникла ошибка" + Символы.ПС + ПараметрыМК.ТекстОшибки;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"Ошибка");
		
		ТекстОшибки = ПараметрыМК.ТекстОшибки;
	КонецЕсли;
			
КонецПроцедуры

&НаКлиенте
Процедура МодульКастомизации_ОбработатьСобытиеЭлемента(Элемент)
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ОсновнаяФорма",ЭтаФорма);
	ПараметрыМК.Вставить("ТекСтрока",Элементы.СписокДокументов.ТекущиеДанные);	
	ПараметрыМК.Вставить("Элемент",Элемент);
	ПараметрыМК.Вставить("ТекстОшибки","");
	
	МодульКастомизации_ОбработатьСобытиеФормы_Клиент("ОсновнаяФорма_ОбработатьСобытиеЭлемента",ПараметрыМК);
КонецПроцедуры


