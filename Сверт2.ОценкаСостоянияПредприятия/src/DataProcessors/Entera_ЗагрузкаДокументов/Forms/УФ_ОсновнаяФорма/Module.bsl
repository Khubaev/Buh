КонецФункции

&НаСервере
Функция СоздатьДокументыНаСервере(ДопПараметры)
	
	РезультатСоздания = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	ОбщийТекстОшибки = "";
	
	//Устанавливаем строкам списка документов и в данных портала идентификатор объединения,
	//по которым будут потом заполняться сгруппированные документы
	ЗаполнитьИдентификаторыОбъединенияДокументов(ДопПараметры);
	
	//Формируем массив идентификаторов объединения документов
	ТаблицаИдентификаторов = Объект.СписокДокументов.Выгрузить(,"ИдентификаторОбъединения");
	ТаблицаИдентификаторов.Свернуть("ИдентификаторОбъединения");
	
	//Удаляем строку с пустым идентификатором
	ПустаяСтрока = ТаблицаИдентификаторов.Найти("","ИдентификаторОбъединения");
	Если ПустаяСтрока <> Неопределено Тогда
		ТаблицаИдентификаторов.Удалить(ПустаяСтрока);
	КонецЕсли;
	
	СозданоДокументов = 0;
	
	//Заполняем по полученной структуре новый документ по исходной схеме
	ОписаниеСобытия = "Начало обхода идентификаторов объединенных документов [" + ТаблицаИдентификаторов.Количество() + "]";
	ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
	
	Для Каждого СтрокаТаблицыИдентификаторов Из ТаблицаИдентификаторов Цикл
		
		ДокументСсылка = Неопределено;
		
		ИдентификаторОбъединения = СтрокаТаблицыИдентификаторов.ИдентификаторОбъединения;
		
		ТекстОшибки = "";
				
		СтрокиДокументов = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ИдентификаторОбъединения",ИдентификаторОбъединения));
		
		//Пользователь выбрал удаление связи существующих документов?
		МассивОтвязываемыхДокументов = Новый Массив;
		Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл		
			
			Если ДопПараметры.Свойство("УдалитьСвязьСуществующихДокументов")
				И ДопПараметры.УдалитьСвязьСуществующихДокументов = Истина
				И ЗначениеЗаполнено(СтрокаДокумента.Документ1с) Тогда
				МассивОтвязываемыхДокументов.Добавить(СтрокаДокумента.Документ1с);
			КонецЕсли;
			
		КонецЦикла;
		
		СтруктураЗаполненияДокумента = ПолучитьСтруктуруОбъединенныхДанныхЗаполненияДокумента(ИдентификаторОбъединения,ДопПараметры);
		
		//Заполняем по полученной структуре новый документ по исходной схеме
		ОписаниеСобытия = "Начало заполнения документов [" + СтрокиДокументов.Количество() + "], Автоопределение типа [" + ДопПараметры.АвтоопределениеТипа + "]"
			+ ?(ДопПараметры.АвтоопределениеТипа,"",", выбран тип [" + ДопПараметры.ТипСоздаваемогоДокумента + "]");
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
						
		//2019.10.11 ( При использовании поиска комплектов документ-основание мог быть создан ранее, проверим
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
			
			//В таком случае ищем только документ-основание для полученного документа счет-фактура, если найден - используем его
			Если СтруктураЗаполненияДокумента.document.type = "VAT_INVOICE" Тогда
				СтрокиДокументаРодителя = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтруктураЗаполненияДокумента.document.parent));
				Если СтрокиДокументаРодителя.Количество() > 0
					И ЗначениеЗаполнено(СтрокиДокументаРодителя[0].Документ1с) Тогда
					
					ДокументСсылка = СтрокиДокументаРодителя[0].Документ1с;
					
					ОписаниеСобытия = "Найден существующий родитель документа [" + СтруктураЗаполненияДокумента.document.ДокументСсылка + "] - " + Строка(ДокументСсылка);
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДокументСсылка) Тогда
		// ) 2019.10.11
		
			ДокументСсылка = ПолучитьСсылку_ЗаполнениеДокумент(СтруктураЗаполненияДокумента,ДопПараметры,ТекстОшибки);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДокументСсылка) Тогда
						
			//В зависимости от типа документа (+++ или статуса УПД) создать документ счет-фактура полученный
			ДанныеДокумента = СтруктураЗаполненияДокумента.document;
			
			Если ДанныеДокумента.ТипСоздаваемогоДокумента = "АвансовыйОтчет" Тогда
				// 2020.07.30 Кейс: на основании УПД может быть введен документ Авансовый отчет, не вводим СФ автоматически
				
			Иначе
				
				Если ДанныеДокумента.type = "VAT_INVOICE" Или ДанныеДокумента.type = "E_VAT_INVOICE"
					Или (СтруктураНастроек.СозданиеДокумента_СоздаватьСчетФактуруПоУПД = Истина И ДанныеДокумента.type = "UTD")
					Или (СтруктураНастроек.СозданиеДокумента_СоздаватьСчетФактуруПоТОРГ12 = Истина И ДанныеДокумента.type = "TORG12")
					Или (СтруктураНастроек.СозданиеДокумента_СоздаватьСчетФактуруПоАкту = Истина И ДанныеДокумента.type = "CERTIFICATE") Тогда
					
					//раньше счета-фактуры создавались только по входящим документам,
					//чтобы принудительно не устанавливать нумерацию из скана выданным счетам-фактурам,
					//теперь условие убрали, создаем по настройке, нумерацию при необходимости устанавливаем в МК
					
					//2021.10.18 ( Временно отключим это условие, требуется создание СФ даже при установленном флаге УПД в документе-поступлении
					СоздаватьСчетФактуруПриПризнакеВДокументеУПД = Истина;
					
					// 2020.10.07 (
					Если Не СоздаватьСчетФактуруПриПризнакеВДокументеУПД
						И СчетФактура_ДанныеСчетаФактурыУказываютсяВДокументеОсновании(ДокументСсылка) И ДанныеДокумента.НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
						//Данные СФ уже есть в документе
						ОписаниеСобытия = "В документе <" + ДокументСсылка + "> установлен флаг <УПД>, создание счета-фактуры пропущено";
						ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
					Иначе
					// ) 2020.10.07
					
						Попытка
							СчетФактураСсылка = ПолучитьСсылку_ЗаполнениеСчетФактура(СтруктураЗаполненияДокумента,ДокументСсылка,ДанныеДокумента,ТекстОшибки);
						Исключение
							ОписаниеСобытия = "- ошибка при заполнении счета-фактуры на основании созданного документа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
							ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
							ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
						КонецПопытки;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	
		Если ЗначениеЗаполнено(ДокументСсылка) Тогда
			
			СозданоДокументов = СозданоДокументов + 1;
			
			Если МассивОтвязываемыхДокументов.Количество() > 0 Тогда
				Для Каждого ОтвязываемыйДокумент Из МассивОтвязываемыхДокументов Цикл
					ЗаписатьСвязьСДокументомПортала(СтрокаДокумента.ДокументИД,СтрокаДокумента.ПространствоИД,,ОтвязываемыйДокумент,ТекстОшибки);
					
					ОписаниеСобытия = "Удаление связи существующего документа <" + ОтвязываемыйДокумент + "> (" + СтрокаДокумента.ДокументИД + ")";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"УдалениеСвязиДокументов");
				КонецЦикла;
			КонецЕсли;
			
			//E1C-50: Заполним ссылку на объединенные документы, при условии, что было объединение нескольких в один
			Если СтрокиДокументов.Количество() > 1 Тогда
				Для Каждого СтрокаОбъединяемогоДокумента Из СтрокиДокументов Цикл
					УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,СтрокаОбъединяемогоДокумента.ДокументИД);
				КонецЦикла;
			КонецЕсли;
			
		Иначе
			//Один или несколько из документов не были созданы
			РезультатСоздания.Успешно = Ложь;
			
		КонецЕсли;
		
		Если ТекстОшибки <> "" Тогда
			ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки);
		КонецЕсли;
	КонецЦикла;
	
	ОписаниеСобытия = "Завершение создания документов, успешно [" + СозданоДокументов + "]";
	ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
	
	Если ЗначениеЗаполнено(ОбщийТекстОшибки) Тогда
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,2,"СозданиеДокументов",ОбщийТекстОшибки,"Ошибка");
	КонецЕсли;
	
	ПересчитатьИтогиПоСтатусамДокументов();
	
	РезультатСоздания.ТекстОшибки = ОбщийТекстОшибки;
	
	Возврат РезультатСоздания;
	
КонецФункции
&НаСервере
Функция ПолучитьСсылку_ЗаполнениеДокумент(СтруктураЗаполненияДокумента,ДопПараметры,ТекстОшибки)
	
	КэшированныеЗначения = Новый Структура();
	КэшированныеЗначения.Вставить("КоэффициентыУпаковок",Новый Соответствие);
	КэшированныеЗначения.Вставить("ОбъемУпаковок",Новый Соответствие);
	КэшированныеЗначения.Вставить("ВесУпаковок",Новый Соответствие);
	
	ИдентификаторОбъединения = СтруктураЗаполненияДокумента.ИдентификаторОбъединения;
	
	ДанныеДокумента = СтруктураЗаполненияДокумента.document;
	ДанныеНоменклатуры = СтруктураЗаполненияДокумента.documentItems;
	
	ДокументИД = ДанныеДокумента.id;
	НаправлениеСоздаваемогоДокумента = ДанныеДокумента.НаправлениеСоздаваемогоДокумента;
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект"); //Для вызова функций модуля объекта
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		
	Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
		ОрганизацияСсылка = ДанныеДокумента.ПлательщикСсылка;
		КонтрагентСсылка = ДанныеДокумента.ПоставщикСсылка;
	Иначе
		ОрганизацияСсылка = ДанныеДокумента.ПоставщикСсылка;
		КонтрагентСсылка = ДанныеДокумента.ПлательщикСсылка;
	КонецЕсли;
	
	ТипСоздаваемогоДокумента = ДанныеДокумента.ТипСоздаваемогоДокумента;
	
	//2021.06.23 ( возникает кейс, когда ТипСоздаваемогоДокумента не заполнен или заполнен некорректно,
	//чтобы отловить эту ситуацию - выведем сообщение и зафиксируем в протоколе
	Попытка
		МенеджерОбъекта = Документы[ТипСоздаваемогоДокумента];
	Исключение
		ОписаниеСобытия = "- ошибка определения менеджера объекта типа [" + ТипСоздаваемогоДокумента
			+ "] создаваемого документа " + ДанныеДокумента.ПредставлениеДокумента + " [" + ДанныеДокумента.id + "], "
			+ "направление [" + ДанныеДокумента.Направление + "]: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
		ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
		
		Возврат Неопределено;
	КонецПопытки;
	// ) 2021.06.23
	
	МодульБухгалтерскийУчетПереопределяемый = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("БухгалтерскийУчетПереопределяемый");
	МодульОбработкаТабличнойЧастиКлиентСервер = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ОбработкаТабличнойЧастиКлиентСервер");
	
	ДокументОбъект = МенеджерОбъекта.СоздатьДокумент();
		
	//2019.03.25 ( модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("ДокументИД",ДокументИД);
	ПараметрыМК.Вставить("ДанныеДокумента",ДанныеДокумента);
	ПараметрыМК.Вставить("ДанныеНоменклатуры",ДанныеНоменклатуры);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	ПараметрыМК.Вставить("ТипСоздаваемогоДокумента",ТипСоздаваемогоДокумента);
	ПараметрыМК.Вставить("ДопПараметры",ДопПараметры);
	ПараметрыМК.Вставить("ДокументОбъект",ДокументОбъект);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	//Теперь данные документа есть в структуре заполнения документа, но оставляем их для обратной совместимости МК
	ПараметрыМК.Вставить("СтруктураЗаполненияДокумента",СтруктураЗаполненияДокумента);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередЗаполнениемШапки",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) 2019.03.25
			
		//Поиск связанных документов комплекта
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина
			И ЗначениеЗаполнено(СтруктураЗаполненияДокумента.document.parent) Тогда
			
			//Если у текущего документа есть parent, то используем его номер и дату
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
			СвязанныйДокумент = ДанныеПортала.documents.Найти(СтруктураЗаполненияДокумента.document.parent,"id");
						
			Если СвязанныйДокумент <> Неопределено Тогда
				
				//Связанный документ уже создали ранее
				Если ЗначениеЗаполнено(СвязанныйДокумент.ДокументСсылка) Тогда
					Возврат СвязанныйДокумент.ДокументСсылка;
				КонецЕсли;
				
				date = СвязанныйДокумент.date;
				number = СвязанныйДокумент.number;
				СвязанныйДокументИД = СвязанныйДокумент.id;
			Иначе
				date = ДанныеДокумента.date;
				number = ДанныеДокумента.number;
			КонецЕсли;
		Иначе
			date = ДанныеДокумента.date;
			number = ДанныеДокумента.number;
		КонецЕсли;
		
		//2019.12.10 ( Попробуем получить номер и дату дочернего документа текущего, в старых УТ11 номер и дату счета-фактуры можно указать
		// в реквизитах НомерСчетаФактуры и ДатаСчетаФактуры документа ПоступлениеТоваровУслуг
		childDate = ДанныеДокумента.date;
		childNumber = ДанныеДокумента.number;
		
		Если ЗначениеЗаполнено(СтруктураЗаполненияДокумента.document.children) Тогда
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
			СвязанныйДочернийДокумент = ДанныеПортала.documents.Найти(СтруктураЗаполненияДокумента.document.children,"id");
			
			Если СвязанныйДочернийДокумент <> Неопределено Тогда
				childDate = СвязанныйДочернийДокумент.date;
				childNumber = СвязанныйДочернийДокумент.number;
			КонецЕсли;
		КонецЕсли;
		// ) 2019.12.10
		
		СтруктураЗаполненияДокумента.Вставить("childNumber",childNumber);
		СтруктураЗаполненияДокумента.Вставить("childDate",childDate);
		
		//E1C-503, 2025.08.11: Для распознанного типа документа ЭСФ для заполнения в ПТиУ "Вх номер" = значение берется из deliveryDocNum,
		//Вх. дата = значение берется из deliveryDocDate.
		Если ЗначениеЗаполнено(ДанныеДокумента.esfKzDeliveryDocNum)
			И ЗначениеЗаполнено(ДанныеДокумента.esfKzDeliveryDocDate) Тогда
			number = ДанныеДокумента.esfKzDeliveryDocNum;
			date = ДанныеДокумента.esfKzDeliveryDocDate;
		КонецЕсли;
		
		СтруктураЗаполнения = Новый Структура;
		
		//Общие данные структуры шапки документа
		
		//E1C-208: при работе с комплектами для заполнения обоих документов используется только счет-фактура,
		//берем для основного документа дату, установленную пользователем в форме сопоставления
		ДатаДокумента = ДанныеДокумента.ДатаДокумента;		
		СтруктураЗаполнения.Вставить("Дата",?(ЗначениеЗаполнено(ДатаДокумента),ДатаДокумента,ТекущаяДата()));
		
		СтруктураЗаполнения.Вставить("ДатаВходящегоДокумента",date);
		СтруктураЗаполнения.Вставить("НомерВходящегоДокумента",number);
		
		//НомерВходящегоДокумента
		
		СтруктураЗаполнения.Вставить("НомерПоДаннымПоставщика",number);
		СтруктураЗаполнения.Вставить("ДатаПоДаннымПоставщика",date);
		
		// Добавлено для старых УТ11.1
		Если Конф = "УТ11" Тогда
			СтруктураЗаполнения.Вставить("ПредъявленСчетФактура",Истина);
			СтруктураЗаполнения.Вставить("НомерСчетаФактуры",childNumber);
			СтруктураЗаполнения.Вставить("ДатаСчетаФактуры",childDate);
		КонецЕсли;
				
		СтруктураЗаполнения.Вставить("НомерЭД",number);
		
		//БИТ.Строительство
		СтруктураЗаполнения.Вставить("ВходящийНомер",number);
		СтруктураЗаполнения.Вставить("ВходящаяДата",date);
				
		//БГУ2
		СтруктураЗаполнения.Вставить("ДатаПервичногоДокумента",date);
		СтруктураЗаполнения.Вставить("НомерПервичногоДокумента",number);
		СтруктураЗаполнения.Вставить("ВидПервичногоДокумента",ДанныеДокумента.ПредставлениеТипа);
		Если РеквизитСуществует("Перечисления","ВидыПоступленийМЗ","ПоступлениеОтПоставщика") Тогда
			СтруктураЗаполнения.Вставить("ВидПоступленияМЗ",Перечисления.ВидыПоступленийМЗ.ПоступлениеОтПоставщика);
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("Организация",ОрганизацияСсылка);
		СтруктураЗаполнения.Вставить("Контрагент",КонтрагентСсылка);
		СтруктураЗаполнения.Вставить("Партнер",ДанныеДокумента.ПартнерСсылка);
		СтруктураЗаполнения.Вставить("Договор",ДанныеДокумента.ДоговорСсылка);
		СтруктураЗаполнения.Вставить("ДоговорКонтрагента",ДанныеДокумента.ДоговорСсылка);
		
		//в УТ11 в некоторых документах Партнер изменен на реквизит Клиент с определяемым типом ПартнерБЭД
		Если ТипСоздаваемогоДокумента = "КоммерческоеПредложениеКлиенту" Тогда
			СтруктураЗаполнения.Вставить("Клиент",ДанныеДокумента.ПартнерСсылка);
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("БанковскийСчетКонтрагента",ДанныеДокумента.БанковскийСчетКонтрагентаСсылка);
		СтруктураЗаполнения.Вставить("БанковскийСчетПолучателя",ДанныеДокумента.БанковскийСчетКонтрагентаСсылка);
		СтруктураЗаполнения.Вставить("СчетКонтрагента",ДанныеДокумента.БанковскийСчетКонтрагентаСсылка);
		
		Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_БанковскийСчетОрганизацииПоУмолчанию) Тогда
			СтруктураЗаполнения.Вставить("БанковскийСчет",СтруктураНастроек.ЗаполнениеШапки_БанковскийСчетОрганизацииПоУмолчанию);
			СтруктураЗаполнения.Вставить("БанковскийСчетОрганизации",СтруктураНастроек.ЗаполнениеШапки_БанковскийСчетОрганизацииПоУмолчанию);
		КонецЕсли;
			
		СтруктураЗаполнения.Вставить("Склад",ДанныеДокумента.СкладСсылка);
		СтруктураЗаполнения.Вставить("СкладОрдер",ДанныеДокумента.СкладСсылка);
		СтруктураЗаполнения.Вставить("СкладОтправитель",ДанныеДокумента.СкладСсылка);
		СтруктураЗаполнения.Вставить("СкладПолучатель",ДанныеДокумента.СкладСсылка);
		
		//E1C-387: Перемещение ТМЗ (БП KAZ), Поступление от структурного подразделения
		Если Конф = "БП30" И СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
			СтруктураЗаполнения.Вставить("СтруктурноеПодразделениеОтправитель",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
			СтруктураЗаполнения.Вставить("СтруктурноеПодразделениеПолучатель",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
			
			Если ЗначениеЗаполнено(СтруктураЗаполненияДокумента.document.ВидОперацииСсылка)
				И СтруктураЗаполненияДокумента.document.ВидОперацииСсылка = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ОтСтруктурногоПодразделения Тогда
				СтруктураЗаполнения.Вставить("СтруктурноеПодразделение",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
			КонецЕсли;
		КонецЕсли;
		
		
		//E1C-266: УНФ: при заполнении документа получать пользовательское значение для заполнения склада "Шапка/табличная часть"
		Если Конф = "УНФ" Тогда
			
			Если РеквизитСуществует("Перечисления","ПоложениеРеквизитаНаФорме","ВТабличнойЧасти") Тогда
				МодульУправлениеНебольшойФирмойПовтИсп = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("УправлениеНебольшойФирмойПовтИсп");
				Если МодульУправлениеНебольшойФирмойПовтИсп <> Неопределено Тогда
					Попытка
						ПоложениеСклада_УНФ = МодульУправлениеНебольшойФирмойПовтИсп.ПолучитьЗначениеНастройки("ПоложениеСкладаВДокументахПоступления");
					Исключение
						//Не обрабатываем
					КонецПопытки;
				КонецЕсли;
				
				Если ПоложениеСклада_УНФ = Перечисления.ПоложениеРеквизитаНаФорме.ВТабличнойЧасти Тогда
					СтруктураЗаполнения.Вставить("ПоложениеСклада",ПоложениеСклада_УНФ);
				КонецЕсли;
			КонецЕсли;
			
			СтруктураЗаполнения.Вставить("СтруктурнаяЕдиница",ДанныеДокумента.СкладСсылка);
			
		КонецЕсли;
		
		//БГУ2
		СтруктураЗаполнения.Вставить("ЦМО",ДанныеДокумента.СкладСсылка);
				
		Если Конф = "БГУ2" Тогда
			Если ТипСоздаваемогоДокумента = "СчетНаОплату" Тогда
				СтруктураЗаполнения.Вставить("Плательщик",КонтрагентСсылка);
				СтруктураЗаполнения.Вставить("СчетПлательщика",ДанныеДокумента.БанковскийСчетКонтрагентаСсылка);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеДокумента.ИФОСсылка) Тогда
				СтруктураЗаполнения.Вставить("ИФО",ДанныеДокумента.ИФОСсылка);
			КонецЕсли;
			
			Если ТипСоздаваемогоДокумента = "РегистрацияОбязательствИСведенийПоДоговорам" Тогда
				Если ЗначениеЗаполнено(ДанныеДокумента.ДоговорСсылка)
					И ДанныеДокумента.ДоговорСсылка.УчетПредметаДоговора Тогда
					СтруктураЗаполнения.Вставить("ВидОбязательства",Перечисления.ВидыПринятыхОбязательств.ПринятоеОбязательствоУчетПредмета);
				Иначе
					СтруктураЗаполнения.Вставить("ВидОбязательства",Перечисления.ВидыПринятыхОбязательств.ПринятоеОбязательство);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		

		СтруктураЗаполнения.Вставить("Подразделение",ДанныеДокумента.ПодразделениеСсылка);
		СтруктураЗаполнения.Вставить("ПодразделениеОрганизации",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
		
		Если ТипСоздаваемогоДокумента = "ОтчетПроизводстваЗаСмену" Тогда
			СтруктураЗаполнения.Вставить("ПодразделениеЗатрат",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеДокумента.НоменклатурнаяГруппаСсылка) Тогда
			СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",ДанныеДокумента.НоменклатурнаяГруппаСсылка);
		КонецЕсли;
		
		//E1C-363: Направление деятельности для КА2
		Если ЗначениеЗаполнено(ДанныеДокумента.НаправлениеДеятельностиСсылка) Тогда
			НаправлениеДеятельностиСсылка = ДанныеДокумента.НаправлениеДеятельностиСсылка;
		Иначе
			//E1C-539: КА2 Заполнять реквизит "Направление деятельности" значением из Договора/Соглашение	
			Если Конф = "КА2" Тогда
				Если ЗначениеЗаполнено(ДанныеДокумента.СоглашениеСсылка) Тогда
					НаправлениеДеятельностиСсылка = ДанныеДокумента.СоглашениеСсылка.НаправлениеДеятельности;
				ИначеЕсли ЗначениеЗаполнено(ДанныеДокумента.ДоговорСсылка) Тогда
					НаправлениеДеятельностиСсылка = ДанныеДокумента.ДоговорСсылка.НаправлениеДеятельности;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("НаправлениеДеятельности",НаправлениеДеятельностиСсылка);
		
		//Статью заполняем/подменяем только если заполнена в настройках
		Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_СтатьяДДСПоУмолчанию) Тогда
			СтруктураЗаполнения.Вставить("СтатьяДвиженияДенежныхСредств",СтруктураНастроек.ЗаполнениеШапки_СтатьяДДСПоУмолчанию);
		КонецЕсли;
				
		//E1C-427: Объект расчетов для КА2
		Если ЗначениеЗаполнено(ДанныеДокумента.ОбъектРасчетовСсылка) Тогда
			СтруктураЗаполнения.Вставить("ОбъектРасчетов",ДанныеДокумента.ОбъектРасчетовСсылка);
			
			//E1C-440: Заполним статью ДДС значением из выбранного для документа "объекта расчетов"
			Если РеквизитСуществует("Перечисления","ТипыОбъектовРасчетов","Договор")
				И ДанныеДокумента.ОбъектРасчетовСсылка.ТипОбъектаРасчетов = Перечисления.ТипыОбъектовРасчетов.Договор Тогда
				СтруктураЗаполнения.Вставить("СтатьяДвиженияДенежныхСредств",ДанныеДокумента.ОбъектРасчетовСсылка.Договор.СтатьяДвиженияДенежныхСредств);
			КонецЕсли;
			
		КонецЕсли;
		
		ВалютаРегламентированногоУчета = СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета;
		КратностьВзаиморасчетов = 1;
		КурсВзаиморасчетов = 1;
		
		СтруктураЗаполнения.Вставить("Соглашение",ДанныеДокумента.СоглашениеСсылка);
				
		Если ЗначениеЗаполнено(ДанныеДокумента.ДоговорСсылка) Тогда
			
			//Если валюта есть в договоре - берем ее из него, если нет - валюта по умолчанию
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Договор_ИмяРеквизитаВалюта)
				И ЗначениеЗаполнено(ДанныеДокумента.ДоговорСсылка[СтруктураНастроек.СведенияОКонфигурации.Договор_ИмяРеквизитаВалюта]) Тогда
			
				Валюта = ДанныеДокумента.ДоговорСсылка[СтруктураНастроек.СведенияОКонфигурации.Договор_ИмяРеквизитаВалюта];
					
				Если Валюта <> ВалютаРегламентированногоУчета Тогда
					
					//2023.07.10 ( Бухгалтерия для Казахстана
					Если Конф = "БП30" И СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
						МодульОбщегоНазначенияБК = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ОбщегоНазначенияБК");
						Если МодульОбщегоНазначенияБК <> Неопределено Тогда
							СтруктураКурсаДокумента = МодульОбщегоНазначенияБК.ПолучитьКурсВалюты(Валюта,СтруктураЗаполнения.Дата);
							КратностьВзаиморасчетов = СтруктураКурсаДокумента.Кратность;
							КурсВзаиморасчетов = СтруктураКурсаДокумента.Курс;
						КонецЕсли;
						
					Иначе
					// ) 2023.07.10
					
						МодульРаботаСКурсамиВалют = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("РаботаСКурсамиВалют");
						Если МодульРаботаСКурсамиВалют <> Неопределено Тогда
							СтруктураКурсаДокумента = МодульРаботаСКурсамиВалют.ПолучитьКурсВалюты(Валюта,СтруктураЗаполнения.Дата);
							КратностьВзаиморасчетов = СтруктураКурсаДокумента.Кратность;
							КурсВзаиморасчетов = СтруктураКурсаДокумента.Курс;
							
						ИначеЕсли Метаданные.РегистрыСведений.Найти("КурсыВалют") <> Неопределено Тогда
							КурсКратность = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(СтруктураЗаполнения.Дата, Новый Структура("Валюта",Валюта));
							Если КурсКратность <> Неопределено Тогда
								КратностьВзаиморасчетов = КурсКратность.Кратность;
								КурсВзаиморасчетов = КурсКратность.Курс;
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
		
				КонецЕсли;
				
			Иначе
				Валюта = ВалютаРегламентированногоУчета;
			КонецЕсли;
			
			// 2020.10.07 ( начиная с релиза БП 3.0.83 данные СФ могут быть указаны в самом документе ПТиУ, в этом случае не требуется создание счета-фактуры
			// а реквизиты НомерВходящегоДокумента и ДатаВходящегоДокумента являются обязательными. Определим установку этого флага по реквизиту выбранного договора
			Если ДанныеДокумента.type = "UTD" И СтруктураНастроек.СведенияОКонфигурации.Договор_ИспользуютсяДанныеУПДВДокументе = Истина
				И ДанныеДокумента.ДоговорСсылка.СпособВыставленияДокументов = Перечисления.СпособыВыставленияДокументов.УниверсальныйДокумент Тогда
				СтруктураЗаполнения.Вставить("ЭтоУниверсальныйДокумент",Истина);
			КонецЕсли;
			// ) 2020.10.07
			
			//ГруппаФинансовогоУчета,СпособЗачетаПредоплатыПоУмолчанию
			СтруктураДляПереноса = Новый Структура("ГруппаФинансовогоУчета,СпособЗачетаПредоплатыПоУмолчанию");
			ЗаполнитьЗначенияСвойств(СтруктураДляПереноса,ДанныеДокумента.ДоговорСсылка);
			
			Если ЗначениеЗаполнено(СтруктураДляПереноса.ГруппаФинансовогоУчета) Тогда
				СтруктураЗаполнения.Вставить("ГруппаФинансовогоУчета",СтруктураДляПереноса.ГруппаФинансовогоУчета);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураДляПереноса.СпособЗачетаПредоплатыПоУмолчанию) Тогда
				СтруктураЗаполнения.Вставить("СпособЗачетаПредоплаты",СтруктураДляПереноса.СпособЗачетаПредоплатыПоУмолчанию);
			КонецЕсли;
			
		Иначе
			Валюта = ВалютаРегламентированногоУчета;
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("Валюта",Валюта);
		СтруктураЗаполнения.Вставить("ВалютаДокумента",Валюта);
		СтруктураЗаполнения.Вставить("ВалютаВзаиморасчетов",Валюта);
		СтруктураЗаполнения.Вставить("КратностьВзаиморасчетов", КратностьВзаиморасчетов);
		СтруктураЗаполнения.Вставить("КурсВзаиморасчетов", КурсВзаиморасчетов);
		
		СтруктураЗаполнения.Вставить("ОтражатьВУправленческомУчете", Истина);
		СтруктураЗаполнения.Вставить("ОтражатьВБухгалтерскомУчете", Истина);
		СтруктураЗаполнения.Вставить("ОтражатьВНалоговомУчете", Истина);
			
		УчитыватьНДС = ДанныеДокумента.УчитыватьНДС = Истина;
		СтруктураЗаполнения.Вставить("УчитыватьНДС",УчитыватьНДС);
		
		//2022.04.20 (
		СтруктураЗаполнения.Вставить("НДСНеВыделять",НЕ СтруктураНастроек.ЗаполнениеШапки_УчитыватьНДС);
		// ) 2022.04.20
		
		//2022.05.25 ( Для УНФ отображение НДС в документе определяем реквизитом НалогообложениеНДС
		Если Конф = "УНФ" Или Конф = "РОЗН3" Тогда
			Если СтруктураНастроек.ЗаполнениеШапки_УчитыватьНДС Тогда
				Если РеквизитСуществует("Перечисления","ТипыНалогообложенияНДС") Тогда
					СтруктураЗаполнения.Вставить("НалогообложениеНДС",Перечисления.ТипыНалогообложенияНДС.ОблагаетсяНДС);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// ) 2022.05.25
		
		//E1C-246: для RECEIPT считать, что документ, полученный от ОФД с данными чека всегда с СуммаВключаетНДС = Истина
		СуммаВключаетНДС = СтруктураНастроек.ЗаполнениеШапки_СуммаВключаетНДС = Истина Или ДанныеДокумента.type = "RECEIPT";
		
		СтруктураЗаполнения.Вставить("СуммаВключаетНДС",СуммаВключаетНДС);
		СтруктураЗаполнения.Вставить("ЦенаВключаетНДС",СуммаВключаетНДС);
		
		//E1C-218: по настройке устанавливаем значение флага НДСВключенВСтоимость
		Если СтруктураНастроек.Свойство("ЗаполнениеШапки_НДСВключенВСтоимость") Тогда
			Если СтруктураНастроек.ЗаполнениеШапки_НДСВключенВСтоимость = "Да" Тогда
				СтруктураЗаполнения.Вставить("НДСВключенВСтоимость",Истина);
			ИначеЕсли СтруктураНастроек.ЗаполнениеШапки_НДСВключенВСтоимость = "Нет" Тогда
				СтруктураЗаполнения.Вставить("НДСВключенВСтоимость",Ложь);
			КонецЕсли;
		КонецЕсли;
		
		//2023.09.07 ( для документа Поступление доп. расходов реквизит документа Сумма заполняется с/без НДС.
		//заполнение реквизита СуммаДокумента оставляем исходное. Возможно, следует дополнительно анализировать тип заполняемого документа.
		Если Не СуммаВключаетНДС Тогда
			СтруктураЗаполнения.Вставить("Сумма",ДанныеДокумента.amountWithoutVat);
		Иначе
		// ) 2023.09.07
			СтруктураЗаполнения.Вставить("Сумма",ДанныеДокумента.amount);
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("СуммаДокумента",ДанныеДокумента.amount);
		
		Если УчитыватьНДС Тогда
			СтруктураЗаполнения.Вставить("СуммаНДС",ДанныеДокумента.vat);
			СтруктураЗаполнения.Вставить("НДС",ДанныеДокумента.vat);
		КонецЕсли;
		
		//2019.12.10 ( Комментарий может содержать предопределенные параметры
		Комментарий = РеквизитОбъект.ЗаполнениеДокумента_СформироватьКомментарийСПараметрами(АдресХранилищаДанныхПортала,СтруктураЗаполненияДокумента,СтруктураНастроек);
		СтруктураЗаполнения.Вставить("Комментарий",Комментарий);
		// ) 2019.12.10
		
		//2019.12.14 ( заполняем реквизит документа Диадок_url
		СтруктураЗаполнения.Вставить("Энтера_Диадок_url",ДанныеДокумента.Диадок_url);
		// ) 2019.12.14
		
		Если РеквизитСуществует("Перечисления","ВидыПоступленияТоваров","НаСклад") Тогда
			СтруктураЗаполнения.Вставить("ВидПоступления",Перечисления.ВидыПоступленияТоваров.НаСклад);
		КонецЕсли;
		
		//E1C-196: Способ зачета авансов
		Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию) Тогда
			СтруктураЗаполнения.Вставить("СпособЗачетаАвансов",СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию);
		КонецЕсли;
							
		//E1C-178: Вид операции документа теперь может быть выбран пользователем для ряда документов в форме сопоставления
		ПользовательскийВидОперации = СтруктураЗаполненияДокумента.document.ВидОперацииСсылка;
		
		Если ЗначениеЗаполнено(ПользовательскийВидОперации) Тогда
			СтруктураЗаполнения.Вставить("ВидОперации",ПользовательскийВидОперации);
			СтруктураЗаполнения.Вставить("ХозяйственнаяОперация",ПользовательскийВидОперации);
			
		Иначе
			//Оставляем исходную логику
		
		//БП30: Сперва определим для документа общую форму
			Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
				Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ПокупкаКомиссия") Тогда
					СтруктураЗаполнения.Вставить("ВидОперации",Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПокупкаКомиссия);
				КонецЕсли;
			Иначе
				Если РеквизитСуществует("Перечисления","ВидыОперацийРеализацияТоваров","ПродажаКомиссия") Тогда
					СтруктураЗаполнения.Вставить("ВидОперации",Перечисления.ВидыОперацийРеализацияТоваров.ПродажаКомиссия);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		
		Если ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг" Тогда
			//E1C-375: Услуги аренды
			Если ЗначениеЗаполнено(ПользовательскийВидОперации)
				И РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","УслугиАренды")
				И ПользовательскийВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.УслугиАренды Тогда
				//Реквизит - булево, но выбор значения выполнен по аналогии с выбором его в форме документа 
				СтруктураЗаполнения.Вставить("ВедетсяУчетПредметовАренды",ДанныеДокумента.ВедетсяУчетПредметовАренды = 1);
			КонецЕсли;
		
		//E1C-234: Подотчетное лицо в АвансовыйОтчет, прочие реквизиты
		ИначеЕсли ТипСоздаваемогоДокумента = "АвансовыйОтчет" Тогда
			СтруктураЗаполнения.Вставить("ФизЛицо",ДанныеДокумента.ПодотчетноеЛицоСсылка);
			СтруктураЗаполнения.Вставить("Сотрудник",ДанныеДокумента.ПодотчетноеЛицоСсылка);
			СтруктураЗаполнения.Вставить("ПодотчетноеЛицо",ДанныеДокумента.ПодотчетноеЛицоСсылка);
			
			//E1C-394: Назначение аванса Командировка
			СтруктураЗаполнения.Вставить("НазначениеАванса",ДанныеДокумента.НазначениеАванса);
			
		//E1C-378: Физ лицо в Доверенность
		ИначеЕсли ТипСоздаваемогоДокумента = "Доверенность" Тогда
			СтруктураЗаполнения.Вставить("ФизЛицо",ДанныеДокумента.ПодотчетноеЛицоСсылка);
			
			//E1C-379: Формируем строку для реквизита ПоДокументу в формате:
			//"счету" *номер распознанного документа* от *дата распознанного документа*
			ПоДокументу = "счету " + number + " от " + Формат(date,"ДФ=dd.MM.yyyy");
			СтруктураЗаполнения.Вставить("ПоДокументу",ПоДокументу);
			
		ИначеЕсли ТипСоздаваемогоДокумента = "СчетФактураПолученный" Тогда
			
			Если Конф = "БП30" Тогда
				//E1C-477: Казахстан: 1С. БП 3.0 для КЗ. Работа с ЭСФ и Источником происхождения
				Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
					СтруктураЗаполнения.Вставить("Покупатель",ОрганизацияСсылка);
					СтруктураЗаполнения.Вставить("Поставщик",КонтрагентСсылка);
				Иначе				
					//E1C-509:
					//Заполнение документа в 1С: Поля номер, дата, контрагент, организация, табличная часть заполняются данными из распознанного документа.
					//Поле "Вид счет-фактуры" -  предзаполнено значением "На аванс"
					//Поле "Документ основание" - ручной выбор на этапе сопоставлении в дополнительном описании по полю Документ.
					//Основанием может быть "Списание с расчетного счета" или "выдача наличных".
					//Код вида операции - предзаполнено значением "02".
					СтруктураЗаполнения.Вставить("СтавкаНДС",ДанныеДокумента.СтавкаНДССсылка);
					СтруктураЗаполнения.Вставить("ДокументОснование",ДанныеДокумента.ДокументОснованиеСсылка);
					СтруктураЗаполнения.Вставить("ВидСчетаФактуры",Перечисления.ВидСчетаФактурыПолученного.НаАванс);
					СтруктураЗаполнения.Вставить("КодВидаОперации","02");
					
					СтрокаАвансы = ДокументОбъект.Авансы.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаАвансы,СтруктураЗаполнения);
					
					СтрокаДокументыОснования = ДокументОбъект.ДокументыОснования.Добавить();
					СтрокаДокументыОснования.ДокументОснование = ДанныеДокумента.ДокументОснованиеСсылка;
				КонецЕсли;
			КонецЕсли;
			
		//E1C-327: Для документа ОтчетКомиссионераОПродажах заполняем ТЧ Покупатели
		ИначеЕсли ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах"
			//2024.04.23 ( УНФ
			Или ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
			// ) 2024.04.23
			
			Если ДокументОбъект.Метаданные().ТабличныеЧасти.Найти("Покупатели") <> Неопределено Тогда
				ДокументОбъект.Покупатели.Очистить();
				НоваяСтрокаПокупатели = ДокументОбъект.Покупатели.Добавить();
				НоваяСтрокаПокупатели.Покупатель = КонтрагентСсылка;
			КонецЕсли;
			
		//E1C-310: УТ, КА, ERP
		ИначеЕсли ТипСоздаваемогоДокумента = "ПриобретениеТоваровУслуг"
			И ПользовательскийВидОперации = Перечисления.ХозяйственныеОперации.ЗакупкаЧерезПодотчетноеЛицо Тогда
			СтруктураЗаполнения.Вставить("ПодотчетноеЛицо",ДанныеДокумента.ПодотчетноеЛицоСсылка);
			
		ИначеЕсли ТипСоздаваемогоДокумента = "ОтчетОРозничныхПродажах" Тогда
			Если РеквизитСуществует("Перечисления","ВидыОперацийОтчетОРозничныхПродажах","ОтчетККМОПродажах") Тогда
				СтруктураЗаполнения.Вставить("ВидОперации",Перечисления.ВидыОперацийОтчетОРозничныхПродажах.ОтчетККМОПродажах);
			КонецЕсли;
			
			КассаККМ = Неопределено;
			
			Если Конф = "УТ11" Тогда					
				//Настройка ЗаполнениеШапки_КассаККМПоУмолчанию была удалена
				Если Не ЗначениеЗаполнено(КассаККМ) Тогда
					Попытка КассаККМ = Справочники.КассыККМ.АвтономнаяКассаККМПоУмолчанию(); Исключение; КонецПопытки;
				КонецЕсли;
				
				Если КассаККМ <> Неопределено Тогда
					СтруктураЗаполнения.Вставить("КассаККМ",КассаККМ);
				КонецЕсли;
				
			ИначеЕсли Конф = "УНФ" Тогда
				Если Не ЗначениеЗаполнено(КассаККМ) Тогда
					Попытка КассаККМ = Справочники.КассыККМ.ПолучитьКассуККМПоУмолчанию(); Исключение; КонецПопытки;
				КонецЕсли;
				
				Если КассаККМ <> Неопределено Тогда
					СтруктураЗаполнения.Вставить("КассаККМ",КассаККМ);
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ТипСоздаваемогоДокумента = "ВозвратТоваровОтПокупателя" Тогда
			СтруктураЗаполнения.Вставить("ПокупателюВыставляетсяКорректировочныйСчетФактура",Ложь);
			СтруктураЗаполнения.Вставить("ПокупателемВыставляетсяСчетФактураНаВозврат",Истина);
			
		ИначеЕсли ТипСоздаваемогоДокумента = "ПлатежноеПоручение"
						
			//2021.02.25 ( Добавили ЗаявкаНаРасходованиеДенежныхСредств, заполняем по аналогии с ППИ
			Или ТипСоздаваемогоДокумента = "ЗаявкаНаРасходованиеДенежныхСредств"
			// ) 2021.02.25
			
			//2021.06.22 (E1C-248: СписаниеБезналичныхДенежныхСредств, заполняем по аналогии с ППИ
			Или ТипСоздаваемогоДокумента = "СписаниеБезналичныхДенежныхСредств"
			// ) 2021.06.22
			
			//2022.04.20 ( ПриходныйКассовыйОрдер
			Или ТипСоздаваемогоДокумента = "ПриходныйКассовыйОрдер"
			// ) 2022.04.20
			
			//2024.09.15 ( ПлатежноеПоручениеИсходящее Далион
			Или ТипСоздаваемогоДокумента = "ПлатежноеПоручениеИсходящее" Тогда
			// ) 2024.09.15
			
			//E1C-527: Теперь ставку НДС берем определяем для шапки документа в модуле объекта при поиске ссылок
			СтавкаНДС = ДанныеДокумента.СтавкаНДССсылка;
							
			Если Не ЗначениеЗаполнено(СтавкаНДС) Тогда
				//Исходный вариант
				Попытка СуммаНДС = Число(ДанныеДокумента.vat); Исключение СуммаНДС = 0; КонецПопытки;
				Если СуммаНДС = 0 Тогда
					//Если сумма НДС документа 0 - значит СтавкаНДС = 0
					СтавкаНДС = СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС.БезНДС;
				Иначе
					//Берем из произвольной позиции документа
					Если СтруктураЗаполненияДокумента.documentItems.Количество() > 0 Тогда
						СтавкаНДС = СтруктураЗаполненияДокумента.documentItems[0].СтавкаНДССсылка;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			СтруктураЗаполнения.Вставить("СтавкаНДС",СтавкаНДС);
			
			СтруктураЗаполнения.Вставить("ВидПлатежа","Электронно");
			СтруктураЗаполнения.Вставить("ФормаОплатыБезналичная",Истина);
			
			//Теперь назначение платежа мог отредактировать пользователь в форме сопоставления
			СтруктураЗаполнения.Вставить("НазначениеПлатежа",ДанныеДокумента.НазначениеПлатежа);
			
			Если Конф = "Далион" Тогда
				СтруктураЗаполнения.Вставить("НазначениеПлатежаРучноеИзменение",Истина);
			КонецЕсли;
			
			//2022.02.01 ( Кроме УНФ пока никто не жаловался, заполним только для УНФ,
			//пока упрощенно, без перетаскивания из формы документа всех алгоритмов заполнения этих реквизитов
			Если Конф = "УНФ" Тогда
				СтруктураИННКПП = Новый Структура("ИНН,КПП");
				ЗаполнитьЗначенияСвойств(СтруктураИННКПП,КонтрагентСсылка);
				СтруктураЗаполнения.Вставить("ИННПолучателя",СтруктураИННКПП.ИНН);
				Если ЗначениеЗаполнено(СтруктураЗаполнения.СчетКонтрагента)
					И СтруктураЗаполнения.СчетКонтрагента.ВариантУказанияКПП = Перечисления.ВариантыУказанияКПП.ВоВсехПлатежныхПоручениях Тогда
					СтруктураЗаполнения.Вставить("КПППолучателя",СтруктураИННКПП.КПП);
				КонецЕсли;				
				СтруктураЗаполнения.Вставить("ТекстПолучателя",КонтрагентСсылка.НаименованиеПолное);				
				
				СтруктураИННКПП = Новый Структура("ИНН,КПП");
				ЗаполнитьЗначенияСвойств(СтруктураИННКПП,ОрганизацияСсылка);
				СтруктураЗаполнения.Вставить("ИННПлательщика",СтруктураИННКПП.ИНН);
				СтруктураЗаполнения.Вставить("КПППлательщика",СтруктураИННКПП.КПП);
				СтруктураЗаполнения.Вставить("ТекстПлательщика",ОрганизацияСсылка.НаименованиеПолное);
			КонецЕсли;
			// ) 2022.02.01
			
			//2020.10.23 ( УправлениеХолдингом при записи формирует сумму по итогу Суммы ТЧ РасшифровкаПлатежа
			Если ДокументОбъект.Метаданные().ТабличныеЧасти.Найти("РасшифровкаПлатежа") <> Неопределено Тогда
				
				СтруктураЗаполнения.Вставить("СуммаПлатежа",ДанныеДокумента.amount);
				
				Если ТипСоздаваемогоДокумента = "ЗаявкаНаРасходованиеДенежныхСредств"
					Или ТипСоздаваемогоДокумента = "СписаниеБезналичныхДенежныхСредств"
					Или ТипСоздаваемогоДокумента = "ПриходныйКассовыйОрдер"
					// Задача 344476: БП30.KAZ
					Или ТипСоздаваемогоДокумента = "ПлатежноеПоручениеИсходящее" Тогда
					
					СтруктураЗаполнения.Вставить("СуммаВзаиморасчетов",ДанныеДокумента.amount);
				КонецЕсли;
				
				НоваяСтрокаТЧРасшифровкаПлатежа = ДокументОбъект.РасшифровкаПлатежа.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаТЧРасшифровкаПлатежа,СтруктураЗаполнения);
			КонецЕсли;
			// ) 2020.10.23
			
			//Для списания БДС номер и дата входящего документа будут заполнены при загрузке банковской выписки
			Если ТипСоздаваемогоДокумента = "СписаниеБезналичныхДенежныхСредств" Тогда
				СтруктураЗаполнения.Вставить("НомерВходящегоДокумента",Неопределено);
				СтруктураЗаполнения.Вставить("ДатаВходящегоДокумента",Неопределено);
			КонецЕсли;
			
			//2022.02.19 ( ИдентификаторПлатежа
			СтруктураЗаполнения.Вставить("ИдентификаторПлатежа",ДанныеДокумента.paymentOrderId);
			// ) 2022.02.19
			
			//2022.04.20 ( СпособПогашенияЗадолженности для ПКО
			Если РеквизитСуществует("Перечисления","СпособыПогашенияЗадолженности","Автоматически") Тогда
				СтруктураЗаполнения.Вставить("СпособПогашенияЗадолженности",Перечисления.СпособыПогашенияЗадолженности.Автоматически);
			КонецЕсли;
			// ) 2022.04.20
			
		КонецЕсли;
		
		
		//2019.08.26 ( Отраслевые БИТ-решения на базе типовых
		Если ТипСоздаваемогоДокумента = "бит_ЗаявкаНаРасходованиеСредств"
			Или ТипСоздаваемогоДокумента = "бит_кзн_ЗаявкаНаРасходованиеСредств" Тогда
			
			СтруктураЗаполнения.Вставить("КурсДокумента",1);
			СтруктураЗаполнения.Вставить("КратностьДокумента",1);
			
			//Ставку НДС определим по первой строке товаров
			Если ДанныеНоменклатуры.Количество() > 0 Тогда
				СтавкаНДССсылка = ДанныеНоменклатуры[0].СтавкаНДССсылка;
				СтруктураЗаполнения.Вставить("СтавкаНДС",СтавкаНДССсылка);
			КонецЕсли;
			
			//Назначение платежа - "Оплата по счёту № {распознанный номер} от {распознанная дата}. В т.ч. НДС {распознанные данные}"
			НазначениеПлатежа = "Оплата по счёту №" + number + " от " + Формат(date,"ДФ=dd.MM.yyyy") + ". ";
			Если ЗначениеЗаполнено(СтавкаНДССсылка) Тогда
				НазначениеПлатежа = НазначениеПлатежа + "В т.ч. НДС (" + СтавкаНДССсылка + ") " + ДанныеДокумента.vat;
			Иначе
				НазначениеПлатежа = НазначениеПлатежа + "Без НДС";
			КонецЕсли;
			
			СтруктураЗаполнения.Вставить("НазначениеПлатежа",НазначениеПлатежа);
			СтруктураЗаполнения.Вставить("НазначениеПлатежаУпр",НазначениеПлатежа);
			
			//Хозяйственная операция 
			Если РеквизитСуществует("Справочники","бит_ХозяйственныеОперации") Тогда
				СтруктураЗаполнения.Вставить("ХозяйственнаяОперация",Справочники.бит_ХозяйственныеОперации.НайтиПоНаименованию("Оплата поставщику",Истина));
			КонецЕсли;
			
			//Форма оплаты
			Если РеквизитСуществует("Перечисления","бит_ВидыДенежныхСредств","Безналичные") Тогда
				СтруктураЗаполнения.Вставить("ФормаОплаты",Перечисления.бит_ВидыДенежныхСредств.Безналичные);
			КонецЕсли;
			
			//Вид плана
			Если РеквизитСуществует("Перечисления","бит_кзн_ВидыПланов","План") Тогда
				СтруктураЗаполнения.Вставить("ВидПлана",Перечисления.бит_кзн_ВидыПланов.План);
			КонецЕсли;
			
			//Важность
			Если РеквизитСуществует("Перечисления","бит_Важность","Средняя") Тогда
				СтруктураЗаполнения.Вставить("Важность",Перечисления.бит_Важность.Средняя);
			КонецЕсли;
			
		ИначеЕсли ТипСоздаваемогоДокумента = "бит_стр_ЗаказПоставщику" Тогда
			
			//Условие поставки
			Если РеквизитСуществует("Перечисления","бит_стр_ВидыУсловийДоставки","Самовывоз") Тогда
				СтруктураЗаполнения.Вставить("УсловиеДоставки",Перечисления.бит_стр_ВидыУсловийДоставки.Самовывоз);
			КонецЕсли;			
			
		ИначеЕсли ТипСоздаваемогоДокумента = "бит_стр_ЗаявкаНаМПЗ" Тогда
			
			//Вид операции
			Если РеквизитСуществует("Перечисления","бит_стр_ВидыОперацийЗаявкаНаМПЗ","НаСклад") Тогда
				СтруктураЗаполнения.Вставить("ВидОперации",Перечисления.бит_стр_ВидыОперацийЗаявкаНаМПЗ.НаСклад);
			КонецЕсли;			
			
		ИначеЕсли ТипСоздаваемогоДокумента = "бит_стр_ПриходныйОрдер" Тогда
			
			//Вид операции
			Если РеквизитСуществует("Перечисления","бит_стр_ВидыОперацииПриходныйОрдер","ОтПоставщика") Тогда
				СтруктураЗаполнения.Вставить("ВидОперации",Перечисления.бит_стр_ВидыОперацииПриходныйОрдер.ОтПоставщика);
			КонецЕсли;
			
		КонецЕсли;
		// ) 2019.08.26
		
		//E1C-193: настройка Виды/Типы цен по умолчанию
		Если НаправлениеСоздаваемогоДокумента = "Входящий"
			И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныВходящихДокументов) Тогда
			СтруктураЗаполнения.Вставить("ВидЦен",СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныВходящихДокументов);
			СтруктураЗаполнения.Вставить("ТипЦен",СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныВходящихДокументов);
		ИначеЕсли НаправлениеСоздаваемогоДокумента = "Исходящий"
			И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныИсходящихДокументов) Тогда
			СтруктураЗаполнения.Вставить("ВидЦен",СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныИсходящихДокументов);
			СтруктураЗаполнения.Вставить("ТипЦен",СтруктураНастроек.ЗаполнениеШапки_ВидТипЦеныИсходящихДокументов);
		Иначе
			СтруктураЗаполнения.Вставить("ВидЦен");
			СтруктураЗаполнения.Вставить("ТипЦен");
		КонецЕсли;
		
		//E1C-228: УТ11: в некоторых случаях при заполнении не инициализируется значение ВариантПриемкиТоваров
		МодульЗакупкиСервер = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ЗакупкиСервер");
		Если МодульЗакупкиСервер <> Неопределено Тогда
			Попытка
				ВариантПриемкиТоваров = МодульЗакупкиСервер.ПолучитьВариантПриемкиТоваров(,ДанныеДокумента.ДоговорСсылка);
				Если ЗначениеЗаполнено(ВариантПриемкиТоваров) Тогда
					СтруктураЗаполнения.Вставить("ВариантПриемкиТоваров",ВариантПриемкиТоваров);
				КонецЕсли;
			Исключение
				// не обрабатываем это исключение
			КонецПопытки;
		КонецЕсли;
		
		//То же самое у одного клиента касается реквизита СпособДоставки, заполняется пустым значением
		//попробуем принудительно заполнить значением из Значения заполнения реквизита документа
		Если ДокументОбъект.Метаданные().Реквизиты.Найти("СпособДоставки") <> Неопределено
			И ЗначениеЗаполнено(ДокументОбъект.Метаданные().Реквизиты.СпособДоставки.ЗначениеЗаполнения) Тогда
			СтруктураЗаполнения.Вставить("СпособДоставки",ДокументОбъект.Метаданные().Реквизиты.СпособДоставки.ЗначениеЗаполнения);
		КонецЕсли;
		// ) E1C-228
		
		//E1C-308: Для типа документа ПоступлениеДопРасходов из формы сопоставления
		//может быть передан список документов Поступления для заполнения ПоступленияДопРасходов
		Если ТипСоздаваемогоДокумента = "ПоступлениеДопРасходов"
			И ЗначениеЗаполнено(ДанныеДокумента.ДокументыПоступленияДляДопРасходов) Тогда
			СписокДокументовПоступления = ЗначениеИзСтрокиВнутр(ДанныеДокумента.ДокументыПоступленияДляДопРасходов);
			
			СодержаниеУслуги = Новый Структура("Содержание,СтавкаНДС");
			СодержаниеУслуги.Содержание = ДанныеДокумента.СодержаниеУслугиДляДопРасходов;
			Если ДанныеНоменклатуры.Количество() > 0 Тогда
				СодержаниеУслуги.СтавкаНДС = ДанныеНоменклатуры[0].СтавкаНДССсылка;
			КонецЕсли;
			
			ДокументОбъект = ДопРасходы_ЗаполнитьДокументПоСпискуОснований(СписокДокументовПоступления,СодержаниеУслуги,СтруктураЗаполнения,ПараметрыМК,ТекстОшибки);
			
		Иначе
			ЗаполнитьЗначенияСвойств(ДокументОбъект,СтруктураЗаполнения);
			
			//При заполнении может возникнуть исключение
			Попытка	ДокументОбъект.Заполнить(СтруктураЗаполнения); Исключение; КонецПопытки;
			
			ЗаполнитьЗначенияСвойств(ДокументОбъект,СтруктураЗаполнения);
			
		КонецЕсли;
		
		//Комплексная автоматизация, ERP
		Если Конф = "КА2" Или Конф = "ERP" Тогда
			
			Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
				МодульУчетНДСУП = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("УчетНДСУП");
		
				Если МодульУчетНДСУП <> Неопределено Тогда
					Попытка
						ПараметрыЗаполнения = Документы[ТипСоздаваемогоДокумента].ПараметрыЗаполненияВидаДеятельностиНДС(ДокументОбъект);
						МодульУчетНДСУП.ЗаполнитьВидДеятельностиНДС(ДокументОбъект.ЗакупкаПодДеятельность, ПараметрыЗаполнения);
					Исключение
						// не обрабатываем это исключение
					КонецПопытки;
				КонецЕсли;
				
				Если ТипСоздаваемогоДокумента = "ОтчетОРозничныхПродажах" Тогда
					Попытка	ПартнерРозничныйПокупатель = Справочники.Партнеры.РозничныйПокупатель; Исключение; КонецПопытки;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		//Управление торговлей 11
		Если Конф = "УТ11"
			//Добавим КА2 и ERP
			Или Конф = "КА2" Или Конф = "ERP" Тогда
			
			МодульУчетНДСУП = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("УчетНДСУП");
			
			//Обрабатываем заполнение условий продаж/закупок в зависимости от типа документа
			Если ТипСоздаваемогоДокумента = "ЗаказКлиента" Тогда
				
				Если Не ЗначениеЗаполнено(ДокументОбъект.ХозяйственнаяОперация)
					И РеквизитСуществует("Перечисления","ХозяйственныеОперации","РеализацияКлиенту") Тогда
						ДокументОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
				КонецЕсли;
								
				Попытка
