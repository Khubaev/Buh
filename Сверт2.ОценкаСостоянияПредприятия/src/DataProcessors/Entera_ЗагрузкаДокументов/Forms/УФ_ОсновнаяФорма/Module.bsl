&НаКлиенте
Функция ВыполнитьЗапрос(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса = Неопределено,ПараметрыЗапроса = Неопределено) Экспорт
		
	Если ПараметрыЗапроса = Неопределено Тогда
		ПараметрыЗапроса = Новый Структура;
	КонецЕсли;
	
	ПараметрыЗапроса.Вставить("Токен",Токен);
	ПараметрыЗапроса.Вставить("Назначение",Назначение);
	ПараметрыЗапроса.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыЗапроса.Вставить("ТестовыйРежим",Отладка_ТестовыйРежим);
		
	//Для аудитора Fresh: в процедуре ПриСозданииНаСервере определяется работа обработки в режиме расширения, в этом случае
	//используется выполнение HTTP-запросов на сервере с применением разрешений использования внешних ресурсов,
	//установленных при подключении данного расширения к базе 1с: флаг ЭтоРасширениеКонфигурации. Таким образом разрешения
	//для использования внешних ресурсов были запрошены и установлены на этапе подключения расширения к базе 1с, с клиента
	//соединения с внешними ресурсами не устанавливаются.
	
	Если ЭтоРасширениеКонфигурации Или ЭтоВебКлиент Или СтруктураНастроек.СистемныеНастройки_УстанавливатьСоединениеССервера = Истина Тогда
		РезультатЗапроса = ВыполнитьЗапросНаСервере(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса,ПараметрыЗапроса);
	Иначе
		РезультатЗапроса = ВыполнитьЗапросНаКлиенте(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса,ПараметрыЗапроса);
	КонецЕсли;
	
	Если РезультатЗапроса.Успешно Тогда
		РезультатЗапроса = ОбработатьРезультатЗапроса(Назначение,ПараметрыЗапроса,РезультатЗапроса.ПараметрыОтвета);
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции
&НаКлиенте
Функция ВыполнитьЗапросНаКлиенте(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса,ПараметрыЗапроса)
	
#Если Не ВебКлиент Тогда
	
	РезультатЗапроса = Новый Структура("Успешно,ТекстОшибки");
	Успешно = Ложь;
	
	Если ПараметрыЗапроса.Свойство("АдресСервера") Тогда
		АдресСервера = ПараметрыЗапроса.АдресСервера;
		
	ИначеЕсли Назначение = "Авторизация"
		Или Назначение = "ПодтверждениеТелефона"
		Или Назначение = "ПодтверждениеТелефонаКод" Тогда
		АдресСервера = СтруктураПодключения.АдресСервераАвторизации;
		
	Иначе
		АдресСервера = СтруктураПодключения.Адрес;
		
	КонецЕсли;
	
	МетодAPI = СтрЗаменить(МетодAPI,Символы.НПП,"");
	
	//Аутентификация при установке соединения
	Если ПараметрыЗапроса.Свойство("АутентификацияИмяПользователя") Тогда
		АутентификацияИмяПользователя = ПараметрыЗапроса.АутентификацияИмяПользователя;
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("АутентификацияПароль") Тогда
		АутентификацияПароль = ПараметрыЗапроса.АутентификацияПароль;
	КонецЕсли;
	
	Таймаут = 120;
	
	Если СтруктураНастроек.Свойство("СистемныеНастройки_СоединениеАутентификацияОС")
		И СтруктураНастроек.СистемныеНастройки_СоединениеАутентификацияОС = Истина Тогда
		//доступно начиная с 8.3.7
		Соединение = Новый HTTPСоединение(АдресСервера, СтруктураПодключения.Порт,АутентификацияИмяПользователя ,АутентификацияПароль , , Таймаут, СтруктураПодключения.SSL, Истина);
	Иначе
		Соединение = Новый HTTPСоединение(АдресСервера, СтруктураПодключения.Порт,АутентификацияИмяПользователя ,АутентификацияПароль , , Таймаут, СтруктураПодключения.SSL);
	КонецЕсли;
				
	//Заголовки запроса
	ЗаголовкиHTTP = Новый Соответствие();
	
	//Авторизация по токену
	ЗаголовкиHTTP.Вставить("Cookie", СтруктураПодключения.Токен_Cookie + ПараметрыЗапроса.Токен);
	
	Если ТипЗапроса = "POST" Или ТипЗапроса = "PUT" Или ТипЗапроса = "PATCH" Тогда
		ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("ДопЗаголовки") Тогда
		Для Каждого Элемент Из ПараметрыЗапроса.ДопЗаголовки Цикл
			ЗаголовкиHTTP.Вставить(Элемент.Ключ, Элемент.Значение);
		КонецЦикла;
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("ФайлыДляПередачи") Тогда //отправка будет выполняться методом multiple
		
		Boundary = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
		
		ИмяФайлаОтправки = ПолучитьИмяВременногоФайла("txt");
		
		МассивВременныхФайлов = Новый Массив;
		
		ИмяФайла_Начало = ПолучитьИмяВременногоФайла("txt"); 
		ЗаписьТекста_Начало = Новый ЗаписьТекста(ИмяФайла_Начало, "CESU-8", Символы.ПС, Ложь); 
		ЗаписьТекста_Начало.ЗаписатьСтроку("");
		ЗаписьТекста_Начало.Закрыть();
		МассивВременныхФайлов.Добавить(ИмяФайла_Начало);
		
		СтрокаИменОтправляемыхФайлов = "";
		
		Для Каждого ЭлементМассиваФайлов Из ПараметрыЗапроса.ФайлыДляПередачи Цикл
			
			Индекс = "file" + (ПараметрыЗапроса.ФайлыДляПередачи.Найти(ЭлементМассиваФайлов) + 1);
			
			ФайлДляПередачи = ЭлементМассиваФайлов.ПолноеИмяФайлаНаКлиенте;
			
			Файл = Новый Файл(ФайлДляПередачи);		
															
			ИмяФайла_НачалоФайла = ПолучитьИмяВременногоФайла("txt"); 
					
			ФайлОтправкиНачало = Новый ЗаписьТекста(ИмяФайла_НачалоФайла, "CESU-8", Символы.ПС, Ложь); 
			
			//Определяем раздел двоичных данных
			ФайлОтправкиНачало.ЗаписатьСтроку("");
			ФайлОтправкиНачало.ЗаписатьСтроку("--" + Boundary); 
			ФайлОтправкиНачало.ЗаписатьСтроку("Content-Disposition: form-data; name=""" + Индекс + """; filename=""" + ЭлементМассиваФайлов.ИмяФайла + """"); 
			ФайлОтправкиНачало.ЗаписатьСтроку(""); 
			ФайлОтправкиНачало.Закрыть(); 

			МассивВременныхФайлов.Добавить(ИмяФайла_НачалоФайла); 
			МассивВременныхФайлов.Добавить(ФайлДляПередачи); 
			
			СтрокаИменОтправляемыхФайлов = СтрокаИменОтправляемыхФайлов + ?(СтрокаИменОтправляемыхФайлов <> "",", ","") + ЭлементМассиваФайлов.ИмяФайла;
			
		КонецЦикла;
		
		//Формируем конечный фрагмент файла POST-запроса 
		ИмяФайлаОтправкиКонец = ПолучитьИмяВременногоФайла("txt"); 
		ФайлОтправкиКонец = Новый ЗаписьТекста(ИмяФайлаОтправкиКонец, "CESU-8", Символы.ПС, Ложь); 
		
		//Завершение раздела двоичных данных
		ФайлОтправкиКонец.ЗаписатьСтроку(Символы.ПС + "--" + Boundary + "--");
		ФайлОтправкиКонец.Закрыть(); 

		МассивВременныхФайлов.Добавить(ИмяФайлаОтправкиКонец); 

		//Теперь сформированные фрагменты сообщения для сервера объединяем в один файл POST-запроса 
		ОбъединитьФайлы(МассивВременныхФайлов, ИмяФайлаОтправки); 
		
		//После выполнения запроса файлы массива будут удалены
		МассивВременныхФайлов.Добавить(ИмяФайлаОтправки);
		//Поэтому сами отправляемые файлы теперь удаляем из массива
		Для Каждого ЭлементМассиваФайлов Из ПараметрыЗапроса.ФайлыДляПередачи Цикл
			МассивВременныхФайлов.Удалить(МассивВременныхФайлов.Найти(ЭлементМассиваФайлов.ПолноеИмяФайлаНаКлиенте));
		КонецЦикла;

		ЗаголовкиHTTP.Вставить("Content-Type", "multipart/form-data; boundary=" + Boundary); 
		
		Запрос = Новый HTTPЗапрос(МетодAPI,ЗаголовкиHTTP);
		Запрос.УстановитьИмяФайлаТела(ИмяФайлаОтправки);
		
		ОписаниеЗапроса = ТипЗапроса + " " + МетодAPI + " " + СтрокаИменОтправляемыхФайлов;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
					
		Попытка
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
			Успешно = Истина;
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
		КонецПопытки;
		
		Для Каждого Файл ИЗ МассивВременныхФайлов Цикл
			ПараметрыВызова = Новый Структура("Обработчик,УдаляемыйФайл","Заглушка_ОписаниеОповещения",Файл);
			_ЗФ_ОбработатьАсинхронныйВызов("УдалитьФайлы",ПараметрыВызова);
		КонецЦикла;
		
	ИначеЕсли ПараметрыЗапроса.Свойство("ФайлДляПередачи") Тогда
		
		МассивВременныхФайлов = Новый Массив;
		
		ФайлДляОтправки = ПараметрыЗапроса.ФайлДляПередачи.ПолноеИмяФайлаНаКлиенте;
		
		Файл = Новый Файл(ФайлДляОтправки);		
											
		Boundary = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
		
		ИмяФайлаОтправки = ПолучитьИмяВременногоФайла("txt");
		ИмяФайлаОтправкиНачало = ПолучитьИмяВременногоФайла("txt"); 
				
		ФайлОтправкиНачало = Новый ЗаписьТекста(ИмяФайлаОтправкиНачало, КодировкаТекста.UTF8, Символы.ПС, Ложь); 
		
		//Определяем раздел двоичных данных
		ФайлОтправкиНачало.ЗаписатьСтроку("");
		ФайлОтправкиНачало.ЗаписатьСтроку("");
		ФайлОтправкиНачало.ЗаписатьСтроку("--" + Boundary); 
		ФайлОтправкиНачало.ЗаписатьСтроку("Content-Disposition: form-data; name=""file""; filename=""" + ПараметрыЗапроса.ФайлДляПередачи.ИмяФайла + """"); 
		ФайлОтправкиНачало.ЗаписатьСтроку(""); 
		ФайлОтправкиНачало.Закрыть(); 

		МассивВременныхФайлов.Добавить(ИмяФайлаОтправкиНачало); 
		МассивВременныхФайлов.Добавить(ФайлДляОтправки); 

		//Формируем конечный фрагмент файла POST-запроса 
		ИмяФайлаОтправкиКонец = ПолучитьИмяВременногоФайла("txt"); 
		ФайлОтправкиКонец = Новый ЗаписьТекста(ИмяФайлаОтправкиКонец, КодировкаТекста.UTF8, Символы.ПС, Ложь); 

		//Завершение раздела двоичных данных 
		ФайлОтправкиКонец.ЗаписатьСтроку(Символы.ПС + "--" + Boundary + "--");
		ФайлОтправкиКонец.Закрыть(); 

		МассивВременныхФайлов.Добавить(ИмяФайлаОтправкиКонец); 

		//Теперь сформированные фрагменты сообщения для сервера объединяем в один файл POST-запроса 
		ОбъединитьФайлы(МассивВременныхФайлов, ИмяФайлаОтправки); 
		
		//После выполнения запроса файлы массива будут удалены
		МассивВременныхФайлов.Добавить(ИмяФайлаОтправки);
		//Поэтому сам отправляемый файл теперь удаляем из массива
		МассивВременныхФайлов.Удалить(МассивВременныхФайлов.Найти(ФайлДляОтправки));

		ЗаголовкиHTTP.Вставить("Content-Type", "multipart/form-data; boundary=" + Boundary); 
		
		Запрос = Новый HTTPЗапрос(МетодAPI,ЗаголовкиHTTP);
		Запрос.УстановитьИмяФайлаТела(ИмяФайлаОтправки);
		
		ОписаниеЗапроса = ТипЗапроса + " " + МетодAPI + " " + ПараметрыЗапроса.ФайлДляПередачи.ИмяФайла;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
		
		Попытка
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
			Успешно = Истина;
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
		КонецПопытки;
		
		Для Каждого Файл ИЗ МассивВременныхФайлов Цикл
			ПараметрыВызова = Новый Структура("Обработчик,УдаляемыйФайл","Заглушка_ОписаниеОповещения",Файл);
			_ЗФ_ОбработатьАсинхронныйВызов("УдалитьФайлы",ПараметрыВызова);
		КонецЦикла;
		
	Иначе
		
		Запрос = Новый HTTPЗапрос(МетодAPI, ЗаголовкиHTTP);
		
		Запрос.УстановитьТелоИзСтроки(ТелоЗапроса);
		
		ОписаниеЗапроса = ТипЗапроса + " " + МетодAPI + " " + ?(Назначение = "Авторизация","{*** данные скрыты ***}",ТелоЗапроса);
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
		
		Если ТипЗапроса = "GET" Тогда
			
			Попытка				
				Ответ = Соединение.Получить(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		ИначеЕсли ТипЗапроса = "PUT" Тогда
			
			Попытка
				Ответ = Соединение.Записать(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		ИначеЕсли ТипЗапроса = "PATCH" Тогда
			
			Попытка
				Ответ = Соединение.Изменить(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		ИначеЕсли ТипЗапроса = "DELETE" Тогда
			
			Попытка
				Ответ = Соединение.Удалить(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		Иначе //POST
			Попытка
				Ответ = Соединение.ОтправитьДляОбработки(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
		
	Если Успешно Тогда
				
		ПараметрыОтвета = Новый Структура("МетодAPI,КодСостояния,ТипСодержимого,ContentDisposition,Cookie,ТелоОтветаСтрока,ТелоОтветаДвоичныеДанные");
		ПараметрыОтвета.МетодAPI = МетодAPI;
		ПараметрыОтвета.КодСостояния = Ответ.КодСостояния;
		ПараметрыОтвета.ТипСодержимого = Ответ.Заголовки.Получить("Content-Type");
		ПараметрыОтвета.ContentDisposition = Ответ.Заголовки.Получить("Content-Disposition");
		ПараметрыОтвета.Cookie = Ответ.Заголовки.Получить("Set-Cookie");
				
		Если ПараметрыЗапроса.Свойство("ЗапросФайла") Тогда 
			
			//разберем xml, возможно, там текст ошибки
			Если ПараметрыОтвета.ТипСодержимого = "text/xml" Тогда
				ПараметрыОтвета.ТелоОтветаСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
			КонецЕсли;
			
			ПараметрыОтвета.ТелоОтветаДвоичныеДанные = ПоместитьВоВременноеХранилище(Ответ.ПолучитьТелоКакДвоичныеДанные(),УникальныйИдентификатор);
			
		Иначе
			ПараметрыОтвета.ТелоОтветаСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
			
		КонецЕсли;
		
		ОписаниеЗапроса = "[" + ПараметрыОтвета.КодСостояния + "]: " + ПараметрыОтвета.ТипСодержимого
			+ ?(ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаСтрока),Символы.ПС + ПараметрыОтвета.ТелоОтветаСтрока,"")
			+ ?(ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаДвоичныеДанные),Символы.ПС + ПараметрыОтвета.ТелоОтветаДвоичныеДанные,"");
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
		
		ОбработатьОтветПортала(ПараметрыЗапроса,ПараметрыОтвета,РезультатЗапроса);
		РезультатЗапроса.Вставить("ПараметрыОтвета",ПараметрыОтвета);
		
	Иначе
		РезультатЗапроса.Вставить("Успешно",Ложь);
		РезультатЗапроса.Вставить("ТекстОшибки",ТекстОшибки);
		
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
	КонецЕсли;
		
	Возврат РезультатЗапроса;
	
#КонецЕсли

КонецФункции
&НаСервере
Функция ВыполнитьЗапросНаСервере(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса,ПараметрыЗапроса)
		
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РезультатЗапроса = РеквизитОбъект.ВыполнитьЗапрос(Назначение,ТипЗапроса,МетодAPI,ТелоЗапроса,ПараметрыЗапроса);
	
	Возврат РезультатЗапроса;
КонецФункции

&НаСервере
Функция ОбработатьОтветПортала(ПараметрыЗапроса,ПараметрыОтвета,РезультатЗапроса)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РеквизитОбъект.ОбработатьОтветПортала(ПараметрыЗапроса,ПараметрыОтвета,РезультатЗапроса);
КонецФункции
&НаСервере
Функция ОбработатьРезультатЗапроса(Назначение,ПараметрыЗапроса,ПараметрыОтвета)
	
	РезультатОбработки = Новый Структура("Успешно,ТекстОшибки",Истина);	
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РезультатЧтения = РеквизитОбъект.ПрочитатьОтветПортала(Назначение,ПараметрыЗапроса,ПараметрыОтвета);
	
	Если РезультатЧтения.Успешно Тогда
	
		Если Назначение = "Авторизация" Тогда //Не требуется обработка ответа
			РезультатОбработки.Вставить("Токен",РезультатЧтения.Токен);
						
			СохранитьПоследнююЗапущеннуюВерсиюМодуля(РеквизитОбъект.ВерсияМодуля.Версия);
			
		ИначеЕсли Назначение = "ПодтверждениеТелефонаКод" Тогда //Не требуется обработка ответа
			Если РезультатЧтения.Свойство("Токен") Тогда
				//Успешно получили новую куку для выполнения дальнейших запросов
				РезультатОбработки.Вставить("Токен",РезультатЧтения.Токен);
			Иначе
				РезультатОбработки.Успешно = Ложь;
				РезультатОбработки.ТекстОшибки = "Не удалось подтвердить номер телефона";
			КонецЕсли;
						
		ИначеЕсли Назначение = "ДанныеПользователя" Тогда
			ДанныеПользователя = РеквизитОбъект.ПрочитатьДанныеПользователя(РезультатЧтения.Дерево);
			
			Элементы.Отбор_Пространство.СписокВыбора.Очистить();
			Для Каждого Пространство Из ДанныеПользователя.spaces Цикл
				Элементы.Отбор_Пространство.СписокВыбора.Добавить(Пространство.Значение,Пространство.Представление);
			КонецЦикла;
						
			//В случае наличия пространств - установим сразу одно из значений
			Если Элементы.Отбор_Пространство.СписокВыбора.Количество() > 0 Тогда
				
				ПоследнееРабочееПространство = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","ПоследнееРабочееПространство");
				Если Элементы.Отбор_Пространство.СписокВыбора.НайтиПоЗначению(ПоследнееРабочееПространство) <> Неопределено Тогда
					 Отбор_Пространство = ПоследнееРабочееПространство;
				Иначе
					Отбор_Пространство = Элементы.Отбор_Пространство.СписокВыбора[0].Значение;
				КонецЕсли;
				
				//Определяем регион пространства
				РегионПространства = ДанныеПользователя.spaceCountries.Получить(Отбор_Пространство);
				СтруктураНастроек.Вставить("РегионПространства",РегионПространства);
				
			Иначе				
				Отбор_Пространство = "";
				
			КонецЕсли;
			
			//2019.09.09 ( Поместим в структуру справочников портала настройки распознавания для доступных пространств
			Если СправочникиПортала = Неопределено Тогда
				СправочникиПортала = Новый Структура;
			КонецЕсли;
			
			СправочникиПортала.Вставить("recognitionSettings",ДанныеПользователя.recognitionSettings);
			// ) 2019.09.09
			
			//E1C-294: Теперь в этом методе прилетает "сториз" broadcastMessages для интерактивного взаимодействия с пользователями
			ДанныеПользователя_ТаблицаНовостей.Очистить();
			Для Каждого broadcastMessage Из ДанныеПользователя.broadcastMessages Цикл
				НоваяСтрока = ДанныеПользователя_ТаблицаНовостей.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,broadcastMessage);
			КонецЦикла;
			
		ИначеЕсли Назначение = "СправочникиПортала_ТипыДокументов"
			Или Назначение = "СправочникиПортала_СтатусыДокументов" Тогда
			ЧтениеСправочника = РеквизитОбъект.ПрочитатьСправочникПортала(РезультатЧтения.Дерево,Назначение);
			
			Если ЧтениеСправочника.Успешно Тогда
				Если СправочникиПортала = Неопределено Тогда
					СправочникиПортала = Новый Структура;
				КонецЕсли;
				
				СправочникиПортала.Вставить(ЧтениеСправочника.ИмяСправочника,ЧтениеСправочника.Справочник);
			КонецЕсли;
			
			//2021.04.02 ( Заполним список команд доступными типами портала
			Если Назначение = "СправочникиПортала_ТипыДокументов" Тогда
				ИзменитьТипДокументаПортала_ЗаполнитьМенюСпискаТиповДокументов();
			КонецЕсли;
			// ) 2021.04.02
			
		ИначеЕсли Назначение = "СправочникиПортала_Плательщики"
			Или Назначение = "СправочникиПортала_Поставщики" Тогда
			ЧтениеСправочника = РеквизитОбъект.ПрочитатьСправочникПортала_Компании(РезультатЧтения.Дерево,Назначение);
			
			Если ЧтениеСправочника.Успешно Тогда
				Если СправочникиПортала = Неопределено Тогда
					СправочникиПортала = Новый Структура;
				КонецЕсли;
				
				СправочникиПортала.Вставить(ЧтениеСправочника.ИмяСправочника,ЧтениеСправочника.Справочник);
			КонецЕсли;
			
		ИначеЕсли Назначение = "БалансСтраниц" Тогда
			
			РезультатОбработки.Вставить("balance",РезультатЧтения.Дерево.balance);			
			
		ИначеЕсли Назначение = "Обновить" Тогда
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
			РезультатОбработки = РеквизитОбъект.ПрочитатьДанныеДокументов(РезультатЧтения.Дерево,ДанныеПортала,СправочникиПортала,СтруктураНастроек,ПараметрыЗапроса);
			ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
			
		ИначеЕсли Назначение = "КоличествоДокументовСоответствующихОтбору" Тогда
			Попытка
				КоличествоДокументов = Число(РезультатЧтения.Дерево.documentsCount);
			Исключение
				КоличествоДокументов = 0;
			КонецПопытки;
			
			РезультатОбработки.Вставить("КоличествоДокументов",КоличествоДокументов);
			
		ИначеЕсли Назначение = "ПроверитьДубликатыФайловПоХэш" Тогда
			
			fileMetaDataList = РеквизитОбъект.ПолучитьКоллекциюXDTO(РезультатЧтения.Дерево.fileMetaDataList.fileMetaData);
			
			//Сейчас файлы передаются для проверки по одному
			Если fileMetaDataList.Количество() > 0
				И fileMetaDataList[0].fileId <> Неопределено Тогда
				КонтрольДубликата = "Дубликат";
			Иначе
				КонтрольДубликата = "Новый";
			КонецЕсли;
			
			РезультатОбработки.Вставить("КонтрольДубликата",КонтрольДубликата);
			
		ИначеЕсли Назначение = "ОтправкаНаРаспознавание" Тогда
			
			МассивЗаданий = Новый Массив;
			
			recognitionTasks = РеквизитОбъект.ПолучитьКоллекциюXDTO(РезультатЧтения.Дерево.recognitionTasks.recognitionTask);
			Для Каждого recognitionTask Из recognitionTasks Цикл
				
				ИмяФайла = "";
				Если РеквизитОбъект.ЗначениеЗаполненоXDTO(recognitionTask.files) Тогда
					files = РеквизитОбъект.ПолучитьКоллекциюXDTO(recognitionTask.files.file);
					Для Каждого file Из files Цикл
						ИмяФайла = ИмяФайла + ?(ИмяФайла <> "",", ","") + РаскодироватьСтрокуПараметровНаСервере(file.name);
					КонецЦикла;
					
					Задание = Новый Структура("recognitionTaskId,ИмяФайла,КоличествоФайлов",recognitionTask.id,ИмяФайла,files.Количество());
				
					МассивЗаданий.Добавить(Задание);
				КонецЕсли;
			КонецЦикла;
			
			РезультатОбработки.Вставить("МассивЗаданий",МассивЗаданий);
			
		ИначеЕсли Назначение = "СписокВыполняющихсяЗаданийРаспознавания" Тогда
			
			МассивЗаданий = Новый Массив;
			
			Если РеквизитОбъект.ЗначениеЗаполненоXDTO(РезультатЧтения.Дерево.runningRecognitionTasks) Тогда
				runningRecognitionTasks = РеквизитОбъект.ПолучитьКоллекциюXDTO(РезультатЧтения.Дерево.runningRecognitionTasks.runningRecognitionTask);
				Для Каждого recognitionTask Из runningRecognitionTasks Цикл
					
					ИмяФайла = "";
					Если РеквизитОбъект.ЗначениеЗаполненоXDTO(recognitionTask.files) Тогда
						files = РеквизитОбъект.ПолучитьКоллекциюXDTO(recognitionTask.files.file);
						Для Каждого file Из files Цикл
							ИмяФайла = ИмяФайла + ?(ИмяФайла <> "",", ","") + РаскодироватьСтрокуПараметровНаСервере(file.name);
						КонецЦикла;
						
						Задание = Новый Структура("recognitionTaskId,ИмяФайла,КоличествоФайлов",recognitionTask.id,ИмяФайла,files.Количество());
					
						МассивЗаданий.Добавить(Задание);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			РезультатОбработки.Вставить("МассивЗаданий",МассивЗаданий);
		
		ИначеЕсли Назначение = "СтатусЗаданияРаспознавания" Тогда
			
			recognitionTask = РезультатЧтения.Дерево.recognitionTask;
			
			state = recognitionTask.state;
			РезультатОбработки.Вставить("state",state);
			
			Если state = "RECOGNIZED"
				//2019.08.30 (
				Или state = "RECOGNIZING" Тогда
				// ) 2019.08.30
				
				Если РеквизитОбъект.ЗначениеЗаполненоXDTO(recognitionTask.documents) Тогда
					
					recognitionDocuments = РеквизитОбъект.ПолучитьКоллекциюXDTO(recognitionTask.documents.document);
					
					//прочитаем данные документов, дополним таблицу данных портала
					ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
					РезультатЧтения = РеквизитОбъект.ПрочитатьДанныеДокументов(recognitionTask,ДанныеПортала,СправочникиПортала,СтруктураНастроек,ПараметрыЗапроса);
					
					Если РезультатЧтения.Успешно Тогда
						
						РеквизитОбъект.ВыполнитьПоискСсылокПоДаннымПортала(СтруктураНастроек,ДанныеПортала);
						ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
					
						Для Каждого document Из recognitionDocuments Цикл
													
							//и выведем его в СписокДокументов						
							ВывестиДокументВСписокДокументов(ДанныеПортала,document.id,Истина);
						
						КонецЦикла;
											
					КонецЕсли;
				КонецЕсли;
								
			ИначеЕсли state = "ERROR" Тогда
				РезультатОбработки.Вставить("errorDescription",РезультатЧтения.Дерево.recognitionTask.errorDescription);			
				
			КонецЕсли;
			
			ПересчитатьИтогиПоСтатусамДокументов();
			
		ИначеЕсли Назначение = "ПолучениеСпискаНовыхВерсий" Тогда
			
			//проверить номер версии, о которой пользователь попросил не напоминать
			НеНапоминатьОВерсии = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","НеНапоминатьОВерсии");
			
			СписокНовыхВерсий = Новый Массив;
			
			Если РеквизитОбъект.СвойствоXDTOСуществует(РезультатЧтения.Дерево,"moduleVersions")
				И РеквизитОбъект.ЗначениеЗаполненоXDTO(РезультатЧтения.Дерево.moduleVersions) Тогда
				
				moduleVersions = РеквизитОбъект.ПолучитьКоллекциюXDTO(РезультатЧтения.Дерево.moduleVersions.moduleVersion);
				
				Если moduleVersions.Количество() > 0 Тогда
				
					Для Каждого version Из moduleVersions Цикл
						Структура = Новый Структура("id,version,description,critical");
						ЗаполнитьЗначенияСвойств(Структура,version);
						СписокНовыхВерсий.Добавить(Структура);
					КонецЦикла;
					
					//Последняя версия в массиве - самая актуальная, сверим ее с сохраненным значением НеНапоминатьОВерсии
					ПоследняяВерсия = Структура.version;
					
				КонецЕсли;
				
			КонецЕсли;
			
			РезультатОбработки.Вставить("СписокНовыхВерсий",СписокНовыхВерсий);
			РезультатОбработки.Вставить("ПоследняяВерсия",ПоследняяВерсия);
			РезультатОбработки.Вставить("НеНапоминатьОВерсии",Строка(НеНапоминатьОВерсии));
			
		ИначеЕсли Назначение = "УведомлениеОСозданииДокументов" Тогда
			//Очищаем список заданий уведомления
			ЗаданияУведомления.Очистить();
			
		ИначеЕсли Назначение = "ПолучениеФайлаСкана" Тогда
			//Портал может вернуть вместо печатной формы код ошибки, уведомляющий, что она еще не готова
			Если РезультатЧтения.Свойство("ПредложитьПовторитьЗапрос") Тогда
				РезультатОбработки.Вставить("ПредложитьПовторитьЗапрос",Истина);
				РезультатОбработки.ТекстОшибки = РезультатЧтения.ТекстОшибки;
			Иначе
				РезультатОбработки.Вставить("АдресВХ",РезультатЧтения.АдресВХ);
				
				//2020.12.01 ( Имя файла у нас теперь формируется по заданному шаблону
				ИмяФайла = РеквизитОбъект.СформироватьИмяФайлаСканаПоШаблону(АдресХранилищаДанныхПортала,,ПараметрыЗапроса.ДокументИД,РезультатЧтения.ИмяФайла,СтруктураНастроек);
				// ) 2020.12.01
				
				РезультатОбработки.Вставить("ИмяФайла",ИмяФайла);
			КонецЕсли;
			
		ИначеЕсли Назначение = "ПолучениеФайлаВнешнейОбработки" Тогда
			РезультатОбработки.Вставить("АдресВХ",РезультатЧтения.АдресВХ);
			РезультатОбработки.Вставить("ИмяФайла",РезультатЧтения.ИмяФайла);
			
		ИначеЕсли Назначение = "ПолучениеРеестраАрхиваДокументов" Тогда
			РезультатОбработки.Вставить("АдресВХ",РезультатЧтения.АдресВХ);
			ИмяФайла = РезультатЧтения.ИмяФайла;
			
			//E1C-209: формировать имя файла по шаблону для скачиваемых оригиналов и печатных форм
			Если ПараметрыЗапроса.Свойство("ДокументИД") И ЗначениеЗаполнено(ПараметрыЗапроса.ДокументИД) Тогда
				ИмяФайла = РеквизитОбъект.СформироватьИмяФайлаСканаПоШаблону(АдресХранилищаДанныхПортала,,ПараметрыЗапроса.ДокументИД,ИмяФайла,СтруктураНастроек);
			КонецЕсли;
			
			РезультатОбработки.Вставить("ИмяФайла",ИмяФайла);
			
		ИначеЕсли Назначение = "ВыполнениеЗапросИзМК" Тогда
			//Обработка ответа выполняется в МК

		КонецЕсли;
		
	Иначе
		ЗаполнитьЗначенияСвойств(РезультатОбработки,РезультатЧтения);
	КонецЕсли;
	
	Возврат РезультатОбработки;
	
КонецФункции


// ================= Заполнение списка документов ===================

&НаКлиенте
Процедура Обновить(Команда)
	
	Если Не ЗначениеЗаполнено(Токен) Тогда
		ОткрытьФормуАвторизации(Ложь);
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Отбор_Пространство) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Пространство не может быть пустым";
		Сообщение.Поле = "Отбор_Пространство";		
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеПользователя.phoneConfirm Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Для начала работы с сервисом необходимо подтвердить телефон пользователя.";
		Сообщение.Поле = "Авторизация";
		Сообщение.Сообщить();
		
		ОткрытьФормуПодтвержденияТелефона();
		
		Возврат;
	КонецЕсли;
	
	//2019.11.12 ( В случае использования свернутой ТЧ помещаем необходимо убедиться, что номенклатура, которая будет указана в свернутой ТЧ выбрана в настройках
	Если СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку <> "Нет" Тогда
		Если Не ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧНоменклатура) Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Поле = "Настройки";
			Сообщение.Текст = "При включенной настройке <Сворачивать данные табличной части в одну строку> необходимо выбрать номенклатуру";
			Сообщение.Сообщить();
			
			Настройки(Неопределено);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	// ) 2019.11.12
		
	//очистить загруженные данные
	Объект.СписокДокументов.Очистить();
	ПоместитьВоВременноеХранилище(Неопределено,АдресХранилищаДанныхПортала);
	
	ЗаполнитьСписокДокументов();
	
КонецПроцедуры
&НаКлиенте
Функция СформироватьСтрокуПараметровОтбора()
	
	СтрокаОтбора = "";
	
	Если ЗначениеЗаполнено(Отбор_Пространство) Тогда
		СтрокаОтбора = СтрокаОтбора + "&spaceId=" + Отбор_Пространство;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаНачала) Тогда
		СтрокаОтбора = СтрокаОтбора + "&createdDateFrom=" + Формат(Отбор_ПериодЗагрузки.ДатаНачала,"ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаОкончания) Тогда
		СтрокаОтбора = СтрокаОтбора + "&createdDateTo=" + Формат(Отбор_ПериодЗагрузки.ДатаОкончания,"ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаНачала) Тогда
		СтрокаОтбора = СтрокаОтбора + "&documentDateFrom=" + Формат(Отбор_ПериодДокументов.ДатаНачала,"ДФ=yyyy-MM-dd");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаОкончания) Тогда
		СтрокаОтбора = СтрокаОтбора + "&documentDateTo=" + Формат(Отбор_ПериодДокументов.ДатаОкончания,"ДФ=yyyy-MM-dd");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_Плательщик) Тогда
		Для Каждого ЭлементСписка Из Отбор_Плательщик Цикл
			СтрокаОтбора = СтрокаОтбора + "&customer=" + ЭлементСписка.Значение;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_Поставщик) Тогда
		Для Каждого ЭлементСписка Из Отбор_Поставщик Цикл
			СтрокаОтбора = СтрокаОтбора + "&supplier=" + ЭлементСписка.Значение;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПоискПоКлючевымСловам) Тогда
		СтрокаПоиска = СокрЛП(Отбор_ПоискПоКлючевымСловам);
		СтрокаОтбора = СтрокаОтбора + "&search=" + КодироватьСтрокуПараметровНаСервере(Отбор_ПоискПоКлючевымСловам);
	КонецЕсли;
	
	Возврат СтрокаОтбора;
	
КонецФункции
&НаКлиенте
Функция ЗаполнитьСписокДокументов() Экспорт
	
	//2020.04.21 ( может возникнуть ситуация, когда при входе в систему по каким-то причинам не были получены справочники портала,
	Если ТипЗнч(СправочникиПортала) = Тип("Структура")
		И СправочникиПортала.Свойство("ТипДокумента")
		И СправочникиПортала.Свойство("СтатусДокумента") Тогда
		//Все ОК!
	Иначе
		Попытка КартинкаОшибка = БиблиотекаКартинок.Ошибка32; Исключение КонецПопытки;
		ПоказатьОповещениеПользователя("Ошибка",,"Не были получены все необходимые справочники портала, попробуйте выполнить повторную авторизацию",КартинкаОшибка);
		Возврат Неопределено;
	КонецЕсли;
	// ) 2020.04.21
	
	СтрокаОтбора = СформироватьСтрокуПараметровОтбора();
	
	//Проверяем, не получится ли слишком много документов по отбору
	ПорогПредупреждения = 200;
	РезультатЗапроса = ВыполнитьЗапрос("КоличествоДокументовСоответствующихОтбору","GET","/api/v1/documents/count?format=xml" + СтрокаОтбора);
	
	Если РезультатЗапроса.Успешно Тогда
		КоличествоДокументовСоответствующихОтбору = РезультатЗапроса.КоличествоДокументов;
	Иначе
		//Проверка не удалась, продолжаем
		КоличествоДокументовСоответствующихОтбору = 0;
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("СтрокаОтбора",СтрокаОтбора);
	
	Если КоличествоДокументовСоответствующихОтбору > ПорогПредупреждения Тогда
		ТекстВопроса = "В результате запроса будет получено большое количество документов (" + КоличествоДокументовСоответствующихОтбору + "),
					   |это может занять продолжительное время, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ЗаполнитьСписокДокументов_КонтрольКоличестваДокументов",ДопПараметры,ТекстВопроса,Кнопки);
			
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
	Иначе
		ЗаполнитьСписокДокументов_КонтрольКоличестваДокументов(КодВозвратаДиалога.Да,ДопПараметры);
		
	КонецЕсли;
		
КонецФункции
&НаКлиенте
Функция ЗаполнитьСписокДокументов_КонтрольКоличестваДокументов(Результат,ДопПараметры) Экспорт
	
	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Страница = 1;
	
	Состояние("Получение данных портала...",25,"Для прерывания нажмите Ctrl + Break");
	
	ПродолжитьЗагрузку = Истина;
	Пока ПродолжитьЗагрузку = Истина Цикл
				
		ОбработкаПрерыванияПользователя();
		
		//Первым запросом помимо документов выполняем получение общего количества страниц, соответствующих отбору
		СтрокаПараметров = "?format=xml&include=full&pageSize=100&page=" + Страница + ДопПараметры.СтрокаОтбора;
		
		//E1C-206, EN-1090: новый  фильтр documentsForSendingToEdi в постраничный запрос документов,
		//который может принимать значения INCLUDED, EXCLUDED, ONLY
		Если СтруктураНастроек.ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот = Истина Тогда
			СтрокаПараметров = СтрокаПараметров + "&documentsForSendingToEdi=INCLUDED";
		Иначе
			СтрокаПараметров = СтрокаПараметров + "&documentsForSendingToEdi=EXCLUDED";
		КонецЕсли;
		// ) 2021.02.25
		
		РезультатЗапроса = ВыполнитьЗапрос("Обновить","GET","/api/v1/documents" + СтрокаПараметров);
		
		Если РезультатЗапроса.Успешно Тогда
			Если РезультатЗапроса.ОтветПустой Тогда
				СообщитьСообщение("За указанный период нет загруженных документов, измените настройки отбора");
			Иначе
				Страница = Страница + 1;
			КонецЕсли;
		Иначе
			СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
			Возврат Неопределено;
		КонецЕсли;
		
		ПродолжитьЗагрузку = Не РезультатЗапроса.ЗагрузкаДанныхЗавершена;
		
	КонецЦикла;
	
	//2019.10.11 ( Если требуются связанные документы и их нет в полученном списке - получаем их дополнительными запросами
	Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
		СписокСвязанныхДокументов = ПолучитьСписокСвязанныхДокументовДляЗаполнения(АдресХранилищаДанныхПортала);
		
		Если СписокСвязанныхДокументов.Количество() > 0 Тогда
			ОписаниеСобытия = "Получение списка связанных документов [" + СписокСвязанныхДокументов.Количество() + "]";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"СвязанныеДокументы");
			
			Состояние("Получение данных связанных документов...",50);
			
			Для Каждого СвязанныйДокумент Из СписокСвязанныхДокументов Цикл
				
				ОбработкаПрерыванияПользователя();
				
				ПараметрыЗапроса = Новый Структура("ПолучениеСвязанныхДокументов",Истина);
			
				СтрокаПараметров = "?format=xml&include=full";
				РезультатЗапроса = ВыполнитьЗапрос("Обновить","GET","/api/v1/documents/" + СвязанныйДокумент.Значение + СтрокаПараметров,,ПараметрыЗапроса);
				
				Если РезультатЗапроса.Успешно Тогда
					ОписаниеСобытия = "Связанный документ получен [" + СвязанныйДокумент.Значение + "]";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"СвязанныеДокументы");
				Иначе
					ОписаниеСобытия = "Ошибка при получении связанного документа [" + СвязанныйДокумент.Значение + "]: " + РезультатЗапроса.ТекстОшибки;
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"СвязанныеДокументы");
					СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
					Возврат Неопределено;
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// ) 2019.10.11
	
	Состояние("Обработка данных портала...",60);
	
	ВыполнитьПоискСсылокПоДаннымПорталаНаСервере();
	
	Состояние("Заполнение списка документов...",70);
	
	ЗаполнитьСписокДокументовНаСервере();
	УстановитьНаправленияДокументов();
	
	БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам();
	
	УстановитьОтборСтрокСпискаДокументов();
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
	
	Если СтруктураНастроек.Свойство("ОбменДанными_ОтображатьЗаданияРаспознавания")
		И СтруктураНастроек.ОбменДанными_ОтображатьЗаданияРаспознавания = Истина Тогда
		Состояние("Получение текущих заданий распознавания...",90);
		ЗаданияРаспознавания_ПолучитьСписокВыполняющихся();
	КонецЕсли;
	
	ОбновитьТекстКнопкиБаланс();
	Состояние("Завершено",100);
	
	//2019.05.14 (EN-438: теперь задания на распознавание нужно отображать и в списке документов
	//чтобы пользователь мог увидеть какие файлы загрузил а какие нет.
	СписокДокументов_ОтобразитьЗаданияНаРаспознавание();
	// ) 2019.05.14
	
	ВыполнитьОбновлениеСтатусовЗаданийРаспознавания();
	
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьСписокСвязанныхДокументовДляЗаполнения(АдресХранилищаДанныхПортала)
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	СписокСвязанныхДокументов = Новый СписокЗначений;
	
	Если ДанныеПортала <> Неопределено Тогда
	
		Для Каждого СтрокаТаблицы Из ДанныеПортала.documents Цикл
			Если ЗначениеЗаполнено(СтрокаТаблицы.parent) И ДанныеПортала.documents.Найти(СтрокаТаблицы.parent,"id") = Неопределено Тогда
				СписокСвязанныхДокументов.Добавить(СтрокаТаблицы.parent);
			КонецЕсли; 
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.children) И ДанныеПортала.documents.Найти(СтрокаТаблицы.children,"id") = Неопределено Тогда
				СписокСвязанныхДокументов.Добавить(СтрокаТаблицы.children);
			КонецЕсли; 
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СписокСвязанныхДокументов;
	
КонецФункции
&НаСервере
Процедура ВыполнитьПоискСсылокПоДаннымПорталаНаСервере()
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Если ДанныеПортала <> Неопределено Тогда
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		
		ПараметрыПоиска = Новый Структура;
		
		РеквизитОбъект.ВыполнитьПоискСсылок_Документы(СтруктураНастроек,ДанныеПортала,ПараметрыПоиска);
		
		ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция ЗаполнитьСписокДокументовНаСервере()
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	// 2022.12.20 ( Возникают странные кейсы, когда получение данных от портала было прервано, но ошибок не возникало
	Если ДанныеПортала = Неопределено Или НЕ ДанныеПортала.Свойство("documents") Тогда
		СообщитьСообщение("Данные не были получены от портала, попробуйте перезапустить модуль интеграции");
		Возврат Неопределено;
	КонецЕсли;
	// ) 2022.12.20
	
	Для Каждого ДокументПортала Из ДанныеПортала.documents Цикл
				
		ВывестиДокументВСписокДокументов(ДанныеПортала,ДокументПортала.id,Ложь);
				
	КонецЦикла;
	
	ПересчитатьИтогиПоСтатусамДокументов();
	
КонецФункции
&НаСервере
Процедура ВывестиДокументВСписокДокументов(ДанныеПортала,ДокументИД,ВставитьСтроку)
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	ДокументПортала = ДанныеПортала.documents.Найти(ДокументИД,"id");
	Если ДокументПортала <> Неопределено
		И Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",ДокументПортала.id)).Количество() = 0 Тогда
				
		Если ВставитьСтроку Тогда
			//проверим отображаемые в списке документов задания распознавания и расчитаем индекс строки сразу после них, достаточно вычислить их количество
			СтрокиЗаданий = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументСтатус","RECOGNIZING"));
			Индекс = СтрокиЗаданий.Количество();
			
			НоваяСтрокаДокумент = Объект.СписокДокументов.Вставить(Индекс);
		Иначе
			НоваяСтрокаДокумент = Объект.СписокДокументов.Добавить();
		КонецЕсли;
		
		НоваяСтрокаДокумент.ДокументИД = ДокументПортала.id;
		НоваяСтрокаДокумент.ПространствоИД = ДокументПортала.spaceId;
		НоваяСтрокаДокумент.ДокументТип = ДокументПортала.type;
		НоваяСтрокаДокумент.НаправлениеСоздаваемогоДокумента = РеквизитОбъект.ОпределитьНаправлениеСоздаваемогоДокумента(ДокументПортала,СтруктураНастроек);
		НоваяСтрокаДокумент.ДокументСтатус = ДокументПортала.state;
		НоваяСтрокаДокумент.ДокументСтатусЧека = ДокументПортала.receiptState;
		НоваяСтрокаДокумент.СуммаДокумента = ДокументПортала.amount;
		НоваяСтрокаДокумент.url = ДокументПортала.url;
		
		НоваяСтрокаДокумент.parentId = ДокументПортала.parent;
		НоваяСтрокаДокумент.childrenId = ДокументПортала.children;
		
		НоваяСтрокаДокумент.Документ1с = ДокументПортала.ДокументСсылка;
		НоваяСтрокаДокумент.ПредставлениеДокумента = ДокументПортала.ПредставлениеДокумента;
		НоваяСтрокаДокумент.ПредставлениеТипа = ДокументПортала.ПредставлениеТипа;
		НоваяСтрокаДокумент.ПредставлениеСтатуса = ДокументПортала.ПредставлениеСтатуса;
		
		Если ЗначениеЗаполнено(ДокументПортала.printFormId) Тогда
			НоваяСтрокаДокумент.ИндексКартинкиПечатнойФормы = 0;
		Иначе
			НоваяСтрокаДокумент.ИндексКартинкиПечатнойФормы = 1;
		КонецЕсли;
		
		//E1C-466: Отображение в реестре документов замечаний по распознаванию документа
		НоваяСтрокаДокумент.ИндексКартинкиЗамечанийРаспознавания = ДокументПортала.validationNotificationSeverity;
		НоваяСтрокаДокумент.ТекстЗамечанийРаспознавания = ДокументПортала.validationNotificationTextFull;
		
		НоваяСтрокаДокумент.ДокументКомментарий = ДокументПортала.comment;
		
		//E1C-48: для чеков в столбце статус писать не статусы документа, а статус чека который отображается в карточке документа
		Если ДокументПортала.type = "RECEIPT" Тогда
			НоваяСтрокаДокумент.ПредставлениеСтатуса = ДокументПортала.ПредставлениеСтатусаЧека;
		КонецЕсли; 
		
		НоваяСтрокаДокумент.Диадок_Статус = ДокументПортала.Диадок_Статус;
		НоваяСтрокаДокумент.Диадок_url = ДокументПортала.Диадок_url;
		
		НоваяСтрокаДокумент.ПредставлениеПлательщика = ДокументПортала.ПредставлениеПлательщика;
		НоваяСтрокаДокумент.ПредставлениеПоставщика = ДокументПортала.ПредставлениеПоставщика;
		НоваяСтрокаДокумент.ДокументЗагрузил = ДокументПортала.creatorEmail;
		НоваяСтрокаДокумент.Источник = ДокументПортала.ПредставлениеИсточника;
		
		НоваяСтрокаДокумент.ДатаЗагрузки = ДокументПортала.createdDate;
		НоваяСтрокаДокумент.ЗагруженСПортала = Истина;
		
		НоваяСтрокаДокумент.ЭтоДокументЭДО = ДокументПортала.forSendingToEdi = Истина;
		
		Если ЗначениеЗаполнено(ДокументПортала.СтруктураДополнительныхДанных) Тогда
			НоваяСтрокаДокумент.СтруктураДополнительныхДанных = ЗначениеВСтрокуВнутр(ДокументПортала.СтруктураДополнительныхДанных);
		КонецЕсли;
		
		//Подсчет статусов
		Если ДокументПортала.state = "UPLOADED" Тогда
			НоваяСтрокаДокумент.Счетчик_Загружен = 1;
		ИначеЕсли ДокументПортала.state = "VERIFIED" Тогда
			НоваяСтрокаДокумент.Счетчик_Проверен = 1;
		ИначеЕсли ДокументПортала.state = "RECOGNIZED" Тогда
			НоваяСтрокаДокумент.Счетчик_Распознан = 1;
		ИначеЕсли ДокументПортала.state = "EDI_SEND" Тогда
			НоваяСтрокаДокумент.Счетчик_ОтправленныеВЭДО = 1;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВСпискеДокументовДополнительныеДанные()
	
	//Для строки таблицы документа структура дополнительных данных содержит набор ключей,
	//соответствующих реквизитам таблицы формы для их отображения
	
	Для Каждого СтрокаТаблицы Из Объект.СписокДокументов Цикл
