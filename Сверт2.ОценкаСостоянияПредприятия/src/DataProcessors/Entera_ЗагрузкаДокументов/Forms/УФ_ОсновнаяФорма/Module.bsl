			КонецЕсли;
			
		// 2022.09.28 ( в БП30.КОРП есть вид операции у этого типа документа	
		ИначеЕсли ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
			Если РеквизитСуществует("Перечисления","ВидыОперацийОтчетКомиссионера","ОтчетОПродажах") Тогда
				Операция.Вставить("ВидОперации",Перечисления.ВидыОперацийОтчетКомиссионера.ОтчетОПродажах);
			КонецЕсли;
		// ) 2022.09.28
			
		ИначеЕсли ТипСоздаваемогоДокумента = "бит_ЗаявкаНаРасходованиеСредств"
			Или ТипСоздаваемогоДокумента = "бит_кзн_ЗаявкаНаРасходованиеСредств" Тогда
			Если РеквизитСуществует("Перечисления","бит_ВидыОперацийЗаявкаНаРасходование","ОплатаПоставщику") Тогда
				Операция.Вставить("ВидОперации",Перечисления.бит_ВидыОперацийЗаявкаНаРасходование.ОплатаПоставщику);
			КонецЕсли;
			
		//2023.02.02 ( БСО
		ИначеЕсли ТипСоздаваемогоДокумента = "ИмпПриемкаСтроительныхРаботУслуг" Тогда
			Если РеквизитСуществует("Перечисления","ИмпВидыОперацийПриемкаСтроительныхРаботУслуг","ПриемкаСубподрядныхРабот") Тогда
				Операция.Вставить("ВидОперации",Перечисления.ИмпВидыОперацийПриемкаСтроительныхРаботУслуг.ПриемкаСубподрядныхРабот);
			КонецЕсли;
			
		ИначеЕсли ТипСоздаваемогоДокумента = "ИмпРеализацияСтроительныхРаботУслуг" Тогда
			Если РеквизитСуществует("Перечисления","ИмпВидыОперацийРеализацияСтроительныхРаботУслуг","ПередачаЗаконченныхСМР") Тогда
				Операция.Вставить("ВидОперации",Перечисления.ИмпВидыОперацийРеализацияСтроительныхРаботУслуг.ПередачаЗаконченныхСМР);
			КонецЕсли;
		// ) 2023.02.02
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ДокументОбъект,Операция);
		
		
		//E1C-503: Заполняем Реквизит ВидВходящегоДокумента документа ПоступлениеТоваровУслуг.
		//Тип - строковый, поэтому даже для предопределенных данных можем заполнить строку наименования
		Если Конф = "БП30" И СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ"
			И ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг" Тогда
						
			Если ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Услуги Тогда
				ВидВходящегоДокумента = "Акт выполненных работ";
			ИначеЕсли ДокументОбъект.ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Импорт Тогда
				ВидВходящегоДокумента = "Грузовая таможенная декларация";
			Иначе
				ВидВходящегоДокумента = "Накладная/Товарный чек";
			КонецЕсли;
			
			СтруктураВидВходящегоДокумента = Новый Структура("ВидВходящегоДокумента",ВидВходящегоДокумента);
			ЗаполнитьЗначенияСвойств(ДокументОбъект,СтруктураВидВходящегоДокумента);
		КонецЕсли;
		
		
		//+++ Пока оставлено, как было раньше, потом удалить
		Если Ложь Тогда
			//заполняем счета учета в документах
			СчетаУчетаВДокументах_ЗаполнениеВыполнено = Ложь;
			
			МодульСчетаУчетаВДокументах = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("СчетаУчетаВДокументах");
			Если МодульСчетаУчетаВДокументах <> Неопределено Тогда
				Попытка
					МодульСчетаУчетаВДокументах.ЗаполнитьСтроки(ДокументОбъект[ИмяТЧТовары], ИмяТЧТовары, ДокументОбъект, МенеджерОбъекта, Ложь);
					СчетаУчетаВДокументах_ЗаполнениеВыполнено = Истина;
				Исключение;
					
				КонецПопытки;
				
				Если ИмяТЧУслуги <> Неопределено Тогда
					Попытка
						МодульСчетаУчетаВДокументах.ЗаполнитьСтроки(ДокументОбъект[ИмяТЧУслуги], ИмяТЧУслуги, ДокументОбъект, МенеджерОбъекта, Ложь);
						СчетаУчетаВДокументах_ЗаполнениеВыполнено = Истина;
					Исключение;
						
					КонецПопытки;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// Если не отработало стандартное заполнение счетов учета в документе
		Если Не СчетаУчетаВДокументах_ЗаполнениеВыполнено = Истина Тогда
			
			Если Конф = "БП30" Тогда
				
				//E1C-375: Услуги аренды. Обрабатывается строго кейс ВедетсяУчетПредметовАренды = 1 для ПТиУ
				Если ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
					И СтруктураЗаполнения.Свойство("ВедетсяУчетПредметовАренды")
					И СтруктураЗаполнения.ВедетсяУчетПредметовАренды = Истина Тогда
					
					ДокументОбъект.СчетУчетаРасчетовСКонтрагентом = ПланыСчетов.Хозрасчетный.АрендныеПлатежи;
				КонецЕсли;
				// ) E1C-375
				
				Если ТипСоздаваемогоДокумента = "ПоступлениеВЛизинг"
					Или ТипСоздаваемогоДокумента = "ПоступлениеВАренду" Тогда
					
					//Из формы документа типового документа "Поступление в лизинг"
					РасчетыВУЕ = ДокументОбъект.ДоговорКонтрагента.РасчетыВУсловныхЕдиницах;
					
					Если РасчетыВУЕ Тогда
						ДокументОбъект.СчетУчетаРасчетовСКонтрагентом = ПланыСчетов.Хозрасчетный.АрендныеОбязательстваУЕ;
					ИначеЕсли ДокументОбъект.ВалютаДокумента <> СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета Тогда
						ДокументОбъект.СчетУчетаРасчетовСКонтрагентом = ПланыСчетов.Хозрасчетный.АрендныеОбязательстваВал;
					Иначе
						ДокументОбъект.СчетУчетаРасчетовСКонтрагентом = ПланыСчетов.Хозрасчетный.АрендныеОбязательства;
					КонецЕсли;
					
					ДанныеОбъекта = Новый Структура("Дата, Организация, Склад, СуммаВключаетНДС,
						|ВалютаДокумента, КурсВзаиморасчетов, КратностьВзаиморасчетов, ДоговорКонтрагента");
					ЗаполнитьЗначенияСвойств(ДанныеОбъекта, ДокументОбъект);
	                ДанныеОбъекта.Вставить("РасчетыВУЕ", РасчетыВУЕ);
					
					Для Каждого СтрокаТаблицы Из ДокументОбъект.ПредметыЛизинга Цикл
						Если Не ЗначениеЗаполнено(СтрокаТаблицы.СчетУчета) Тогда
							Документы[ТипСоздаваемогоДокумента].ЗаполнитьСчетаУчетаВСтрокеТабличнойЧасти(ДанныеОбъекта, СтрокаТаблицы, "ПредметыЛизинга");
						КонецЕсли;
					КонецЦикла;
					
				Иначе
					
					//2023.04.12 ( Бухгалтерия для Казахстана
					Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
						ДокументОбъект.ДополнительныеСвойства.Вставить("ЗаполнитьСчетаУчетаПередЗаписью",Истина);
					КонецЕсли;
					// ) 2023.04.12
					
					//Шапка документа
					// 2022.03.06 ( Замена устаревшей функции конфигурации
					//Попытка МенеджерОбъекта.ЗаполнитьСчетаУчетаРасчетов(ДокументОбъект); Исключение; КонецПопытки;
					Если МодульСчетаУчетаВДокументах <> Неопределено Тогда
						Попытка МодульСчетаУчетаВДокументах.ЗаполнитьПередЗаписью(ДокументОбъект,РежимЗаписиДокумента.Запись); Исключение; КонецПопытки;
					КонецЕсли;
					// ) 2022.03.06
					
				КонецЕсли;
			
			ИначеЕсли Конф = "БГУ2" Тогда
				//
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	//E1C-512: Не всех устраивает автоматическая установка времени
	Если СтруктураНастроек.ЗаполнениеШапки_УстанавливатьВремяДокументаАвтоматически = Истина Тогда
		//2021.03.22 ( Установим время документа
		ДокументОбъект.УстановитьВремя();
		// ) 2021.03.22
	КонецЕсли;
	
	//2019.05.21 ( модуль кастомизации	
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередЗаписьюДокумента",ПараметрыМК);
	
		
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) 2019.05.21	
	
		ОписаниеСобытия = "Выполняется стандартная обработка записи документа <" + ТипСоздаваемогоДокумента + "> (" + ДокументИД + ")";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
	
		//Проверяем наличие установленной даты запрета
		ОтказЗаписи = Ложь;
		МодульДатыЗапретаИзменения = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ДатыЗапретаИзменения");
		Если МодульДатыЗапретаИзменения <> Неопределено Тогда
			Попытка
				МодульДатыЗапретаИзменения.ПроверитьДатуЗапретаИзмененияПередЗаписьюДокумента(ДокументОбъект,ОтказЗаписи,РежимЗаписиДокумента.Запись,РежимПроведенияДокумента.Неоперативный);
			Исключение
				ОписаниеСобытия = "Не удалось выполнить штатный механизм определения даты запрета <" + ТипСоздаваемогоДокумента + "> (" + ДокументИД + ")";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			КонецПопытки;
		КонецЕсли;
		
		Если ОтказЗаписи = Истина Тогда
			ТекстОшибки = ТекстОшибки + "запись документа в закрытом для редактирования периоде [" + Формат(ДокументОбъект.Дата,"ДФ=dd.MM.yyyy") + "] невозможна.";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ТекстОшибки,"ОтказЗаписи");
			
		Иначе
						
			Попытка
				ДокументОбъект.Записать();
				ДокументСсылка = ДокументОбъект.Ссылка;
				
				ОписаниеСобытия = "<" + ДокументСсылка + ">: документ успешно записан";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
				
				ЗаписатьСвязьСДокументомПортала(СтруктураЗаполненияДокумента.МассивИдентификаторовДокументов,ДанныеДокумента.spaceId,ДокументСсылка,Неопределено,ТекстОшибки);
				
				//+++ записать ДанныеПортала со ссылками на документы?
				ДанныеДокумента.ДокументСсылка = ДокументСсылка;
			Исключение
				ОписаниеСобытия = "- ошибка при записи документа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		
		//2020.04.07 (
		ПараметрыМК.Вставить("ДокументСсылка",ДокументСсылка);
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПослеЗаписиДокумента",ПараметрыМК);
		// ) 2020.04.07
		
		//EN-370: По настройке устанавливать флаг Оригинал получен: Если СтруктураНастроек.СозданиеДокумента_УстанавливатьФлагОригиналПолучен = Истина Тогда
		//E1C-230: Теперь этот флаг получаем из формы сопоставления
		Если ДанныеДокумента.ОригиналПолучен = Истина Тогда
			ОшибкаУстановкиФлага = УстановитьСтатусДокумента_ОригиналПолучен(ДокументСсылка);
			
			Если ЗначениеЗаполнено(ОшибкаУстановкиФлага) Тогда
				ОписаниеСобытия = "Ошибка при установке флага Оригинал получен для <" + ДокументСсылка + ">: " + КраткоеОписаниеОшибки(ОшибкаУстановкиФлага);
			Иначе
				ОписаниеСобытия = "Флаг Оригинал получен для <" + ДокументСсылка + "> установлен";
			КонецЕсли;
			
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			
		КонецЕсли;
		// ) EN-370
		
		//Платежное поручение
		Если ТипСоздаваемогоДокумента = "ПлатежноеПоручение" Тогда
			Если РеквизитСуществует("РегистрыСведений","СостоянияБанковскихДокументов") Тогда
				Попытка
					РегистрыСведений.СостоянияБанковскихДокументов.УстановитьСостояниеДокумента(ДокументСсылка,"Подготовлено");
				Исключение
					//Не обрабатываем
				КонецПопытки;
			КонецЕсли;
			
		//E1C-457: Выплаты самозанятым
		ИначеЕсли ТипСоздаваемогоДокумента = "ВыплатыСамозанятым" Тогда
			НовыеСтатусыДокумента = РегистрыСведений.СтатусыДокументов.НовыеСтатусыДокумента();
			Если ЗначениеЗаполнено(НоваяСсылкаПервыйПрисоединенныйФайл) Тогда
				НовыеСтатусыДокумента.Статус = Перечисления.СтатусыДокументовВыплатыСамозанятым.ЧекиЗагружены;
			Иначе
				НовыеСтатусыДокумента.Статус = Перечисления.СтатусыДокументовВыплатыСамозанятым.ЧекиЧастичноЗагружены;
			КонецЕсли;
			РегистрыСведений.СтатусыДокументов.УстановитьСтатусыДокумента(ДокументСсылка,НовыеСтатусыДокумента);
		КонецЕсли;
		
		
		//2021.10.18 ( Временно отключим это условие, требуется создание СФ даже при установленном флаге УПД в документе-поступлении
		СтандартноеЗаполнениеСФПриФлагеДокументаУПД = Истина;
		
		Если Не СтандартноеЗаполнениеСФПриФлагеДокументаУПД Тогда
		// ) 2021.10.18
		
			//E1C-268: Если это поступление и у документа флаг ЭтоУниверсальныйДокумент, то в самой конфигурации ПОСЛЕ записи в ФОРМЕ
			//заполняется счет-фактура. Вызовем тот же алгоритм после записи тут
			Если ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
				И СтруктураЗаполнения.Свойство("ЭтоУниверсальныйДокумент")
				И СтруктураЗаполнения.ЭтоУниверсальныйДокумент = Истина Тогда
				
				МодульУчетНДСКлиентСервер = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("УчетНДСКлиентСервер");
				МодульУчетНДСВызовСервера = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("УчетНДСВызовСервера");
				
				Если МодульУчетНДСКлиентСервер <> Неопределено
					И МодульУчетНДСВызовСервера <> Неопределено Тогда
					
					ПараметрыСчетаФактуры = МодульУчетНДСКлиентСервер.НовыеПараметрыСозданияПолученногоСчетаФактуры();
					ПараметрыСчетаФактуры.Основание = ДокументСсылка;
					ПараметрыСчетаФактуры.НомерСчетаФактурыПолученного = ДокументОбъект.НомерВходящегоДокумента;
					ПараметрыСчетаФактуры.ДатаСчетаФактурыПолученного  = ДокументОбъект.ДатаВходящегоДокумента;
					
					ПараметрыСчетаФактуры.ЭтоУниверсальныйДокумент = Истина;
					
					МодульУчетНДСВызовСервера.СоздатьСчетФактуруПолученныйНаОсновании(
						ПараметрыСчетаФактуры,,
						Истина,
						ДанныеДокумента.ОригиналПолучен);
						
					КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		//БГУ: получим и запишем типовую операцию для данного документа
		Если Конф = "БГУ2" Тогда
			МодульБухгалтерскиеОперацииСервер = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("БухгалтерскиеОперацииСервер");
			Если МодульБухгалтерскиеОперацииСервер <> Неопределено Тогда
				
				Если ТипСоздаваемогоДокумента = "ПоступлениеМЗ" Тогда
					ТиповаяОперация = Справочники.ТиповыеОперации.ПоступлениеМЗ_Покупка1;
				КонецЕсли;
				
				Попытка
					МодульБухгалтерскиеОперацииСервер.ЗаписатьДанныеТиповойОперацииОбъекта(ДокументОбъект,ТиповаяОперация);
					ОписаниеСобытия = "БГУ2: бухгалтерская операция <" + ТиповаяОперация + "> для документа <" + ДокументСсылка + "> установлена";
				Исключение
					ОписаниеСобытия = "БГУ2: ошибка при установке бухгалтерской операции для документа <" + ДокументСсылка + ":" + Символы.ПС + ОписаниеОшибки();
				КонецПопытки;
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			КонецЕсли;
		КонецЕсли;
		
		
		Если СтруктураНастроек.СозданиеДокумента_ПроводитьЗаполненныеДокументы = Истина Тогда
			
			Если ДокументСсылка.Проведен Тогда
				ОписаниеСобытия = "- проведение документа <" + ДокументОбъект + "> пропущено: документ уже проведен";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
				
			Иначе
				Попытка					
					ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
					
					ОписаниеСобытия = "<" + ДокументСсылка + ">: документ успешно проведен";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
				Исключение
					ОписаниеСобытия = "- ошибка при проведении документа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
				КонецПопытки;
				
			КонецЕсли;
		КонецЕсли;
		
		//По флагу в настройках прикрепляем файла как ПрисоединенныйФайл
		Если СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина Тогда
			
			//2019.10.22 ( обработка события модуля кастомизации
			ПараметрыМК.Вставить("НоваяСсылкаПервыйПрисоединенныйФайл",НоваяСсылкаПервыйПрисоединенныйФайл);
			ПараметрыМК.Вставить("МассивФайлов",СтруктураЗаполненияДокумента.МассивФайлов);
			ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередПрисоединениемФайлов",ПараметрыМК);
			ТекстОшибки = ПараметрыМК.ТекстОшибки;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			// ) 2019.10.22
			
				ПрисоединитьФайлы_СканыДокумента(ДокументСсылка,СтруктураЗаполненияДокумента.МассивФайлов,ТекстОшибки,НоваяСсылкаПервыйПрисоединенныйФайл);
			КонецЕсли;
		КонецЕсли;
				
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		
		//2020.10.18 ( Заполняем документ Доп. расходов
		Если СтрокиДопРасходов.Количество() > 0 Тогда
			ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
		
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередСозданиемПоступлениеДопРасходов",ПараметрыМК);
			ТекстОшибки = ПараметрыМК.ТекстОшибки;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
				ДопРасходыСсылка = ДопРасходы_ЗаполнитьДокументПоОснованию(ДокументСсылка,СтрокиДопРасходов,СтруктураЗаполненияДокумента,ПараметрыМК,ТекстОшибки);
				Если ЗначениеЗаполнено(ДопРасходыСсылка) Тогда
					СтруктураЗаполненияДокумента.Вставить("ПоступлениеДопРасходовСсылка",ДопРасходыСсылка);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// ) 2020.10.18
		
		Если ЗначениеЗаполнено(СвязанныйДокументИД) Тогда
			//Запишем связь с дочерним документом
			ЗаписатьСвязьСДокументомПортала(СвязанныйДокументИД,ДанныеДокумента.spaceId,ДокументСсылка,Неопределено,ТекстОшибки);
			СвязанныйДокумент.ДокументСсылка = ДокументСсылка;
			
			УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,СвязанныйДокументИД);
		
		Иначе
			//Запишем связь с основным документом
			ЗаписатьСвязьСДокументомПортала(ДокументИД,ДанныеДокумента.spaceId,ДокументСсылка,Неопределено,ТекстОшибки);
			ДанныеДокумента.ДокументСсылка = ДокументСсылка;
			
			УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,ДокументИД);
		
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДокументСсылка;
КонецФункции
&НаСервере
Функция ПолучитьСсылку_ЗаполнениеСчетФактура(СтруктураЗаполненияДокумента,ДокументРодитель,ДанныеДокумента,ТекстОшибки)
	
	ДокументИД = СтруктураЗаполненияДокумента.document.id;
	НаправлениеСоздаваемогоДокумента = СтруктураЗаполненияДокумента.НаправлениеСоздаваемогоДокумента;
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект"); //Для вызова функций модуля объекта
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	//Теперь ВидОперации для создаваемого основного документа может быть выбран пользователем,
	//для некоторых видов операции счет-фактура не создается, независимо от настроек
	Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ВПереработку")
		И ДокументРодитель.Метаданные().Реквизиты.Найти("ВидОперации") <> Неопределено
		И ДокументРодитель.ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	//E1C-327: Для документа ОтчетКомиссионераОПродажах счет-фактуру автоматически не заполняем
	Если ДанныеДокумента.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах"
		Или ДанныеДокумента.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если НаправлениеСоздаваемогоДокумента = "Входящий"
		И ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.СчетФактураПолученный) Тогда
		ДокументОбъект = Документы[СтруктураНастроек.СведенияОКонфигурации.СчетФактураПолученный].СоздатьДокумент();
	Иначе
		//E1C-153: отдельный пункт настройки "Создавать счета-фактуры к ИСХОДЯЩИМ документам"
		Если СтруктураНастроек.СозданиеДокумента_СчетФактура_СоздаватьИсходящимДокументам = Истина
			И ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.СчетФактураВыданный) Тогда
			ДокументОбъект = Документы[СтруктураНастроек.СведенияОКонфигурации.СчетФактураВыданный].СоздатьДокумент();
		Иначе
		// ) E1C-153
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	// 2022.02.01 ( Следует проверить, а вводится ли в этой конфигурации счет-фактура на основании этого документа
	//2022.05.11: ОТМЕНЕНО
	Если Ложь Тогда
		МетаданныеСчетаФактуры = ДокументОбъект.Метаданные();
		МетаданныеРодителя = ДокументРодитель.Метаданные();
		Если Не МетаданныеСчетаФактуры.ВводитсяНаОсновании.Содержит(МетаданныеРодителя) Тогда
			ОписаниеСобытия = "Ввод <" + МетаданныеСчетаФактуры.Имя + "> не предполагает ввода на основании <"
				+ МетаданныеРодителя.Имя + ">, создание счета-фактуры пропущено";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	// ) 2022.02.01
	
	// модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("ДокументИД",ДокументИД);
	ПараметрыМК.Вставить("ДанныеДокумента",ДанныеДокумента);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	ПараметрыМК.Вставить("ТипСоздаваемогоДокумента",ДанныеДокумента.type);
	ПараметрыМК.Вставить("ДопПараметры",Новый Структура);
	ПараметрыМК.Вставить("ДокументОбъект",ДокументОбъект);
	ПараметрыМК.Вставить("ДокументРодитель",ДокументРодитель);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	//Теперь данные документа есть в структуре заполнения документа, но оставляем их для обратной совместимости МК
	ПараметрыМК.Вставить("СтруктураЗаполненияДокумента",СтруктураЗаполненияДокумента);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("СчетФактура_ПередЗаполнениемШапки",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
		// ) модуль кастомизации
		
		//Поиск связанных документов комплекта
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина
			И ЗначениеЗаполнено(СтруктураЗаполненияДокумента.document.children) Тогда
			
			//Если у текущего документа есть children, то используем его номер и дату
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
			СвязанныйДокумент = ДанныеПортала.documents.Найти(СтруктураЗаполненияДокумента.document.children,"id");
			
			Если СвязанныйДокумент <> Неопределено Тогда
				
				//Связанный документ уже создали ранее
				Если ЗначениеЗаполнено(СвязанныйДокумент.ДокументСсылка) Тогда
					Возврат СвязанныйДокумент.ДокументСсылка;
				КонецЕсли;

				ДатаДокумента = СвязанныйДокумент.ДатаДокумента;
				date = СвязанныйДокумент.date;
				number = СвязанныйДокумент.number;
				СвязанныйДокументИД = СвязанныйДокумент.id;
			Иначе
				ДатаДокумента = ДанныеДокумента.ДатаДокумента;
				date = ДанныеДокумента.date;
				number = ДанныеДокумента.number;
			КонецЕсли;
		Иначе
			ДатаДокумента = ДанныеДокумента.ДатаДокумента;
			date = ДанныеДокумента.date;
			number = ДанныеДокумента.number;
		КонецЕсли;
		
		
		//Выбор дальнейшего заполнения в зависимости от конфигурации
		Если Конф = "БП30" Тогда
			ДокументОбъект.Заполнить(ДокументРодитель);
			
			//E1C-197: Добавим в список документов-оснований поступление доп. расходов, если он есть
			Если СтруктураЗаполненияДокумента.Свойство("ПоступлениеДопРасходовСсылка")
				И ЗначениеЗаполнено(СтруктураЗаполненияДокумента.ПоступлениеДопРасходовСсылка) Тогда
				НоваяСтрокаОснований = ДокументОбъект.ДокументыОснования.Добавить();
				НоваяСтрокаОснований.ДокументОснование = СтруктураЗаполненияДокумента.ПоступлениеДопРасходовСсылка;
			КонецЕсли;
			
		ИначеЕсли Конф = "БГУ2" Тогда
			Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
				ДокументОбъект.Заполнить(ДокументРодитель);
			Иначе
				ДанныеЗаполнения = Новый Структура;
				ДанныеЗаполнения.Вставить("ОснованиеСсылка",ДокументРодитель);
			КонецЕсли;
			
		ИначеЕсли Конф = "ERP"
			//Проверено на 2.4.7.150: выполняется заполнение СФ только по проведенному документу-основанию,
			//можно заполнить документ СФ непроведенным для его проверки и проведения пользователем
			//эту часть в дальнейшем следует вынести в модуль кастомизации для этого клиента (
			Или Конф = "КА2" Тогда
			
			Если ДокументРодитель.Проведен Тогда
				ДанныеЗаполнения = Новый Структура;
				ДанныеЗаполнения.Вставить("ДокументОснование",ДокументРодитель);
				ДокументОбъект.Заполнить(ДанныеЗаполнения);
			Иначе
				ЗаполнитьЗначенияСвойств(ДокументОбъект,ДокументРодитель);
							
				НоваяСтрокаОснование = ДокументОбъект.ДокументыОснования.Добавить();
				СтруктураЗаполненияСтрокиОснования = Новый Структура;
				СтруктураЗаполненияСтрокиОснования.Вставить("ДокументОснование",ДокументРодитель);
				СтруктураЗаполненияСтрокиОснования.Вставить("Сумма",СтруктураЗаполненияДокумента.document.amount);
				СтруктураЗаполненияСтрокиОснования.Вставить("СуммаНДС",СтруктураЗаполненияДокумента.document.vat);
				
				ЗаполнитьЗначенияСвойств(НоваяСтрокаОснование,СтруктураЗаполненияСтрокиОснования);
				
				СтруктураЗаполнения = Новый Структура;
				СтруктураЗаполнения.Вставить("ИННКонтрагента",ДокументРодитель.Контрагент.ИНН);
				СтруктураЗаполнения.Вставить("КППКонтрагента",ДокументРодитель.Контрагент.КПП);
				СтруктураЗаполнения.Вставить("КодВидаОперации","01");
				
				ЗаполнитьЗначенияСвойств(ДокументОбъект,СтруктураЗаполнения);
			КонецЕсли;
			// )
		ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Полн = "УНФ1618" Тогда
			//Вероятно, временный костыль: в конфигурации уже убрали реквизит ДокументОснование, но обработчик заполнения на его основании остался.
			//При этом полноценно он больше не работает, сделаем отдельную ветку условия заполнения в данной конфе
			ДокументОбъект.Заполнить(ДокументРодитель);
			
		Иначе
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("ДокументОснование",ДокументРодитель); // УТ11
			ДанныеЗаполнения.Вставить("Ссылка",ДокументРодитель); //УНФ
			ДокументОбъект.Заполнить(ДанныеЗаполнения);
		КонецЕсли;
				
						
		СтруктураЗаполнения = Новый Структура;
		СтруктураЗаполнения.Вставить("Дата",ДокументРодитель.Дата);
		
		СтруктураЗаполнения.Вставить("ДатаВходящегоДокумента",date);
		СтруктураЗаполнения.Вставить("НомерВходящегоДокумента",number);
		
		СтруктураЗаполнения.Вставить("ДатаПервичногоДокумента",date);
		СтруктураЗаполнения.Вставить("НомерПервичногоДокумента",number);
		
		СтруктураЗаполнения.Вставить("НомерЭД",number);
		
		//E1C-487: Казахстан: дата оборота для типа документа ЭСФ
		//2) В связанном СФ поле Дата оборота заполняется значением "turnoverDate".
		//2.1) Дату в Поступлении ТМЦ берем из turnoverDate, а дату СФ на его основании - из даты распознанного документа
		Если ЗначениеЗаполнено(ДанныеДокумента.esfKzTurnoverDate) Тогда
			СтруктураЗаполнения.Вставить("ДатаСовершенияОборотаПоРеализации",ДанныеДокумента.esfKzTurnoverDate);
			СтруктураЗаполнения.Вставить("Дата",ДанныеДокумента.sourceDate);
			СтруктураЗаполнения.Вставить("ДатаВходящегоДокумента",ДанныеДокумента.sourceDate);
		КонецЕсли;
		
		Если Конф = "УТ11" Тогда
			СтруктураЗаполнения.Вставить("Номер",number);
			СтруктураЗаполнения.Вставить("ДатаСоставления",date);
			СтруктураЗаполнения.Вставить("Контрагент",ДокументРодитель.Контрагент);
			
		ИначеЕсли Конф = "КА2" Тогда
			СтруктураЗаполнения.Вставить("Номер",number);
			СтруктураЗаполнения.Вставить("ДатаСоставления",date);
			СтруктураЗаполнения.Вставить("Контрагент",ДокументРодитель.Контрагент);
			
		ИначеЕсли Конф = "ERP" Тогда
			СтруктураЗаполнения.Вставить("Номер",number);
			СтруктураЗаполнения.Вставить("ДатаСоставления",date);
			СтруктураЗаполнения.Вставить("Контрагент",ДокументРодитель.Контрагент);
			
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("НДСПредъявленКВычету",СтруктураНастроек.СозданиеДокумента_СчетФактура_ОтразитьВычетВКнигеПокупок = Истина);
				
		//E1C-88: Если документ прилетел из Диадок - у него будет заполнен статус, указываем код способа получения = 2
		Если ЗначениеЗаполнено(СтруктураЗаполненияДокумента.document.Диадок_Статус) Тогда
			СтруктураЗаполнения.Вставить("КодСпособаПолучения",2);
		Иначе
			СтруктураЗаполнения.Вставить("КодСпособаПолучения",1);
		КонецЕсли;
		
		Комментарий = РеквизитОбъект.ЗаполнениеДокумента_СформироватьКомментарийСПараметрами(АдресХранилищаДанныхПортала,СтруктураЗаполненияДокумента,СтруктураНастроек);
		СтруктураЗаполнения.Вставить("Комментарий",Комментарий);
		
		ЗаполнитьЗначенияСвойств(ДокументОбъект,СтруктураЗаполнения);

	КонецЕсли;
	
	// модуль кастомизации	
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("СчетФактура_ПередЗаписьюДокумента",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
		// ) модуль кастомизации
		
		//E1C-126: Добавлена настройка проверки наличия НДС в заполняемом счете-фактуре
		Если СтруктураНастроек.СозданиеДокумента_СчетФактура_СоздаватьБезНДС <> Истина Тогда
			
			//Определяем по распознанной сумме из документа
			Если СтруктураЗаполненияДокумента.document.vat = Неопределено Тогда
				СуммаНДС = 0;
			Иначе
				Попытка
					СуммаНДС = Число(СтруктураЗаполненияДокумента.document.vat);
				Исключение
					//продолжаем создавать
				КонецПопытки;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СуммаНДС = 0 Тогда
			//Реквизит суммы НДС определили и он равен нулю
			ОписаниеСобытия = "Сумма НДС счета-фактуры к документу <" + ДокументРодитель + "> равна 0, создание счета-фактуры пропущено";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
		Иначе
		// ) 2019.11.27
		
			ОписаниеСобытия = "Выполняется стандартная обработка записи счета-фактуры";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			
			//E1C-512: Не всех устраивает автоматическая установка времени
			Если СтруктураНастроек.ЗаполнениеШапки_УстанавливатьВремяДокументаАвтоматически = Истина Тогда
				//2021.03.22 ( Установим время документа
				ДокументОбъект.УстановитьВремя();
				// ) 2021.03.22
			КонецЕсли;
			
			Попытка
				ДокументОбъект.Записать();
				ДокументСсылка = ДокументОбъект.Ссылка;
				
				ОписаниеСобытия = "<" + ДокументСсылка + ">: документ успешно записан";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			Исключение
				ОписаниеСобытия = "- ошибка при записи счета-фактуры: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
			КонецПопытки;
			
			Если ЗначениеЗаполнено(ДокументСсылка) И ДокументРодитель.Проведен Тогда
				
				Если ДокументСсылка.Проведен Тогда
					ОписаниеСобытия = "- проведение документа <" + ДокументОбъект + "> пропущено: документ уже проведен";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
					
				Иначе
					Попытка
						ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
						
						ОписаниеСобытия = "<" + ДокументСсылка + ">: документ успешно проведен";
						ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
					Исключение
						ОписаниеСобытия = "- ошибка при проведении счета-фактуры: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
						ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
						ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
					КонецПопытки;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		
		//2020.04.07 (
		ПараметрыМК.Вставить("ДокументСсылка",ДокументСсылка);
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("СчетФактура_ПослеЗаписиДокумента",ПараметрыМК);
		// ) 2020.04.07
		
		//EN-370: По настройке устанавливать флаг Оригинал получен
		Если СтруктураНастроек.СозданиеДокумента_УстанавливатьФлагОригиналПолучен = Истина Тогда
			
			ОшибкаУстановкиФлага = УстановитьСтатусДокумента_ОригиналПолучен(ДокументСсылка);
			
			Если ЗначениеЗаполнено(ОшибкаУстановкиФлага) Тогда
				ОписаниеСобытия = "Ошибка при установке флага Оригинал получен для <" + ДокументСсылка + ">: " + КраткоеОписаниеОшибки(ОшибкаУстановкиФлага);
			Иначе
				ОписаниеСобытия = "Флаг Оригинал получен для <" + ДокументСсылка + "> установлен";
			КонецЕсли;
			
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			
		КонецЕсли;
		// ) EN-370
		
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
			
			Если ЗначениеЗаполнено(СвязанныйДокументИД) Тогда
				//Запишем связь с дочерним документом
				ЗаписатьСвязьСДокументомПортала(СвязанныйДокументИД,ДанныеДокумента.spaceId,ДокументСсылка,Неопределено,ТекстОшибки);
				СвязанныйДокумент.ДокументСсылка = ДокументСсылка;
				
				УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,СвязанныйДокументИД);
			
			Иначе
				//Запишем связь с основным документом, только если этот документ Счет-фактура
				Если СтруктураЗаполненияДокумента.document.type = "VAT_INVOICE" Тогда
					ЗаписатьСвязьСДокументомПортала(ДокументИД,ДанныеДокумента.spaceId,ДокументСсылка,Неопределено,ТекстОшибки);
					ДанныеДокумента.ДокументСсылка = ДокументСсылка;
					
					УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,ДокументИД);
				КонецЕсли;
			
			КонецЕсли;
			
		Иначе
			//Исходный вариант, оставляем отображение связи с основным документом
			
		КонецЕсли;		
		
		//По флагу в настройках прикрепляем файла как ПрисоединенныйФайл
		Если СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина Тогда
			
			//2019.10.22 ( обработка события модуля кастомизации
			ПараметрыМК.Вставить("ДокументСсылка",ДокументСсылка);
			ПараметрыМК.Вставить("МассивФайлов",СтруктураЗаполненияДокумента.МассивФайлов);
			ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("СчетФактура_ПередПрисоединениемФайлов",ПараметрыМК);
			ТекстОшибки = ПараметрыМК.ТекстОшибки;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			// ) 2019.10.22
			
				ПрисоединитьФайлы_СканыДокумента(ДокументСсылка,СтруктураЗаполненияДокумента.МассивФайлов,ТекстОшибки);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДокументСсылка;
КонецФункции

&НаСервере
Процедура УстановитьСсылкуДокументаПоИдентификатору(ДокументСсылка,ДокументИД)
	
	НайденныеСтроки = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",ДокументИД));
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		СтрокаДокумента = НайденныеСтроки[0];
		
		СтрокаДокумента.Документ1с = ДокументСсылка;
		
		УведомлениеПорталуОСозданииДокументов_ДобавитьДокумент(ДокументСсылка,ДокументИД);
		
		Если СтрокаДокумента.ДокументСтатус = "EDI_SEND" Тогда
			//E1C-450: Это не касается исходящих ЭДО-документов				
		Иначе
			СтрокаДокумента.ДокументСтатус = "UPLOADED";
			СтрокаДокумента.ПредставлениеСтатуса = "Выгружен";
			СтрокаДокумента.Счетчик_Загружен = 1;
		КонецЕсли;
		
		СтрокаДокумента.Счетчик_Проверен = 0;
		СтрокаДокумента.Счетчик_Распознан = 0;
		
		ОписаниеСобытия = "<" + ДокументСсылка + ">: ссылка для документа (" + ДокументИД + ") успешно установлена";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
	Иначе
		ОписаниеСобытия = "<" + ДокументСсылка + ">: строка для установки связи с документом (" + ДокументИД + ") не найдена";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"Ошибка");
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАналитикуСчетовУчета(НоваяСтрока,СтрокаНоменклатуры,ТипСоздаваемогоДокумента)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	СтруктураТовар = Новый Структура;
	
	//Пока ограничимся только для БП30
	Если Конф = "БП30" Тогда	
		//В зависимости от счета учета размещаем данные об аналитике счета учета в структуре заполнения строки табличной части
		
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.СчетУчетаСсылка) Тогда
			СчетУчетаСсылка = СтрокаНоменклатуры.СчетУчетаСсылка;
			
		Иначе
			//E1C-253: Проверяем, заполнен ли самой конфигурацией счет учета в строке табличной части документа,
			//поскольку мы не знаем, какую табличную часть заполняем - проверим заполнение ключей заданной структуры
			СчетУчетаСтрокиДокумента = Новый Структура("СчетУчета,СчетЗатрат,СчетЗатратБУ");
			ЗаполнитьЗначенияСвойств(СчетУчетаСтрокиДокумента,НоваяСтрока);
			Если ЗначениеЗаполнено(СчетУчетаСтрокиДокумента.СчетУчета) Тогда
				СчетУчетаСсылка = СчетУчетаСтрокиДокумента.СчетУчета;
			ИначеЕсли ЗначениеЗаполнено(СчетУчетаСтрокиДокумента.СчетЗатрат) Тогда
				СчетУчетаСсылка = СчетУчетаСтрокиДокумента.СчетЗатрат;
			ИначеЕсли ЗначениеЗаполнено(СчетУчетаСтрокиДокумента.СчетЗатратБУ) Тогда
				СчетУчетаСсылка = СчетУчетаСтрокиДокумента.СчетЗатратБУ;
			КонецЕсли;
			
		КонецЕсли;
			
		Если ЗначениеЗаполнено(СчетУчетаСсылка) Тогда
		
			//перезаполняем счет учета на выбранный пользователем, так как до этого мы вызывали принудительное заполнение счетов учета и субконто
			СтруктураТовар.Вставить("СчетУчета",СчетУчетаСсылка);
			СтруктураТовар.Вставить("СчетЗатратНУ",СчетУчетаСсылка);
			СтруктураТовар.Вставить("СчетУчетаНДС",СтрокаНоменклатуры.СчетУчетаНДССсылка);

			//2021.12.09 ( Требование-накладная
			Если ТипСоздаваемогоДокумента = "ТребованиеНакладная" Тогда
				СтруктураТовар.Вставить("Счет",СчетУчетаСсылка);
			Иначе
				СтруктураТовар.Вставить("СчетЗатрат",СчетУчетаСсылка);
			КонецЕсли;
			// ) 2021.12.09
			
			//обходим субконто табличной части и заполняем выбранные в форме сопоставления значения 
			//в отраслевых решениях на базе БП30 тип счета учета в конфигурации может быть определен другой, не обрабатываем
			Если (Метаданные.ПланыСчетов.Найти("Хозрасчетный") <> Неопределено И ТипЗнч(СчетУчетаСсылка) = Тип("ПланСчетовСсылка.Хозрасчетный"))
				Или (Метаданные.ПланыСчетов.Найти("Типовой") <> Неопределено И ТипЗнч(СчетУчетаСсылка) = Тип("ПланСчетовСсылка.Типовой")) Тогда
				ИндексСубконто = 0;
				Для Каждого ЭлементВидаСубконто Из СчетУчетаСсылка.ВидыСубконто Цикл
					ИндексСубконто = ИндексСубконто + 1;
					Если Метаданные.Справочники.Найти("СтатьиЗатрат") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.СтатьиЗатрат")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.СтатьяЗатратСсылка) Тогда
						СтруктураТовар.Вставить("Субконто" + ИндексСубконто,СтрокаНоменклатуры.СтатьяЗатратСсылка);
						СтруктураТовар.Вставить("СубконтоНУ" + ИндексСубконто,СтрокаНоменклатуры.СтатьяЗатратСсылка);
						СтруктураТовар.Вставить("СубконтоЗатратБУ" + ИндексСубконто,СтрокаНоменклатуры.СтатьяЗатратСсылка);
						
					//2023.03.15 (
					ИначеЕсли Метаданные.Справочники.Найти("Доходы") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Доходы")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.СтатьяДоходовСсылка) Тогда
						СтруктураТовар.Вставить("СубконтоДоходовБУ" + ИндексСубконто,СтрокаНоменклатуры.СтатьяДоходовСсылка);
						СтруктураТовар.Вставить("СубконтоДоходовНУ" + ИндексСубконто,СтрокаНоменклатуры.СтатьяДоходовСсылка);
					// ) 2023.03.15
						
					ИначеЕсли Метаданные.Справочники.Найти("НоменклатурныеГруппы") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.НоменклатурныеГруппы")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.НоменклатурнаяГруппаСсылка) Тогда
						СтруктураТовар.Вставить("Субконто" + ИндексСубконто,СтрокаНоменклатуры.НоменклатурнаяГруппаСсылка);
						СтруктураТовар.Вставить("СубконтоНУ" + ИндексСубконто,СтрокаНоменклатуры.НоменклатурнаяГруппаСсылка);
						СтруктураТовар.Вставить("СубконтоЗатратБУ" + ИндексСубконто,СтрокаНоменклатуры.НоменклатурнаяГруппаСсылка);
						
					ИначеЕсли Метаданные.Перечисления.Найти("СпособыУчетаНДС") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("ПеречислениеСсылка.СпособыУчетаНДС")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.СпособУчетаНДС) Тогда
						СтруктураТовар.Вставить("Субконто" + ИндексСубконто,СтрокаНоменклатуры.СпособУчетаНДС);
						СтруктураТовар.Вставить("СубконтоНУ" + ИндексСубконто,СтрокаНоменклатуры.СпособУчетаНДС);
						
					ИначеЕсли Метаданные.Справочники.Найти("ПодразделенияОрганизаций") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.ПодразделениеЗатратСсылка) Тогда
						СтруктураТовар.Вставить("Субконто" + ИндексСубконто,СтрокаНоменклатуры.ПодразделениеЗатратСсылка);
						СтруктураТовар.Вставить("СубконтоНУ" + ИндексСубконто,СтрокаНоменклатуры.ПодразделениеЗатратСсылка);
						СтруктураТовар.Вставить("СубконтоЗатратБУ" + ИндексСубконто,СтрокаНоменклатуры.ПодразделениеЗатратСсылка);
						
					//2024.08.07 ( Задача 266190: Склады в субконто
					ИначеЕсли Метаданные.Справочники.Найти("Склады") <> Неопределено
						И ЭлементВидаСубконто.ВидСубконто.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Склады")
						И ЗначениеЗаполнено(СтрокаНоменклатуры.СкладСсылка) Тогда
						СтруктураТовар.Вставить("Субконто" + ИндексСубконто,СтрокаНоменклатуры.СкладСсылка);
						СтруктураТовар.Вставить("СубконтоНУ" + ИндексСубконто,СтрокаНоменклатуры.СкладСсылка);
						СтруктураТовар.Вставить("СубконтоЗатратБУ" + ИндексСубконто,СтрокаНоменклатуры.СкладСсылка);
					// ) 2024.08.07
					
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.СчетУчетаНДССсылка) Тогда
			СтруктураТовар.Вставить("СчетУчетаНДС",СтрокаНоменклатуры.СчетУчетаНДССсылка);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.СпособУчетаНДС) Тогда
			СтруктураТовар.Вставить("СпособУчетаНДС",СтрокаНоменклатуры.СпособУчетаНДС);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаНоменклатуры.ПодразделениеЗатратСсылка) Тогда
			СтруктураТовар.Вставить("ПодразделениеЗатрат",СтрокаНоменклатуры.ПодразделениеЗатратСсылка);
		КонецЕсли;
				
		ЗаполнитьЗначенияСвойств(НоваяСтрока,СтруктураТовар);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция УТ11_ПолучитьВидЦеныПоставщика(ТипЦен,ДокументОбъект)
	
	Если ЗначениеЗаполнено(ТипЦен) Тогда
		ВидЦеныПоставщика = ТипЦен;
	Иначе
		//Вид цены из соглашения
		Если ДокументОбъект.Метаданные().Реквизиты.Найти("Соглашение") <> Неопределено И ЗначениеЗаполнено(ДокументОбъект.Соглашение) Тогда
			Попытка ВидЦеныПоставщика = ДокументОбъект.Соглашение.ВидЦеныПоставщика; Исключение; КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	//Новая вводная: если не определили вид цены поставщика - используем существующую, если она единственная у этого Партнера
	Если Не ЗначениеЗаполнено(ВидЦеныПоставщика) Тогда
		Если Метаданные.Справочники.Найти("ВидыЦенПоставщиков") <> Неопределено Тогда
			Если ДокументОбъект.Метаданные().Реквизиты.Найти("Партнер") <> Неопределено И ЗначениеЗаполнено(ДокументОбъект.Партнер) Тогда
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
				               |	ВидыЦенПоставщиков.Ссылка КАК Ссылка
				               |ИЗ
				               |	Справочник.ВидыЦенПоставщиков КАК ВидыЦенПоставщиков
				               |ГДЕ
				               |	НЕ ВидыЦенПоставщиков.ПометкаУдаления
				               |	И ВидыЦенПоставщиков.ДоступноДляЗакупки
				               |	И ВидыЦенПоставщиков.Владелец = &Владелец";
				
				Запрос.УстановитьПараметр("Владелец",ДокументОбъект.Партнер);
				
				Выборка = Запрос.Выполнить().Выбрать();
				Если Выборка.Количество() = 1 Тогда
					Выборка.Следующий();
					ВидЦеныПоставщика = Выборка.Ссылка;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВидЦеныПоставщика;
	
КонецФункции


