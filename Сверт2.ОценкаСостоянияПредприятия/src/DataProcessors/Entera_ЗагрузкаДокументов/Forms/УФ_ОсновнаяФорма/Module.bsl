&НаКлиенте
Процедура Команда_ИзменитьСтороныДокумента(Команда)
	
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		ПоказатьОповещениеПользователя("Ошибка",,"Не выделены строки с документами для изменения сторон");
	Иначе
		ТекстВопроса = "Для документов в выделенных строках [" + ВыделенныеСтроки.Количество() + "]
			|будут заменены стороны Плательщик-Поставщик, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_ИзменитьСтороныДокумента",ДопПараметры,ТекстВопроса,Кнопки);
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);

	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продолжить_ИзменитьСтороныДокумента(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		МассивИдентификаторов = Новый Массив;
		Для Каждого ИдентификаторСтроки Из ДопПараметры.ВыделенныеСтроки Цикл
			СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
			МассивИдентификаторов.Добавить(СтрокаДокумента.ДокументИД);
		КонецЦикла;
		
		//изменяем данные портала в 1с и данные в форме реестра, формируем запрос с изменениями порталу
		РезультатИзменения = ИзменитьСтороныДокумента_ПодготовитьДанныеДляПортала(МассивИдентификаторов);
		
		Если РезультатИзменения.Успешно Тогда
			Счетчик = 0;
			
			//Формируем запросы порталу, отправляем обновленные данные документов
			Для Каждого ЗапросПорталу Из РезультатИзменения.КоллекцияЗапросов Цикл
		
				ДокументИД = ЗапросПорталу.Ключ;
				ТелоЗапроса = ЗапросПорталу.Значение;
		
				Счетчик = Счетчик + 1;
				Прогресс = Счетчик / РезультатИзменения.КоллекцияЗапросов.Количество() * 100;
				Состояние("Обновление данных документов на портале...",Прогресс);
				
				//отправляем запрос, обновляем данные документа
				МетодAPI = "/api/v1/documents/" + ДокументИД + "/accept?format=xml";
				РезультатЗапроса = ВыполнитьЗапрос("ОбновлениеДанныхДокументов","PUT",МетодAPI,ТелоЗапроса);
				
				Если РезультатЗапроса.Успешно Тогда
					//
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "[" + Строка(ДокументИД) + "]: ошибка при обновлении данных портала" + Символы.ПС + РезультатЗапроса.ТекстОшибки;
					Сообщение.Сообщить();
				КонецЕсли;
				
			КонецЦикла;
		Иначе
			СообщитьСообщение(РезультатИзменения.ТекстОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция ИзменитьСтороныДокумента_ПодготовитьДанныеДляПортала(МассивИдентификаторов)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РезультатИзменения = РеквизитОбъект.ИзменитьСтороныДокумента_ПодготовитьДанныеДляПортала(АдресХранилищаДанныхПортала,МассивИдентификаторов);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	Возврат РезультатИзменения;
КонецФункции


&НаКлиенте
Процедура СписокДокументов_УстановитьСтатус_Выгружен(Команда)
	
	//Статус Выгружен не может быть установлен методом акцептации документа,
	//сформируем задание уведомления по выделенным строкам и отправим запрос о создании документов в 1с
	
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	ОчищаемыеСтроки = Новый Массив;
	
	//Документам, которые уже в статусе Выгружен - снимаем выделение
	СчетчикСтрок = 0;
	Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
		СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если СтрокаДокумента.ДокументСтатус = "UPLOADED" Тогда
			ОчищаемыеСтроки.Добавить(ИдентификаторСтроки);
			СчетчикСтрок = СчетчикСтрок + 1;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ОчищаемаяСтрока Из ОчищаемыеСтроки Цикл
		Элементы.СписокДокументов.ВыделенныеСтроки.Удалить(Элементы.СписокДокументов.ВыделенныеСтроки.Найти(ОчищаемаяСтрока));
	КонецЦикла;
	
	Если СчетчикСтрок > 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Снят выбор документов [" + СчетчикСтрок + "], которые уже в статусе <Выгружен>";
		Сообщение.Сообщить();
	КонецЕсли;
	
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		ПоказатьОповещениеПользователя("Ошибка",,"Не выделены строки с документами для изменения статуса");
	Иначе
		ТекстВопроса = "Для документов в выделенных строках [" + ВыделенныеСтроки.Количество() + "]
			|будет установлен статус <Выгружен>, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_УстановитьСтатусДокумента_Выгружен",ДопПараметры,ТекстВопроса,Кнопки);
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);

	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продолжить_УстановитьСтатусДокумента_Выгружен(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Для Каждого ИдентификаторСтроки Из ДопПараметры.ВыделенныеСтроки Цикл
			СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
			Если ЗначениеЗаполнено(СтрокаДокумента.Документ1с) Тогда
				ДокументСсылка = СтрокаДокумента.Документ1с;
			Иначе
				ДокументСсылка = Неопределено;
			КонецЕсли;
			ЗаданияУведомления.Добавить(ДокументСсылка,СтрокаДокумента.ДокументИД);
		КонецЦикла;
		
		РезультатЗапроса = УведомлениеПорталуОСозданииДокументов_Отправить();
		
		Если РезультатЗапроса.Успешно Тогда
			//+++ изменить статусы нужно также в данных портала
			Для Каждого ИдентификаторСтроки Из ДопПараметры.ВыделенныеСтроки Цикл
				СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
				СтрокаДокумента.ДокументСтатус = "UPLOADED";
				СтрокаДокумента.ПредставлениеСтатуса = "Выгружен";
				
				СтрокаДокумента.Счетчик_Загружен = 1;
				СтрокаДокумента.Счетчик_Проверен = 0;
				СтрокаДокумента.Счетчик_Распознан = 0;
			КонецЦикла;
			
			ПересчитатьИтогиПоСтатусамДокументов();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура СписокДокументов_УстановитьСтатус_Проверен(Команда)
	
	//Изначально метод планировался как общий для изменения на любой статус, в соответствии с описанием метода в задаче,
	//но описание оказалось некорректным и данным методом может быть установлен только статус VERIFIED
	Статус = Новый Структура("Статус,ПредставлениеСтатуса","VERIFIED","Проверен");
	
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	ОчищаемыеСтроки = Новый Массив;
	
	//Дополнительное описание задачи: установить статус VERIFIED можно только для документов в статусе RECOGNIZED
	СчетчикСтрок = 0;
	Для Каждого ИдентификаторСтроки Из ВыделенныеСтроки Цикл
		СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если СтрокаДокумента.ДокументСтатус <> "RECOGNIZED" Тогда
			ОчищаемыеСтроки.Добавить(ИдентификаторСтроки);
			СчетчикСтрок = СчетчикСтрок + 1;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ОчищаемаяСтрока Из ОчищаемыеСтроки Цикл
		Элементы.СписокДокументов.ВыделенныеСтроки.Удалить(Элементы.СписокДокументов.ВыделенныеСтроки.Найти(ОчищаемаяСтрока));
	КонецЦикла;
	
	Если СчетчикСтрок > 0 Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Установить статус <Проверен> можно только для документов в статусе <Распознан>, снят выбор документов [" + СчетчикСтрок + "], не соответствующих данному условию";
		Сообщение.Сообщить();
	КонецЕсли;
	
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		ПоказатьОповещениеПользователя("Ошибка",,"Не выделены строки с документами для изменения статуса");
	Иначе
		ТекстВопроса = "Для документов в выделенных строках [" + ВыделенныеСтроки.Количество() + "]
			|будет установлен статус <" + Статус.ПредставлениеСтатуса + ">, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("Статус",Статус);
		ДопПараметры.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_УстановитьСтатусДокумента",ДопПараметры,ТекстВопроса,Кнопки);
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);

	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продолжить_УстановитьСтатусДокумента(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		МассивИдентификаторов = Новый Массив;
		Для Каждого ИдентификаторСтроки Из ДопПараметры.ВыделенныеСтроки Цикл
			СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
			МассивИдентификаторов.Добавить(СтрокаДокумента.ДокументИД);
		КонецЦикла;
		
		//изменяем данные портала в 1с и данные в форме реестра, формируем запрос с изменениями порталу
		РезультатИзменения = УстановитьСтатусДокумента_ПодготовитьДанныеДляПортала(МассивИдентификаторов,ДопПараметры.Статус);
		
		Если РезультатИзменения.Успешно Тогда
			Счетчик = 0;
			
			//Формируем запросы порталу, отправляем обновленные данные документов
			Для Каждого ЗапросПорталу Из РезультатИзменения.КоллекцияЗапросов Цикл
		
				ДокументИД = ЗапросПорталу.Ключ;
				ТелоЗапроса = ЗапросПорталу.Значение;
		
				Счетчик = Счетчик + 1;
				Прогресс = Счетчик / РезультатИзменения.КоллекцияЗапросов.Количество() * 100;
				Состояние("Обновление данных документов на портале...",Прогресс);
				
				//отправляем запрос, обновляем данные документа
				МетодAPI = "/api/v1/documents/" + ДокументИД + "/accept?format=xml";
				РезультатЗапроса = ВыполнитьЗапрос("ОбновлениеДанныхДокументов","PUT",МетодAPI,ТелоЗапроса);
				
				Если РезультатЗапроса.Успешно Тогда
					//
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "[" + Строка(ДокументИД) + "]: ошибка при обновлении данных портала" + Символы.ПС + РезультатЗапроса.ТекстОшибки;
					Сообщение.Сообщить();
				КонецЕсли;
				
			КонецЦикла;
			
			ПересчитатьИтогиПоСтатусамДокументов();
			
		Иначе
			СообщитьСообщение(РезультатИзменения.ТекстОшибки);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция УстановитьСтатусДокумента_ПодготовитьДанныеДляПортала(МассивИдентификаторов,Статус)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РезультатИзменения = РеквизитОбъект.УстановитьСтатусДокумента_ПодготовитьДанныеДляПортала(АдресХранилищаДанныхПортала,МассивИдентификаторов,Статус);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	Возврат РезультатИзменения;
КонецФункции


&НаКлиенте
Процедура Команда_ОбъединитьВКомплект(Команда)
	
	//Объединение комплектов выполняется попарно, должно быть выбрано 2 строки документов
	ВыделенныеСтроки = Элементы.СписокДокументов.ВыделенныеСтроки;
	Если ВыделенныеСтроки.Количество() <> 2 Тогда
		ПоказатьОповещениеПользователя("Ошибка",,"Выделите две строки объединяемых в комплект документов");
		Возврат;
	КонецЕсли;
	
	//E1C-8: Необходимо проверить суммы документов и типы: один из документов должен быть счет-фактура, другой - акт или накладная
	Строка1 = Объект.СписокДокументов.НайтиПоИдентификатору(ВыделенныеСтроки[0]);
	Строка2 = Объект.СписокДокументов.НайтиПоИдентификатору(ВыделенныеСтроки[1]);
			
	Если Строка1.ДокументТип = "UTD" Или Строка2.ДокументТип = "UTD" Тогда
		ПоказатьОповещениеПользователя("Ошибка",,"Документ УПД невозможно объединить в комплект");
		
	ИначеЕсли (Строка1.ДокументТип = "VAT_INVOICE" И Строка2.ДокументТип = "TORG12"
		Или Строка1.ДокументТип = "VAT_INVOICE" И Строка2.ДокументТип = "CERTIFICATE")
		Или (Строка2.ДокументТип = "VAT_INVOICE" И Строка1.ДокументТип = "TORG12"
		Или Строка2.ДокументТип = "VAT_INVOICE" И Строка1.ДокументТип = "CERTIFICATE") Тогда
				
		//Все ок, можно объединять
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
		
		Различия = Новый Массив;
		
		//Если суммы документов различаются - необходимо будет выдать вопрос пользователю
		Если Строка1.СуммаДокумента <> Строка2.СуммаДокумента Тогда
			Различия.Добавить("Суммы");
		КонецЕсли;
		
		Если Строка1.ПредставлениеПлательщика <> Строка2.ПредставлениеПлательщика Тогда
			Различия.Добавить("Плательщики");
		КонецЕсли;
		
		Если Строка1.ПредставлениеПоставщика <> Строка2.ПредставлениеПоставщика Тогда
			Различия.Добавить("Поставщики");
		КонецЕсли;
		
		ДопПараметры.Вставить("Различия",Различия);
		
		ТекстВопроса = "Документы " + Строка1.ПредставлениеДокумента + " и " + Строка2.ПредставлениеДокумента + "
			|будут объединены в комплект, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продожить_СписокДокументов_ПроверкаСуммы",ДопПараметры,ТекстВопроса,Кнопки);
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		
	Иначе
		//Не соответствуют типы
		ПоказатьОповещениеПользователя("Ошибка",,"Объединить в комплект можно Накладную/Акт и Счет-фактуру");
		
	КонецЕсли;	
	
КонецПроцедуры
&НаКлиенте
Процедура Продожить_СписокДокументов_ПроверкаСуммы(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		Если ДопПараметры.Различия.Количество() > 0 Тогда
			
			ТекстРазличия = "";
			Для Каждого ЭлементМассива Из ДопПараметры.Различия Цикл
				ТекстРазличия = ТекстРазличия + ЭлементМассива;
				ТекстРазличия = ТекстРазличия + ?(ДопПараметры.Различия.Найти(ЭлементМассива) = ДопПараметры.Различия.ВГраница(),"",", ");
			КонецЦикла;
			
			ТекстВопроса = ТекстРазличия + " объединяемых документов различаются, продолжить?";
			Кнопки = РежимДиалогаВопрос.ДаНет;
			
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продожить_СписокДокументов_ОбъединениеКомплекта",ДопПараметры,ТекстВопроса,Кнопки);
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
			
		Иначе
			//Все ок, продолжаем
			Продожить_СписокДокументов_ОбъединениеКомплекта(КодВозвратаДиалога.Да,ДопПараметры);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продожить_СписокДокументов_ОбъединениеКомплекта(Результат,ДопПараметры)
	Если Результат = КодВозвратаДиалога.Да Тогда
		Комплекты_ОбъединениеКомплекта(ДопПараметры.ВыделенныеСтроки);
		
		ПоказатьОповещениеПользователя("Успешно",,"Связь комплектов установлена");
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура Комплекты_ОбъединениеКомплекта(МассивИдентификаторовСтрок)
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	//связь должна храниться как в children, так и в parent	
	Строка1 = Объект.СписокДокументов.НайтиПоИдентификатору(МассивИдентификаторовСтрок[0]);
	Строка2 = Объект.СписокДокументов.НайтиПоИдентификатору(МассивИдентификаторовСтрок[1]);
		
	Если Строка1.ДокументТип = "VAT_INVOICE" Тогда
		//заполняем для этого документа parent, родительскому документу - children
		
		Строка1.parentId = Строка2.ДокументИД;
		Строка2.childrenId = Строка1.ДокументИД;
		
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(Строка1.ДокументИД,"id");
		ДанныеДокументаПортала.parent = Строка2.ДокументИД;
		
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(Строка2.ДокументИД,"id");
		ДанныеДокументаПортала.children = Строка1.ДокументИД;
		
	Иначе
		//заполняем для этого документа children, родительскому документу - parent
		Строка1.childrenId = Строка2.ДокументИД;
		Строка2.parentId = Строка1.ДокументИД;
		
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(Строка1.ДокументИД,"id");
		ДанныеДокументаПортала.children = Строка2.ДокументИД;
		
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(Строка2.ДокументИД,"id");
		ДанныеДокументаПортала.parent = Строка1.ДокументИД;
		
	КонецЕсли;
				
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
КонецПроцедуры

&НаКлиенте
Процедура Команда_РазъединитьКомплект(Команда)
	
	Если Элементы.СписокДокументов.ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ВыделенныеСтроки",Элементы.СписокДокументов.ВыделенныеСтроки);
	ТекстВопроса = "Существующая связь комплектов документов (Накладная/акт + Счет-фактура)
				   |в выделенных строках будет очищена, продолжить?";
	Кнопки = РежимДиалогаВопрос.ДаНет;
	
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продожить_СписокДокументов_РазъединениеКомплекта",ДопПараметры,ТекстВопроса,Кнопки);
	_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);

КонецПроцедуры
&НаКлиенте
Процедура Продожить_СписокДокументов_РазъединениеКомплекта(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		Комплекты_РазъединениеКомплекта(ДопПараметры.ВыделенныеСтроки);
		
		ПоказатьОповещениеПользователя("Успешно",,"Связь комплектов очищена");
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура Комплекты_РазъединениеКомплекта(МассивИдентификаторовСтрок)
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	//связь может храниться как в children, так и в parent, необходимо очистить связь в обоих документах
	Для Каждого ИдентификаторСтроки Из МассивИдентификаторовСтрок Цикл
		
		СтрокаТаблицы = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		parentId = СтрокаТаблицы.parentId;
		childrenId = СтрокаТаблицы.childrenId;
		
		Если ЗначениеЗаполнено(parentId) Тогда
			//Очищаем ссылку на parent у документа списка и в данных портала
			СтрокаТаблицы.parentId = "";
			ДанныеДокументаПортала = ДанныеПортала.documents.Найти(СтрокаТаблицы.ДокументИД,"id");
			Если ДанныеДокументаПортала <> Неопределено Тогда
				ДанныеДокументаПортала.parent = "";
			КонецЕсли;
			
			//Очищаем связь комплектов у связанных с текущим документов
			НайденныеСтроки = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",parentId));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.childrenId = "";
			КонецЦикла;
			
			//Очищаем связь комплектов у связанных с текущим документов
			НайденныеСтроки = ДанныеПортала.documents.НайтиСтроки(Новый Структура("id",parentId));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.children = "";
			КонецЦикла;
		
		КонецЕсли;
		
		Если ЗначениеЗаполнено(childrenId) Тогда
			//Очищаем ссылку на children у документа списка и в данных портала
			СтрокаТаблицы.childrenId = "";
			ДанныеДокументаПортала = ДанныеПортала.documents.Найти(СтрокаТаблицы.ДокументИД,"id");
			Если ДанныеДокументаПортала <> Неопределено Тогда
				ДанныеДокументаПортала.children = "";
			КонецЕсли;
			
			//Очищаем связь комплектов у связанных с текущим документов
			НайденныеСтроки = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",childrenId));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.parentId = "";
			КонецЦикла;
			
			//Очищаем связь комплектов у связанных с текущим документов
			НайденныеСтроки = ДанныеПортала.documents.НайтиСтроки(Новый Структура("id",childrenId));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.parent = "";
			КонецЦикла;
		КонецЕсли;
			
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
КонецПроцедуры

&НаКлиенте
Процедура Команда_ПрисоединитьФайлСканаКДокументу(Команда)
	
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекСтрока.Документ1с) Тогда
			
			//Получаем печатную форму PDF
			РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(ТекСтрока.ДокументИД,ТекСтрока.ПредставлениеДокумента);
			Если РезультатЗапроса.Успешно Тогда
				
				Если РезультатЗапроса.ТребуетсяПовтор Тогда
					СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
				Иначе
					ТекСтрока.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
					ТекСтрока.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
					
					Массив = Новый Массив;
					СтруктураФайла = Новый Структура("АдресВХ,ИмяФайла",РезультатЗапроса.АдресВХ,РезультатЗапроса.ИмяФайла);
					Массив.Добавить(СтруктураФайла);
					
					ТекстОшибки = "";
					ПрисоединитьФайлы_СканыДокумента(ТекСтрока.Документ1с,Массив,ТекстОшибки);
					
					Если ЗначениеЗаполнено(ТекстОшибки) Тогда
						СообщитьСообщение(ТекстОшибки);
					Иначе
						Попытка КартинкаУспешно = БиблиотекаКартинок.Успешно32; Исключение; КонецПопытки;
						ПоказатьОповещениеПользователя("Успешно",,"Файл скана прикреплен к документу",КартинкаУспешно);
					КонецЕсли;
				КонецЕсли;
			Иначе
				СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
			КонецЕсли;			
			
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Не заполнен документ, к которому будет прикреплен скан";
			Сообщение.Поле = "Объект.СписокДокументов[" + ТекСтрока.ПолучитьИдентификатор() + "].Документ1с";
			Сообщение.Сообщить();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПоискСуществующихДокументов_ЗаполнитьМенюСпискаТиповДокументов()
	
	//E1C-149: новая команда-подменю контекстного меню списка документов для поиска существующего документа
	СписокТиповДокументов = СтруктураНастроек.СведенияОКонфигурации.ТипыЗаполняемыхДокументов.Скопировать();
	
	//E1C-312: также в список тех документов, с которыми могут быть связаны распознанные документы нужно добавить
	//счета-фактуры, они отсутствуют в этом списке, так как не создаются по скану как отдельный документ, а вводятся по основному документу
	ДобавляемыйДокумент = Метаданные.Документы.Найти("СчетФактураПолученный");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	
	ДобавляемыйДокумент = Метаданные.Документы.Найти("СчетФактураВыданный");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	// ) E1C-312
	
	ДобавляемыйДокумент = Метаданные.Документы.Найти("КорректировкаПриобретения");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	
	//E1C-468
	ДобавляемыйДокумент = Метаданные.Документы.Найти("ПоступлениеНМА");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	
	//2025.07.28 (
	ДобавляемыйДокумент = Метаданные.Документы.Найти("_АктСверкиВзаиморасчетов");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	// ) 2025.07.28
	
	//2025.09.25 (
	ДобавляемыйДокумент = Метаданные.Документы.Найти("ПеремещениеТоваров");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить(ДобавляемыйДокумент.Имя,ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	// ) 2025.09.25
	
	//E1C-447: Прикрепление скана документа к Договору с контрагентом
	ДобавляемыйДокумент = Метаданные.Справочники.Найти("ДоговорыКонтрагентов");
	Если ДобавляемыйДокумент <> Неопределено Тогда
		СписокТиповДокументов.Добавить("Справочник_" + ДобавляемыйДокумент.Имя,"Справочник: " + ДобавляемыйДокумент.Синоним);
	КонецЕсли;
	
	Если Элементы.Найти("СписокДокументовКонтекстноеМеню_ПоискСуществующихДокументов") <> Неопределено Тогда
		Элемент_ГруппаПодменю = Элементы.СписокДокументовКонтекстноеМеню_ПоискСуществующихДокументов;
		Для Каждого ЭлементСписка Из СписокТиповДокументов Цикл
			ИмяКоманды = "ИмяТипаДокумента_" + ЭлементСписка.Значение;
			ДобавитьКнопкуНаФорму(ЭтаФорма,ИмяКоманды,ИмяКоманды,ЭлементСписка.Представление,"ПоискСуществующихДокументов_ВыборТипаДокумента",Элемент_ГруппаПодменю);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПоискСуществующихДокументов_ВыборТипаДокумента(Команда)
	
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(ТекСтрока.Документ1с) Тогда
			Попытка КартинкаОшибка = БиблиотекаКартинок.Остановить; Исключение; КонецПопытки;
			ПоказатьОповещениеПользователя("Ошибка",,"Соответствие уже установлено",КартинкаОшибка);
			
		Иначе
	
			ТипСуществующегоДокумента = СтрЗаменить(Команда.Имя,"ИмяТипаДокумента_","");
			
			Если Найти(ТипСуществующегоДокумента,"Справочник_") > 0 Тогда
				ТипСуществующегоДокумента = СтрЗаменить(ТипСуществующегоДокумента,"Справочник_","");
				РазделМетаданных = "Справочник";
			Иначе
				РазделМетаданных = "Документ";
			КонецЕсли;
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("РежимВыбора",Истина);
			ПараметрыОткрытия.Вставить("КлючНазначенияИспользования","Энтера_ВыборСуществующегоДокумента");
			
			Попытка
				ФормаВыбора = ПолучитьФорму(РазделМетаданных + "." + ТипСуществующегоДокумента + ".ФормаВыбора",ПараметрыОткрытия,ЭтаФорма);
				ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
				ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			Исключение
				Попытка КартинкаОшибка = БиблиотекаКартинок.Остановить; Исключение; КонецПопытки;
				ПоказатьОповещениеПользователя("Ошибка",,"Не удалось получить форму выбора документа",КартинкаОшибка);
			КонецПопытки;
			
			Если ФормаВыбора <> Неопределено Тогда
				ДопПараметры = Новый Структура;
				ДопПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
				ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ФормаВыбора","ПоискСуществующихДокументов_ВыборДокумента",ДопПараметры,ФормаВыбора);
				
				_ЗФ_ОбработатьАсинхронныйВызов("ВыбратьЭлементИзФормыВыбора",ПараметрыВызова);
			КонецЕсли;
			
		КонецЕсли;		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПоискСуществующихДокументов_ВыборДокумента(Результат,ДопПараметры)
	
	Если Результат <> Неопределено Тогда
		ТекСтрока = Объект.СписокДокументов.НайтиПоИдентификатору(ДопПараметры.ИдентификаторСтроки);
		
		Если ТекСтрока <> Неопределено Тогда
			ТекСтрока.Документ1с = Результат;
			ТекстОшибки = "";
			ЗаписатьСвязьСДокументомПортала(ТекСтрока.ДокументИД,ТекСтрока.ПространствоИД,ТекСтрока.Документ1с,Неопределено,ТекстОшибки);
			
			Если ЗначениеЗаполнено(ТекстОшибки) Тогда
				СообщитьСообщение(ТекстОшибки);
			КонецЕсли;
			
			//Если включена настройка - прикрепляем скан к документу
			Если СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина Тогда
				
				//Получаем печатную форму PDF
				РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(ТекСтрока.ДокументИД,ТекСтрока.ПредставлениеДокумента);
				Если РезультатЗапроса.Успешно Тогда
					
					Если РезультатЗапроса.ТребуетсяПовтор Тогда
						СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
					Иначе
						ТекСтрока.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
						ТекСтрока.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
						
						Массив = Новый Массив;
						СтруктураФайла = Новый Структура("АдресВХ,ИмяФайла",РезультатЗапроса.АдресВХ,РезультатЗапроса.ИмяФайла);
						Массив.Добавить(СтруктураФайла);
						
						ТекстОшибки = "";
						ПрисоединитьФайлы_СканыДокумента(ТекСтрока.Документ1с,Массив,ТекстОшибки);
						
						Если ЗначениеЗаполнено(ТекстОшибки) Тогда
							СообщитьСообщение(ТекстОшибки);
						Иначе
							Попытка КартинкаУспешно = БиблиотекаКартинок.Успешно32; Исключение; КонецПопытки;
							ПоказатьОповещениеПользователя("Успешно",,"Файл скана прикреплен к документу",КартинкаУспешно);
						КонецЕсли;
					КонецЕсли;
				Иначе
					СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
				КонецЕсли;
			КонецЕсли;
			
			//E1C-479: Передача статуса выгрузки документа из 1С на портал при выполнении связывания с существующим документов 1С
			ВыделенныеСтроки = Новый Массив;
			ВыделенныеСтроки.Добавить(ТекСтрока.ПолучитьИдентификатор());
			
			ПараметрыУстановкиСтатуса = Новый Структура;
			ПараметрыУстановкиСтатуса.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
			Продолжить_УстановитьСтатусДокумента_Выгружен(КодВозвратаДиалога.Да,ПараметрыУстановкиСтатуса);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИзменитьТипДокументаПортала_ЗаполнитьМенюСпискаТиповДокументов()
	
	//E1C-149: новая команда-подменю контекстного меню списка документов для поиска существующего документа
	Элемент_ГруппаПодменю = Элементы.СписокДокументов_КонтекстноеМеню_ИзменитьТипДокументаПортала;
	Если Элемент_ГруппаПодменю.ПодчиненныеЭлементы.Количество() = 0 Тогда
		Для Каждого ЭлементСписка Из СправочникиПортала.ТипДокумента Цикл
			ИмяКоманды = "ТипДокументаПортала_" + ЭлементСписка.Ключ;
			ДобавитьКнопкуНаФорму(ЭтаФорма,ИмяКоманды,ИмяКоманды,ЭлементСписка.Значение,"ИзменитьТипДокументаПортала_ВыборТипаДокумента",Элемент_ГруппаПодменю);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ИзменитьТипДокументаПортала_ВыборТипаДокумента(Команда)
	
	МассивИдентификаторов = Элементы.СписокДокументов.ВыделенныеСтроки;			
	
	Если МассивИдентификаторов.Количество() > 0 Тогда
		НовыйТипДокумента = СтрЗаменить(Команда.Имя,"ТипДокументаПортала_","");
		
		ИзменитьТипДокументаПортала_НаСервере(МассивИдентификаторов,НовыйТипДокумента);	
		
		//Обновим отбор строк, может быть установлен отбор по типу документа
		БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам();
		УстановитьОтборСтрокСпискаДокументов();
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура ИзменитьТипДокументаПортала_НаСервере(МассивИдентификаторов,НовыйТипДокумента)
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	ПредставлениеТипа = СправочникиПортала.ТипДокумента.Получить(НовыйТипДокумента);
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Для Каждого ИдентификаторСтроки Из МассивИдентификаторов Цикл
		
		ТекСтрока = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(ТекСтрока.ДокументИД,"id");
		
		Если ДанныеДокументаПортала <> Неопределено Тогда
			
			//Обновим данные, полученные от портала
			ДанныеДокументаПортала.type = НовыйТипДокумента;
			ДанныеДокументаПортала.ПредставлениеТипа = ПредставлениеТипа;
			
			ПредставлениеДокумента = РеквизитОбъект.СформироватьПредставлениеДокументаПортала(ДанныеДокументаПортала);
			ДанныеДокументаПортала.ПредставлениеДокумента = ПредставлениеДокумента;
			
			//Обновляем отображение в данных формы
			ТекСтрока.ДокументТип = НовыйТипДокумента;
			ТекСтрока.ПредставлениеТипа = ПредставлениеТипа;
			ТекСтрока.ПредставлениеДокумента = ПредставлениеДокумента;
		
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);	
	
КонецПроцедуры


&НаКлиенте
Процедура Отбор_ПространствоОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Если ВыбранноеЗначение <> Отбор_Пространство Тогда
		ПоказатьОповещениеПользователя("Пространство изменено",,"Нажмите кнопку Обновить для актуализации данных");
		
		// 2020.07.14 ( очистим существующие задания распознавания, оставшиеся по старому пространству
		ЗаданияРаспознавания_Таблица.Очистить();
		// ) 2020.07.14
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура Отбор_ПространствоПриИзменении(Элемент)
	
	УстановитьОтборСтрокСпискаДокументов();
	ЗаполнитьНастройки();
	
	//Сохраним выбранное значение пространства
	Отбор_Пространство_СохранитьВыбранноеЗначение(Отбор_Пространство);
	
	//Обновляем баланс страниц
	ОбновитьТекстКнопкиБаланс();
	
	//Определяем регион пространства
	РегионПространства = ДанныеПользователя.spaceCountries.Получить(Отбор_Пространство);
	СтруктураНастроек.Вставить("РегионПространства",РегионПространства);
	
	//Обновляем справочники выбора Плательщика/Поставщика для выбранного пространства
	ЗаполнитьСправочникиПортала();
	
	
	//Очищаем плательщиков и поставщиков, которых нет в новом пространстве
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементСписка Из Отбор_Плательщик Цикл
		Если Элементы.Отбор_Плательщик.СписокВыбора.НайтиПоЗначению(ЭлементСписка.Значение) = Неопределено Тогда
			МассивУдаляемых.Добавить(ЭлементСписка);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементМассива Из МассивУдаляемых Цикл
		Отбор_Плательщик.Удалить(ЭлементМассива);
	КонецЦикла;
	
	МассивУдаляемых = Новый Массив;
	Для Каждого ЭлементСписка Из Отбор_Поставщик Цикл
		Если Элементы.Отбор_Поставщик.СписокВыбора.НайтиПоЗначению(ЭлементСписка.Значение) = Неопределено Тогда
			МассивУдаляемых.Добавить(ЭлементСписка);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ЭлементМассива Из МассивУдаляемых Цикл
		Отбор_Поставщик.Удалить(ЭлементМассива);
	КонецЦикла;
	
	
	// 2019.08.03 ( Добавлен Стартовый помощник, открываем, если не пустое пространство и для его настроек установлен флаг "Открывать помощник"
	Если ЗначениеЗаполнено(Отбор_Пространство) И СтруктураНастроек.СистемныеНастройки_ОткрыватьСтартовыйПомощник = Истина Тогда
		ПодключитьОбработчикОжидания("ОткрытьФорму_СтартовыйПомощник",0.1,Истина);
	КонецЕсли;
	// ) 2019.08.03
	
КонецПроцедуры
&НаСервереБезКонтекста
Процедура Отбор_Пространство_СохранитьВыбранноеЗначение(Отбор_Пространство)
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","ПоследнееРабочееПространство",Отбор_Пространство);
КонецПроцедуры

