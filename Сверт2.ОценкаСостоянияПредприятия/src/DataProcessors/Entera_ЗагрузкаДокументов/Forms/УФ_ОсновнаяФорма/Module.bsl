	Если Результат <> Неопределено Тогда
		Если Результат.Значение = "Выход" Тогда
		
			//очистить загруженные данные
			Объект.СписокДокументов.Очистить();
			ПоместитьВоВременноеХранилище(Неопределено,АдресХранилищаДанныхПортала);
			
			Токен = "";
			Элементы.Авторизация.Заголовок = "Авторизация";
			
			Отбор_Пространство = "";
			Элементы.Отбор_Пространство.СписокВыбора.Очистить();
			
			ПересчитатьИтогиПоСтатусамДокументов();
			ОбновитьТекстКнопкиБаланс();
			
			ОткрытьФормуАвторизации(Ложь);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

