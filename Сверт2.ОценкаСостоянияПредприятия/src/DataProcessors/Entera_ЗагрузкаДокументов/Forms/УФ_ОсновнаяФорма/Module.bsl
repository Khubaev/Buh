&НаКлиенте
Процедура Техподдержка_Помощь(Команда)
	
	ДопПараметры = Новый Структура;
	
	Попытка КартинкаПочта = БиблиотекаКартинок.Обсуждения; Исключение КонецПопытки;
	Попытка КартинкаБазаЗнаний = БиблиотекаКартинок.Справка; Исключение КонецПопытки;
	Попытка КартинкаКупить = БиблиотекаКартинок.РегистрНакопления; Исключение КонецПопытки;
	
	СписокВыбора = Новый СписокЗначений;
	СписокВыбора.Добавить("СоздатьОбращение","Создать обращение",,КартинкаПочта);
	СписокВыбора.Добавить("БазаЗнаний","База знаний",,КартинкаБазаЗнаний);
	СписокВыбора.Добавить("Купить","Купить",,КартинкаКупить);
		
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,СписокВыбора,ЭлементФормы","Техподдержка_Помощь_ОбработатьВыборИзМеню",ДопПараметры,СписокВыбора,Элементы.Техподдержка_Помощь);
	
	_ЗФ_ОбработатьАсинхронныйВызов("ВыборИзМеню",ПараметрыВызова);
	
КонецПроцедуры
&НаКлиенте
Процедура Техподдержка_Помощь_ОбработатьВыборИзМеню(Результат,ДопПараметры)
	
	Если Результат = Неопределено Тогда
	
	ИначеЕсли Результат.Значение = "СоздатьОбращение" Тогда
		ТехподдержкаЭлектроннаяПочтаНажатие(Неопределено);
		
	ИначеЕсли Результат.Значение = "БазаЗнаний" Тогда
		_ЗФ_Команда_ПерейтиПоСсылке("https://entera.pro/knowledge_base");
		
	ИначеЕсли Результат.Значение = "Купить" Тогда
		ПараметрыОткрытия = Новый Структура;
		ПараметрыОткрытия.Вставить("ЗаявкаНаПокупку");
		
		Если ДанныеПользователя <> Неопределено Тогда
			ПараметрыОткрытия.Вставить("НомерТелефона",ДанныеПользователя.phone);
		КонецЕсли;
		
		ФормаПодтверждения = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ПодтверждениеТелефона", ПараметрыОткрытия, ЭтаФорма);
		ФормаПодтверждения.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;
		ФормаПодтверждения.ЗакрыватьПриЗакрытииВладельца = Истина;
		ФормаПодтверждения.Открыть();
		
	КонецЕсли;
	
КонецПроцедуры


