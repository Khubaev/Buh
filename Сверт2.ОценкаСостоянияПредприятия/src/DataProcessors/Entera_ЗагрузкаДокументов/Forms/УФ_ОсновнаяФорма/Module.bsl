// ================= Протокол работы ===================

&НаКлиенте
Процедура Команда_ВыгрузитьПротокол(Команда)
	
	РезультатВыгрузки = Команда_ВыгрузитьПротоколНаСервере();
	
	Если РезультатВыгрузки.Успешно Тогда
		ИмяФайла = "ENTERA_" + Формат(ТекущаяДата(),"ДФ=yyyy-MM-dd_HH-mm") + ".log";
		ПолучитьФайл(РезультатВыгрузки.АдресВХ,ИмяФайла,Истина);
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
		Сообщение.Текст = "Ошибка при формировании протокола работы: " + РезультатВыгрузки.ТекстОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция Команда_ВыгрузитьПротоколНаСервере()
	
	Результат = Новый Структура("Успешно,АдресВХ,ТекстОшибки",Истина);
		
	НастройкиДляВыгрузки = СтруктураНастроек;
	
	//удалим из выгрузки данные авторизации
	Если НастройкиДляВыгрузки.Свойство("Логин") Тогда
		НастройкиДляВыгрузки.Удалить("Логин");
	КонецЕсли;
	Если НастройкиДляВыгрузки.Свойство("Пароль") Тогда
		НастройкиДляВыгрузки.Удалить("Пароль");
	КонецЕсли;
	
	//И данные о статусах ЭДО-документов и синонимах ЕИ, они там лишние
	Если НастройкиДляВыгрузки.Свойство("Диадок_СоответствиеСтатусов") Тогда
		НастройкиДляВыгрузки.Удалить("Диадок_СоответствиеСтатусов");
	КонецЕсли;
	Если НастройкиДляВыгрузки.Свойство("СБИС_СоответствиеСтатусов") Тогда
		НастройкиДляВыгрузки.Удалить("СБИС_СоответствиеСтатусов");
	КонецЕсли;
	Если НастройкиДляВыгрузки.Свойство("КодыТиповДокументов") Тогда
		НастройкиДляВыгрузки.Удалить("КодыТиповДокументов");
	КонецЕсли;
	Если НастройкиДляВыгрузки.Свойство("ИсточникиДокументов") Тогда
		НастройкиДляВыгрузки.Удалить("ИсточникиДокументов");
	КонецЕсли;
	Если НастройкиДляВыгрузки.Свойство("СловарьСинонимовЕИ") Тогда
		НастройкиДляВыгрузки.Удалить("СловарьСинонимовЕИ");
	КонецЕсли;	
	
	//сформируем структуру необходимых для анализа данных
	ДанныеДляАнализа = Новый Структура;
	ДанныеДляАнализа.Вставить("ОписаниеКонфигурации",ПолучитьТекстовоеОписаниеКонфигурации());
	ДанныеДляАнализа.Вставить("СтруктураНастроек",НастройкиДляВыгрузки);
	ДанныеДляАнализа.Вставить("Протокол",Объект.ПротоколРаботы.Выгрузить());
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(ЗначениеВСтрокуВнутр(ДанныеДляАнализа));
	
	ИмяВременногоФайла = ПолучитьИмяВременногоФайла();
	
	Попытка
		ТекстовыйДокумент.Записать(ИмяВременногоФайла);
		Результат.АдресВХ = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяВременногоФайла),УникальныйИдентификатор);
	Исключение
		Результат.Успешно = Ложь;
		Результат.ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	//Прибираемся
	Попытка УдалитьФайлы(ИмяВременногоФайла); Исключение; КонецПопытки;
	
	Возврат Результат;
	
КонецФункции
&НаСервере
Функция ПолучитьТекстовоеОписаниеКонфигурации() Экспорт
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ОписаниеКонфигурации = РеквизитОбъект.ПолучитьТекстовоеОписаниеКонфигурации(СтруктураНастроек);
				
	Возврат ОписаниеКонфигурации;
	
КонецФункции
