&НаСервере
Процедура ЗаполнитьИдентификаторыОбъединенияДокументов(ДопПараметры)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РеквизитОбъект.ЗаполнитьИдентификаторыОбъединенияДокументов(АдресХранилищаДанныхПортала,ДопПараметры);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
КонецПроцедуры
&НаСервере
Функция ПолучитьСтруктуруОбъединенныхДанныхЗаполненияДокумента(ИдентификаторОбъединения,ДопПараметры)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Возврат РеквизитОбъект.ПолучитьСтруктуруОбъединенныхДанныхЗаполненияДокумента(АдресХранилищаДанныхПортала,ИдентификаторОбъединения,СтруктураНастроек,ДопПараметры);
КонецФункции

&НаСервере
Процедура ЗаписатьСвязьСДокументомПортала(Идентификаторы,spaceId,ДокументСсылка,ИсходнаяСсылка,ТекстОшибки = Неопределено)
	
	//в параметре Идентификаторы теперь будет прилетать строка с идентификатором, или массив.
	//Если строка или в массиве один элемент - пишем как раньше в свойство документа, если несколько - в таблицу объединенных документов
	Если ТипЗнч(Идентификаторы) = Тип("Строка") Тогда
		id = Идентификаторы;
	Иначе //Массив
		Если Идентификаторы.Количество() = 1 Тогда
			id = Идентификаторы[0];
		Иначе
			//обработать сохранение в таблицу, запись идентификатора выполняется там же
			ЗаписатьСвязь_ОбъединениеДокументовПортала(Идентификаторы,spaceId,ДокументСсылка,ИсходнаяСсылка,ТекстОшибки);
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	// если ДокументСсылка очистили - надо найти в данных портала запись с требуемым id и очистить в регистре установленное соответствие этого документа
	Если Не ЗначениеЗаполнено(ДокументСсылка) Тогда
		ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		
		Если ДанныеПортала = Неопределено Тогда
			//+++ очистить связь и без данных портала?
			
		Иначе
			
			ДанныеДокумента = ДанныеПортала.documents.НайтиСтроки(Новый Структура("id,ДокументСсылка",id,ИсходнаяСсылка));
			
			Если ДанныеДокумента.Количество() > 0 Тогда
				ДанныеДокумента[0].ДокументСсылка = Неопределено;
				ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
			КонецЕсли;
		КонецЕсли;
		
		//Связь может также храниться в дополнительной таблице объединенных документов
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		ТаблицаОбъединенныхДокументов = РеквизитОбъект.ПолучитьДанныеИзОбщегоХранилища("ОбъединенныеДокументы");
		
		Если ТипЗнч(ТаблицаОбъединенныхДокументов) = Тип("ТаблицаЗначений") Тогда
			//Удаляем существующие, если есть, эта связь нам больше не нужна
			СтрокиДокументов = ТаблицаОбъединенныхДокументов.НайтиСтроки(Новый Структура("documentId",id));
			Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
				ТаблицаОбъединенныхДокументов.Удалить(СтрокаДокумента);
			КонецЦикла;
			
			РеквизитОбъект.ЗаписатьДанныеВОбщееХранилище("ОбъединенныеДокументы",ТаблицаОбъединенныхДокументов);
		КонецЕсли;
	КонецЕсли;
	
	//Измерение Объект регистра ЗначенияСвойствОбъектов не позволяет хранить ссылки на документы,
	//сохраняем связь в свою таблицу в ХранилищеОбщихНастроек
	Если СтруктураНастроек.СведенияОКонфигурации.ХранениеСвязиДокументов_СвояТаблица = Истина Тогда
		ЗаписатьОчиститьЗначение_ТаблицаСвязьДокументов(ДокументСсылка,ИсходнаяСсылка,id,spaceId,ТекстОшибки)
	Иначе
		ЗаписатьОчиститьЗначениеСвойстваДокумента(СтруктураНастроек.Свойство_Entera_documentId,ДокументСсылка,ИсходнаяСсылка,id,ТекстОшибки);
		ЗаписатьОчиститьЗначениеСвойстваДокумента(СтруктураНастроек.Свойство_Entera_spaceId,ДокументСсылка,ИсходнаяСсылка,spaceId,ТекстОшибки);	
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура ЗаписатьОчиститьЗначениеСвойстваДокумента(Свойство,ДокументСсылка,ИсходнаяСсылка,Значение,ТекстОшибки)
	
	ИмяРегистраСведений = СтруктураНастроек.ИмяРегистраСведений;
		
	Если ИмяРегистраСведений <> Неопределено Тогда
	
		НаборЗаписей = РегистрыСведений[ИмяРегистраСведений].СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Свойство.Установить(Свойство);
		
		НаборЗаписей.Отбор.Объект.Установить(?(ЗначениеЗаполнено(ДокументСсылка),ДокументСсылка,ИсходнаяСсылка));
			
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		
		Если ЗначениеЗаполнено(ДокументСсылка) Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.Объект = ДокументСсылка;
			Запись.Свойство = Свойство;
			Запись.Значение = Значение;
		КонецЕсли;
		
		Попытка
			НаборЗаписей.Записать();
		Исключение
			ДополнитьТекстОшибки(ТекстОшибки,"При записи дополнительного свойства <" + ДокументСсылка + "> возникла ошибка: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
		
	КонецЕсли;
		
КонецПроцедуры
&НаСервере
Процедура ЗаписатьОчиститьЗначение_ТаблицаСвязьДокументов(ДокументСсылка,ИсходнаяСсылка,documentId,spaceId,ТекстОшибки)

	СвязьДокументов = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьДокументов");
	
	Если ТипЗнч(СвязьДокументов) <> Тип("ТаблицаЗначений") Тогда
		СвязьДокументов = Новый ТаблицаЗначений;
		СвязьДокументов.Колонки.Добавить("Ссылка");
		СвязьДокументов.Колонки.Добавить("documentId");
		СвязьДокументов.Колонки.Добавить("spaceId");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		СтрокиТаблицы = СвязьДокументов.НайтиСтроки(Новый Структура("Ссылка",ДокументСсылка));
		Если СтрокиТаблицы.Количество() > 0 Тогда
			//вряд ли такое возможно
			НоваяСтрока = СтрокиТаблицы[0];
		Иначе
			НоваяСтрока = СвязьДокументов.Добавить();
		КонецЕсли;
		
		НоваяСтрока.Ссылка = ДокументСсылка;
		НоваяСтрока.documentId = documentId;
		НоваяСтрока.spaceId = spaceId;
		
	Иначе
		//удаляем связь
		СтрокиТаблицы = СвязьДокументов.НайтиСтроки(Новый Структура("Ссылка",ИсходнаяСсылка));
		Для Каждого СтрокаТаблицы Из СтрокиТаблицы Цикл
			СвязьДокументов.Удалить(СтрокаТаблицы);
		КонецЦикла;
	КонецЕсли;
	
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","СвязьДокументов",СвязьДокументов);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьСвязь_ОбъединениеДокументовПортала(Идентификаторы,spaceId,ДокументСсылка,ИсходнаяСсылка,ТекстОшибки)
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ТаблицаОбъединенныхДокументов = РеквизитОбъект.ПолучитьДанныеИзОбщегоХранилища("ОбъединенныеДокументы");
	
	Если ТипЗнч(ТаблицаОбъединенныхДокументов) <> Тип("ТаблицаЗначений") Тогда
		ТаблицаОбъединенныхДокументов = Новый ТаблицаЗначений;
		ТаблицаОбъединенныхДокументов.Колонки.Добавить("documentId");
		ТаблицаОбъединенныхДокументов.Колонки.Добавить("spaceId");
		ТаблицаОбъединенныхДокументов.Колонки.Добавить("Ссылка");
		ТаблицаОбъединенныхДокументов.Колонки.Добавить("Представление");
	КонецЕсли;
	
	Для Каждого Идентификатор Из Идентификаторы Цикл
		
		//Удаляем существующие, если есть, эта связь нам больше не нужна
		СтрокиДокументов = ТаблицаОбъединенныхДокументов.НайтиСтроки(Новый Структура("documentId",Идентификатор));
		Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
			ТаблицаОбъединенныхДокументов.Удалить(СтрокаДокумента);
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ДокументСсылка) Тогда
			//Создаем новые
			НоваяСтрока = ТаблицаОбъединенныхДокументов.Добавить();
			НоваяСтрока.documentId = Идентификатор;
			НоваяСтрока.spaceId = spaceId;
			НоваяСтрока.Ссылка = ДокументСсылка;
			НоваяСтрока.Представление = Строка(ДокументСсылка);
			
		Иначе
			//Очистим ссылки в данных портала
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
			ДанныеДокумента = ДанныеПортала.documents.НайтиСтроки(Новый Структура("id",Идентификатор));
			Для Каждого СтрокаДокумента Из ДанныеДокумента Цикл
				СтрокаДокумента.ДокументСсылка = Неопределено;
			КонецЦикла;
			
			ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
			
		КонецЕсли;
		
	КонецЦикла;
	
	РеквизитОбъект.ЗаписатьДанныеВОбщееХранилище("ОбъединенныеДокументы",ТаблицаОбъединенныхДокументов);
	
	//Для Документа запишем в свойство Entera_documentId его собственный GUID, чтобы понимать, что связанные с ним документы хранятся в этой таблице
	ГУИДДокумента = Строка(ДокументСсылка.УникальныйИдентификатор());
	ЗаписатьОчиститьЗначениеСвойстваДокумента(СтруктураНастроек.Свойство_Entera_documentId,ДокументСсылка,ИсходнаяСсылка,ГУИДДокумента,ТекстОшибки);
	ЗаписатьОчиститьЗначениеСвойстваДокумента(СтруктураНастроек.Свойство_Entera_spaceId,ДокументСсылка,ИсходнаяСсылка,spaceId,ТекстОшибки);	
	
КонецПроцедуры

&НаСервере
Функция ДопРасходы_ЗаполнитьДокументПоОснованию(ДокументСсылка,СтрокиДопРасходов,СтруктураЗаполненияДокумента,ПараметрыМК,ТекстОшибки)
		
	Если ЗначениеЗаполнено(ДокументСсылка) Тогда
		
		//Пока заполняем только документ ПоступлениеДопРасходов, если он присутствует в конфигурации
		
		//2024.08.05 ( В УНФ поступление доп. расходов отражается документом ДополнительныеРасходы
		Если Метаданные.Документы.Найти("ПоступлениеДопРасходов") <> Неопределено Тогда
			ИмяМетаданныхДокумента = "ПоступлениеДопРасходов";
		ИначеЕсли Метаданные.Документы.Найти("ДополнительныеРасходы") <> Неопределено Тогда
			ИмяМетаданныхДокумента = "ДополнительныеРасходы";
		// ) 2024.08.05
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "В конфигурации не был найден документ отражения поступления доп. расходов";
			Сообщение.Сообщить();
			Возврат Неопределено;
		КонецЕсли;
		
		СуммаВключаетНДС = СтруктураНастроек.ЗаполнениеШапки_СуммаВключаетНДС = Истина;
		
		СуммаДопРасходов = 0;
		СуммаНДСДопРасходов = 0;
		
		Для Каждого СтрокаДопРасходов Из СтрокиДопРасходов Цикл
			СуммаДопРасходов = СуммаДопРасходов + ?(СуммаВключаетНДС,СтрокаДопРасходов.amount,СтрокаДопРасходов.amountWithoutVat);
			СуммаНДСДопРасходов = СуммаНДСДопРасходов + СтрокаДопРасходов.vat;
		КонецЦикла;
		
		Если СуммаДопРасходов > 0 Тогда
			СтрокаДопРасходов = СтрокиДопРасходов[0];
			СтавкаНДС = СтрокаДопРасходов.СтавкаНДССсылка;
		
			ПоступлениеДопРасходовОбъект = Документы[ИмяМетаданныхДокумента].СоздатьДокумент();
			ПоступлениеДопРасходовОбъект.Заполнить(ДокументСсылка);
			ПоступлениеДопРасходовОбъект.Дата = ДокументСсылка.Дата;
			
			СтруктураЗаполненияДопРасходов = Новый Структура;
			
			Если РеквизитСуществует("Перечисления","СпособыРаспределенияДопРасходов","ПоСумме") Тогда
				СтруктураЗаполненияДопРасходов.Вставить("СпособРаспределения",Перечисления.СпособыРаспределенияДопРасходов.ПоСумме);
			КонецЕсли;
						
			СтруктураЗаполненияДопРасходов.Вставить("НомерВходящегоДокумента",СтруктураЗаполненияДокумента.document.number);
			СтруктураЗаполненияДопРасходов.Вставить("ДатаВходящегоДокумента",СтруктураЗаполненияДокумента.document.date);
			СтруктураЗаполненияДопРасходов.Вставить("Сумма",СуммаДопРасходов);
			СтруктураЗаполненияДопРасходов.Вставить("СтавкаНДС",СтавкаНДС);
			СтруктураЗаполненияДопРасходов.Вставить("СуммаНДС",СуммаНДСДопРасходов);
			СтруктураЗаполненияДопРасходов.Вставить("Содержание",СтрокаДопРасходов.name);
			
			СтруктураЗаполненияДопРасходов.Вставить("СуммаВключаетНДС",СуммаВключаетНДС);
			
			СтруктураЗаполненияДопРасходов.Вставить("Комментарий",ДокументСсылка.Комментарий);
			
			ЗаполнитьЗначенияСвойств(ПоступлениеДопРасходовОбъект,СтруктураЗаполненияДопРасходов);
			
			//В УНФ в документе ДополнительныеРасходы заполняется табличную часть Расходы
			Если ИмяМетаданныхДокумента = "ДополнительныеРасходы" Тогда
				Для Каждого СтрокаДопРасходов Из СтрокиДопРасходов Цикл
					
					НоваяСтрока = ПоступлениеДопРасходовОбъект.Расходы.Добавить();
					СтруктураРасход = Новый Структура;
					СтруктураРасход.Вставить("Номенклатура",СтрокаДопРасходов.НоменклатураСсылка);
					СтруктураРасход.Вставить("Количество",СтрокаДопРасходов.quantity);
					СтруктураРасход.Вставить("ЕдиницаИзмерения",СтрокаДопРасходов.ЕдиницаИзмеренияСсылка);
					СтруктураРасход.Вставить("Цена",СтрокаДопРасходов.price);
					СтруктураРасход.Вставить("Сумма",СтрокаДопРасходов.amountWithoutVat);
					СтруктураРасход.Вставить("СтавкаНДС",СтрокаДопРасходов.СтавкаНДССсылка);
					СтруктураРасход.Вставить("СуммаНДС",СтрокаДопРасходов.vat);
					СтруктураРасход.Вставить("Всего",СтрокаДопРасходов.amount);
					
					//расшифровка услуги
					Если СтруктураНастроек.ЗаполнениеТЧ_ОписаниеУслугиИзРаспознанногоДокумента = Истина Тогда
						СодержаниеУслуги = СтрокаДопРасходов.name;
					ИначеЕсли ЗначениеЗаполнено(СтрокаДопРасходов.НоменклатураСсылка) Тогда
						СодержаниеУслуги = СтрокаДопРасходов.НоменклатураСсылка.НаименованиеПолное;
					Иначе
						СодержаниеУслуги = СтрокаДопРасходов.name;
					КонецЕсли;
					
					СтруктураРасход.Вставить("Содержание",СодержаниеУслуги);
					
					ЗаполнитьЗначенияСвойств(НоваяСтрока,СтруктураРасход);
				КонецЦикла;
				
				//Распределяем по сумме
				Попытка
					ПоступлениеДопРасходовОбъект.РаспределитьТабЧастьРасходыПоСумме();
				Исключение
					//Не обрабатываем
				КонецПопытки;
				
			КонецЕсли;
			
			
			ПараметрыМК.Вставить("ДокументОбъект",ПоступлениеДопРасходовОбъект);
			ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
		
			РеквизитОбъект = РеквизитФормыВЗначение("Объект");
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередЗаписьюПоступлениеДопРасходов",ПараметрыМК);
			ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
			
			ТекстОшибки = ПараметрыМК.ТекстОшибки;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
				
				//E1C-512: Не всех устраивает автоматическая установка времени
				Если СтруктураНастроек.ЗаполнениеШапки_УстанавливатьВремяДокументаАвтоматически = Истина Тогда
					//2021.03.22 ( Установим время документа
					ПоступлениеДопРасходовОбъект.УстановитьВремя();
					// ) 2021.03.22
				КонецЕсли;
				
				Попытка
					ПоступлениеДопРасходовОбъект.Записать();
					ПоступлениеДопРасходовСсылка = ПоступлениеДопРасходовОбъект.Ссылка;
				Исключение
					
				КонецПопытки;
				
				Если ЗначениеЗаполнено(ПоступлениеДопРасходовСсылка) Тогда
					
					//Устанавливаем флаг Оригинал получен
					Если СтруктураНастроек.СозданиеДокумента_УстанавливатьФлагОригиналПолучен = Истина Тогда
			
						ОшибкаУстановкиФлага = УстановитьСтатусДокумента_ОригиналПолучен(ПоступлениеДопРасходовСсылка);
						
						Если ЗначениеЗаполнено(ОшибкаУстановкиФлага) Тогда
							ОписаниеСобытия = "Ошибка при установке флага Оригинал получен для <" + ПоступлениеДопРасходовСсылка + ">: " + КраткоеОписаниеОшибки(ОшибкаУстановкиФлага);
						Иначе
							ОписаниеСобытия = "Флаг Оригинал получен для <" + ПоступлениеДопРасходовСсылка + "> установлен";
						КонецЕсли;
						
						ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
						
					КонецЕсли;
					
					//Проводим заполненный документ
					Если СтруктураНастроек.СозданиеДокумента_ПроводитьЗаполненныеДокументы = Истина Тогда
						Попытка
							ПоступлениеДопРасходовОбъект.Записать(РежимЗаписиДокумента.Проведение);
							
							ОписаниеСобытия = "<" + ПоступлениеДопРасходовОбъект + ">: документ успешно проведен";
							ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
						Исключение
							ОписаниеСобытия = "- ошибка при проведении документа <" + ПоступлениеДопРасходовОбъект + ">: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
							ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
							ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
						КонецПопытки;
					КонецЕсли;
					
				КонецЕсли;
				
				ПараметрыМК.Вставить("ТекстОшибки",ТекстОшибки);
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
				РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПослеЗаписиПоступлениеДопРасходов",ПараметрыМК);
				ТекстОшибки = ПараметрыМК.ТекстОшибки;
				
				Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
					Возврат ПоступлениеДопРасходовСсылка;
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			ОписаниеСобытия = "Ошибка при заполнении поступления доп. расходов: документ-основание не был записан";
			ДополнитьТекстОшибки(ТекстОшибки,ОписаниеСобытия);
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ОшибкаЗаписи");
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции
&НаСервере
Функция ДопРасходы_ЗаполнитьДокументПоСпискуОснований(СписокОснований,СодержаниеУслуги,СтруктураЗаполнения,ПараметрыМК,ТекстОшибки)
		
	Если ЗначениеЗаполнено(СписокОснований) Тогда
		
		//Пока заполняем только документ ПоступлениеДопРасходов, если он присутствует в конфигурации
		Если Метаданные.Документы.Найти("ПоступлениеДопРасходов") = Неопределено Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "В конфигурации не найден документ <Поступление доп. расходов>";
			Сообщение.Сообщить();
			Возврат Неопределено;
		КонецЕсли;
		
		СуммаВключаетНДС = СтруктураНастроек.ЗаполнениеШапки_СуммаВключаетНДС = Истина;
		
		СуммаДопРасходов = 0;
		СуммаНДСДопРасходов = 0;
		
		ПоступлениеДопРасходовОбъект = Документы.ПоступлениеДопРасходов.СоздатьДокумент();
		ПоступлениеДопРасходовОбъект.СпособРаспределения = Перечисления.СпособыРаспределенияДопРасходов.ПоСумме;
		
		Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию) Тогда
			СтруктураЗаполнения.Вставить("СпособЗачетаАвансов",СтруктураНастроек.ЗаполнениеТЧ_СпособЗачетаАвансовПоУмолчанию);
		ИначеЕсли РеквизитСуществует("Перечисления","СпособыЗачетаАвансов","Автоматически") Тогда
			СтруктураЗаполнения.Вставить("СпособЗачетаАвансов",Перечисления.СпособыЗачетаАвансов.Автоматически);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ПоступлениеДопРасходовОбъект,СтруктураЗаполнения);
		ПоступлениеДопРасходовОбъект.Содержание = СодержаниеУслуги.Содержание;
		ПоступлениеДопРасходовОбъект.СтавкаНДС = СодержаниеУслуги.СтавкаНДС;
		ПоступлениеДопРасходовОбъект.СуммаВключаетНДС = СуммаВключаетНДС;
		
		Для Каждого ЭлементСписка Из СписокОснований Цикл
			ДокументСсылка = ЭлементСписка.Значение;
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
				ПоступлениеДопРасходовОбъект.ЗаполнитьПоДокументуОснования(ДокументСсылка);
			Иначе
				ПоступлениеДопРасходовОбъект.ЗаполнитьПоПоступлению(ДокументСсылка);
			КонецЕсли;
		КонецЦикла;
		
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		МодульСчетаУчетаВДокументах = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("СчетаУчетаВДокументах");
		МодульБухгалтерскийУчетПереопределяемый = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("БухгалтерскийУчетПереопределяемый");
		
		//Заполняем счет учета НДС
		Если МодульСчетаУчетаВДокументах <> Неопределено Тогда
			
			Если МодульБухгалтерскийУчетПереопределяемый <> Неопределено Тогда
			
				Для Каждого СтрокаТаблицы Из ПоступлениеДопРасходовОбъект.Товары Цикл
					Если Не ЗначениеЗаполнено(СтрокаТаблицы.СчетУчетаНДС) Тогда
						
						//Логика из формы документа ПоступлениеДопРасходов
						ДанныеОбъекта = Новый Структура("Организация, Дата, СуммаВключаетНДС, СтавкаНДС, ПрименяетсяМалоценка");
						ЗаполнитьЗначенияСвойств(ДанныеОбъекта,ПоступлениеДопРасходовОбъект);
						ДанныеОбъекта.ПрименяетсяМалоценка = Ложь;

						ДанныеСтроки = Новый Структура("Номенклатура, Количество, Сумма, СтавкаНДС, СуммаНДС, Малоценка, АналитикаУчета, АналитикаУчетаЗаполнена");
						ЗаполнитьЗначенияСвойств(ДанныеСтроки,СтрокаТаблицы);
						
						СведенияОНоменклатуре = МодульБухгалтерскийУчетПереопределяемый.ПолучитьСведенияОНоменклатуре(СтрокаТаблицы.Номенклатура, ДанныеОбъекта, Ложь, Ложь);
						
						СчетаУчетаКЗаполнению = Новый Соответствие;
						СчетаУчетаКЗаполнению.Вставить("Товары.СчетУчетаНДС",Истина);
						
						ЗаполненныеСчета = МодульСчетаУчетаВДокументах.ЗаполнитьРеквизитыПриИзменении(
							Документы.ПоступлениеДопРасходов,
							СчетаУчетаКЗаполнению,
							ДанныеОбъекта,
							"Товары",
							СтрокаТаблицы);
						
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			//Шапка документа
			ПоступлениеДопРасходовОбъект.ДополнительныеСвойства.Вставить("ЗаполнитьСчетаУчетаПередЗаписью",Истина);
			Попытка МодульСчетаУчетаВДокументах.ЗаполнитьПередЗаписью(ПоступлениеДопРасходовОбъект,РежимЗаписиДокумента.Запись); Исключение; КонецПопытки;
			
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПоступлениеДопРасходовОбъект;
	
КонецФункции

&НаСервереБезКонтекста
Функция УстановитьСтатусДокумента_ОригиналПолучен(ДокументСсылка)
	
	Если Метаданные.РегистрыСведений.Найти("СтатусыДокументов") <> Неопределено
		И Метаданные.Перечисления.Найти("СтатусыДокументовПоступления") <> Неопределено
		И Метаданные.Перечисления.СтатусыДокументовПоступления.ЗначенияПеречисления.Найти("ОригиналПолучен") <> Неопределено Тогда
		
		Организация = Неопределено;
		
		//В свежих версиях бухни УстановитьСтатусыДокумента в качестве статуса принимает на вход Структуру из СтатусыДокументов.НовыеСтатусыДокумента()
		//Пробуем в попытке вызвать функцию НовыеСтатусыДокумента, если вернется структура - передадим ее, если нет - версия конфигурации старая,
		//используем исходный алгоритм установки статуса из перечисления
		Попытка
			//Статус ОригиналПолучен относится к документу ПоступлениеТоваровУслуг,
			//для других типов документов такая операция сбросит предустановленный статус
			ЗначениеСтатуса = РегистрыСведений.СтатусыДокументов.ПолучитьСтатусыДокумента(ДокументСсылка, Организация);
			Если ТипЗнч(ЗначениеСтатуса.Статус) = Тип("ПеречислениеСсылка.СтатусыДокументовПоступления") Тогда
				ЗначениеСтатуса = РегистрыСведений.СтатусыДокументов.НовыеСтатусыДокумента();
				ЗначениеСтатуса.Статус = Перечисления.СтатусыДокументовПоступления.ОригиналПолучен;
			КонецЕсли;
		Исключение
			ЗначениеСтатуса = Перечисления.СтатусыДокументовПоступления.ОригиналПолучен;
		КонецПопытки;			
		
		Попытка
			РегистрыСведений.СтатусыДокументов.УстановитьСтатусыДокумента(ДокументСсылка,ЗначениеСтатуса);
		Исключение
			ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Возврат ТекстОшибки;
		КонецПопытки;
		
	КонецЕсли;
	
КонецФункции
&НаСервереБезКонтекста
Функция СчетФактура_ДанныеСчетаФактурыУказываютсяВДокументеОсновании(ДокументСсылка)
	
	Результат = Ложь;
	
	Если ДокументСсылка.Метаданные().Реквизиты.Найти("ЭтоУниверсальныйДокумент") <> Неопределено
		И ДокументСсылка.ЭтоУниверсальныйДокумент = Истина Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
		
КонецФункции


// ================= Отправка документа на распознавание ===================

&НаКлиенте
Процедура СписокДокументовПроверкаПеретаскивания(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	//Не нужно пытаться открыть файл средствами платформы
	СтандартнаяОбработка = Ложь;
КонецПроцедуры
&НаКлиенте
Процедура СписокДокументовПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	Если Не ЗначениеЗаполнено(Отбор_Пространство) Тогда
		ПоказатьОповещениеПользователя("Не выбрано пространство",,"для отправки документа на распознавание");
		Возврат;
	КонецЕсли;
	
	ФайлыДляПередачи = Новый Массив;
	
	Если ЭтоВебКлиент Тогда
		//перетаскивание файла в веб-клиенте не реализовано
	Иначе
		
	
		Если ТипЗнч(ПараметрыПеретаскивания.Значение) = Тип("Файл") Тогда
			МассивФайлов = Новый Массив;
			МассивФайлов.Добавить(ПараметрыПеретаскивания.Значение);
		ИначеЕсли ТипЗнч(ПараметрыПеретаскивания.Значение) = Тип("Массив") Тогда
			МассивФайлов = ПараметрыПеретаскивания.Значение;
		КонецЕсли;
				
		Если МассивФайлов <> Неопределено Тогда
			
			Для Каждого ФайлМассива Из МассивФайлов Цикл
				Файл = Новый Файл(ФайлМассива.ПолноеИмя);
					
				//При отправке файла с клиента используем ПолноеИмяФайлаНаКлиенте, на сервер отдаем файл через временное хранилище
				ОтправляемыйФайл = Новый Структура;
				ОтправляемыйФайл.Вставить("АдресВХ",ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Файл.ПолноеИмя),Новый УникальныйИдентификатор));
				ОтправляемыйФайл.Вставить("ИмяФайла",Файл.Имя);
				ОтправляемыйФайл.Вставить("ПолноеИмяФайлаНаКлиенте",Файл.ПолноеИмя);
				ОтправляемыйФайл.Вставить("КодированноеИмяФайла",КодироватьСтрокуПараметровНаСервере(Файл.Имя));
				ОтправляемыйФайл.Вставить("РазмерФайла",СформироватьПредставлениеРазмераФайла(Файл.Размер()));
				
				ФайлыДляПередачи.Добавить(ОтправляемыйФайл);
			КонецЦикла;
			
		КонецЕсли;
	КонецЕсли;
	
	Если ФайлыДляПередачи.Количество() > 0 Тогда
		ПоказатьФорму_ОтправляемыеФайлы(ФайлыДляПередачи);				
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьДокумент(Команда)
		
	Если Не ЗначениеЗаполнено(Отбор_Пространство) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Пространство не может быть пустым";
		Сообщение.Поле = "Отбор_Пространство";		
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	
	Если ЭтоВебКлиент Тогда
		ПараметрыВызоваНачало = Новый Структура("Обработчик,ДопПараметры","ОбработатьНачалоВыбораФайлов_ВебКлиент",ДопПараметры);
		ПараметрыВызоваЗавершение = Новый Структура("Обработчик,ДопПараметры","ОбработатьВыборФайлов_ВебКлиент",ДопПараметры);
		ПараметрыВызова = Новый Структура("ПараметрыВызоваНачало,ПараметрыВызоваЗавершение",ПараметрыВызоваНачало,ПараметрыВызоваЗавершение);
		_ЗФ_ОбработатьАсинхронныйВызов("ПоместитьФайлы",ПараметрыВызова);
		
	Иначе		
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		Диалог.МножественныйВыбор = Истина;
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ДиалогВыбораФайла","ОбработатьВыборФайлов",ДопПараметры,Диалог);
		_ЗФ_ОбработатьАсинхронныйВызов("ДиалогВыбораФайла",ПараметрыВызова);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборФайлов(Результат,ДопПараметры) Экспорт
	Если Результат <> Неопределено Тогда
		
		ФайлыДляПередачи = Новый Массив;
		
		Для Каждого ФайлМассива Из Результат Цикл
			ОтправляемыйФайл = Новый Структура;
		
			Файл = Новый Файл(ФайлМассива);
			
			//При отправке файла с клиента используем ПолноеИмяФайлаНаКлиенте, на сервер отдаем файл через временное хранилище
			ОтправляемыйФайл.Вставить("АдресВХ",ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(Файл.ПолноеИмя),УникальныйИдентификатор));
			ОтправляемыйФайл.Вставить("ИмяФайла",Файл.Имя);
			ОтправляемыйФайл.Вставить("ПолноеИмяФайлаНаКлиенте",Файл.ПолноеИмя);
			ОтправляемыйФайл.Вставить("КодированноеИмяФайла",КодироватьСтрокуПараметровНаСервере(Файл.Имя));
			ОтправляемыйФайл.Вставить("РазмерФайла",СформироватьПредставлениеРазмераФайла(Файл.Размер()));
				
			ФайлыДляПередачи.Добавить(ОтправляемыйФайл);
		КонецЦикла;
		
		ПоказатьФорму_ОтправляемыеФайлы(ФайлыДляПередачи);
						
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьНачалоВыбораФайлов_ВебКлиент(ПомещенныеФайлы,Отказ,ДопПараметры) Экспорт
	Соответствия = Новый Соответствие;
	Для Каждого ФайлДляПередачи Из ПомещенныеФайлы Цикл
		Соответствия.Вставить(Строка(ФайлДляПередачи.ИдентификаторФайла),ФайлДляПередачи.Имя);
	КонецЦикла;
	ДопПараметры.Вставить("Соответствия",Соответствия);
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборФайлов_ВебКлиент(ПомещенныеФайлы,ДопПараметры) Экспорт
	Если ПомещенныеФайлы <> Неопределено Тогда
		
		ФайлыДляПередачи = Новый Массив;
		
		Для Каждого ФайлДляПередачи Из ПомещенныеФайлы Цикл
			
			ИмяФайла = ДопПараметры.Соответствия.Получить(Строка(ФайлДляПередачи.ИдентификаторФайла));
			
			ОтправляемыйФайл = Новый Структура;
			ОтправляемыйФайл.Вставить("АдресВХ",ФайлДляПередачи.Хранение);
			ОтправляемыйФайл.Вставить("ИмяФайла",ИмяФайла);
			ОтправляемыйФайл.Вставить("ПолноеИмяФайлаНаКлиенте",ИмяФайла);
			ОтправляемыйФайл.Вставить("КодированноеИмяФайла",КодироватьСтрокуПараметровНаСервере(ИмяФайла));
			ОтправляемыйФайл.Вставить("РазмерФайла");
			
			ФайлыДляПередачи.Добавить(ОтправляемыйФайл);			
		КонецЦикла;
			
		ПоказатьФорму_ОтправляемыеФайлы(ФайлыДляПередачи);
		
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура ПоказатьФорму_ОтправляемыеФайлы(ФайлыДляПередачи)
	
	//E1C-399: Теперь предварительно уточняем по хэшу файлов, отправлялись ли они ранее на распознавание
	ОтправляемыеФайлы_РасчитатьХэшИПроверитьДубликаты(ФайлыДляПередачи);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ФайлыДляПередачи",ФайлыДляПередачи);
	ПараметрыОткрытия.Вставить("ЭтоВебКлиент",ЭтоВебКлиент);
	ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
	
	ФормаОтправляемыеФайлы = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ОтправляемыеФайлы", ПараметрыОткрытия, ЭтаФорма);

	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Источник","УФ_ОтправляемыеФайлы");
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,Форма","ОбработатьЗакрытиеФормы_СинхронноАсинхронно",ДопПараметры,ФормаОтправляемыеФайлы);
	
	_ЗФ_ОбработатьАсинхронныйВызов("ОткрытьФормуМодально",ПараметрыВызова);	
	
КонецПроцедуры
&НаКлиенте
Процедура ОтправляемыеФайлы_РасчитатьХэшИПроверитьДубликаты(ФайлыДляПередачи)
	
	//Описание метода /api/v1/checkExistence:
	//POST запрос на https://app.entera.pro/api/v1/checkExistence
	//hashList - Array of strings (Список хешей файлов.)
	//spaceId - string <uuid> (ID папки)
	
	ОбщееКоличество = ФайлыДляПередачи.Количество();
	Счетчик = 0;
	
	Для Каждого ФайлДляПередачи Из ФайлыДляПередачи Цикл
		
		Счетчик = Счетчик + 1;
		Прогресс = Счетчик / ОбщееКоличество * 100;
		Состояние("Проверка ранее отправленных файлов...",Прогресс);
		
		СтрокаХэш = ОтправляемыеФайлы_РасчитатьХэшФайлаНаСервере(ФайлДляПередачи.АдресВХ);
		
		ТелоЗапроса = ОтправляемыеФайлы_СформироватьТелоЗапросаПроверкиДубликатов(СтрокаХэш);
		
		МетодAPI = "/api/v1/checkExistence?format=xml";
		РезультатЗапроса = ВыполнитьЗапрос("ПроверитьДубликатыФайловПоХэш","POST",МетодAPI,ТелоЗапроса);
		
		Если РезультатЗапроса.Успешно Тогда
			КонтрольДубликата = РезультатЗапроса.КонтрольДубликата;
		Иначе
			КонтрольДубликата = "Ошибка проверки";
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "[" + Строка(ФайлДляПередачи.ИмяФайла) + "]: ошибка при проверке на повторную отправку" + Символы.ПС + РезультатЗапроса.ТекстОшибки;
			Сообщение.Сообщить();
		КонецЕсли;
		
		ФайлДляПередачи.Вставить("Статус",КонтрольДубликата);
		
	КонецЦикла;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция ОтправляемыеФайлы_РасчитатьХэшФайлаНаСервере(АдресВХ)
	
	ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХ);
	Хэш = Новый ХешированиеДанных(ХешФункция.SHA256);
	Хэш.Добавить(ДвоичныеДанныеФайла);
	СтрокаХэш = Base64Строка(Хэш.ХешСумма);
	
	Возврат СтрокаХэш;
	
КонецФункции
&НаКлиенте
Функция ОтправляемыеФайлы_СформироватьТелоЗапросаПроверкиДубликатов(СтрокаХэш)
	
	//Пример тела запроса:
	//{
 	//"spaceId": "a64adf64-92fb-4ce2-8b34-e91cc8a9e2fa",
 	//"hashList": [
    //"wfOIhJYF8wxWedftLXD+goZkuFnYIbo1cLkWpHEztBg=",
    //"3XNAvD8BW0IqgV4+OaV1HeAbBk0HhocyK6hk9F2VaYo="
	//]
	//}
	
	ТелоЗапроса = "";
	ТелоЗапроса = ТелоЗапроса + "{" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """spaceId"": """ + Отбор_Пространство + """," + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """hashList"": [""" + СтрокаХэш + """]" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + "}";
	
	Возврат ТелоЗапроса;
	
КонецФункции

&НаКлиенте
Функция ОтправитьДокументНаПортал(ФайлыДляПередачи,УведомлятьНаПочтуОВыполненныхЗаданиях)
		
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("ФайлыДляПередачи",ФайлыДляПередачи);
	
	Состояние("Отправка файлов на портал...");
	
	source = ?(ЭтоФреш,"MODULE_1C_FRESH","MODULE_1C");
	
	РезультатЗапроса = ВыполнитьЗапрос("ОтправкаНаРаспознавание","POST","/api/v1/recognitionTasks/multiple?format=xml&source=" + source + "&spaceId=" + Отбор_Пространство,,ПараметрыЗапроса);
	
	Если РезультатЗапроса.Успешно Тогда
		
		// добавить задания распознавания в коллекцию и отслеживать по настройке
		Для Каждого Задание Из РезультатЗапроса.МассивЗаданий Цикл
			
			НоваяСтрока = ЗаданияРаспознавания_Таблица.Добавить();
			НоваяСтрока.recognitionTaskId = Задание.recognitionTaskId;
			НоваяСтрока.ИмяФайла = Задание.ИмяФайла;
			НоваяСтрока.КоличествоФайлов = Задание.КоличествоФайлов;
			
			//E1C-18: уведомление о готовности распознавания при отправке на распознавание
			Если УведомлятьНаПочтуОВыполненныхЗаданиях = Истина Тогда
				
				//POST /api/v1/recognitionTasks/:id/scheduleCompletionNotification
				
				ОписаниеСобытия = "Запрос уведомления о готовности распознавания: recognitionTaskId=[" + Задание.recognitionTaskId + "]";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"ЗаданияРаспознавания",ОписаниеСобытия,"ЗаданияРаспознавания");	
				
				РезультатЗапроса_Уведомление = ВыполнитьЗапрос("УведомленияНаПочтуОВыполненныхЗаданиях","POST","/api/v1/recognitionTasks/" + Задание.recognitionTaskId + "/scheduleCompletionNotification","{}");
				
				//О результате этого запроса пользователю можно не сообщать, только запишем в лог
				Если РезультатЗапроса_Уведомление.Успешно Тогда
					ОписаниеСобытия = "Успешно: запрос уведомления о готовности распознавания: recognitionTaskId=[" + Задание.recognitionTaskId + "]";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"ЗаданияРаспознавания",ОписаниеСобытия,"ЗаданияРаспознавания");	
				Иначе
					ОписаниеСобытия = "Ошибка: запрос уведомления о готовности распознавания: recognitionTaskId=[" + Задание.recognitionTaskId + "]: " + РезультатЗапроса_Уведомление.ТекстОшибки;
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"ЗаданияРаспознавания",ОписаниеСобытия,"ЗаданияРаспознавания");	
				КонецЕсли;
			КонецЕсли;
						
		КонецЦикла;
		
		//Обработка успешной отправки файлов в МК: выполняем на клиенте
		Если ИспользуетсяМК Тогда
			
			// модуль кастомизации
			ПараметрыМК = Новый Структура;
			ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
			ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
			ПараметрыМК.Вставить("ДопПараметры",Новый Структура);
			ПараметрыМК.Вставить("ФайлыДляПередачи",ФайлыДляПередачи);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			ИмяСобытия = "ОсновнаяФорма_ПослеУспешнойОтправкиФайловНаРаспознавание";
			
			ОписаниеОбработчика = ИмяСобытия + ": передача клиентского события для обработки в МК";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"ВыполнениеМК_Клиент");
			
			Попытка
				МодульМК_Клиент.ОбработатьКлиентскоеСобытиеОсновногоМодуля(ИмяСобытия,ПараметрыМК);
			Исключение
				ТекстОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				
				Если ПараметрыМК.Свойство("ТекстОшибки") Тогда
					ТекстОшибки = ТекстОшибки + Символы.ПС + ПараметрыМК.ТекстОшибки;
				КонецЕсли;
				
				ОписаниеОбработчика = ИмяСобытия + ": при обработке клиентского события в МК возникла ошибка:" + Символы.ПС + ТекстОшибки;
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"Ошибка");
			КонецПопытки;
			
		КонецЕсли;
		
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
	//2019.05.14 (EN-438: теперь задания на распознавание нужно отображать и в списке документов
	//чтобы пользователь мог увидеть какие файлы загрузил а какие нет.
	СписокДокументов_ОтобразитьЗаданияНаРаспознавание();
	// ) 2019.05.14
		
	Возврат РезультатЗапроса;
	
КонецФункции
&НаКлиенте
Процедура СписокДокументов_ОтобразитьЗаданияНаРаспознавание()
	
	Если СтруктураНастроек.Свойство("ОбменДанными_ОтображатьЗаданияРаспознавания")
		И СтруктураНастроек.ОбменДанными_ОтображатьЗаданияРаспознавания = Ложь Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Задание Из ЗаданияРаспознавания_Таблица Цикл
		
		СтрокиЗадания = Объект.СписокДокументов.НайтиСтроки(Новый Структура("recognitionTaskId",Задание.recognitionTaskId));
		
		Если СтрокиЗадания.Количество() = 0 Тогда
			НоваяСтрокаДокумент = Объект.СписокДокументов.Вставить(0);
			
			НоваяСтрокаДокумент.recognitionTaskId = Задание.recognitionTaskId;
			НоваяСтрокаДокумент.ПредставлениеДокумента = Задание.ИмяФайла;
							
			НоваяСтрокаДокумент.ПространствоИД = Отбор_Пространство;
			
			НоваяСтрокаДокумент.ДокументСтатус = "RECOGNIZING";
			НоваяСтрокаДокумент.ПредставлениеСтатуса = "На распознавании";
			НоваяСтрокаДокумент.ПредставлениеПлательщика = "-";
			НоваяСтрокаДокумент.ПредставлениеПоставщика = "-";
			НоваяСтрокаДокумент.НаправлениеСоздаваемогоДокумента = "-";
			
			НоваяСтрокаДокумент.url = "https://app.entera.pro/spaces/" + Отбор_Пространство + "/documents/recognizing";
			
			НоваяСтрокаДокумент.ДатаЗагрузки = ТекущаяДата();
			НоваяСтрокаДокумент.ДокументЗагрузил = Элементы.Авторизация.Заголовок;				
			
			//2021.11.01 ( Отображаем строку в списке
			НоваяСтрокаДокумент.Документ_СоответствуетОтбору = Истина;
			// ) 2021.11.01
		КонецЕсли;
	КонецЦикла;
	
	Если СтруктураНастроек.ОбменДанными_ОпрашиватьСтатусЗаданийРаспознавания = Истина
		И ЗаданияРаспознавания_Таблица.Количество() > 0 Тогда
		Элементы.НаРаспознаванииАнимация.Видимость = Истина;
		
		//E1C-102: Интервал опроса выполняющихся заданий распознавания вынесен в настройки
		Если СтруктураНастроек.ОбменДанными_ИнтервалОпросаЗаданий = "15 секунд" Тогда
			ИнтервалОпроса = 15;
		ИначеЕсли СтруктураНастроек.ОбменДанными_ИнтервалОпросаЗаданий = "1 минута" Тогда
			ИнтервалОпроса = 60;
		ИначеЕсли СтруктураНастроек.ОбменДанными_ИнтервалОпросаЗаданий = "5 минут" Тогда
			ИнтервалОпроса = 300;
		ИначеЕсли СтруктураНастроек.ОбменДанными_ИнтервалОпросаЗаданий = "10 минут" Тогда
			ИнтервалОпроса = 600;
		Иначе
			//Исходный вариант
			ИнтервалОпроса = 15;
		КонецЕсли;
		// ) E1C-102
	
		ПодключитьОбработчикОжидания("ВыполнитьОбновлениеСтатусовЗаданийРаспознавания",ИнтервалОпроса,Ложь);
	Иначе
		Элементы.НаРаспознаванииАнимация.Видимость = Ложь;
	КонецЕсли;
	
	БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам();
	ПересчитатьИтогиПоСтатусамДокументов();
	
КонецПроцедуры


// ================= Задания распознавания ===================

&НаКлиенте
Процедура ВыполнитьОбновлениеСтатусовЗаданийРаспознавания() Экспорт
		
	Если СтруктураНастроек.ОбменДанными_ОпрашиватьСтатусЗаданийРаспознавания = Ложь Тогда
		ОтключитьОбработчикОжидания("ВыполнитьОбновлениеСтатусовЗаданийРаспознавания");
	КонецЕсли;
	
	Если ДанныеПользователя = Неопределено Тогда //Не авторизовался
		Возврат;
	ИначеЕсли Не ДанныеПользователя.phoneConfirm Тогда
		ПоказатьОповещениеПользователя("Не подтвержден телефон",,"Не удалось получить статус заданий распознавания");
		ОткрытьФормуПодтвержденияТелефона();		
		Возврат;
	КонецЕсли;
	
	Если ЗаданияРаспознавания_Таблица.Количество() > 0 Тогда
				
		УдалитьЗадания = Новый Массив;
		
		Для Каждого ЗаданиеРаспознавания Из ЗаданияРаспознавания_Таблица Цикл
			РезультатЗапроса = ВыполнитьЗапрос("СтатусЗаданияРаспознавания","GET","/api/v1/recognitionTasks/" + ЗаданиеРаспознавания.recognitionTaskId + "?format=xml");
			
			//Сейчас два статуса говорят о том, что распознание документа завершено, RECOGNIZED и ERROR
			Если РезультатЗапроса.Успешно Тогда
				Если РезультатЗапроса.state = "RECOGNIZED" Тогда //распознавание завершено
					УдалитьЗадания.Добавить(ЗаданиеРаспознавания.recognitionTaskId);
					
				ИначеЕсли РезультатЗапроса.state = "ERROR" Тогда //распознавание завершено с ошибками
					УдалитьЗадания.Добавить(ЗаданиеРаспознавания.recognitionTaskId);
					СообщитьСообщение("Ошибка распознавания файла <" + ЗаданиеРаспознавания.ИмяФайла + ">: " + РезультатЗапроса.errorDescription,СтатусСообщения.Важное);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого УдаляемоеЗадание Из УдалитьЗадания Цикл
			КоличествоФайлов = 0;
			УдаляемыеСтроки = ЗаданияРаспознавания_Таблица.НайтиСтроки(Новый Структура("recognitionTaskId",УдаляемоеЗадание));
			Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
				ИмяФайла = УдаляемаяСтрока.ИмяФайла;
				КоличествоФайлов = КоличествоФайлов + УдаляемаяСтрока.КоличествоФайлов;
				ЗаданияРаспознавания_Таблица.Удалить(УдаляемаяСтрока);
			КонецЦикла;
			
			//2019.05.14 (EN-438: теперь задания на распознавание нужно отображать и в списке документов
			//чтобы пользователь мог увидеть какие файлы загрузил а какие нет. Очищаем завершенные задания
			СтрокиЗадания = Объект.СписокДокументов.НайтиСтроки(Новый Структура("recognitionTaskId",УдаляемоеЗадание));
			Для каждого СтрокаЗадания Из СтрокиЗадания Цикл
				Объект.СписокДокументов.Удалить(СтрокаЗадания);
			КонецЦикла;
			// ) 2019.05.14
			
		КонецЦикла;
		
		//В старых конфигурациях может не оказаться этой картинки
		Попытка КартинкаУспешно = БиблиотекаКартинок.Успешно32; Исключение; КонецПопытки;
		
		Если УдалитьЗадания.Количество() = 1 Тогда
			ПоказатьОповещениеПользователя("Распознавание завершено",,ИмяФайла,КартинкаУспешно);
		ИначеЕсли УдалитьЗадания.Количество() > 1 Тогда
			ПоказатьОповещениеПользователя("Распознавание завершено",,"Распознавание " + КоличествоФайлов + " файлов завершено",КартинкаУспешно);
		КонецЕсли;
		
		Если ЗаданияРаспознавания_Таблица.Количество() = 0 Тогда
			ОтключитьОбработчикОжидания("ВыполнитьОбновлениеСтатусовЗаданийРаспознавания");
			Элементы.НаРаспознаванииАнимация.Видимость = Ложь;
			ОбновитьТекстКнопкиБаланс();
		КонецЕсли;
		
	КонецЕсли;
	
	БыстрыйФильтр_УстановитьОтборПоВыбраннымТипам();
	
	ПересчитатьИтогиПоСтатусамДокументов();
		
КонецПроцедуры

&НаКлиенте
Процедура ЗаданияРаспознаванияКоличествоСтрокНажатие(Элемент, СтандартнаяОбработка)
	ВыполнитьОбновлениеСтатусовЗаданийРаспознавания();
КонецПроцедуры

&НаКлиенте
Процедура ЗаданияРаспознавания_ПолучитьСписокВыполняющихся() Экспорт
				
	Если ЗначениеЗаполнено(Отбор_Пространство) Тогда
		
		РезультатЗапроса = ВыполнитьЗапрос("СписокВыполняющихсяЗаданийРаспознавания","GET","/api/v1/recognitionTasks/running?format=xml&spaceId=" + Отбор_Пространство);
		
		Если РезультатЗапроса.Успешно Тогда
		
			// добавить задания распознавания в коллекцию и отслеживать по настройке
			Для Каждого Задание Из РезультатЗапроса.МассивЗаданий Цикл
				
				СуществующиеЗадания = ЗаданияРаспознавания_Таблица.НайтиСтроки(Новый Структура("recognitionTaskId",Задание.recognitionTaskId));
				
				Если СуществующиеЗадания.Количество() = 0 Тогда
				
					НоваяСтрока = ЗаданияРаспознавания_Таблица.Добавить();
					НоваяСтрока.recognitionTaskId = Задание.recognitionTaskId;
					НоваяСтрока.ИмяФайла = Задание.ИмяФайла;
					НоваяСтрока.КоличествоФайлов = Задание.КоличествоФайлов;
					
				КонецЕсли;
							
			КонецЦикла;
		Иначе
			СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
		КонецЕсли;
		
		СписокДокументов_ОтобразитьЗаданияНаРаспознавание();
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура Команда_УскоритьРаспознавание(Команда)
	
	ТекСтрока = Элементы.СписокДокументов.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекСтрока.recognitionTaskId) Тогда
			 
			РезультатЗапроса = ВыполнитьЗапрос("УскорениеРаспознавания","POST","/api/v1/recognitionTasks/" + ТекСтрока.recognitionTaskId + "/speedUp?format=xml","{}");
			
			Если РезультатЗапроса.Успешно Тогда
				ПоказатьОповещениеПользователя("Ускорение распознавания",,"приоритет задания повышен");
			Иначе
				СообщитьСообщение("Запрос ускорения распознавания:" + Символы.ПС + РезультатЗапроса.ТекстОшибки);
			КонецЕсли;
			
		Иначе
			ПоказатьОповещениеПользователя("Ускорение распознавания",,"недоступно для уже распознанных документов");
			
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура Команда_УдалитьДокументНаПортале(Команда)
	
	МассивСтрок = Новый Массив;
	
	Для Каждого ИдентификаторСтроки Из Элементы.СписокДокументов.ВыделенныеСтроки Цикл
		СтрокаТаблицы = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
		//Задания распознавания не удаляются
		Если СтрокаТаблицы.recognitionTaskId = "" Тогда
			МассивСтрок.Добавить(ИдентификаторСтроки);
		КонецЕсли;
	КонецЦикла;	
	
	Если МассивСтрок.Количество() > 0 Тогда
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("МассивСтрок",МассивСтрок);
		
		ТекстВопроса = "Документы в выбранных строках будут удалены
					   |из вашего личного кабинета на сайте entera.pro, продолжить?";
		Кнопки = РежимДиалогаВопрос.ДаНет;
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_УдалениеДокументовНаПортале",ДопПараметры,ТекстВопроса,Кнопки);
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
	Иначе
		ПоказатьОповещениеПользователя("Удаление документов",,"не выбрано документов, доступных для удаления");
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продолжить_УдалениеДокументовНаПортале(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ОбщийТекстОшибки = "";
		
		УдаляемыеСтроки = Новый Массив;
		
		Для Каждого ЭлементМассива Из ДопПараметры.МассивСтрок Цикл
			
			СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(ЭлементМассива);
			
			РезультатЗапроса = ВыполнитьЗапрос("УдалениеДокументовНаПортале","DELETE","/api/v1/documents/" + СтрокаДокумента.ДокументИД + "?format=xml");
			
			Если РезультатЗапроса.Успешно Тогда
				УдаляемыеСтроки.Добавить(ЭлементМассива);
			Иначе
				ТекстОшибки = СтрокаДокумента.ПредставлениеДокумента + "<" + СтрокаДокумента.ДокументИД
					+ "> ошибка при удалении: " + РезультатЗапроса.ТекстОшибки;
				ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки);
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"УдалениеДокументов",ТекстОшибки,"УдалениеДокументов");
			КонецЕсли;
		КонецЦикла;
		
		//удаляем из списка успешно удаленные на портале
		Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
			СтрокаДокумента = Объект.СписокДокументов.НайтиПоИдентификатору(УдаляемаяСтрока);
			Объект.СписокДокументов.Удалить(СтрокаДокумента);
		КонецЦикла;
		
		//Уведомляем пользователя
		Если УдаляемыеСтроки.Количество() = 1 Тогда
			ПоказатьОповещениеПользователя("Удаление выполнено",,СтрокаДокумента.ПредставлениеДокумента);
		ИначеЕсли УдаляемыеСтроки.Количество() > 1 Тогда
			ПоказатьОповещениеПользователя("Удаление выполнено",,"Удалено документов: " + УдаляемыеСтроки.Количество());
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ОбщийТекстОшибки) Тогда
			СообщитьСообщение(ОбщийТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


// ================= Задания уведомлений ===================

&НаСервере
Функция УведомлениеПорталуОСозданииДокументов_ДобавитьДокумент(ДокументСсылка,ДокументИД)
	
	//Чтобы не заводить под это еще одну таблицу используется СписокЗначений, Значение - документ, Представление - идентификатор
	//перебираем Задания на наличие такого идентификатора в представлении
	
	Для Каждого ЭлементСписка Из ЗаданияУведомления Цикл
		Если ЭлементСписка.Представление = ДокументИД Тогда
			//Такой ИД документа уже есть, заменяем на актуальный документ
			ДобавляемыйЭлемент = ЭлементСписка;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ДобавляемыйЭлемент = Неопределено Тогда
		ЗаданияУведомления.Добавить(ДокументСсылка,ДокументИД);
	Иначе
		ДобавляемыйЭлемент.Значение = ДокументСсылка;
	КонецЕсли;		
	
КонецФункции
&НаКлиенте
Процедура УведомлениеПорталуОСозданииДокументов_ОпределитьНеобходимостьОтправки() Экспорт
		
	Если ЗаданияУведомления.Количество() > 0 Тогда
		
		// Отправляем по настройке		
		Если СтруктураНастроек.ОбменДанными_ОтправлятьУведомлениеОЗагрузкеАвтоматически = Истина Тогда
			УведомлениеПорталуОСозданииДокументов_Отправить();
			
		Иначе
			//с 2019.06.24 эта часть не выполняется, так как оставлена только автоматическая отправка
			Возврат;
			
			ДопПараметры = Новый Структура;
			ТекстВопроса = "Отправить уведомление порталу об успешном созданнии документов?
						   |(Вывод этого предупреждения можно отключить в настройках обработки)";
			Кнопки = РежимДиалогаВопрос.ДаНет;
			
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","УведомлениеПорталуОСозданииДокументов_ОбработатьОпределениеНеобходимостиОтправки",ДопПараметры,ТекстВопроса,Кнопки);
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Процедура УведомлениеПорталуОСозданииДокументов_ОбработатьОпределениеНеобходимостиОтправки(Результат,ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		УведомлениеПорталуОСозданииДокументов_Отправить();
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Функция УведомлениеПорталуОСозданииДокументов_Отправить() Экспорт
	
	ТелоЗапроса = УведомлениеПорталуОСозданииДокументов_СформироватьТелоЗапроса();
	
	Если ЗначениеЗаполнено(ТелоЗапроса) Тогда
		ПараметрыЗапроса = Новый Структура;
		РезультатЗапроса = ВыполнитьЗапрос("УведомлениеОСозданииДокументов","POST","/api/v1/integrations/1c?format=xml",ТелоЗапроса,ПараметрыЗапроса);
		
		Если РезультатЗапроса.Успешно Тогда
			//Список заданий уже очистили в ОбработатьРезультатЗапроса
		Иначе
			СообщитьСообщение("Отправка уведомления порталу о созданных документах:" + Символы.ПС + РезультатЗапроса.ТекстОшибки);
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции
&НаСервере
Функция УведомлениеПорталуОСозданииДокументов_СформироватьТелоЗапроса()
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Возврат РеквизитОбъект.УведомлениеПорталуОСозданииДокументов_СформироватьТелоЗапроса(ЗаданияУведомления);
	
КонецФункции


// ================= Работа со сканами документов ===================

&НаКлиенте
Функция ЗаполнитьАдресХранилищаСканаДокумента()
	
	Результат = Новый Структура("Успешно,ТекстОшибки,ТребуетсяПовтор",Истина);
	
	СтрокиДокументов = Объект.СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	
	ОбщийТекстОшибки = "";
	
	Счетчик = 0;
	
	ТребуетсяПовтор = Ложь;
	
	Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
		
		Счетчик = Счетчик + 1;
		Прогресс = Счетчик / СтрокиДокументов.Количество() * 100;
		Состояние("Получение сканов документов от портала...",Прогресс);
		
		ОписаниеСобытия = "Получение с портала файла скана для документа [" + СтрокаДокумента.ДокументИД + "]";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
		
		РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(СтрокаДокумента.ДокументИД,СтрокаДокумента.ПредставлениеДокумента);
		
		Если РезультатЗапроса.Успешно Тогда
			Если РезультатЗапроса.ТребуетсяПовтор Тогда
				ТребуетсяПовтор = Истина;
				ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
			Иначе
				СтрокаДокумента.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
				СтрокаДокумента.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
			КонецЕсли;
		Иначе
			ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
		КонецЕсли;
		
		//Также если используется настройка комплектов документов, нужно получить скан дочернего документа
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
			
			Если ЗначениеЗаполнено(СтрокаДокумента.parentId) Тогда
			
				СтрокиСвязанногоДокумента = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтрокаДокумента.parentId));
				
				Если СтрокиСвязанногоДокумента.Количество() > 0 Тогда
					
					СвязанныйДокумент = СтрокиСвязанногоДокумента[0];
					
					ОписаниеСобытия = "Получение с портала файла скана для связанного документа [" + СвязанныйДокумент.ДокументИД + "]";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");

					
					//E1C-13: для типа документа Чек не получаем печатные формы
					Если СвязанныйДокумент.ДокументТип <> "RECEIPT" Тогда
				
						РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(СвязанныйДокумент.ДокументИД,СвязанныйДокумент.ПредставлениеДокумента);
						
						Если РезультатЗапроса.Успешно Тогда
							Если РезультатЗапроса.ТребуетсяПовтор Тогда
								ТребуетсяПовтор = Истина;
								ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
							Иначе
								СвязанныйДокумент.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
								СвязанныйДокумент.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
							КонецЕсли;
						Иначе
							ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
						КонецЕсли;
						
					КонецЕсли;
				КонецЕсли;
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаДокумента.childrenId) Тогда
			
				СтрокиСвязанногоДокумента = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтрокаДокумента.childrenId));
				
				Если СтрокиСвязанногоДокумента.Количество() > 0 Тогда
				
					СвязанныйДокумент = СтрокиСвязанногоДокумента[0];
					
					ОписаниеСобытия = "Получение с портала файла скана для связанного документа [" + СвязанныйДокумент.ДокументИД + "]";
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");

					
					//E1C-13: для типа документа Чек не получаем печатные формы
					Если СвязанныйДокумент.ДокументТип <> "RECEIPT" Тогда
				
						РезультатЗапроса = ПолучитьПечатнуюФормуСканаДокумента(СвязанныйДокумент.ДокументИД,СвязанныйДокумент.ПредставлениеДокумента);
						
						Если РезультатЗапроса.Успешно Тогда
							Если РезультатЗапроса.ТребуетсяПовтор Тогда
								ТребуетсяПовтор = Истина;
								ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
							Иначе
								СвязанныйДокумент.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
								СвязанныйДокумент.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
							КонецЕсли;
						Иначе
							ДополнитьТекстОшибки(ОбщийТекстОшибки,РезультатЗапроса.ТекстОшибки);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
					
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	//нужно перенести полученные сведения в таблицы данных портала, чтобы были доступны из МК
	ЗаполнитьАдресХранилищаСканаДокументаВДанныхПортала(АдресХранилищаДанныхПортала);
	
	Результат.ТекстОшибки = ОбщийТекстОшибки;
	Результат.ТребуетсяПовтор = ТребуетсяПовтор;
	
	Возврат Результат;
		
КонецФункции
&НаКлиенте
Функция ПолучитьПечатнуюФормуСканаДокумента(ДокументИД,ПредставлениеДокумента) Экспорт
	
	Результат = Новый Структура("Успешно,ТекстОшибки,АдресВХ,ИмяФайла,ТребуетсяПовтор",Истина);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("ЗапросФайла",Истина);
	ПараметрыЗапроса.Вставить("ДокументИД",ДокументИД);
	ПараметрыЗапроса.Вставить("ПредставлениеДокумента",ПредставлениеДокумента);
	
	//ссылка на оригинальный файл: https://app.entera.pro/api/v1/documents/{documentId}/file
	//ссылка на сгенерированную печатную форму: https://app.entera.pro/api/v1/documents/:id/printForm
	МетодAPI = "/api/v1/documents/" + ДокументИД + "/printForm?format=xml";
	
	РезультатЗапроса = ВыполнитьЗапрос("ПолучениеФайлаСкана","GET",МетодAPI,,ПараметрыЗапроса);
	
	ТребуетсяПовтор = Ложь;
	
	Если РезультатЗапроса.Успешно Тогда
		Если РезультатЗапроса.Свойство("ПредложитьПовторитьЗапрос") Тогда
			ТребуетсяПовтор = Истина;
			Результат.ТекстОшибки = РезультатЗапроса.ТекстОшибки;
		Иначе
			Результат.АдресВХ = РезультатЗапроса.АдресВХ;
			Результат.ИмяФайла = РезультатЗапроса.ИмяФайла;
		КонецЕсли;
	Иначе
		Результат.Успешно = Ложь;
		ТекстОшибки = РезультатЗапроса.ТекстОшибки;
		Результат.ТекстОшибки = ТекстОшибки;
		
		ОписаниеСобытия = "Получение с портала файла скана для документа [" + ДокументИД + "]: " + ТекстОшибки;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
	КонецЕсли;
	
	Результат.ТребуетсяПовтор = ТребуетсяПовтор;
		
	Возврат Результат;
	
КонецФункции
&НаСервере
Процедура ЗаполнитьАдресХранилищаСканаДокументаВДанныхПортала(АдресХранилищаДанныхПортала) Экспорт
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РеквизитОбъект.ЗаполнитьАдресХранилищаСканаДокументаВДанныхПортала(АдресХранилищаДанныхПортала);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
КонецПроцедуры

&НаСервере
Процедура ПрисоединитьФайлы_СканыДокумента(ДокументСсылка,МассивФайлов,ОбщийТекстОшибки,СсылкаНового = Неопределено)
		
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	//2019.12.11 ( Костыль для старых конфигураций, проверено на УТ11.1, поэтому пока выполняем только для нее
	//в ней присутствует общий модуль РаботаСФайлами, но за присоединение отвечает общий модуль ПрисоединенныеФайлы
	Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Полн = "УТ11.1"
		//2021.04.07 ( новая БСП с полноценным переходом на РаботаСФайлами, судя по всему, начинается с 11.4
		Или СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Полн = "УТ11.2"
		Или СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Полн = "УТ11.3" Тогда
		// ) 2021.04.07
		
		//счета-фактуры там не предполагают хранения дополнительных файлов, прицепляем скан только к ПТиУ
		Если ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.СчетФактураПолученный") Тогда
			ОписаниеСобытия = "Прикрепление файла к документу <" + ДокументСсылка + "> пропущено, конфигурация не предполагает хранения доп. файлов для счетов-фактур";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
			
			Возврат;
		КонецЕсли;
		
		ПрисоединитьФайлы_СканыДокумента_Модуль_ПрисоединенныеФайлы(ДокументСсылка,МассивФайлов,ОбщийТекстОшибки);
		
		Возврат;
	Иначе
	// ) 2019.12.11
	
		МодульРаботаСФайлами = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("РаботаСФайлами");
	КонецЕсли;
	
	Если МодульРаботаСФайлами <> Неопределено Тогда
		
		ПервыйЭлемент = Истина;
		
		Для Каждого ЭлементМассива Из МассивФайлов Цикл
			
			ДанныеФайла = ЭлементМассива.АдресВХ;
			Если ЭтоАдресВременногоХранилища(ДанныеФайла) Тогда				        
				
				ОписаниеСобытия = "Прикрепление файла " + ЭлементМассива.ИмяФайла + " к документу " + ДокументСсылка;
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
				
				ПараметрыФайла = Новый Структура("Автор,ВладелецФайлов,ИмяБезРасширения,РасширениеБезТочки,ВремяИзмененияУниверсальное");
				ПараметрыФайла.ВладелецФайлов = ДокументСсылка;
				ПараметрыФайла.ИмяБезРасширения = ЭлементМассива.ИмяФайла;
				
				//Если передали ссылку на файл - присваиваем ее только первому из сохраненных файлов
				Если ПервыйЭлемент Тогда
					ПервыйЭлемент = Ложь;
					НоваяСсылкаНаФайл = СсылкаНового;
				Иначе
					НоваяСсылкаНаФайл = Неопределено;
				КонецЕсли;
									
				Попытка
					МодульРаботаСФайлами.ДобавитьФайл(ПараметрыФайла,ДанныеФайла,,,НоваяСсылкаНаФайл);
				Исключение
					ТекстОшибки = "<" + ДокументСсылка + "> ошибка при выполнении присоединения скана документа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки);
					
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ТекстОшибки,"ПолучениеСкана");
				КонецПопытки;
				
			Иначе
				ОписаниеСобытия = "При прикреплении файла к документу не был передан адрес во временном хранилище";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		ОписаниеСобытия = "Не обнаружен общий модуль конфигурации <РаботаСФайлами>";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
			
		//Общий модуль ПрисоединенныеФайлы является устаревшим, но в старых конфигурациях РаботаСФайлами может отсутствовать
		ПрисоединитьФайлы_СканыДокумента_Модуль_ПрисоединенныеФайлы(ДокументСсылка,МассивФайлов,ОбщийТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура ПрисоединитьФайлы_СканыДокумента_Модуль_ПрисоединенныеФайлы(ДокументСсылка,МассивФайлов,ОбщийТекстОшибки)
		
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");	
	
	МодульПрисоединенныеФайлы = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ПрисоединенныеФайлы");	

	Если МодульПрисоединенныеФайлы <> Неопределено Тогда
		
		Для Каждого ЭлементМассива Из МассивФайлов Цикл
			
			ДанныеФайла = ЭлементМассива.АдресВХ;
			Если ЭтоАдресВременногоХранилища(ДанныеФайла) Тогда				        
				
				ОписаниеСобытия = "Прикрепление файла " + ЭлементМассива.ИмяФайла + " к документу " + ДокументСсылка;
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
				
				Попытка
					МодульПрисоединенныеФайлы.ДобавитьФайл(ДокументСсылка, ЭлементМассива.ИмяФайла, , , , ДанныеФайла);
				Исключение
					ТекстОшибки = "<" + ДокументСсылка + "> ошибка при выполнении присоединения скана документа: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
					ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки);
					
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ТекстОшибки,"ПолучениеСкана");
				КонецПопытки;
				
			Иначе
				ОписаниеСобытия = "При прикреплении файла к документу не был передан адрес во временном хранилище";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
			КонецЕсли;
			
		КонецЦикла;
	Иначе
		ОписаниеСобытия = "Не обнаружен общий модуль конфигурации <ПрисоединенныеФайлы>";
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"ПолучениеСкана");
	КонецЕсли;
	
КонецПроцедуры


// ================= Работа с архивом документов ===================

&НаКлиенте
Процедура Команда_ПолучитьАрхивДокументов(Команда)
	
	//POST /api/v1/documents/archive
	//обязательные параметры spaceId/createdDateFrom/createdDateTo
		
	Если Не ЗначениеЗаполнено(Отбор_Пространство) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Пространство не может быть пустым";
		Сообщение.Поле = "Отбор_Пространство";		
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	//2024.09.15: Изначально отбор должен был задан по дате загрузки,
	//теперь обязателен отбор хотя бы по одному из полей дат: Дата документа или Дата создания
	
	Если Не ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаНачала)
		И Не ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаОкончания)
		И Не ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаНачала)
		И Не ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаОкончания) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
		Сообщение.Текст = "Не задан период выгружаемых документов или их даты загрузки!";
		Сообщение.Поле = "Отбор_ПериодЗагрузки";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	МетодAPI = "/api/v1/documents/archive?format=xml";
			
	ТелоЗапроса = СформироватьТелоЗапроса_РеестрАрхивДокументов();
		
	ОписаниеСобытия = "Получение архива документов с [" + Отбор_ПериодЗагрузки.ДатаНачала + "] по [" + Отбор_ПериодЗагрузки.ДатаОкончания + "]";
	ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
		
	РезультатЗапроса = ВыполнитьЗапрос("ПолучениеАрхиваДокументов","POST",МетодAPI,ТелоЗапроса);
	
	Если РезультатЗапроса.Успешно Тогда
		Попытка КартинкаУспешно = БиблиотекаКартинок.Успешно; Исключение КонецПопытки;
		ПоказатьОповещениеПользователя("Успешно",,"Ссылка для скачивания будет отправлена на электронную почту",КартинкаУспешно);
	Иначе
		ОписаниеСобытия = "Ошибка получения архива документов: " + РезультатЗапроса.ТекстОшибки;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Команда_ПолучитьРеестрДокументовАрхива(Команда)
	
	//POST /api/v1/documents/export
	
	//2024.09.15: Изначально отбор должен был задан по дате загрузки,
	//теперь обязателен отбор хотя бы по одному из полей дат: Дата документа или Дата создания
	
	Если Не ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаНачала)
		И Не ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаОкончания)
		И Не ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаНачала)
		И Не ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаОкончания) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
		Сообщение.Текст = "Не задан период выгружаемых документов или их даты загрузки!";
		Сообщение.Поле = "Отбор_ПериодЗагрузки";
		Сообщение.Сообщить();
		Возврат;
	КонецЕсли;
	
	МетодAPI = "/api/v1/documents/export?format=xml";
		
	ТелоЗапроса = СформироватьТелоЗапроса_РеестрАрхивДокументов();
		
	ОписаниеСобытия = "Получение реестра документов с [" + Отбор_ПериодЗагрузки.ДатаНачала + "] по [" + Отбор_ПериодЗагрузки.ДатаОкончания + "]";
	ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("ЗапросФайла",Истина);
	
	РезультатЗапроса = ВыполнитьЗапрос("ПолучениеРеестраАрхиваДокументов","POST",МетодAPI,ТелоЗапроса,ПараметрыЗапроса);
	
	Если РезультатЗапроса.Успешно Тогда
		ПолучитьФайл(РезультатЗапроса.АдресВХ,РезультатЗапроса.ИмяФайла,Истина);
	Иначе
		ОписаниеСобытия = "Ошибка получения реестра документов: " + ОписаниеОшибки();
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Функция СформироватьТелоЗапроса_РеестрАрхивДокументов()
	
	ТелоЗапроса = "";
	ТелоЗапроса = ТелоЗапроса + "{" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """filter"": {" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """spaceId"": """ + Отбор_Пространство + """" + Символы.ПС;
	
	Если ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаНачала) Тогда
		ТелоЗапроса = ТелоЗапроса + ",";
		ТелоЗапроса = ТелоЗапроса + """createdDateFrom"": """ + Формат(УниверсальноеВремя(Отбор_ПериодЗагрузки.ДатаНачала),"ДФ=yyyy-MM-ddTHH:mm:ss") + ".000Z" + """" + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодЗагрузки.ДатаОкончания) Тогда
		ТелоЗапроса = ТелоЗапроса + ",";
		ТелоЗапроса = ТелоЗапроса + """createdDateTo"": """ + Формат(УниверсальноеВремя(Отбор_ПериодЗагрузки.ДатаОкончания),"ДФ=yyyy-MM-ddTHH:mm:ss") + ".999Z" + """" + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаНачала) Тогда
		ТелоЗапроса = ТелоЗапроса + ",";
		ТелоЗапроса = ТелоЗапроса + """documentDateFrom"": """ + Формат(УниверсальноеВремя(Отбор_ПериодДокументов.ДатаНачала),"ДФ=yyyy-MM-ddTHH:mm:ss") + ".000Z" + """" + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_ПериодДокументов.ДатаОкончания) Тогда
		ТелоЗапроса = ТелоЗапроса + ",";
		ТелоЗапроса = ТелоЗапроса + """documentDateTo"": """ + Формат(УниверсальноеВремя(Отбор_ПериодДокументов.ДатаОкончания),"ДФ=yyyy-MM-ddTHH:mm:ss") + ".999Z" + """" + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_Плательщик) Тогда
		ТелоЗапроса = ТелоЗапроса + "," + Символы.ПС  + """customer"": [" + Символы.ПС;
		ПервыйЭлемент = Истина;
		Для Каждого ЭлементОтбора Из Отбор_Плательщик Цикл
			ТелоЗапроса = ТелоЗапроса + ?(ПервыйЭлемент,"",",") + """" + ЭлементОтбора.Значение + """";
			ПервыйЭлемент = Ложь;
		КонецЦикла;
		ТелоЗапроса = ТелоЗапроса + Символы.ПС + "]" + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Отбор_Поставщик) Тогда
		ТелоЗапроса = ТелоЗапроса + "," + Символы.ПС  + """supplier"": [" + Символы.ПС;
		ПервыйЭлемент = Истина;
		Для Каждого ЭлементОтбора Из Отбор_Поставщик Цикл
			ТелоЗапроса = ТелоЗапроса + ?(ПервыйЭлемент,"",",") + """" + ЭлементОтбора.Значение + """";
			ПервыйЭлемент = Ложь;
		КонецЦикла;
		ТелоЗапроса = ТелоЗапроса + Символы.ПС + "]" + Символы.ПС;
	КонецЕсли;
	
	ЕстьОтборПоТипу = Ложь;
	Для Каждого ТипДокумента Из БыстрыйФильтр_ТипыДокументов Цикл
		Если ТипДокумента.Пометка Тогда
			ЕстьОтборПоТипу = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьОтборПоТипу Тогда
		ТелоЗапроса = ТелоЗапроса + "," + Символы.ПС  + """documentType"": [" + Символы.ПС;
		ПервыйЭлемент = Истина;
		Для Каждого ТипДокумента Из БыстрыйФильтр_ТипыДокументов Цикл
			Если ТипДокумента.Пометка Тогда
				ТелоЗапроса = ТелоЗапроса + ?(ПервыйЭлемент,"",",") + """" + ТипДокумента.Значение + """";
				ПервыйЭлемент = Ложь;
			КонецЕсли;
		КонецЦикла;
		ТелоЗапроса = ТелоЗапроса + Символы.ПС + "]" + Символы.ПС;
	КонецЕсли;
	
	ТелоЗапроса = ТелоЗапроса + "}" + Символы.ПС; //filter
	ТелоЗапроса = ТелоЗапроса + "}";
	
	Возврат ТелоЗапроса;
	
КонецФункции


