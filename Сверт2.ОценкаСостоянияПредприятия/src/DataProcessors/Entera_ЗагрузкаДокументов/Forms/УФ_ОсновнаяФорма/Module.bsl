&НаКлиенте
Функция ОбработатьЗакрытиеФормы_СинхронноАсинхронно(Результат,ПараметрыВызова)
	
	//Сбрасываем значение переменной, хранящей форму
	ПараметрыВызова.Форма = Неопределено;
	ДопПараметры = ПараметрыВызова.ДопПараметры;
	
	Если ДопПараметры.Источник = "УФ_Авторизация" Тогда
		ОбработатьЗакрытиеФормыАвторизации(Результат);
	
	ИначеЕсли ДопПараметры.Источник = "УФ_ОтправляемыеФайлы" Тогда
		
		Если Результат <> Неопределено Тогда
			Если Результат.Свойство("ОтправляемыеФайлы") И Результат.ОтправляемыеФайлы.Количество() > 0 Тогда
				
				//Значение из настроек об уведомлении может быть изменено пользователем
				УведомлятьНаПочтуОВыполненныхЗаданиях = СтруктураНастроек.ОбменДанными_УведомлятьНаПочтуОВыполненныхЗаданиях;
				Результат.Свойство("УведомлятьНаПочтуОВыполненныхЗаданиях",УведомлятьНаПочтуОВыполненныхЗаданиях);
				
				РезультатЗапроса = ОтправитьДокументНаПортал(Результат.ОтправляемыеФайлы,УведомлятьНаПочтуОВыполненныхЗаданиях);
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ДопПараметры.Источник = "УФ_Дубликаты" Тогда
		Если Результат = Неопределено Тогда
			//Пользователь просто закрыл форму дубликатов, ничего не делаем
		Иначе
			ПродолжитьСозданиеДокументов_ПослеСопоставленияДубликатов(Результат,Результат.ДопПараметры);
		КонецЕсли;
		
	ИначеЕсли ДопПараметры.Источник = "УФ_ЗагружаемыеОбъекты" Тогда
		
		Если Результат = Неопределено Тогда
			//Пользователь просто закрыл форму сопоставления, ничего не делаем
			
		ИначеЕсли Результат.Успешно Тогда
			
			ОписаниеСобытия = "Все элементы созданы, переход к заполнению документов";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
	
			РезультатСоздания = СоздатьДокументыНаСервере(Результат.ДопПараметры);
			Если РезультатСоздания.Успешно = Истина Тогда
				
				//Если возникали ошибки их следует сообщить?
				Если ЗначениеЗаполнено(РезультатСоздания.ТекстОшибки) Тогда
					Сообщение = Новый СообщениеПользователю;
					Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
					Сообщение.Текст = "Документы были успешно созданы, но в процессе возникали ошибочные ситуации: " + Символы.ПС + РезультатСоздания.ТекстОшибки;
					Сообщение.Сообщить();
				КонецЕсли;
				
			Иначе
				Если ЭтоВебКлиент Тогда
					//в веб-клиенте в этом алгоритме может не отображаться СообщениеПользователю
					ПоказатьПредупреждение(,"Ошибка: " + РезультатСоздания.ТекстОшибки);
				Иначе
					Сообщение = Новый СообщениеПользователю;
					Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
					Сообщение.Текст = РезультатСоздания.ТекстОшибки;
					Сообщение.Сообщить();
				КонецЕсли;
			КонецЕсли;
			
			Если ЗаданияУведомления.Количество() > 0 Тогда
				ПодключитьОбработчикОжидания("УведомлениеПорталуОСозданииДокументов_ОпределитьНеобходимостьОтправки",0.1,Истина);
			КонецЕсли;
		Иначе
			ОписаниеСобытия = "Ошибка при создании элементов справочников: " + Результат.ТекстОшибки;
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			
			СообщитьСообщение(Результат.ТекстОшибки);
		КонецЕсли;
		
	ИначеЕсли ДопПараметры.Источник = "УФ_ОсновнаяФорма_Мультиселект" Тогда
		Мультиселект_СписокЗакрытиеФормы(Результат);
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	//2019.01.28 (EN-185: Перед открытием проверяем, если это окно уже открыто - переключаемся на него
	Окна = ПолучитьОкна();
	Для Каждого ОткрытоеОкно Из Окна Цикл
		Если ОткрытоеОкно.Заголовок = ЭтаФорма.Заголовок Тогда
			
			//2019.02.05 (при запуске НЕ в интерфейсе Такси на этом этапе форма уже присутствует в списке окон
			//но переключиться на нее платформа не дает, проверяем есть ли в содержимом формы ОкноКлиентскогоПриложения
			Если ОткрытоеОкно.Содержимое.Количество() > 0 Тогда
				Если ОткрытоеОкно.Содержимое[0].Окно <> Неопределено Тогда
					
					ОткрытоеОкно.Активизировать();					
					Отказ = Истина;
					
					Возврат;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	// ) 2019.01.28
	
	//2024.11.27 ( Функция перенесена из ПриСозданииНаСервере в ПриОткрытии из-за потенциальной проблемы
	//"Неизвестный идентификатор формы". Предположение: https://infostart.ru/1c/articles/2178185/
	АдресХранилищаДанныхПортала = ПолучитьАдресХранилищаДанныхПортала(УникальныйИдентификатор);
	// ) 2024.11.27
	
	#Если ВебКлиент Тогда
		ЭтоВебКлиент = Истина;
	#Иначе
		ЭтоВебКлиент = Ложь;
		СтруктураПодключения = ЗаполнитьСтруктуруПодключения();
	#КонецЕсли
			
	СимволТочка = ".";
	ПозицияТочки = СтрДлина(ЭтаФорма.ИмяФормы);
	Пока Сред(ЭтаФорма.ИмяФормы, ПозицияТочки, 1) <> СимволТочка Цикл 
		ПозицияТочки = ПозицияТочки - 1; 
	КонецЦикла; 
	ПрефиксИмениФорм = Лев(ЭтаФорма.ИмяФормы, ПозицияТочки);
	
	ЗаполнитьНастройки();
	
	//"Раскрасим" список отбора по статусу
	УстановитьОтборСтрокСпискаДокументов();
	
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	МодульКастомизации_ОбработатьСобытиеФормы_Клиент("ОсновнаяФорма_ПриОткрытии",ПараметрыМК);
				
	//Сперва покажем основную форму, потом окно авторизации
	ПодключитьОбработчикОжидания("ВыполнитьАвторизацию",0.1,Истина);
		
КонецПроцедуры
&НаСервереБезКонтекста
Функция ПолучитьАдресХранилищаДанныхПортала(УникальныйИдентификаторФормы)
	//Заполним адрес хранилища данных портала
	Возврат ПоместитьВоВременноеХранилище(Неопределено,УникальныйИдентификаторФормы);
КонецФункции
	
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ЗакрытиеФормы_Авторизация" Тогда
		ОбработатьЗакрытиеФормыАвторизации(Параметр);
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_ПодтверждениеТелефона" Тогда
		Если Параметр.Свойство("Токен") Тогда
			//После успешного выполнения потверждения телефона будет возвращена изменённая кука,
			//с которой нужно продолжать выполнять последующие запросы.
			Токен = Параметр.Токен;
			ДанныеПользователя.phoneConfirm = Истина;
		КонецЕсли;
	
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_Настройки" Тогда
		
		Если Параметр.Свойство("СтруктураНастроек",СтруктураНастроек) Тогда
			
			//Стартовать периодический опрос статусов заданий распознавания
			ВыполнитьОбновлениеСтатусовЗаданийРаспознавания();
			
			УстановитьВидимость_КомандыИнтерфейсаПоНастройкам();
			
			//E1C-149: новая команда-подменю контекстного меню списка документов для поиска существующего документа
			ПоискСуществующихДокументов_ЗаполнитьМенюСпискаТиповДокументов();
			
			// Используется модуль кастомизации в этих настройках
			УстановитьВидимость_ИспользуетсяМодульКастомизации();
			
			//Теперь список обрабатываемых типов документов храним в реквизите формы
			ЗаполнитьСписокОбрабатываемыхТиповДокументов();
			
			//токен для выполнения запросов с сервера при работе модуля кастомизации
			СтруктураНастроек.Вставить("Токен",Токен);
						
		КонецЕсли;
		
		//2019.09.09 (
		Если Параметр.Свойство("recognitionSettings")
			И ТипЗнч(СправочникиПортала) = Тип("Структура")
			И СправочникиПортала.Свойство("recognitionSettings") Тогда
				СправочникиПортала.recognitionSettings = Параметр.recognitionSettings;
		КонецЕсли;
		// ) 2019.09.09
		
		//Изменение некоторых настроек предполагает очистку списка документов
		Если Параметр.Свойство("ОчиститьСписокДокументов") И Параметр.ОчиститьСписокДокументов = Истина Тогда
			Объект.СписокДокументов.Очистить();
			ПересчитатьИтогиПоСтатусамДокументов();
		КонецЕсли;
		
		Если Параметр.Успешно Тогда
			УстановитьНаправленияДокументов();
			ВыполнитьПоискСсылокПоДаннымПорталаНаСервере();			
		КонецЕсли;
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_Мультиселект" Тогда
		Мультиселект_СписокЗакрытиеФормы(Параметр);
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_ВыгрузкаНоменклатуры" Тогда
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_СопоставлениеДубликатов" Тогда
		//Обработчик закрытия формы перенесен в _ЗФ_ОбработатьАсинхронныйВызов
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_ОтправляемыеФайлы" Тогда
		//Обработчик закрытия формы перенесен в _ЗФ_ОбработатьАсинхронныйВызов
		
	ИначеЕсли ИмяСобытия = "ЗакрытиеФормы_ЗагружаемыеОбъекты" Тогда
		//Обработчик закрытия формы перенесен в _ЗФ_ОбработатьАсинхронныйВызов
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьНастройки()
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Пространство",Отбор_Пространство);
	ПараметрыОткрытия.Вставить("РегионПространства",РегионПространства);
	ПараметрыОткрытия.Вставить("ИсходнаяСтруктураНастроек",СтруктураНастроек);
	ПараметрыОткрытия.Вставить("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
	ПараметрыОткрытия.Вставить("ВладелецФормыУникальныйИдентификатор",ЭтаФорма.УникальныйИдентификатор);
	ПараметрыОткрытия.Вставить("ЭтоРасширениеКонфигурации",ЭтоРасширениеКонфигурации);
	ПараметрыОткрытия.Вставить("ЭтоФреш",ЭтоФреш);
	
	Если ТипЗнч(СправочникиПортала) = Тип("Структура") И СправочникиПортала.Свойство("recognitionSettings") Тогда
		ПараметрыОткрытия.Вставить("recognitionSettings",СправочникиПортала.recognitionSettings);
	КонецЕсли;
	
	ФормаНастроек = ПолучитьФорму(ПрефиксИмениФорм + "УФ_Настройки", ПараметрыОткрытия, ЭтаФорма);
	СтруктураНастроек = ФормаНастроек.ПолучитьСтруктуруНастроекНаСервере();
	ФормаНастроек = Неопределено;
	
	//токен для выполнения запросов с сервера при работе модуля кастомизации
	СтруктураНастроек.Вставить("Токен",Токен);
	
	УстановитьВидимость_ИспользуетсяМодульКастомизации();
	УстановитьВидимость_КомандыИнтерфейсаПоНастройкам();
	
	//E1C-149: новая команда-подменю контекстного меню списка документов для поиска существующего документа
	ПоискСуществующихДокументов_ЗаполнитьМенюСпискаТиповДокументов();
	
	//Теперь список обрабатываемых типов документов храним в реквизите формы
	ЗаполнитьСписокОбрабатываемыхТиповДокументов();
	
	УстановитьНаправленияДокументов();
	
КонецПроцедуры
&НаСервере
Процедура УстановитьНаправленияДокументов()
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	РеквизитОбъект.ЗаполнитьНаправленияСоздаваемыхДокументов(АдресХранилищаДанныхПортала,СтруктураНастроек);
	ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	
	ЗаполнитьВСпискеДокументовДополнительныеДанные();
КонецПроцедуры
&НаКлиенте
Процедура УстановитьВидимость_КомандыИнтерфейсаПоНастройкам()
	
	//Кнопка выгрузки протокола видна, если включено его ведение
	Элементы.Команда_ВыгрузитьПротокол.Видимость = Не СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Нет";
	
	//Если не используются комплекты - команды контекстного меню для комплектов не отображаем
	//2020.10.01 ( Один из пользователей во Фреш умудрился прибить эту группу в форме,
	//чтобы не было ошибки выполнения - проверим наличие элемента
	Если Элементы.Найти("СписокДокументов_КонтекстноеМеню_Группа5") <> Неопределено Тогда
	// ) 2020.10.01
		Элементы.СписокДокументов_КонтекстноеМеню_Группа5.Видимость = СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина;
	КонецЕсли;
	
	//2021.02.25 ( Отображаем фильтр только при включенной настройке работы с ЭДО
	Если Элементы.Найти("ГруппаОтправленныеЭДО") <> Неопределено Тогда
		Элементы.ГруппаОтправленныеЭДО.Видимость = СтруктураНастроек.ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот = Истина;
	КонецЕсли;
	// ) 2021.02.25
	
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьСписокОбрабатываемыхТиповДокументов()
	
	ТипыСоздаваемыхДокументов.Очистить();
	
	Для Каждого ТипДокумента Из СтруктураНастроек.СведенияОКонфигурации.ТипыЗаполняемыхДокументов Цикл
		ТипыСоздаваемыхДокументов.Добавить(ТипДокумента.Значение,ТипДокумента.Представление);
	КонецЦикла;
	
	//Можем добавить "несуществующие" в метаданных типы документов, явным образом описав обработку таких значений программно.
	//Попробуем унифицировать описание: элементы значения, разделенные знаком подчеркивания "_"
	// - Префикс "Энтера" - определяем, что это "наш добавленный тип"
	// - Имя метаданных добавляемого документа
	// - Имя предопределенного значения для его получения функцией ПредопределенноеЗначение()
	// - имя метаданных справочника, переопределяющего используемый справочник для обработки товарных позиций документа
	
	Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ОсновныеСредства") Тогда
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
			//Для Казахстана пока не включаем, есть различия в структуре справочников
		Иначе
			ТипыСоздаваемыхДокументов.Добавить("Энтера_ПоступлениеТоваровУслуг_Перечисление.ВидыОперацийПоступлениеТоваровУслуг.ОсновныеСредства_ОсновныеСредства",
				"Поступление товаров и услуг: Основные средства");
		КонецЕсли;
	КонецЕсли;
	
	//E1C-509: аккуратно добавляем счет-фактуру на аванс
	Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БП30" Тогда
		Если РеквизитСуществует("Перечисления","ВидСчетаФактурыПолученного","НаАванс") Тогда
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
				//Для Казахстана пока не включаем, есть различия в структуре справочников
			Иначе
				ТипыСоздаваемыхДокументов.Добавить("Энтера_СчетФактураПолученный_Перечисление.ВидСчетаФактурыПолученного.НаАванс",
					"Счет-фактура на аванс");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьАвторизацию()
	ОткрытьФормуАвторизации(Истина);
КонецПроцедуры
&НаКлиенте
Процедура ОткрытьФормуАвторизации(ВыполнитьАвтоматическийВход)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ВыполнитьАвтоматическийВход",ВыполнитьАвтоматическийВход);
	ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыОткрытия.Вставить("ЭтоФреш",ЭтоФреш);
		
	ФормаАвторизации = ПолучитьФорму(ПрефиксИмениФорм + "УФ_Авторизация", ПараметрыОткрытия, ЭтаФорма);
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("Источник","УФ_Авторизация");
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,Форма","ОбработатьЗакрытиеФормы_СинхронноАсинхронно",ДопПараметры,ФормаАвторизации);
	
	_ЗФ_ОбработатьАсинхронныйВызов("ОткрытьФормуМодально",ПараметрыВызова);
		
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьЗакрытиеФормыАвторизации(Результат)
	
	Если Результат <> Неопределено И Результат.АвторизацияВыполнена Тогда
		Токен = Результат.Токен;
		Элементы.Авторизация.Заголовок = Результат.Логин;
		
		//E1C-14: Автоматическая авторизация
		Если Результат.Свойство("АвтоматическийВход") Тогда
			
			Попытка
				КартинкаАвторизация = БиблиотекаКартинок.Пользователь;
			Исключение
				//Не обрабатываем исключение
			КонецПопытки;
			
			ПоказатьОповещениеПользователя("Авторизация",,"Выполнен автоматический вход",КартинкаАвторизация);
		КонецЕсли;
				
		ЗаполнитьДанныеПользователя();
		ЗаполнитьСправочникиПортала();
		
		// 2019.08.03 ( Добавлен Стартовый помощник, открываем, если нет флага "Не открывать помощник"
		Если СтруктураНастроек.СистемныеНастройки_ОткрыватьСтартовыйПомощник = Истина Тогда
			ПодключитьОбработчикОжидания("ОткрытьФорму_СтартовыйПомощник",0.1,Истина);
			
		Иначе
		// ) 2019.08.03
		
			// 2019.01.29 (EN-195: Автоматическое обновление сразу после авторизации
			Если СтруктураНастроек.СистемныеНастройки_ЗаполнятьСписокДокументовПриСтарте Тогда
				Обновить(Неопределено);
			КонецЕсли;
			// ) 2019.01.29
			
			ПодключитьОбработчикОжидания("ПроверитьСписокНовыхВерсий",0.1,Истина);
			
		КонецЕсли;
		
		//2021.12.11 ( Покажем новости, пока просто по таймауту
		Если ДанныеПользователя_ТаблицаНовостей.Количество() > 0 Тогда
			ПодключитьОбработчикОжидания("ПоказатьНовости",10,Истина);
		КонецЕсли;
		// ) 2021.12.11
		
		//если потребуется заполнение данных для регламентного задания - поместим в СтруктуруНастроек логин/пароль
		СтруктураНастроек.Вставить("Логин",Результат.Логин);
		СтруктураНастроек.Вставить("Пароль",Результат.Пароль);
		
		//токен для выполнения запросов с сервера при работе модуля кастомизации
		СтруктураНастроек.Вставить("Токен",Токен);
		
	Иначе
		Элементы.Авторизация.Заголовок = "Авторизация";
	КонецЕсли;
	
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("Параметр",Результат);
	МодульКастомизации_ОбработатьСобытиеФормы_Клиент("ОсновнаяФорма_ЗакрытиеФормы_Авторизация",ПараметрыМК);
	
КонецПроцедуры
&НаКлиенте
Процедура ЗаполнитьДанныеПользователя()
	
	РезультатЗапроса = ВыполнитьЗапрос("ДанныеПользователя","GET","/api/v1/currentUser?format=xml");
		
	Если РезультатЗапроса.Успешно Тогда
		ОбновитьТекстКнопкиБаланс();
	
		//могло измениться пространство, перезаполним настройки
		ЗаполнитьНастройки();
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ЗаполнитьСправочникиПортала()
	
	РезультатЗапроса = ВыполнитьЗапрос("СправочникиПортала_ТипыДокументов","GET","/api/v1/documentTypes?format=xml");
	
	Если РезультатЗапроса.Успешно Тогда
		БыстрыйФильтр_ЗаполнитьТипыДокументов();
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
	РезультатЗапроса = ВыполнитьЗапрос("СправочникиПортала_СтатусыДокументов","GET","/api/v1/documentStates?format=xml");
	
	Если Не РезультатЗапроса.Успешно Тогда
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
	//Добавились списки поставщиков и плательщиков
	РезультатЗапроса = ВыполнитьЗапрос("СправочникиПортала_Плательщики","GET","/api/v1/spaces/" + Отбор_Пространство + "/customers?format=xml");
	
	Если РезультатЗапроса.Успешно Тогда
		//В реквизит элемента формы больше не заполняем, используем для выбора значения структуры СправочникиПортала
		Если Ложь Тогда
			Элементы.Отбор_Плательщик.СписокВыбора.Очистить();
			Если СправочникиПортала.Свойство("Плательщики") Тогда
				Для Каждого ЭлементСписка Из СправочникиПортала.Плательщики Цикл
					НовыйЭлемент = Элементы.Отбор_Плательщик.СписокВыбора.Добавить();
					ЗаполнитьЗначенияСвойств(НовыйЭлемент,ЭлементСписка);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
	//Поставщики	
	РезультатЗапроса = ВыполнитьЗапрос("СправочникиПортала_Поставщики","GET","/api/v1/spaces/" + Отбор_Пространство + "/suppliers?format=xml");
	
	Если РезультатЗапроса.Успешно Тогда
		//В реквизит элемента формы больше не заполняем, используем для выбора значения структуры СправочникиПортала
		Если Ложь Тогда
			Элементы.Отбор_Поставщик.СписокВыбора.Очистить();
			Если СправочникиПортала.Свойство("Поставщики") Тогда
				Для Каждого ЭлементСписка Из СправочникиПортала.Поставщики Цикл
					НовыйЭлемент = Элементы.Отбор_Поставщик.СписокВыбора.Добавить();
					ЗаполнитьЗначенияСвойств(НовыйЭлемент,ЭлементСписка);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСписокНовыхВерсий() Экспорт
	ПолучитьСписокНовыхВерсий(Ложь);
КонецПроцедуры
&НаКлиенте
Функция ПолучитьСписокНовыхВерсий(ПринудительнаяПроверка = Ложь)
		
	//При проверке обновлений по запросу пользователя показываем все изменения существующих версий
	Если ПринудительнаяПроверка Тогда
		НачальнаяВерсия = 0;
	Иначе
		НачальнаяВерсия = ВерсияМодуля.Версия;
	КонецЕсли;
	
	//E1C-169: При обновлении расширения следует проверить, есть ли описание новой версии, соответствующей версии расширения,
	//если есть - показываем, если нет - показываем только если это принудительная проверка обновлений
	Если ЭтоРасширениеКонфигурации И ПринудительнаяПроверка = Ложь Тогда
		ПоследняяЗапущеннаяВерсия = ПолучитьПоследнююЗапущеннуюВерсиюМодуля();
		Если ПоследняяЗапущеннаяВерсия = ВерсияМодуля.Версия Тогда
			ПоказатьОповещениеПользователя("Проверка обновлений",,"Используется актуальная версия расширения");
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ТипВерсии = ?(ЭтоФреш,"FRESH","1C");
	СтрокаЗапроса = "/api/v1/moduleVersions?format=xml&type=" + ТипВерсии + "&sinceVersion=" + НачальнаяВерсия;
		
	РезультатЗапроса = ВыполнитьЗапрос("ПолучениеСпискаНовыхВерсий","GET",СтрокаЗапроса);
	
	Если РезультатЗапроса.Успешно Тогда
		
		//Проверяем, это пользователь "руками" запросил список обновлений, или запрос был выполнен автоматически после авторизации
		Если ПринудительнаяПроверка = Истина
			Или РезультатЗапроса.ПоследняяВерсия <> РезультатЗапроса.НеНапоминатьОВерсии Тогда
		
			СписокНовыхВерсий = РезультатЗапроса.СписокНовыхВерсий;
			
			Если СписокНовыхВерсий.Количество() > 0 Тогда
			
				//Открываем форму списка обновлений
				ПараметрыОткрытия = Новый Структура;
				ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
				ПараметрыОткрытия.Вставить("ПрефиксИмениФорм",ПрефиксИмениФорм);
				ПараметрыОткрытия.Вставить("СписокНовыхВерсий",СписокНовыхВерсий);
				ПараметрыОткрытия.Вставить("ПринудительнаяПроверка",ПринудительнаяПроверка);
				ПараметрыОткрытия.Вставить("ЭтоФреш",ЭтоФреш);
				ПараметрыОткрытия.Вставить("ЭтоРасширениеКонфигурации",ЭтоРасширениеКонфигурации);
				
				ФормаОбновлений = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ФормаОбновлений",ПараметрыОткрытия,ЭтаФорма);
				ФормаОбновлений.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс;
				ФормаОбновлений.ЗакрыватьПриЗакрытииВладельца = Истина;
				ФормаОбновлений.Открыть();
				
			Иначе
				//При старте это показывать не обязательно?
				Если Не ПринудительнаяПроверка Тогда
					ПоказатьОповещениеПользователя("Проверка обновлений",,"Используется актуальная версия обработки");
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
	КонецЕсли;
	
КонецФункции
