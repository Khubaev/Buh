
&НаКлиенте
Перем
СтруктураПодключения,				// Данные для подключения при выполнении запросов с клиента
МодульМК_Клиент						// Форма модуля кастомизации для обработчиков клиентских событий
;		

&НаКлиенте
Перем
ЭтоВебКлиент                       // HTTP-запросы выполнять с сервера 
Экспорт;				

// ================= Обработчики событий формы ===================

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//Предустановленный отбор
	Если Не ЗначениеЗаполнено(Отбор_ПериодЗагрузки) Тогда
		Отбор_ПериодЗагрузки.Вариант = ВариантСтандартногоПериода.Последние7Дней;
	КонецЕсли;
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	//EN-180: версия обработки в интерфейсе и дата релиза
	ВерсияМодуля = РеквизитОбъект.ВерсияМодуля;
	
	//E1C-100: обработка используется в режиме расширения?
	Если Метаданные.Подсистемы.Найти("Entera_ЗагрузкаДокументов") <> Неопределено Тогда
		ЭтоРасширениеКонфигурации = Истина;
	КонецЕсли;
	
	ЭтоФреш = Не РеквизитОбъект.СведенияОВнешнейОбработке().Свойство("НеФреш");
	
	//E1C-168: Покажем в интерфейсе, где вообще работаем
	Если ЭтоРасширениеКонфигурации И ЭтоФреш Тогда
		Постфикс = "E";
	ИначеЕсли ЭтоФреш Тогда
		Постфикс = "F";
	Иначе
		Постфикс = "";
	КонецЕсли;
	
	Элементы.ТехподдержкаВерсия.Заголовок = "Версия 1." + ВерсияМодуля.Версия + Постфикс + " " + Формат(ВерсияМодуля.Дата,"ДФ=[yyyy.MM.dd]") + ".";
	
	Элементы.Команда_ЗарегистрироватьОбработку.Видимость = Ложь;
	_ЗФ_ДоступностьКоманды_ЗарегистрироватьОбработку(РеквизитОбъект);
		
	//Определим возможность использования описания оповещения
	СисИнфо = Новый СистемнаяИнформация;
	ВерсияМассив = РеквизитОбъект.Энтера_РазложитьСтрокуВМассивПодстрок(СисИнфо.ВерсияПриложения,".");
	ВтораяЦифра = Число(ВерсияМассив[1]); ТретьяЦифра = Число(ВерсияМассив[2]);
			
	ДоступноОписаниеОповещения = (ВтораяЦифра = 3 и ТретьяЦифра >= 4) Или ВтораяЦифра > 3;
		
	#Если ВебКлиент Тогда
		
	#Иначе
	
	#КонецЕсли
	
	//Установим картинку АнимацияОжидание
	НаРаспознаванииАнимация = ПоместитьВоВременноеХранилище(РеквизитОбъект.ПолучитьМакет("АнимацияОжидание"),УникальныйИдентификатор);
	
	Попытка
		КартинкаПечатнойФормы = БиблиотекаКартинок.ФорматPDF;
	Исключение
		КартинкаПечатнойФормы = БиблиотекаКартинок.Печать;
	КонецПопытки;
	
	//E1C-14: для Фреш не показываем
	Если Не ЭтоФреш Тогда
		//Установим картинку печатной формы для колонки списка документов	
		Элементы.СписокДокументовПредставлениеДокумента.КартинкаШапки = КартинкаПечатнойФормы;
		Элементы.СписокДокументов_ПрисоединитьФайлСканаКДокументу.Картинка = КартинкаПечатнойФормы;
	КонецЕсли;
	
	//E1C-133: скачивание файлов документов с портала
	Если Элементы.Найти("СписокДокументов_СкачатьPDF") <> Неопределено Тогда
		Элементы.СписокДокументов_СкачатьPDF.Картинка = КартинкаПечатнойФормы;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура _УФ_Команда_ЗарегистрироватьОбработку(Команда)
	
	АдресВХ = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяФайлаТекущейОбработки));
	Результат = _УФ_Команда_ЗарегистрироватьОбработкуНаСервере(АдресВХ);
	
	Если Результат.Успешно Тогда
		ПоказатьОповещениеПользователя("Успешно",,"Обработка успешно зарегистрирована в базе 1с"
			+ ?(ЗначениеЗаполнено(Результат.ИменаРазделов)," (" + Результат.ИменаРазделов + ")",""));
	Иначе
		СообщитьСообщение(Результат.ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция _УФ_Команда_ЗарегистрироватьОбработкуНаСервере(АдресВХ)
	
	Результат = Новый Структура("Успешно,ТекстОшибки",Ложь);
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ИмяФайла = РеквизитОбъект.ИспользуемоеИмяФайла;
	
	//Найдем публикацию этой обработки в справочнике внешних обработок
	МодульДополнительныеОтчетыИОбработки = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ДополнительныеОтчетыИОбработки");
	МодульОбщегоНазначения = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("ОбщегоНазначения");
	
	Если МодульДополнительныеОтчетыИОбработки <> Неопределено
		И МодульОбщегоНазначения <> Неопределено Тогда
		
		Обработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяОбъекта","Entera_ЗагрузкаДокументов");
		
		Если ЗначениеЗаполнено(Обработка) Тогда
			//обновляем текущую
			ОбработкаОбъект = Обработка.ПолучитьОбъект();
		Иначе
			ОбработкаОбъект = Справочники.ДополнительныеОтчетыИОбработки.СоздатьЭлемент();
		КонецЕсли;		
		
		ПараметрыРегистрации = РеквизитОбъект.СведенияОВнешнейОбработке();
		ПараметрыРегистрации.Вставить("ОтключатьКонфликтующие",Ложь);
		ПараметрыРегистрации.Вставить("ОтключатьПубликацию",Ложь);
		ПараметрыРегистрации.Вставить("Конфликтующие",Новый СписокЗначений);
		ПараметрыРегистрации.Вставить("ИмяФайла","Entera_ЗагрузкаДокументов.epf");
		ПараметрыРегистрации.Вставить("ЭтоОтчет",Ложь);
		ПараметрыРегистрации.Вставить("АдресДанныхОбработки",АдресВХ);
				
		ПодходящиеРазделы = Новый Массив;
		
		ИспользуемыеРазделы = МодульДополнительныеОтчетыИОбработки.РазделыДополнительныхОбработок();
		Для Каждого Раздел Из ИспользуемыеРазделы Цикл
			Если ТипЗнч(Раздел) = Тип("ОбъектМетаданных")
				И (Раздел.Имя = "Покупки"
				Или Раздел.Имя = "Закупки") Тогда
				ПодходящиеРазделы.Добавить(Раздел);
			КонецЕсли;
		КонецЦикла;
		
		//ОбработкаОбъект.БезопасныйРежим	= ПараметрыРегистрации.БезопасныйРежим;
		//ОбработкаОбъект.Версия = ПараметрыРегистрации.Версия;
		//ОбработкаОбъект.Вид = Перечисления.ВидыДополнительныхОтчетовИОбработок.ДополнительнаяОбработка;
		//ОбработкаОбъект.ИмяОбъекта = ПараметрыРегистрации.Наименование;
		//ОбработкаОбъект.ИмяФайла = "Entera_ЗагрузкаДокументов.epf";
		//ОбработкаОбъект.ИспользоватьДляФормыОбъекта	= Истина;
		//ОбработкаОбъект.ИспользоватьДляФормыСписка = Ложь;
		//ОбработкаОбъект.ИспользуетХранилищеВариантов = Ложь;
		//ОбработкаОбъект.Наименование = ПараметрыРегистрации.Наименование;
		//ОбработкаОбъект.Ответственный = ПараметрыСеанса.АвторизованныйПользователь;

		ОбработкаОбъект.Публикация = Перечисления.ВариантыПубликацииДополнительныхОтчетовИОбработок.Используется;
		ОбработкаОбъект.РежимСовместимостиРазрешений = Перечисления.РежимыСовместимостиРазрешенийДополнительныхОтчетовИОбработок.Версия_2_1_3;
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресВХ);
		ОбработкаОбъект.ХранилищеОбработки = Новый ХранилищеЗначения(ДвоичныеДанные);
		ОбработкаОбъект.ХранилищеНастроек = ОбработкаОбъект.ХранилищеОбработки;
		
		РезультатРегистрации = МодульДополнительныеОтчетыИОбработки.ЗарегистрироватьОбработку(ОбработкаОбъект, ПараметрыРегистрации);
				
		Если РезультатРегистрации.Успех = Истина Тогда
			
			//При записи новой внешней обработки в справочник в вызываемом методе ЗарегистрироватьОбработку() выполняется Объект.Разделы.Очистить()
			//поэтому разделы указываем уже после вызова этого метода
			Если ПодходящиеРазделы.Количество() > 0 И ОбработкаОбъект.Разделы.Количество() = 0 Тогда
				ИменаРазделов = "";
				Для Каждого Раздел Из ПодходящиеРазделы Цикл
					Если ОбработкаОбъект.Разделы.Найти(Раздел,"Раздел") = Неопределено Тогда
						НоваяСтрока = ОбработкаОбъект.Разделы.Добавить();
						НоваяСтрока.Раздел = МодульОбщегоНазначения.ИдентификаторОбъектаМетаданных(Раздел);
						ИменаРазделов = ИменаРазделов + ?(ИменаРазделов = "","","/") + Раздел.Имя;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			Попытка
				ОбработкаОбъект.Записать();
							
				Результат.Успешно = Истина;
				Результат.Вставить("ИменаРазделов",ИменаРазделов); 
			Исключение
				Результат.ТекстОшибки = "Ошибка при регистрации внешней обработки: " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			КонецПопытки;
		Иначе
			Результат.ТекстОшибки = РезультатРегистрации.ТекстОшибки;
		КонецЕсли;
			
	Иначе
		Результат.ТекстОшибки = "Ошибка при регистрации внешней обработки: в конфигурации не найден справочник ДополнительныеОтчетыИОбработки";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура _ЗФ_Команда_ПерейтиПоСсылке(url) Экспорт
	
	Если ЗначениеЗаполнено(СтруктураНастроек.СистемныеНастройки_ПутьКБраузеру) Тогда
		Попытка
			ЗапуститьПриложение(СтруктураНастроек.СистемныеНастройки_ПутьКБраузеру + " " + url);
		Исключение
			ПерейтиПоНавигационнойСсылке(url);
		КонецПопытки;
	Иначе
		ПерейтиПоНавигационнойСсылке(url);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура _ЗФ_Команда_ПоказатьФайлСкана(АдресВХ,ИмяФайла = Неопределено) Экспорт
	
	#Если ВебКлиент Тогда
		ПолучитьФайл(АдресВХ,ИмяФайла,Истина);
		
	#Иначе
		ФайлСкана = ПолучитьИмяВременногоФайла("pdf");
		
		ДанныеФайла = ПолучитьИзВременногоХранилища(АдресВХ);
		ДанныеФайла.Записать(ФайлСкана);
		
		ЗапуститьПриложение(ФайлСкана);
		
	#КонецЕсли
		
КонецПроцедуры
&НаСервере
Процедура _3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(ЗаписываемыйОбъект)
	//Для 1с:Фреш эту процедуру очищаем
	ЗаписываемыйОбъект.ОбменДанными.Загрузка = Истина;
КонецПроцедуры
&НаСервере
Функция _3Ф_ПодключитьВнешнююОбработку(АдресХранилища)
	
	//Комментарий для аудитора: Для Фреш не выполняется подключение дополнительной внешней обработки "Модуль кастомизации",
	//реквизит ЭтоФреш определяется в процедуре ПриСозданииНаСервере этой формы
	Если ЭтоФреш Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ВнешниеОбработки.Подключить(АдресХранилища)
КонецФункции
&НаСервере
Процедура _ЗФ_ДоступностьКоманды_ЗарегистрироватьОбработку(РеквизитОбъект)
	//Для 1с:Фреш эту процедуру очищаем	
	ИмяФайлаТекущейОбработки = РеквизитОбъект.ИспользуемоеИмяФайла;
		
	Если Найти(ИмяФайлаТекущейОбработки,"e1cib") > 0
		И Найти(ИмяФайлаТекущейОбработки,"tempstorage") > 0 Тогда
		//запуск уже подключенной в базе обработки
		Элементы.Команда_ЗарегистрироватьОбработку.Видимость = Ложь;
	Иначе
		Элементы.Команда_ЗарегистрироватьОбработку.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Функция _ЗФ_ОбработатьАсинхронныйВызов(ТипВызова,ПараметрыВызова) Экспорт
	
	//Для реализации возможности открытия этой формы внешней обработке на платформах, не поддерживающих ОписаниеОповещения,
	//(не будет пройден синтаксический контроль), обработчики асинхронных вызовов вынесены в эту процедуру.
	//Для прохождения аудита 1С:Фреш эта функция заменяется на аналогичную, но без методов Вычислить(). Profit!
	
	Если ТипВызова = "Вопрос" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВопрос(ОписаниеОповещения,ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		Иначе
			Вопрос(ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		КонецЕсли;
	
	ИначеЕсли ТипВызова = "ВыборИзМеню" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			
			ЭлементФормы = Неопределено;
			ПараметрыВызова.ДопПараметры.Свойство("ЭлементФормы",ЭлементФормы);
			
			ПоказатьВыборИзМеню(ОписаниеОповещения,ПараметрыВызова.СписокВыбора,ЭлементФормы);
		Иначе
			ВыбратьИзМеню(ПараметрыВызова.СписокВыбора);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыборИзСписка" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			
			ЭлементФормы = Неопределено;
			ПараметрыВызова.ДопПараметры.Свойство("ЭлементФормы",ЭлементФормы);
						
			ПоказатьВыборИзСписка(ОписаниеОповещения,ПараметрыВызова.СписокВыбора,ЭлементФормы);
		Иначе
			ВыбратьИзСписка(ПараметрыВызова.СписокВыбора);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВводСтроки" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВводСтроки(ОписаниеОповещения,ПараметрыВызова.Строка,ПараметрыВызова.Подсказка);
		Иначе
			ВвестиСтроку(ПараметрыВызова.Строка,ПараметрыВызова.Подсказка);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ПоказатьЗначение" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьЗначение(ОписаниеОповещения,ПараметрыВызова.Значение);
		Иначе
			ОткрытьЗначение(ПараметрыВызова.Значение);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ЗапуститьПриложение" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			//Экранируем от синтаксического контроля платформ до 8.3.6
			Выполнить("НачатьЗапускПриложения(ОписаниеОповещения,ПараметрыВызова.СтрокаЗапуска)");
		Иначе
			ЗапуститьПриложение(ПараметрыВызова.СтрокаЗапуска);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыбратьЭлементИзФормыВыбора" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.ФормаВыбора.ОписаниеОповещенияОЗакрытии = ОписаниеОповещения;
			ПараметрыВызова.ФормаВыбора.Открыть();
		Иначе
			Результат = ПараметрыВызова.ФормаВыбора.ОткрытьМодально();
			ПоискСуществующихДокументов_ВыборДокумента(Результат,ПараметрыВызова.ДопПараметры);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "УдалитьФайлы" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова_1Параметр"",ЭтаФорма,ПараметрыВызова)");
			НачатьУдалениеФайлов(ОписаниеОповещения,ПараметрыВызова.УдаляемыйФайл);
		Иначе
			УдалитьФайлы(ПараметрыВызова.УдаляемыйФайл);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ПоместитьФайлы" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещенияНачало = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова_3Параметра"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваНачало)");
			ОписаниеОповещенияОкончание = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваЗавершение)");
			НачатьПомещениеФайлов(ОписаниеОповещенияОкончание,,Истина,УникальныйИдентификатор,ОписаниеОповещенияНачало);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ДиалогВыбораФайла" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.ДиалогВыбораФайла.Показать(ОписаниеОповещения);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ОткрытьФормуМодально" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.Форма.ОписаниеОповещенияОЗакрытии = ОписаниеОповещения;
			ПараметрыВызова.Форма.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ПараметрыВызова.Форма.ЗакрыватьПриЗакрытииВладельца = Истина;
			ПараметрыВызова.Форма.Открыть();
		Иначе
			Результат = ПараметрыВызова.Форма.ОткрытьМодально();
			ОбработатьЗакрытиеФормы_СинхронноАсинхронно(Результат,ПараметрыВызова);
		КонецЕсли;
		          
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ОбработатьРезультатАсинхронногоВызова(Результат,ПараметрыВызова) Экспорт
		
	//Сюда в условия переносятся все присутствующие в форме обработчики результатов асинхронных вызовов
	Если ПараметрыВызова.Обработчик = "ОбработатьВыборИзМенюАвторизация" Тогда
		ОбработатьВыборИзМенюАвторизация(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ЗаполнитьСписокДокументов_КонтрольКоличестваДокументов" Тогда
		ЗаполнитьСписокДокументов_КонтрольКоличестваДокументов(Результат,ПараметрыВызова.ДопПараметры);
				
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеДокументов_Тип" Тогда
		ПродолжитьСозданиеДокументов_Тип(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеДокументов_ДублиВСписке" Тогда
		ПродолжитьСозданиеДокументов_ДублиВСписке(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеДокументов_СнятьОтметкиДублиВСписке" Тогда
		ПродолжитьСозданиеДокументов_СнятьОтметкиДублиВСписке(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеДокументов_ОбъединениеДокументов" Тогда
		ПродолжитьСозданиеДокументов_ОбъединениеДокументов(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеДокументов_ВсеСканыПолучены" Тогда
		ПродолжитьСозданиеДокументов_ВсеСканыПолучены(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_СписокДокументов_ОчиститьСвязь" Тогда
		Продолжить_СписокДокументов_ОчиститьСвязь(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_УдалениеДокументовНаПортале" Тогда
		Продолжить_УдалениеДокументовНаПортале(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продожить_СписокДокументов_РазъединениеКомплекта" Тогда
		Продожить_СписокДокументов_РазъединениеКомплекта(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продожить_СписокДокументов_ОбъединениеКомплекта" Тогда
		Продожить_СписокДокументов_ОбъединениеКомплекта(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_ИзменитьСтороныДокумента" Тогда
		Продолжить_ИзменитьСтороныДокумента(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_УстановитьСтатусДокумента" Тогда
		Продолжить_УстановитьСтатусДокумента(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_УстановитьСтатусДокумента_Выгружен" Тогда
		Продолжить_УстановитьСтатусДокумента_Выгружен(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продожить_СписокДокументов_ПроверкаСуммы" Тогда
		Продожить_СписокДокументов_ПроверкаСуммы(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПоискСуществующихДокументов_ВыборДокумента" Тогда
		ПоискСуществующихДокументов_ВыборДокумента(Результат,ПараметрыВызова.ДопПараметры);
	
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборФайлов_ВебКлиент" Тогда
		ОбработатьВыборФайлов_ВебКлиент(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборФайлов" Тогда
		ОбработатьВыборФайлов(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборКаталога_СкачатьФайлДокументаСПортала" Тогда
		ОбработатьВыборКаталога_СкачатьФайлДокументаСПортала(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "БыстрыйФильтр_ОбработатьВыборТипаДокумента" Тогда
		БыстрыйФильтр_ОбработатьВыборТипаДокумента(Результат,ПараметрыВызова);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Техподдержка_Помощь_ОбработатьВыборИзМеню" Тогда
		Техподдержка_Помощь_ОбработатьВыборИзМеню(Результат,ПараметрыВызова);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьЗакрытиеФормы_СинхронноАсинхронно" Тогда
		ОбработатьЗакрытиеФормы_СинхронноАсинхронно(Результат,ПараметрыВызова);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Заглушка_ОписаниеОповещения" Тогда
		//Ничего не выполняем
		
	ИначеЕсли ПараметрыВызова.Обработчик = "УведомлениеПорталуОСозданииДокументов_ОбработатьОпределениеНеобходимостиОтправки" Тогда
		УведомлениеПорталуОСозданииДокументов_ОбработатьОпределениеНеобходимостиОтправки(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьЗагрузкуДокументаПоПрямойСсылке" Тогда
		ОбработатьЗагрузкуДокументаПоПрямойСсылке(Результат);
			
	КонецЕсли;
КонецФункции
