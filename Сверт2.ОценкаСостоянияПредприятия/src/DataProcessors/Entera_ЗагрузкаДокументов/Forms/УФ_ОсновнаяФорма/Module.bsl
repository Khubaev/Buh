&НаКлиенте
Процедура СписокДокументов_СкачатьФайлДокументаСПортала(ТипФайла)
		
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ТипФайла",ТипФайла);
	
	//В веб-клиенте или с одним файлом обойдемся исходной схемой, иначе предложим выбрать каталог для сохранения файлов
	Если Не ЭтоВебКлиент И Элементы.СписокДокументов.ВыделенныеСтроки.Количество() > 1 Тогда
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
		Диалог.МножественныйВыбор = Ложь;
		
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ДиалогВыбораФайла","ОбработатьВыборКаталога_СкачатьФайлДокументаСПортала",ДопПараметры,Диалог);
		_ЗФ_ОбработатьАсинхронныйВызов("ДиалогВыбораФайла",ПараметрыВызова);
	Иначе
		ОбработатьВыборКаталога_СкачатьФайлДокументаСПортала("",ДопПараметры);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборКаталога_СкачатьФайлДокументаСПортала(Результат,ДопПараметры)
	
	Если Результат = "" Тогда
		//Просто получаем файлы по исходной схеме
	ИначеЕсли Результат = Неопределено Тогда
		Возврат;
	Иначе
		КаталогСохранения = Результат[0];
	КонецЕсли;
	
	ТипФайла = ДопПараметры.ТипФайла;
	МассивСохраняемыхФайлов = Новый Массив;
	
	//E1C-133
	//Скачивание оригинала файла или zip-архива с оригинальными файлами:
	//GET https://app.entera.pro/api/v1/documents/:id/files
	//Скачивание печатной формы в PDF, которую мы изготавливаем:
	//GET https://app.entera.pro/api/v1/documents/:id/printForm
	//Скачивание ФНС XML на основе распознанных данных работает только для типов документов УПД (UTD), ТОРГ-12 (TORG12), СЧФ (VAT_INVOICE)
	//GET https://app.entera.pro/api/v1/documents/:id/fnsXml
	
	//E1C-209: пакетное получение файлов, выбираем каталог для сохранения
	Для Каждого ИдентификаторСтроки Из Элементы.СписокДокументов.ВыделенныеСтроки Цикл
		
		ТекСтрока = Объект.СписокДокументов.НайтиПоИдентификатору(ИдентификаторСтроки);
	
		Если ТекСтрока <> Неопределено Тогда
			
			ДокументИД = ТекСтрока.документИД;
			
			ОписаниеСобытия = "Получение файла документа [" + ДокументИД + "] в формате [" + ТипФайла + "]";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
			
			ПараметрыЗапроса = Новый Структура;
			ПараметрыЗапроса.Вставить("ЗапросФайла",Истина);
			ПараметрыЗапроса.Вставить("ТипФайла",ТипФайла);
			ПараметрыЗапроса.Вставить("ДокументИД",ДокументИД);
			
			Если ТипФайла = "ORIGINAL" Тогда
				МетодAPI = "/api/v1/documents/" + ДокументИД + "/files?format=xml";
			ИначеЕсли ТипФайла = "PDF" Тогда
				МетодAPI = "/api/v1/documents/" + ДокументИД + "/printForm?format=xml";
			ИначеЕсли ТипФайла = "XML" Тогда
				МетодAPI = "/api/v1/documents/" + ДокументИД + "/fnsXml?format=xml";
			КонецЕсли;
			
			РезультатЗапроса = ВыполнитьЗапрос("ПолучениеРеестраАрхиваДокументов","GET",МетодAPI,"{}",ПараметрыЗапроса);
			
			Если РезультатЗапроса.Успешно Тогда
				//Если выбран каталог сохранения - соберем все файлы и сохраним их после получения в этот каталог
				Если КаталогСохранения = Неопределено Тогда
					ПолучитьФайл(РезультатЗапроса.АдресВХ,РезультатЗапроса.ИмяФайла,Истина);
				Иначе
					МассивСохраняемыхФайлов.Добавить(Новый Структура("АдресВХ,ИмяФайла",РезультатЗапроса.АдресВХ,РезультатЗапроса.ИмяФайла));
				КонецЕсли;
			Иначе
				ОписаниеСобытия = "Ошибка получения файла документа [" + ДокументИД + "]: " + ОписаниеОшибки();
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"Запрос",ОписаниеСобытия,"АрхивДокументов");	
				СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
		
	Если МассивСохраняемыхФайлов.Количество() > 0 Тогда
		
		ОшибкиПриСохранении = "";
		
		Для Каждого ДанныеФайла Из МассивСохраняемыхФайлов Цикл
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДанныеФайла.АдресВХ);
			Попытка
				ДвоичныеДанные.Записать(КаталогСохранения + ПолучитьРазделительПутиКлиента() + ДанныеФайла.ИмяФайла);
			Исключение
				ДополнитьТекстОшибки(ОшибкиПриСохранении,ОписаниеОшибки());
			КонецПопытки;
		КонецЦикла;
		
		Если ОшибкиПриСохранении = "" Тогда
			Попытка КартинкаУспешно = БиблиотекаКартинок.Успешно32; Исключение; КонецПопытки;
			ПоказатьОповещениеПользователя("Успешно",,"Все файлы сохранены в выбранный каталог",КартинкаУспешно);
		Иначе
			СообщитьСообщение("При загрузке файлов в выбранный каталог возникали ошибки:" + Символы.ПС + ОшибкиПриСохранении);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры


