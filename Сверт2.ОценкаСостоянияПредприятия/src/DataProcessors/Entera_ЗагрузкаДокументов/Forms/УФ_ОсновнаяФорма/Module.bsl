	ФормаОбновлений.Открыть();
	
КонецПроцедуры
&НаКлиенте
Функция ОбновитьТекстКнопкиБаланс(ЗапрашиватьКоличество = Ложь)
	
	//EN-353: Отображение Безлимитного тарифа в ui пользователя
	//Для пользователя с безлимитным тарифом отображать “Безлимитно до ДД.ММ.ГГГГ”
	//Для пользователей без безлимитного тарифа отображаться: “N страниц до ДД.ММ.ГГГГ”
	
	КоличествоСтраниц = 0;
	
	Если ДанныеПользователя.unlimited = Истина Тогда
		//E1C-385: теперь - не показываем
		Если Истина Тогда
			ТекстБаланс = "Подписка";
		Иначе
			ТекстБаланс = "Подписка: Безлимитно";
		КонецЕсли;
	Иначе
		Если ЗапрашиватьКоличество И ЗначениеЗаполнено(Отбор_Пространство) Тогда
			// /api/v1/spaces/:spaceId/balance
			РезультатЗапроса = ВыполнитьЗапрос("БалансСтраниц","GET","/api/v1/spaces/" + Отбор_Пространство + "/balance?format=xml");
			
			Если РезультатЗапроса.Успешно Тогда
				КоличествоСтраниц = РезультатЗапроса.balance;
			КонецЕсли;
			
		КонецЕсли;
		ТекстБаланс = "Подписка";
	КонецЕсли;
	
	//и дополняем датой завешения
	Если ЗначениеЗаполнено(ДанныеПользователя.transactionExpirationDate) Тогда
		ТекстБаланс = ТекстБаланс + " до " + Формат(ДанныеПользователя.transactionExpirationDate,"ДФ=dd.MM.yyyy");
	КонецЕсли;
	
	Элементы.КнопкаБаланс.Заголовок = ТекстБаланс;
	
	Результат = Новый Структура("Количество,ДатаОкончания,Безлимитно",КоличествоСтраниц,ДанныеПользователя.transactionExpirationDate,ДанныеПользователя.unlimited = Истина);
	Возврат Результат;
	
КонецФункции


