			ИначеЕсли ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
				И РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ОсновныеСредства")
				И СтруктураЗаполнения.Свойство("ВидОперации") И СтруктураЗаполнения.ВидОперации = Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ОсновныеСредства Тогда
				
				Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
					ИмяТЧТовары = "ОС";
				Иначе
					ИмяТЧТовары = "ОсновныеСредства";
				КонецЕсли;
				
				ИмяТЧУслуги = "Услуги";
				
				//Склад в этом случае не заполняем?
				ДокументОбъект.Склад = Неопределено;
			
			//2020.01.31 (БП30: Поступление в лизинг
			ИначеЕсли ТипСоздаваемогоДокумента = "ПоступлениеВЛизинг"
				Или ТипСоздаваемогоДокумента = "ПоступлениеВАренду" Тогда
				ИмяТЧТовары = "ПредметыЛизинга";
				ИмяТЧУслуги = "ПредметыЛизинга";
			// ) 2020.01.31
			
			// 2023.06.06 (
			ИначеЕсли ТипСоздаваемогоДокумента = "ПоступлениеУслугПоАренде" Тогда
				ИмяТЧТовары = "Начисления";
				ИмяТЧУслуги = "Начисления";
			// ) 2023.06.06
			
			// 2024.08.30 (
			ИначеЕсли ТипСоздаваемогоДокумента = "РеализацияУслугПоПереработке" Тогда
				ИмяТЧТовары = "МатериалыЗаказчика";
				ИмяТЧУслуги = "МатериалыЗаказчика";
			// ) 2024.08.30
			
			//2021.10.07 (БП30: Выпуск продукции (Отчет производства)
			ИначеЕсли ТипСоздаваемогоДокумента = "ОтчетПроизводстваЗаСмену" Тогда
				//E1C-524: Табличной части Материалы может не быть
				Если РеквизитСуществует("Документы","ОтчетПроизводстваЗаСмену",,"Материалы") Тогда
					ИмяТЧТовары = "Материалы";
				Иначе
					ИмяТЧТовары = "Продукция";
				КонецЕсли;
				ИмяТЧУслуги = "Услуги";
			// ) 2021.10.07
			
			//2024.12.03 (БП30: ВыплатыСамозанятым
			ИначеЕсли ТипСоздаваемогоДокумента = "ВыплатыСамозанятым" Тогда
				ИмяТЧТовары = "Выплаты";
				ИмяТЧУслуги = "Выплаты";
			// ) 2021.10.07
			
			//2023.07.06 ( БГУ2
			ИначеЕсли ТипСоздаваемогоДокумента = "РегистрацияОбязательствИСведенийПоДоговорам" Тогда
				ИмяТЧТовары = "РасшифровкаОбязательстваБюджет";
				ИмяТЧУслуги = "РасшифровкаОбязательстваБюджет";
			// ) 2023.07.06
			
			//2023.02.02 ( БСО
			ИначеЕсли ТипСоздаваемогоДокумента = "ИмпПриемкаСтроительныхРаботУслуг"
				Или ТипСоздаваемогоДокумента = "ИмпРеализацияСтроительныхРаботУслуг" Тогда
				ИмяТЧТовары = "Услуги";
				ИмяТЧУслуги = "Услуги";
			// ) 2023.02.02
			
			//2022.04.04
			ИначеЕсли ТипСоздаваемогоДокумента = "бит_ЗаявкаНаРасходованиеСредств" Тогда
				ТребуетсяЗаполнениеТЧ = Ложь;
			// ) 2022.04.04
			
			//2023.04.12 (Уже заполнили РасшифровкуПлатежа ранее при проверке типа документа
			ИначеЕсли ТипСоздаваемогоДокумента = "ПриходныйКассовыйОрдер" Тогда
				ТребуетсяЗаполнениеТЧ = Ложь;
			// ) 2023.04.12
			
			КонецЕсли;
			
			
			//2022.03.01 ( Пользователю теперь доступно изменение заполняемой табличной части
			Если ЗначениеЗаполнено(ДанныеДокумента.ИмяТабличнойЧасти) Тогда
				ИмяТЧТовары = ДанныеДокумента.ИмяТабличнойЧасти;
				ИмяТЧУслуги = ДанныеДокумента.ИмяТабличнойЧасти;
				ОписаниеСобытия = ?(ДанныеДокумента.ВидОперацииПринудительно = Истина,"Установлено Видом операции","Выбрано пользовательское")
					+ " значение ТЧ <" + ДанныеДокумента.ИмяТабличнойЧасти
					+ "> для документа <" + ТипСоздаваемогоДокумента + "> (" + ДокументИД + "): " + ОписаниеОшибки();
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"СозданиеДокументов",ОписаниеСобытия,"СозданиеДокументов");
			КонецЕсли;
			// ) 2022.03.01
						
			//Самопроверка: сообщим, если номенклатуру некуда заполнять
			Если ИмяТЧТовары = Неопределено И ИмяТЧУслуги = Неопределено И ТребуетсяЗаполнениеТЧ Тогда
				СообщитьСообщение("Внутренняя ошибка модуля: при заполнении документа с типом " + МенеджерОбъекта + " не удалось определить табличную часть для заполнения.");
			КонецЕсли;
			
			Если ДокументОбъект.Метаданные().Реквизиты.Найти("Склад") <> Неопределено Тогда
				СкладДляТабличнойЧасти = ДокументОбъект.Склад;
			ИначеЕсли ДокументОбъект.Метаданные().Реквизиты.Найти("СтруктурнаяЕдиница") <> Неопределено Тогда 
				СтруктурнаяЕдиницаДляТабличнойЧасти = ДокументОбъект.СтруктурнаяЕдиница;
			
			//E1C-347: Склад для табличной части заполняем независимо от наличия реквизита в шапке
			Иначе
				СкладДляТабличнойЧасти = ДанныеДокумента.СкладСсылка;
				СтруктурнаяЕдиницаДляТабличнойЧасти = ДанныеДокумента.СкладСсылка;
				
			КонецЕсли;
			
			//заполнение счетов учета в документах
			СчетаУчетаВДокументах_ЗаполнениеВыполнено = Ложь;
			МодульСчетаУчетаВДокументах = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("СчетаУчетаВДокументах");
			
			Для Каждого СтрокаНоменклатуры Из ДанныеНоменклатуры Цикл
				
				//2019.03.25 ( модуль кастомизации
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
				ПараметрыМК.Вставить("СтрокаНоменклатуры",СтрокаНоменклатуры);
				
				РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Документ_ПередЗаполнениемСтрокиТЧ",ПараметрыМК);
				
				Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
				// ) 2019.03.25
				
				    //Номенклатура, которую пользователь пометил как доп. расход, не попадает в основной документ
					Если СтрокаНоменклатуры.ПеренестиНаДопРасходы = Истина Тогда
						СтрокиДопРасходов.Добавить(СтрокаНоменклатуры);
						Продолжить;
					КонецЕсли;
					
					//Определяем услуга/товар
					ЭтоУслуга = Ложь;
					Если ЗначениеЗаполнено(СтрокаНоменклатуры.НоменклатураСсылка) Тогда
						Если Метаданные.Справочники.Номенклатура.Реквизиты.Найти("Услуга") <> Неопределено Тогда
							ЭтоУслуга = СтрокаНоменклатуры.НоменклатураСсылка.Услуга;
						ИначеЕсли Метаданные.Справочники.Номенклатура.Реквизиты.Найти("ТипНоменклатуры") <> Неопределено Тогда
							Если РеквизитСуществует("Перечисления","ТипыНоменклатуры","Услуга") Тогда
								ЭтоУслуга = СтрокаНоменклатуры.НоменклатураСсылка.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
									
					НоменклатураУслуга = ИмяТЧУслуги <> Неопределено И ЭтоУслуга = Истина;
					
					//E1C-257: Табличная часть Агентские услуги
					Если СтрокаНоменклатуры.ЭтоАгентскаяУслуга = Истина И ИмяТЧАгентскиеУслуги <> Неопределено Тогда
						НоваяСтрока = ДокументОбъект[ИмяТЧАгентскиеУслуги].Добавить();
					
					ИначеЕсли НоменклатураУслуга Или ИмяТЧТовары = Неопределено Тогда
						
						//2019.08.26 ( пропускаем заполнение табличной части, если не определили табличных частей
						Если ИмяТЧУслуги = Неопределено Тогда
							Продолжить;
						КонецЕсли;
						// ) 2019.08.26
						
						НоваяСтрока = ДокументОбъект[ИмяТЧУслуги].Добавить();
					Иначе
						НоваяСтрока = ДокументОбъект[ИмяТЧТовары].Добавить();
					КонецЕсли;
								
					СтруктураТовар = Новый Структура;
					СтруктураТовар.Вставить("Номенклатура",СтрокаНоменклатуры.НоменклатураСсылка);
					СтруктураТовар.Вставить("ЕдиницаИзмерения",СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
					СтруктураТовар.Вставить("Коэффициент",1);
					
					//E1C-407: Теперь у нас может заполняться поступление Основных средств
					СтруктураТовар.Вставить("ОсновноеСредство",СтрокаНоменклатуры.ОсновноеСредствоСсылка);
					СтруктураТовар.Вставить("ИнвентарныйНомер",СтрокаНоменклатуры.ИнвентарныйНомер);
					СтруктураТовар.Вставить("СрокПолезногоИспользования",СтрокаНоменклатуры.СрокСлужбы);
					
					Если ЗначениеЗаполнено(СтрокаНоменклатуры.ОсновноеСредствоСсылка) Тогда
						Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.ИнвентарныйНомер) Тогда
							СтруктураТовар.Вставить("ИнвентарныйНомер", 
							?(СтрокаНоменклатуры.ОсновноеСредствоСсылка.ЕдиницаУчета = Перечисления.ЕдиницыУчетаОС.ГрупповойОбъект,
								"", СтрокаНоменклатуры.ОсновноеСредствоСсылка.Код));
						КонецЕсли;
					КонецЕсли;
					
					//2023.09.22 ( Доверенность БП30 для Казахстана
					Если ТипСоздаваемогоДокумента = "Доверенность" Тогда
						СтруктураТовар.Вставить("НаименованиеТовара",СтрокаНоменклатуры.НоменклатураСсылка);
						СтруктураТовар.Вставить("ЕдиницаПоКлассификатору",СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
					КонецЕсли;
					// ) 2023.09.22
					
					//2023.03.10 ( Упаковка единиц измерения для УТ11-подобных конфигураций заполняется в табличной части
					//только в том случае, когда она отличается от единицы хранения Номенклатуры
					//Ниже выполняется пересчет количества из количества упаковок в зависимости от наличия ключа "Упаковка" в СтруктураТовар!
					Если Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
						Если ЗначениеЗаполнено(СтрокаНоменклатуры.НоменклатураСсылка)
							И СтрокаНоменклатуры.НоменклатураСсылка.ЕдиницаИзмерения <> СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка Тогда
							СтруктураТовар.Вставить("Упаковка",СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка);
						КонецЕсли;
					КонецЕсли;
					// ) 2023.03.10
					
					//2020.01.13 ( добавлены характеристики
					СтруктураТовар.Вставить("Характеристика",СтрокаНоменклатуры.ХарактеристикаСсылка);
					СтруктураТовар.Вставить("ХарактеристикаНоменклатуры",СтрокаНоменклатуры.ХарактеристикаСсылка);
					// ) 2020.01.13
					
					//2020.05.26 ( добавлена Номенклатура поставщика
					СтруктураТовар.Вставить("НоменклатураПоставщика",СтрокаНоменклатуры.НоменклатураПоставщикаСсылка);
					СтруктураТовар.Вставить("НоменклатураПартнера",СтрокаНоменклатуры.НоменклатураПоставщикаСсылка);
					// ) 2020.05.26
					
					//E1C-291: Объект для строки Номенклатуры
					Если ЗначениеЗаполнено(СтрокаНоменклатуры.ОбъектСсылка) Тогда
						СтруктураТовар.Вставить("Объект",СтрокаНоменклатуры.ОбъектСсылка);
					КонецЕсли;
					
					//2019.08.01 ( Используем КоэффициентПересчета если включен флаг в настройках
					ИспользоватьКоэффициентПересчета = СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьКоэффициентПересчета = Истина;
					КоэффициентПересчета = ?(ТипЗнч(СтрокаНоменклатуры.КоэффициентПересчета) = Тип("Число"),СтрокаНоменклатуры.КоэффициентПересчета,1);
					
					Если ИспользоватьКоэффициентПересчета Тогда
						quantity = СтрокаНоменклатуры.quantity * КоэффициентПересчета;
					Иначе
						quantity = СтрокаНоменклатуры.quantity;
					КонецЕсли;
					
					СтруктураТовар.Вставить("Количество",quantity);
					СтруктураТовар.Вставить("КоличествоУпаковок",quantity);
					СтруктураТовар.Вставить("КоличествоЕдиницИзмерения",quantity);
					// ) 2019.08.01
					
					//2025.10.15 ( При выбранной упаковке количество единиц может отличаться и расчитывается
					//в зависимости от коэффициента упаковки, вызовем стандартный пересчет.
					Если МодульОбработкаТабличнойЧастиКлиентСервер <> Неопределено Тогда
						Если СтруктураТовар.Свойство("Упаковка") Тогда
							СтруктураДействий = Новый Структура("ПересчитатьКоличествоЕдиниц");
							Попытка
								МодульОбработкаТабличнойЧастиКлиентСервер.ПересчитатьКоличествоЕдиницВСтрокеТЧ(СтруктураТовар,СтруктураДействий,КэшированныеЗначения);
							Исключение
								//Не обрабатываем
							КонецПопытки;
						КонецЕсли;
					КонецЕсли;
					// ) 2025.10.15
					
					Если УчитыватьНДС Тогда
						СтруктураТовар.Вставить("СуммаНДС",СтрокаНоменклатуры.vat);
						СтруктураТовар.Вставить("СтавкаНДС",СтрокаНоменклатуры.СтавкаНДССсылка);
					Иначе
						СтруктураТовар.Вставить("СуммаНДС",0);
						СтруктураТовар.Вставить("СтавкаНДС",СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС.БезНДС);
					КонецЕсли;
					
					Если СуммаВключаетНДС
						// 2019.05.30 ( для НЕ-плательщиков НДС сразу ставим общую сумму и расчетную цену 
						Или УчитыватьНДС = Ложь Тогда
						// ) 2019.05.30
						
						Если quantity = 0 Тогда
							Цена = 0;
						Иначе
							Попытка Цена = СтрокаНоменклатуры.amount / quantity; Исключение Цена = 0; КонецПопытки;
						КонецЕсли;
						
						СтруктураТовар.Вставить("Цена",Цена);
						СтруктураТовар.Вставить("Сумма",СтрокаНоменклатуры.amount);
						
					Иначе
						
						Если ИспользоватьКоэффициентПересчета Тогда
							
							Если quantity = 0 Тогда
								Цена = 0;
							Иначе
								Цена = СтрокаНоменклатуры.price / КоэффициентПересчета;
							КонецЕсли;
							
						Иначе
							Цена = СтрокаНоменклатуры.price;
							
						КонецЕсли;
						
						СтруктураТовар.Вставить("Цена",Цена);
						СтруктураТовар.Вставить("Сумма",СтрокаНоменклатуры.amountWithoutVat);
						
					КонецЕсли;
							
					СтруктураТовар.Вставить("СуммаСНДС",СтрокаНоменклатуры.amount);
					СтруктураТовар.Вставить("Всего",СтрокаНоменклатуры.amount);
					
					СтруктураТовар.Вставить("СуммаТовара",СтрокаНоменклатуры.amount);
					
					//2019.09.30 ( БИТ:Строительство. Приходный ордер
					СтруктураТовар.Вставить("ЦенаБух",СтруктураТовар.Цена);
					СтруктураТовар.Вставить("СуммаБух",СтруктураТовар.Сумма);
					СтруктураТовар.Вставить("СуммаНДСБух",СтруктураТовар.СуммаНДС);
					// ) 2019.09.30
					
					СтруктураТовар.Вставить("Склад",СкладДляТабличнойЧасти);
					СтруктураТовар.Вставить("СтруктурнаяЕдиница",СтруктурнаяЕдиницаДляТабличнойЧасти); //УНФ
					
					СтруктураТовар.Вставить("СпособУчетаНДС",СтрокаНоменклатуры.СпособУчетаНДС);
					СтруктураТовар.Вставить("ПодразделениеЗатрат",СтрокаНоменклатуры.ПодразделениеЗатратСсылка);
					
					СтруктураТовар.Вставить("Подразделение",ДанныеДокумента.ПодразделениеСсылка);
					СтруктураТовар.Вставить("ПодразделениеОрганизации",ДанныеДокумента.ПодразделениеОрганизацииСсылка);
					
					//E1C-363: Направление деятельности для КА2
					Если ЗначениеЗаполнено(НаправлениеДеятельностиСсылка) Тогда
						СтруктураТовар.Вставить("НаправлениеДеятельности",НаправлениеДеятельностиСсылка);
					КонецЕсли;
					
