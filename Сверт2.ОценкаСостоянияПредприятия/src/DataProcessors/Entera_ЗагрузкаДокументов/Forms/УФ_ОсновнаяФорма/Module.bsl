&НаКлиенте
Процедура УстановитьСнятьФлажкиВТаблице(Флаг, ВсемДокументам = Истина, ПечатнаяФорма = Ложь, ВключаяСкрытые = Ложь)
	
	Для Каждого Строка Из Объект.СписокДокументов Цикл 
		
		//По новой вводной если флаг снимаем для всех строк - то видимость строк значения не имеет
		Если ВсемДокументам И Не Флаг Тогда
			Строка.Пометка = Ложь;
			Продолжить;
		КонецЕсли;
		
		//Обрабатывать только видимые строки?
		Если Не Элементы.СписокДокументов.ПроверитьСтроку(Строка.ПолучитьИдентификатор()) Тогда
			
			//E1C-179: если флаг снимается не для всех документов, но включая скрытые
			Если ВключаяСкрытые И Не ВсемДокументам И Не Флаг Тогда
				Строка.Пометка = Ложь;
			КонецЕсли;
			
			Продолжить;
		КонецЕсли;
		
		// 2019.05.14 ( EN-438: теперь задания на распознавание нужно отображать и в списке документов, таким строкам флаг не устанавливаем
		Если ЗначениеЗаполнено(Строка.recognitionTaskId) Тогда
			Строка.Пометка = Ложь;
			Продолжить;
		КонецЕсли;
		// ) 2019.05.14
		
		Если ВсемДокументам Тогда
			Строка.Пометка = Флаг;
			
		ИначеЕсли ПечатнаяФорма Тогда
			Если Флаг Тогда
				Строка.Пометка = Строка.ИндексКартинкиПечатнойФормы = 0;
			Иначе
				Строка.Пометка = Строка.ИндексКартинкиПечатнойФормы = 0 И Строка.Пометка;
			КонецЕсли;
			
		Иначе
			Если Флаг Тогда
				Строка.Пометка = Не ЗначениеЗаполнено(Строка.Документ1с);
			Иначе
				Строка.Пометка = Не ЗначениеЗаполнено(Строка.Документ1с) И Строка.Пометка;
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры


