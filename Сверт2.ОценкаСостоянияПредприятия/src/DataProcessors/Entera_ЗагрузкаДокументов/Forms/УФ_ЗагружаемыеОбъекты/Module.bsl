Функция СоздатьЭлементСправочника_ИсточникПроисхождения(СтруктураЗаполнения,ТекстОшибки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(СтруктураЗаполнения.ИдентификаторСтроки);
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	Если Метаданные.Справочники.Найти("НомераГТД") = Неопределено Тогда
		Результат = СтруктураЗаполнения.Код;
	Иначе
		
		ПараметрыПоиска = Новый Структура("Код,КодТНВЭД,НомерСтрокиГТД",
			ТекСтрока.ИсточникиПроисхождения_Код,ТекСтрока.ИсточникиПроисхождения_КодТНВЭД,ТекСтрока.ИсточникиПроисхождения_НомерСтрокиГТД);
		Результат = РеквизитОбъект.ПолучитьСсылку_ИсточникПроисхождения(ПараметрыПоиска);
		
		Если Не ЗначениеЗаполнено(Результат) Тогда
			НомерГТДОбъект = Справочники.НомераГТД.СоздатьЭлемент(); 		
			
			СтруктураЗаполнения.Вставить("СтранаПроисхожденияТовара",ТекСтрока.ИсточникиПроисхождения_СтранаПроисхождения);
			СтруктураЗаполнения.Вставить("СпособПроисхожденияТовара",ТекСтрока.ИсточникиПроисхождения_СпособПроисхождения);
			СтруктураЗаполнения.Вставить("ПризнакПроисхождения",ТекСтрока.ИсточникиПроисхождения_ПризнакПроисхождения);
			СтруктураЗаполнения.Вставить("НомерСтрокиГТД",ТекСтрока.ИсточникиПроисхождения_НомерСтрокиГТД);
			СтруктураЗаполнения.Вставить("КодТНВЭД",ТекСтрока.ИсточникиПроисхождения_КодТНВЭД);
			
			СтруктураЗаполнения.Вставить("Комментарий","#Создан автоматически при загрузке из сервиса Entera.pro");
			
			ЗаполнитьЗначенияСвойств(НомерГТДОбъект,СтруктураЗаполнения);
			
			// ( модуль кастомизации
			ПараметрыМК = Новый Структура;
			ПараметрыМК.Вставить("ТекущаяСтрока",ТекСтрока);
			ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
			ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
			ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
			ПараметрыМК.Вставить("ДокументИД",СтруктураЗаполнения.ДокументИД);
			ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
			ПараметрыМК.Вставить("Объект",НомерГТДОбъект);
			ПараметрыМК.Вставить("Ссылка",Результат);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_ИсточникПроисхождения_ПередЗаписью",ПараметрыМК);
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			// ) модуль кастомизации
			
				Попытка
					НомерГТДОбъект.Записать();
					Результат = НомерГТДОбъект.Ссылка;
				Исключение
					ТекстОшибки = "Запись номера ГТД " + СтруктураЗаполнения.Код + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
				КонецПопытки;
				
			Иначе
				Результат = ПараметрыМК.Ссылка;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
		
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ЗаписатьСоответствиеНоменклатуры(НоменклатураСсылка,ХарактеристикаСсылка,Наименование,КонтрагентИД)
	
	//таблица хранится по исходной схеме в настройках текущего пользователя
	СвязьНоменклатуры = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьНоменклатуры");
	
	Если СвязьНоменклатуры = Неопределено Тогда
		СвязьНоменклатуры = Новый ТаблицаЗначений;
		СвязьНоменклатуры.Колонки.Добавить("Ссылка");
		СвязьНоменклатуры.Колонки.Добавить("Наименование");
		СвязьНоменклатуры.Колонки.Добавить("КонтрагентИД");
	КонецЕсли;
	
	//2020.01.13 ( добавлена работа с характеристиками
	Если СвязьНоменклатуры.Колонки.Найти("Характеристика") = Неопределено Тогда
		СвязьНоменклатуры.Колонки.Добавить("Характеристика");
	КонецЕсли;
	// ) 2020.01.13
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Наименование",Наименование);
	СтруктураПоиска.Вставить("КонтрагентИД",КонтрагентИД);
	
	НайденныеСтроки = СвязьНоменклатуры.НайтиСтроки(СтруктураПоиска);
	
	Если ЗначениеЗаполнено(НоменклатураСсылка) Тогда
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = СвязьНоменклатуры.Добавить();
			ТекстОповещения = "Связь номенклатуры добавлена";
		Иначе
			НоваяСтрока = НайденныеСтроки[0];
			ТекстОповещения = "Связь номенклатуры обновлена"
		КонецЕсли;
		
		НоваяСтрока.Ссылка = НоменклатураСсылка;
		НоваяСтрока.Наименование = Наименование;
		НоваяСтрока.КонтрагентИД = КонтрагентИД;
		НоваяСтрока.Характеристика = ХарактеристикаСсылка;
		
	Иначе
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				СвязьНоменклатуры.Удалить(НайденнаяСтрока);
			КонецЦикла;		
			ТекстОповещения = "Связь номенклатуры очищена";
		КонецЕсли;
	КонецЕсли;
	
	//сохраняем по исходной схеме, в настройках пользователя
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","СвязьНоменклатуры",СвязьНоменклатуры);
	
	Возврат ТекстОповещения;
	
КонецФункции
