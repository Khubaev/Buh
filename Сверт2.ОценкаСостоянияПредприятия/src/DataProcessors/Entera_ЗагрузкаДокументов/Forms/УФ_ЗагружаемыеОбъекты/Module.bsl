&НаСервере
Функция Договоры_СформироватьПредставление(ИдентификаторСтроки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	Если ТекСтрока <> Неопределено Тогда
		
		СтруктураДанных = Новый Структура("transferBaseDate,transferBaseName,transferBaseNumber,transferBaseAdditionalInfo",
			ТекСтрока.Договоры_Дата,ТекСтрока.Договоры_Наименование,ТекСтрока.Договоры_Номер,ТекСтрока.Договоры_ДопИнформация);
			
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		Представление = РеквизитОбъект.ЗаполнениеДокумента_Договор_СформироватьПредставление(СтруктураДанных,СтруктураНастроек);
		
		Если ЗначениеЗаполнено(Представление) Тогда
			ТекСтрока.ПредставлениеОбъекта = Представление;
		Иначе
			ТекСтрока.ПредставлениеОбъекта = СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора;
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции


&НаКлиенте
Процедура ВыполнитьГрупповуюОбработкуВыделенныхСтрок(ИмяРеквизита)
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока.ТипОбъекта = "Номенклатура"
		Или ТекСтрока.ТипОбъекта = "ОсновныеСредства"
		Или ТекСтрока.ТипОбъекта = "Документ"
		Или ТекСтрока.ТипОбъекта = "Договоры"
		Или ТекСтрока.ТипОбъекта = "ИсточникиПроисхождения" Тогда
	
		Если ТекСтрока <> Неопределено И ЗначениеЗаполнено(ТекСтрока[ИмяРеквизита]) Тогда
			
			//Срабатывать должно только если выделено больше одной строки
			ВыделенныеСтроки = Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки;
			
			Если ВыделенныеСтроки.Количество() > 1 Тогда
				
				ДопПараметры = Новый Структура;
				ДопПараметры.Вставить("ИмяРеквизита",ИмяРеквизита);
				ДопПараметры.Вставить("ТипОбъекта",ТекСтрока.ТипОбъекта);
				ДопПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
				ДопПараметры.Вставить("ВыделенныеСтроки",ВыделенныеСтроки);
				
				ТекстВопроса = "Установить это значение для всех выделенных строк данного типа?";
				Кнопки = РежимДиалогаВопрос.ДаНет;
				ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьВыполнениеГрупповойОбработкиВыделенныхСтрок",ДопПараметры,ТекстВопроса,Кнопки);
				
				_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
				
			ИначеЕсли ВыделенныеСтроки.Количество() = 1 Тогда
				
				Если ТекСтрока.ТипОбъекта = "Номенклатура"
					Или ТекСтрока.ТипОбъекта = "ОсновныеСредства" Тогда
					
					ОбрабатываемаяСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ВыделенныеСтроки[0]);
					
					//Заполним аналитику по выбранному счету учета
					Если ИмяРеквизита = "Номенклатура_СчетУчета" Тогда
						СтруктураДанных = СчетаУчета_ПолучитьСтруктуруДанныхДляОпределения(ОбрабатываемаяСтрока);
						СчетаУчета = СчетаУчета_ПолучитьСчетаУчетаНоменклатуры(СтруктураНастроек,СтруктураДанных);
						Если СчетаУчета <> Неопределено И Не СтруктураДанных.АгентскиеУслуги Тогда
							СчетаУчета_ЗаполнитьАналитикуСчетовУчета(ОбрабатываемаяСтрока,СчетаУчета);
						КонецЕсли;
						
					ИначеЕсли ИмяРеквизита = "Номенклатура_Комитент" Тогда
						СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(ОбрабатываемаяСтрока);
						
					ИначеЕсли ИмяРеквизита = "Номенклатура_ВидНоменклатуры" Тогда
						//E1C-523: На этапе сопоставления заполнять поле "Группа финансового учета"
						СтруктураЗаполненияСвязанныхРеквизитов = ВидНоменклатуры_ПолучитьСтруктуруЗаполненияСвязанныхРеквизитов(СтруктураНастроек,ТекСтрока.Номенклатура_ВидНоменклатуры);
						Если СтруктураЗаполненияСвязанныхРеквизитов <> Неопределено Тогда
							ЗаполнитьЗначенияСвойств(ОбрабатываемаяСтрока,СтруктураЗаполненияСвязанныхРеквизитов);
						КонецЕсли;
						
					КонецЕсли;
					
				ИначеЕсли ТекСтрока.ТипОбъекта = "Документ" Тогда
					// 2022.02.24 ( Дадим выбрать подотчетное лицо
					Если ИмяРеквизита = "Документ_ВидОперации" Тогда
						ЗагружаемыеОбъектыПриАктивизацииСтроки(Элементы.ЗагружаемыеОбъекты);
					КонецЕсли;
					// ) 2022.02.24
					
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьВыполнениеГрупповойОбработкиВыделенныхСтрок(Результат,ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДопПараметры.ИдентификаторСтроки);
		Значение = ТекСтрока[ДопПараметры.ИмяРеквизита];
				
		Для Каждого ИдентификаторСтроки Из ДопПараметры.ВыделенныеСтроки Цикл

			ОбрабатываемаяСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
			
			//Обрабатываем строки с тем же типом объекта, как в исходной
			Если ОбрабатываемаяСтрока.ТипОбъекта = ДопПараметры.ТипОбъекта Тогда
				
				//E1C-178: Вид операции документа обработаем только для строк, имеющих такой же тип создаваемого документа
				Если ТекСтрока.ТипОбъекта = "Документ" Тогда
					Если ОбрабатываемаяСтрока.ТипСоздаваемогоДокумента = ТекСтрока.ТипСоздаваемогоДокумента Тогда
						ОбрабатываемаяСтрока[ДопПараметры.ИмяРеквизита] = Значение;
					КонецЕсли;
						
				Иначе
					//Исходная логика
				
					ОбрабатываемаяСтрока[ДопПараметры.ИмяРеквизита] = Значение;
					
					//Заполним аналитику по выбранному счету учета
					Если ДопПараметры.ИмяРеквизита = "Номенклатура_СчетУчета" Тогда
						СтруктураДанных = СчетаУчета_ПолучитьСтруктуруДанныхДляОпределения(ОбрабатываемаяСтрока);
						СчетаУчета = СчетаУчета_ПолучитьСчетаУчетаНоменклатуры(СтруктураНастроек,СтруктураДанных);
						Если СчетаУчета <> Неопределено И Не СтруктураДанных.АгентскиеУслуги Тогда
							СчетаУчета_ЗаполнитьАналитикуСчетовУчета(ОбрабатываемаяСтрока,СчетаУчета);
						КонецЕсли;
						
					ИначеЕсли ДопПараметры.ИмяРеквизита = "Номенклатура_Комитент" Тогда
						ОбрабатываемаяСтрока.Номенклатура_ДоговорКомитента = ТекСтрока.Номенклатура_ДоговорКомитента;
						СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(ОбрабатываемаяСтрока);
						
					ИначеЕсли ДопПараметры.ИмяРеквизита = "Номенклатура_ВидНоменклатуры" Тогда
						//E1C-523: На этапе сопоставления заполнять поле "Группа финансового учета"
						СтруктураЗаполненияСвязанныхРеквизитов = ВидНоменклатуры_ПолучитьСтруктуруЗаполненияСвязанныхРеквизитов(СтруктураНастроек,ТекСтрока.Номенклатура_ВидНоменклатуры);
						Если СтруктураЗаполненияСвязанныхРеквизитов <> Неопределено Тогда
							ЗаполнитьЗначенияСвойств(ОбрабатываемаяСтрока,СтруктураЗаполненияСвязанныхРеквизитов);
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура Номенклатура_ХарактеристикаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ВидНоменклатуры = УстановитьСвязьПараметровВыбора_СправочникаХарактеристики(Элементы.ЗагружаемыеОбъекты.ТекущаяСтрока,СтандартнаяОбработка);
	Если СтандартнаяОбработка = Ложь Тогда
		ПоказатьОповещениеПользователя("<" + ВидНоменклатуры + ">",,"Для вида номенклатуры учет по характеристикам не используется");
	КонецЕсли;
КонецПроцедуры
&НаСервере
Функция УстановитьСвязьПараметровВыбора_СправочникаХарактеристики(ИдентификаторСтроки,СтандартнаяОбработка)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
	ВидНоменклатуры = ТекСтрока.Номенклатура_ВидНоменклатуры;
	
	Если Конф = "УНФ" Тогда
		ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Объект1с;
		
	ИначеЕсли Конф = "БИТСтоматология" Тогда
		ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Объект1с;
	
	ИначеЕсли РеквизитСуществует("Перечисления","ВариантыИспользованияХарактеристикНоменклатуры") Тогда
		//УТ11, КА2, ERP
		Если ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Объект1с;
		ИначеЕсли ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Номенклатура_ВидНоменклатуры;
		ИначеЕсли ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеСДругимВидомНоменклатуры Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Объект1с.ВладелецХарактеристик;
		ИначеЕсли ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = Неопределено;
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
		
	ИначеЕсли РеквизитСуществует("Перечисления","ВариантыВеденияДополнительныхДанныхПоНоменклатуре") Тогда
		//Розница2
		Если ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыВеденияДополнительныхДанныхПоНоменклатуре.ИндивидуальныеДляНоменклатуры Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Объект1с;
		ИначеЕсли ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыВеденияДополнительныхДанныхПоНоменклатуре.ОбщиеДляВидаНоменклатуры Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = ТекСтрока.Номенклатура_ВидНоменклатуры;
		ИначеЕсли ВидНоменклатуры.ИспользованиеХарактеристик = Перечисления.ВариантыВеденияДополнительныхДанныхПоНоменклатуре.НеИспользовать Тогда
			ТекСтрока.Номенклатура_ВладелецХарактеристик = Неопределено;
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
	Элементы.Номенклатура_Характеристика.СвязиПараметровВыбора = Новый ФиксированныйМассив(Новый Массив);
	Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_ВладелецХарактеристик) Тогда
		НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Владелец", "Элементы.ЗагружаемыеОбъекты.ТекущиеДанные.Номенклатура_ВладелецХарактеристик");
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НоваяСвязь);
		Элементы.Номенклатура_Характеристика.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыйМассив);
	КонецЕсли;
	
	Возврат ВидНоменклатуры;
	
КонецФункции

&НаКлиенте
Процедура Номенклатура_ХарактеристикаПриИзменении(Элемент)
	
	ВыполнитьГрупповуюОбработкуВыделенныхСтрок("Номенклатура_Характеристика");
	
	//Обработаем сохранение Номенклатуры + Характеристики для выделенных строк
	ВыделенныеСтроки = Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки;
	
	Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
		
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ВыделеннаяСтрока);
		
		// сохраняем установленную пользователем связь номенклатуры поставщика и Номенклатуры + Характеристики
		Если ТекСтрока.ТипОбъекта = "Номенклатура" И ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			Если СтруктураНастроек.Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия = Истина Тогда
				ТекстОповещения = ЗаписатьСоответствиеНоменклатуры(ТекСтрока.Объект1с,ТекСтрока.Номенклатура_Характеристика,ТекСтрока.ПредставлениеОбъекта,ТекСтрока.КонтрагентИД);
				ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Номенклатура_НоменклатураПоставщикаПриИзменении(Элемент)
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
