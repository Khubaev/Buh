&НаКлиенте
Процедура СканДокумента_ПоказатьСканДокумента()
	
	Если ПоказыватьСканДокументаСредствамиEntera Тогда
		Если ПоказыватьСканДокумента Тогда
			СканДокумента_ПоказатьСканДокумента_ENTERA();
		Иначе
			ОтображаемыйАдрес = Неопределено;
		КонецЕсли;
		
	Иначе
		Элементы.ГруппаПросмотрСкана_PNG.Видимость = ПоказыватьСканДокумента;
		Если ПоказыватьСканДокумента Тогда
			СканДокумента_ПоказатьСканДокумента_PNG();
		КонецЕсли;		
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СканДокумента_ПоказатьСканДокумента_ENTERA()
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
			Если ЗначениеЗаполнено(ТекСтрока.parentId) Тогда
				СвязанныйДокумент = ТекСтрока.parentId;
			ИначеЕсли ЗначениеЗаполнено(ТекСтрока.childrenId) Тогда
				СвязанныйДокумент = ТекСтрока.childrenId;
			КонецЕсли;
		КонецЕсли;
		
		АдресДокумента = "https://" + СтруктураПодключения.Адрес + "/api/v1/pages/documentPagesViewer?documentId=" + ТекСтрока.ДокументИД;
	
		Если ЗначениеЗаполнено(СвязанныйДокумент) Тогда
			АдресДокумента = АдресДокумента + "&documentId=" + СвязанныйДокумент;
		КонецЕсли;
			
		//Страница для отображения документа может быть еще не готова
		ПодключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы",1);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы() Экспорт
	
	ИспользуетсяОтдельнаяФормаПросмотра = Ложь;
	
	Если ИспользуетсяОтдельнаяФормаПросмотра Тогда
		
		//Показываем в отдельной форме, исходный вариант
		
		Если ФормаПросмотра = Неопределено Тогда
			ОтключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы");
		Иначе
			//Проверяем, готова ли страница для отображения документа
			СтатусЗавершено = "complete";
			Если Нрег(ФормаПросмотра.Элементы.HTML_СканДокумента.Документ.readyState) = СтатусЗавершено Тогда
				ОтключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы");
				ФормаПросмотра.ОтобразитьДокумент(ВладелецФормы.Токен,АдресДокумента);
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		
		//Показываем в этой же форме
		
		Если Элементы.ГруппаПросмотраСкана_HTML.Видимость = Ложь Тогда
			ОтключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы");
		Иначе
			//Проверяем, готова ли страница для отображения документа
			СтатусЗавершено = "complete";
			Если Нрег(Элементы.HTML_СканДокумента.Документ.readyState) = СтатусЗавершено Тогда
				ОтключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы");
				
				Если ОтображаемыйАдрес = АдресДокумента Тогда
					//пропускаем, мы это уже показываем
					
				Иначе
				
					Попытка
						//При первом отображении выполняем метод этой страницы для авторизации и перехода к требуемому документу
						Элементы.HTML_СканДокумента.Документ.defaultView.setCookieAndRedirect(ВладелецФормы.Токен,АдресДокумента);
						ОтображаемыйАдрес = АдресДокумента;
						
						//документ еще может быть не готов, на 8.3.27 проблема устраняется повторным назначение адреса
						Если ПоказыватьСканДокумента_ОбновлятьАдрес Тогда
							ПодключитьОбработчикОжидания("СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы_ОтложенноеОбновление",0.5,Истина);							
						КонецЕсли;
						
					Исключение
						ОписаниеСобытия = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
						
						//При последующих - только меняем location, так как мы уже авторизованы в этом окне
						Попытка
							Элементы.HTML_СканДокумента.Документ.location.assign(АдресДокумента);
							ОтображаемыйАдрес = АдресДокумента;
							
						Исключение
							ОписаниеСобытия = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
							ПоказатьОповещениеПользователя("Ошибка отображения документ",,ОписаниеСобытия);
							
							ВладелецФормы.ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"ОтображениеСкана",ОписаниеСобытия,"ОтображениеСкана");
						КонецПопытки;
						
					КонецПопытки;
					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_ПоказатьСканДокумента_ПоГотовностиСтраницы_ОтложенноеОбновление() Экспорт
	
	Попытка
		Элементы.HTML_СканДокумента.Документ.location.assign(АдресДокумента);
	Исключение
		ОписаниеСобытия = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ПоказатьОповещениеПользователя("Ошибка отображения документ",,ОписаниеСобытия);
		
		ВладелецФормы.ЗаписатьСобытиеВПротокол(СтруктураНастроек,0,"ОтображениеСкана",ОписаниеСобытия,"ОтображениеСкана");
	КонецПопытки;
	
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_ИнициализироватьСтраницу_ENTERA()
	
	ИспользуетсяОтдельнаяФормаПросмотра = Ложь;
	
	Если ИспользуетсяОтдельнаяФормаПросмотра Тогда
		
		//Показываем в отдельной форме, исходный вариант
	
		Если ПоказыватьСканДокумента Тогда
			Если ФормаПросмотра = Неопределено Тогда
				ПараметрыОткрытия = Новый Структура;
				ФормаПросмотра = ПолучитьФорму(ПрефиксИмениФорм + "УФ_ПросмотрСкана", ПараметрыОткрытия, ВладелецФормы);
				ФормаПросмотра.ЗакрыватьПриЗакрытииВладельца = Истина;
				ФормаПросмотра.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
				ФормаПросмотра.СтруктураПодключения = СтруктураПодключения;
				
				ФормаПросмотра.Открыть();
			КонецЕсли;
		Иначе
			Если ФормаПросмотра <> Неопределено Тогда
				ФормаПросмотра.Закрыть();
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		
		//Показываем в этой же форме
		
		Если ПоказыватьСканДокумента Тогда
			Элементы.ГруппаПросмотраСкана_HTML.Видимость = Истина;
			АдресСтраницы = "https://" + СтруктураПодключения.АдресСервераАвторизации + "/api/v1/pages/setCookieAndRedirect";
			HTML_СканДокумента = АдресСтраницы;
			Попытка
				//документ еще может быть не готов
				Элементы.HTML_СканДокумента.Документ.location.assign(АдресСтраницы);
			Исключение
				
			КонецПопытки;
		Иначе
			Элементы.ГруппаПросмотраСкана_HTML.Видимость = Ложь;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СканДокумента_ПоказатьСканДокумента_PNG()
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		//Получаем файл скана текущей страницы текущего документа, сперва проверяем его  в списке
		//уже полученных страниц таблицы documentPages, если его там еще нет, получаем с портала
		
		documentId = Строка(ТекСтрока.ДокументИД);
		number = Строка(ТекСтрока.СканДокумента_ТекущаяСтраница);
		
		//Попробуем хранения клиентского кэша с адресами хранилища страниц документов, чтобы получать адрес без вызова сервера
		ЗначениеКэша = СканДокумента_ПолучитьЗначениеИзКлиентскогоКэша(documentId,number);
		
		Если ЗначениеКэша <> Неопределено Тогда
			НовыйАдресСкана = ЗначениеКэша;
			
		Иначе
		
			Результат = СканДокумента_ПолучитьАдресХранилищаИзТаблицы_documentPages(АдресХранилищаДанныхПортала,documentId,number);
			
			Если Результат.Успешно Тогда			
				Если ЭтоАдресВременногоХранилища(Результат.АдресВХ) Тогда
					//ранее уже загружали
					НовыйАдресСкана = Результат.АдресВХ;
					
					//дополним клиентский кэш
					СканДокумента_ПоместитьЗначениеВКлиентскийКэш(documentId,number,АдресХранилищаСканаДокумента);
				Иначе
				
					ПараметрыЗапроса = Новый Структура;
					ПараметрыЗапроса.Вставить("ЗапросФайла",Истина);
					ПараметрыЗапроса.Вставить("ДокументИД",documentId);
					
					МетодAPI = Результат.url;
									
					РезультатЗапроса = ВладелецФормы.ВыполнитьЗапрос("ПолучениеФайлаСкана","GET",МетодAPI,"",ПараметрыЗапроса);
					
					Если РезультатЗапроса.Успешно Тогда
						НовыйАдресСкана = РезультатЗапроса.АдресВХ;
						
						//при успешном результате запроса нужно записать адрес хранилища скана в таблицу documentPages
						Результат = СканДокумента_ПоместитьАдресХранилищаВТаблицу_documentPages(АдресХранилищаДанныхПортала,documentId,number,НовыйАдресСкана);
						
						//дополним клиентский кэш
						СканДокумента_ПоместитьЗначениеВКлиентскийКэш(documentId,number,НовыйАдресСкана);
						
						Если Не Результат.Успешно Тогда
							СообщитьСообщение(Результат.ТекстОшибки);
						КонецЕсли;
					Иначе
						СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				СообщитьСообщение(Результат.ТекстОшибки);
			КонецЕсли;
		КонецЕсли;
		
		Если АдресХранилищаСканаДокумента <> НовыйАдресСкана Тогда
			АдресХранилищаСканаДокумента = НовыйАдресСкана;
			ТекСтрока.СканДокумента_АдресХранилища = НовыйАдресСкана;
		КонецЕсли;
		
		//Устанавливаем этот скан всем строкам этого документа.
		СтрокиДокумента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД",documentId));
		Для Каждого СтрокаДокумента Из СтрокиДокумента Цикл
			СтрокаДокумента.СканДокумента_ТекущаяСтраница = ТекСтрока.СканДокумента_ТекущаяСтраница;
			СтрокаДокумента.СканДокумента_АдресХранилища = ТекСтрока.СканДокумента_АдресХранилища;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Функция СканДокумента_ПолучитьЗначениеИзКлиентскогоКэша(documentId,number)
	
	//Кэш документов - соответствие, хранящее соответствия
	Если Кэш_СканыДокументов <> Неопределено Тогда
		ТекущийДокумент = Кэш_СканыДокументов.Получить(documentId);
		Если ТекущийДокумент <> Неопределено Тогда
			Страница = ТекущийДокумент.Получить(number);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Страница;
	
КонецФункции
&НаКлиенте
Функция СканДокумента_ПоместитьЗначениеВКлиентскийКэш(documentId,number,Значение)
	
	//Кэш документов - соответствие, хранящее соответствия
	Если Кэш_СканыДокументов = Неопределено Тогда
		Кэш_СканыДокументов = Новый Соответствие;
	КонецЕсли;
	
	Если ЭтоАдресВременногоХранилища(Значение) Тогда
		ТекущийДокумент = Кэш_СканыДокументов.Получить(documentId);
		Если ТекущийДокумент = Неопределено Тогда
			ТекущийДокумент = Новый Соответствие;
		КонецЕсли;
		
		ТекущийДокумент.Вставить(number,Значение);
		
		Кэш_СканыДокументов.Вставить(documentId,ТекущийДокумент);
	КонецЕсли;
	
КонецФункции
&НаСервереБезКонтекста
Функция СканДокумента_ПолучитьАдресХранилищаИзТаблицы_documentPages(АдресХранилищаДанныхПортала,documentId,number)
		
	Результат = Новый Структура("Успешно,ТекстОшибки,url,АдресВХ",Истина);
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	НайденныеСтроки = ДанныеПортала.documentPages.НайтиСтроки(Новый Структура("documentId,number",documentId,Строка(number)));
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		Результат.url = НайденныеСтроки[0].url;
		Результат.АдресВХ = НайденныеСтроки[0].АдресВХ;
	Иначе
		Результат.Успешно = Ложь;
		Результат.ТекстОшибки = "Внутренняя ошибка модуля: не удалось найти данные скана в таблице страниц документов";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция СканДокумента_ПоместитьАдресХранилищаВТаблицу_documentPages(АдресХранилищаДанныхПортала,documentId,number,АдресХранилищаСканаДокумента)
		
	Результат = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	НайденныеСтроки = ДанныеПортала.documentPages.НайтиСтроки(Новый Структура("documentId,number",documentId,Строка(number)));
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		НайденныеСтроки[0].АдресВХ = АдресХранилищаСканаДокумента;
		ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	Иначе
		Результат.Успешно = Ложь;
		Результат.ТекстОшибки = "Внутренняя ошибка модуля: не удалось поместить данные скана в таблицу страниц документов";
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура СканДокумента_Предыдущий(Команда)
	СканДокумента_СменитьСтраницу(-1);
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_Следующий(Команда)
	СканДокумента_СменитьСтраницу(1);
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_СменитьСтраницу(Изменение)
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		НовыйНомерСтроки = ТекСтрока.СканДокумента_ТекущаяСтраница + Изменение;
		Если НовыйНомерСтроки > 0 И НовыйНомерСтроки <= ТекСтрока.СканДокумента_КоличествоСтраниц Тогда
			ТекСтрока.СканДокумента_ТекущаяСтраница = НовыйНомерСтроки;
			СканДокумента_ПоказатьСканДокумента();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура СканДокумента_Увеличить(Команда)
	Элементы.АдресХранилищаСканаДокумента.РазмерКартинки = РазмерКартинки.РеальныйРазмер;
КонецПроцедуры
&НаКлиенте
Процедура СканДокумента_Уменьшить(Команда)
	Элементы.АдресХранилищаСканаДокумента.РазмерКартинки = РазмерКартинки.Пропорционально;
КонецПроцедуры
