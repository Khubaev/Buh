				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//пункт Стандартный поиск
	НовыйЭлемент = СписокВыбора.Добавить();
	НовыйЭлемент.Значение = "СтандартныйПодбор";
	НовыйЭлемент.Представление = "Стандартный подбор...";
