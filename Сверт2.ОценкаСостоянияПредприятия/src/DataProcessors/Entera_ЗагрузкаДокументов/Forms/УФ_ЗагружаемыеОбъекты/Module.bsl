&НаСервереБезКонтекста
Функция _ЗФ_ПолучитьОбщийМодульКонфигурации(ИмяОбщегоМодуля)
	Если Метаданные.ОбщиеМодули.Найти(ИмяОбщегоМодуля) <> Неопределено Тогда
		ТребуемыйОбщийМодуль = Вычислить(ИмяОбщегоМодуля);
	КонецЕсли;
	
	Возврат ТребуемыйОбщийМодуль;
КонецФункции
&НаСервере          
Процедура _3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(ЗаписываемыйОбъект)
	//Для 1с:Фреш эту процедуру очищаем
	ЗаписываемыйОбъект.ОбменДанными.Загрузка = Истина;
КонецПроцедуры
&НаКлиенте
Функция _ЗФ_ОбработатьАсинхронныйВызов(ТипВызова,ПараметрыВызова)
	
	//Для реализации возможности открытия этой формы внешней обработке на платформах, не поддерживающих ОписаниеОповещения,
	//(не будет пройден синтаксический контроль), обработчики асинхронных вызовов вынесены в эту процедуру.
	//Для прохождения аудита 1С:Фреш эта процедура заменяется на аналогичную, но без методов Вычислить(). Profit!
	
	Если ТипВызова = "Вопрос" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВопрос(ОписаниеОповещения,ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		Иначе
			Вопрос(ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыборИзМеню" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			
			ЭлементФормы = Неопределено;
			ПараметрыВызова.ДопПараметры.Свойство("ЭлементФормы",ЭлементФормы);
			
			ПоказатьВыборИзМеню(ОписаниеОповещения,ПараметрыВызова.СписокВыбора,ЭлементФормы);
		Иначе
			ВыбратьИзМеню(ПараметрыВызова.СписокВыбора);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыборИзСписка" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			
			ЭлементФормы = Неопределено;
			ПараметрыВызова.ДопПараметры.Свойство("ЭлементФормы",ЭлементФормы);
						
			ПоказатьВыборИзСписка(ОписаниеОповещения,ПараметрыВызова.СписокВыбора,ЭлементФормы);
		Иначе
			ВыбратьИзСписка(ПараметрыВызова.СписокВыбора);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВводЧисла" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВводЧисла(ОписаниеОповещения,ПараметрыВызова.Число,ПараметрыВызова.Подсказка,ПараметрыВызова.Длина,ПараметрыВызова.Точность);
		Иначе
			ВвестиЧисло(ПараметрыВызова.Число,ПараметрыВызова.Подсказка,ПараметрыВызова.Длина,ПараметрыВызова.Точность);
		КонецЕсли;
	
	ИначеЕсли ТипВызова = "ПоместитьФайлы" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещенияНачало = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова_3Параметра"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваНачало)");
			ОписаниеОповещенияОкончание = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваЗавершение)");
			НачатьПомещениеФайлов(ОписаниеОповещенияОкончание,,Истина,УникальныйИдентификатор,ОписаниеОповещенияНачало);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
				
	ИначеЕсли ТипВызова = "ДиалогВыбораФайла" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.ДиалогВыбораФайла.Показать(ОписаниеОповещения);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыборЗначенияИзФормыСписка" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.ФормаВыбора.ОписаниеОповещенияОЗакрытии = ОписаниеОповещения;
			
			ПараметрыВызова.ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ПараметрыВызова.ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			ПараметрыВызова.ФормаВыбора.Открыть();
		Иначе
			РезультатВыбора = ПараметрыВызова.ФормаВыбора.ОткрытьМодально();
			ОбработатьРезультатАсинхронногоВызова(РезультатВыбора,ПараметрыВызова);
		КонецЕсли;                                                                                  
		          
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ОбработатьРезультатАсинхронногоВызова(Результат,ПараметрыВызова) Экспорт
		
	//Сюда в условия переносятся все присутствующие в форме обработчики результатов асинхронных вызовов
	Если ПараметрыВызова.Обработчик = "ПродолжитьСозданиеОбъектов_НеЗаполненСклад" Тогда
		ПродолжитьСозданиеОбъектов_НеЗаполненСклад(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьСозданиеОбъектов_КонтрольИНН_Контрагентов" Тогда
		ПродолжитьСозданиеОбъектов_КонтрольИНН_Контрагентов(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыбор_Дополнительно" Тогда
		ОбработатьВыбор_Дополнительно(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ПродолжитьВыполнениеГрупповойОбработкиВыделенныхСтрок" Тогда
		ПродолжитьВыполнениеГрупповойОбработкиВыделенныхСтрок(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборВариантаПоиска_АртикулНаименование" Тогда
		ОбработатьВыборВариантаПоиска_АртикулНаименование(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборПроцента_ВыполнитьПоискПохожих" Тогда
		ОбработатьВыборПроцента_ВыполнитьПоискПохожих(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборИзФормыСписка_Организации" Тогда
		ОбработатьВыборИзФормыСписка_Организации(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ЗагружаемыеОбъекты_ВыбратьНоменклатуру_ОбработатьРанееЗаполненные" Тогда
		ЗагружаемыеОбъекты_ВыбратьНоменклатуру_ОбработатьРанееЗаполненные(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборИзФормыСписка_ОбщаяНоменклатура" Тогда
		ОбработатьВыборИзФормыСписка_ОбщаяНоменклатура(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_УстановитьПолноеНаименованиеПоКраткому" Тогда
		Продолжить_УстановитьПолноеНаименованиеПоКраткому(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Заглушка_ОписаниеОповещения" Тогда
		//Ничего не выполняем
		
	КонецЕсли;
	
КонецФункции


// ================= События формы ===================

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
	Параметры.Свойство("ПрефиксИмениФорм",ПрефиксИмениФорм);
	Параметры.Свойство("ДопПараметры",ДополнительныеПараметрыФормы);
	Параметры.Свойство("СтруктураНастроек",СтруктураНастроек);
	Параметры.Свойство("ИспользуетсяМК",ИспользуетсяМК);
	
	ДополнительныеПараметрыФормы.Свойство("ПредставлениеСоздаваемогоДокумента",ПредставлениеСоздаваемогоДокумента);
	Если ЗначениеЗаполнено(ПредставлениеСоздаваемогоДокумента) Тогда
		Заголовок = Заголовок + " для " + ПредставлениеСоздаваемогоДокумента;
	КонецЕсли;
	
	//E1C-79: добавлен поиск по справочнику Номенклатура поставщиков
	СтруктураНастроек.Свойство("Номенклатура_ИспользоватьНоменклатуруПоставщиков",ПоискПоНоменклатуреПоставщиков);
	
	//E1C-421: для региона пространства KAZ не отображаем КПП, ИНН отображаем как ИИН/БИН
	Если СтруктураНастроек.РегионПространства = "KAZ" Тогда
		Элементы.Контрагенты_КПП.Видимость = Ложь;
		Элементы.Контрагенты_ИНН.Заголовок = "ИИН/БИН";
		Элементы.Организации_КПП.Видимость = Ложь;
		Элементы.Организации_ИНН.Заголовок = "ИИН/БИН";
	КонецЕсли;
	
	//2020.03.30 (	
	Если ИспользуетсяМК Тогда
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("Форма",ЭтаФорма);
		
		РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("ПриСозданииНаСервере_УФ_ЗагружаемыеОбъекты",ПараметрыМК);
		ЗначениеВРеквизитФормы(РеквизитОбъект,"Объект");
	КонецЕсли;
	// ) 2020.03.30
	
	//E1C-80: По умолчанию для новых клиентов этот флаг должен быть взведен, проверяем по наличию сохраненных данных формы
	ТекущаяНастройкаДанныхФормы = ХранилищеСистемныхНастроек.Загрузить(ПрефиксИмениФорм + "УФ_ЗагружаемыеОбъекты/ТекущиеДанные");
	Если ТекущаяНастройкаДанныхФормы = Неопределено Тогда
		//для этой формы еще не существует сохраненных настроек, взводим флаг
		ДополнительноеОписаниеЭлемента = Истина;
	КонецЕсли;
	
	//E1C-506: на 8.3.27 проблема с отображением скана, устраняется повторным назначение адреса
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	СисИнфо = Новый СистемнаяИнформация;
	ВерсияМассив = РеквизитОбъект.Энтера_РазложитьСтрокуВМассивПодстрок(СисИнфо.ВерсияПриложения,".");
	ВтораяЦифра = Число(ВерсияМассив[1]); ТретьяЦифра = Число(ВерсияМассив[2]);
			
	ПоказыватьСканДокумента_ОбновлятьАдрес = (ВтораяЦифра = 3 и ТретьяЦифра >= 27) Или ВтораяЦифра > 3;
	
	УстановитьОграниченияЭлементовФормы();
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьКнопкуНаФорму(ИмяКоманды,ИмяКнопки,Синоним,ИмяДействия,ГруппаРодитель = Неопределено, Картинка = Неопределено, Пометка = Ложь)
	
	// Добавляем новую команду обработки выбора вида операции.
	Команда = Команды.Добавить(ИмяКоманды);
	Команда.Действие = ИмяДействия;
	
	Если Картинка <> Неопределено Тогда
		Команда.Картинка = Картинка;
	КонецЕсли;
	
	Если ГруппаРодитель = Неопределено Тогда
		НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"));
	Иначе    
		НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), ГруппаРодитель);
	КонецЕсли;
	
	НоваяКнопка.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
	НоваяКнопка.ИмяКоманды = ИмяКоманды;
	НоваяКнопка.Заголовок = Синоним;
	НоваяКнопка.Пометка = Пометка;

КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ФормаПросмотра <> Неопределено Тогда
		ФормаПросмотра.Закрыть();
	КонецЕсли;
	
	//E1C-103: при включенной настройке передадим порталу данные об изменениях наименований, внесенных пользователем
	Если ЗавершениеРаботы <> Истина Тогда
		//При завершении работы приложения запрещены серверные вызовы
		Если СтруктураНастроек.Свойство("ОбменДанными_ОтправлятьИзмененияРаспознанныхНаименований")
			И СтруктураНастроек.ОбменДанными_ОтправлятьИзмененияРаспознанныхНаименований = Истина Тогда
			ОбновлениеДанныхДокументов_ОтправкаНаПортал();
		КонецЕсли;
		
		Если ИспользуетсяМК Тогда
			//+++
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ФормаПросмотра_Закрытие" Тогда
		ПоказыватьСканДокумента = Ложь;
		ФормаПросмотра = Неопределено;
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	КопироватьДанныеФормы(ВладелецФормы.Объект,Объект);
	
	АдресХранилищаДанныхПортала = ВладелецФормы.АдресХранилищаДанныхПортала;
	
	// Заполняем таблицу "маркеров" - подстрок поиска номенклатуры в иерархии группы
	ЗаполнитьКэшФормы_СловаМаркеры();
	
	Попытка
		РазмерСпискаПохожейНоменклатуры = Цел(Число(СтруктураНастроек.Номенклатура_РазмерСпискаПохожих));
	Исключение
		РазмерСпискаПохожейНоменклатуры = 5;
	КонецПопытки;
	
	Если РазмерСпискаПохожейНоменклатуры < 1 Тогда
		РазмерСпискаПохожейНоменклатуры = 1;
	КонецЕсли;
	
	Отбор = 0;
	ПодключитьОбработчикОжидания("УстановитьОтборСтрокТаблицы",1,Истина);
	
	СчетаУчета_ЗаполнитьСчетаУчетаНоменклатуры();
	
	Элементы.ГруппаОписаниеСоздаваемыхЭлементов.Видимость = ДополнительноеОписаниеЭлемента;
	
	//E1C-80: компоновка элементов горизонтальная/вертикальная
	Если Не ЗначениеЗаполнено(СпособКомпоновкиЭлементовФормы) Тогда
		СпособКомпоновкиЭлементовФормы = "Горизонтально";
	КонецЕсли;
	УстановитьСпособКомпоновкиЭлементовФормы();
	
	//Показываем сканы документов
	//+++ во Фреш все равно иногда возникает проблема преавторизации поля предпосмотра скана,
	//даже в тощем клиенте: возможно, следует дополнить условие Или ВладелецФормы.ЭтоФреш
	ПоказыватьСканДокументаСредствамиEntera = Не (ВладелецФормы.ЭтоВебКлиент);
		
	//Подгрузим страницу преавторизации	
	Если ПоказыватьСканДокументаСредствамиEntera Тогда
		СтруктураПодключения = ВладелецФормы.ЗаполнитьСтруктуруПодключения();
		СканДокумента_ИнициализироватьСтраницу_ENTERA();
	КонецЕсли;
	
	СканДокумента_ПоказатьСканДокумента();
	
	
	// EN-229: Показываем колонку с Артикулом только если по нему будет выполняться поиск или они заполняются в новой номенклатуре
	Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул"
		Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул,Наименование"
		Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование,Артикул"
		Или СтруктураНастроек.Номенклатура_ЗаполнятьАртикулы = Истина Тогда
		Элементы.ЗагружаемыеОбъектыНоменклатура_Код.Видимость = Истина;
	Иначе
		Элементы.ЗагружаемыеОбъектыНоменклатура_Код.Видимость = Ложь;
	КонецЕсли;
	
	// Показываем поле КоэффициентПересчета если включен флаг в настройках
	ПоказыватьКоэффициент = СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьКоэффициентПересчета = Истина;
	Элементы.Номенклатура_КоэффициентПересчета.Видимость = ПоказыватьКоэффициент;
	Элементы.Номенклатура_Количество.Видимость = ПоказыватьКоэффициент;
	
	//E1C-75: настройка, скрывающая флаги создания номенклатуры
	Элементы.ЗагружаемыеОбъектыПометка.Видимость = СтруктураНастроек.СозданиеДокумента_ВыбиратьСоздаваемыеЭлементы = Истина;
	
	//E1C-297: настройка, отображающая нумерацию строк номенклатуры документов. В E1C-374 была удалена
	Элементы.ЗагружаемыеОбъектыНоменклатура_serialNumber.Видимость = Истина;
			
	ДобавитьКнопкиКонтекстногоМеню();
	
КонецПроцедуры
&НаСервере
Процедура УстановитьСпособКомпоновкиЭлементовФормы()
	
	Если СпособКомпоновкиЭлементовФормы = "Горизонтально" Тогда
		
		//Старые версии платформы умеют Горизонтальная, новые - ГоризонтальнаяВсегда
		Попытка
			ГруппировкаГоризонтальная = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		Исключение
			ГруппировкаГоризонтальная = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		КонецПопытки;
		
		Элементы.ГруппаСоздаваемыхЭлементов.Группировка = ГруппировкаГоризонтальная;
		Элементы.Переместить(Элементы.ГруппаОписаниеСоздаваемыхЭлементов,Элементы.ГруппаСоздаваемыхЭлементов);
		Элементы.Переместить(Элементы.ГруппаПросмотрСкана_PNG,Элементы.ГруппаСоздаваемыхЭлементов);
		Элементы.Переместить(Элементы.ГруппаПросмотраСкана_HTML,Элементы.ГруппаСоздаваемыхЭлементов);
		
	ИначеЕсли СпособКомпоновкиЭлементовФормы = "Вертикально" Тогда
		Элементы.ГруппаСоздаваемыхЭлементов.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		Элементы.Переместить(Элементы.ГруппаОписаниеСоздаваемыхЭлементов,Элементы.ГруппаСоздаваемыхЭлементовВертикальная);
		Элементы.Переместить(Элементы.ГруппаПросмотрСкана_PNG,Элементы.ГруппаСоздаваемыхЭлементовВертикальная);
		Элементы.Переместить(Элементы.ГруппаПросмотраСкана_HTML,Элементы.ГруппаСоздаваемыхЭлементовВертикальная);
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Процедура УстановитьОграниченияЭлементовФормы()
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	Элемент = Элементы.Номенклатура_ЕдиницаИзмерения;
	Если Конф = "УНФ"
		//2024.10.22 (
		Или Конф = "РОЗН3" Тогда
		// ) 2024.10.22
		
		//Выбор типа единицы измерения не осуществляется "напрямую", а выбирается методом конфигурации ПолучитьДанныеВыбора
		Элемент.ВыбиратьТип = Ложь;
		
	ИначеЕсли Конф = "Далион" Тогда
		//У Далион в ОбработкаПолученияДанныхВыбора Единиц измерения может возвращаться и КлассификаторЕдиницИзмерения
		Элемент.ВыбиратьТип = Ложь;
		
	ИначеЕсли ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.ЕдиницыИзмерения_ИмяСправочникаЕдиницыИзмерения) Тогда		
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка." + СтруктураНастроек.СведенияОКонфигурации.ЕдиницыИзмерения_ИмяСправочникаЕдиницыИзмерения));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
	
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
	ИначеЕсли Метаданные.Справочники.Найти("КлассификаторЕдиницИзмерения") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.КлассификаторЕдиницИзмерения"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
	КонецЕсли;
	
	Элемент = Элементы.Номенклатура_ВидНоменклатуры;
	Если Метаданные.Справочники.Найти("ВидыНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ВидыНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
	ИначеЕсли Метаданные.Перечисления.Найти("ВидыНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("ПеречислениеСсылка.ВидыНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
	//2022.11.11 ( Хеликс.Стоматология: ВидаНоменклатуры нет, но может быть выбрано перечисление ТипНоменклатуры
	ИначеЕсли Метаданные.Перечисления.Найти("ТипыНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("ПеречислениеСсылка.ТипыНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		Элемент.Заголовок = "Тип номенклатуры";
	// ) 2022.11.11
	
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	//2020.01.13 ( Добавлен учет по характеристикам
	Элемент = Элементы.Номенклатура_Характеристика;
	Если Метаданные.Справочники.Найти("ХарактеристикиНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ХарактеристикиНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		ОтображатьХарактеристики = СтруктураНастроек.Свойство("ЗаполнениеТЧ_ИспользоватьХарактеристики") И СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьХарактеристики = Истина;
		Элемент.Видимость = ОтображатьХарактеристики;
	КонецЕсли;
	// ) 2020.01.13
	
	Элемент = Элементы.Номенклатура_ГруппаФинансовогоУчета;
	Если Метаданные.Справочники.Найти("ГруппыФинансовогоУчетаНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ГруппыФинансовогоУчетаНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	Элемент = Элементы.Номенклатура_ГруппаАналитическогоУчета;
	Если Метаданные.Справочники.Найти("ГруппыАналитическогоУчетаНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ГруппыАналитическогоУчетаНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	Элемент = Элементы.Номенклатура_Категория;
	Если Метаданные.Справочники.Найти("КатегорииНоменклатуры") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.КатегорииНоменклатуры"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
		
	//НаправленияДеятельности для новой номенклатуры УНФ
	Элемент = Элементы.Номенклатура_НаправлениеДеятельности;
	Если Конф = "УНФ" Тогда
		Если Метаданные.Справочники.Найти("НаправленияДеятельности") <> Неопределено Тогда
			Массив = Новый Массив();
			Массив.Добавить(Тип("СправочникСсылка.НаправленияДеятельности"));
			ОписаниеТипов = Новый ОписаниеТипов(Массив);
			
			Элемент.ОграничениеТипа = ОписаниеТипов;
		Иначе
			Элемент.Видимость = Ложь;
		КонецЕсли;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	//НаправленияДеятельности для переноса в документ в Комплексной автоматизации 2
	Если Конф = "КА2"	
		//и для Управления торговлей Казахстана
		Или СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Имя = "УправлениеТорговлейДляКазахстана" Тогда
	
		Если Метаданные.Справочники.Найти("НаправленияДеятельности") <> Неопределено Тогда
			Массив = Новый Массив();
			Массив.Добавить(Тип("СправочникСсылка.НаправленияДеятельности"));
			ОписаниеТипов = Новый ОписаниеТипов(Массив);
			
			Элементы.Документ_НаправлениеДеятельности.ОграничениеТипа = ОписаниеТипов;
			Элементы.Договоры_НаправлениеДеятельности.ОграничениеТипа = ОписаниеТипов;
		Иначе
			Элементы.Документ_НаправлениеДеятельности.Видимость = Ложь;
			Элементы.Договоры_НаправлениеДеятельности.Видимость = Ложь;
		КонецЕсли;
	Иначе
		Элементы.Документ_НаправлениеДеятельности.Видимость = Ложь;
		Элементы.Договоры_НаправлениеДеятельности.Видимость = Ложь;
	КонецЕсли;
	
	//Объект расчетов
	Элемент = Элементы.Документ_ОбъектРасчетов;
	Если Метаданные.Справочники.Найти("ОбъектыРасчетов") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ОбъектыРасчетов"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		Элемент.Видимость = Истина;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	
	//Объект
	Элемент = Элементы.Номенклатура_Объект;
	Если Метаданные.Справочники.Найти("Объекты") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.Объекты"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		Элемент.Видимость = Истина;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
		
	ЭлементСчетУчета = Элементы.Номенклатура_СчетУчета;
	ЭлементСчетУчетаНДС = Элементы.Номенклатура_СчетУчетаНДС;
	
	
	Массив = Новый Массив();
	
	//2022.10.18 ( Отраслевое решение БНФО
	Если Метаданные.ПланыСчетов.Найти("БНФОБанковский") <> Неопределено Тогда
		Массив.Добавить(Тип("ПланСчетовСсылка.БНФОБанковский"));
	КонецЕсли;
	// ) 2022.10.18
	
	Если Метаданные.ПланыСчетов.Найти("Хозрасчетный") <> Неопределено Тогда
		Массив.Добавить(Тип("ПланСчетовСсылка.Хозрасчетный"));
		
	//БГУ2	
	ИначеЕсли Метаданные.ПланыСчетов.Найти("ЕПСБУ") <> Неопределено Тогда
		Массив.Добавить(Тип("ПланСчетовСсылка.ЕПСБУ"));
		ЭлементСчетУчетаНДС.Видимость = Ложь;
		
	//Казахстан
	ИначеЕсли Метаданные.ПланыСчетов.Найти("Типовой") <> Неопределено Тогда
		Массив.Добавить(Тип("ПланСчетовСсылка.Типовой"));		
		ЭлементСчетУчетаНДС.Видимость = Ложь;
		
	КонецЕсли;
	
	Если Массив.Количество() > 0 Тогда
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
			
		ЭлементСчетУчета.ОграничениеТипа = ОписаниеТипов;
		ЭлементСчетУчетаНДС.ОграничениеТипа = ОписаниеТипов;
		
	Иначе
		ЭлементСчетУчета.Видимость = Ложь;
		ЭлементСчетУчетаНДС.Видимость = Ложь;
		
	КонецЕсли;
	
	
	//ИФО
	Элемент = Элементы.Документ_ИФО;
	Если Метаданные.Справочники.Найти("ИсточникиФинансовогоОбеспечения") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.ИсточникиФинансовогоОбеспечения"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		Элемент.Видимость = Истина;
	Иначе
		Элемент.Видимость = Ложь;
	КонецЕсли;
	
	
	//Для УНФ - "своя атмосфера"
	Если Конф = "УНФ" И Метаданные.ПланыСчетов.Найти("Управленческий") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("ПланСчетовСсылка.Управленческий"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элементы.Номенклатура_СчетУчетаЗапасов.ОграничениеТипа = ОписаниеТипов;		
		Элементы.Номенклатура_СчетУчетаЗатрат.ОграничениеТипа = ОписаниеТипов;		
		
	Иначе
		Элементы.Номенклатура_СчетУчетаЗапасов.Видимость = Ложь;
		Элементы.Номенклатура_СчетУчетаЗатрат.Видимость = Ложь;
	КонецЕсли;
	
	
	//Статьи расходов и аналитика расходов
	Элемент = Элементы.Номенклатура_СтатьяРасходов;
	ЭлементАналитика = Элементы.Номенклатура_АналитикаРасходов;
	Если Метаданные.ПланыВидовХарактеристик.Найти("СтатьиРасходов") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("ПланВидовХарактеристикСсылка.СтатьиРасходов"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
		
		Массив = Новый Массив();
		Массив.Добавить(Метаданные.ПланыВидовХарактеристик.СтатьиРасходов.Тип);
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		ЭлементАналитика.ОграничениеТипа = ОписаниеТипов;	
		
		НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Владелец","Элементы.ЗагружаемыеОбъекты.ТекущиеДанные.Номенклатура_СтатьяРасходов");
		НовыйМассив = Новый Массив();
		НовыйМассив.Добавить(НоваяСвязь);
		ЭлементАналитика.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыйМассив);
	Иначе
		Элемент.Видимость = Ложь;
		ЭлементАналитика.Видимость = Ложь;
	КонецЕсли;
	
		
	Элемент = Элементы.Номенклатура_СтатьяЗатрат;
	Если Метаданные.Справочники.Найти("СтатьиЗатрат") <> Неопределено Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип("СправочникСсылка.СтатьиЗатрат"));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
		
		Элемент.ОграничениеТипа = ОписаниеТипов;
	Иначе
