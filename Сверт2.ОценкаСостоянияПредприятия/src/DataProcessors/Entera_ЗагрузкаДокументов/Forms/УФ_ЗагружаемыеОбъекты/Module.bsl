&НаСервере
Функция СоздатьЭлементСправочника_СтранаМира(СтруктураЗаполнения,ТекстОшибки)
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	СправочникСтраныМира = СтруктураНастроек.СведенияОКонфигурации.СправочникСтраныМира;
				
	Если ЗначениеЗаполнено(СправочникСтраныМира) Тогда
		Если ЗначениеЗаполнено(СтруктураЗаполнения.Код) Тогда
			Результат = Справочники[СправочникСтраныМира].НайтиПоКоду(СтруктураЗаполнения.Код,Истина);
		КонецЕсли;
		
		//Если не нашли страну по коду - повторим поиск по наименованию
		Если Не ЗначениеЗаполнено(Результат) И ЗначениеЗаполнено(СтруктураЗаполнения.Наименование) Тогда
			Результат = Справочники[СправочникСтраныМира].НайтиПоНаименованию(СтруктураЗаполнения.Наименование,Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
	
		Если РеквизитСуществует("Справочники","СтраныМира") Тогда
			
			Результат = Справочники.СтраныМира.ПустаяСсылка();
			
			Макет = Справочники.СтраныМира.ПолучитьМакет("Классификатор");
			
			Чтение = Новый ЧтениеXML;
			Чтение.УстановитьСтроку(Макет.ПолучитьТекст());
			
			ТаблицаСтран = СериализаторXDTO.ПрочитатьXML(Чтение);
			
			Если ЗначениеЗаполнено(СтруктураЗаполнения.Код) Тогда
				НайденнаяСтрока = ТаблицаСтран.Найти(СтруктураЗаполнения.Код);
			КонецЕсли;
			
			Если НайденнаяСтрока = Неопределено Тогда
				Если ЗначениеЗаполнено(СтруктураЗаполнения.Наименование) Тогда
					НайденнаяСтрока = ТаблицаСтран.Найти(СтруктураЗаполнения.Наименование);
				КонецЕсли;
			КонецЕсли;
			
			//2019.04.18 ( Обрабатываем возможно отсутствующие элементы классификатора
			Если НайденнаяСтрока = Неопределено Тогда
				НайденнаяСтрока = РеквизитОбъект.Классификатор_ПолучитьСтрануМира(СтруктураЗаполнения);
			КонецЕсли;
			// ) 2019.04.18
			
			Если НайденнаяСтрока <> Неопределено Тогда
				СтруктураЗаполнения.Вставить("Код",НайденнаяСтрока.Код);
				СтруктураЗаполнения.Вставить("Наименование",НайденнаяСтрока.Наименование);
				СтруктураЗаполнения.Вставить("НаименованиеПолное",НайденнаяСтрока.НаименованиеПолное);
				СтруктураЗаполнения.Вставить("КодАльфа2",НайденнаяСтрока.КодАльфа2);
				СтруктураЗаполнения.Вставить("КодАльфа3",НайденнаяСтрока.КодАльфа3);
			
				СтранаОбъект = Справочники.СтраныМира.СоздатьЭлемент();
				ЗаполнитьЗначенияСвойств(СтранаОбъект,СтруктураЗаполнения);
			КонецЕсли;
			
			
		ИначеЕсли РеквизитСуществует("Справочники","КлассификаторСтранМира") Тогда
		
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
				ТабличныйДокумент = Справочники.КлассификаторСтранМира.ПолучитьМакет("ПФ_MXL_КлассификаторСтранМира");
			КонецЕсли;
			
			ОбластьКодЧисловой = ТабличныйДокумент.Области.КодЧисловой;
			ОбластьНаименованиеКраткое = ТабличныйДокумент.Области.НаименованиеКраткое;
			ОбластьНаименованиеПолное = ТабличныйДокумент.Области.НаименованиеПолное;
			ОбластьКодАльфа2 = ТабличныйДокумент.Области.КодАльфа2;
			ОбластьКодАльфа3 = ТабличныйДокумент.Области.КодАльфа3;
			
			Если ЗначениеЗаполнено(СтруктураЗаполнения.Код) Тогда
				ТекущаяОбласть = ТабличныйДокумент.НайтиТекст(СтруктураЗаполнения.Код, , ОбластьКодЧисловой, , Истина, , Истина);
			КонецЕсли;
			
			Если ТекущаяОбласть = Неопределено Тогда
				Если ЗначениеЗаполнено(СтруктураЗаполнения.Наименование) Тогда
					ТекущаяОбласть = ТабличныйДокумент.НайтиТекст(СтруктураЗаполнения.Наименование, , ОбластьНаименованиеКраткое, , Истина, , Истина);
				КонецЕсли;
			КонецЕсли;	
					
			Если ТекущаяОбласть <> Неопределено Тогда
				ТабличныйДокумент.ТекущаяОбласть = ТекущаяОбласть;
							
				Код = ТабличныйДокумент.Область(ТекущаяОбласть.Верх, ОбластьКодЧисловой.Лево, ТекущаяОбласть.Низ, ОбластьКодЧисловой.Право).Текст;
				Наименование = ТабличныйДокумент.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеКраткое.Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеКраткое.Право).Текст;
				НаименованиеПолное = ТабличныйДокумент.Область(ТекущаяОбласть.Верх, ОбластьНаименованиеПолное. Лево, ТекущаяОбласть.Низ, ОбластьНаименованиеПолное.Право).Текст;
				КодАльфа2 = ТабличныйДокумент.Область(ТекущаяОбласть.Верх, ОбластьКодАльфа2. Лево, ТекущаяОбласть.Низ, ОбластьКодАльфа2.Право).Текст;
				КодАльфа3 = ТабличныйДокумент.Область(ТекущаяОбласть.Верх, ОбластьКодАльфа3. Лево, ТекущаяОбласть.Низ, ОбластьКодАльфа3.Право).Текст;
				
			КонецЕсли;
				
			Если ТекущаяОбласть <> Неопределено Тогда
				СтруктураЗаполнения.Вставить("Код",Код);
				СтруктураЗаполнения.Вставить("Наименование",Наименование);
				СтруктураЗаполнения.Вставить("НаименованиеПолное",НаименованиеПолное);
				СтруктураЗаполнения.Вставить("КодАльфа2",КодАльфа2);
				СтруктураЗаполнения.Вставить("КодАльфа3",КодАльфа3);
			
				СтранаОбъект = Справочники.КлассификаторСтранМира.СоздатьЭлемент();
				ЗаполнитьЗначенияСвойств(СтранаОбъект,СтруктураЗаполнения);
				
			КонецЕсли;
		КонецЕсли;	
					
		// ( модуль кастомизации
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
		ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("ДокументИД",СтруктураЗаполнения.ДокументИД);
		ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
		ПараметрыМК.Вставить("Объект",СтранаОбъект);
		ПараметрыМК.Вставить("Ссылка",Результат);
		ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
		
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_СтранаМира_ПередЗаписью",ПараметрыМК);
		
		Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
		// ) модуль кастомизации
		
			Если СтранаОбъект <> Неопределено Тогда
				Попытка
					СтранаОбъект.Записать();
					Результат = СтранаОбъект.Ссылка;
				Исключение
					ТекстОшибки = "Запись страны " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
				КонецПопытки;
				
			КонецЕсли;
		Иначе
			Результат = ПараметрыМК.Ссылка;
			
		КонецЕсли;
	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
