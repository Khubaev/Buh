	Иначе
		Результат = Справочники.НомераГТД.НайтиПоКоду(СтруктураЗаполнения.Код);
		
		Если Не ЗначениеЗаполнено(Результат) Тогда
			НомерГТДОбъект = Справочники.НомераГТД.СоздатьЭлемент(); 		
			
			//2019.09.25 ( УНФ: Отключаем контроль
			СтруктураЗаполнения.Вставить("ДопускаетсяЗаписьСОшибкой",Истина);
			// ) 2019.09.25
			
			//2023.12.15 ( В этом же справочнике хранятся номера РНПТ
			Если РеквизитСуществует("Перечисления","ТипыНомеровГТД","НомерГТД") Тогда
				СтруктураЗаполнения.Вставить("ТипНомераГТД",Перечисления.ТипыНомеровГТД.НомерГТД);
			КонецЕсли;
			// ) 2023.12.15
			
			ЗаполнитьЗначенияСвойств(НомерГТДОбъект,СтруктураЗаполнения);
			
			// ( модуль кастомизации
			ПараметрыМК = Новый Структура;
			ПараметрыМК.Вставить("ТекущаяСтрока",ТекСтрока);
			ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
			ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
			ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
			ПараметрыМК.Вставить("ДокументИД",СтруктураЗаполнения.ДокументИД);
			ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
			ПараметрыМК.Вставить("Объект",НомерГТДОбъект);
			ПараметрыМК.Вставить("Ссылка",Результат);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_НомерГТД_ПередЗаписью",ПараметрыМК);
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			// ) модуль кастомизации
			
				Попытка
					НомерГТДОбъект.Записать();
					Результат = НомерГТДОбъект.Ссылка;
				Исключение
					ТекстОшибки = "Запись номера ГТД " + СтруктураЗаполнения.Код + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
				КонецПопытки;
				
			Иначе
				Результат = ПараметрыМК.Ссылка;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
		
	Возврат Результат;
	
