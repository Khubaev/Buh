		ТекСтрока.Объект1с = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Номенклатура_НоменклатураПоставщика,"Номенклатура");
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура Номенклатура_ЕдиницаИзмеренияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если Конф = "УНФ"
		//2024.10.22 (
		Или Конф = "РОЗН3" Тогда
		// ) 2024.10.22
		ДопПараметры = Новый Структура;
		Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			ДопПараметры.Вставить("Владелец",ТекСтрока.Объект1с);
		КонецЕсли;
		ДанныеВыбора = УНФ_ПолучитьДанныеВыбора_ЕдиницаИзмерения(ДопПараметры,СтандартнаяОбработка);
		
	ИначеЕсли Конф = "Далион" Тогда
		ДопПараметры = Новый Структура;
		Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			ДопПараметры.Вставить("Владелец",ТекСтрока.Объект1с);
		КонецЕсли;
		ДанныеВыбора = Далион_ПолучитьДанныеВыбора_ЕдиницаИзмерения(ДопПараметры,СтандартнаяОбработка);
		
	ИначеЕсли Конф = "КА2"
		Или Конф = "УТ11" Тогда
		
		МассивПараметров = Новый Массив;
		
		Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			МассивПараметров.Добавить(Новый ПараметрВыбора("Номенклатура",ТекСтрока.Объект1с));
		КонецЕсли;
		
		Элементы.Номенклатура_ЕдиницаИзмерения.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Номенклатура_ЕдиницаИзмеренияОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		
		Если Конф = "УНФ" Или Конф = "РОЗН3" Тогда
			//+++ реализовать расчет коэффциента из распознанной единицы в выбранную единицу и перенести в документ
			
		КонецЕсли;
	Иначе
		
		Если Конф = "КА2" Тогда
			//Не заполненная единица измерения может предполагать, что выбрана единица хранения номенклатуры,
			//по логике конфигурации ее не заполняем в табличной части. Для спокойствия пользователя отобразим ее тут,
			//при заполнении документа в основной форме если значение совпадает с единицей хранения - очистим
			ЕдиницаХранения = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с, "ЕдиницаИзмерения");
			ТекСтрока.Номенклатура_ЕдиницаИзмерения = ЕдиницаХранения;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция УНФ_ПолучитьДанныеВыбора_ЕдиницаИзмерения(ДопПараметры,СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если ДопПараметры.Свойство("Владелец") Тогда
		ПараметрыОтбор = Новый Структура("Отбор",ДопПараметры);
		ДанныеВыбора = Справочники.КлассификаторЕдиницИзмерения.ПолучитьДанныеВыбора(ПараметрыОтбор);
	Иначе
		ДанныеВыбора = Новый СписокЗначений;
		Выборка = Справочники.КлассификаторЕдиницИзмерения.Выбрать();
		Пока Выборка.Следующий() Цикл
			ДанныеВыбора.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДанныеВыбора;
	
КонецФункции
