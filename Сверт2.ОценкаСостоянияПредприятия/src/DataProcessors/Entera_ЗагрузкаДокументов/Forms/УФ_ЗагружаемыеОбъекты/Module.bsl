Функция СоздатьЭлементСправочника_ОсновноеСредство(СтруктураЗаполнения,ТекстОшибки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(СтруктураЗаполнения.ИдентификаторСтроки);
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
		
	Результат = Справочники.ОсновныеСредства.ПустаяСсылка();
	
	СтруктураЗаполнения.Вставить("НаименованиеПолное",ТекСтрока.ОсновныеСредства_НаименованиеПолное);
	СтруктураЗаполнения.Вставить("Изготовитель",ТекСтрока.ОсновныеСредства_Изготовитель);
	СтруктураЗаполнения.Вставить("ЗаводскойНомер",ТекСтрока.ОсновныеСредства_ЗаводскойНомер);
	СтруктураЗаполнения.Вставить("НомерПаспорта",ТекСтрока.ОсновныеСредства_НомерПаспорта);
	СтруктураЗаполнения.Вставить("ДатаВыпуска",ТекСтрока.ОсновныеСредства_ДатаВыпуска);
	СтруктураЗаполнения.Вставить("КодПоОКОФ",ТекСтрока.ОсновныеСредства_КодПоОКОФ);
	СтруктураЗаполнения.Вставить("ГруппаОС",ТекСтрока.ОсновныеСредства_ГруппаОС);
	СтруктураЗаполнения.Вставить("АмортизационнаяГруппа",ТекСтрока.ОсновныеСредства_АмортизационнаяГруппа);
	СтруктураЗаполнения.Вставить("ТипОС",ТекСтрока.ОсновныеСредства_ТипОС);
	СтруктураЗаполнения.Вставить("ЕдиницаУчета",ТекСтрока.ОсновныеСредства_ЕдиницаУчета);
	
	Родитель = ТекСтрока.ОсновныеСредства_Родитель;
	Если ЗначениеЗаполнено(Родитель) И Родитель.ЭтоГруппа Тогда
		СтруктураЗаполнения.Вставить("Родитель",Родитель);
	КонецЕсли;
	
	ОсновноеСредствоОбъект = Справочники.ОсновныеСредства.СоздатьЭлемент();
		
	ОсновноеСредствоОбъект.Заполнить(СтруктураЗаполнения);
	
	ЗаполнитьЗначенияСвойств(ОсновноеСредствоОбъект,СтруктураЗаполнения);
		
	// ( модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ТекущаяСтрока",ТекСтрока);
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ДокументИД",ТекСтрока.ДокументИД);
	ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	ПараметрыМК.Вставить("Объект",ОсновноеСредствоОбъект);
	ПараметрыМК.Вставить("Ссылка",Результат);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_ОсновноеСредство_ПередЗаписью",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) модуль кастомизации
	
		Попытка
			ОсновноеСредствоОбъект.Записать();
			Результат = ОсновноеСредствоОбъект.Ссылка;
		Исключение
			ТекстОшибки = "Запись основного средства " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
		КонецПопытки;
		
	Иначе
		Результат = ПараметрыМК.Ссылка;
		
	КонецЕсли;
	
	Возврат Результат;
	
