Процедура Документ_ВидОперацииПриИзменении(Элемент)
	// 2022.02.24 ( Дадим выбрать подотчетное лицо
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БП30" Тогда
		
		//2023.09.13 (
		Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","УслугиАренды") Тогда
			Элементы.Документ_ВедетсяУчетПредметовАренды.Видимость = ТекСтрока.ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
				И ТекСтрока.Документ_ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступлениеТоваровУслуг.УслугиАренды");
		Иначе
			Элементы.Документ_ВедетсяУчетПредметовАренды.Видимость = Ложь;
		КонецЕсли;
		// ) 2023.09.13
		
	Иначе
		Элементы.Документ_ПодотчетноеЛицо.Видимость = (ТекСтрока.ТипСоздаваемогоДокумента = "ПриобретениеТоваровУслуг"
				И ТекСтрока.Документ_ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ЗакупкаЧерезПодотчетноеЛицо"))
			//2025.08.13 ( Старая УТ11.1	
			Или (СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Полн = "УТ11.1" И ТекСтрока.ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
				И ТекСтрока.Документ_ВидОперации = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ЗакупкаЧерезПодотчетноеЛицо"));
			// ) 2025.08.13	
		
	КонецЕсли;
	// ) 2022.02.24
КонецПроцедуры
