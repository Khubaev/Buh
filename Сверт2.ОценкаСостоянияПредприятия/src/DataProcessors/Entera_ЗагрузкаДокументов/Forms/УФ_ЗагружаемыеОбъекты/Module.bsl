&НаСервере
Функция ЗаписатьСоответствиеЕдиницыИзмерения(ИдентификаторСтроки)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	СтрокаТаблицы = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	НоменклатураСсылка = СтрокаТаблицы.Объект1с;
	НаименованиеНоменклатуры = СтрокаТаблицы.Номенклатура_НаименованиеПолное;
	КонтрагентИД = СтрокаТаблицы.КонтрагентИД;
	Наименование = СтрокаТаблицы.Номенклатура_ЕдиницаИзмеренияПредставление;
	ЕдиницаИзмеренияСсылка = СтрокаТаблицы.Номенклатура_ЕдиницаИзмерения;
	КоэффициентПересчета = СтрокаТаблицы.Номенклатура_КоэффициентПересчета;	
	
	//возможно, таблица хранится по исходной схеме в настройках текущего пользователя
	СвязьЕдиницы = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьЕдиницыИзмерения");
	
	Если СвязьЕдиницы = Неопределено Тогда
		//Номенклатура + Контрагент + РаспознаннаяЕдиница (строка) -> Коэффициент + Конечная единица?
		СвязьЕдиницы = Новый ТаблицаЗначений;
		СвязьЕдиницы.Колонки.Добавить("НоменклатураСсылка");
		СвязьЕдиницы.Колонки.Добавить("НаименованиеНоменклатуры");
		СвязьЕдиницы.Колонки.Добавить("КонтрагентИД");
		СвязьЕдиницы.Колонки.Добавить("Наименование");		
		СвязьЕдиницы.Колонки.Добавить("Ссылка");
		СвязьЕдиницы.Колонки.Добавить("КоэффициентПересчета");
	КонецЕсли;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("Наименование",Наименование);
	СтруктураПоиска.Вставить("КонтрагентИД",КонтрагентИД);
	
	Если ЗначениеЗаполнено(НоменклатураСсылка) Тогда
		СтруктураПоиска.Вставить("НоменклатураСсылка",НоменклатураСсылка);
	Иначе
		СтруктураПоиска.Вставить("НаименованиеНоменклатуры",НаименованиеНоменклатуры);
	КонецЕсли;
	
	НайденныеСтроки = СвязьЕдиницы.НайтиСтроки(СтруктураПоиска);
	
	Если ЗначениеЗаполнено(ЕдиницаИзмеренияСсылка)
		//E1C-494: Для УТ11, КА2, ERP сохраняем сопоставление даже с пустой единицей,
		//так как пустое значение ЕИ в документе определяет использование единицы хранения Номенклатуры
		Или (Конф = "УТ11" Или Конф = "ERP" Или Конф = "КА2") Тогда
		
		Если НайденныеСтроки.Количество() = 0 Тогда
			НоваяСтрока = СвязьЕдиницы.Добавить();
			ТекстОповещения = "Связь единицы измерения добавлена";
		Иначе
			НоваяСтрока = НайденныеСтроки[0];
			ТекстОповещения = "Связь единицы измерения обновлена"
		КонецЕсли;
		
		НоваяСтрока.НоменклатураСсылка = НоменклатураСсылка;
		НоваяСтрока.НаименованиеНоменклатуры = НаименованиеНоменклатуры;
		НоваяСтрока.КонтрагентИД = КонтрагентИД;
		НоваяСтрока.Наименование = Наименование;
		НоваяСтрока.Ссылка = ЕдиницаИзмеренияСсылка;
		НоваяСтрока.КоэффициентПересчета = КоэффициентПересчета;
		
	Иначе
		Если НайденныеСтроки.Количество() > 0 Тогда
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				СвязьЕдиницы.Удалить(НайденнаяСтрока);
			КонецЦикла;		
			ТекстОповещения = "Связь единицы измерения очищена";
		КонецЕсли;
	КонецЕсли;
	
	//сохраняем по исходной схеме, в настройках пользователя
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","СвязьЕдиницыИзмерения",СвязьЕдиницы);
	
	Возврат ТекстОповещения;
КонецФункции

&НаСервереБезКонтекста
Функция ПредзаполнитьНовыйОбъект(ОбъектФормы,СтруктураНастроек,АдресХранилищаДанныхПортала,ДокументИД,ПараметрыЗаполнения)
	
	СтруктураЗаполнения = ПолучитьСтруктуруЗаполненияНовогоОбъекта(СтруктураНастроек,АдресХранилищаДанныхПортала,ДокументИД,ПараметрыЗаполнения);
	ЗаполнитьЗначенияСвойств(ОбъектФормы,СтруктураЗаполнения);
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	//2020.03.12 ( при работе с характеристиками в УТ11 может потребоваться заполнение владельца характеристики по виду номенклатуры
	Если ПараметрыЗаполнения.ТипОбъекта = "Номенклатура" Тогда
		Если Конф = "УТ11" Или Конф = "ERP" Или Конф = "КА2" Тогда
			Если ЗначениеЗаполнено(ОбъектФормы.ВидНоменклатуры) Тогда
				
				Попытка
					Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(ОбъектФормы);
				Исключение
					//Не обрабатываем
				КонецПопытки;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	// ) 2020.03.12
	
	//На всякий случай вернем структуру заполнения, если потребуется дозаполнение реквизитов формы на клиенте
	Возврат СтруктураЗаполнения;
	
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьСтруктуруЗаполненияНовогоОбъекта(СтруктураНастроек,АдресХранилищаДанныхПортала,ДокументИД,ПараметрыЗаполнения)
	
	ИдентификаторОбъекта = ПараметрыЗаполнения.ИдентификаторОбъекта;
	ТипОбъекта = ПараметрыЗаполнения.ТипОбъекта;
	ДополнительноеОписаниеОбъекта = ПараметрыЗаполнения.ДополнительноеОписаниеОбъекта;
	НаправлениеСоздаваемогоДокумента = ПараметрыЗаполнения.НаправлениеСоздаваемогоДокумента;
	ПользовательскиеПараметрыЗаполнения = ПараметрыЗаполнения.ПользовательскиеПараметрыЗаполнения;
		
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
				
	ДанныеДокументаПортала = ДанныеПортала.documents.Найти(ДокументИД,"id");
	ДанныеНоменклатурыПортала = ДанныеПортала.documentItems.Найти(ИдентификаторОбъекта,"Id");
	
	Если ТипОбъекта = "Контрагенты" Тогда
		Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			СтруктураЗаполнения = Новый Структура("Наименование,НаименованиеПолное,ИНН,КПП,ИдентификационныйКодЛичности",ДанныеДокументаПортала.supplierShortName,ДанныеДокументаПортала.supplierName,ДанныеДокументаПортала.supplierInn,ДанныеДокументаПортала.supplierKpp,ДанныеДокументаПортала.supplierTaxId);
		Иначе
			СтруктураЗаполнения = Новый Структура("Наименование,НаименованиеПолное,ИНН,КПП,ИдентификационныйКодЛичности",ДанныеДокументаПортала.customerShortName,ДанныеДокументаПортала.customerName,ДанныеДокументаПортала.customerInn,ДанныеДокументаПортала.customerKpp,ДанныеДокументаПортала.customerTaxId);
		КонецЕсли;
		
	ИначеЕсли ТипОбъекта = "Договоры" Тогда
		Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			СтруктураЗаполнения = Новый Структура("Наименование,Контрагент,Организация",СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора,ДанныеДокументаПортала.ПоставщикСсылка,ДанныеДокументаПортала.ПлательщикСсылка);
		Иначе
			СтруктураЗаполнения = Новый Структура("Наименование,Контрагент,Организация",СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора,ДанныеДокументаПортала.ПлательщикСсылка,ДанныеДокументаПортала.ПоставщикСсылка);
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("Номер",ПользовательскиеПараметрыЗаполнения.Номер);
		СтруктураЗаполнения.Вставить("Дата",ПользовательскиеПараметрыЗаполнения.Дата);
		СтруктураЗаполнения.Вставить("Наименование",ПользовательскиеПараметрыЗаполнения.Наименование);
		
	ИначеЕсли ТипОбъекта = "Номенклатура" Тогда	
		ВестиУчетПоГТД = ЗначениеЗаполнено(ДанныеНоменклатурыПортала.recognizedCustomsDeclaration);
		СтруктураЗаполнения = Новый Структура("Наименование,НаименованиеПолное,СтавкаНДС,ЕдиницаИзмерения,ВестиУчетПоГТД",ДанныеНоменклатурыПортала.name,ДанныеНоменклатурыПортала.name,ДанныеНоменклатурыПортала.СтавкаНДССсылка,ДанныеНоменклатурыПортала.ЕдиницаИзмеренияСсылка,ВестиУчетПоГТД);
		
		Если ДополнительноеОписаниеОбъекта = "Услуга" Тогда
			СтруктураЗаполнения.Вставить("ВидНоменклатуры",СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга);
			СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга);
			СтруктураЗаполнения.Вставить("Услуга",Истина);
			Родитель = СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги;
			
		Иначе
			СтруктураЗаполнения.Вставить("ВидНоменклатуры",СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар);
			СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар);
			СтруктураЗаполнения.Вставить("Услуга",Ложь);
			Родитель = СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатуры;
		КонецЕсли;
	
		Если ЗначениеЗаполнено(Родитель) И Родитель.ЭтоГруппа Тогда
			СтруктураЗаполнения.Вставить("Родитель",Родитель);
		КонецЕсли;
		
		Если РеквизитСуществует("Перечисления","ГрадацииКачества","Новый") Тогда
			СтруктураЗаполнения.Вставить("Качество",Перечисления.ГрадацииКачества.Новый);
		КонецЕсли;
		
		Если РеквизитСуществует("Перечисления","ВариантыИспользованияХарактеристикНоменклатуры","НеИспользовать") Тогда
			СтруктураЗаполнения.Вставить("ИспользованиеХарактеристик",Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать);
		КонецЕсли;
		
		Если РеквизитСуществует("Справочники","ВидыНоменклатуры","ГруппаДоступа") Тогда
			СтруктураЗаполнения.Вставить("ГруппаДоступа",СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар.ГруппаДоступа);
		КонецЕсли;
		
		//попробуем предзаполнить единицу измерения
		Если РеквизитСуществует("Справочники","УпаковкиЕдиницыИзмерения") Тогда
			
			Если РеквизитСуществует("Справочники","НаборыУпаковок") Тогда
				
				ВладелецЕдиницы = Справочники.НаборыУпаковок.БазовыеЕдиницыИзмерения;
				НайденнаяЕдиница = Справочники.УпаковкиЕдиницыИзмерения.НайтиПоКоду(ДанныеНоменклатурыПортала.recognizedUnitCode,Ложь,,ВладелецЕдиницы);
				
				Если Не ЗначениеЗаполнено(НайденнаяЕдиница) Тогда
					НайденнаяЕдиница = Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию(ДанныеНоменклатурыПортала.unitName,Ложь,,ВладелецЕдиницы);
				КонецЕсли;
				
				СтруктураЗаполнения.Вставить("ЕдиницаИзмерения",НайденнаяЕдиница);
				
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли ТипОбъекта = "УпаковкиЕдиницыИзмерения" Тогда
		СтруктураЗаполнения = Новый Структура("Код,Наименование,Номенклатура",ДанныеНоменклатурыПортала.recognizedUnitCode,ДанныеНоменклатурыПортала.unitName,ДанныеНоменклатурыПортала.НоменклатураСсылка);		
			
	ИначеЕсли ТипОбъекта = "НомераГТД" Тогда
		СтруктураЗаполнения = Новый Структура("Код",ДанныеНоменклатурыПортала.recognizedCustomsDeclaration);
			
	ИначеЕсли ТипОбъекта = "СтраныМира" Тогда
		СтруктураЗаполнения = Новый Структура("Код,Наименование",ДанныеНоменклатурыПортала.recognizedCountryCode,ДанныеНоменклатурыПортала.recognizedCountryShortName);
		
	ИначеЕсли ТипОбъекта = "ИсточникиПроисхождения" Тогда
		СтруктураЗаполнения = Новый Структура("Код,КодТНВЭД,НомерСтрокиГТД,ПризнакПроисхождения,НаименованиеТовара,Наименование",
			ДанныеНоменклатурыПортала.esfKzProductDeclaration,ДанныеНоменклатурыПортала.esfKzUnitCode,
			ДанныеНоменклатурыПортала.esfKzProductNumberInDeclaration,ДанныеНоменклатурыПортала.esfKzTruOriginCode,
			ДанныеНоменклатурыПортала.name,ДанныеНоменклатурыПортала.esfKzProductDeclaration);
			
	КонецЕсли;
	
	Возврат СтруктураЗаполнения;
	
КонецФункции
&НаСервереБезКонтекста
Функция РеквизитСуществует(РазделМетаданных, ОбъектМетаданных, ИмяРеквизита = Неопределено, ИмяТабЧасти = Неопределено)
	
	Существует = Ложь;
		
	Если Метаданные[РазделМетаданных].Найти(ОбъектМетаданных) <> Неопределено Тогда
		Если ИмяРеквизита = Неопределено И ИмяТабЧасти = Неопределено Тогда
			Существует = Истина;
		Иначе	
			Если ИмяТабЧасти = Неопределено Тогда
				Если РазделМетаданных = "Перечисления" Тогда
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].ЗначенияПеречисления.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				Иначе
					Если Метаданные[РазделМетаданных][ОбъектМетаданных].Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
						Существует = Истина;
					КонецЕсли;
				КонецЕсли;
			Иначе
				ТабличнаяЧасть = Метаданные[РазделМетаданных][ОбъектМетаданных].ТабличныеЧасти.Найти(ИмяТабЧасти);
				Если ТабличнаяЧасть <> Неопределено И ТабличнаяЧасть.Реквизиты.Найти(ИмяРеквизита) <> Неопределено Тогда
					Существует = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Существует;
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьСсылку_ОбъектПоНаименованию(ТипОбъекта,Наименование)
	
	Результат = Справочники[ТипОбъекта].ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Номенклатура.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	НЕ Номенклатура.ЭтоГруппа
	               |	И Номенклатура.Наименование = &Наименование";	
	Запрос.УстановитьПараметр("Наименование",Наименование);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьЗначениеРеквизитаОбъекта(ОбъектСсылка,ИмяРеквизита)
	Попытка Результат = ОбъектСсылка[ИмяРеквизита]; Исключение; КонецПопытки;	
	Возврат Результат;	
КонецФункции
