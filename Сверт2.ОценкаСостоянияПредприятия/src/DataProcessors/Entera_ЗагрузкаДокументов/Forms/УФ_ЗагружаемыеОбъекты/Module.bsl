КонецФункции
&НаСервереБезКонтекста
Функция КраткоеОписаниеОшибки(ТекстОшибки)
	
	КонецСлужебнойИнформации = Найти(ТекстОшибки,"}: ");
	Если КонецСлужебнойИнформации > 0 Тогда
		ТекстОшибки = Сред(ТекстОшибки,КонецСлужебнойИнформации + 3);
	КонецЕсли;				
	
	Возврат ТекстОшибки;
	
КонецФункции
&НаКлиентеНаСервереБезКонтекста
Процедура СообщитьСообщение(Текст,Поле = Неопределено,ИдентификаторНазначения = Неопределено) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = Текст;
	СообщениеПользователю.Поле = Поле;
	
	Если ТипЗнч(ИдентификаторНазначения) = Тип("УникальныйИдентификатор") Тогда
		СообщениеПользователю.ИдентификаторНазначения = ИдентификаторНазначения;
	КонецЕсли;
	
	СообщениеПользователю.Сообщить();
	
КонецПроцедуры


//EN-200: Поиск похожих соответствий в справочнике
&НаКлиенте
Процедура ЗагружаемыеОбъектыОбъект1сНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
		
	Если СтруктураНастроек.Номенклатура_ИспользоватьПомощникПоиска = Истина
		И ТекСтрока <> Неопределено И ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
		
		Элементы.ЗагружаемыеОбъектыОбъект1с.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
		
		Если ТекСтрока <> Неопределено И ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
			СтандартнаяОбработка = Ложь;
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("СтрокаПоиска",ТекСтрока.ПредставлениеОбъекта);
			СтруктураПоиска.Вставить("КонтрагентИД",ТекСтрока.КонтрагентИД);
			СтруктураПоиска.Вставить("ДополнятьПользовательскимиСоответствиями",СтруктураНастроек.Номенклатура_ИспользоватьВподбореУстановленныеВручнуюСоответствия);
			СтруктураПоиска.Вставить("Приоритет",СтруктураНастроек.Номенклатура_ПриоритетПриПоискеСопоставленийНоменклатуры);
			СтруктураПоиска.Вставить("РазмерСпискаПохожейНоменклатуры",РазмерСпискаПохожейНоменклатуры);
			
			//Для поиска по Номенклатуре поставщиков нужен отбор по Владельцу
			СтруктураПоиска.Вставить("ПоискПоНоменклатуреПоставщиков",ПоискПоНоменклатуреПоставщиков);
			
			Если ПоискПоНоменклатуреПоставщиков Тогда
				СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",ТекСтрока.ДокументИД));
				Если СтрокиКонтрагента.Количество() > 0 Тогда
					Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Партнер" Тогда
						СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Контрагенты_Партнер);
					ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
						СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Объект1с);
					Иначе
						//Отбор по владельцу не будем устанавливать
						СтруктураПоиска.Вставить("Владелец");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			//2020.12.23 ( Добавлена настройка для выбора групп поиска
			Если Не ПоискПоНоменклатуреПоставщиков Тогда
				СписокГрупп = ПолучитьСписокГруппДляПоискаНоменклатуры(ТекСтрока);
					
				Если СписокГрупп.Количество() > 0 Тогда
					СтруктураПоиска.Вставить("СписокГрупп",СписокГрупп);
				КонецЕсли;
			КонецЕсли;
			// ) 2020.12.23
			
			СтруктураПоиска.Вставить("НоменклатураПоставщиков_ИмяСправочника",СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяСправочника);
			
			//2022.06.29 ( Поиск по полному наименованию	
			Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование полное" Тогда
				СтруктураПоиска.Вставить("ИмяРеквизита","НаименованиеПолное");
			КонецЕсли;
			// ) 2022.06.29
			
			//УНФ: отбор по реквизиту 
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен) И ПоискПоНоменклатуреПоставщиков = Ложь Тогда
				КлючОтбора = СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен;
				СтруктураПоиска.Вставить("ОтборНедействителен",КлючОтбора);
			КонецЕсли;
			
			СписокВыбора = ПолучитьСписокПохожейНоменклатуры(СтруктураПоиска);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
			
			Если ПоискПоНоменклатуреПоставщиков Тогда
				ДополнительныеПараметры.Вставить("Элемент",Элементы.Номенклатура_НоменклатураПоставщика);
				ДополнительныеПараметры.Вставить("ЭлементНоменклатура",Элемент);
			Иначе
				ДополнительныеПараметры.Вставить("Элемент",Элемент);
			КонецЕсли;
			
			ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ОбработатьВыборНоменклатуры",ЭтаФорма,ДополнительныеПараметры),СписокВыбора);
		КонецЕсли;
		
	//Контрагенты
	ИначеЕсли СтруктураНастроек.Контрагенты_ИспользоватьПомощникПоиска = Истина
		И ТекСтрока <> Неопределено И ТекСтрока.ТипОбъекта = "Контрагенты" Тогда
		
		Элементы.ЗагружаемыеОбъектыОбъект1с.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
		
		Если ТекСтрока <> Неопределено И ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
			СтандартнаяОбработка = Ложь;
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("СтрокаПоиска",ТекСтрока.Контрагенты_Наименование);
			СтруктураПоиска.Вставить("КонтрагентИД",ТекСтрока.КонтрагентИД);
			СтруктураПоиска.Вставить("ДополнятьПользовательскимиСоответствиями",Ложь);
			СтруктураПоиска.Вставить("РазмерСпискаПохожейНоменклатуры",РазмерСпискаПохожейНоменклатуры);
			
			СписокВыбора = ПолучитьСписокПохожихКонтрагентов(СтруктураПоиска);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
			ДополнительныеПараметры.Вставить("Элемент",Элемент);
			
			ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ОбработатьВыборКонтрагента",ЭтаФорма,ДополнительныеПараметры),СписокВыбора);
		КонецЕсли;
		
	//Организации
	ИначеЕсли СтруктураНастроек.Контрагенты_ИспользоватьПомощникПоиска = Истина
		И ТекСтрока <> Неопределено И ТекСтрока.ТипОбъекта = "Организации" Тогда
		
		Элементы.ЗагружаемыеОбъектыОбъект1с.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.НеИспользовать;
		
		Если ТекСтрока <> Неопределено И ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
			СтандартнаяОбработка = Ложь;
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("СтрокаПоиска",ТекСтрока.Организации_Наименование);
			СтруктураПоиска.Вставить("КонтрагентИД",ТекСтрока.Организации_ИНН);
			СтруктураПоиска.Вставить("ДополнятьПользовательскимиСоответствиями",Ложь);
			СтруктураПоиска.Вставить("РазмерСпискаПохожейНоменклатуры",РазмерСпискаПохожейНоменклатуры);
			
			СписокВыбора = ПолучитьСписокПохожихОрганизаций(СтруктураПоиска);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
			ДополнительныеПараметры.Вставить("Элемент",Элемент);
			
			ПоказатьВыборИзМеню(Новый ОписаниеОповещения("ОбработатьВыборОрганизации",ЭтаФорма,ДополнительныеПараметры),СписокВыбора);
		КонецЕсли;
		
	Иначе
		Элементы.ЗагружаемыеОбъектыОбъект1с.ИсторияВыбораПриВводе = ИсторияВыбораПриВводе.Авто;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборНоменклатуры(Результат,ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
		Если Результат.Значение = "СтрокаПоиска" Тогда
			//ничего не делаем
			
		ИначеЕсли Результат.Значение = "СоздатьЭлемент" Тогда
			Элементы.ЗагружаемыеОбъекты.ТекущаяСтрока = ДополнительныеПараметры.ИдентификаторСтроки;
			ЗагружаемыеОбъектыОбъект1сСоздание(Элементы.ЗагружаемыеОбъекты,Истина);
			
		ИначеЕсли Результат.Значение = "СтандартныйПодборНоменклатура" Тогда
			
			ПараметрыОткрытия = Новый Структура;
			ФормаВыбора = ПолучитьФорму("Справочник.Номенклатура.ФормаВыбора",ПараметрыОткрытия,ДополнительныеПараметры.ЭлементНоменклатура);
			
			ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			ФормаВыбора.Открыть();
			
		ИначеЕсли Результат.Значение = "СтандартныйПодбор" Тогда
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("РежимВыбора",Истина); //УНФ
			
			Если ПоискПоНоменклатуреПоставщиков Тогда
				
				//справочник имеет владельца, добавим отбор
				СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",ТекСтрока.ДокументИД));
				Если СтрокиКонтрагента.Количество() > 0 Тогда
					Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Партнер" Тогда
						ОтборВладелец = Новый Структура("Владелец",СтрокиКонтрагента[0].Контрагенты_Партнер);
					ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
						ОтборВладелец = Новый Структура("Владелец",СтрокиКонтрагента[0].Объект1с);
					КонецЕсли;
					
					Если ОтборВладелец <> Неопределено Тогда
						ПараметрыОткрытия.Вставить("Отбор",ОтборВладелец);
					КонецЕсли; 
				КонецЕсли;
				
				ФормаВыбора = ПолучитьФорму("Справочник." + СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяСправочника + ".ФормаВыбора",ПараметрыОткрытия,ДополнительныеПараметры.Элемент);
			Иначе
				ФормаВыбора = ПолучитьФорму("Справочник.Номенклатура.ФормаВыбора",ПараметрыОткрытия,ДополнительныеПараметры.Элемент);
			КонецЕсли;
			
			ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			ФормаВыбора.Открыть();
		Иначе
			
			Если ПоискПоНоменклатуреПоставщиков Тогда
				ТекСтрока.Номенклатура_НоменклатураПоставщика = Результат.Значение;
				ТекСтрока.Объект1с = ПолучитьЗначениеРеквизитаОбъекта(Результат.Значение,"Номенклатура");
				ТекСтрока.Номенклатура_Характеристика = ПолучитьЗначениеРеквизитаОбъекта(Результат.Значение,"Характеристика");
				
				//В данном случае связь Номенклатура поставщика - Номенклатура и так есть в самой конфигурации, не записываем в нашу таблицу
				
			Иначе
				ТекСтрока.Объект1с = Результат.Значение;
				
				//сбрасываем характеристику, при "программном" выборе номенклатуры связь по владельцу не отрабатывает
				ТекСтрока.Номенклатура_Характеристика = Неопределено;
				
				Если СтруктураНастроек.Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия = Истина Тогда
					ТекстОповещения = ЗаписатьСоответствиеНоменклатуры(ТекСтрока.Объект1с,ТекСтрока.Номенклатура_Характеристика,ТекСтрока.ПредставлениеОбъекта,ТекСтрока.КонтрагентИД);
					ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
				КонецЕсли;
			КонецЕсли;
			
			ТекСтрока.СработавшийВариантПоиска = "РучнойВыбор";
			
			ЗаполнитьВсеСоответствующиеЗначения(ТекСтрока.ПолучитьИдентификатор());
			УстановитьДополнительныеРеквизиты(ТекСтрока);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция ПолучитьСписокПохожейНоменклатуры(СтруктураПоиска)
		
	ПоискПоНоменклатуреПоставщиков = СтруктураПоиска.Свойство("ПоискПоНоменклатуреПоставщиков") И СтруктураПоиска.ПоискПоНоменклатуреПоставщиков = Истина;
	
	СписокВыбора = Новый СписокЗначений;
	
	//пункт "Вы искали"
	НовыйЭлемент = СписокВыбора.Добавить();
	НовыйЭлемент.Значение = "СтрокаПоиска";
	НовыйЭлемент.Представление = "Вы искали: " + СтруктураПоиска.СтрокаПоиска;
	НовыйЭлемент.Картинка = БиблиотекаКартинок.Найти;
	
	//Покажем, в какой группе это искали
	Если ПоискПоНоменклатуреПоставщиков Тогда
		ИмяСправочника = СтруктураПоиска.НоменклатураПоставщиков_ИмяСправочника;
	Иначе
		ИмяСправочника = "Номенклатура";
		Если СтруктураПоиска.Свойство("СписокГрупп") Тогда
			СтрокаГрупп = " [";
			Для Каждого ГруппаПоиска Из СтруктураПоиска.СписокГрупп Цикл
				Запятая = ?(СтруктураПоиска.СписокГрупп.Найти(ГруппаПоиска) = СтруктураПоиска.СписокГрупп.Вграница(),"",",");
				СтрокаГрупп = СтрокаГрупп + ГруппаПоиска + Запятая;
			КонецЦикла;
			НовыйЭлемент.Представление = НовыйЭлемент.Представление + СтрокаГрупп + "]";
		КонецЕсли;
	КонецЕсли;
	
	Таблица = ЗаполнитьТаблицуСравнения(ИмяСправочника,СтруктураПоиска);
	
	Попытка КартинкаИстория = БиблиотекаКартинок.История; Исключение; КартинкаИстория = Новый Картинка; КонецПопытки;
	
	Если Таблица <> Неопределено Тогда
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			Если СписокВыбора.НайтиПоЗначению(СтрокаТаблицы.Ссылка) = Неопределено Тогда
				НовыйЭлемент = СписокВыбора.Добавить();
				НовыйЭлемент.Значение = СтрокаТаблицы.Ссылка;
				НовыйЭлемент.Представление = СтрокаТаблицы.Представление;
				
				Если СтрокаТаблицы.ИсточникЗначения = 0 Тогда
					НовыйЭлемент.Картинка = КартинкаИстория;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//Если в настройках включена работа со справочником Номенклатура поставщиков,
	//дадим возможность выбрать соответствующую существующую Номенклатуру, а номенклатура поставщика будет создана
	Если ПоискПоНоменклатуреПоставщиков Тогда
		
		//пункт Стандартный поиск по Номенклатуре поставщика
		НовыйЭлемент = СписокВыбора.Добавить();
		НовыйЭлемент.Значение = "СтандартныйПодбор";
		НовыйЭлемент.Представление = "Стандартный подбор [Номенклатура поставщика]...";
		НовыйЭлемент.Картинка = БиблиотекаКартинок.Справочник;
		
		//пункт Стандартный поиск по Номенклатуре
		НовыйЭлемент = СписокВыбора.Добавить();
		НовыйЭлемент.Значение = "СтандартныйПодборНоменклатура";
		НовыйЭлемент.Представление = "Стандартный подбор [Номенклатура]...";
		НовыйЭлемент.Картинка = БиблиотекаКартинок.Справочник;
		
	Иначе
		//пункт Стандартный поиск
		НовыйЭлемент = СписокВыбора.Добавить();
		НовыйЭлемент.Значение = "СтандартныйПодбор";
		НовыйЭлемент.Представление = "Стандартный подбор...";
		НовыйЭлемент.Картинка = БиблиотекаКартинок.Справочник;
	
	КонецЕсли;
	
	//пункт Создать элемент справочника
	НовыйЭлемент = СписокВыбора.Добавить();
	НовыйЭлемент.Значение = "СоздатьЭлемент";
	НовыйЭлемент.Представление = "Создать новый элемент...";
	НовыйЭлемент.Картинка = БиблиотекаКартинок.СоздатьЭлементСписка;
	
	Возврат СписокВыбора;
	
КонецФункции
&НаСервере
Процедура ЗаполнитьКэшФормы_СловаМаркеры()
	ДанныеСвязей = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СловаМаркеры");
	Если ТипЗнч(ДанныеСвязей) = Тип("ТаблицаЗначений") Тогда
		Для Каждого СтрокаМаркер Из ДанныеСвязей Цикл
			Если СтрокаМаркер.Маркер <> "" И СтрокаМаркер.Номенклатура.ЭтоГруппа Тогда
				НоваяСтрока = СловаМаркеры.Добавить();
				НоваяСтрока.Маркер = СтрокаМаркер.Маркер;
				НоваяСтрока.Номенклатура = СтрокаМаркер.Номенклатура;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Функция ПолучитьСписокГруппДляПоискаНоменклатуры(СтрокаТаблицы)
	
	СписокГрупп = Новый Массив;

	// Получаем таблицу "маркеров" - подстрок поиска номенклатуры в иерархии группы
	СтрокаДляПоиска = Нрег(СтрокаТаблицы.ПредставлениеОбъекта);				
	Для Каждого СтрокаМаркер Из СловаМаркеры Цикл
		Если Найти(СтрокаДляПоиска,Нрег(СтрокаМаркер.Маркер)) > 0 Тогда
			СписокГрупп.Добавить(СтрокаМаркер.Номенклатура);
		КонецЕсли;
	КонецЦикла;
	
	Если СтруктураНастроек.Свойство("Номенклатура_ГруппаДляПоискаПохожейНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры) Тогда
		
		Если ТипЗнч(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры) = Тип("СписокЗначений") Тогда
			Для Каждого ЭлементСписка Из СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры Цикл
				СписокГрупп.Добавить(ЭлементСписка.Значение);
			КонецЦикла;
		Иначе
			СписокГрупп.Добавить(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры);
		КонецЕсли;
	КонецЕсли;
		
	Возврат СписокГрупп;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьВыборКонтрагента(Результат,ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
		Если Результат.Значение = "СтрокаПоиска" Тогда
			//ничего не делаем
			
		ИначеЕсли Результат.Значение = "СоздатьЭлемент" Тогда
			Элементы.ЗагружаемыеОбъекты.ТекущаяСтрока = ДополнительныеПараметры.ИдентификаторСтроки;
			ЗагружаемыеОбъектыОбъект1сСоздание(Элементы.ЗагружаемыеОбъекты,Истина);
			
		ИначеЕсли Результат.Значение = "СтандартныйПодбор" Тогда
			ПараметрыОткрытия = Новый Структура;
			ФормаВыбора = ПолучитьФорму("Справочник.Контрагенты.ФормаВыбора",ПараметрыОткрытия,ДополнительныеПараметры.Элемент);
			ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			ФормаВыбора.Открыть();
			
		Иначе
			ТекСтрока.Объект1с = Результат.Значение;
			ТекстОповещения = ЗаписатьСоответствиеКонтрагента(ТекСтрока.Объект1с,ТекСтрока.Контрагенты_Наименование,ТекСтрока.Контрагенты_НаименованиеПолное);
			ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
			
			//2020.04.14 ( для конфигураций, предполагающих наличие справочника Партнеры нужно заполнить партнера при выборе контрагента
			Если РеквизитСуществует("Справочники","Контрагенты","Партнер") Тогда
				ТекСтрока.Контрагенты_Партнер = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,"Партнер");
			КонецЕсли;
			// ) 2020.04.14
			
			ЗаполнитьВсеСоответствующиеЗначения(ТекСтрока.ПолучитьИдентификатор());
			УстановитьДополнительныеРеквизиты(ТекСтрока);
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция ПолучитьСписокПохожихКонтрагентов(СтруктураПоиска)
		
