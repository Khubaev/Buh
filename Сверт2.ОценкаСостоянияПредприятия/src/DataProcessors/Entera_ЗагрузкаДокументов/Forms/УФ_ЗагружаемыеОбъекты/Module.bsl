&НаКлиенте
Процедура Контрагенты_НаименованиеПриИзменении(Элемент)
	
	//EN-357: Если контрагент не распознан, то на этапе сопоставления пользователь сможет
	//в панели доп.описания (справа) изменить поле "наименование" с трансляцией
	//этого наименования в поле "Полное наименование"
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		
		Если Не ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
			ТекСтрока.ПредставлениеОбъекта = ТекСтрока.Контрагенты_Наименование;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТекСтрока.Контрагенты_НаименованиеПолное) Тогда
			ТекСтрока.Контрагенты_НаименованиеПолное = ТекСтрока.Контрагенты_Наименование;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Контрагенты_СоглашениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	//Нужно в зависимости от направления документа выбрать тип справочника
	//и установить отбор по партнеру, если партнер еще не заполнен/создан - соглашение не выбираем
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		
		СтруктураОтбора = Новый Структура;
		
		Если ЗначениеЗаполнено(ТекСтрока.Контрагенты_Партнер) Тогда
			СтруктураОтбора.Вставить("Партнер",ТекСтрока.Контрагенты_Партнер);
		Иначе
			Попытка КартинкаОшибка = БиблиотекаКартинок.Ошибка32; Исключение; КартинкаОшибка = Новый Картинка; КонецПопытки;
			ПоказатьОповещениеПользователя("Не выбран партнер",,,КартинкаОшибка);
			Возврат;
		КонецЕсли;
		
		//Нужен отбор по организации? Форма выбора соглашения такого отбора в процедуре ПриСозданииНаСервере не предполагает
		
		ПараметрыОткрытияФормы = Новый Структура("Отбор",СтруктураОтбора);
		
		//E1C-337: ( Для документа ОтчетКомиссионера выбираем из соглашений с клиентами
		Если ТекСтрока.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
			ФормаВыбора = ПолучитьФорму("Справочник.СоглашенияСКлиентами.ФормаВыбора",ПараметрыОткрытияФормы,Элемент);
			
		Иначе
			Если ТекСтрока.Документ_Направление = "Исходящий" Тогда
				ФормаВыбора = ПолучитьФорму("Справочник.СоглашенияСКлиентами.ФормаВыбора",ПараметрыОткрытияФормы,Элемент);
			Иначе
				ФормаВыбора = ПолучитьФорму("Справочник.СоглашенияСПоставщиками.ФормаВыбора",ПараметрыОткрытияФормы,Элемент);
			КонецЕсли;
			
		КонецЕсли;
		
		Если ФормаВыбора <> Неопределено Тогда
			ФормаВыбора.ЗакрыватьПриЗакрытииВладельца = Истина;
			ФормаВыбора.РежимОткрытияОкна = РежимОткрытияОкнаФормы.БлокироватьОкноВладельца;
			ФормаВыбора.Открыть();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры


