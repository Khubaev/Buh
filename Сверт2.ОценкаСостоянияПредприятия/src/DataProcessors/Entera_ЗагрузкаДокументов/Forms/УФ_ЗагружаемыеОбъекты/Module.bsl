			//ничего не делаем
		ИначеЕсли Результат.Значение = "СтандартныйПодбор" Тогда
			ПараметрыОткрытия = Новый Структура;
			ФормаВыбора = ПолучитьФорму("Справочник.Организации.ФормаВыбора",ПараметрыОткрытия,ДополнительныеПараметры.Элемент);
						
			ПараметрыВызова = Новый Структура("Обработчик,ФормаВыбора,ДопПараметры","ОбработатьВыборИзФормыСписка_Организации",ФормаВыбора,ДополнительныеПараметры);
			_ЗФ_ОбработатьАсинхронныйВызов("ВыборЗначенияИзФормыСписка",ПараметрыВызова);
			
		Иначе
			ТекСтрока.Объект1с = Результат.Значение;
			ТекстОповещения = ЗаписатьСоответствиеОрганизации(ТекСтрока.Объект1с,ТекСтрока.Организации_Наименование,ТекСтрока.Организации_НаименованиеПолное);
			ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
			
			ЗаполнитьВсеСоответствующиеЗначения(ТекСтрока.ПолучитьИдентификатор());
			УстановитьДополнительныеРеквизиты(ТекСтрока);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборИзФормыСписка_Организации(Результат,ДопПараметры) Экспорт
	Если Результат <> Неопределено Тогда
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДопПараметры.ИдентификаторСтроки);
		ТекстОповещения = ЗаписатьСоответствиеОрганизации(Результат,ТекСтрока.Организации_Наименование,ТекСтрока.Организации_НаименованиеПолное);
		ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
	
		ЗаполнитьВсеСоответствующиеЗначения(ТекСтрока.ПолучитьИдентификатор());
		УстановитьДополнительныеРеквизиты(ТекСтрока);
	КонецЕсли;
КонецПроцедуры
&НаСервереБезКонтекста
Функция ПолучитьСписокПохожихОрганизаций(СтруктураПоиска)
		
	СписокВыбора = Новый СписокЗначений;
	
	//пункт "Вы искали"
	НовыйЭлемент = СписокВыбора.Добавить();
	НовыйЭлемент.Значение = "СтрокаПоиска";
	НовыйЭлемент.Представление = "Вы искали: " + СтруктураПоиска.СтрокаПоиска;
	НовыйЭлемент.Картинка = БиблиотекаКартинок.Найти;
	
	Таблица = ЗаполнитьТаблицуСравнения("Организации",СтруктураПоиска);
	
	Попытка КартинкаИстория = БиблиотекаКартинок.История; Исключение; КартинкаИстория = Новый Картинка; КонецПопытки;
	
	Если Таблица <> Неопределено Тогда
		Для Каждого СтрокаТаблицы Из Таблица Цикл
			Если СписокВыбора.НайтиПоЗначению(СтрокаТаблицы.Ссылка) = Неопределено Тогда
				НовыйЭлемент = СписокВыбора.Добавить();
				НовыйЭлемент.Значение = СтрокаТаблицы.Ссылка;
				НовыйЭлемент.Представление = СтрокаТаблицы.Представление;
				
				Если СтрокаТаблицы.ИсточникЗначения = 0 Тогда
					НовыйЭлемент.Картинка = КартинкаИстория;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//пункт Стандартный поиск
	НовыйЭлемент = СписокВыбора.Добавить();
	НовыйЭлемент.Значение = "СтандартныйПодбор";
	НовыйЭлемент.Представление = "Стандартный подбор...";
	НовыйЭлемент.Картинка = БиблиотекаКартинок.Справочник;
	
	Возврат СписокВыбора;
	
КонецФункции


// ( идея подсмотрена у 42cloud
&НаСервереБезКонтекста
Функция ЗаполнитьТаблицуСравнения(ИмяСправочника,СтруктураПоиска) Экспорт

	Если СтруктураПоиска.Свойство("ИмяРеквизита") Тогда
		ИмяРеквизита = СтруктураПоиска.ИмяРеквизита;
	Иначе
		ИмяРеквизита = "Наименование";
	КонецЕсли;
	
	СтрокаПоиска = СтруктураПоиска.СтрокаПоиска;
	
	Если СтруктураПоиска.Свойство("Владелец") Тогда
		Владелец = СтруктураПоиска.Владелец;
	КонецЕсли;
	
	Если СтруктураПоиска.Свойство("СписокГрупп") Тогда
		СписокГрупп = СтруктураПоиска.СписокГрупп;
	КонецЕсли;
	
	СтрокаВ = ВРег(СтрЗаменить(СтрокаПоиска, """", ""));
	ДлинаВ = СтрДлина(СтрокаВ);
	Список = Новый СписокЗначений;
	
	Если ДлинаВ > 100 Тогда
		ДлинаПодстроки = 10; 
	ИначеЕсли ДлинаВ > 50 Тогда
		ДлинаПодстроки = 5;
	ИначеЕсли ДлинаВ > 28 Тогда
		ДлинаПодстроки = 4;
	ИначеЕсли ДлинаВ > 12 Тогда
		ДлинаПодстроки = 3;
	ИначеЕсли ДлинаВ > 2 Тогда
		ДлинаПодстроки = 2;
	Иначе
		ДлинаПодстроки = ДлинаВ;
	КонецЕсли;
	
	Для ПозСтрВ = 1 По ДлинаВ - ДлинаПодстроки + 1 Цикл
		ПодстрокаВ = Сред(СтрокаВ, ПозСтрВ, ДлинаПодстроки);
		Список.Добавить(ПодстрокаВ);
	КонецЦикла; 
		
	РазмерСписка = Список.Количество() - 1;
	ДлинаСтроки = Метаданные.Справочники[ИмяСправочника].ДлинаНаименования;
	Если ДлинаСтроки = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	//Проверка нужен ли поиск только в заданных группах
	Если СписокГрупп <> Неопределено Тогда
		ВИерархии = "И ИсходныйСправочник.Ссылка В ИЕРАРХИИ (&СписокГрупп)";
	Иначе
		ВИерархии = "";
	КонецЕсли;	
	
	//Проверка является ли справочник иерархическим
	Иерархический = ?(Метаданные.Справочники[ИмяСправочника].Иерархический И Метаданные.Справочники[ИмяСправочника].ВидИерархии = Метаданные.СвойстваОбъектов.ВидИерархии.ИерархияГруппИЭлементов, Истина, Ложь);
	Если Иерархический Тогда
		НЕГруппа = "И НЕ ИсходныйСправочник.ЭтоГруппа";
	Иначе
		НЕГруппа = "";
	КонецЕсли;
	
	//Проверка на наличие реквизита "Владелец" у справочника
	ОтборПоВладельцу = "";
	Если Метаданные.Справочники[ИмяСправочника].Владельцы.Количество() > 0 И Владелец <> Неопределено Тогда
		Если ТипЗнч(Владелец) = Тип("Строка") Тогда
			ОтборПоВладельцу = "И ИсходныйСправочник.Владелец.Наименование = &Владелец ";
		Иначе
			ОтборПоВладельцу = "И ИсходныйСправочник.Владелец = &Владелец ";
		КонецЕсли;
	КонецЕсли;
	
	Если СтруктураПоиска.Свойство("ОтборНедействителен") Тогда
		ОтборНедействителен = "И ИсходныйСправочник." + СтруктураПоиска.ОтборНедействителен + " = Ложь";
	Иначе
		ОтборНедействителен = "";
	КонецЕсли;
	
	Запрос = Новый Запрос; 
	
	//EN-291: Первыми в списке должны идти ранее устанавливашиеся ручные соответствия
	ДополнятьПользовательскимиСоответствиями = Ложь;
	Если СтруктураПоиска.Свойство("ДополнятьПользовательскимиСоответствиями") И СтруктураПоиска.ДополнятьПользовательскимиСоответствиями = Истина Тогда
		
		СвязьНоменклатуры = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьНоменклатуры");
		Если ТипЗнч(СвязьНоменклатуры) = Тип("ТаблицаЗначений") И СвязьНоменклатуры.Количество() > 0 Тогда
			
			ТаблицаСоответствий = Новый ТаблицаЗначений;
			ТаблицаСоответствий.Колонки.Добавить("Ссылка",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			ТаблицаСоответствий.Колонки.Добавить("Наименование",Новый ОписаниеТипов("Строка"));
			
			Для Каждого СтрокаСвязи Из СвязьНоменклатуры Цикл
				//+++ Замерить выполнение перебором или поиском строк
				Если СтрокаСвязи.КонтрагентИД = СтруктураПоиска.КонтрагентИД Тогда
					НоваяСтрока = ТаблицаСоответствий.Добавить();
					НоваяСтрока.Ссылка = СтрокаСвязи.Ссылка;
					НоваяСтрока.Наименование = СтрокаСвязи.Наименование;
				КонецЕсли;
			КонецЦикла;
			
			Если ТаблицаСоответствий.Количество() > 0 Тогда
				ДополнятьПользовательскимиСоответствиями = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ДополнятьПользовательскимиСоответствиями Тогда
				
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Соответствия.Ссылка КАК Ссылка,
			|	ВЫРАЗИТЬ(Соответствия.Наименование КАК Строка(1000)) КАК Наименование
			|ПОМЕСТИТЬ ВТ_Связи
			|ИЗ
			|	&ТаблицаСоответствий КАК Соответствия;
			|
 			|////////////////////////////////////////////////////////////////////////////////
			|
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		 	|	ИсходныйСправочник.Ссылка КАК Ссылка,
			|	1 КАК ИсточникЗначения,
			|	ВЫРАЗИТЬ(ИсходныйСправочник." + ИмяРеквизита + " КАК Строка(1000)) КАК Наименование  
			|ПОМЕСТИТЬ ОтобраноДляПоиска
		 	|ИЗ
		 	|	Справочник." + ИмяСправочника + " КАК ИсходныйСправочник
		 	|ГДЕ
		 	|	НЕ ИсходныйСправочник.ПометкаУдаления 
		 	|	" + ВИерархии + "
		 	|	" + НЕГруппа + "
			|	" + ОтборПоВладельцу + "
			|	" + ОтборНедействителен + "
			|
			|ОБЪЕДИНИТЬ ВСЕ
		 	|
			|ВЫБРАТЬ
			|	Соответствия.Ссылка,
			|	0,
			|	Выразить(Соответствия.Наименование КАК Строка(1000))
			|ИЗ
			|	ВТ_Связи КАК Соответствия;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|
			|ВЫБРАТЬ
			|	ОтобраноДляПоиска.Ссылка КАК Ссылка,
			|	МИНИМУМ(ОтобраноДляПоиска.ИсточникЗначения) КАК ИсточникЗначения,
			|	ОтобраноДляПоиска.Наименование КАК Наименование
			|ПОМЕСТИТЬ ОтфильтрованоДляПоиска
			|ИЗ
			|	ОтобраноДляПоиска КАК ОтобраноДляПоиска
			|
			|СГРУППИРОВАТЬ ПО
			|	ОтобраноДляПоиска.Ссылка,
			|	ОтобраноДляПоиска.Наименование
			|
	  		|ИНДЕКСИРОВАТЬ ПО
	  		|	Ссылка
		 	|;";
		
		Запрос.УстановитьПараметр("ТаблицаСоответствий",ТаблицаСоответствий);
	
	Иначе
	// ) EN-291
	
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		 	|	ИсходныйСправочник.Ссылка КАК Ссылка,
			|	1 КАК ИсточникЗначения,
			|	ВЫРАЗИТЬ(ИсходныйСправочник." + ИмяРеквизита + " КАК Строка(1000)) КАК Наименование  
			|ПОМЕСТИТЬ ОтфильтрованоДляПоиска
		 	|ИЗ
		 	|	Справочник." + ИмяСправочника + " КАК ИсходныйСправочник
		 	|ГДЕ
		 	|	НЕ ИсходныйСправочник.ПометкаУдаления 
		 	|	" + ВИерархии + "
		 	|	" + НЕГруппа + "
			|	" + ОтборПоВладельцу + "
			|	" + ОтборНедействителен + "
			|
	  		|ИНДЕКСИРОВАТЬ ПО
	  		|	Ссылка
		 	|;";
	КонецЕсли;
	
	Запрос.Текст = Запрос.Текст + "
	 	|
	 	|////////////////////////////////////////////////////////////////////////////////

		| ВЫБРАТЬ ПЕРВЫЕ 5
		| 	СУММА(ВложенныйЗапрос.Количество) КАК Количество,
		| 	ВложенныйЗапрос.Ссылка,
		| 	МИНИМУМ(ВложенныйЗапрос.ИсточникЗначения) КАК ИсточникЗначения,
		| 	ВложенныйЗапрос.Представление КАК Представление,
		|	&УпорядочиваниеДопТаблицы КАК ПроцентВхождения
		|ИЗ
		| (";
		
	Для к = 0 По РазмерСписка Цикл
		
		//E1C-142: Экранируем спецсимволы ПОДОБНО
		ТекущееЗначение = "%" + ЭкранироватьСпецсимволыПодобно(Список[к].Значение) + "%";
		Запрос.УстановитьПараметр("Шаблон" + СтрЗаменить(к,Символы.НПП,""),ТекущееЗначение);
		
		Запрос.Текст =  Запрос.Текст + "
		|ВЫБРАТЬ
		|	ПоискПодстроки.Ссылка КАК Ссылка,
		|	ПоискПодстроки.Наименование КАК Представление,
		|	ПоискПодстроки.ИсточникЗначения КАК ИсточникЗначения,
		|	1 КАК Количество
		| ИЗ
		|	ОтфильтрованоДляПоиска КАК ПоискПодстроки
		| ГДЕ
		|	ПоискПодстроки.Наименование ПОДОБНО &Шаблон" + СтрЗаменить(к,Символы.НПП,"") + " СПЕЦСИМВОЛ ""~""
		| 	" + ?(к < РазмерСписка, "ОБЪЕДИНИТЬ ВСЕ", "");
	КонецЦикла; 
	
	Запрос.Текст = Запрос.Текст + 
		") КАК ВложенныйЗапрос
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Ссылка,
		|	ВложенныйЗапрос.Представление
		|УПОРЯДОЧИТЬ ПО
		|	Количество УБЫВ";
	
	//Проверка на наличие реквизита "Владелец" у справочника
	Если ОтборПоВладельцу <> "" И Владелец <> Неопределено Тогда
		Запрос.УстановитьПараметр("Владелец",Владелец);
	КонецЕсли;
	Если СписокГрупп <> Неопределено Тогда
		Запрос.УстановитьПараметр("СписокГрупп",СписокГрупп);
	КонецЕсли;
	
	//2019.11.22 ( Если выполняем автопоиск нам не нужно, чтобы сверху оказывались строки из ручных сопоставлений,
	//за это у нас отвечает ключ структуры ПроцентСоответствияАвтоПоиск
	Если СтруктураПоиска.Свойство("ПроцентСоответствияАвтоПоиск") Тогда
		Запрос.УстановитьПараметр("УпорядочиваниеДопТаблицы",1);
	Иначе
		Запрос.УстановитьПараметр("УпорядочиваниеДопТаблицы",0);
	КонецЕсли;
	// ) 2019.11.22
	
	//2019.04.15 (
	Попытка РазмерСпискаПохожих = Число(СтруктураПоиска.РазмерСпискаПохожейНоменклатуры); Исключение РазмерСпискаПохожих = 1; КонецПопытки;
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"ПЕРВЫЕ 5","ПЕРВЫЕ " + СтрЗаменить(РазмерСпискаПохожих,Символы.НПП,""));
	// ) 2019.04.15
	
	Таблица = Запрос.Выполнить().Выгрузить();
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		СтрокаТаблицы.ПроцентВхождения = ПодсчитатьПроцентВхождения(СтрокаПоиска,СтрокаТаблицы.Представление);
		СтрокаТаблицы.Представление = "[" + СтрокаТаблицы.ПроцентВхождения + "%] " + СтрокаТаблицы.Ссылка[ИмяРеквизита];
	КонецЦикла;
	
	//E1C-68: Настройка действует на порядок отображения значений в выпадашке с подходящими и на автозаполнение подходящих
	Если СтруктураПоиска.Свойство("Приоритет") И СтруктураПоиска.Приоритет = "Лучшее из всех доступных" Тогда
		Таблица.Сортировать("ПроцентВхождения УБЫВ");
	Иначе
		Таблица.Сортировать("ИсточникЗначения ВОЗР,ПроцентВхождения УБЫВ");
	КонецЕсли;
	
	Возврат Таблица;
	
КонецФункции
&НаСервереБезКонтекста
Функция ПодсчитатьПроцентВхождения(Знач СтрокаПоиска, Знач Строка) 
	
	КвоВхождений = 0;
	КвоВхождений2 = 0;
	СтепеньСовпадения = 0;
	
	СтрокаПоиска = СокрЛП(ВРЕГ(СтрокаПоиска));
	Строка = СокрЛП(ВРЕГ(Строка));
	
	СтрокаПоиска = СтрЗаменить(СтрокаПоиска, """", "");
	Строка = СтрЗаменить(Строка, """", "");
	
	ДлинаВ = СтрДлина(Строка);
	Если ДлинаВ > 100 Тогда
		ДлинаПодстрокиНач = 3;
	ИначеЕсли ДлинаВ > 50 Тогда
		ДлинаПодстрокиНач = 2;
	Иначе
		ДлинаПодстрокиНач = 1;
	КонецЕсли;
 
	Если НЕ (СтрДлина(СтрокаПоиска) = 0 ИЛИ СтрДлина(Строка) = 0) Тогда
		
		Для ДлинаПодстроки = ДлинаПодстрокиНач По 3 Цикл
			
			НачНомерПодстроки = 1;
			НомерСимвола = 0;
			Пока НомерСимвола + ДлинаПодстроки <= СтрДлина(Строка) Цикл
				Подстрока = СРЕД(Строка, НачНомерПодстроки, ДлинаПодстроки);
				Если Найти(СтрокаПоиска, Подстрока) > 0 Тогда
					КвоВхождений2=КвоВхождений2 + 1;
				КонецЕсли;
				КвоВхождений = КвоВхождений + 1;
				НачНомерПодстроки = НачНомерПодстроки + 1;
				НомерСимвола = НомерСимвола + 1;
			КонецЦикла;
			
			НачНомерПодстроки = 1;
			НомерСимвола = 0;
			Пока НомерСимвола + ДлинаПодстроки <= СтрДлина(СтрокаПоиска) Цикл
				Подстрока = СРЕД(СтрокаПоиска, НачНомерПодстроки, ДлинаПодстроки);
				Если Найти(Строка, Подстрока) <> 0 Тогда
					КвоВхождений2=КвоВхождений2 + 1;
				КонецЕсли;
				КвоВхождений = КвоВхождений + 1;
				НачНомерПодстроки = НачНомерПодстроки + 1;
				НомерСимвола = НомерСимвола + 1;
			КонецЦикла;
			
		КонецЦикла;

	КонецЕсли;

	Если КвоВхождений > 0 Тогда
		Результат = ?(КвоВхождений>КвоВхождений2, Окр((КвоВхождений2/КвоВхождений)*100),Окр((КвоВхождений/КвоВхождений2)*100));
		Результат = ?(Результат = 100 И КвоВхождений<>КвоВхождений2, 99, Результат);
	Иначе
		Результат = 0;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
