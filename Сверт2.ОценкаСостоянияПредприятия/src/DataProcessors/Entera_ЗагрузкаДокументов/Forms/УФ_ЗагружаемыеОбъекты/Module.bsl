			НовыйМассив = Новый Массив();
			НовыйМассив.Добавить(НоваяСвязь);
			Элементы.Номенклатура_ЕдиницаИзмерения.СвязиПараметровВыбора = Новый ФиксированныйМассив(НовыйМассив);
		КонецЕсли;
	КонецЕсли;
	
	//Склад
	Массив = Новый Массив;
	Массив.Добавить(ТипЗнч(СтруктураНастроек.ЗаполнениеШапки_СкладПоУмолчанию));
	Элементы.Документ_Склад.ОграничениеТипа = Новый ОписаниеТипов(Массив);
	
	//Подразделение
	Если СтруктураНастроек.ЗаполнениеШапки_ПодразделениеПоУмолчанию = "" Тогда
		Элементы.Документ_Подразделение.Видимость = Ложь;
	Иначе
		Массив = Новый Массив;
		Массив.Добавить(ТипЗнч(СтруктураНастроек.ЗаполнениеШапки_ПодразделениеПоУмолчанию));
		Элементы.Документ_Подразделение.ОграничениеТипа = Новый ОписаниеТипов(Массив);
	КонецЕсли;
	
	//Подразделение организации
	Массив = Новый Массив;
	Массив.Добавить(ТипЗнч(СтруктураНастроек.ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию));
	Элементы.Документ_ПодразделениеОрганизации.ОграничениеТипа = Новый ОписаниеТипов(Массив);
	
	//Номенклатуру поставщиков отображаем если включена настройка
	Элемент = Элементы.Номенклатура_НоменклатураПоставщика;
	Элемент.Видимость = ПоискПоНоменклатуреПоставщиков;
	
	Если ПоискПоНоменклатуреПоставщиков Тогда	
		
		Если Метаданные.Справочники.Найти("НоменклатураПоставщиков") <> Неопределено Тогда
			Тип_НоменклатураПоставщиков = Тип("СправочникСсылка.НоменклатураПоставщиков");
		ИначеЕсли Метаданные.Справочники.Найти("НоменклатураКонтрагентов") <> Неопределено Тогда
			Тип_НоменклатураПоставщиков = Тип("СправочникСсылка.НоменклатураКонтрагентов");
		КонецЕсли;
		
		Если Тип_НоменклатураПоставщиков <> Неопределено Тогда
			Массив = Новый Массив();
			Массив.Добавить(Тип_НоменклатураПоставщиков);
			ОписаниеТипов = Новый ОписаниеТипов(Массив);
			
			Элемент.ОграничениеТипа = ОписаниеТипов;
		КонецЕсли;
		
	КонецЕсли;
	
	//Отображаем элемент выбора табличной части документа по настройке
	Элементы.Документ_ИмяТабличнойЧасти.Видимость = СтруктураНастроек.ЗаполнениеТЧ_ВыбиратьТабличнуюЧастьДляЗаполнения = Истина;
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьОграничениеТипа_ЭлементТекущейСтроки(ТекСтрока)
	
	Если ЗначениеЗаполнено(ТекСтрока.ОписаниеТипа) Тогда
		Массив = Новый Массив();
		Массив.Добавить(Тип(ТекСтрока.ОписаниеТипа));
		ОписаниеТипов = Новый ОписаниеТипов(Массив);
	Иначе
		ОписаниеТипов = Новый ОписаниеТипов();
	КонецЕсли;
	
	Элементы.ЗагружаемыеОбъектыОбъект1с.ОграничениеТипа = ОписаниеТипов;
	
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьКнопкиКонтекстногоМеню()
	
	//Кнопки смены типа номенклатуры
	СписокКнопок = ЗначениеИзСтрокиВнутрСервер(СтруктураНастроек.Номенклатура_ТипНоменклатурыТоварУслуга_СписокВыбора);
	
	Для Каждого Кнопка Из СписокКнопок Цикл
		ИмяКоманды = "ТипНоменклатуры_" + Кнопка.Значение;
		ДобавитьКнопкуНаФорму(ИмяКоманды,ИмяКоманды,Кнопка.Представление,"УстановитьТипНоменклатурыВыделеннымСтрокам",Элементы.ЗагружаемыеОбъектыГруппаУстановитьТипНоменклатуры);
	КонецЦикла;
	
	//Добавление связи маркера и номенклатуры
	ИмяКоманды = "ДобавитьМаркерНоменклатуры";
	ДобавитьКнопкуНаФорму(ИмяКоманды,ИмяКоманды,"Добавить в маркеры","ДобавитьМаркерНоменклатуры",Элементы.ЗагружаемыеОбъектыКонтекстноеМенюМаркеры);
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура Команда_Дополнительно(Команда)
	
	СписокВыбора = Новый СписокЗначений;
	
	Если СпособКомпоновкиЭлементовФормы = "Горизонтально" Тогда
		Попытка Картинка = БиблиотекаКартинок.ВнешнийИсточникДанныхКубТаблицаИзмерения; Исключение; КонецПопытки;
		СписокВыбора.Добавить("СпособКомпоновкиЭлементовФормы_Вертикально","Отображать элементы вертикально",,Картинка);
	Иначе
		Попытка Картинка = БиблиотекаКартинок.ВнешнийИсточникДанныхКубТаблицаИзмерения; Исключение; КонецПопытки;
		СписокВыбора.Добавить("СпособКомпоновкиЭлементовФормы_Горизонтально","Отображать элементы горизонтально",,Картинка);
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("ЭлементФормы",Элементы.Дополнительно);
	
	ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,СписокВыбора","ОбработатьВыбор_Дополнительно",ДопПараметры,СписокВыбора);
		
	_ЗФ_ОбработатьАсинхронныйВызов("ВыборИзМеню",ПараметрыВызова);
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыбор_Дополнительно(Результат,ДопПараметры)
	
	Если Результат = Неопределено Тогда
		Возврат;	
		
	Иначе
		ВыбранноеЗначение = Результат.Значение;
		
		Если ВыбранноеЗначение = "СпособКомпоновкиЭлементовФормы_Вертикально" Тогда
			СпособКомпоновкиЭлементовФормы = "Вертикально";
			УстановитьСпособКомпоновкиЭлементовФормы();
			
		ИначеЕсли ВыбранноеЗначение = "СпособКомпоновкиЭлементовФормы_Горизонтально" Тогда
			СпособКомпоновкиЭлементовФормы = "Горизонтально";
			УстановитьСпособКомпоновкиЭлементовФормы();
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДополнительноеОпианиеЭлементаПриИзменении(Элемент)
	Элементы.ГруппаОписаниеСоздаваемыхЭлементов.Видимость = ДополнительноеОписаниеЭлемента;
КонецПроцедуры
&НаКлиенте
Процедура ПоказыватьСканДокументаПриИзменении(Элемент)
	
	Если ПоказыватьСканДокументаСредствамиEntera Тогда
		СканДокумента_ИнициализироватьСтраницу_ENTERA();
	КонецЕсли;
	
	СканДокумента_ПоказатьСканДокумента();
	
КонецПроцедуры
&НаКлиенте
Процедура ОтборПриИзменении(Элемент)
	УстановитьОтборСтрокТаблицы();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОтборСтрокТаблицы() Экспорт
	Если Отбор = 0 Тогда
		Элементы.ЗагружаемыеОбъекты.ОтборСтрок = Неопределено;
	Иначе
		Элементы.ЗагружаемыеОбъекты.ОтборСтрок = Новый ФиксированнаяСтруктура("СоответствиеУстановлено",Отбор = 2); 
	КонецЕсли;		
	Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки.Очистить();
КонецПроцедуры


&НаКлиенте
Процедура ЗагружаемыеОбъектыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если Поле = Элементы.ЗагружаемыеОбъектыПредставлениеДокумента Тогда
				
		Если ВладелецФормы.ЭтоВебКлиент Тогда
			//Переходим по навигационной ссылке на pdf
			ВладелецФормы._ЗФ_Команда_ПерейтиПоСсылке("https://app.entera.pro/api/v1/documents/" + ТекСтрока.ДокументИД + "/printForm?view");
		Иначе
			//Получим файл на локальную машину и откроем штатным просмотрщиком pdf
			Если ЗначениеЗаполнено(ТекСтрока.АдресХранилищаСканаДокумента) Тогда
				//Печатная форма уже получена ранее
				АдресХранилищаСканаДокумента = ТекСтрока.АдресХранилищаСканаДокумента;
			Иначе
					
				//Получаем печатную форму PDF
				РезультатЗапроса = ВладелецФормы.ПолучитьПечатнуюФормуСканаДокумента(ТекСтрока.ДокументИД,ТекСтрока.ПредставлениеДокумента);
				Если РезультатЗапроса.Успешно Тогда
					
					Если РезультатЗапроса.ТребуетсяПовтор Тогда
						СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
					Иначе
						АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
						ТекСтрока.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
						ТекСтрока.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
						
						АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
						
						//Установим полученное значение для всех строк этого документа
						СтрокиДокумента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД",ТекСтрока.ДокументИД));
						Для Каждого СтрокаДокумента Из СтрокиДокумента Цикл
							СтрокаДокумента.АдресХранилищаСканаДокумента = РезультатЗапроса.АдресВХ;
							СтрокаДокумента.ИмяФайлаСканаДокумента = РезультатЗапроса.ИмяФайла;
						КонецЦикла;
						
					КонецЕсли;
				Иначе
					СообщитьСообщение(РезультатЗапроса.ТекстОшибки);
				КонецЕсли;
				
			КонецЕсли;
			
			Если ЭтоАдресВременногоХранилища(АдресХранилищаСканаДокумента) Тогда
				//Открываем полученный скан системным просмотрщиком
				ВладелецФормы._ЗФ_Команда_ПоказатьФайлСкана(АдресХранилищаСканаДокумента);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагружаемыеОбъектыПриАктивизацииСтроки(Элемент)
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		
		Если ТекСтрока.ПолучитьИдентификатор() = ИдентификаторТекущейСтроки Тогда
			Возврат;
		КонецЕсли;
		
		//Сбросим возможно установленные ранее параметры выбора
		Элементы.ЗагружаемыеОбъектыОбъект1с.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);	
				
		Если ТекСтрока.ТипОбъекта = "Документ" Тогда
			
			//Вид операции может быть зафиксирован при выборе пользователем типа создаваемого документа (Основные средства)
			Если ТекСтрока.Документ_ВидОперацииЗаданПринудительно = Истина Тогда
				Элементы.Документ_ВидОперации.Доступность = Ложь;
				Элементы.Документ_ВидОперации.Подсказка = "Вид операции определен при выборе типа документа";
			Иначе
				//Вид операции доступен для изменения только для значений, предусмотренных дальнейшим заполнением по виду операции документа
				ДоступныеВидыОпераций = СтруктураНастроек.СведенияОКонфигурации.ВидыОперацийЗаполняемыхДокументов.Получить(ТекСтрока.ТипСоздаваемогоДокумента);
				Если ДоступныеВидыОпераций <> Неопределено И ДоступныеВидыОпераций.Количество() > 0 Тогда
					Элементы.Документ_ВидОперации.Доступность = Истина;
					Элементы.Документ_ВидОперации.Подсказка = "Вид операции создаваемого документа";
				Иначе
					Элементы.Документ_ВидОперации.Доступность = Ложь;
					Элементы.Документ_ВидОперации.Подсказка = "Для создаваемого типа документа недоступен выбор вида операции";
				КонецЕсли;
			КонецЕсли;
			
			//Назначение платежа видно только для типа создаваемого документа, у которого есть реквизит НазначениеПлатежа
			Элементы.Документ_НазначениеПлатежа.Видимость = РеквизитСуществует("Документы",ТекСтрока.ТипСоздаваемогоДокумента,"НазначениеПлатежа");
			
			//Подотчетное лицо видимо только для типа создаваемого документа АвансовыйОтчет
			Элементы.Документ_ПодотчетноеЛицо.Видимость = ТекСтрока.ТипСоздаваемогоДокумента = "АвансовыйОтчет"
			    //2023.09.26 ( БП30 KAZ
				Или ТекСтрока.ТипСоздаваемогоДокумента = "Доверенность"
				// ) 2023.09.26
				// 2022.02.24 ( Для УТ, КА, ERP
				Или (ТекСтрока.ТипСоздаваемогоДокумента = "ПриобретениеТоваровУслуг" И ЗначениеЗаполнено(ТекСтрока.Документ_ВидОперации));
				// ) 2022.02.24
				
			Элементы.Документ_НазначениеАванса.Видимость = ТекСтрока.ТипСоздаваемогоДокумента = "АвансовыйОтчет";
			
			//E1C-509: Документ-основание пока что отображаем только для типа создаваемого документа СчетФактураПолученный с видом операции НаАванс (других пока тут и не предполагаем)
			Если ТекСтрока.ТипСоздаваемогоДокумента = "СчетФактураПолученный" Тогда
				Элементы.Документ_ДокументОснование.Видимость = Истина;
				
				МассивТипов = Новый Массив;
				МассивТипов.Добавить(Тип("ДокументСсылка.СписаниеСРасчетногоСчета"));
				МассивТипов.Добавить(Тип("ДокументСсылка.РасходныйКассовыйОрдер"));
				Элементы.Документ_ДокументОснование.ОграничениеТипа = Новый ОписаниеТипов(МассивТипов);
				
			Иначе
				Элементы.Документ_ДокументОснование.Видимость = Ложь;
			КонецЕсли;
			
			//E1C-308: для документа ПоступлениеДопРасходов
			Если ТекСтрока.ТипСоздаваемогоДокумента = "ПоступлениеДопРасходов" Тогда
				Элементы.Документ_ДокументыПоступленияДляДопРасходов.Видимость = Истина;
				Элементы.Документ_СодержаниеУслугиДляДопРасходов.Видимость = Истина;
			
				Если ЗначениеЗаполнено(ТекСтрока.Документ_ДокументыПоступленияДляДопРасходов) Тогда
					ЗначенияСписка = ТекСтрока.Документ_ДокументыПоступленияДляДопРасходов;
					ТекСтрока.Документ_ДокументыПоступленияДляДопРасходовСписок = ЗначениеИзСтрокиВнутрСервер(ЗначенияСписка);
				Иначе
					ТекСтрока.Документ_ДокументыПоступленияДляДопРасходовСписок = Новый СписокЗначений;
				КонецЕсли;
				
				//Зададим тип значения списка значений
				ТекСтрока.Документ_ДокументыПоступленияДляДопРасходовСписок.ТипЗначения = Новый ОписаниеТипов("ДокументСсылка.ПоступлениеТоваровУслуг");
				
			Иначе
				Элементы.Документ_ДокументыПоступленияДляДопРасходов.Видимость = Ложь;
				Элементы.Документ_СодержаниеУслугиДляДопРасходов.Видимость = Ложь;
				
			КонецЕсли;
			
			//+++ Если заполняем авансовый отчет, выделим жирным заголовок ПодотчетногоЛица для первого документа списка (для шапки документа) 
			
		Иначе
			Элементы.ЗагружаемыеОбъектыДополнительноеОписаниеОбъекта.ТолькоПросмотр = ТекСтрока.ДополнительноеОписание_СписокВыбора = "";
					
			// 2019.02.28 ( Никита попросил сделать, чтобы выпадашка с похожими работала "в 2 клика"
			РежимРедактирования = РежимРедактированияКолонки.ВходПриВводе;
			КнопкаВыпадающегоСписка = Неопределено;
			КнопкаСоздания = Неопределено;
			РедактированиеТекста = Истина;
			ИсторияВыбора = ИсторияВыбораПриВводе.Авто;
			
			Если (ТекСтрока.ТипОбъекта = "Номенклатура" И СтруктураНастроек.Номенклатура_ИспользоватьПомощникПоиска = Истина)
				Или (ТекСтрока.ТипОбъекта = "Контрагенты" И СтруктураНастроек.Контрагенты_ИспользоватьПомощникПоиска = Истина)
				Или (ТекСтрока.ТипОбъекта = "Организации" И СтруктураНастроек.Контрагенты_ИспользоватьПомощникПоиска = Истина)
				Или (ТекСтрока.ТипОбъекта = "Договоры" И СтруктураНастроек.ЗаполнениеШапки_РучноеРедактированиеДоговора = Истина)
				Или (ТекСтрока.ТипОбъекта = "БанковскиеСчета" И СтруктураНастроек.ЗаполнениеШапки_СоздаватьБанковскийСчетКонтрагента = Истина) Тогда
				
				КнопкаВыпадающегоСписка = Ложь;
				КнопкаСоздания = Ложь;
				РедактированиеТекста = Истина; //2019.07.05 - снова изменили на доступность редактирования, будет многоклик для "умного" поиска
				ИсторияВыбора = ИсторияВыбораПриВводе.НеИспользовать;
				
				//Отбор при выборе договора
				Если ТекСтрока.ТипОбъекта = "Договоры" Тогда
					
					//E1C-516:
					КнопкаСоздания = Истина;
					
					//Зададим параметры выбора для этого поля: организация и контрагент известны, если не заполнены - не даем выбрать
					НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД,ТипОбъекта",ТекСтрока.ДокументИД,"Контрагенты"));
					Если НайденныеСтроки.Количество() > 0 Тогда
						КонтрагентСсылка = НайденныеСтроки[0].Объект1с;
					КонецЕсли;
					
					НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД,ТипОбъекта",ТекСтрока.ДокументИД,"Организации"));
					Если НайденныеСтроки.Количество() > 0 Тогда
						ОрганизацияСсылка = НайденныеСтроки[0].Объект1с;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(КонтрагентСсылка) И ЗначениеЗаполнено(ОрганизацияСсылка) Тогда
						
						//задаем параметры выбора			
						ОтборОрганизация = Новый ПараметрВыбора("Отбор.Организация",ОрганизацияСсылка);
						
						ОтборВладелец = Новый ПараметрВыбора("Отбор.Владелец",КонтрагентСсылка);
						ОтборКонтрагент = Новый ПараметрВыбора("Отбор.Контрагент",КонтрагентСсылка);
						
						//+++ возможно, следует определять по конфе, какой отбор накладывать
						МассивПараметров = Новый Массив();
						МассивПараметров.Добавить(ОтборОрганизация);
						
						Если СтруктураНастроек.СведенияОКонфигурации.Договоры_ВладелецКонтрагенты Тогда
							МассивПараметров.Добавить(ОтборВладелец);
						Иначе
							МассивПараметров.Добавить(ОтборКонтрагент);
						КонецЕсли;
						
						//E1C-327: Если тип создаваемого документа ОтчетКомиссионераОПродажах, добавляем в отбор ВидДоговора
						Если ТекСтрока.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда							
							Если РеквизитСуществует("Перечисления","ВидыДоговоровКонтрагентов","СКомиссионером") Тогда
								ОтборВидДоговора = Новый ПараметрВыбора("Отбор.ВидДоговора",ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));
								МассивПараметров.Добавить(ОтборВидДоговора);
							КонецЕсли;
							
						//2024.04.23 ( УНФ
						ИначеЕсли ТекСтрока.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
							Если РеквизитСуществует("Перечисления","ВидыДоговоров","СКомиссионером") Тогда
								ОтборВидДоговора = Новый ПараметрВыбора("Отбор.ВидДоговора",ПредопределенноеЗначение("Перечисление.ВидыДоговоров.СКомиссионером"));
								МассивПараметров.Добавить(ОтборВидДоговора);								
							КонецЕсли;
						// ) 2024.04.23
						
						КонецЕсли;
						
						Элементы.ЗагружаемыеОбъектыОбъект1с.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
						
					КонецЕсли;
				КонецЕсли;
					
				//Отбор при выборе банковского счета контрагента
				Если ТекСтрока.ТипОбъекта = "БанковскиеСчета" Тогда
							
					//Зададим параметры выбора для этого поля: организация и контрагент известны, если не заполнены - не даем выбрать
					НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД,ТипОбъекта",ТекСтрока.ДокументИД,"Контрагенты"));
					Если НайденныеСтроки.Количество() > 0 Тогда
						КонтрагентСсылка = НайденныеСтроки[0].Объект1с;
					КонецЕсли;
											
					Если ЗначениеЗаполнено(КонтрагентСсылка) Тогда
						
						ОтборВладелец = Новый ПараметрВыбора("Отбор.Владелец",КонтрагентСсылка);
						
						МассивПараметров = Новый Массив();
						МассивПараметров.Добавить(ОтборВладелец);
						
						Элементы.ЗагружаемыеОбъектыОбъект1с.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметров);
						
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			Элементы.ЗагружаемыеОбъектыОбъект1с.РежимРедактирования = РежимРедактирования;
			Элементы.ЗагружаемыеОбъектыОбъект1с.КнопкаВыпадающегоСписка = КнопкаВыпадающегоСписка;
			Элементы.ЗагружаемыеОбъектыОбъект1с.КнопкаСоздания = КнопкаСоздания;
			Элементы.ЗагружаемыеОбъектыОбъект1с.РедактированиеТекста = РедактированиеТекста;
			Элементы.ЗагружаемыеОбъектыОбъект1с.ИсторияВыбораПриВводе = ИсторияВыбора;
						
		КонецЕсли;
		// ) 2019.02.28
		
		//2020.10.07 (
		Элементы.ЗагружаемыеОбъектыОбъект1с.ТолькоПросмотр = ТекСтрока.ТипОбъекта = "Номенклатура" И НЕ ТекСтрока.Номенклатура_ТребуетсяСозданиеНоменклатуры = Истина;
		// ) 2020.10.07
		
		УстановитьОграничениеТипа_ЭлементТекущейСтроки(ТекСтрока);
		
		//Отображаем группа описания выбранного типа элемента
		Элементы.ГруппаОписаниеДокумент.Видимость = ТекСтрока.ТипОбъекта = "Документ";
		Элементы.ГруппаОписаниеНоменклатура.Видимость = ТекСтрока.ТипОбъекта = "Номенклатура";
		Элементы.ГруппаОписаниеОсновныеСредства.Видимость = ТекСтрока.ТипОбъекта = "ОсновныеСредства";
		Элементы.ГруппаОписаниеОрганизации.Видимость = ТекСтрока.ТипОбъекта = "Организации";
		Элементы.ГруппаОписаниеКонтрагенты.Видимость = ТекСтрока.ТипОбъекта = "Контрагенты";
		Элементы.ГруппаОписаниеДоговоры.Видимость = ТекСтрока.ТипОбъекта = "Договоры";
		Элементы.ГруппаОписаниеБанковскиеСчета.Видимость = ТекСтрока.ТипОбъекта = "БанковскиеСчета";
		Элементы.ГруппаОписаниеУпаковкиЕдиницыИзмерения.Видимость = ТекСтрока.ТипОбъекта = "УпаковкиЕдиницыИзмерения";
		Элементы.ГруппаОписаниеНомераГТД.Видимость = ТекСтрока.ТипОбъекта = "НомераГТД";
		Элементы.ГруппаОписаниеСтраныМира.Видимость = ТекСтрока.ТипОбъекта = "СтраныМира";
		Элементы.ГруппаОписаниеИсточникиПроисхождения.Видимость = ТекСтрока.ТипОбъекта = "ИсточникиПроисхождения";
		
		//Костылим отключение повторного выполнения ПриАктивацииСтроки,
		//которое срабатывает после изменения видимости элементов групп-описаний
		ИдентификаторТекущейСтроки = ТекСтрока.ПолучитьИдентификатор();
		
		//Показываем скан документа
		Если ПоказыватьСканДокумента Тогда
			СканДокумента_ПоказатьСканДокумента();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьВидимостьЭлементов_ДополнительноеОписаниеЭлемента() Экспорт
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Элементы.ГруппаОписаниеНоменклатура.Видимость = ТекСтрока.ТипОбъекта = "Номенклатура";
	Элементы.ГруппаОписаниеКонтрагенты.Видимость = ТекСтрока.ТипОбъекта = "Контрагенты";
	Элементы.ГруппаОписаниеБанковскиеСчета.Видимость = ТекСтрока.ТипОбъекта = "БанковскиеСчета";
	Элементы.ГруппаОписаниеУпаковкиЕдиницыИзмерения.Видимость = ТекСтрока.ТипОбъекта = "УпаковкиЕдиницыИзмерения";
	Элементы.ГруппаОписаниеНомераГТД.Видимость = ТекСтрока.ТипОбъекта = "НомераГТД";
	Элементы.ГруппаОписаниеСтраныМира.Видимость = ТекСтрока.ТипОбъекта = "СтраныМира";
КонецПроцедуры

&НаКлиенте
Процедура ЗагружаемыеОбъектыПриИзменении(Элемент)
	
	ТекСтрока = Элемент.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		
		Если Элемент.ТекущийЭлемент = Элементы.ЗагружаемыеОбъектыПредставлениеОбъекта Тогда
			//EN-225: Пользователю нельзя дать возможность изменив наименование создать дубль существующей номеклатуры
			//при изменении представления номенклатуры выполним ее поиск по наименованию
			Если ТекСтрока.ТипОбъекта = "Номенклатура" И ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
				Если Не ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
					//2024.04.17 ( Поиск по наименованию выполняем только если это предполагает настройка
					Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование,Артикул"
						Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование" Тогда
						// ) 2024.04.17
						ТекСтрока.Объект1с = ПолучитьСсылку_ОбъектПоНаименованию("Номенклатура",ТекСтрока.ПредставлениеОбъекта);
						ТекСтрока.СоответствиеУстановлено = ЗначениеЗаполнено(ТекСтрока.Объект1с);
						ТекСтрока.Пометка = Не ТекСтрока.СоответствиеУстановлено;
					КонецЕсли;
					
					//E1C-9: краткое наименование равно полному наименованию. Спросим у пользователя
					ДопПараметры = Новый Структура;
					ДопПараметры.Вставить("ТекСтрока",ТекСтрока);
					
					ТекстВопроса = "Установить это значение для поля <Полное наименование>?";
					Кнопки = РежимДиалогаВопрос.ДаНет;
					ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","Продолжить_УстановитьПолноеНаименованиеПоКраткому",ДопПараметры,ТекстВопроса,Кнопки);
					
					_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
				КонецЕсли;
				
				ТекСтрока.Номенклатура_ПредставлениеИзменено = Истина;
			КонецЕсли;
			
		ИначеЕсли Элемент.ТекущийЭлемент = Элементы.ЗагружаемыеОбъектыОбъект1с Тогда
		
			ТекСтрока.СоответствиеУстановлено = ЗначениеЗаполнено(ТекСтрока.Объект1с);
			ТекСтрока.СработавшийВариантПоиска = "РучнойВыбор";
			
			//2019.02.20 ( раз соответствие не установлено - устанавливаем флаг создания
			ТекСтрока.Пометка = Не ТекСтрока.СоответствиеУстановлено;
			// ) 2019.02.20
						
			//2019.02.15 ( сохраняем установленную пользователем связь номенклатуры поставщика и Номенклатуры
			Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
				Если СтруктураНастроек.Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия = Истина Тогда
					ТекстОповещения = ЗаписатьСоответствиеНоменклатуры(ТекСтрока.Объект1с,ТекСтрока.Номенклатура_Характеристика,ТекСтрока.ПредставлениеОбъекта,ТекСтрока.КонтрагентИД);
					ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
				КонецЕсли;
				
				УстановитьДополнительныеРеквизиты(ТекСтрока);
				
			ИначеЕсли ТекСтрока.ТипОбъекта = "Контрагенты" Тогда
				ТекстОповещения = ЗаписатьСоответствиеКонтрагента(ТекСтрока.Объект1с,ТекСтрока.Контрагенты_Наименование,ТекСтрока.Контрагенты_НаименованиеПолное);
				ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
			
				УстановитьДополнительныеРеквизиты(ТекСтрока);
				
				//2020.04.14 ( для конфигураций, предполагающих наличие справочника Партнеры нужно заполнить партнера при выборе контрагента
				Если РеквизитСуществует("Справочники","Контрагенты","Партнер") Тогда
					ТекСтрока.Контрагенты_Партнер = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,"Партнер");
				КонецЕсли;
				// ) 2020.04.14
				
			ИначеЕсли ТекСтрока.ТипОбъекта = "Организации" Тогда
				//Организация влияет на счет учета номенклатуры, поэтому перезаполним у строк номенклатуры этого документа счета учета
				СтруктураПоиска = Новый Структура("ТипОбъекта,ДокументИД","Номенклатура",ТекСтрока.ДокументИД);
				СтрокиНоменклатуры = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
				Для Каждого СтрокаНоменклатуры Из СтрокиНоменклатуры Цикл
					СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(СтрокаНоменклатуры,ТекСтрока.Объект1с);
				КонецЦикла;
				
			КонецЕсли;
			// ) 2019.02.15
			
			ЗаполнитьВсеСоответствующиеЗначения(ТекСтрока.ПолучитьИдентификатор());
			
			УстановитьОграничениеТипа_ЭлементТекущейСтроки(ТекСтрока);
			
		ИначеЕсли Элемент.ТекущийЭлемент = Элементы.ЗагружаемыеОбъектыДополнительноеОписаниеОбъекта Тогда
			Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
				СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(ТекСтрока);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("УстановитьОтборСтрокТаблицы",1,Истина);
	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьДополнительныеРеквизиты(ТекСтрока)
	
	Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
		
		Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаВидНоменклатуры) Тогда
				ТекСтрока.Номенклатура_ВидНоменклатуры = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаВидНоменклатуры);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаРодитель) Тогда
				ТекСтрока.Номенклатура_Родитель = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаРодитель);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаКатегория) Тогда
				ТекСтрока.Номенклатура_Категория = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаКатегория);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНаправлениеДеятельности) Тогда
				ТекСтрока.Номенклатура_НаправлениеДеятельности = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНаправлениеДеятельности);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаСтатьяЗатрат) Тогда
				ТекСтрока.Номенклатура_СтатьяЗатрат = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаСтатьяЗатрат);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаАртикул) Тогда
				ТекСтрока.Номенклатура_Артикул1с = ПолучитьЗначениеРеквизитаОбъекта(ТекСтрока.Объект1с,СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаАртикул);
			КонецЕсли;
			
			//E1C-66: отображаем счет учета, устанавливаемый по умолчанию для данной номенклатуры
			СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(ТекСтрока);
			
		Иначе
			Номенклатура_ЗаполнитьЗначенияПоУмолчанию(ТекСтрока);
			
		КонецЕсли;
		
		//Поищем связанную единицу измерения
		Если СтруктураНастроек.СведенияОКонфигурации.ЕдиницыИзмерения_ВладелецНоменклатура = Истина Тогда
			//пробуем найти существующую единицу измерения, пока под конфу, на которой это вызвало проблему
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БИТСтоматология"
				//2023.05.24 (
				Или СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Имя = "дсуУАТ" Тогда
				// ) 2023.05.24
				
				ДопПараметры = Новый Структура;
				ДопПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
				
				ТекСтрока.Номенклатура_ЕдиницаИзмерения = ПолучитьСсылку_УпаковкаЕдиницаИзмерения(ДопПараметры);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура Продолжить_УстановитьПолноеНаименованиеПоКраткому(Результат,ДопПараметры)
	Если Результат = КодВозвратаДиалога.Да Тогда
		ДопПараметры.ТекСтрока.Номенклатура_НаименованиеПолное = ДопПараметры.ТекСтрока.ПредставлениеОбъекта;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗагружаемыеОбъектыОбъект1сСоздание(Элемент, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		
		ТипОбъекта = ТекСтрока.ТипОбъекта;
		
		ПользовательскиеПараметрыЗаполнения = Новый Структура;
		
		Если ТекСтрока.ТипОбъекта = "БанковскиеСчета" Тогда
			//Справочник БанковскиеСчета в разных конфигурациях называется по-разному
			ТипОбъекта = СтруктураНастроек.СведенияОКонфигурации.Банк_ИмяСправочникаБанковскиеСчетаКонтрагентов;
			
			//передадим контрагента-владельца банковского счета
			НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ДокументИД,ТипОбъекта",ТекСтрока.ДокументИД,"Контрагенты"));
			Если НайденныеСтроки.Количество() > 0 И ЗначениеЗаполнено(НайденныеСтроки[0].Объект1с) Тогда
				ПараметрыОткрытияФормы = Новый Структура("Владелец",НайденныеСтроки[0].Объект1с);
			КонецЕсли;
			
		ИначеЕсли ТекСтрока.ТипОбъекта = "Договоры" Тогда
			ТипОбъекта = СтруктураНастроек.СведенияОКонфигурации.Договоры_ИмяСправочникаДоговорыКонтрагентов;
			
			//Для договора нужно передать потенциально измененные в форме сведения о договоре
			ПользовательскиеПараметрыЗаполнения.Вставить("Наименование",ТекСтрока.ПредставлениеОбъекта);
			ПользовательскиеПараметрыЗаполнения.Вставить("Номер",ТекСтрока.Договоры_Номер);
			ПользовательскиеПараметрыЗаполнения.Вставить("Дата",ТекСтрока.Договоры_Дата);
			
		ИначеЕсли ТекСтрока.ТипОбъекта = "ИсточникиПроисхождения" Тогда
			ТипОбъекта = "НомераГТД";
			
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ТипОбъекта) Тогда
			Возврат;
		КонецЕсли;
		
		СтандартнаяОбработка = Ложь;
		
		//делаем через заполнение нового объекта формы и КопироватьДанныеФормы()
		Попытка
			ФормаНовогоОбъекта = ПолучитьФорму("Справочник." + ТипОбъекта + ".ФормаОбъекта",ПараметрыОткрытияФормы,ЭтаФорма);
		Исключение
			
		КонецПопытки;
		
		Если ФормаНовогоОбъекта <> Неопределено Тогда
			
			//2019.06.25 ( Теперь пользователь может переопределить направление для каждого документа пакета
			СтрокиДокумента = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",ТекСтрока.ДокументИД));
			Если СтрокиДокумента.Количество() > 0 Тогда
				НаправлениеСоздаваемогоДокумента = СтрокиДокумента[0].НаправлениеСоздаваемогоДокумента;
			Иначе
				СообщитьСообщение("Внутренняя ошибка модуля: не удалось найти строку документа по идентификатору для определения направления документа");
			КонецЕсли;
						
			ОбъектФормы = ФормаНовогоОбъекта.Объект;
			
			ПараметрыЗаполнения = Новый Структура;
			ПараметрыЗаполнения.Вставить("ТипОбъекта",ТекСтрока.ТипОбъекта);
			ПараметрыЗаполнения.Вставить("ИдентификаторОбъекта",ТекСтрока.ИдентификаторОбъекта);
			ПараметрыЗаполнения.Вставить("ДополнительноеОписаниеОбъекта",ТекСтрока.ДополнительноеОписаниеОбъекта);
			ПараметрыЗаполнения.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
			ПараметрыЗаполнения.Вставить("ПользовательскиеПараметрыЗаполнения",ПользовательскиеПараметрыЗаполнения);
			
			СтруктураЗаполнения = ПредзаполнитьНовыйОбъект(ОбъектФормы,СтруктураНастроек,АдресХранилищаДанныхПортала,
				ТекСтрока.ДокументИД,ПараметрыЗаполнения);
			
			КопироватьДанныеФормы(ОбъектФормы,ФормаНовогоОбъекта.Объект);
			
			//У Далиона может присутствовать реквизит ЕдиницаИзмеренияОтчетов, который будучи скрытым, но предзаполненным при стандартной работе
			//не позволит записать заполняемы элемент справочника Номенклатура.
			Если СтруктураЗаполнения.Свойство("ЕдиницаИзмерения") Тогда
				СтруктураЗаполненияФормы = Новый Структура;
				СтруктураЗаполненияФормы.Вставить("ЕдиницаИзмеренияОтчетов",СтруктураЗаполнения.ЕдиницаИзмерения);
				ЗаполнитьЗначенияСвойств(ФормаНовогоОбъекта,СтруктураЗаполненияФормы);
			КонецЕсли;
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ТипОбъекта",ТекСтрока.ТипОбъекта);
			ДополнительныеПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
			ДополнительныеПараметры.Вставить("Форма",ФормаНовогоОбъекта);
			
			//Открываем форму нового объекта с предзаполненным объектом
			ФормаНовогоОбъекта.ОписаниеОповещенияОЗакрытии = Новый ОписаниеОповещения("ЗакрытиеФормыСозданияОбъекта",ЭтаФорма,ДополнительныеПараметры);
			
			ФормаНовогоОбъекта.Открыть();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ЗакрытиеФормыСозданияОбъекта(Результат,ДополнительныеПараметры) Экспорт
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
	
	//2022.01.20 ( На 8.3.18 и 8.3.20 у пользователей возникает ситуация при работе в тонком клиенте в базе, опубликованной на веб-сервере,
	//что Форма, переданная в дополнительных параметрах, возвращается Неопределено и ссылку на объект из нее не получить.
	//В БП30 ПриЗакрытии формы элемента Номенклатуры в ОписаниеОповещенияОЗакрытии.ДополнительныеПараметры помещается Объект.Ссылка
	//+++ Возможен еще вариант костыля: устанавливать новому заполняемому объекту ссылку и после закрытия формы проверять,
	//существует ли что-то с такой ссылкой в базе
	Если ДополнительныеПараметры.Форма = Неопределено Тогда
		Если ДополнительныеПараметры.ТипОбъекта = "Номенклатура"
			И ДополнительныеПараметры.Свойство("Номенклатура") Тогда
			ТекСтрока.Объект1с = ДополнительныеПараметры.Номенклатура;
			ТекСтрока.СоответствиеУстановлено = Истина;
		КонецЕсли;
		
	Иначе
	// ) 2022.01.20
	
		ОбъектСсылка = ДополнительныеПараметры.Форма.Объект.Ссылка;
		
		Если ТекСтрока <> Неопределено
			И ЗначениеЗаполнено(ОбъектСсылка) Тогда
			
			ТекСтрока.Объект1с = ОбъектСсылка;
			ТекСтрока.СоответствиеУстановлено = Истина;
				
			Если ТекСтрока.ТипОбъекта = "Контрагенты" Тогда
				Если РеквизитСуществует("Справочники","Контрагенты","Партнер") Тогда
					ТекСтрока.Контрагенты_Партнер = ПолучитьЗначениеРеквизитаОбъекта(ОбъектСсылка,"Партнер");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		//Платформа не отпускает объект
		ДополнительныеПараметры.Форма = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагружаемыеОбъектыПередНачаломИзменения(Элемент, Отказ)
		
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока.ТипОбъекта = "Документ" Тогда
		//Для аудитора: у создаваемого документа реквизиты редактируются в доп. описании в панели справа.
		//Но поскольку редактирование других типов создаваемых объектов разрешается в самом поле таблицы формы,
		//допустимость такого редактирования регулируется переменной Отказ. Выводить дополнительное уведомление пользователю
		//при каждом двойном клике в табличной части раздражает пользователя, так как это и так является для него очевидным.
		//Поэтому лишних уведомлений в этом условии выводить не предполагается.
		Отказ = Истина;
	
	//для Номенклатуры нужно позволить выбрать тип Товар/Услуга
	ИначеЕсли Элемент.ТекущийЭлемент = Элементы.ЗагружаемыеОбъектыДополнительноеОписаниеОбъекта Тогда
			
		Если ЗначениеЗаполнено(ТекСтрока.ДополнительноеОписание_СписокВыбора) Тогда
			
			СтандартнаяОбработка = Ложь;
			
			ДополнительныеПараметры = Новый Структура("ИдентификаторСтроки,ИсходноеЗначение",ТекСтрока.ПолучитьИдентификатор(),ТекСтрока.ДополнительноеОписаниеОбъекта);
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьВыборЗначенияИзСписка",ЭтаФорма,ДополнительныеПараметры);
			
			СписокВыбора = ЗначениеИзСтрокиВнутрСервер(ТекСтрока.ДополнительноеОписание_СписокВыбора);
			ПоказатьВыборИзМеню(ОписаниеОповещения,СписокВыбора);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборЗначенияИзСписка(Результат,ДополнительныеПараметры) Экспорт
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
	Если Результат = Неопределено Тогда
		ТекСтрока.ДополнительноеОписаниеОбъекта = ДополнительныеПараметры.ИсходноеЗначение;
		
	Иначе
		ТекСтрока.ДополнительноеОписаниеОбъекта = Результат.Значение;
		
		Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
			Если Не ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
				Номенклатура_ЗаполнитьЗначенияПоУмолчанию(ТекСтрока);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура Номенклатура_ЗаполнитьЗначенияПоУмолчанию(ТекСтрока)
	
	Если ТекСтрока.ДополнительноеОписаниеОбъекта = "Услуга" Тогда
		ТекСтрока.Номенклатура_ВидНоменклатуры = СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга;
		ТекСтрока.Номенклатура_Родитель = СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги;
		ТекСтрока.Номенклатура_НоменклатурнаяГруппа = СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга;
		ТекСтрока.Номенклатура_СчетУчета = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюУслуга;
		ТекСтрока.Номенклатура_СчетУчетаНДС = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаНДСПоУмолчаниюУслуга
		
	ИначеЕсли ТекСтрока.ДополнительноеОписаниеОбъекта = "Товар" Тогда
		ТекСтрока.Номенклатура_ВидНоменклатуры = СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар;
		ТекСтрока.Номенклатура_Родитель = СтруктураНастроек.Номенклатура_ГруппаСоздаваемойНоменклатуры;
		ТекСтрока.Номенклатура_НоменклатурнаяГруппа = СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар;
		ТекСтрока.Номенклатура_СчетУчета = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар;
		ТекСтрока.Номенклатура_СчетУчетаНДС = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаНДСПоУмолчаниюТовар;
		
	Иначе
		//Расходы
		ТекСтрока.Номенклатура_ВидНоменклатуры = Неопределено;
		ТекСтрока.Номенклатура_Родитель = Неопределено;
		ТекСтрока.Номенклатура_СчетУчета = Неопределено;
		ТекСтрока.Номенклатура_СчетУчетаНДС = Неопределено;
		
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура Флажки_УстановитьФлаг_ВсемДокументам(Команда)
	УстановитьСнятьФлажкиВТаблице(Истина,Истина);
КонецПроцедуры
&НаКлиенте
Процедура Флажки_УстановитьФлаг_ПустымДокументам(Команда)
	УстановитьСнятьФлажкиВТаблице(Истина,Ложь);
КонецПроцедуры
&НаКлиенте
Процедура Флажки_СнятьФлаг_ВсемДокументам(Команда)
	УстановитьСнятьФлажкиВТаблице(Ложь,Истина);
КонецПроцедуры
&НаКлиенте
Процедура Флажки_СнятьФлаг_ЗаполненнымДокументам(Команда)
	УстановитьСнятьФлажкиВТаблице(Ложь,Ложь);
КонецПроцедуры
&НаКлиенте
Процедура УстановитьСнятьФлажкиВТаблице(Флаг, ВсемДокументам = Истина)
	Для Каждого Строка Из Объект.ЗагружаемыеОбъекты Цикл 
		
		//Обрабатывать только видимые строки
		Если Не Элементы.ЗагружаемыеОбъекты.ПроверитьСтроку(Строка.ПолучитьИдентификатор()) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ВсемДокументам Тогда
			Строка.Пометка = Флаг;
		Иначе
			Если Флаг Тогда
				Строка.Пометка = Не ЗначениеЗаполнено(Строка.Объект1с);
			Иначе
				Строка.Пометка = Не ЗначениеЗаполнено(Строка.Объект1с) И Строка.Пометка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры


// ================= Отправка изменений номенклатуры на портал ===================

&НаКлиенте
Функция ОбновлениеДанныхДокументов_ОтправкаНаПортал()
	
	//PUT https://app.entera.pro/api/v1/documents/{{documentId}}/accept
	//{
	// "items": [
	// { "id": "{{itemId}}", "serialNumber": 1, "name": "Новое название" }
	// ]
	//}
	
	//Запросы могут выполняться на клиенте, по каждому документу нужно выполнить отдельный запрос.
	//Получаем список различных идентификаторов документов в форме сопоставления, поочередно по каждому пуляем запрос
	
	СписокДокументов = ОбновлениеДанныхДокументов_ПолучитьСписокИдентификаторовДокументов();
	Счетчик = 0;
	Для Каждого ЭлементСписка Из СписокДокументов Цикл
		
		ДокументИД = ЭлементСписка.Значение;
		
		Счетчик = Счетчик + 1;
		Прогресс = Счетчик / СписокДокументов.Количество() * 100;
		Состояние("Обновление данных документа на портале...",Прогресс,ЭлементСписка.Представление);
		
		ТелоЗапроса = ОбновлениеДанныхДокументов_СформироватьТелоЗапроса(ДокументИД);
		
		//отправляем запрос, обновляем данные документа
		МетодAPI = "/api/v1/documents/" + ДокументИД + "/accept?format=xml";
		РезультатЗапроса = ВладелецФормы.ВыполнитьЗапрос("ОбновлениеДанныхДокументов","PUT",МетодAPI,ТелоЗапроса);
		
		Если РезультатЗапроса.Успешно Тогда
			//
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = Строка(ЭлементСписка.Представление) + ": ошибка при обновлении данных портала" + Символы.ПС + РезультатЗапроса.ТекстОшибки;
			Сообщение.ИдентификаторНазначения = ВладелецФормы.УникальныйИдентификатор;
			Сообщение.Сообщить();
		КонецЕсли;
		
	КонецЦикла;
	
КонецФункции
&НаСервере
Функция ОбновлениеДанныхДокументов_СформироватьТелоЗапроса(ДокументИД)
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ТелоЗапроса = РеквизитОбъект.ОбновлениеДанныхДокументов_СформироватьТелоЗапроса_items(ДокументИД);
	
	Возврат ТелоЗапроса;
КонецФункции
&НаСервере
Функция ОбновлениеДанныхДокументов_ПолучитьСписокИдентификаторовДокументов()
	
	СписокДокументов = Новый СписокЗначений;
	
	//Нам нужны только строки номенклатуры
	НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,Номенклатура_ПредставлениеИзменено","Номенклатура",Истина));
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		
		ОбновлениеДанныхДокументов_ПеренестиИзмененияНоменклатурыВДанныеПортала(НайденныеСтроки);
		
		ТаблицаДокументов = Объект.ЗагружаемыеОбъекты.Выгрузить(НайденныеСтроки,"ДокументИД,ПредставлениеДокумента");
		ТаблицаДокументов.Свернуть("ДокументИД,ПредставлениеДокумента");
		
		Для Каждого СтрокаТаблицы Из ТаблицаДокументов Цикл
			СписокДокументов.Добавить(СтрокаТаблицы.ДокументИД,СтрокаТаблицы.ПредставлениеДокумента);
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат СписокДокументов;
	
КонецФункции
&НаСервере
Процедура ОбновлениеДанныхДокументов_ПеренестиИзмененияНоменклатурыВДанныеПортала(НайденныеСтроки)
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Для Каждого СтрокаТаблицы Из НайденныеСтроки Цикл
		ДанныеНоменклатурыПортала = ДанныеПортала.documentItems.Найти(СтрокаТаблицы.ИдентификаторОбъекта,"Id");
		ДанныеНоменклатурыПортала.name = СтрокаТаблицы.ПредставлениеОбъекта;
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
КонецПроцедуры


// ================= Создание элементов справочников по данным портала ===================

&НаКлиенте
Процедура СоздатьОбъекты(Команда)
	
	//E1C-158: проверка заполнения Организации документа: они не создаются и должны быть заполнены до создания документа
	ДокументыБезОрганизации = "";
	СтруктураПоиска = Новый Структура("ТипОбъекта","Организации");
	СтрокиОрганизации = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	
	Для Каждого СтрокаТаблицы Из СтрокиОрганизации Цикл
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Объект1с) Тогда
			ДокументыБезОрганизации = ДокументыБезОрганизации + Символы.ПС + СтрокаТаблицы.ПредставлениеДокумента;
			//Запомним идентификатор первого документа без организации, чтобы вывести сообщение к этой строке
			СтрокаБезОрганизаций = ?(СтрокаБезОрганизаций = Неопределено,Объект.ЗагружаемыеОбъекты.Индекс(СтрокаТаблицы),СтрокаБезОрганизаций);
		КонецЕсли;
	КонецЦикла;
	
	//E1C-258: Отключение подтверждающего окна "склад" для документов, где находятся только услуги
	//и для документов, где используется вообще не требуется склад. Общая для обоих интерфейсов функция в модуле объекта
	РезультатПроверки = КонтрольЗаполнения_Склады_НаСервере();
	
	ТекстСообщения = "";
	Если ЗначениеЗаполнено(ДокументыБезОрганизации) Тогда
		ТекстСообщения = "Необходимо выбрать Организацию в следующих документах:" + ДокументыБезОрганизации + Символы.ПС;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РезультатПроверки.ДокументыБезСклада) Тогда
		ТекстСообщения = ТекстСообщения + "Не выбран Склад в следующих документах:" + РезультатПроверки.ДокументыБезСклада;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ТекстСообщения) Тогда
		
		ДопПараметры = Новый Структура;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ТекстСообщения;
		
		Если ЗначениеЗаполнено(ДокументыБезОрганизации) Тогда
			Сообщение.Поле = "Объект.ЗагружаемыеОбъекты[" + СтрокаБезОрганизаций + "].Объект1с";
			Сообщение.Сообщить();
			Возврат;
		ИначеЕсли ЗначениеЗаполнено(РезультатПроверки.ДокументыБезСклада) Тогда
			Сообщение.Поле = "Объект.ЗагружаемыеОбъекты[" + РезультатПроверки.СтрокаБезСклада + "].ПредставлениеОбъекта";
			Сообщение.Сообщить();
			
			//Задаем вопрос, продолжать без склада, или нет
			ТекстВопроса = "В данных следующих документов не заполнен склад, продолжить?" + Символы.ПС + РезультатПроверки.ДокументыБезСклада;
			Кнопки = РежимДиалогаВопрос.ДаНет;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеОбъектов_НеЗаполненСклад",ДопПараметры,ТекстВопроса,Кнопки);
			
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		КонецЕсли;
	Иначе
		ПродолжитьСозданиеОбъектов_НеЗаполненСклад(КодВозвратаДиалога.Да,ДопПараметры);
	КонецЕсли;			
		
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеОбъектов_НеЗаполненСклад(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		//E1C-69: проверка на наличие ИНН контрагента для строк с незаполненной ссылкой Контрагента
		ДокументыБезИНН = "";
		СтрокиКонтрагентов = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта","Контрагенты"));
		
		Для Каждого СтрокаКонтрагента Из СтрокиКонтрагентов Цикл
			Если Не ЗначениеЗаполнено(СтрокаКонтрагента.Контрагенты_ИНН)
				И Не ЗначениеЗаполнено(СтрокаКонтрагента.Объект1с) Тогда
				ДокументыБезИНН = ДокументыБезИНН + Символы.ПС + СтрокаКонтрагента.ПредставлениеДокумента;
			КонецЕсли;
		КонецЦикла;
		
		ДопПараметры = Новый Структура;
		
		Если ДокументыБезИНН = "" Тогда
			ПродолжитьСозданиеОбъектов_КонтрольИНН_Контрагентов(КодВозвратаДиалога.Да,ДопПараметры);
			
		Иначе
			ТекстВопроса = "В данных следующих документов отсутствует ИНН контрагентов, создать новых контрагентов без ИНН?" + ДокументыБезИНН;
			Кнопки = РежимДиалогаВопрос.ДаНетОтмена;
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ПродолжитьСозданиеОбъектов_КонтрольИНН_Контрагентов",ДопПараметры,ТекстВопроса,Кнопки);
			
			_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ПродолжитьСозданиеОбъектов_КонтрольИНН_Контрагентов(Результат,ДопПараметры)
	
	Если Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	Иначе
		СоздаватьКонтрагентовБезИНН = Результат = КодВозвратаДиалога.Да;
	КонецЕсли;
	
	ПараметрыСозданияОбъектов = Новый Структура;
	ПараметрыСозданияОбъектов.Вставить("СоздаватьКонтрагентовБезИНН",СоздаватьКонтрагентовБезИНН);
	
	РезультатСозданияДокументов = СоздатьОбъектыНаСервере(ПараметрыСозданияОбъектов);
	
	Если РезультатСозданияДокументов.Успешно Тогда
		
		//Переходим к заполнению документов
		РезультатСозданияДокументов.Вставить("ДопПараметры",ДополнительныеПараметрыФормы);
		
		//Обновим данные объекта формы-владельца (в частности, протокол работы)
		КопироватьДанныеФормы(ЭтаФорма.Объект,ВладелецФормы.Объект);
		
		ЭтаФорма.Закрыть(РезультатСозданияДокументов);
		// ) 2021.06.08
		
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = РезультатСозданияДокументов.ТекстОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция СоздатьОбъектыНаСервере(ПараметрыСозданияОбъектов)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	Результат = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	// ( модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ЗагружаемыеОбъекты",Объект.ЗагружаемыеОбъекты);
	ПараметрыМК.Вставить("Отказ",Ложь);
	ПараметрыМК.Вставить("ПричинаОтказа","");
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_ПередСозданиемОбъектов",ПараметрыМК);
	
	Если ПараметрыМК.Отказ = Истина Тогда
		Результат.Успешно = Ложь;
		Результат.ТекстОшибки = ПараметрыМК.ПричинаОтказа;
		Возврат Результат;
	КонецЕсли;
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	
		ОбщийТекстОшибки = "";
		
		Для Каждого СтрокаОбъекта Из Объект.ЗагружаемыеОбъекты Цикл
			
			ТекстОшибки = "";
			
			ИдентификаторСтроки = СтрокаОбъекта.ПолучитьИдентификатор();
			
			ДанныеДокументаПортала = ДанныеПортала.documents.Найти(СтрокаОбъекта.ДокументИД,"id");
			ДанныеНоменклатурыПортала = ДанныеПортала.documentItems.Найти(СтрокаОбъекта.ИдентификаторОбъекта,"Id");
			
			//2019.06.25 ( Теперь пользователь может переопределить направление для каждого документа пакета
			СтрокиДокумента = Объект.СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтрокаОбъекта.ДокументИД));
			Если СтрокиДокумента.Количество() > 0 Тогда
				НаправлениеСоздаваемогоДокумента = СтрокиДокумента[0].НаправлениеСоздаваемогоДокумента;
			Иначе
				СообщитьСообщение("Внутренняя ошибка модуля: не удалось найти строку документа по идентификатору для определения направления документа");
			КонецЕсли;
			
			//+++ Переделать получение структуры заполнения объекта на функцию ПолучитьСтруктуруЗаполненияНовогоОбъекта()
			
			ОбъектСоздан = Ложь;
			Если СтрокаОбъекта.ТипОбъекта = "Документ" Тогда
				ДанныеДокументаПортала.number = СтрокаОбъекта.Документ_Номер;
				ДанныеДокументаПортала.date = СтрокаОбъекта.Документ_Дата;
				ДанныеДокументаПортала.ДатаДокумента = СтрокаОбъекта.Документ_ДатаСоздаваемогоДокумента;
				ДанныеДокументаПортала.СкладСсылка = СтрокаОбъекта.Документ_Склад;
				ДанныеДокументаПортала.ПодразделениеСсылка = СтрокаОбъекта.Документ_Подразделение;
				ДанныеДокументаПортала.ПодразделениеОрганизацииСсылка = СтрокаОбъекта.Документ_ПодразделениеОрганизации;
				ДанныеДокументаПортала.ИФОСсылка = СтрокаОбъекта.Документ_ИФО;
				ДанныеДокументаПортала.ПодотчетноеЛицоСсылка = СтрокаОбъекта.Документ_ПодотчетноеЛицо;
				ДанныеДокументаПортала.НоменклатурнаяГруппаСсылка = СтрокаОбъекта.Документ_НоменклатурнаяГруппа;
				ДанныеДокументаПортала.НаправлениеДеятельностиСсылка = СтрокаОбъекта.Документ_НаправлениеДеятельности;
				ДанныеДокументаПортала.ОбъектРасчетовСсылка = СтрокаОбъекта.Документ_ОбъектРасчетов;
				ДанныеДокументаПортала.ВидОперацииСсылка = СтрокаОбъекта.Документ_ВидОперации;
				ДанныеДокументаПортала.ИмяТабличнойЧасти = СтрокаОбъекта.Документ_ИмяТабличнойЧасти;
				ДанныеДокументаПортала.НазначениеАванса = СтрокаОбъекта.Документ_НазначениеАванса;
				ДанныеДокументаПортала.НазначениеПлатежа = СтрокаОбъекта.Документ_НазначениеПлатежа;
				ДанныеДокументаПортала.ОригиналПолучен = СтрокаОбъекта.Документ_ОригиналПолучен;
				ДанныеДокументаПортала.ДокументОснованиеСсылка = СтрокаОбъекта.Документ_ДокументОснование;
				ДанныеДокументаПортала.ДокументыПоступленияДляДопРасходов = СтрокаОбъекта.Документ_ДокументыПоступленияДляДопРасходов;
				ДанныеДокументаПортала.СодержаниеУслугиДляДопРасходов = СтрокаОбъекта.Документ_СодержаниеУслугиДляДопРасходов;
				ДанныеДокументаПортала.ВедетсяУчетПредметовАренды = СтрокаОбъекта.Документ_ВедетсяУчетПредметовАренды;
			
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "Организации" Тогда
				
				//Организации не создаем, только позволяем выбирать
			    Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
					ДанныеДокументаПортала.ПлательщикСсылка = СтрокаОбъекта.Объект1с;
				Иначе
					ДанныеДокументаПортала.ПоставщикСсылка = СтрокаОбъекта.Объект1с;
				КонецЕсли;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "Контрагенты" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
					
					СтруктураЗаполнения = Новый Структура("Наименование,НаименованиеПолное,ИНН,КПП",СтрокаОбъекта.Контрагенты_Наименование,СтрокаОбъекта.Контрагенты_НаименованиеПолное,СтрокаОбъекта.Контрагенты_ИНН,СтрокаОбъекта.Контрагенты_КПП);
					СтруктураЗаполнения.Вставить("СсылкаНовогоОбъекта",СтрокаОбъекта.СсылкаНовогоОбъекта);
					СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
					СтруктураЗаполнения.Вставить("ДокументТип",СтрокаОбъекта.ДокументТип);
					
					Наименование = ?(ЗначениеЗаполнено(СтруктураЗаполнения.Наименование),СтруктураЗаполнения.Наименование,СтруктураЗаполнения.НаименованиеПолное);
					Если ЗначениеЗаполнено(Наименование) Тогда //совсем без наименования, наверное, не стоит создавать?
						
						Если СтрокаОбъекта.Пометка = Истина Тогда
							//2020.05.12 (
							Если Не ЗначениеЗаполнено(СтруктураЗаполнения.ИНН) И ПараметрыСозданияОбъектов.СоздаватьКонтрагентовБезИНН = Ложь Тогда
								//пропускаем
							Иначе
							// ) 2020.05.12
								СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_Контрагент(СтруктураЗаполнения,ТекстОшибки);
								ОбъектСоздан = ЗначениеЗаполнено(СтрокаОбъекта.Объект1с);
							КонецЕсли;
						КонецЕсли;
						
					КонецЕсли;
				КонецЕсли;
				
				Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
					ДанныеДокументаПортала.ПоставщикСсылка = СтрокаОбъекта.Объект1с;
					ОрганизацияСсылка = ДанныеДокументаПортала.ПлательщикСсылка;
				Иначе
					ДанныеДокументаПортала.ПлательщикСсылка = СтрокаОбъекта.Объект1с;
					ОрганизацияСсылка = ДанныеДокументаПортала.ПоставщикСсылка;
				КонецЕсли;
				
				Если РеквизитСуществует("Справочники","Контрагенты","Партнер") Тогда
					Если ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
						ДанныеДокументаПортала.ПартнерСсылка = СтрокаОбъекта.Объект1с.Партнер;
					КонецЕсли;
					Если Не ЗначениеЗаполнено(СтрокаОбъекта.Контрагенты_Партнер) Тогда
						СтрокаОбъекта.Контрагенты_Партнер = ДанныеДокументаПортала.ПартнерСсылка;
					КонецЕсли;
				КонецЕсли;
				
				ДанныеДокументаПортала.СоглашениеСсылка = СтрокаОбъекта.Контрагенты_Соглашение;
				
				//Договор может быть выбран в форме пользователем, его еще нет в данных документа портала
				СтрокаДоговора = Неопределено;
				СтрокиДоговора = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Договоры",СтрокаОбъекта.ДокументИД));
				Если СтрокиДоговора.Количество() > 0 Тогда
					СтрокаДоговора = СтрокиДоговора[0];
				КонецЕсли; 
				
				//2018.12.13 (			
				Если СтруктураНастроек.ЗаполнениеШапки_СоздаватьДоговор = Истина
					И ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) И ЗначениеЗаполнено(ОрганизацияСсылка)
					И (ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора)
						Или СтрокаДоговора <> Неопределено И ЗначениеЗаполнено(СтрокаДоговора.ПредставлениеОбъекта)) Тогда
					
					Если СтрокаДоговора <> Неопределено Тогда
						//2025.05.15 ( Ниже сохранен исходный вариант
						Если Истина Тогда
							ДанныеДокументаПортала.ДоговорСсылка = СтрокаДоговора.Объект1с;
						Иначе
						// ) 2025.05.15
							Если ЗначениеЗаполнено(СтрокиДоговора[0].Объект1с) Тогда
								ДанныеДокументаПортала.ДоговорСсылка = СтрокаДоговора.Объект1с;
							КонецЕсли;
						КонецЕсли;
						НаименованиеДоговора = СтрокаДоговора.ПредставлениеОбъекта;
					Иначе
						НаименованиеДоговора = Неопределено;
					КонецЕсли;
					
					//Проверим найденный договор, если он с другой организацией - он нам не подходит
					Если ЗначениеЗаполнено(ДанныеДокументаПортала.ДоговорСсылка)
						И ДанныеДокументаПортала.ДоговорСсылка.Организация <> ОрганизацияСсылка Тогда
						ДанныеДокументаПортала.ДоговорСсылка = Неопределено;
					КонецЕсли;
					
					Если Не ЗначениеЗаполнено(ДанныеДокументаПортала.ДоговорСсылка) Тогда
						//2025.07.21 ( Задача 305690: убираем логику поиска существующего договора: если строка "красная" - создаем договор
						Если Ложь Тогда
							//Сперва поискать договор между этой организацией и контрагентом перед созданием
							ДанныеДокументаПортала.ДоговорСсылка = РеквизитОбъект.ПолучитьСсылку_Договор(ДанныеДокументаПортала,НаправлениеСоздаваемогоДокумента,СтруктураНастроек);
						КонецЕсли;
						
						//Если не нашли - создаем новый
						Если Не ЗначениеЗаполнено(ДанныеДокументаПортала.ДоговорСсылка)
							//2020.07.30 ( У документа может отсутствовать этот реквизит, не создаем договор
							И Не ДанныеДокументаПортала.ДоговорНеТребуется = Истина Тогда
							// ) 2020.07.30				
							
							НаименованиеДоговора = ?(ЗначениеЗаполнено(НаименованиеДоговора),НаименованиеДоговора,СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора);
							СтруктураЗаполнения = Новый Структура("Наименование,Контрагент,Организация",НаименованиеДоговора,СтрокаОбъекта.Объект1с,ОрганизацияСсылка);
							
							Если Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
								СтруктураЗаполнения.Вставить("Партнер",СтрокаОбъекта.Объект1с.Партнер);
							КонецЕсли;
							
							//Добавляем для заполнения реквизиты Договоров
							Если СтрокаДоговора <> Неопределено Тогда
								СтруктураЗаполнения.Вставить("Наименование",СтрокаДоговора.ПредставлениеОбъекта);
								СтруктураЗаполнения.Вставить("Номер",СтрокаДоговора.Договоры_Номер);								
								СтруктураЗаполнения.Вставить("Дата",СтрокаДоговора.Договоры_Дата);
								
								СтруктураЗаполнения.Вставить("НомерДоговора",СтрокаДоговора.Договоры_Номер);								
								СтруктураЗаполнения.Вставить("ДатаДоговора",СтрокаДоговора.Договоры_Дата);
								
								СтруктураЗаполнения.Вставить("Подразделение",СтрокаДоговора.Договоры_Подразделение);
								СтруктураЗаполнения.Вставить("НаправлениеДеятельности",СтрокаДоговора.Договоры_НаправлениеДеятельности);
								СтруктураЗаполнения.Вставить("СтатьяДвиженияДенежныхСредств",СтрокаДоговора.Договоры_СтатьяДДС);
							КонецЕсли;
														
							ПараметрыЗаполнения = Новый Структура;
							ПараметрыЗаполнения.Вставить("ТипСоздаваемогоДокумента",СтрокаОбъекта.ТипСоздаваемогоДокумента);
							ПараметрыЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
							
							ДанныеДокументаПортала.ДоговорСсылка = СоздатьЭлементСправочника_Договор(СтруктураЗаполнения,ПараметрыЗаполнения,ТекстОшибки);
							
							Если ЗначениеЗаполнено(ДанныеДокументаПортала.ДоговорСсылка) Тогда
								
								//Установим этот договор строкам с совпадающими поставщиками/плательщиками
								Для Каждого СтрокаДанных Из ДанныеПортала.documents Цикл
									
									Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
										
										Если СтрокаДанных.supplierId = СтрокаОбъекта.ИдентификаторОбъекта //Поставщики совпадают
											И СтрокаДанных.ПлательщикСсылка = ДанныеДокументаПортала.ПлательщикСсылка Тогда //Плательщики совпадают
											СтрокаДанных.ДоговорСсылка = ДанныеДокументаПортала.ДоговорСсылка;
										КонецЕсли;
										
									Иначе
										
										Если СтрокаДанных.customerId = СтрокаОбъекта.ИдентификаторОбъекта //Плательщики совпадают
											И СтрокаДанных.ПоставщикСсылка = ДанныеДокументаПортала.ПоставщикСсылка Тогда //Плательщики совпадают
											СтрокаДанных.ДоговорСсылка = ДанныеДокументаПортала.ДоговорСсылка;
										КонецЕсли;
										
									КонецЕсли;
									
								КонецЦикла;
								
								//Созданный обработкой договор сделаем основным, чтобы в дальнейшем при наличии других договоров можно было использовать его
								МодульРаботыВБезопасномРежиме = РеквизитОбъект._ЗФ_ПолучитьОбщийМодульКонфигурации("РаботаВБезопасномРежиме");
								
								Если МодульРаботыВБезопасномРежиме <> Неопределено Тогда
									
									Если Конф = "БП30" Тогда
										
										Если Метаданные.ОбщиеМодули.Найти("РаботаСДоговорамиКонтрагентовБП") <> Неопределено Тогда
											
											ПараметрыВыполнения = Новый Структура;
											ПараметрыВыполнения.Вставить("ДоговорСсылка",ДанныеДокументаПортала.ДоговорСсылка);
											
											Попытка
												МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("РаботаСДоговорамиКонтрагентовБП.УстановитьОсновнойДоговорКонтрагента(Параметры.ДоговорСсылка)",ПараметрыВыполнения);
											Исключение
												
											КонецПопытки;
											
										КонецЕсли;
										
									КонецЕсли;
								КонецЕсли;
								
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;	
				// ) 2018.12.13
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "Договоры" И ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
				ДанныеДокументаПортала.ДоговорСсылка = СтрокаОбъекта.Объект1с;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "БанковскиеСчета" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
					
					СтруктураЗаполнения = Новый Структура("БИК,НаименованиеБанка,НомерСчета",СтрокаОбъекта.БанковскиеСчета_БИК,СтрокаОбъекта.БанковскиеСчета_НаименованиеБанка,СтрокаОбъекта.БанковскиеСчета_НомерСчета);
					СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
					
					Если ЗначениеЗаполнено(ДанныеДокументаПортала.ПоставщикСсылка) Тогда
						ВладелецБанковскогоСчета = ДанныеДокументаПортала.ПоставщикСсылка;
						
					Иначе
						ВладелецБанковскогоСчета = Справочники.Контрагенты.ПолучитьСсылку();
						СтрокаОбъекта.СсылкаНовогоОбъекта = ВладелецБанковскогоСчета;
					КонецЕсли;
					
					СтруктураЗаполнения.Вставить("Владелец",ВладелецБанковскогоСчета);
					
					СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_БанковскийСчет(СтруктураЗаполнения,ТекстОшибки);
					
				КонецЕсли;
				ДанныеДокументаПортала.БанковскийСчетКонтрагентаСсылка = СтрокаОбъекта.Объект1с;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "ОсновныеСредства" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
					
					СтруктураЗаполнения = Новый Структура("ИдентификаторСтроки,Наименование",ИдентификаторСтроки,СтрокаОбъекта.ПредставлениеОбъекта);
					СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_ОсновноеСредство(СтруктураЗаполнения,ТекстОшибки);
					
				КонецЕсли;
				ДанныеНоменклатурыПортала.ОсновноеСредствоСсылка = СтрокаОбъекта.Объект1с;	
				ДанныеНоменклатурыПортала.ИнвентарныйНомер = СтрокаОбъекта.ОсновныеСредства_ИнвентарныйНомер;
				ДанныеНоменклатурыПортала.СрокСлужбы = СтрокаОбъекта.ОсновныеСредства_СрокСлужбы;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "Номенклатура" Тогда
							
				Если СтрокаОбъекта.ДополнительноеОписаниеОбъекта = "Расходы" Тогда
					//Для этой строки не создаем номенклатуру, так как сумма этой строки будет перенесена в документ поступления доп. расходов
					ПеренестиНаДопРасходы = Истина;
					
				Иначе
					ПеренестиНаДопРасходы = Ложь;
				
					//2022.07.18 ( Создаем номенклатуру поставщика, даже если пользователь выбрал для Номенклатуры сопоставление вручную
					Если СтрокаОбъекта.Номенклатура_ТребуетсяСозданиеНоменклатуры Тогда
					// ) 2022.07.18
						
						//Если используется работа со справочником НоменклатураПоставщиков, номенклатура может быть получена оттуда
						Если ПоискПоНоменклатуреПоставщиков Тогда
							Если ЗначениеЗаполнено(СтрокаОбъекта.Номенклатура_НоменклатураПоставщика) Тогда
								Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
									СтрокаОбъекта.Объект1с = СтрокаОбъекта.Номенклатура_НоменклатураПоставщика.Номенклатура;
								КонецЕсли;
							Иначе
								Если ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
									НоваяНоменклатураСсылка = СтрокаОбъекта.Объект1с;
									
								ИначеЕсли ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_СсылкаДляНовойНоменклатурыПоставщика) Тогда
									НоваяНоменклатураСсылка = СтруктураНастроек.Номенклатура_СсылкаДляНовойНоменклатурыПоставщика;
									СтрокаОбъекта.Объект1с = НоваяНоменклатураСсылка;
									
								Иначе
									НоваяНоменклатураСсылка = Справочники.Номенклатура.ПолучитьСсылку();									
									СтрокаОбъекта.СсылкаНовогоОбъекта = НоваяНоменклатураСсылка;
								КонецЕсли;
								
								//Создаем элемент справочника НоменклатураПоставщиков, в качестве ссылки на номенклатуру указываем сформированную ссылку нового
								СтруктураЗаполнения = Новый Структура("ИдентификаторСтроки,Наименование,Упаковка,Номенклатура",ИдентификаторСтроки,СтрокаОбъекта.ПредставлениеОбъекта,СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения,НоваяНоменклатураСсылка);
								
								//В справочнике НоменклатураКонтрагентов расширен набор реквизитов элемента
								СтруктураЗаполнения.Вставить("НаименованиеУпаковки",ДанныеНоменклатурыПортала.unitName);
								СтруктураЗаполнения.Вставить("КодОКЕИБазовойЕдиницыИзмерения",ДанныеНоменклатурыПортала.unitCode);
								СтруктураЗаполнения.Вставить("НаименованиеБазовойЕдиницыИзмерения",ДанныеНоменклатурыПортала.unitName);
								СтруктураЗаполнения.Вставить("КоличествоУпаковок",1);
								СтруктураЗаполнения.Вставить("КоличествоБазовойЕдиницыИзмерения",1);
								СтруктураЗаполнения.Вставить("СтавкаНДС",ДанныеНоменклатурыПортала.СтавкаНДССсылка);
								СтруктураЗаполнения.Вставить("НаименованиеНоменклатуры",СтрокаОбъекта.ПредставлениеОбъекта);
								СтруктураЗаполнения.Вставить("НаименованиеПолное",СтрокаОбъекта.ПредставлениеОбъекта);
								
								СтруктураЗаполнения.Вставить("Характеристика",СтрокаОбъекта.Номенклатура_Характеристика);
								СтруктураЗаполнения.Вставить("НаименованиеХарактеристики",Строка(СтрокаОбъекта.Номенклатура_Характеристика));
								
								СтрокаОбъекта.Номенклатура_НоменклатураПоставщика = СоздатьЭлементСправочника_НоменклатураПоставщика(СтруктураЗаполнения,ТекстОшибки);
								
								Если ЗначениеЗаполнено(СтрокаОбъекта.Номенклатура_НоменклатураПоставщика)
									И Не РеквизитОбъект.ОбъектНеНайден(СтрокаОбъекта.Номенклатура_НоменклатураПоставщика.Номенклатура) Тогда
									//Ссылка на номенклатуру могла быть установлена в модуле кастомизации при заполнении Номенклатуры поставщика
									СтрокаОбъекта.Объект1с = СтрокаОбъекта.Номенклатура_НоменклатураПоставщика.Номенклатура;
									СтрокаОбъекта.СсылкаНовогоОбъекта = СтрокаОбъекта.Объект1с;
								КонецЕсли;
									
							КонецЕсли;
						КонецЕсли;
						
						Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
							//2019.05.15 ( EN-229: По настройке выполним поиск номенклатуры по заданному алгоритму
							ДанныеНоменклатурыПортала.name = СтрокаОбъекта.ПредставлениеОбъекта;
							//+++ код-артикул тоже перенести в ДанныеНоменклатурыПортала.nomenclatureCode?
							
							//2020.03.04 ( E1C-23: Не создавать новую номенклатуру если есть точное совпадение по наименованию,
							//При поиске по Номенклатуре контрагентов настройка должна игнорироваться?
							Если Не ПоискПоНоменклатуреПоставщиков И СтруктураНастроек.Номенклатура_НеСоздаватьЕслиЕстьПолноеСовпадениеПоНаименованию = Истина Тогда
								СтрокаОбъекта.Объект1с = РеквизитОбъект.ПолучитьСсылку_НоменклатураПоЗаданномуАлгоритмуПоиска(ДанныеНоменклатурыПортала,ДанныеДокументаПортала,СтруктураНастроек);
							КонецЕсли;
							// ) 2020.03.04
							
							Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с)
								Или РеквизитОбъект.ОбъектНеНайден(СтрокаОбъекта.Объект1с) Тогда
							// ) 2019.05.15
								
								Если Не ЗначениеЗаполнено(СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения) Тогда
									
									//Пробуем найти созданную ранее
									СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения = РеквизитОбъект.ПолучитьСсылку_УпаковкаЕдиницаИзмерения(ДанныеНоменклатурыПортала,СтруктураНастроек);
									
									Если Не ЗначениеЗаполнено(СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения) Тогда
										
										КодЕИДляПоиска = ?(ЗначениеЗаполнено(ДанныеНоменклатурыПортала.unitCode),ДанныеНоменклатурыПортала.unitCode,ДанныеНоменклатурыПортала.recognizedUnitCode);
										СтруктураЕдиницыИзмерения = Новый Структура("Код,Наименование",КодЕИДляПоиска,ДанныеНоменклатурыПортала.userUnitName);
										
										СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения = СоздатьЭлементСправочника_ЕдиницаИзмерения(СтруктураЕдиницыИзмерения,ТекстОшибки);
										
									КонецЕсли;
								КонецЕсли;
								
								СтрокиГТД = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ИдентификаторОбъекта","НомераГТД",СтрокаОбъекта.ИдентификаторОбъекта));
								ВестиУчетПоГТД = СтрокиГТД.Количество() > 0 И ЗначениеЗаполнено(ДанныеНоменклатурыПортала.recognizedCustomsDeclaration);
												
								СтруктураЗаполнения = Новый Структура("ИдентификаторСтроки,Наименование,СтавкаНДС,ВестиУчетПоГТД,СсылкаНовогоОбъекта",ИдентификаторСтроки,СтрокаОбъекта.ПредставлениеОбъекта,ДанныеНоменклатурыПортала.СтавкаНДССсылка,ВестиУчетПоГТД,СтрокаОбъекта.СсылкаНовогоОбъекта);
								СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
								СтруктураЗаполнения.Вставить("ДанныеНоменклатурыПортала",ДанныеНоменклатурыПортала);
								
								Если СтрокаОбъекта.Пометка = Истина Тогда
									СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_Номенклатура(СтруктураЗаполнения,СтрокаОбъекта.ДополнительноеОписаниеОбъекта,ТекстОшибки);
									ОбъектСоздан = ЗначениеЗаполнено(СтрокаОбъекта.Объект1с);
								КонецЕсли;
								
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;			
				ДанныеНоменклатурыПортала.НоменклатураСсылка = СтрокаОбъекта.Объект1с;
				ДанныеНоменклатурыПортала.name = СтрокаОбъекта.Номенклатура_НаименованиеПолное;
				ДанныеНоменклатурыПортала.ЕдиницаИзмеренияСсылка = СтрокаОбъекта.Номенклатура_ЕдиницаИзмерения;
				
				ДанныеНоменклатурыПортала.СчетУчетаСсылка = СтрокаОбъекта.Номенклатура_СчетУчета;
				ДанныеНоменклатурыПортала.СчетУчетаНДССсылка = СтрокаОбъекта.Номенклатура_СчетУчетаНДС;
				ДанныеНоменклатурыПортала.СтатьяЗатратСсылка = СтрокаОбъекта.Номенклатура_СтатьяЗатрат;
				ДанныеНоменклатурыПортала.НоменклатурнаяГруппаСсылка = СтрокаОбъекта.Номенклатура_НоменклатурнаяГруппа;
				ДанныеНоменклатурыПортала.ПодразделениеЗатратСсылка = СтрокаОбъекта.Номенклатура_ПодразделениеЗатрат;
				ДанныеНоменклатурыПортала.ОбъектСсылка = СтрокаОбъекта.Номенклатура_Объект;
				ДанныеНоменклатурыПортала.СпособУчетаНДС = СтрокаОбъекта.Номенклатура_СпособУчетаНДС;			
				ДанныеНоменклатурыПортала.СтатьяРасходовСсылка = СтрокаОбъекта.Номенклатура_СтатьяРасходов;
				ДанныеНоменклатурыПортала.АналитикаРасходовСсылка = СтрокаОбъекта.Номенклатура_АналитикаРасходов;
				ДанныеНоменклатурыПортала.СтатьяДоходовСсылка = СтрокаОбъекта.Номенклатура_СтатьяДоходов;				
				
				ДанныеНоменклатурыПортала.КПССсылка = СтрокаОбъекта.Номенклатура_КПС;
				ДанныеНоменклатурыПортала.КФОСсылка = СтрокаОбъекта.Номенклатура_КФО;
				ДанныеНоменклатурыПортала.КЭКСсылка = СтрокаОбъекта.Номенклатура_КЭК;
				
				ДанныеНоменклатурыПортала.ХарактеристикаСсылка = СтрокаОбъекта.Номенклатура_Характеристика;
				ДанныеНоменклатурыПортала.НоменклатураПоставщикаСсылка = СтрокаОбъекта.Номенклатура_НоменклатураПоставщика;
				
				ДанныеНоменклатурыПортала.КоэффициентПересчета = СтрокаОбъекта.Номенклатура_КоэффициентПересчета;
				ДанныеНоменклатурыПортала.ПеренестиНаДопРасходы = ПеренестиНаДопРасходы;
				ДанныеНоменклатурыПортала.Направление = НаправлениеСоздаваемогоДокумента;
				
				//+++ Пока убрал: для переноса в субконто при заполнении документа
				Если Ложь Тогда
					ДанныеНоменклатурыПортала.СкладСсылка = ДанныеДокументаПортала.СкладСсылка;
				КонецЕсли;
				
				ДанныеНоменклатурыПортала.НДСВидПоступленияСсылка = СтрокаОбъекта.Номенклатура_НДСВидПоступления;
				
				//E1C-257: Агентские услуги
				ДанныеНоменклатурыПортала.ЭтоАгентскаяУслуга = СтрокаОбъекта.ДополнительноеОписаниеОбъекта = "АгентскиеУслуги";
				ДанныеНоменклатурыПортала.КомитентСсылка = СтрокаОбъекта.Номенклатура_Комитент;
				ДанныеНоменклатурыПортала.ДоговорКомитентаСсылка = СтрокаОбъекта.Номенклатура_ДоговорКомитента;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "НомераГТД" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
					
					//2019.11.19 ( В УТ11 СтранаПроисхождения в реквизите справочника НомерГТД, обязательна к заполнению
					НомерГТД_СтранаМира = Неопределено;
					НайденныеСтроки = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ИдентификаторОбъекта","СтраныМира",СтрокаОбъекта.ИдентификаторОбъекта));
					Если НайденныеСтроки.Количество() > 0 Тогда
						НайденнаяСтрока = НайденныеСтроки[0];
						Если ЗначениеЗаполнено(НайденнаяСтрока.Объект1с) Тогда
							НомерГТД_СтранаМира = НайденнаяСтрока.Объект1с;
						Иначе
							СтруктураЗаполнения = Новый Структура("Код,Наименование",ДанныеНоменклатурыПортала.recognizedCountryCode,ДанныеНоменклатурыПортала.recognizedCountryShortName);
							СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
							
							НомерГТД_СтранаМира = СоздатьЭлементСправочника_СтранаМира(СтруктураЗаполнения,ТекстОшибки);
							НайденнаяСтрока.Объект1с = НомерГТД_СтранаМира;
							
							НайденнаяСтрока.СоответствиеУстановлено = Истина;
							ЗаполнитьВсеСоответствующиеЗначения(НайденнаяСтрока.ПолучитьИдентификатор());
						КонецЕсли;
					КонецЕсли;
					// ) 2019.11.19
					
					СтруктураЗаполнения = Новый Структура("Код",СтрокаОбъекта.ПредставлениеОбъекта);
					СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
					СтруктураЗаполнения.Вставить("СтранаПроисхождения",НомерГТД_СтранаМира);
					СтруктураЗаполнения.Вставить("ИдентификаторСтроки",ИдентификаторСтроки);
					
					Если СтрокаОбъекта.Пометка = Истина Тогда
						СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_НомерГТД(СтруктураЗаполнения,ТекстОшибки);
						ОбъектСоздан = ЗначениеЗаполнено(СтрокаОбъекта.Объект1с);
					КонецЕсли;
					
				КонецЕсли;
				ДанныеНоменклатурыПортала.НомерГТДСсылка = СтрокаОбъекта.Объект1с;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "СтраныМира" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
					СтруктураЗаполнения = Новый Структура("Код,Наименование",ДанныеНоменклатурыПортала.recognizedCountryCode,ДанныеНоменклатурыПортала.recognizedCountryShortName);
					СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
					
					Если СтрокаОбъекта.Пометка = Истина Тогда
						СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_СтранаМира(СтруктураЗаполнения,ТекстОшибки);
						ОбъектСоздан = ЗначениеЗаполнено(СтрокаОбъекта.Объект1с);
					КонецЕсли;
					
				КонецЕсли;
				ДанныеНоменклатурыПортала.СтранаПроисхожденияСсылка = СтрокаОбъекта.Объект1с;
				
			ИначеЕсли СтрокаОбъекта.ТипОбъекта = "ИсточникиПроисхождения" Тогда
				Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
										
					СтруктураЗаполнения = Новый Структура("Код",СтрокаОбъекта.ИсточникиПроисхождения_Код);
					СтруктураЗаполнения.Вставить("Наименование",СтрокаОбъекта.ПредставлениеОбъекта);
					СтруктураЗаполнения.Вставить("ДокументИД",СтрокаОбъекта.ДокументИД);
					СтруктураЗаполнения.Вставить("СтранаПроисхождения",НомерГТД_СтранаМира);
					СтруктураЗаполнения.Вставить("ИдентификаторСтроки",ИдентификаторСтроки);
					
					СтрокиНоменклатуры = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ИдентификаторОбъекта","Номенклатура",СтрокаОбъекта.ИдентификаторОбъекта));
					
					Если СтрокиНоменклатуры.Количество() > 0 Тогда
						СтруктураЗаполнения.Вставить("НаименованиеТовара",СтрокиНоменклатуры[0].ПредставлениеОбъекта);
					КонецЕсли;
					
					Если СтрокаОбъекта.Пометка = Истина Тогда
						СтрокаОбъекта.Объект1с = СоздатьЭлементСправочника_ИсточникПроисхождения(СтруктураЗаполнения,ТекстОшибки);
						ОбъектСоздан = ЗначениеЗаполнено(СтрокаОбъекта.Объект1с);
					КонецЕсли;
					
				КонецЕсли;
				ДанныеНоменклатурыПортала.ИсточникПроисхожденияСсылка = СтрокаОбъекта.Объект1с;
				
			КонецЕсли;
						
			//2025.05.21 ( 
			ПараметрыМК.Вставить("СтрокаОбъекта",СтрокаОбъекта);
			ПараметрыМК.Вставить("ДанныеДокументаПортала",ДанныеДокументаПортала);
			ПараметрыМК.Вставить("ДанныеНоменклатурыПортала",ДанныеНоменклатурыПортала);
			РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_ПослеПереносаСтрокиДанныхДокумента",ПараметрыМК);
			// ) 2025.05.21
			
			
			Если ОбъектСоздан = Истина И ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
				СтрокаОбъекта.СоответствиеУстановлено = Истина;
				ЗаполнитьВсеСоответствующиеЗначения(СтрокаОбъекта.ПолучитьИдентификатор());
			КонецЕсли;
			
			Если ТекстОшибки <> "" Тогда
				Результат.Успешно = Ложь;
				ОбщийТекстОшибки = ОбщийТекстОшибки + ТекстОшибки + Символы.ПС;
			КонецЕсли;
		КонецЦикла;
		
		Результат.ТекстОшибки = ОбщийТекстОшибки;
		
		ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервере
Процедура ЗаполнитьВсеСоответствующиеЗначения(ИдентификаторСтроки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	СтруктураПоиска = Новый Структура("ТипОбъекта",ТекСтрока.ТипОбъекта);
	
	Если ТекСтрока.ТипОбъекта = "Договоры" Тогда
		//+++ Добавить групповую установку договоров
		Возврат;
		
    //2023.08.10 ( Возможен поиск только по артикулу 
	ИначеЕсли ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
		Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул" Тогда
			Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_Код) Тогда
				СтруктураПоиска.Вставить("Номенклатура_Код",ТекСтрока.Номенклатура_Код);
			Иначе
				Возврат;
			КонецЕсли;
		Иначе
			//В ряде кейсов для пользователя допустимо создание дубликатов по наименованию, в этом случае не ищем по наименованию
			Если СтруктураНастроек.Номенклатура_НеСоздаватьЕслиЕстьПолноеСовпадениеПоНаименованию = Истина Тогда
				СтруктураПоиска.Вставить("ПредставлениеОбъекта",ТекСтрока.ПредставлениеОбъекта);
			Иначе
				Возврат;
			КонецЕсли;
		КонецЕсли;
	// ) 2023.08.10
	
	ИначеЕсли ТекСтрока.ТипОбъекта = "Организации"
		Или ТекСтрока.ТипОбъекта = "Контрагенты" Тогда
		СтруктураПоиска.Вставить("ИдентификаторОбъекта",ТекСтрока.ИдентификаторОбъекта);
	Иначе
		СтруктураПоиска.Вставить("ПредставлениеОбъекта",ТекСтрока.ПредставлениеОбъекта);
	КонецЕсли;
	
	СтрокиОбъекта = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	
	Для Каждого СтрокаОбъекта Из СтрокиОбъекта Цикл
		Если Не ЗначениеЗаполнено(СтрокаОбъекта.Объект1с) Тогда
			СтрокаОбъекта.Объект1с = ТекСтрока.Объект1с;
			
			Если ТекСтрока.ТипОбъекта = "Контрагенты" Тогда
				СтрокаОбъекта.Контрагенты_Партнер = ТекСтрока.Контрагенты_Партнер;
			ИначеЕсли ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
				СтрокаОбъекта.Номенклатура_НоменклатураПоставщика = ТекСтрока.Номенклатура_НоменклатураПоставщика;
			КонецЕсли;
			
		КонецЕсли;
		СтрокаОбъекта.СоответствиеУстановлено = ЗначениеЗаполнено(ТекСтрока.Объект1с);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция КонтрольЗаполнения_Склады_НаСервере()
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Результат = РеквизитОбъект.КонтрольЗаполнения_ФормаСопоставления_Склады();
	
	//Если в табличной части были добавлены дополнительные реквизиты, они будут сброшены
	//помещении значения объекта в реквизит формы
	
	Возврат Результат;
КонецФункции


&НаСервере
Функция СоздатьЭлементСправочника_Контрагент(СтруктураЗаполнения,ТекстОшибки)
		
	//EN-371: Не давать создавать дубликаты контрагентов
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	ПоляПоиска = Новый Структура("ИНН,КПП,ИдентификационныйКодЛичности,Наименование,НаименованиеПолное",СтруктураЗаполнения.ИНН,СтруктураЗаполнения.КПП,СтруктураЗаполнения.ИНН);
	КонтрагентСсылка = РеквизитОбъект.ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП("Контрагенты",ПоляПоиска,СтруктураНастроек);
	
	Если Не ЗначениеЗаполнено(КонтрагентСсылка) Тогда
	// ) EN-371
	
	    //Пока что ИИН/БИН передан в форму сопоставления в реквизите ИНН контрагента
		СтруктураЗаполнения.Вставить("ИдентификационныйКодЛичности",СтруктураЗаполнения.ИНН);
		
		Если НаправлениеСоздаваемогоДокумента = "Исходящий" Тогда
			СтруктураЗаполнения.Вставить("Покупатель",Истина);
		КонецЕсли;	
		СтруктураЗаполнения.Вставить("Поставщик",Истина);
		
		СтруктураЗаполнения.Вставить("ВестиРасчетыПоДоговорам",Истина);
		
		//2019.08.06 ( БГУ2
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БГУ2" Тогда
			Если СтрДлина(СтруктураЗаполнения.ИНН) = 12 Тогда
				ВидКонтрагента = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ФизЛицо");
				ЮрФизЛицоМенеджер = Справочники.ФизическиеЛица;
				
			Иначе
				ВидКонтрагента = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.ЮрЛицо");
				ЮрФизЛицоМенеджер = Справочники.ЮридическиеЛица;
				
			КонецЕсли;
			
			ЮрФизЛицо = ЮрФизЛицоМенеджер.НайтиПоРеквизиту("ИНН",СтруктураЗаполнения.ИНН);
			
			Если Не ЗначениеЗаполнено(ЮрФизЛицо) И СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента = "ИНН,Наименование" Тогда
				ЮрФизЛицо = ЮрФизЛицоМенеджер.НайтиПоНаименованию(СтруктураЗаполнения.Наименование,Истина);
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ЮрФизЛицо) Тогда
				ЮрФизЛицо = ЮрФизЛицоМенеджер.ПолучитьСсылку();
			КонецЕсли;
			
			СтруктураЗаполнения.Вставить("ЮридическоеФизическоеЛицо", ЮрФизЛицо);
			СтруктураЗаполнения.Вставить("ВидКонтрагента", ВидКонтрагента);
			
		Иначе
		// ) БГУ2 2019.08.06 
		
			Если Метаданные.Перечисления.Найти("ЮрФизЛицо") <> Неопределено Тогда
				ЗначениеЮрЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
				ЗначениеФизЛицо = ?(РеквизитСуществует("Перечисления","ЮрФизЛицо","ИндивидуальныйПредприниматель"),
									Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель,
									Перечисления.ЮрФизЛицо.ФизЛицо);
									
			ИначеЕсли Метаданные.Перечисления.Найти("ВидыКонтрагентов") <> Неопределено Тогда // УНФ
				ЗначениеЮрЛицо = Перечисления.ВидыКонтрагентов.ЮридическоеЛицо;
				ЗначениеФизЛицо = Перечисления.ВидыКонтрагентов.ФизическоеЛицо;
				
				//Для УНФ попробуем заполнить счета учета по умолчанию
				Попытка
					Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
						СтруктураЗаполнения.Вставить("СчетУчетаАвансовПокупателя",ПредопределенноеЗначение("ПланСчетов.Управленческий.КраткосрочныеАвансыПолученные"));
						СтруктураЗаполнения.Вставить("СчетУчетаАвансовПоставщику",ПредопределенноеЗначение("ПланСчетов.Управленческий.КраткосрочныеАвансыВыданные"));
						СтруктураЗаполнения.Вставить("СчетУчетаРасчетовСПокупателем",ПредопределенноеЗначение("ПланСчетов.Управленческий.КраткосрочнаяДебиторскаяЗадолженностьПокупателейИЗаказчиков"));
						СтруктураЗаполнения.Вставить("СчетУчетаРасчетовСПоставщиком",ПредопределенноеЗначение("ПланСчетов.Управленческий.КраткосрочнаяЗадолженностьПоставщикамИПодрядчикам"));
					Иначе					
						СтруктураЗаполнения.Вставить("СчетУчетаАвансовПокупателя",ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыПоАвансамПолученным"));
						СтруктураЗаполнения.Вставить("СчетУчетаАвансовПоставщику",ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыПоАвансамВыданным"));
						СтруктураЗаполнения.Вставить("СчетУчетаРасчетовСПокупателем",ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПокупателями"));
						СтруктураЗаполнения.Вставить("СчетУчетаРасчетовСПоставщиком",ПредопределенноеЗначение("ПланСчетов.Управленческий.РасчетыСПоставщиками"));
					КонецЕсли;
				Исключение
					
				КонецПопытки;
				
			ИначеЕсли Метаданные.Перечисления.Найти("ЮридическоеФизическоеЛицо") <> Неопределено Тогда 
				ЗначениеЮрЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
				ЗначениеФизЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;		
				
			Иначе
				//+++
				
			КонецЕсли;
				
			//E1C-421: Костыль: для KAZ-конфигураций
			Если СтруктураНастроек.РегионПространства = "KAZ" Тогда
				//Номер ИИН можно отличить от номера БИН по пятой цифре: у ИИН это 0, 1, 2 или 3; а у БИН это 4, 5 или 6
				Если ЗначениеЗаполнено(СтруктураЗаполнения.ИНН) Тогда
					ПятаяЦифра = Сред(СтруктураЗаполнения.ИНН,5,1);
					Если ПятаяЦифра = "0" Или ПятаяЦифра = "1" Или ПятаяЦифра = "2" Или ПятаяЦифра = "3" Тогда
						ЮрФизЛицо = ЗначениеФизЛицо;
					Иначе
						ЮрФизЛицо = ЗначениеЮрЛицо;
					КонецЕсли;
				Иначе
					ЮрФизЛицо = ЗначениеЮрЛицо;
				КонецЕсли;
			Иначе
				ЮрФизЛицо = ?(СтрДлина(СтруктураЗаполнения.ИНН) = 12,ЗначениеФизЛицо,ЗначениеЮрЛицо);
			КонецЕсли;
			
			СтруктураЗаполнения.Вставить("ЮрФизЛицо", ЮрФизЛицо);
			СтруктураЗаполнения.Вставить("ЮридическоеФизическоеЛицо", ЮрФизЛицо);
			СтруктураЗаполнения.Вставить("ВидКонтрагента", ЮрФизЛицо);
			
		КонецЕсли;
		
		//E1C-457: Самозанятых создаем с отдельным видом (в БП30 - флаг Самозанятый
		Если СтруктураЗаполнения.ДокументТип = "SELF_EMPLOYED_RECEIPT" Тогда
			СтруктураЗаполнения.Вставить("Самозанятый",Истина);
		КонецЕсли;
		
		//Флаг Индивидуальный предприниматель
		Если Найти(Нрег(СтруктураЗаполнения.НаименованиеПолное),"индивидуальный") > 0
			Или Найти(Нрег(СтруктураЗаполнения.НаименованиеПолное),"предприниматель") > 0
			Или Найти(Нрег(СтруктураЗаполнения.НаименованиеПолное),"ип ") > 0 Тогда
			СтруктураЗаполнения.Вставить("ИндивидуальныйПредприниматель",Истина);
		КонецЕсли;
		
		Если РеквизитСуществует("Справочники","Контрагенты","СтранаРегистрации")
			И Метаданные.Справочники.Найти("СтраныМира") <> Неопределено Тогда
			СтруктураЗаполнения.Вставить("СтранаРегистрации",Справочники.СтраныМира.Россия);
		КонецЕсли;
		
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "УНФ" Тогда
			Если РеквизитСуществует("Константы","ВестиРасчетыПоДоговорам") Тогда
				СтруктураЗаполнения.Вставить("ВестиРасчетыПоДоговорам",Константы.ВестиРасчетыПоДоговорам.Получить());
			КонецЕсли;
			
			Если РеквизитСуществует("Константы","ВестиРасчетыПоДокументам") Тогда
				СтруктураЗаполнения.Вставить("ВестиРасчетыПоДокументам",Константы.ВестиРасчетыПоДокументам.Получить());
			КонецЕсли;
			
			Если РеквизитСуществует("Константы","ВестиРасчетыПоЗаказам") Тогда
				СтруктураЗаполнения.Вставить("ВестиРасчетыПоЗаказам",Константы.ВестиРасчетыПоЗаказам.Получить());
			КонецЕсли;
			
			Если РеквизитСуществует("Константы","ВестиУчетОплатыПоСчетам") Тогда
				СтруктураЗаполнения.Вставить("ВестиУчетОплатыПоСчетам",Константы.ВестиУчетОплатыПоСчетам.Получить());
			КонецЕсли;			
		КонецЕсли;
		
		СтруктураЗаполнения.Вставить("Комментарий","#Создан автоматически при загрузке из сервиса Entera.pro");
		
		// Схема с формированием наименования вида <НаименованиеКраткое ОПФ>
		Если СтруктураНастроек.ЗаполнениеШапки_ФормироватьНаименованиеКонтрагентаПоШаблону = Истина Тогда
			СтруктураНаименования = РеквизитОбъект.Энтера_НаименованиеОрганизации(СтруктураЗаполнения.НаименованиеПолное);
			
			//Пока костыль: если полное и краткое при преобразовании оказались одинаковыми,
			//значит не удалось обработать наименование, оставим краткое наименование по данным Синтеки
			Если СтруктураНаименования.СокращенноеНаименование <> СтруктураНаименования.ПолноеНаименование Тогда
				СтруктураЗаполнения.Вставить("Наименование", СтруктураНаименования.СокращенноеНаименование);
			КонецЕсли;
		КонецЕсли;
		
		НовыйКонтрагент = Справочники.Контрагенты.СоздатьЭлемент();
		
		//Может быть передана ссылка на элемент справочника Контрагенты, если ее использовали при создании банковского счета
		Если СтруктураЗаполнения.Свойство("СсылкаНовогоОбъекта") И ЗначениеЗаполнено(СтруктураЗаполнения.СсылкаНовогоОбъекта) Тогда
			НовыйКонтрагент.УстановитьСсылкуНового(СтруктураЗаполнения.СсылкаНовогоОбъекта);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(НовыйКонтрагент,СтруктураЗаполнения);
		
		Если Метаданные.Справочники.Найти("Партнеры") <> Неопределено Тогда
			НовыйПартнер = Справочники.Партнеры.СоздатьЭлемент();
			
			Если НаправлениеСоздаваемогоДокумента = "Исходящий" Тогда
				НовыйПартнер.Клиент = Истина;
			КонецЕсли;
			НовыйПартнер.Поставщик = Истина;
			
			НовыйПартнер.ПрочиеОтношения = Истина;
			НовыйПартнер.ДатаРегистрации = ТекущаяДата();
			НовыйПартнер.Комментарий = "#Создан автоматически при загрузке из сервиса Entera.pro";
			НовыйПартнер.Наименование = НовыйКонтрагент.Наименование;
			НовыйПартнер.НаименованиеПолное = НовыйКонтрагент.НаименованиеПолное;
			
			Если НовыйПартнер.Метаданные().Реквизиты.Найти("ЮрФизЛицо") <> Неопределено Тогда
				НовыйПартнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания;
			КонецЕсли;
			
			НовыйПартнер.Записать();
			НовыйПартнер = НовыйПартнер.Ссылка;
			
			НовыйКонтрагент.Партнер = НовыйПартнер;
		Иначе
			НовыйПартнер = Неопределено;
		КонецЕсли;
		
		// ( модуль кастомизации
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
		ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("ДокументИД",СтруктураЗаполнения.ДокументИД);
		ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
		ПараметрыМК.Вставить("Объект",НовыйКонтрагент);
		ПараметрыМК.Вставить("Ссылка",КонтрагентСсылка);
		ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
		
		РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_Контрагент_ПередЗаписью",ПараметрыМК);
		
		Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
		// ) модуль кастомизации
		
			Попытка
				НовыйКонтрагент.Записать();
				КонтрагентСсылка = НовыйКонтрагент.Ссылка;
			Исключение
				ТекстОшибки = "Запись контрагента " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
			КонецПопытки;
		
			//2019.08.06 ( БГУ2: запишем элемент справочника ЮрФизЛицо
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БГУ2"
				И ЗначениеЗаполнено(ПараметрыМК.Ссылка) Тогда
					
				ЮрФизЛицоОбъект = ЮрФизЛицоМенеджер.СоздатьЭлемент();
				ЮрФизЛицоОбъект.УстановитьСсылкуНового(ЮрФизЛицо);
				ЗаполнитьЗначенияСвойств(ЮрФизЛицоОбъект,СтруктураЗаполнения);
				
				Попытка
					ЮрФизЛицоОбъект.Записать();
				Исключение
					ТекстОшибки = "Запись юридического/физического лица контрагента " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
				КонецПопытки;
			КонецЕсли;
			// ) БГУ2 2019.08.06 
		Иначе
			КонтрагентСсылка = ПараметрыМК.Ссылка;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат КонтрагентСсылка;
	
КонецФункции
&НаСервере
Функция СоздатьЭлементСправочника_Договор(СтруктураЗаполнения,ПараметрыЗаполнения,ТекстОшибки)
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	Если Метаданные.Справочники.Найти("ДоговорыКонтрагентов") <> Неопределено Тогда
		ДоговорМенеджер = Справочники.ДоговорыКонтрагентов;
		Если Метаданные.Справочники.ДоговорыКонтрагентов.Владельцы.Содержит(Метаданные.Справочники.Контрагенты) Тогда
			СтруктураЗаполнения.Вставить("Владелец",СтруктураЗаполнения.Контрагент);
		КонецЕсли;
		
	ИначеЕсли Метаданные.Справочники.Найти("Договоры") <> Неопределено Тогда
		ДоговорМенеджер = Справочники.Договоры;
		Если Метаданные.Справочники.Договоры.Владельцы.Содержит(Метаданные.Справочники.Контрагенты) Тогда
			СтруктураЗаполнения.Вставить("Владелец",СтруктураЗаполнения.Контрагент);
		КонецЕсли;
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
			
	//E1C-327: ( Для документа ОтчетКомиссионераОПродажах создаем договор с видом СКомиссионером
	Если ПараметрыЗаполнения.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
		Если РеквизитСуществует("Перечисления","ВидыДоговоровКонтрагентов","СКомиссионером") Тогда
			СтруктураЗаполнения.Вставить("ВидДоговора",Перечисления.ВидыДоговоровКонтрагентов.СКомиссионером);
		КонецЕсли;
	// ) E1C-327
	
	//E1C-337: ( Для документа ОтчетКомиссионера создаем договор с видом СКомиссионером
	ИначеЕсли ПараметрыЗаполнения.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
		Если РеквизитСуществует("Перечисления","ХозяйственныеОперации","ПередачаНаКомиссию") Тогда
			СтруктураЗаполнения.Вставить("ХозяйственныеОперации",Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию);
		КонецЕсли;
		
		//2024.04.23 ( УНФ
		Если РеквизитСуществует("Перечисления","ВидыДоговоров","СКомиссионером") Тогда
			СтруктураЗаполнения.Вставить("ВидДоговора",Перечисления.ВидыДоговоров.СКомиссионером);
		КонецЕсли;
		// ) 2024.04.23
		
	Иначе
	// ) E1C-337
	
		Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			Если РеквизитСуществует("Перечисления","ВидыДоговоровКонтрагентов","СПоставщиком") Тогда
				СтруктураЗаполнения.Вставить("ВидДоговора",Перечисления.ВидыДоговоровКонтрагентов.СПоставщиком);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ТипыДоговоров","СПоставщиком") Тогда
				СтруктураЗаполнения.Вставить("ТипДоговора",Перечисления.ТипыДоговоров.СПоставщиком);
			КонецЕсли;
			
		Иначе
			Если РеквизитСуществует("Перечисления","ВидыДоговоровКонтрагентов","СПокупателем") Тогда
				СтруктураЗаполнения.Вставить("ВидДоговора",Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ТипыДоговоров","СПокупателем") Тогда
				СтруктураЗаполнения.Вставить("ТипДоговора",Перечисления.ТипыДоговоров.СПокупателем);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Если РеквизитСуществует("Перечисления","СпособыВыставленияДокументов","Автоматически") Тогда
		СтруктураЗаполнения.Вставить("СпособВыставленияДокументов",Перечисления.СпособыВыставленияДокументов.Автоматически);
	КонецЕсли;
	
	Если РеквизитСуществует("Перечисления","СтатусыДоговоровКонтрагентов","Действует") Тогда
		СтруктураЗаполнения.Вставить("Статус",Перечисления.СтатусыДоговоровКонтрагентов.Действует);
	КонецЕсли;
	
	//УТ11
	Если Метаданные.Константы.Найти("ВариантПриемкиТоваров") <> Неопределено Тогда
		СтруктураЗаполнения.Вставить("ВариантПриемкиТоваров",Константы.ВариантПриемкиТоваров.Получить());
	КонецЕсли;
	
	Если РеквизитСуществует("Перечисления","ПорядокРасчетов","ПоНакладным") Тогда
		СтруктураЗаполнения.Вставить("ВариантПриемкиТоваров",Перечисления.ПорядокРасчетов.ПоНакладным);
	КонецЕсли;
	
	СтруктураЗаполнения.Вставить("ПредъявляетНДС",Истина);
		
	СтруктураЗаполнения.Вставить("ВалютаВзаиморасчетов",СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета);
		
	// БГУ2 2019.08.06 (
	//ОтдельныйСчетДляРасчетовПоГОЗ
	//ГосударственныйКонтрактПоГОЗ
	// ) БГУ2 2019.08.06 
	
	СтруктураЗаполнения.Вставить("Комментарий","#Создан автоматически при загрузке из сервиса Entera.pro");
	
	ДоговорОбъект = ДоговорМенеджер.СоздатьЭлемент();
			
	Попытка ДоговорОбъект.Заполнить(СтруктураЗаполнения); Исключение; КонецПопытки;
	
	ЗаполнитьЗначенияСвойств(ДоговорОбъект,СтруктураЗаполнения);
	
	// ( модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ДокументИД",ПараметрыЗаполнения.ДокументИД);
	ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	ПараметрыМК.Вставить("Объект",ДоговорОбъект);
	ПараметрыМК.Вставить("Ссылка",ДоговорМенеджер.ПустаяСсылка());
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_Договор_ПередЗаписью",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) модуль кастомизации
	
		Попытка
			ДоговорОбъект.Записать();
			ПараметрыМК.Ссылка = ДоговорОбъект.Ссылка;
		Исключение
			ТекстОшибки = "Запись договора " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
		
	Возврат ПараметрыМК.Ссылка;
	
КонецФункции
&НаСервере
Функция СоздатьЭлементСправочника_БанковскийСчет(СтруктураЗаполнения,ТекстОшибки)
	
	СтруктураЗаполнения.Вставить("Валюта",СтруктураНастроек.СведенияОКонфигурации.ВалютаУчета);
	
	//Поищем существующий банковский счет
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Результат = РеквизитОбъект.ПолучитьСсылку_БанковскийСчет(СтруктураЗаполнения,СтруктураНастроек);
	
	Если Не ЗначениеЗаполнено(Результат) Тогда	
		
		ИмяСправочникаБанковскиеСчета = СтруктураНастроек.СведенияОКонфигурации.Банк_ИмяСправочникаБанковскиеСчетаКонтрагентов;
		ИмяСправочникаБанки = СтруктураНастроек.СведенияОКонфигурации.Банк_ИмяСправочникаБанки;
		ИмяСправочникаКлассификаторБанков = СтруктураНастроек.СведенияОКонфигурации.Банк_ИмяСправочникаКлассификаторБанков;
		
		НачатьТранзакцию();
	
		Если ЗначениеЗаполнено(ИмяСправочникаБанки) Тогда
			БанкСсылка = Справочники[ИмяСправочникаБанки].НайтиПоКоду(СтруктураЗаполнения.БИК);
			
			Если Не ЗначениеЗаполнено(БанкСсылка) Тогда
				БанкОбъект = Справочники[ИмяСправочникаБанки].СоздатьЭлемент();
				
				Если ЗначениеЗаполнено(ИмяСправочникаКлассификаторБанков) Тогда
					БанкПоКлассификатору = Справочники[ИмяСправочникаКлассификаторБанков].НайтиПоКоду(СтруктураЗаполнения.БИК);
				КонецЕсли;
				
				Если ЗначениеЗаполнено(БанкПоКлассификатору) Тогда
					ЗаполнитьЗначенияСвойств(БанкОбъект,БанкПоКлассификатору,,"Владелец");
				Иначе
					
					Банк_СтруктураЗаполнения = Новый Структура;
					Банк_СтруктураЗаполнения.Вставить("Код",СтруктураЗаполнения.БИК);
					Банк_СтруктураЗаполнения.Вставить("Наименование",СтруктураЗаполнения.НаименованиеБанка);
					Банк_СтруктураЗаполнения.Вставить("РучноеИзменение",1);
					
					ЗаполнитьЗначенияСвойств(БанкОбъект,Банк_СтруктураЗаполнения);
					
					_3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(БанкОбъект);
				КонецЕсли;
				
				Попытка
					БанкОбъект.Записать();
					БанкСсылка = БанкОбъект.Ссылка;
				Исключение
					ТекстОшибки = ТекстОшибки + "Не удалось создать банк """ + СтруктураЗаполнения.НаименованиеБанка + """ (БИК " + СтруктураЗаполнения.БИК + ")";
					ОтменитьТранзакцию();
					Возврат Неопределено;
				КонецПопытки;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(БанкСсылка) Тогда
				
				Если ЗначениеЗаполнено(ИмяСправочникаБанковскиеСчета) Тогда
					
					СчетОбъект = Справочники[ИмяСправочникаБанковскиеСчета].СоздатьЭлемент();
					
					СтруктураЗаполнения_Счет = Новый Структура;
					СтруктураЗаполнения_Счет.Вставить("Банк",БанкСсылка);
					СтруктураЗаполнения_Счет.Вставить("Владелец",СтруктураЗаполнения.Владелец);
					СтруктураЗаполнения_Счет.Вставить("ВалютаДенежныхСредств",СтруктураЗаполнения.Валюта);
					СтруктураЗаполнения_Счет.Вставить("ВидСчета","Расчетный");
					
					Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БГУ2" Тогда
						СтруктураЗаполнения_Счет.Вставить("Код",СтруктураЗаполнения.НомерСчета);
					КонецЕсли;
					
					СтруктураЗаполнения_Счет.Вставить("НомерСчета",СтруктураЗаполнения.НомерСчета);
					
					//E1C-501: При создании нового банковского счета поле "Наименование" заполнять в формате "Номер счета, Наименование банка"
					Наименование = Строка(СтруктураЗаполнения.НомерСчета)
						+ ?(ЗначениеЗаполнено(СтруктураЗаполнения.НомерСчета),", ","") + Строка(БанкСсылка);
					СтруктураЗаполнения_Счет.Вставить("Наименование",Наименование);
					
					ЗаполнитьЗначенияСвойств(СчетОбъект,СтруктураЗаполнения_Счет);
					
					_3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(СчетОбъект);
					
					Попытка
						СчетОбъект.Записать();
						Результат = СчетОбъект.Ссылка;
					Исключение
						ТекстОшибки = ТекстОшибки + "Не удалось создать банковский счет """ + СтруктураЗаполнения.НаименованиеБанка + """ (БИК " + СтруктураЗаполнения.БИК + ")";
						Возврат Неопределено;
					КонецПопытки;
					
				Иначе
					СообщитьСообщение("Внутренняя ошибка: не удалось определить имя метаданных справочника <Банковские счета>");
					ОтменитьТранзакцию();
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли ЗначениеЗаполнено(ИмяСправочникаКлассификаторБанков) Тогда //Ищем в классификаторе банков, УТ11, ERP, Розница2
			БанкСсылка = Справочники[ИмяСправочникаКлассификаторБанков].НайтиПоКоду(СтруктураЗаполнения.БИК);
			
			Если ЗначениеЗаполнено(БанкСсылка) Тогда
				
				Если ЗначениеЗаполнено(ИмяСправочникаБанковскиеСчета) Тогда
					
					СчетОбъект = Справочники[ИмяСправочникаБанковскиеСчета].СоздатьЭлемент();
					
					СтруктураЗаполнения_Счет = Новый Структура;
					СтруктураЗаполнения_Счет.Вставить("Банк",БанкСсылка);
					СтруктураЗаполнения_Счет.Вставить("Владелец",СтруктураЗаполнения.Владелец);
					СтруктураЗаполнения_Счет.Вставить("ВалютаДенежныхСредств",СтруктураЗаполнения.Валюта);
					
					СтруктураЗаполнения_Счет.Вставить("НомерСчета",СтруктураЗаполнения.НомерСчета);
					СтруктураЗаполнения_Счет.Вставить("Наименование",СтруктураЗаполнения.НомерСчета);
					
					СтруктураЗаполнения_Счет.Вставить("БИКБанка",БанкСсылка.Код);
					СтруктураЗаполнения_Счет.Вставить("НаименованиеБанка",БанкСсылка.Наименование);
					СтруктураЗаполнения_Счет.Вставить("КоррСчетБанка",БанкСсылка.КоррСчет);
					СтруктураЗаполнения_Счет.Вставить("ГородБанка",БанкСсылка.Город);
					СтруктураЗаполнения_Счет.Вставить("АдресБанка",БанкСсылка.Адрес);
					СтруктураЗаполнения_Счет.Вставить("ТелефоныБанка",БанкСсылка.Телефоны);
					
					ЗаполнитьЗначенияСвойств(СчетОбъект,СтруктураЗаполнения_Счет);				
					
					_3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(СчетОбъект);
					Попытка
						СчетОбъект.Записать();
						Результат = СчетОбъект.Ссылка;
					Исключение
						ТекстОшибки = ТекстОшибки + "Не удалось создать банковский счет """ + СтруктураЗаполнения.НаименованиеБанка + """ (БИК " + СтруктураЗаполнения.БИК + "): " + КраткоеОписаниеОшибки(ОписаниеОшибки());
						ОтменитьТранзакцию();
						Возврат Неопределено;
					КонецПопытки;
					
				Иначе
					СообщитьСообщение("Внутренняя ошибка: не удалось определить имя метаданных справочника <Банковские счета>");
					ОтменитьТранзакцию();
				КонецЕсли;
				
			Иначе
				ТекстОшибки = ТекстОшибки + "Не удалось определить банк """ + СтруктураЗаполнения.НаименованиеБанка + """ (БИК " + СтруктураЗаполнения.БИК + "): " + КраткоеОписаниеОшибки(ОписаниеОшибки());
			КонецЕсли;
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
				
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервере
Функция СоздатьЭлементСправочника_Номенклатура(СтруктураЗаполнения,ДополнительноеОписание,ТекстОшибки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(СтруктураЗаполнения.ИдентификаторСтроки);
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	Результат = Справочники.Номенклатура.ПустаяСсылка();
	
	СтруктураЗаполнения.Вставить("НаименованиеПолное",ТекСтрока.Номенклатура_НаименованиеПолное);
	СтруктураЗаполнения.Вставить("ВидНоменклатуры",ТекСтрока.Номенклатура_ВидНоменклатуры);
	СтруктураЗаполнения.Вставить("ЕдиницаИзмерения",ТекСтрока.Номенклатура_ЕдиницаИзмерения);
	СтруктураЗаполнения.Вставить("ГруппаФинансовогоУчета",ТекСтрока.Номенклатура_ГруппаФинансовогоУчета);
	СтруктураЗаполнения.Вставить("ГруппаАналитическогоУчета",ТекСтрока.Номенклатура_ГруппаАналитическогоУчета);
	СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",ТекСтрока.Номенклатура_НоменклатурнаяГруппа);
	
	//БП30 для Казахстана
	СтруктураЗаполнения.Вставить("БазоваяЕдиницаИзмерения",ТекСтрока.Номенклатура_ЕдиницаИзмерения);
	
	
	//БИТ:Стоматология
	СтруктураЗаполнения.Вставить("ЕдиницаХраненияОстатков",ТекСтрока.Номенклатура_ЕдиницаИзмерения);
	СтруктураЗаполнения.Вставить("ЕдиницаТоваров",ТекСтрока.Номенклатура_ЕдиницаИзмерения);
	
	//2020.03.04 ( E1C-22: При создании новой номенклатуры артикул должен записываться в поле "Артикул"
	Если СтруктураНастроек.Номенклатура_ЗаполнятьАртикулы = Истина Тогда
		Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_Код) Тогда
			СтруктураЗаполнения.Вставить("Артикул",ТекСтрока.Номенклатура_Код);
		КонецЕсли;
	КонецЕсли;
	// ) 2020.03.04
	
	//2021.12.09 (
	Если Не ЗначениеЗаполнено(СтруктураЗаполнения.НоменклатурнаяГруппа) Тогда
		Если ДополнительноеОписание = "Услуга"
			Или ДополнительноеОписание = "АгентскиеУслуги" Тогда
			СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга);			
		Иначе
			СтруктураЗаполнения.Вставить("НоменклатурнаяГруппа",СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар);
		КонецЕсли;
	КонецЕсли;
	// ) 2021.12.09 
	
	//E1C-165: При выключенной настройке <Учитывать НДС при заполнении документа> при создании номенклатуры использовать ставку БезНДС
	Если СтруктураНастроек.ЗаполнениеШапки_УчитыватьНДС = Ложь Тогда
		СтруктураЗаполнения.Вставить("СтавкаНДС",СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС.БезНДС);
	КонецЕсли;
		
	Если ДополнительноеОписание = "Услуга"
		Или ДополнительноеОписание = "АгентскиеУслуги" Тогда
		
		СтруктураЗаполнения.Вставить("Услуга",Истина);
		СтруктураЗаполнения.Вставить("СчетУчетаЗатрат",ТекСтрока.Номенклатура_СчетУчета);
		
		Если РеквизитСуществует("Справочники","ВидыНоменклатуры") Тогда
			Если РеквизитСуществует("Справочники","ВидыНоменклатуры","ТипНоменклатуры") Тогда
				СтруктураЗаполнения.Вставить("ТипНоменклатуры",ТекСтрока.Номенклатура_ВидНоменклатуры.ТипНоменклатуры);
			КонецЕсли;
			
		ИначеЕсли РеквизитСуществует("Перечисления","ТипыНоменклатуры","Услуга") Тогда //УНФ
				СтруктураЗаполнения.Вставить("ТипНоменклатуры",Перечисления.ТипыНоменклатуры.Услуга);
				
		КонецЕсли;
					
	Иначе
		СтруктураЗаполнения.Вставить("Услуга",Ложь);
		СтруктураЗаполнения.Вставить("СчетУчетаЗапасов",СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар);
		
		//2023.05.31 ( Статью затрат заполняем только для НЕ-Услуг
		СтруктураЗаполнения.Вставить("СтатьяЗатрат",ТекСтрока.Номенклатура_СтатьяЗатрат);
		// ) 2023.05.31
		
		Если РеквизитСуществует("Справочники","ВидыНоменклатуры") Тогда			
			Если РеквизитСуществует("Справочники","ВидыНоменклатуры","ТипНоменклатуры")
				И ЗначениеЗаполнено(ТекСтрока.Номенклатура_ВидНоменклатуры) Тогда
				СтруктураЗаполнения.Вставить("ТипНоменклатуры",ТекСтрока.Номенклатура_ВидНоменклатуры.ТипНоменклатуры);
			КонецЕсли;
			
		ИначеЕсли РеквизитСуществует("Перечисления","ТипыНоменклатуры","Запас") Тогда //УНФ
			СтруктураЗаполнения.Вставить("ТипНоменклатуры",Перечисления.ТипыНоменклатуры.Запас);
			
		КонецЕсли;
				
	КонецЕсли;
	
	Родитель = ТекСтрока.Номенклатура_Родитель;
	Если ЗначениеЗаполнено(Родитель) И Родитель.ЭтоГруппа Тогда
		СтруктураЗаполнения.Вставить("Родитель",Родитель);
	КонецЕсли;	
	
	Если РеквизитСуществует("Перечисления","ГрадацииКачества","Новый") Тогда
		СтруктураЗаполнения.Вставить("Качество",Перечисления.ГрадацииКачества.Новый);
	КонецЕсли;
	
	Если РеквизитСуществует("Перечисления","ВариантыИспользованияХарактеристикНоменклатуры","НеИспользовать") Тогда
		СтруктураЗаполнения.Вставить("ИспользованиеХарактеристик",Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать);
	КонецЕсли;
	
	Если РеквизитСуществует("Справочники","ВидыНоменклатуры") И РеквизитСуществует("Справочники","ВидыНоменклатуры","ГруппаДоступа") Тогда
		СтруктураЗаполнения.Вставить("ГруппаДоступа",СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар.ГруппаДоступа);
	КонецЕсли;
	
	//2019.05.21 ( УНФ: предзаполним счета учета запасов/затрат по умолчанию, если не заданы в настройках
	Если Конф = "УНФ" Тогда
		Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_СчетУчетаЗапасов) Тогда
			СчетУчетаЗапасов = ТекСтрока.Номенклатура_СчетУчетаЗапасов;
		ИначеЕсли ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар) Тогда
			СчетУчетаЗапасов = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар;
		Иначе
			Попытка	СчетУчетаЗапасов = ПредопределенноеЗначение("ПланСчетов.Управленческий.СырьеИМатериалы"); Исключение; КонецПопытки;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_СчетУчетаЗатрат) Тогда
			СчетУчетаЗатрат = ТекСтрока.Номенклатура_СчетУчетаЗатрат;		
		ИначеЕсли ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюУслуга) Тогда
			СчетУчетаЗатрат = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюУслуга;
		Иначе
			Попытка	СчетУчетаЗатрат = ПредопределенноеЗначение("ПланСчетов.Управленческий.КоммерческиеРасходы"); Исключение; КонецПопытки;
		КонецЕсли;		
		
		СтруктураЗаполнения.Вставить("СчетУчетаЗапасов",СчетУчетаЗапасов);
		СтруктураЗаполнения.Вставить("СчетУчетаЗатрат",СчетУчетаЗатрат);
		
		//2022.05.25 ( определяем и заполняем ВидСтавкиНДС
		Если РеквизитСуществует("Перечисления","ВидыСтавокНДС") Тогда
			Попытка
				СтруктураЗаполнения.Вставить("ВидСтавкиНДС",Перечисления.ВидыСтавокНДС.ВидСтавки(СтруктураЗаполнения.СтавкаНДС));
			Исключение
				//Не обрабатываем
			КонецПопытки;
		КонецЕсли;
		// ) 2022.05.25
		
	КонецЕсли;
	// ) 2019.05.21
	
	Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_Категория) Тогда
		СтруктураЗаполнения.Вставить("КатегорияНоменклатуры",ТекСтрока.Номенклатура_Категория);
	Иначе
		Если Метаданные.Справочники.Найти("КатегорииНоменклатуры") <> Неопределено Тогда
			Попытка СтруктураЗаполнения.Вставить("КатегорияНоменклатуры",Справочники.КатегорииНоменклатуры.БезКатегории); Исключение; КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	// 2023.08.24 ( Часть заполнения может выполняться по данным выбранной категории
	Если СтруктураЗаполнения.Свойство("КатегорияНоменклатуры")
		И ЗначениеЗаполнено(СтруктураЗаполнения.КатегорияНоменклатуры)
		И РеквизитСуществует("Справочники","КатегорииНоменклатуры","МетодОценки") Тогда
		СтруктураЗаполнения.Вставить("МетодОценки",СтруктураЗаполнения.КатегорияНоменклатуры.МетодОценки);
	КонецЕсли;
	// ) 2023.08.24
	
	Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_НаправлениеДеятельности) Тогда
		СтруктураЗаполнения.Вставить("НаправлениеДеятельности",ТекСтрока.Номенклатура_НаправлениеДеятельности);
	КонецЕсли;
	
	//По идее, если номенклатуру создают, а не выбирают из списка, то характеристика на этом этапе еще не выбрана,
	//значит новая номенклатура создается без ведения учета по характеристикам? Пока оставляю код ниже, может быть будет другая логика
	УстанавливатьФлагИспользованияХарактеристик = Ложь;
	
	Если УстанавливатьФлагИспользованияХарактеристик Тогда
		Если СтруктураНастроек.Свойство("ЗаполнениеТЧ_ИспользоватьХарактеристики")
			И СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьХарактеристики = Истина Тогда
			Если РеквизитСуществует("Перечисления","ВариантыИспользованияХарактеристикНоменклатуры","ИндивидуальныеДляНоменклатуры") Тогда
				СтруктураЗаполнения.Вставить("ИспользованиеХарактеристик",Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
		
	НоменклатураОбъект = Справочники.Номенклатура.СоздатьЭлемент();
	Если СтруктураЗаполнения.Свойство("СсылкаНовогоОбъекта") И ЗначениеЗаполнено(СтруктураЗаполнения.СсылкаНовогоОбъекта) Тогда
		НоменклатураОбъект.УстановитьСсылкуНового(СтруктураЗаполнения.СсылкаНовогоОбъекта);
	КонецЕсли;
	
	//2021.10.08 ( в УТ-подобных конфигурациях базовое заполнение объекта Номенклатуры выполняется по виду номенклатуры,
	//если такой реквизит у Номенклатуры есть - заполним его до вызова ОбработкиЗаполнения объекта
	Если НоменклатураОбъект.Метаданные().Реквизиты.Найти("ВидНоменклатуры") <> Неопределено Тогда
		НоменклатураОбъект.ВидНоменклатуры = СтруктураЗаполнения.ВидНоменклатуры;
		
		//2022.06.08 ( В Рознице по виду номенклатуры заполняем ценовую группу
		Если Конф = "РОЗН2" Тогда
			
			//Из модуля менеджера типовой Розницы
			СтруктураРеквизитов = Новый Структура;
			СтруктураРеквизитов.Вставить("ТипНоменклатуры", 				"ТипНоменклатуры");
			СтруктураРеквизитов.Вставить("АгентскиеУслуги", 				"АгентскиеУслуги");
			СтруктураРеквизитов.Вставить("АлкогольнаяПродукция", 			"АлкогольнаяПродукция");
			СтруктураРеквизитов.Вставить("ВидАлкогольнойПродукцииЕГАИС", 	"ВидАлкогольнойПродукцииЕГАИС");
			СтруктураРеквизитов.Вставить("ИмпортнаяАлкогольнаяПродукция", 	"ИмпортнаяАлкогольнаяПродукция");
			СтруктураРеквизитов.Вставить("ЕдиницаИзмерения", 				"ЕдиницаИзмерения");
			СтруктураРеквизитов.Вставить("НаборУпаковок", 					"НаборУпаковок");
			СтруктураРеквизитов.Вставить("ЦеноваяГруппа", 					"ЦеноваяГруппа");
			СтруктураРеквизитов.Вставить("ТоварнаяГруппа", 					"ТоварнаяГруппа");
			СтруктураРеквизитов.Вставить("ОсобенностьУчета", 				"ОсобенностьУчета");
			СтруктураРеквизитов.Вставить("ПродукцияМаркируемаяДляГИСМ", 	"ПродукцияМаркируемаяДляГИСМ");
			СтруктураРеквизитов.Вставить("КиЗГИСМ", 						"КиЗГИСМ");
			СтруктураРеквизитов.Вставить("ИспользоватьRFIDМеткиСерии", 		"ИспользоватьRFIDМеткиСерии");
			СтруктураРеквизитов.Вставить("ИспользоватьНомерКИЗГИСМСерии", 	"ИспользоватьНомерКИЗГИСМСерии");
			СтруктураРеквизитов.Вставить("ИспользоватьВидКИЗГИСМСерии", 	"ИспользоватьВидКИЗГИСМСерии");
			СтруктураРеквизитов.Вставить("СтранаПроисхождения", 			"СтранаПроисхождения");
			СтруктураРеквизитов.Вставить("Производитель", 					"Производитель");
			СтруктураРеквизитов.Вставить("Марка", 							"Марка");
			СтруктураРеквизитов.Вставить("ТипСрокаДействия", 				"ТипСрокаДействия");
			СтруктураРеквизитов.Вставить("ТоварнаяКатегория", 				"ТоварнаяКатегория");
			СтруктураРеквизитов.Вставить("ВидМехаГИСМ", 					"ВидМехаГИСМ");
			СтруктураРеквизитов.Вставить("КодТНВЭД", 						"КодТНВЭД");
			
			Попытка
				Справочники.Номенклатура.ОбновитьПризнакиНоменклатурыВыборочно(НоменклатураОбъект,СтруктураРеквизитов,Истина);
			Исключение
				//не обрабатываем
			КонецПопытки;
		КонецЕсли;
		// ) 2022.06.08 
		
	Иначе
		//2022.11.11 ( Хеликс.Стоматология: ВидаНоменклатуры нет, но может быть выбрано перечисление ТипНоменклатуры
		Если РеквизитСуществует("Перечисления","ТипыНоменклатуры")
			И ТипЗнч(СтруктураЗаполнения.ВидНоменклатуры) = Тип("ПеречислениеСсылка.ТипыНоменклатуры") Тогда
			СтруктураЗаполнения.Вставить("ТипНоменклатуры",СтруктураЗаполнения.ВидНоменклатуры);
		КонецЕсли;
		// ) 2022.11.11
		
	КонецЕсли;
	// ) 2021.10.08
	
	//E1C-477: При создании новой номенклатуры в карточке кроме стандартных полей заполнять дополнительные:
	//Код ТНВЭД - значением из поля "UnitCode";
	//Идентификатор товара (ЭСФ) - значением из поля "catalogTruId";
	//Комментарий - Создан по данным документа ЭСФ *№ Number* от *Date*.
	Если СтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеИсточникПроисхождения = Истина Тогда
		СтруктураЗаполнения.Вставить("КодТНВЭД",СтруктураЗаполнения.ДанныеНоменклатурыПортала.esfKzUnitCode);
		СтруктураЗаполнения.Вставить("ИдентификаторТовараЭСФ",СтруктураЗаполнения.ДанныеНоменклатурыПортала.esfKzCatalogTruId);
		
		Комментарий = "Создан по данным документа ЭСФ №" + ТекСтрока.Документ_Номер + " от " + Формат(ТекСтрока.Документ_Дата,"ДФ=dd.MM.yyyy");
		СтруктураЗаполнения.Вставить("Комментарий",Комментарий);
	КонецЕсли;
	
	НоменклатураОбъект.Заполнить(СтруктураЗаполнения);
	
	ЗаполнитьЗначенияСвойств(НоменклатураОбъект,СтруктураЗаполнения);
	
	// ( модуль кастомизации
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ТекущаяСтрока",ТекСтрока);
	ПараметрыМК.Вставить("АдресХранилищаДанныхПортала",АдресХранилищаДанныхПортала);
	ПараметрыМК.Вставить("СтруктураЗаполнения",СтруктураЗаполнения);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ДокументИД",СтруктураЗаполнения.ДокументИД);
	ПараметрыМК.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	ПараметрыМК.Вставить("Объект",НоменклатураОбъект);
	ПараметрыМК.Вставить("Ссылка",Результат);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	РеквизитОбъект.МодульКастомизации_ОбработатьСобытие("Сопоставление_Номенклатура_ПередЗаписью",ПараметрыМК);
		
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) модуль кастомизации
	
		Попытка
			НоменклатураОбъект.Записать();
			Результат = НоменклатураОбъект.Ссылка;
		Исключение
			ТекстОшибки = "Запись номенклатуры " + СтруктураЗаполнения.Наименование + ": " + КраткоеОписаниеОшибки(ОписаниеОшибки());
		КонецПопытки;
		
	Иначе
		Результат = ПараметрыМК.Ссылка;
		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции
&НаСервере
Функция СоздатьЭлементСправочника_НоменклатураПоставщика(СтруктураЗаполнения,ТекстОшибки)
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(СтруктураЗаполнения.ИдентификаторСтроки);
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	НоменклатураПоставщиков_ИмяСправочника = СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяСправочника;
	
	Результат = Справочники[НоменклатураПоставщиков_ИмяСправочника].ПустаяСсылка();
	
	//2020.03.04 ( E1C-22: При создании новой номенклатуры артикул должен записываться в поле "Артикул"
	Если СтруктураНастроек.Номенклатура_ЗаполнятьАртикулы = Истина Тогда
		Если ЗначениеЗаполнено(ТекСтрока.Номенклатура_Код) Тогда
			СтруктураЗаполнения.Вставить("Артикул",ТекСтрока.Номенклатура_Код);
		КонецЕсли;
	КонецЕсли;
	// ) 2020.03.04
	
	//Владелец уже должен быть на этом этапе
	СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",ТекСтрока.ДокументИД));
	Если СтрокиКонтрагента.Количество() > 0 Тогда
		Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Партнер" Тогда
			СтруктураЗаполнения.Вставить("Владелец",СтрокиКонтрагента[0].Контрагенты_Партнер);
			СтруктураЗаполнения.Вставить("ВладелецНоменклатуры",СтрокиКонтрагента[0].Контрагенты_Партнер);
		ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
			СтруктураЗаполнения.Вставить("Владелец",СтрокиКонтрагента[0].Объект1с);
		Иначе
			//Отбор по владельцу не будем устанавливать
			СтруктураЗаполнения.Вставить("Владелец");
		КонецЕсли;
	КонецЕсли;
	
	НоменклатураОбъект = Справочники[НоменклатураПоставщиков_ИмяСправочника].СоздатьЭлемент();
	
	//Заполним ИдентификаторНоменклатуры
	Если НоменклатураПоставщиков_ИмяСправочника = "НоменклатураКонтрагентов" Тогда
		Попытка
			ИдентификаторНоменклатуры = Справочники.НоменклатураКонтрагентов.ИдентификаторНоменклатурыКонтрагентаПоНаименованию(СтруктураЗаполнения.Наименование,,СтруктураЗаполнения.НаименованиеУпаковки);
			СтруктураЗаполнения.Вставить("Идентификатор",ИдентификаторНоменклатуры);
			СтруктураЗаполнения.Вставить("ИдентификаторНоменклатуры",ИдентификаторНоменклатуры);
		Исключение
			НоменклатураОбъект.ДополнительныеСвойства.Вставить("ТребуетсяЗаписьПриОбновленииНоменклатурыКонтрагентов",Ложь);
			_3Ф_УстановитьРежимЗаписи_ОбменДаннымиЗагрузка(НоменклатураОбъект);
