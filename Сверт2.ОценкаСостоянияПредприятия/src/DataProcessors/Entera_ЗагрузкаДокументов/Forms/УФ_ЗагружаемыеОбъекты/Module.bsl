&НаСервереБезКонтекста
Функция ЭкранироватьСпецсимволыПодобно(Строка)
	
	//В качестве спецсимвола используем ~
	Строка = СтрЗаменить(Строка,"[","~[");
	Строка = СтрЗаменить(Строка,"]","~]");
	Строка = СтрЗаменить(Строка,"?","~?");
	Строка = СтрЗаменить(Строка,"%","~%");
	Строка = СтрЗаменить(Строка,"_","~_");
	Строка = СтрЗаменить(Строка,"^","~^");
	
	Возврат Строка;
	
КонецФункции


// ================= Заполнение счетов учета и аналитики ===================

&НаКлиенте
Процедура СчетаУчета_ЗаполнитьСчетаУчетаНоменклатуры()
	СтруктураПоиска = Новый Структура("ТипОбъекта","Организации");
	СтрокиОрганизации = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	
	Для Каждого СтрокаОрганизации Из СтрокиОрганизации Цикл
		СтруктураПоиска = Новый Структура("ТипОбъекта,ДокументИД","Номенклатура",СтрокаОрганизации.ДокументИД);
		СтрокиНоменклатуры = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
		Для Каждого СтрокаНоменклатуры Из СтрокиНоменклатуры Цикл
			СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(СтрокаНоменклатуры,СтрокаОрганизации.Объект1с);
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры
&НаКлиенте
Процедура СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(СтрокаНоменклатуры,Организация = Неопределено)
	
	СтруктураДанных = СчетаУчета_ПолучитьСтруктуруДанныхДляОпределения(СтрокаНоменклатуры,Организация);
	
	Если ЗначениеЗаполнено(СтрокаНоменклатуры.Объект1с) Тогда
		
		СчетаУчета = СчетаУчета_ПолучитьСчетаУчетаНоменклатуры(СтруктураНастроек,СтруктураДанных);
		
		Если СчетаУчета <> Неопределено Тогда
			Если СтруктураДанных.АгентскиеУслуги Тогда
				СтрокаНоменклатуры.Номенклатура_СчетУчета = СчетаУчета.СчетРасчетовСКомитентом;
				СтрокаНоменклатуры.Номенклатура_СчетУчетаНДС = Неопределено;
			Иначе
				СтрокаНоменклатуры.Номенклатура_СчетУчета = СчетаУчета.СчетУчета;
				СтрокаНоменклатуры.Номенклатура_СчетУчетаНДС = СчетаУчета.СчетУчетаНДС;
			КонецЕсли;
		КонецЕсли;		
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура_СчетУчета) Тогда
		//Заполняем значениями по умолчанию из настроек			
		Если СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "Услуга" Тогда
			СтрокаНоменклатуры.Номенклатура_СчетУчета = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюУслуга;
			СтрокаНоменклатуры.Номенклатура_СчетУчетаНДС = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаНДСПоУмолчаниюУслуга;
			
		ИначеЕсли СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "Товар" Тогда
			СтрокаНоменклатуры.Номенклатура_СчетУчета = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар;
			СтрокаНоменклатуры.Номенклатура_СчетУчетаНДС = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаНДСПоУмолчаниюТовар;
			
		Иначе
			СтрокаНоменклатуры.Номенклатура_СчетУчета = Неопределено;
			СтрокаНоменклатуры.Номенклатура_СчетУчетаНДС = Неопределено;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не СтруктураДанных.АгентскиеУслуги Тогда
		СчетаУчета_ЗаполнитьАналитикуСчетовУчета(СтрокаНоменклатуры,СчетаУчета);
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Функция СчетаУчета_ПолучитьСтруктуруДанныхДляОпределения(СтрокаНоменклатуры,Организация = Неопределено)
	
	СтруктураДанных = Новый Структура("Номенклатура,Склад,Организация,Дата");
	СтруктураДанных.Номенклатура = СтрокаНоменклатуры.Объект1с;
	
	//2020.09.15 ( Склад теперь присутствует в форме сопоставления для каждого документа, получим его оттуда
	СтруктураПоиска = Новый Структура("ТипОбъекта,ДокументИД","Документ",СтрокаНоменклатуры.ДокументИД);
	СтрокиСклада = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	Если СтрокиСклада.Количество() > 0 Тогда
		Если ЗначениеЗаполнено(СтрокиСклада[0].Документ_Склад) Тогда
			СтруктураДанных.Склад = СтрокиСклада[0].Документ_Склад;
		КонецЕсли;
	КонецЕсли;
	// ) 2020.09.15
	
	Если СтруктураНастроек.ЗаполнениеШапки_ИспользоватьДатуВходящегоДокумента = Истина Тогда
		СтруктураДанных.Дата = СтрокаНоменклатуры.Документ_Дата;
	Иначе
		СтруктураДанных.Дата = ТекущаяДата();
	КонецЕсли;
	
	Если Организация = Неопределено Тогда
		//Определим организацию текущего документа
		СтруктураПоиска = Новый Структура("ТипОбъекта,ДокументИД","Организации",СтрокаНоменклатуры.ДокументИД);
		СтрокиОрганизации = Объект.ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
		
		Если СтрокиОрганизации.Количество() > 0 Тогда
			СтруктураДанных.Организация = СтрокиОрганизации[0].Объект1с;
		КонецЕсли;
	Иначе
		СтруктураДанных.Организация = Организация;
	КонецЕсли;
	
	СтруктураДанных.Вставить("АгентскиеУслуги",СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "АгентскиеУслуги");
	СтруктураДанных.Вставить("Комитент",СтрокаНоменклатуры.Номенклатура_Комитент);
	СтруктураДанных.Вставить("ДоговорКомитента",СтрокаНоменклатуры.Номенклатура_ДоговорКомитента);
	СтруктураДанных.Вставить("ТипСоздаваемогоДокумента",СтрокаНоменклатуры.ТипСоздаваемогоДокумента);
	
	Возврат СтруктураДанных;
	
КонецФункции
&НаСервереБезКонтекста
Функция СчетаУчета_ПолучитьСчетаУчетаНоменклатуры(СтруктураНастроек,СтруктураДанных)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	Если Конф = "БП30" Тогда
		
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
			
			МодульСчетаУчетаВДокументах = _ЗФ_ПолучитьОбщийМодульКонфигурации("СчетаУчетаВДокументах");
			Если МодульСчетаУчетаВДокументах <> Неопределено Тогда
				
				Кзаполнению = Новый Соответствие;
				
				ДанныеСтроки = Новый Структура("Номенклатура,СчетУчетаБУ,СчетДоходовБУ",СтруктураДанных.Номенклатура);
				
				Если СтруктураДанных.Номенклатура.Услуга Тогда
					ИмяРеквизитаСчет = "СчетДоходовБУ";
					ИмяТЧ = "Услуги";
				Иначе
					ИмяРеквизитаСчет = "СчетУчетаБУ";
					ИмяТЧ = "Товары";
				КонецЕсли;
				
				Кзаполнению.Вставить(ИмяТЧ + "." + ИмяРеквизитаСчет,Истина);
				
				Попытка
					СчетаУчета = МодульСчетаУчетаВДокументах.ЗаполнитьРеквизитыПриИзменении(Документы[СтруктураДанных.ТипСоздаваемогоДокумента],
						Кзаполнению,СтруктураДанных,ИмяТЧ,ДанныеСтроки,Ложь);
					СчетаУчета.Вставить("СчетУчета",СчетаУчета[ИмяРеквизитаСчет]);
					СчетаУчета.Вставить("СчетУчетаНДС");
				Исключение
					//Не обрабатываем
				КонецПопытки;
			КонецЕсли;
			
		Иначе
			
			МодульБухгалтерскийУчетПереопределяемый = _ЗФ_ПолучитьОбщийМодульКонфигурации("БухгалтерскийУчетПереопределяемый");
			Если МодульБухгалтерскийУчетПереопределяемый <> Неопределено Тогда
				Попытка
					Если СтруктураДанных.АгентскиеУслуги Тогда
						СчетаУчета = МодульБухгалтерскийУчетПереопределяемый.ПолучитьСчетаРасчетовСКонтрагентом(СтруктураДанных.Организация,
							СтруктураДанных.Комитент,СтруктураДанных.ДоговорКомитента);
					Иначе
						СчетаУчета = МодульБухгалтерскийУчетПереопределяемый.ПолучитьСчетаУчетаНоменклатуры(СтруктураДанных.Организация,
							СтруктураДанных.Номенклатура,СтруктураДанных.Склад,СтруктураДанных.Дата);
					КонецЕсли;
				Исключение
					//Не обрабатываем
				КонецПопытки;
				
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли Конф = "УНФ" Тогда
		// Не заполняем
		
	ИначеЕсли Конф = "БГУ2" Тогда
		СчетаУчета = Новый Структура("СчетУчета,СчетУчетаНДС,ДанныеСчетаДляСтроки");
		
		//+++ В зависимости от типа заполняемого документа общий модуль может быть другой, пока предполагаем, что заполняется ПоступлениеМЗ
		МодульУправлениеМатериальнымиЗапасамиВызовСервера = _ЗФ_ПолучитьОбщийМодульКонфигурации("УправлениеМатериальнымиЗапасамиВызовСервера");
		Если МодульУправлениеМатериальнымиЗапасамиВызовСервера <> Неопределено Тогда
			СчетаУчета.СчетУчета = МодульУправлениеМатериальнымиЗапасамиВызовСервера.СчетУчетаНоменклатуры(СтруктураДанных.Номенклатура);
		КонецЕсли;
		
		МодульУправлениеМатериальнымиЗапасамиКлиентСервер = _ЗФ_ПолучитьОбщийМодульКонфигурации("УправлениеМатериальнымиЗапасамиКлиентСервер");

		//Данных об объекте документа у нас пока нет, передадим пустой объект
		ПараметрыОбработки = МодульУправлениеМатериальнымиЗапасамиКлиентСервер.ПараметрыУстановкиСчетаУчетаВСтроке(Документы.ПоступлениеМЗ.СоздатьДокумент());
		СчетаУчета.ДанныеСчетаДляСтроки = МодульУправлениеМатериальнымиЗапасамиВызовСервера.ПолучитьДанныеСчетаУчетаНоменклатуры(ПараметрыОбработки);
	КонецЕсли;
	
	Возврат СчетаУчета;
	
КонецФункции

&НаКлиенте
Функция СчетаУчета_ЗаполнитьАналитикуСчетовУчета(СтрокаНоменклатуры,СчетаУчета = Неопределено)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	Если Конф = "БП30" Тогда
		//Определяем по типу значения субконто, в какое из полей доп. описания поместить значение каждого полученного Субконто
		Если СчетаУчета <> Неопределено Тогда
			
			Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
				//+++ Пока не обрабатываем
				
			ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "BLR" Тогда
				//+++ Пока не обрабатываем
				
			Иначе
				Если ТипЗнч(СчетаУчета.Субконто1) = Тип("СправочникСсылка.СтатьиЗатрат") Тогда
					СтрокаНоменклатуры.Номенклатура_СтатьяЗатрат = СчетаУчета.Субконто1;
				ИначеЕсли ТипЗнч(СчетаУчета.Субконто2) = Тип("СправочникСсылка.СтатьиЗатрат") Тогда
					СтрокаНоменклатуры.Номенклатура_СтатьяЗатрат = СчетаУчета.Субконто2;
				ИначеЕсли ТипЗнч(СчетаУчета.Субконто3) = Тип("СправочникСсылка.СтатьиЗатрат") Тогда
					СтрокаНоменклатуры.Номенклатура_СтатьяЗатрат = СчетаУчета.Субконто3;
				КонецЕсли;
				
				Если ТипЗнч(СчетаУчета.Субконто1) = Тип("СправочникСсылка.НоменклатурныеГруппы") Тогда
					СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = СчетаУчета.Субконто1;
				ИначеЕсли ТипЗнч(СчетаУчета.Субконто2) = Тип("СправочникСсылка.НоменклатурныеГруппы") Тогда
					СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = СчетаУчета.Субконто2;
				ИначеЕсли ТипЗнч(СчетаУчета.Субконто3) = Тип("СправочникСсылка.НоменклатурныеГруппы") Тогда
					СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = СчетаУчета.Субконто3;
				КонецЕсли;
				
				//Заполняем ПодразделениеЗатрат и СпособУчетаНДС, установленные для счета учета настройками базы
				СтрокаНоменклатуры.Номенклатура_СпособУчетаНДС = СчетаУчета.СпособУчетаНДС;
				Если СчетаУчета.Свойство("ПодразделениеЗатрат") Тогда
					СтрокаНоменклатуры.Номенклатура_ПодразделениеЗатрат = СчетаУчета.ПодразделениеЗатрат;
				КонецЕсли;		
			КонецЕсли;
			
		КонецЕсли;
		
	ИначеЕсли Конф = "БГУ2" Тогда
		//+++ заполнение аналитики по данным счета
				
	КонецЕсли;
	
	//Если не заполнили - берем из настроек
	Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура_СтатьяЗатрат) Тогда
		СтрокаНоменклатуры.Номенклатура_СтатьяЗатрат = СтруктураНастроек.Номенклатура_СтатьяЗатратПоУмолчанию;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа) Тогда
		Если СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "Услуга" Тогда
			СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаУслуга;
		ИначеЕсли СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "Товар" Тогда
			СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = СтруктураНастроек.Номенклатура_НоменклатурнаяГруппаТовар;
		Иначе
			СтрокаНоменклатуры.Номенклатура_НоменклатурнаяГруппа = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.Номенклатура_СпособУчетаНДС) Тогда
		СтрокаНоменклатуры.Номенклатура_СпособУчетаНДС = СтруктураНастроек.ЗаполнениеТЧ_СпособУчетаНДСПоУмолчанию;
	КонецЕсли;
	
КонецФункции


// ================= Групповая обработка выделенных строк ===================

&НаКлиенте
Процедура ЗагружаемыеОбъекты_ВыбратьНоменклатуру(Команда)
	
	МассивИдентификаторов = Новый Массив;
	ЕстьЗаполненнныеЗначения = Ложь;
	
	Для Каждого ИдентификаторСтроки Из Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки Цикл
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
			
			МассивИдентификаторов.Добавить(ИдентификаторСтроки);
			
			Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
				ЕстьЗаполненнныеЗначения = Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Если МассивИдентификаторов.Количество() = 0 Тогда
		Попытка КартинкаОшибка = БиблиотекаКартинок.Ошибка32; Исключение; КартинкаОшибка = Новый Картинка; КонецПопытки;
		ПоказатьОповещениеПользователя("Нет выделенных строк для выбора номенклатуры",,,КартинкаОшибка);
		Возврат;
	КонецЕсли;
	
	ДопПараметры = Новый Структура;
	ДопПараметры.Вставить("МассивИдентификаторов",МассивИдентификаторов);
	
	Если ЕстьЗаполненнныеЗначения Тогда
		ТекстВопроса = "Действие для уже установленных соответствий номенклатуры в выбранных строках:";
		Кнопки = Новый СписокЗначений;
		Кнопки.Добавить("Пропускать","Пропускать");
		Кнопки.Добавить("Перезаполнять","Перезаполнять");
		Кнопки.Добавить("Отмена","Отмена");
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,ТекстВопроса,Кнопки","ЗагружаемыеОбъекты_ВыбратьНоменклатуру_ОбработатьРанееЗаполненные",ДопПараметры,ТекстВопроса,Кнопки);
		
		_ЗФ_ОбработатьАсинхронныйВызов("Вопрос",ПараметрыВызова);
	Иначе
		ЗагружаемыеОбъекты_ВыбратьНоменклатуру_ОбработатьРанееЗаполненные("Перезаполнять",ДопПараметры)
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Процедура ЗагружаемыеОбъекты_ВыбратьНоменклатуру_ОбработатьРанееЗаполненные(Результат,ДопПараметры)
	
	Если Результат = Неопределено Или Результат = "Отмена" Тогда
		Возврат;
	КонецЕсли;
	
	ДопПараметры.Вставить("Перезаполнять",Результат = "Перезаполнять");
	
	ПараметрыОткрытия = Новый Структура;
	ФормаВыбора = ПолучитьФорму("Справочник.Номенклатура.ФормаВыбора",ПараметрыОткрытия,ЭтаФорма);
				
	ПараметрыВызова = Новый Структура("Обработчик,ФормаВыбора,ДопПараметры","ОбработатьВыборИзФормыСписка_ОбщаяНоменклатура",ФормаВыбора,ДопПараметры);
	_ЗФ_ОбработатьАсинхронныйВызов("ВыборЗначенияИзФормыСписка",ПараметрыВызова);
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборИзФормыСписка_ОбщаяНоменклатура(Результат,ДопПараметры)
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ИдентификаторСтроки Из ДопПараметры.МассивИдентификаторов Цикл
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ДопПараметры.Перезаполнять = Истина Или Не ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			ТекСтрока.Объект1с = Результат;
			ТекСтрока.СоответствиеУстановлено = Истина;
			ТекСтрока.СработавшийВариантПоиска = "Авто_ЧастичноеСовпадениеНаименования";
			
			УстановитьДополнительныеРеквизиты(ТекСтрока);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагружаемыеОбъекты_ЗапомнитьСопоставления(Команда)
	
	Для Каждого ИдентификаторСтроки Из Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки Цикл
		
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		//Обрабатываем только строки Номенклатуры
		Если ТекСтрока.ТипОбъекта = "Номенклатура" И ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			ТекстОповещения = ЗаписатьСоответствиеНоменклатуры(ТекСтрока.Объект1с,ТекСтрока.Номенклатура_Характеристика,ТекСтрока.ПредставлениеОбъекта,ТекСтрока.КонтрагентИД);
			ПоказатьОповещениеПользователя("Сохранено",,ТекстОповещения);
			ТекСтрока.СоответствиеУстановлено = Истина;
			ТекСтрока.СработавшийВариантПоиска = "Авто_ПолноеСовпадениеНаименования";			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
&НаКлиенте
Процедура ЗагружаемыеОбъекты_ОчиститьСоответствие(Команда)
	
	Для Каждого ИдентификаторСтроки Из Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки Цикл
		
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
		
		//Очищаем только найденные соответствия
		Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
			ТекСтрока.Объект1с = Неопределено;
			ТекСтрока.Пометка = Истина;
			ТекСтрока.СоответствиеУстановлено = Ложь;
			ТекСтрока.СработавшийВариантПоиска = "";
			
			УстановитьДополнительныеРеквизиты(ТекСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
&НаКлиенте
Процедура ЗагружаемыеОбъекты_ВыполнитьПоискПохожих(Команда)
	
	ДопПараметры = Новый Структура;
	
	//E1C-21: Умный поиск по артикулу, с отображением найденных номенклатур и их артикула
	Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул"
		Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул,Наименование"
		Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование,Артикул" Тогда
		
		Попытка Картинка_Артикул = БиблиотекаКартинок.НайтиВСодержании; Исключение; Картинка_Артикул = Новый Картинка; КонецПопытки;
		Попытка Картинка_Наименование = БиблиотекаКартинок.Найти; Исключение; Картинка_Наименование = Новый Картинка; КонецПопытки;
		
		СписокВыбора = Новый СписокЗначений;
		СписокВыбора.Добавить("Артикул","Поиск по артикулам",,Картинка_Артикул);
		СписокВыбора.Добавить("Наименование","Поиск по наименованиям",,Картинка_Наименование);
			
		ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,СписокВыбора","ОбработатьВыборВариантаПоиска_АртикулНаименование",ДопПараметры,СписокВыбора);
		
		_ЗФ_ОбработатьАсинхронныйВызов("ВыборИзМеню",ПараметрыВызова);
		
	Иначе
		//Сразу выполняем поиск по наименованию, в настройках артикул не используется
		ОбработатьВыборВариантаПоиска_АртикулНаименование(Новый Структура("Значение","Наименование"),ДопПараметры);
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьВыборВариантаПоиска_АртикулНаименование(Результат,ДопПараметры)
	
	Если Результат <> Неопределено Тогда
	
		//Логика будет такая: если выделено > 1 строки - выполняем поиск только для них,
		//Если выделена одна или ни одной - для всех, для которых можно выполнить поиск похожих
		Если Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки.Количество() > 1 Тогда
			//Обрабатываем все
			МассивСтрок = Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки;		
		КонецЕсли;
		
		ДопПараметры = Новый Структура;
		ДопПараметры.Вставить("МассивСтрок",МассивСтрок);
		ДопПараметры.Вставить("ВариантПоиска",Результат.Значение);
		
		Если Результат.Значение = "Наименование" Тогда
			
			ПараметрыВызова = Новый Структура("Обработчик,ДопПараметры,Число,Подсказка,Длина,Точность","ОбработатьВыборПроцента_ВыполнитьПоискПохожих",ДопПараметры,ПроцентСоответствияАвтоПоиск,"Минимальный % совпадения",3,0);
			
			_ЗФ_ОбработатьАсинхронныйВызов("ВводЧисла",ПараметрыВызова);
			
		ИначеЕсли Результат.Значение = "Артикул" Тогда
			ОбработатьВыборПроцента_ВыполнитьПоискПохожих(ПроцентСоответствияАвтоПоиск,ДопПараметры);
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборПроцента_ВыполнитьПоискПохожих(Результат,ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		
		ПроцентСоответствияАвтоПоиск = Результат;
				
		ОбрабатываемТолькоВыделенныеСтроки = ЗначениеЗаполнено(ДопПараметры.МассивСтрок);
		
		Для Каждого СтрокаТаблицы Из Объект.ЗагружаемыеОбъекты Цикл
			
			ПроцентВыполнения = Объект.ЗагружаемыеОбъекты.Индекс(СтрокаТаблицы) / Объект.ЗагружаемыеОбъекты.Количество() * 100;
			Состояние("Выполняется поиск номенклатуры...",ПроцентВыполнения);
			
			Если ОбрабатываемТолькоВыделенныеСтроки
				И ДопПараметры.МассивСтрок.Найти(СтрокаТаблицы.ПолучитьИдентификатор()) = Неопределено Тогда
				//Невыделенные строки при переданном массиве идентификаторов пропускаем
				Продолжить;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(СтрокаТаблицы.Объект1с) Тогда
				Продолжить;
			КонецЕсли;
			
			СтруктураПоиска = Новый Структура("ПроцентСоответствияАвтоПоиск",ПроцентСоответствияАвтоПоиск);
			
			//Поиск похожих сейчас выполняется только для номенклатуры
			Если СтрокаТаблицы.ТипОбъекта = "Номенклатура" Тогда
				
				РезультатПоиска = Неопределено;
				
				Если ДопПараметры.ВариантПоиска = "Наименование" Тогда
				
					СтруктураПоиска.Вставить("СтрокаПоиска",СтрокаТаблицы.ПредставлениеОбъекта);
					СтруктураПоиска.Вставить("КонтрагентИД",СтрокаТаблицы.КонтрагентИД);
					СтруктураПоиска.Вставить("ДополнятьПользовательскимиСоответствиями",СтруктураНастроек.Номенклатура_ИспользоватьВподбореУстановленныеВручнуюСоответствия);
					СтруктураПоиска.Вставить("Приоритет",СтруктураНастроек.Номенклатура_ПриоритетПриПоискеСопоставленийНоменклатуры);
					СтруктураПоиска.Вставить("РазмерСпискаПохожейНоменклатуры",10);
					
					//Для поиска по Номенклатуре поставщиков нужен отбор по Владельцу
					СтруктураПоиска.Вставить("ПоискПоНоменклатуреПоставщиков",ПоискПоНоменклатуреПоставщиков);
					СтруктураПоиска.Вставить("НоменклатураПоставщиков_ИмяСправочника",СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяСправочника);
					
					//2020.12.23 ( Добавлена настройка для выбора групп поиска
					СписокГрупп = ПолучитьСписокГруппДляПоискаНоменклатуры(СтрокаТаблицы);
						
					Если СписокГрупп.Количество() > 0 Тогда
						СтруктураПоиска.Вставить("СписокГрупп",СписокГрупп);
					КонецЕсли;
					// ) 2020.12.23
					
					Если ПоискПоНоменклатуреПоставщиков Тогда
						СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",СтрокаТаблицы.ДокументИД));
						Если СтрокиКонтрагента.Количество() > 0 Тогда
							Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Партнер" Тогда
								СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Контрагенты_Партнер);
							ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
								СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Объект1с);
							Иначе
								//Отбор по владельцу не будем устанавливать
								СтруктураПоиска.Вставить("Владелец");
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					
					//2022.06.29 ( Поиск по полному наименованию	
					Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование полное" Тогда
						СтруктураПоиска.Вставить("ИмяРеквизита","НаименованиеПолное");
					КонецЕсли;
					// ) 2022.06.29
					
					//УНФ: отбор по реквизиту 
					Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен) И ПоискПоНоменклатуреПоставщиков = Ложь Тогда
						КлючОтбора = СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен;
						СтруктураПоиска.Вставить("ОтборНедействителен",КлючОтбора);
					КонецЕсли;
					
					РезультатПоиска = ОбработатьВыборПроцента_ВыполнитьПоискПохожихНаСервере("Номенклатура",СтруктураПоиска);
					
				Иначе
					//Пустые артикулы пропускаем
					Если ЗначениеЗаполнено(СтрокаТаблицы.Номенклатура_Код) Тогда
						СтруктураПоиска.Вставить("СтрокаПоиска",СтрокаТаблицы.Номенклатура_Код);
						СтруктураПоиска.Вставить("КонтрагентИД",СтрокаТаблицы.КонтрагентИД);
						СтруктураПоиска.Вставить("РазмерСпискаПохожейНоменклатуры",1); //большее количество не требуется
						
						//Для поиска по Номенклатуре поставщиков нужен отбор по Владельцу
						СтруктураПоиска.Вставить("ПоискПоНоменклатуреПоставщиков",ПоискПоНоменклатуреПоставщиков);
						
						Если ПоискПоНоменклатуреПоставщиков Тогда
							СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",СтрокаТаблицы.ДокументИД));
							Если СтрокиКонтрагента.Количество() > 0 Тогда
								Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Партнер" Тогда
									СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Контрагенты_Партнер);
								ИначеЕсли СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
									СтруктураПоиска.Вставить("Владелец",СтрокиКонтрагента[0].Объект1с);
								Иначе
									//Отбор по владельцу не будем устанавливать
									СтруктураПоиска.Вставить("Владелец");
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						
						РезультатПоиска = ВыполнитьПоиск_Артикул("Номенклатура",СтруктураПоиска);
						
					Иначе
						СтрокаТаблицы.СработавшийВариантПоиска = "Авто_АртикулНеЗаполнен";
						
					КонецЕсли;
					
				КонецЕсли;
				
				Если РезультатПоиска <> Неопределено Тогда
					
					Если ПоискПоНоменклатуреПоставщиков Тогда
						СтрокаТаблицы.Номенклатура_НоменклатураПоставщика = РезультатПоиска.Ссылка;
						СтрокаТаблицы.Объект1с = ПолучитьЗначениеРеквизитаОбъекта(РезультатПоиска.Ссылка,"Номенклатура");
						СтрокаТаблицы.Номенклатура_Характеристика = ПолучитьЗначениеРеквизитаОбъекта(РезультатПоиска.Ссылка,"Характеристика");
						
					Иначе
						СтрокаТаблицы.Объект1с = РезультатПоиска.Ссылка;
						
					КонецЕсли;
					
					СтрокаТаблицы.СоответствиеУстановлено = ЗначениеЗаполнено(СтрокаТаблицы.Объект1с);
					
					Если СтрокаТаблицы.СоответствиеУстановлено Тогда
						СтрокаТаблицы.Пометка = Ложь;
						Если ДопПараметры.ВариантПоиска = "Наименование" Тогда
							Если РезультатПоиска.ПроцентВхождения = 100 Тогда
								СтрокаТаблицы.СработавшийВариантПоиска = "Авто_ПолноеСовпадениеНаименования";
							Иначе
								СтрокаТаблицы.СработавшийВариантПоиска = "Авто_ЧастичноеСовпадениеНаименования";
							КонецЕсли;
							
						ИначеЕсли ДопПараметры.ВариантПоиска = "Артикул" Тогда
							Если РезультатПоиска.ПроцентВхождения = 100 Тогда
								СтрокаТаблицы.СработавшийВариантПоиска = "Авто_ПолноеСовпадениеАртикула";
							Иначе
								СтрокаТаблицы.СработавшийВариантПоиска = "Авто_ЧастичноеСовпадениеАртикула";
							КонецЕсли;
							
						КонецЕсли;
					КонецЕсли;				
					
					УстановитьДополнительныеРеквизиты(СтрокаТаблицы);
					
				КонецЕсли;
				
			КонецЕсли;
						
		КонецЦикла;
			
	КонецЕсли;
	
КонецПроцедуры
&НаСервереБезКонтекста
Функция ОбработатьВыборПроцента_ВыполнитьПоискПохожихНаСервере(ТипОбъекта,СтруктураПоиска)
	
	Результат = Новый Структура("Ссылка,ПроцентВхождения",,0);
	
	ПоискПоНоменклатуреПоставщиков = СтруктураПоиска.Свойство("ПоискПоНоменклатуреПоставщиков") И СтруктураПоиска.ПоискПоНоменклатуреПоставщиков = Истина;
	
	//Поиск похожих сейчас выполняется только для номенклатуры
	Если ТипОбъекта = "Номенклатура" Тогда
		Если ПоискПоНоменклатуреПоставщиков Тогда
			ИмяСправочника = СтруктураПоиска.НоменклатураПоставщиков_ИмяСправочника;
		Иначе
			ИмяСправочника = "Номенклатура";
		КонецЕсли;
		Таблица = ЗаполнитьТаблицуСравнения(ИмяСправочника,СтруктураПоиска);
	КонецЕсли;
	
	Если Таблица <> Неопределено И Таблица.Количество() > 0 Тогда
		Если Таблица[0].ПроцентВхождения >= СтруктураПоиска.ПроцентСоответствияАвтоПоиск Тогда
			Результат.Ссылка = Таблица[0].Ссылка;
			Результат.ПроцентВхождения = Таблица[0].ПроцентВхождения;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция ВыполнитьПоиск_Артикул(ТипОбъекта,СтруктураПоиска)
	
	Результат = Новый Структура("Ссылка,ПроцентВхождения",,0);
	
	//Поиск похожих сейчас выполняется только для номенклатуры
	Если ТипОбъекта = "Номенклатура" Тогда
		
		ПоискПоНоменклатуреПоставщиков = СтруктураПоиска.Свойство("ПоискПоНоменклатуреПоставщиков") И СтруктураПоиска.ПоискПоНоменклатуреПоставщиков = Истина;
	
		Если ПоискПоНоменклатуреПоставщиков Тогда
			ИмяСправочника = СтруктураПоиска.НоменклатураПоставщиков_ИмяСправочника;
		Иначе
			ИмяСправочника = "Номенклатура";
		КонецЕсли;
		
		СоответствияСимволов = ПолучитьСоответствияКириллицыЛатиницы();
		
		//Формируем строку для поиска: по описанию задачи исключаем из поиска знаки препинания, оставляем только числовые и буквенные значения
		//подходящей номенклатурой будет считаться та, у которой встречается та же последовательность знаков, как и в искомой строке
		
		СтрокаПоиска = "";
		СтрокаПодсчетаВхождения = "";
		
		Для Счет = 1 По СтрДлина(СтруктураПоиска.СтрокаПоиска) Цикл
			ТекСимвол = Сред(СтруктураПоиска.СтрокаПоиска,Счет,1);
			
			//Исключить символы, не подходящие под условие задачи
			Если Не СимволАртикулаСоответствуетШаблону(ТекСимвол) Тогда
				Продолжить;
			КонецЕсли;
			
			//Если есть аналогичный символ в другой раскладке - добавим его в той же позиции
			Аналог = СоответствияСимволов.Получить(ТекСимвол);
			
			Если Аналог = Неопределено Тогда
				СтрокаПоиска = СтрокаПоиска + "" + ТекСимвол + "%";
			Иначе
				СтрокаПоиска = СтрокаПоиска + "[" + ТекСимвол + Аналог + "]%";
			КонецЕсли;
			
			СтрокаПодсчетаВхождения = СтрокаПодсчетаВхождения + ТекСимвол;
		КонецЦикла;
		
		Если СтруктураПоиска.Свойство("Владелец") Тогда
			Владелец = СтруктураПоиска.Владелец;
		КонецЕсли;
		
		//Проверка на наличие реквизита "Владелец" у справочника
		ОтборПоВладельцу = "";
		Если Метаданные.Справочники[ИмяСправочника].Владельцы.Количество() > 0 И Владелец <> Неопределено Тогда
			Если ТипЗнч(Владелец) = Тип("Строка") Тогда
				ОтборПоВладельцу = "И ИсходныйСправочник.Владелец.Наименование = &Владелец ";
			Иначе
				ОтборПоВладельцу = "И ИсходныйСправочник.Владелец = &Владелец ";
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаПоиска) Тогда
			СтрокаПоиска = "%" + СтрокаПоиска;
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	ИсходныйСправочник.Ссылка КАК Ссылка,
						   |	ИсходныйСправочник.Наименование КАК Представление,
						   |	ИсходныйСправочник.Артикул КАК Артикул,
			               |	0 КАК ПроцентВхождения
			               |ИЗ
			               |	Справочник." + ИмяСправочника + " КАК ИсходныйСправочник
			               |ГДЕ
			               |	ИсходныйСправочник.Артикул ПОДОБНО &СтрокаПоиска " + ОтборПоВладельцу;
			Запрос.УстановитьПараметр("СтрокаПоиска",СтрокаПоиска);
			
			//Проверка на наличие реквизита "Владелец" у справочника
			Если ОтборПоВладельцу <> "" И Владелец <> Неопределено Тогда
				Запрос.УстановитьПараметр("Владелец",Владелец);
			КонецЕсли;
						
			Таблица = Запрос.Выполнить().Выгрузить();
	
			Для Каждого СтрокаТаблицы Из Таблица Цикл
				СтрокаТаблицы.ПроцентВхождения = ПодсчитатьПроцентВхождения(СтрокаПодсчетаВхождения,СтрокаТаблицы.Артикул);
				СтрокаТаблицы.Представление = "[" + СтрокаТаблицы.ПроцентВхождения + "%] " + СтрокаТаблицы.Представление + " [А]";
			КонецЦикла;
			
			Таблица.Сортировать("ПроцентВхождения УБЫВ");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Таблица <> Неопределено И Таблица.Количество() > 0 Тогда
		Результат.Ссылка = Таблица[0].Ссылка;
		Результат.ПроцентВхождения = Таблица[0].ПроцентВхождения;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция СимволАртикулаСоответствуетШаблону(Символ)
	ИсключаемыеСимволы = " -,.?/\|";
	Возврат Найти(ИсключаемыеСимволы,Символ) = 0;
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьСоответствияКириллицыЛатиницы()
	
	//Артикул с буквами, имеющими одинаковое написание в латинице и кириллице, может быть распознан в раскладке,
	//отличающейся от той, в которой он был введен в 1с, сформируем варинты возможных написаний артикула:
	//E,T,O,P,A,H,K,X,C,B,M
	//e,y,o,p,a,x,c
	
	Соответствия = Новый Соответствие;
	Соответствия.Вставить("E","Е");
	Соответствия.Вставить("T","Т");
	Соответствия.Вставить("O","О");
	Соответствия.Вставить("P","Р");
	Соответствия.Вставить("A","А");
	Соответствия.Вставить("H","Н");
	Соответствия.Вставить("K","К");
	Соответствия.Вставить("X","Х");
	Соответствия.Вставить("C","С");
	Соответствия.Вставить("B","В");
	Соответствия.Вставить("M","М");
	Соответствия.Вставить("e","е");
	Соответствия.Вставить("y","у");
	Соответствия.Вставить("o","о");
	Соответствия.Вставить("p","р");
	Соответствия.Вставить("a","а");
	Соответствия.Вставить("x","х");
	Соответствия.Вставить("c","с");
	
	//Также предусмотрим обратную ситуацию
	Для Каждого ЭлементСоответствия Из Соответствия Цикл
		Соответствия.Вставить(ЭлементСоответствия.Значение,ЭлементСоответствия.Ключ);
	КонецЦикла;
	
	Возврат Соответствия;
	
КонецФункции

&НаКлиенте
Процедура УстановитьТипНоменклатурыВыделеннымСтрокам(Команда) Экспорт
	
	Значение = СтрЗаменить(Команда.Имя,"ТипНоменклатуры_","");
	
	Для Каждого ИдентификаторСтроки Из Элементы.ЗагружаемыеОбъекты.ВыделенныеСтроки Цикл
		ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ТекСтрока.ТипОбъекта = "Номенклатура" Тогда
			ОбработатьВыборЗначенияИзСписка(Новый Структура("Значение",Значение),Новый Структура("ИдентификаторСтроки",ИдентификаторСтроки));
			СчетаУчета_ЗаполнитьСчетаУчетаВСтрокеНоменклатуры(ТекСтрока);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьМаркерНоменклатуры(Команда) Экспорт
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда		
		Если ТекСтрока.ТипОбъекта = "Номенклатура" И ЗначениеЗаполнено(ТекСтрока.ПредставлениеОбъекта) Тогда
			
			НовыйМаркер = Новый Структура;
			НовыйМаркер.Вставить("Маркер",ТекСтрока.ПредставлениеОбъекта);
			НовыйМаркер.Вставить("Номенклатура",ТекСтрока.Объект1с);
			
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
			ПараметрыОткрытия.Вставить("СтруктураНастроек",СтруктураНастроек);
			ПараметрыОткрытия.Вставить("ПрефиксИмениФорм",ПрефиксИмениФорм);
			ПараметрыОткрытия.Вставить("НовыйМаркер",НовыйМаркер);			
			
			ФормаСопоставлений = ПолучитьФорму(ПрефиксИмениФорм + "УФ_РедактированиеСопоставлений", ПараметрыОткрытия, ВладелецФормы);
			ФормаСопоставлений.Открыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

