	Иначе
		ДанныеВыбора = Новый СписокЗначений;
		Выборка = Справочники.КлассификаторЕдиницИзмерения.Выбрать();
		Пока Выборка.Следующий() Цикл
			ДанныеВыбора.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДанныеВыбора;
	
КонецФункции
&НаСервере
Функция ПолучитьСсылку_УпаковкаЕдиницаИзмерения(ДопПараметры)
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	ТекСтрока = Объект.ЗагружаемыеОбъекты.НайтиПоИдентификатору(ДопПараметры.ИдентификаторСтроки);
	ДанныеНоменклатурыПортала = ДанныеПортала.documentItems.Найти(ТекСтрока.ИдентификаторОбъекта,"Id");
	
	Если ЗначениеЗаполнено(ТекСтрока.Объект1с) Тогда
		ДанныеНоменклатурыПортала.НоменклатураСсылка = ТекСтрока.Объект1с;
	КонецЕсли;
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Номенклатура_ЕдиницаИзмерения = РеквизитОбъект.ПолучитьСсылку_УпаковкаЕдиницаИзмерения(ДанныеНоменклатурыПортала,СтруктураНастроек);
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
	Возврат Номенклатура_ЕдиницаИзмерения;
	
КонецФункции

