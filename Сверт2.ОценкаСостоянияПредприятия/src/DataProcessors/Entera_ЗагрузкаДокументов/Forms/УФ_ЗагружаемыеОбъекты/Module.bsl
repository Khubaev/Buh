&НаСервереБезКонтекста
Функция ПолучитьДанныеВыбора_ТабличныеЧастиДокумента(ТипСоздаваемогоДокумента)
	
	СписокТЧ = Новый СписокЗначений;
	
	Для Каждого ИмяТЧ Из Метаданные.Документы[ТипСоздаваемогоДокумента].ТабличныеЧасти Цикл
		СписокТЧ.Добавить(ИмяТЧ.Имя,ИмяТЧ.Синоним);
	КонецЦикла;
	
	Возврат СписокТЧ;
	
КонецФункции

&НаКлиенте
Процедура Документ_ОбъектРасчетовНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ОбъектРасчетов = ПредопределенноеЗначение("Справочник.ОбъектыРасчетов.ПустаяСсылка");
	
	ТекСтрока = Элементы.ЗагружаемыеОбъекты.ТекущиеДанные;
	Если ТекСтрока <> Неопределено Тогда
		ОбъектРасчетов = ТекСтрока.Документ_ОбъектРасчетов;
		Сумма = ТекСтрока.Документ_Сумма;
		
		СтрокиКонтрагента = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Контрагенты",ТекСтрока.ДокументИД));
		Если СтрокиКонтрагента.Количество() > 0 Тогда
			Контрагент = СтрокиКонтрагента[0].Объект1с;
			Партнер = СтрокиКонтрагента[0].Контрагенты_Партнер;
		КонецЕсли;
		
		СтрокиОрганизации = Объект.ЗагружаемыеОбъекты.НайтиСтроки(Новый Структура("ТипОбъекта,ДокументИД","Организации",ТекСтрока.ДокументИД));
		Если СтрокиОрганизации.Количество() > 0 Тогда
			Организация = СтрокиОрганизации[0].Объект1с;
		КонецЕсли;
		
	КонецЕсли;
	
	ЗначенияОтбора = Новый Структура;
	Если ЗначениеЗаполнено(Организация) Тогда
		ЗначенияОтбора.Вставить("Организация",Организация);
	КонецЕсли;
	Если ЗначениеЗаполнено(Контрагент) Тогда
		ЗначенияОтбора.Вставить("Контрагент",Контрагент);
	КонецЕсли;
	Если ЗначениеЗаполнено(Партнер) Тогда
		ЗначенияОтбора.Вставить("Партнер",Партнер);
	КонецЕсли;
	
	НастройкиВыбора = Новый Структура;
	НастройкиВыбора.Вставить("УчитыватьФилиалы", Истина);
	НастройкиВыбора.Вставить("ВыборОснованияПлатежа", Ложь);
	НастройкиВыбора.Вставить("РедактируемыйДокумент", Неопределено);
	НастройкиВыбора.Вставить("Сумма", Сумма);
	НастройкиВыбора.Вставить("Отбор", ЗначенияОтбора);
	
	Если ОбъектРасчетов <> Неопределено Тогда
		НастройкиВыбора.Вставить("ТекущееЗначение", ОбъектРасчетов);
	КонецЕсли;
	
	ОткрытьФорму("Справочник.ОбъектыРасчетов.Форма.ФормаВыбора", НастройкиВыбора, Элемент);
	
КонецПроцедуры

