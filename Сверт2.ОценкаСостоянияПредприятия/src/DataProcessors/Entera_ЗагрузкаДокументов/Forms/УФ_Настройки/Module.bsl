// ================= Обмен настройками с порталом ===================

&НаКлиенте
Процедура ОбменНастройками_ОбновитьНастройкиРаспознавания(ИдентификаторПространства,НовыеНастройки) Экспорт
	
	Если ЗначениеЗаполнено(ИдентификаторПространства) Тогда
		Если ИдентификаторПространства = "ПустоеПространство" Тогда
			Возврат;
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
	
	ТекущиеНастройкиПортала = recognitionSettings.Получить(ИдентификаторПространства);
		
	Если ТипЗнч(ТекущиеНастройкиПортала) = Тип("Структура") Тогда
		ТекущиеНастройкиПортала.Вставить("kppParse","true"); //+++ Пока так, не вижу смысла на стороне 1с отключать парсинг КПП контрагента
		ТекущиеНастройкиПортала.Вставить("customsDeclarationParse",?(НовыеНастройки.ЗаполнениеТЧ_ЗаполнятьДанныеГТД,"true","false"));
		ТекущиеНастройкиПортала.Вставить("hasTransferBase",?(НовыеНастройки.ЗаполнениеШапки_ИспользоватьДанныеОснованияДляДоговора,"true","false"));
		
		ОбменНастройками_ОтправитьНастройкиНаПортал(ИдентификаторПространства,ТекущиеНастройкиПортала);
	КонецЕсли;
		
КонецПроцедуры
&НаКлиенте
Функция ОбменНастройками_ОтправитьНастройкиНаПортал(ИдентификаторПространства,recognitionSettings)
	
	//Настройки портала содержат информацию о полях, которые нужно парсить
	//
	// PUT /api/v1/spaces/:id/recognitionSettings 
	//"kppParse" : false,
	//"exciseParse": false,
	//"customsDeclarationParse": false
	
	//E1C-484: При пользовательском изменении значения настройки "Заполнять в документе данные основания передачи" в модуле:
	//Если устанавливаем значение "Да", то на портал по данному пространству передается флаг hasTransferBase =TRUE для типов УПД, ТОРГ-12, Акт, счет.
	//Также теперь используем PATCH, передавая захардкоженную коллекцию перечисленных в задаче типов документов,
	//для который будет устанавливаться признак распознавания данных договора документа
	// PATCH /api/v1/spaces/:id/recognitionSettings
	РаспознаваниеДанныхОснования = """tableParseByType"": {
       |""UTD"": {
       |""hasTransferBase"": " + recognitionSettings.hasTransferBase + "},
	   |""TORG12"": {
       |""hasTransferBase"": " + recognitionSettings.hasTransferBase + "},
	   |""OFFER"": {
	   |""hasTransferBase"": " + recognitionSettings.hasTransferBase + "},
       |""CERTIFICATE"": {
	   |""hasTransferBase"": " + recognitionSettings.hasTransferBase + "}
	   |}";
	
	//формируем тело запроса с настройками
	ТелоЗапроса = "{" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """kppParse"": " + recognitionSettings.kppParse + "," + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """customsDeclarationParse"": " + recognitionSettings.customsDeclarationParse + "," + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + РаспознаваниеДанныхОснования;
	ТелоЗапроса = ТелоЗапроса + "}";
	
	МетодAPI = "/api/v1/spaces/" + ИдентификаторПространства + "/recognitionSettings?format=xml";
	РезультатЗапроса = ВладелецФормы.ВыполнитьЗапрос("ОбновлениеНастроекРаспознавания","PATCH",МетодAPI,ТелоЗапроса);
	
	Если РезультатЗапроса.Успешно Тогда
		
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = ВладелецФормы.УникальныйИдентификатор;
		Сообщение.Текст = РезультатЗапроса.ТекстОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецФункции


// ================= Подключение модуля кастомизации ===================

&НаСервере
Функция МодульКастомизации_ПолучитьДанныеОбработки(ОбработкаСсылка)
	
	Результат = Новый Структура("Успешно,ТекстОшибки,АдресВХ",Ложь,"");
	
	Попытка
		ОбработкаОбъект = ОбработкаСсылка.ПолучитьОбъект();
		
		//У БИТ.Стоматология реквизит хранилища внешней обработки - ХранилищеВнешнейОбработки
		Если ОбработкаСсылка.Метаданные().Реквизиты.Найти("ХранилищеВнешнейОбработки") <> Неопределено Тогда
			ДвоичныеДанные = ОбработкаОбъект.ХранилищеВнешнейОбработки.Получить();
		Иначе
			ДвоичныеДанные = ОбработкаОбъект.ХранилищеОбработки.Получить();
		КонецЕсли;
		
		Результат.АдресВХ = ПоместитьВоВременноеХранилище(ДвоичныеДанные,Новый УникальныйИдентификатор);		
		Результат.Успешно = Истина;		
	Исключение
		Результат.ТекстОшибки = "При подключении модуля кастомизации произошла ошибка: " + ОписаниеОшибки();
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции
&НаСервере
Процедура МодульКастомизации_ТестовоеПолучениеДанныхОбработки()
	
	//Комментарий для аудитора: Для Фреш не выполняется подключение дополнительной внешней обработки "Модуль кастомизации",
	//реквизит ЭтоФреш определяется в процедуре ПриСозданииНаСервере Владельца этой формы
	Если ЭтоФреш Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	ВременнаяСтруктураНастроек = ПолучитьСтруктуруНастроекНаСервере();
	
	ПолучениеМК = РеквизитОбъект._УФ_МодульКастомизации_Получить(ВременнаяСтруктураНастроек);
	
КонецПроцедуры
