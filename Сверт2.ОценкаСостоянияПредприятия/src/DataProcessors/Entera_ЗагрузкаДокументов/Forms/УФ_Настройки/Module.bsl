
// ================= _ЗФ_УФ_ ===================

&НаКлиенте
Функция _ЗФ_ОбработатьАсинхронныйВызов(ТипВызова,ПараметрыВызова)
	
	//Для реализации возможности открытия этой формы внешней обработке на платформах, не поддерживающих ОписаниеОповещения,
	//(не будет пройден синтаксический контроль), обработчики асинхронных вызовов вынесены в эту процедуру.
	//Для прохождения аудита 1С:Фреш эта процедура заменяется на аналогичную, но без методов Вычислить(). Profit!
	
	Если ТипВызова = "Вопрос" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВопрос(ОписаниеОповещения,ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		Иначе
			Вопрос(ПараметрыВызова.ТекстВопроса,ПараметрыВызова.Кнопки);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВыборИзМеню" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			
			ЭлементФормы = Неопределено;
			ПараметрыВызова.ДопПараметры.Свойство("ЭлементФормы",ЭлементФормы);
			
			ПоказатьВыборИзМеню(ОписаниеОповещения,ПараметрыВызова.СписокВыбора,ЭлементФормы);
		Иначе
			ВыбратьИзМеню(ПараметрыВызова.СписокВыбора);
		КонецЕсли;
		
	ИначеЕсли ТипВызова = "ВводСтроки" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПоказатьВводСтроки(ОписаниеОповещения,ПараметрыВызова.Строка,ПараметрыВызова.Подсказка,ПараметрыВызова.Длина,ПараметрыВызова.Многострочность);
		Иначе
			ВвестиСтроку(ПараметрыВызова.Строка,ПараметрыВызова.Подсказка,ПараметрыВызова.Длина,ПараметрыВызова.Многострочность);
		КонецЕсли;
	
	ИначеЕсли ТипВызова = "ПоместитьФайлы" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещенияНачало = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова_3Параметра"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваНачало)");
			ОписаниеОповещенияОкончание = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова.ПараметрыВызоваЗавершение)");
			НачатьПомещениеФайлов(ОписаниеОповещенияОкончание,,Истина,УникальныйИдентификатор,ОписаниеОповещенияНачало);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
				
	ИначеЕсли ТипВызова = "ДиалогВыбораФайла" Тогда
		Если ДоступноОписаниеОповещения Тогда
			ОписаниеОповещения = Вычислить("Новый ОписаниеОповещения(""ОбработатьРезультатАсинхронногоВызова"",ЭтаФорма,ПараметрыВызова)");
			ПараметрыВызова.ДиалогВыбораФайла.Показать(ОписаниеОповещения);
		Иначе
			ПоместитьФайлы(ПараметрыВызова.ПомещаемыеФайлы,Истина,УникальныйИдентификатор);
		КонецЕсли;
		          
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ОбработатьРезультатАсинхронногоВызова_3Параметра(Результат,Отказ,ПараметрыВызова) Экспорт
	Если ПараметрыВызова.Обработчик = "ОбработатьНачалоВыбораФайлов_ВебКлиент" Тогда
		ОбработатьНачалоВыбораФайлов_ВебКлиент(Результат,Отказ,ПараметрыВызова.ДопПараметры);
	КонецЕсли;	
КонецФункции
&НаКлиенте
Функция ОбработатьРезультатАсинхронногоВызова(Результат,ПараметрыВызова) Экспорт
		
	//Сюда в условия переносятся все присутствующие в форме обработчики результатов асинхронных вызовов
	Если ПараметрыВызова.Обработчик = "ОбработатьВыборИзМеню_ЭкспортИмпорт" Тогда
		ОбработатьВыборИзМеню_ЭкспортИмпорт(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Продолжить_НастройкиСброс" Тогда
		Продолжить_НастройкиСброс(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборФайлов" Тогда
		ОбработатьВыборФайлов(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВыборФайлов_ВебКлиент" Тогда
		ОбработатьВыборФайлов_ВебКлиент(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "ОбработатьВводЗначенияСтроки" Тогда
		ОбработатьВводЗначенияСтроки(Результат,ПараметрыВызова.ДопПараметры);
		
	ИначеЕсли ПараметрыВызова.Обработчик = "Заглушка_ОписаниеОповещения" Тогда
		//Ничего не выполняем
		
	КонецЕсли;
	
КонецФункции


// ================= События формы ===================

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Пространство",Пространство);
	Параметры.Свойство("РегионПространства",РегионПространства);
	Параметры.Свойство("ПрефиксИмениФорм",ПрефиксИмениФорм);
	Параметры.Свойство("ДоступноОписаниеОповещения",ДоступноОписаниеОповещения);
	Параметры.Свойство("ВладелецФормыУникальныйИдентификатор",ВладелецФормыУникальныйИдентификатор);
	Параметры.Свойство("ЭтоФреш",ЭтоФреш);
	Параметры.Свойство("ЭтоРасширениеКонфигурации",ЭтоРасширениеКонфигурации);
	
	//2019.09.09 (
	Если Параметры.Свойство("recognitionSettings")
		И ТипЗнч(Параметры.recognitionSettings) <> Неопределено Тогда
		НастройкиПортала = Параметры.recognitionSettings;
	Иначе
		НастройкиПортала = Новый Соответствие;
	КонецЕсли;
	
	Если ТипЗнч(НастройкиПортала) = Тип("ФиксированноеСоответствие") Тогда
		recognitionSettings = НастройкиПортала;
	Иначе
		recognitionSettings = Новый ФиксированноеСоответствие(НастройкиПортала);
	КонецЕсли;
	// ) 2019.09.09
	
	Если Параметры.Свойство("ИсходнаяСтруктураНастроек") Тогда
		ИсходнаяСтруктураНастроек = Параметры.ИсходнаяСтруктураНастроек;
	Иначе
		ИсходнаяСтруктураНастроек = Новый Структура;
	КонецЕсли;		
	
	// Построить дерево настроек из макета ШаблонНастроек, заполнить их сохраненными пользовательскими,
	//если не нашли - следует предзаполнить для него значения по умолчанию
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	Дерево = РеквизитФормыВЗначение("ДеревоНастроек");	
	РеквизитОбъект.ЗаполнитьДеревоНастроек(Дерево,Пространство,,recognitionSettings);
	ЗначениеВРеквизитФормы(Дерево,"ДеревоНастроек");
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Для Каждого Строка ИЗ ДеревоНастроек.ПолучитьЭлементы() Цикл
    	Элементы.ДеревоНастроек.Развернуть(Строка.ПолучитьИдентификатор(), Истина);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Пространство) Тогда
		ИмяПространства = " (" + ВладелецФормы.Элементы.Отбор_Пространство.СписокВыбора.НайтиПоЗначению(Пространство).Представление + ")";
	Иначе
		ИмяПространства = "";
		Элементы.СохранитьГлобальныеНастройки.Видимость = Ложь;
	КонецЕсли;
	
	Заголовок = "Настройки" + ИмяПространства;
	
	//Идентификатор владельца формы для передачи сообщений пользователю в основную форму
	ВладелецФормыУникальныйИдентификатор = ВладелецФормы.УникальныйИдентификатор;
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура СохранитьНастройки(Команда)
	
	// 2019.01.30 (EN-196: не выдавать запрос на сохранение глобальных настроек	
	РезультатСохранения = СохранитьНастройкиНаСервере(СохранитьГлобальныеНастройки);
		
	Если РезультатСохранения.Успешно Тогда
		
		//2025.11.17 ( Отправляем настройки только если изменились контролируемые значения
		Если ИсходнаяСтруктураНастроек.ЗаполнениеШапки_ИспользоватьДанныеОснованияДляДоговора <> РезультатСохранения.СтруктураНастроек.ЗаполнениеШапки_ИспользоватьДанныеОснованияДляДоговора
			Или ИсходнаяСтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеГТД <> РезультатСохранения.СтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеГТД Тогда
		// ) 2025.11.17
			//обновим настройки распознавания на портале
			ОбменНастройками_ОбновитьНастройкиРаспознавания(Пространство,РезультатСохранения.СтруктураНастроек);
		КонецЕсли;
		
		РезультатСохранения.Вставить("recognitionSettings",recognitionSettings);
		
		// 2019.11.15 ( Если установили флаг работы с одной номенклатурой в табличной части,
		//проверим, что она заполнена и очистим список документов формы-владельца
		Если ИсходнаяСтруктураНастроек.Свойство("ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку")
			И РезультатСохранения.СтруктураНастроек.Свойство("ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку")
			И РезультатСохранения.СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку <> ИсходнаяСтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку Тогда
			РезультатСохранения.Вставить("ОчиститьСписокДокументов",Истина);
			
		//2021.06.05 ( Если был включен-выключен исходящий электронный документооборот - тоже перезаполняем	
		ИначеЕсли ИсходнаяСтруктураНастроек.Свойство("ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот")
			И РезультатСохранения.СтруктураНастроек.Свойство("ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот")
			И РезультатСохранения.СтруктураНастроек.ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот <> ИсходнаяСтруктураНастроек.ОбменДанными_ИспользуетсяИсходящийЭлектронныйДокументооборот Тогда
			РезультатСохранения.Вставить("ОчиститьСписокДокументов",Истина);
		// ) 2021.06.05
		
		КонецЕсли;
		// ) 2019.11.15
	Иначе
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = ВладелецФормы.УникальныйИдентификатор;
		Сообщение.Текст = РезультатСохранения.ТекстОшибки;
		Сообщение.Сообщить();
	КонецЕсли;
	
	Оповестить("ЗакрытиеФормы_Настройки",РезультатСохранения);
	ЭтаФорма.Закрыть();
	// ) 2019.01.30
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруНастроекНаСервере(АдресДереваНастроек = Неопределено) Экспорт
	
	РеквизитОбъект = РеквизитФормыВЗначение("Объект");
	
	//Адрес уже заполненного дерева настроек может быть передан из формы стартового помощника
	Если АдресДереваНастроек = Неопределено Тогда
		Дерево = РеквизитФормыВЗначение("ДеревоНастроек");
	Иначе
		Дерево = ПолучитьИзВременногоХранилища(АдресДереваНастроек);
	КонецЕсли;
		
	СтрокиНастроек = Дерево.Строки.НайтиСтроки(Новый Структура("ЭтоГруппа",Ложь),Истина);
	
	СтруктураНастроек = Новый Структура;
	
	ДоступныеТипы = Новый СписокЗначений;
	
	Для Каждого СтрокаНастройки Из СтрокиНастроек Цикл
		СтруктураНастроек.Вставить(СтрокаНастройки.НастройкаИД,СтрокаНастройки.Значение);
		
		//2019.01.30 ( для Номенклатуры нужно позволить пользователю выбирать тип каждой создаваемой Товар/Услуга
		Если СтрокаНастройки.НастройкаИД = "Номенклатура_ТипНоменклатурыТоварУслуга" Тогда
			СтруктураНастроек.Вставить("Номенклатура_ТипНоменклатурыТоварУслуга_СписокВыбора",СтрокаНастройки.СписокВыбора);
		КонецЕсли;
		// ) 2019.01.30
		
		//2019.02.24 (
		Если СтрокаНастройки.НастройкаИД = "ТипДокумента_Поступление" Тогда
			ДоступныеТипы = ЗначениеИзСтрокиВнутрСервер(СтрокаНастройки.СписокВыбора);
		КонецЕсли;
		// ) 2019.02.24
	КонецЦикла;
	
	//2018.12.25 ( если узел не заполнен - поищем существующий
	Если СтруктураНастроек.Свойство("ОбменДанными_УзелОбменаНоменклатурой")
		И Не ЗначениеЗаполнено(СтруктураНастроек.ОбменДанными_УзелОбменаНоменклатурой) Тогда
		Попытка
			СтруктураНастроек.ОбменДанными_УзелОбменаНоменклатурой = РеквизитОбъект.ПолучитьСсылку_УзелОбменаНоменклатурой(Ложь).Ссылка;
		Исключение
			СообщитьСообщение("Ошибка при получении узла обмена <Entera>:" + Символы.ПС + ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	// ) 2018.12.25
	
	//2019.02.08 ( Если вид номенклатуры не заполнен - предзаполним найденным по наименованию
	Если Метаданные.Справочники.Найти("ВидыНоменклатуры") <> Неопределено Тогда
		Если Не ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар) Тогда
			СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюТовар = ПолучитьВидНоменклатурыПоНаименованию("Товар");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга) Тогда
			СтруктураНастроек.Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга = ПолучитьВидНоменклатурыПоНаименованию("Услуг");
		КонецЕсли;
	КонецЕсли;
	// ) 2019.02.08
	
	//сведения о конфигурации и об используемых обработкой типах в ней
	СведенияОКонфигурации = ПолучитьСведенияОТекущейКонфигурации();
	СтруктураНастроек.Вставить("СведенияОКонфигурации",СведенияОКонфигурации);
	СтруктураНастроек.Вставить("ЭтоФреш",ЭтоФреш);
		
	//для ряда конфигураций используем хранение связей в своей таблице в ХранилищеОбщихНастроек
	Если СтруктураНастроек.СведенияОКонфигурации.ХранениеСвязиДокументов_СвояТаблица <> Истина Тогда
	
		//добавим в структуру ссылки на доп. свойства для хранения идентификаторов портала
		СтруктураДопСведений = ПолучитьСтруктуруДопСведенийСвязиОбъектов();
		Для Каждого ЭлементСтруктуры Из СтруктураДопСведений Цикл
			СтруктураНастроек.Вставить(ЭлементСтруктуры.Ключ,ЭлементСтруктуры.Значение);
		КонецЦикла;
	КонецЕсли;
	
	//Статусы Диадок
	Диадок_СоответствиеСтатусов = РеквизитОбъект.Диадок_ИнициализироватьСоответствияСтатусов();
	СтруктураНастроек.Вставить("Диадок_СоответствиеСтатусов",Диадок_СоответствиеСтатусов);
	
	//Статусы СБИС
	СБИС_СоответствиеСтатусов = РеквизитОбъект.СБИС_ИнициализироватьСоответствияСтатусов();
	СтруктураНастроек.Вставить("СБИС_СоответствиеСтатусов",СБИС_СоответствиеСтатусов);
	
	//Словарь синонимов единиц измерения
	СловарьСинонимовЕИ = РеквизитОбъект.Классификатор_ИнициализироватьСоответствияСинонимовЕдиницИзмерения();
	СтруктураНастроек.Вставить("СловарьСинонимовЕИ",СловарьСинонимовЕИ);
	
	
	//2019.02.24 ( на портале появились новые типы, предзаполним их, если пользователь еще не установил свои значения
	Если Не ЗначениеЗаполнено(СтруктураНастроек.ТипДокумента_Поступление) Тогда
		СтруктураНастроек.ТипДокумента_Поступление = СведенияОКонфигурации.ДокументПоступления;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтруктураНастроек.ТипДокумента_Акт) Тогда
		СтруктураНастроек.ТипДокумента_Акт = СведенияОКонфигурации.ДокументПоступления;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтруктураНастроек.ТипДокумента_Счет) Тогда
		СтруктураНастроек.ТипДокумента_Счет = СведенияОКонфигурации.ДокументПоступления;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтруктураНастроек.ТипДокумента_Чек) Тогда
		СтруктураНастроек.ТипДокумента_Чек = СведенияОКонфигурации.ДокументПоступления;
	КонецЕсли;
	// ) 2019.02.24
	
	//2019.09.16 ( Заполнение реквизита табличной части ОтражениеВУСН
	Если СтруктураНастроек.ЗаполнениеТЧ_РасходыНУПринимаютсяНеПринимаются = "" Тогда
		ОтражениеВУСН = Неопределено;
		
	ИначеЕсли СтруктураНастроек.ЗаполнениеТЧ_РасходыНУПринимаютсяНеПринимаются = "Принимаются" Тогда
		Если РеквизитОбъект.РеквизитСуществует("Перечисления","ОтражениеВУСН","Принимаются") Тогда
			ОтражениеВУСН = Перечисления.ОтражениеВУСН.Принимаются;
		КонецЕсли;
		
	ИначеЕсли СтруктураНастроек.ЗаполнениеТЧ_РасходыНУПринимаютсяНеПринимаются = "Не принимаются" Тогда
		Если РеквизитОбъект.РеквизитСуществует("Перечисления","ОтражениеВУСН","НеПринимаются") Тогда
			ОтражениеВУСН = Перечисления.ОтражениеВУСН.НеПринимаются;
		КонецЕсли;
		
	КонецЕсли;
	СтруктураНастроек.Вставить("ЗаполнениеТЧ_ОтражениеВУСН",ОтражениеВУСН);
	// ) 2019.09.16
	
	//2019.05.21 ( модуль кастомизации
	Если ЗначениеЗаполнено(СтруктураНастроек.СистемныеНастройки_ДополнительныйМодульКастомизации) Тогда
		ПолучениеМК = МодульКастомизации_ПолучитьДанныеОбработки(СтруктураНастроек.СистемныеНастройки_ДополнительныйМодульКастомизации);
		
		Если ПолучениеМК.Успешно Тогда
			ДанныеОбработки = ПолучениеМК.АдресВХ;
		Иначе
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = ПолучениеМК.ТекстОшибки;
			Сообщение.Сообщить();
		КонецЕсли;
		
	КонецЕсли;
	СтруктураНастроек.Вставить("АдресХранилищаДвоичныхДанныхМодуляКастомизации",ДанныеОбработки);
	// ) 2019.05.21
	
	СписокТипов = ЗначениеИзСтрокиВнутр(СтруктураНастроек.Номенклатура_ТипНоменклатурыТоварУслуга_СписокВыбора);
	
	//E1C-4: Создание документов доп. расходов: отключим возможность такого выбора при отсутствии такой необходимости
	Если Не СтруктураНастроек.Свойство("ТипДокумента_ВыбиратьУслугиДляДопРасходов")
		Или СтруктураНастроек.ТипДокумента_ВыбиратьУслугиДляДопРасходов <> Истина Тогда
		//Удалим из списка доступных типов номенклатуры Расходы
		НайденныйЭлемент = СписокТипов.НайтиПоЗначению("Расходы");
		Если НайденныйЭлемент <> Неопределено Тогда
			СписокТипов.Удалить(НайденныйЭлемент);
		КонецЕсли;
	КонецЕсли;
	
	//E1C-257: Агентские услуги
	Если Не СтруктураНастроек.Свойство("ТипДокумента_ИспользуютсяАгентскиеУслуги")
		Или СтруктураНастроек.ТипДокумента_ИспользуютсяАгентскиеУслуги <> Истина Тогда
		//Удалим из списка доступных типов номенклатуры Агентские услуги
		НайденныйЭлемент = СписокТипов.НайтиПоЗначению("АгентскиеУслуги");
		Если НайденныйЭлемент <> Неопределено Тогда
			СписокТипов.Удалить(НайденныйЭлемент);
		КонецЕсли;
	КонецЕсли;
	
	СтруктураНастроек.Вставить("Номенклатура_ТипНоменклатурыТоварУслуга_СписокВыбора",ЗначениеВСтрокуВнутр(СписокТипов));
	
	
	//E1C-79: добавлен поиск по справочнику Номенклатура поставщиков. Если в конфигурации нет справочника НоменклатураПоставщиков/НоменклатураКонтрагентов,
	//то флаг этой настройки всегда должен быть Ложь
	Если СтруктураНастроек.Номенклатура_ИспользоватьНоменклатуруПоставщиков = Истина
		И Метаданные.Справочники.Найти("НоменклатураПоставщиков") = Неопределено
		И Метаданные.Справочники.Найти("НоменклатураКонтрагентов") = Неопределено 
		И Метаданные.Справочники.Найти("Тренд_НоменклатураКонтрагентов") = Неопределено Тогда
		
		СтруктураНастроек.Номенклатура_ИспользоватьНоменклатуруПоставщиков = Ложь;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.ИдентификаторНазначения = Новый УникальныйИдентификатор(ВладелецФормыУникальныйИдентификатор);
		Сообщение.Текст = "В конфигурации отсутствует справочник <Номенклатура поставщиков/контрагентов>, настройка работы с этим справочником была отключена";
		Сообщение.Сообщить();
	КонецЕсли;
	
	//E1C-421: регион пространства добавим в структуру настроек
	СтруктураНастроек.Вставить("РегионПространства",РегионПространства);
	
	//Актуальную структуру помещаем в хранилище для работы с ними внешней печатной формы
	ХранилищеОбщихНастроек.Сохранить("Entera_ВнешняяПечатнаяФорма","СтруктураНастроек",СтруктураНастроек);
			
	Возврат СтруктураНастроек;
	
КонецФункции
&НаСервере
Функция СохранитьНастройкиНаСервере(СохранитьГлобальныеНастройки = Ложь,НоваяСтруктураНастроек = Неопределено) Экспорт
	
	РезультатСохранения = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	//Новая структура настроек может быть передан из формы стартового помощника
	Если НоваяСтруктураНастроек = Неопределено Тогда
		НоваяСтруктураНастроек = ПолучитьСтруктуруНастроекНаСервере();
	КонецЕсли;
	
	//2018.12.19 (	
	ПолнаяСтруктураНастроек = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","ОбщиеНастройки");
	
	ИмяПространства = ?(ЗначениеЗаполнено(Пространство),Пространство,"ПустоеПространство");
		
	Если ПолнаяСтруктураНастроек = Неопределено Тогда
		ПолнаяСтруктураНастроек = Новый Соответствие;
		
	ИначеЕсли ТипЗнч(ПолнаяСтруктураНастроек) = Тип("Структура") Тогда
		ПолнаяСтруктураНастроек = Новый Соответствие;
		
	ИначеЕсли ТипЗнч(ПолнаяСтруктураНастроек) = Тип("Соответствие") Тогда
		
	КонецЕсли;
	
	ПолнаяСтруктураНастроек.Вставить(ИмяПространства,НоваяСтруктураНастроек);
			
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","ОбщиеНастройки",ПолнаяСтруктураНастроек);
	// ) 2018.12.19
	
	//Сохраняем избранные настройки
	Дерево = РеквизитФормыВЗначение("ДеревоНастроек");
	СтрокиИзбранное = Дерево.Строки.НайтиСтроки(Новый Структура("Избранное",1),Истина);
	
	ИзбранныеНастройки = Новый Структура;
	Для Каждого СтрокаИзбранное Из СтрокиИзбранное Цикл 
		ИзбранныеНастройки.Вставить(СтрокаИзбранное.НастройкаИД);
	КонецЦикла;
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","ИзбранныеНастройки",ИзбранныеНастройки);
	
		
	Если СохранитьГлобальныеНастройки = Истина Тогда
		
		//Сохраняем текущее пространство для выгрузки номенклатуры регламентным заданием
		НоваяСтруктураНастроек.Вставить("Пространство",Пространство);
		
		Попытка
			ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","ОбщиеНастройки",НоваяСтруктураНастроек,,"Entera");
		Исключение
			РезультатСохранения.Успешно = Ложь;
			РезультатСохранения.ТекстОшибки = ОписаниеОшибки();
		КонецПопытки;
	КонецЕсли;
	
	РезультатСохранения.Вставить("СтруктураНастроек",НоваяСтруктураНастроек);
	
	Возврат РезультатСохранения;
	
КонецФункции


// ================= Работа с элементов дерева настроек ===================

&НаКлиенте
Процедура ДеревоНастроекПриАктивизацииСтроки(Элемент)
	
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
	
	//Раньше был ПоказатьВыборИзМеню(СписокВыбора), но с целью избавления от ОписаниеОповещения
	//переделано на заполнение СпискаВыбора элемента
	Элементы.ДеревоНастроекЗначение.СписокВыбора.Очистить();
	
	Если ТекСтрока <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(ТекСтрока.СписокВыбора) Тогда
			Элементы.ДеревоНастроекЗначение.РедактированиеТекста = Истина;
			Элементы.ДеревоНастроекЗначение.РежимВыбораИзСписка = Истина;
			
			СписокВыбора = ЗначениеИзСтрокиВнутрСервер(ТекСтрока.СписокВыбора);
			Для Каждого ЭлементСписка Из СписокВыбора Цикл
				
				//E1C-421: Костыль: для KAZ-конфигураций "визуально" предлагаем поиск по ИИН, а не по ИНН, исключаем вариант с КПП
				Если РегионПространства = "KAZ" Тогда
					Если ЭлементСписка.Значение = "ИНН+КПП" Тогда
						Продолжить;
					КонецЕсли;
					ЭлементСписка.Представление = СтрЗаменить(ЭлементСписка.Представление,"ИНН","ИИН");
				КонецЕсли;
				
				НовыйЭлемент = Элементы.ДеревоНастроекЗначение.СписокВыбора.Добавить();
				ЗаполнитьЗначенияСвойств(НовыйЭлемент,ЭлементСписка);
			КонецЦикла;
			
		ИначеЕсли ТекСтрока.ОписаниеТипа = Новый ОписаниеТипов("Строка")
			Или ТекСтрока.ОписаниеТипа = Новый ОписаниеТипов("Число") Тогда
			Элементы.ДеревоНастроекЗначение.РедактированиеТекста = Истина;
			Элементы.ДеревоНастроекЗначение.РежимВыбораИзСписка = Ложь;
			
		Иначе
			Элементы.ДеревоНастроекЗначение.РежимВыбораИзСписка = Ложь;
			Элементы.ДеревоНастроекЗначение.РедактированиеТекста = Ложь;
		КонецЕсли;
		
		//Добавим кнопку выбора для многострочного режима формирования Назначения платежа
		СвойстваЭлемента = Новый Структура;
		
		Если ТекСтрока.НастройкаИД = "ЗаполнениеШапки_ШаблонНазначенияПлатежа" Тогда
			СвойстваЭлемента.Вставить("КнопкаВыбора",Истина);
		Иначе
			СвойстваЭлемента.Вставить("КнопкаВыбора",Неопределено);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(Элементы.ДеревоНастроекЗначение,СвойстваЭлемента);
		
		//2019.04.16 (
		Если ЗначениеЗаполнено(ТекСтрока.ОписаниеТипа) Тогда
			Элементы.ДеревоНастроекЗначение.ОграничениеТипа = ТекСтрока.ОписаниеТипа;
		Иначе
			Элементы.ДеревоНастроекЗначение.ОграничениеТипа = Новый ОписаниеТипов;
		КонецЕсли;
		// ) 2019.04.16
		
		//В УНФ выбор группы выполняется отдельной формой, общей формой выбора группу не выбрать
		Если ТекСтрока.НастройкаИД = "Номенклатура_ГруппаСоздаваемойНоменклатуры"
			Или ТекСтрока.НастройкаИД = "Номенклатура_ГруппаСоздаваемойНоменклатурыУслуги" Тогда
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Группы;
			
		ИначеЕсли ТекСтрока.НастройкаИД = "Номенклатура_СсылкаДляНовойНоменклатурыПоставщика" Тогда
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Элементы;
					
		ИначеЕсли ТекСтрока.НастройкаИД = "Номенклатура_ВидНоменклатурыПоУмолчаниюТовар"
			Или ТекСтрока.НастройкаИД = "Номенклатура_ВидНоменклатурыПоУмолчаниюУслуга" Тогда
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Элементы;
			
		ИначеЕсли ТекСтрока.НастройкаИД = "ЗаполнениеТЧ_СворачиватьТЧНоменклатура" Тогда
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Элементы;
			
		//2020.02.13 ( Добавлен составной тип для выбора группы/списка групп номенклатуры	
		ИначеЕсли ТекСтрока.НастройкаИД = "Номенклатура_ГруппаДляПоискаПохожейНоменклатуры" Тогда
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Группы;
			Если ТекСтрока.Значение = Неопределено Тогда
				ТекСтрока.Значение = Новый СписокЗначений;
			КонецЕсли;
			Если ТипЗнч(ТекСтрока.Значение) = Тип("СписокЗначений") Тогда
				ТекСтрока.Значение.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
			КонецЕсли;
		// ) 2020.02.13
		
		Иначе
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Авто;
		КонецЕсли;	
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
	
	Если Элементы.ДеревоНастроек.ТекущийЭлемент = Элементы.ДеревоНастроекЗначение
		И Элементы.ДеревоНастроек.ТекущиеДанные.ЭтоГруппа Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
		
	Если Элементы.ДеревоНастроек.ТекущийЭлемент = Элементы.ДеревоНастроекИзбранное Тогда
		Если НЕ ТекСтрока.ЭтоГруппа Тогда
			ТекСтрока.Избранное = Число(Не ТекСтрока.Избранное);
			ТекСтрока.ОтображатьВсегда = ТекСтрока.Избранное;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекПередНачаломИзменения(Элемент, Отказ)
	
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
	
	Если Элементы.ДеревоНастроек.ТекущийЭлемент.Имя = "ДеревоНастроекЗначение" Тогда  
		
		Если ТекСтрока.ЭтоГруппа Тогда
			Отказ = Истина;
		КонецЕсли;	
		
		Если ТипЗнч(ТекСтрока.Значение) = Тип("Булево") Тогда
			ТекСтрока.Значение = Не ТекСтрока.Значение;
			Отказ = Истина;
		КонецЕсли;
		
		Если ТекСтрока.ОписаниеТипа = Новый ОписаниеТипов("СписокЗначений") Тогда
			Отказ = Истина;
		КонецЕсли;
		
		//Для внешней обработки модуля кастомизации определим отбор по наименованию
			
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ДеревоНастроекЗначениеПриИзменении(Элемент)
	
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		
		//При подключении модуля кастомизации дернем его сразу, чтобы запрос пользователю с галкой "Защита от опасных действий"
		//был выдан сейчас при подключении, чем когда МК будет вызван при заполнении документа
		Если ТекСтрока.НастройкаИД = "СистемныеНастройки_ДополнительныйМодульКастомизации" И ЗначениеЗаполнено(ТекСтрока.Значение) Тогда
			МодульКастомизации_ТестовоеПолучениеДанныхОбработки();
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекЗначениеОчистка(Элемент, СтандартнаяОбработка)
	
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
		
	Если ТекСтрока <> Неопределено Тогда
		
		//Значения списка выбора при очистке сбрасываем на самое первое
		Если ЗначениеЗаполнено(ТекСтрока.СписокВыбора) Тогда
			
			СтандартнаяОбработка = Ложь;
						
			СписокВыбора = ЗначениеИзСтрокиВнутрСервер(ТекСтрока.СписокВыбора);
			ТекСтрока.Значение = СписокВыбора[0].Значение;
			
		//Предустановим тип Список значений и значение списка значений Номенклатура	
		ИначеЕсли ТекСтрока.НастройкаИД = "Номенклатура_ГруппаДляПоискаПохожейНоменклатуры" Тогда
			СтандартнаяОбработка = Ложь;
			Элементы.ДеревоНастроекЗначение.ВыборГруппИЭлементов = ГруппыИЭлементы.Группы;
			ТекСтрока.Значение = Новый СписокЗначений;
			ТекСтрока.Значение.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Номенклатура");
			
		КонецЕсли;
			
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДеревоНастроекЗначениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	//Установим дополнительные отборы, при необходимости
	ТекСтрока = Элементы.ДеревоНастроек.ТекущиеДанные;
	
	Если ТекСтрока <> Неопределено Тогда
		
		Если ТекСтрока.НастройкаИД = "СистемныеНастройки_ДополнительныйМодульКастомизации" Тогда
		
			НовыйПараметр = Новый ПараметрВыбора("Отбор.Наименование", "Entera: Модуль кастомизации");
			НовыйМассив = Новый Массив();
			НовыйМассив.Добавить(НовыйПараметр);
			НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
			Элемент.ПараметрыВыбора = НовыеПараметры;
			
		//E1C-250: БП30: Выбор в настройках Способ учета НДС любых значений этого перечисления,
		//включая "Списывается, не принимается к НУ", доступный программно из Авансового отчета	
		ИначеЕсли ТекСтрока.НастройкаИД = "ЗаполнениеТЧ_СпособУчетаНДСПоУмолчанию" Тогда
		
			НовыйПараметр = Новый ПараметрВыбора("ОграничениеСпискаВыбора", "НеОграничивать");
			НовыйМассив = Новый Массив();
			НовыйМассив.Добавить(НовыйПараметр);
			НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
			Элемент.ПараметрыВыбора = НовыеПараметры;
			
		//Позволим многострочный ввод с переносами строки для ввода шаблона назначения платежа
		ИначеЕсли ТекСтрока.НастройкаИД = "ЗаполнениеШапки_ШаблонНазначенияПлатежа" Тогда
			ДопПараметры = Новый Структура;
			ДопПараметры.Вставить("ИдентификаторСтроки",ТекСтрока.ПолучитьИдентификатор());
			
			ПараметрыВызова = Новый Структура("Обработчик,Строка,Подсказка,Длина,Многострочность,ДопПараметры",
				"ОбработатьВводЗначенияСтроки",ТекСтрока.Значение,"Шаблон назначения платежа",0,Истина,ДопПараметры);
			
			_ЗФ_ОбработатьАсинхронныйВызов("ВводСтроки",ПараметрыВызова);
			
		Иначе			
			НовыйМассив = Новый Массив();
			НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
			Элемент.ПараметрыВыбора = НовыеПараметры;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВводЗначенияСтроки(Результат,ДопПараметры)
	
	Если Результат <> Неопределено Тогда
		ТекСтрока = ДеревоНастроек.НайтиПоИдентификатору(ДопПараметры.ИдентификаторСтроки);
		
		Если ТекСтрока <> Неопределено Тогда
			ТекСтрока.Значение = Результат;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

