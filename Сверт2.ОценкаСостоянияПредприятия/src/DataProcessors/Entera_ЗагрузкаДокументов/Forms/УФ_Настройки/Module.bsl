Функция ЗначениеИзСтрокиВнутрСервер(Параметр)
	Возврат ЗначениеИзСтрокиВнутр(Параметр) 
КонецФункции
&НаКлиентеНаСервереБезКонтекста
Процедура СообщитьСообщение(Текст,Поле = Неопределено,ИдентификаторНазначения = Неопределено) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = Текст;
	СообщениеПользователю.Поле = Поле;
	
	Если ТипЗнч(ИдентификаторНазначения) = Тип("УникальныйИдентификатор") Тогда
		СообщениеПользователю.ИдентификаторНазначения = ИдентификаторНазначения;
	КонецЕсли;
	
	СообщениеПользователю.Сообщить();
	
