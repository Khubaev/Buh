	РеквизитОбъект.ЗаполнитьДеревоНастроек(Дерево,Пространство,ПустыеНастройки,recognitionSettings);
	ЗначениеВРеквизитФормы(Дерево,"ДеревоНастроек");
	
КонецФункции

&НаКлиенте
Процедура ОбработатьВыборФайлов(Результат,ДопПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда	
		
		Если ДопПараметры.РежимВыбораФайла = "Сохранение" Тогда
			
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(ДопПараметры.АдресВХ);
			ДвоичныеДанные.Записать(Результат[0]);			
			
		ИначеЕсли ДопПараметры.РежимВыбораФайла = "Открытие" Тогда
			
			ИмяФайла = Результат[0];
			АдресВХ = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяФайла));
			Результат = НастройкиИмпортНаСервере(АдресВХ,ДопПараметры.Источник);
			
			Если Результат.Успешно Тогда
				ПоказатьОповещениеПользователя("Настройки заполнены.");
				
				Для Каждого Строка ИЗ ДеревоНастроек.ПолучитьЭлементы() Цикл
			    	Элементы.ДеревоНастроек.Развернуть(Строка.ПолучитьИдентификатор(), Истина);
				КонецЦикла;
				
			Иначе
				Сообщение = Новый СообщениеПользователю;
				Сообщение.ИдентификаторНазначения = ВладелецФормы.УникальныйИдентификатор;
				Сообщение.Текст = Результат.ТекстОшибки;
				Сообщение.Сообщить();
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьНачалоВыбораФайлов_ВебКлиент(ПомещенныеФайлы,Отказ,ДопПараметры) Экспорт
	
