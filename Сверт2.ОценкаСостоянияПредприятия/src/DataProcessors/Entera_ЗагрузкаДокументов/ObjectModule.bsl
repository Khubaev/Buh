// ================= Поиск ссылок на объекты базы 1с ===================

Процедура ВыполнитьПоискСсылок_Документы(СтруктураНастроек,ДанныеПортала,ПараметрыПоиска = Неопределено) Экспорт
	
	Если ПараметрыПоиска = Неопределено Тогда
		ПараметрыПоиска = Новый Структура;
	КонецЕсли;
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
			
	//Обходим коллекцию документов
	Для Каждого СтрокаДокумент Из ДанныеПортала.documents Цикл
		
		//Если передали документ для обновления - выполняем поиск только для него
		Если ПараметрыПоиска.Свойство("documentId") И ПараметрыПоиска.documentId <> Неопределено И СтрокаДокумент.id <> ПараметрыПоиска.documentId Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СтрокаДокумент.ДокументСсылка) Тогда
			СтрокаДокумент.ДокументСсылка = ПолучитьСсылку_ОбъектПоСвойствуИдентификаторуПортала(СтруктураНастроек,СтрокаДокумент.id);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаДокумент.ДокументСсылка) Тогда
			Если СтрокаДокумент.state = "EDI_SEND" Тогда
				//E1C-450: Это не касается исходящих ЭДО-документов				
			Иначе
				СтрокаДокумент.state = "UPLOADED";
				СтрокаДокумент.ПредставлениеСтатуса = "Выгружен";
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьПоискСсылокПоДаннымПортала(СтруктураНастроек,ДанныеПортала,ПараметрыПоиска = Неопределено) Экспорт
		
	Если ПараметрыПоиска = Неопределено Тогда
		ПараметрыПоиска = Новый Структура;
	КонецЕсли;
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
		
	//Получаем таблицу соответствий
	ИспользоватьРучныеСоответствия = Ложь;
	Если СтруктураНастроек.Номенклатура_ЗапоминатьУстановленныеВручнуюСоответствия Тогда
		СвязьНоменклатуры = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьНоменклатуры");
		Если ТипЗнч(СвязьНоменклатуры) = Тип("ТаблицаЗначений")
			И СвязьНоменклатуры.Количество() > 0 Тогда
			ИспользоватьРучныеСоответствия = Истина;
		КонецЕсли;
	КонецЕсли;
	
	//Получаем таблицу "маркеров" - подстрок поиска номенклатуры
	ИспользоватьПоискПоМаркерам = Ложь;
	
	СловаМаркеры = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СловаМаркеры");
	Если ТипЗнч(СловаМаркеры) = Тип("ТаблицаЗначений")
		И СловаМаркеры.Количество() > 0 Тогда
		ИспользоватьПоискПоМаркерам = Истина;
	КонецЕсли;
		
	//Обходим коллекцию документов
	Для Каждого СтрокаДокумент Из ДанныеПортала.documents Цикл
		
		//Если передали документ для обновления - выполняем поиск только для него
		Если ПараметрыПоиска.Свойство("documentId") И ПараметрыПоиска.documentId <> Неопределено И СтрокаДокумент.id <> ПараметрыПоиска.documentId Тогда
			Продолжить;
		КонецЕсли;
				
		Если ПараметрыПоиска.Свойство("НаправлениеСоздаваемогоДокумента") Тогда
			Направление = ПараметрыПоиска.НаправлениеСоздаваемогоДокумента;
		Иначе
			//На этом этапе направление еще не было определено
			Направление = ОпределитьНаправлениеСоздаваемогоДокумента(СтрокаДокумент,СтруктураНастроек);
		КонецЕсли;
				
		//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("ДокументИД",СтрокаДокумент.id);
		ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
		ПараметрыМК.Вставить("СтрокаДокумент",СтрокаДокумент);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("ПараметрыПоиска",ПараметрыПоиска);
		ПараметрыМК.Вставить("Направление",Направление);
		ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
				
		МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеНаправления",ПараметрыМК);
		Направление = ПараметрыМК.Направление;
		СтрокаДокумент.Направление = Направление;
		// ) 2019.10.25
		
		
		Если Направление = "Входящий" Тогда
			СправочникПлательщик = СтруктураНастроек.СведенияОКонфигурации.Организации_ИмяСправочника;
			СправочникПоставщик = "Контрагенты";
		Иначе
			СправочникПлательщик = "Контрагенты";
			СправочникПоставщик = СтруктураНастроек.СведенияОКонфигурации.Организации_ИмяСправочника;
		КонецЕсли;
				
		ПоляПоискаПлательщик = Новый Структура("ИНН,КПП,ИдентификационныйКодЛичности,Наименование,НаименованиеПолное",СтрокаДокумент.customerInn,СтрокаДокумент.customerKpp,СтрокаДокумент.customerTaxId,СтрокаДокумент.customerShortName,СтрокаДокумент.customerName);
		ПоляПоискаПоставщик = Новый Структура("ИНН,КПП,ИдентификационныйКодЛичности,Наименование,НаименованиеПолное",СтрокаДокумент.supplierInn,СтрокаДокумент.supplierKpp,СтрокаДокумент.supplierTaxId,СтрокаДокумент.supplierShortName,СтрокаДокумент.supplierName);
		
		ПлательщикСсылка = ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП(СправочникПлательщик,ПоляПоискаПлательщик,СтруктураНастроек);				
		ПоставщикСсылка = ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП(СправочникПоставщик,ПоляПоискаПоставщик,СтруктураНастроек);
			
		// EN-153: сопоставление по организации плательщика, т.е. если такая организация есть,
		//то в поступлении в поле организация она автоматически проставлялась
		Если Направление = "Входящий" Тогда
			// Задача 4637: с версии 1.39 если значение по умолчанию задано в настройках, то всегда используем его
			Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию) Тогда
				ПлательщикСсылка = СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию;
			КонецЕсли;
			
			СтрокаДокумент.УчитыватьНДС = ОпределитьФлаг_УчитыватьНДС(СтруктураНастроек,ПлательщикСсылка,СтрокаДокумент.date);
			
			//Если нашли контрагента и есть номер счета - поищем его банковский счет
			Если ЗначениеЗаполнено(ПоставщикСсылка) И ЗначениеЗаполнено(СтрокаДокумент.supplierAccountNumber) Тогда
				ПоляПоиска = Новый Структура("Владелец,НомерСчета,БИК",ПоставщикСсылка,СтрокаДокумент.supplierAccountNumber,СтрокаДокумент.supplierAccountBic);
				СтрокаДокумент.БанковскийСчетКонтрагентаСсылка = ПолучитьСсылку_БанковскийСчет(ПоляПоиска,СтруктураНастроек);
			КонецЕсли;
			
		Иначе
			// Задача 4637: с версии 1.39 если значение по умолчанию задано в настройках, то всегда используем его
			Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию) Тогда
				ПоставщикСсылка = СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию;
			КонецЕсли;
			
			СтрокаДокумент.УчитыватьНДС = ОпределитьФлаг_УчитыватьНДС(СтруктураНастроек,ПоставщикСсылка,СтрокаДокумент.date);
		КонецЕсли;
		// ) EN-153
				
		//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
		ПараметрыМК.Вставить("ПлательщикСсылка",ПлательщикСсылка);
		ПараметрыМК.Вставить("ПоставщикСсылка",ПоставщикСсылка);
		ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
				
		МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеПлательщикаПоставщика",ПараметрыМК);
		ПлательщикСсылка = ПараметрыМК.ПлательщикСсылка;
		ПоставщикСсылка = ПараметрыМК.ПоставщикСсылка;
		// ) 2019.10.25
		
		СтрокаДокумент.ПлательщикСсылка = ПлательщикСсылка;
		СтрокаДокумент.ПоставщикСсылка = ПоставщикСсылка;
		
		Если Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
			Если Направление = "Входящий" Тогда
				СтрокаДокумент.ПартнерСсылка = ?(ЗначениеЗаполнено(ПоставщикСсылка),ПоставщикСсылка.Партнер,Справочники.Партнеры.ПустаяСсылка());
			Иначе
				СтрокаДокумент.ПартнерСсылка = ?(ЗначениеЗаполнено(ПлательщикСсылка),ПлательщикСсылка.Партнер,Справочники.Партнеры.ПустаяСсылка());
			КонецЕсли;
		КонецЕсли;
		
		
		//Договор контрагента
		Если ЗначениеЗаполнено(ПоставщикСсылка) И ЗначениеЗаполнено(ПлательщикСсылка) Тогда
			СтрокаДокумент.ДоговорСсылка = ПолучитьСсылку_Договор(СтрокаДокумент,Направление,СтруктураНастроек);		
		КонецЕсли;
		
		//Переопределение модулем кастомизации ссылки на договор перенесено в функцию ПолучитьСсылку_Договор()
		
	КонецЦикла;
	
	//2019.02.20 ( с этим параметром выполняется только поиск ссылок на Организацию/Контрагента и договор
	Если Не ПараметрыПоиска.Свойство("ТолькоРеквизитыШапки") Тогда
	// ) 2019.02.20
	
		//2021.01.20 ( Зафиксированы случаи, когда ключа СловарьСинонимовЕИ на этом этапе еще нет в структуре настроек,
		//поймать такую ситуацию не удалось, но если так получилось - заполним словарь синонимов тут и поместим в Настройки
		Если Не СтруктураНастроек.Свойство("СловарьСинонимовЕИ") Тогда
			СтруктураНастроек.Вставить("СловарьСинонимовЕИ",Классификатор_ИнициализироватьСоответствияСинонимовЕдиницИзмерения());
		КонецЕсли;			
		// ) 2021.01.20
		
		ПерваяСтрокаДокумента = Неопределено;
		КоличествоПозицийДокумента = 0;
		
		//Коллекция товарных позиций документа
		Для Каждого СтрокаНоменклатура Из ДанныеПортала.documentItems Цикл
			
			//Если передали документ для обновления - выполняем поиск только для него
			Если ПараметрыПоиска.Свойство("documentId") И ПараметрыПоиска.documentId <> Неопределено И СтрокаНоменклатура.documentId <> ПараметрыПоиска.documentId Тогда
				Продолжить;
			КонецЕсли;
			
			КоличествоПозицийДокумента = КоличествоПозицийДокумента + 1;
			
			Если ПерваяСтрокаДокумента = Неопределено Тогда
				ПерваяСтрокаДокумента = СтрокаНоменклатура;
			КонецЕсли;
			
			ДанныеДокумента = ДанныеПортала.documents.Найти(СтрокаНоменклатура.documentId,"id");
			
			ПараметрыМК.Вставить("СтрокаНоменклатура",СтрокаНоменклатура);
			
			//Пустые ссылки ЕИ устанавливаются далее при поиске в ПолучитьСсылку_УпаковкаЕдиницаИзмерения
			СтрокаНоменклатура.ЭтоУслуга = Ложь;
			СтрокаНоменклатура.ЭтоАгентскаяУслуга = Ложь;
			СтрокаНоменклатура.НомерГТДСсылка = Неопределено;
			СтрокаНоменклатура.СтранаПроисхожденияСсылка = Неопределено;
			
			СтрокаНоменклатура.СчетУчетаСсылка = Неопределено;
			
			//E1C-407: Теперь у нас может выполняться поиск и для Основных средств
			Если ПараметрыПоиска.Свойство("СправочникТоварныхПозиций")
				И ПараметрыПоиска.СправочникТоварныхПозиций = "ОсновныеСредства" Тогда
				
				СтрокаНоменклатура.ОсновноеСредствоСсылка = Справочники.ОсновныеСредства.ПустаяСсылка();
				
				Если ЗначениеЗаполнено(СтрокаНоменклатура.nomenclatureExternalId) Тогда
					СтрокаНоменклатура.ОсновноеСредствоСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.nomenclatureExternalId,"ОсновныеСредства");
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(СтрокаНоменклатура.ОсновноеСредствоСсылка) Тогда
					СтрокаНоменклатура.ОсновноеСредствоСсылка = ПолучитьСсылку_ОсновноеСредствоПоЗаданномуАлгоритмуПоиска(СтрокаНоменклатура,СтруктураНастроек);
				КонецЕсли;
				
				//модуль кастомизации: можно переопределить установленное стандартным поиском значение
				ПараметрыМК.Вставить("ОсновноеСредствоСсылка",СтрокаНоменклатура.ОсновноеСредствоСсылка);
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
						
				МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеОсновногоСредства",ПараметрыМК);
				СтрокаНоменклатура.ОсновноеСредствоСсылка = ПараметрыМК.ОсновноеСредствоСсылка;
				
			Иначе
			
				//Очистим ранее найденные позиции, если это повторно выполняемый поиск ссылок
				СтрокаНоменклатура.НоменклатураСсылка = Справочники.Номенклатура.ПустаяСсылка();
								
				//Ищем номенклатуру
				НоменклатураСсылка = Справочники.Номенклатура.ПустаяСсылка();
				ХарактеристикаСсылка = Неопределено;
				
				Если ЗначениеЗаполнено(СтрокаНоменклатура.nomenclatureExternalId) Тогда
					НоменклатураСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.nomenclatureExternalId,"Номенклатура");
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(НоменклатураСсылка) Тогда
					//Для поиска номенклатуры поставщика потребуется ссылка на Партнера
					НоменклатураСсылка = ПолучитьСсылку_НоменклатураПоЗаданномуАлгоритмуПоиска(СтрокаНоменклатура,ДанныеДокумента,СтруктураНастроек);
				КонецЕсли;
				
				//2019.02.15 ( Ищем установленную вручную связь, она будет приоритетной над остальными способами поиска, поэтому замещает полученный ранее результат
				Если ИспользоватьРучныеСоответствия Тогда
					СтруктураПоиска = Новый Структура;
					СтруктураПоиска.Вставить("Наименование",СтрокаНоменклатура.name);
					СтруктураПоиска.Вставить("КонтрагентИД",?(ЗначениеЗаполнено(СтрокаНоменклатура.supplierInn),СтрокаНоменклатура.supplierInn,""));
					
					НайденныеСтроки = СвязьНоменклатуры.НайтиСтроки(СтруктураПоиска);
					
					Если НайденныеСтроки.Количество() > 0 И ЗначениеЗаполнено(НайденныеСтроки[0].Ссылка) Тогда
						НоменклатураСсылка = НайденныеСтроки[0].Ссылка;
						
						//2020.01.13 ( добавлена работа с характеристиками
						Если СтруктураНастроек.Свойство("ЗаполнениеТЧ_ИспользоватьХарактеристики")
							И СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьХарактеристики = Истина Тогда
							
							//в сохраненной ранее таблице связей такой колонки может не быть
							Если СвязьНоменклатуры.Колонки.Найти("Характеристика") <> Неопределено Тогда
								ХарактеристикаСсылка = НайденныеСтроки[0].Характеристика;
							КонецЕсли;
						КонецЕсли;
						// ) 2020.01.13
					КонецЕсли;
				КонецЕсли;	
				//2019.02.15
				
				//2019.10.17 ( По настройке поиск по подстроке "маркеру", входящему в наименование
				Если ИспользоватьПоискПоМаркерам Тогда
					СтрокаДляПоиска = Нрег(СтрокаНоменклатура.name);
					Для Каждого СтрокаМаркер Из СловаМаркеры Цикл
						Если СтрокаМаркер.Маркер <> ""
							И ЗначениеЗаполнено(СтрокаМаркер.Номенклатура)
							И СтрокаМаркер.Номенклатура.ЭтоГруппа = Ложь Тогда
							
							//2019.11.20 ( Новая логика: пробел в маркере разбивает маркер на подстроки поиска, поиск по этим подстрокам
							//должен выполняться по вхождению всех подстрок в наименование номенклатуры поставщика
							МассивПодстрок = Энтера_РазложитьСтрокуВМассивПодстрок(Нрег(СтрокаМаркер.Маркер)," ",Истина,Истина);
							ВсеПодстрокиНайдены = Истина;
							Для Каждого Подстрока Из МассивПодстрок Цикл
								Если Найти(СтрокаДляПоиска,Подстрока) = 0 Тогда
									ВсеПодстрокиНайдены = Ложь;
									Прервать;
								КонецЕсли;
							КонецЦикла;
							
							Если ВсеПодстрокиНайдены Тогда
								НоменклатураСсылка = СтрокаМаркер.Номенклатура;
							КонецЕсли;
							// ) 2019.11.20
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				// ) 2019.10.17
				
				//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
				ПараметрыМК.Вставить("НоменклатураСсылка",НоменклатураСсылка);
				ПараметрыМК.Вставить("ХарактеристикаСсылка",ХарактеристикаСсылка);
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
						
				МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеНоменклатуры",ПараметрыМК);
				СтрокаНоменклатура.НоменклатураСсылка = ПараметрыМК.НоменклатураСсылка;
				СтрокаНоменклатура.ХарактеристикаСсылка = ПараметрыМК.ХарактеристикаСсылка;
				// ) 2019.10.25
							
				ЕдиницаИзмеренияСсылка = СтрокаНоменклатура.ЕдиницаИзмеренияСсылка;
				
				Если Не ЗначениеЗаполнено(ЕдиницаИзмеренияСсылка) Тогда
					ЕдиницаИзмеренияСсылка = ПолучитьСсылку_УпаковкаЕдиницаИзмерения(СтрокаНоменклатура,СтруктураНастроек);
				КонецЕсли;
				
				//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
				ПараметрыМК.Вставить("ЕдиницаИзмеренияСсылка",ЕдиницаИзмеренияСсылка);
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
						
				МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеЕдиницыИзмерения",ПараметрыМК);
				СтрокаНоменклатура.ЕдиницаИзмеренияСсылка = ПараметрыМК.ЕдиницаИзмеренияСсылка;
				// ) 2019.10.25
			
			КонецЕсли;
			
			
			Если ЗначениеЗаполнено(СтрокаНоменклатура.СтавкаНДССсылка)
				И СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку <> "Нет" Тогда
				//Ставка НДС могла быть расчитана на этапе приведения к одной строке номенклатуры
				СтавкаНДССсылка = СтрокаНоменклатура.СтавкаНДССсылка;
			Иначе
				СтавкаНДССсылка = ПолучитьСсылку_СтавкаНДС(СтрокаНоменклатура.vatRate,СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС);
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ДанныеДокумента.СтавкаНДССсылка) Тогда
				ДанныеДокумента.СтавкаНДССсылка = СтавкаНДССсылка;
			КонецЕсли;
			
			//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
			ПараметрыМК.Вставить("СтавкаНДССсылка",СтавкаНДССсылка);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
					
			МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеСтавкиНДС",ПараметрыМК);
			СтрокаНоменклатура.СтавкаНДССсылка = ПараметрыМК.СтавкаНДССсылка;
			// ) 2019.10.25
			
			
			// В номере ГТД цифры и знак /, распознанные порталом прочерки и тире пропускаем
			ПрисутствуютДанныеГТД = ЗначениеЗаполнено(СтрокаНоменклатура.recognizedCustomsDeclaration)
				И Найти(СтрокаНоменклатура.recognizedCustomsDeclaration,"-") = 0
				И Найти(СтрокаНоменклатура.recognizedCustomsDeclaration,Символ(8212)) = 0;
				
			Если ПрисутствуютДанныеГТД Тогда
				Если РеквизитСуществует("Справочники","НомераГТД") И ЗначениеЗаполнено(СтрокаНоменклатура.recognizedCustomsDeclaration) Тогда
					НомерГТДСсылка = Справочники.НомераГТД.НайтиПоКоду(СтрокаНоменклатура.recognizedCustomsDeclaration);
				ИначеЕсли РеквизитСуществует("Справочники","ГТД") И ЗначениеЗаполнено(СтрокаНоменклатура.recognizedCustomsDeclaration) Тогда
					НомерГТДСсылка = Справочники.ГТД.НайтиПоНаименованию(СтрокаНоменклатура.recognizedCustomsDeclaration);
				КонецЕсли;
				
				//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
				ПараметрыМК.Вставить("НомерГТДСсылка",НомерГТДСсылка);
				ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
						
				МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеНомераГТД",ПараметрыМК);
				СтрокаНоменклатура.НомерГТДСсылка = ПараметрыМК.НомерГТДСсылка;
				// ) 2019.10.25
				
				
				СправочникСтраныМира = СтруктураНастроек.СведенияОКонфигурации.СправочникСтраныМира;
				
				Если ЗначениеЗаполнено(СправочникСтраныМира) Тогда
					Если ЗначениеЗаполнено(СтрокаНоменклатура.recognizedCountryCode) Тогда
						СтранаПроисхожденияСсылка = Справочники[СправочникСтраныМира].НайтиПоКоду(СтрокаНоменклатура.recognizedCountryCode,Истина);
					КонецЕсли;
					
					//Если не нашли страну по коду - повторим поиск по наименованию
					Если Не ЗначениеЗаполнено(СтранаПроисхожденияСсылка) И ЗначениеЗаполнено(СтрокаНоменклатура.recognizedCountryShortName) Тогда
						СтранаПроисхожденияСсылка = Справочники[СправочникСтраныМира].НайтиПоНаименованию(СтрокаНоменклатура.recognizedCountryShortName,Истина);
					КонецЕсли;
					
					//2019.10.25 ( модуль кастомизации: можно переопределить установленное стандартным поиском значение
					ПараметрыМК.Вставить("СтранаПроисхожденияСсылка",СтранаПроисхожденияСсылка);
					ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
							
					МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеСтраныПроисхождения",ПараметрыМК);
					СтрокаНоменклатура.СтранаПроисхожденияСсылка = ПараметрыМК.СтранаПроисхожденияСсылка;
					// ) 2019.10.25
				КонецЕсли;
				
				Если Конф = "УТ10" Тогда
					ПараметрыПоиска = Новый Структура("Номенклатура,НомерГТД,СтранаПроисхождения",СтрокаНоменклатура.НоменклатураСсылка,СтрокаНоменклатура.НомерГТДСсылка,СтрокаНоменклатура.СтранаПроисхожденияСсылка);
					СтрокаНоменклатура.СерияНоменклатурыСсылка = ПолучитьСсылку_СерияНоменклатуры(СтрокаНоменклатура,СтруктураНастроек,ПараметрыПоиска);					
				КонецЕсли;
				
			КонецЕсли;
			
			//E1C-477: Казахстан: 1С. БП 3.0 для КЗ. Работа с ЭСФ и Источником происхождения
			Если СтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеИсточникПроисхождения = Истина Тогда
				Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.СправочникИсточникиПроисхождения) Тогда
					//Для каждой строки "Источник происхождения" должен происходить поиск и сопоставление Источника,
					//Поиск происходит по соответствию всех реквизитов: Номер ГТД/сертификата, код ТНВЭД, Номер строки ГТД/Заявления.
					ПараметрыПоиска = Новый Структура("Код,КодТНВЭД,НомерСтрокиГТД",
						СтрокаНоменклатура.esfKzProductDeclaration,СтрокаНоменклатура.esfKzUnitCode,СтрокаНоменклатура.esfKzProductNumberInDeclaration);
					СтрокаНоменклатура.ИсточникПроисхожденияСсылка = ПолучитьСсылку_ИсточникПроисхождения(ПараметрыПоиска);
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		//E1C-527: Заполнять ставку НДС в Платежном поручении ставкой НДС из номенклатуры, если в распознанном документе одна позиция
		Если КоличествоПозицийДокумента = 1 И ПерваяСтрокаДокумента <> Неопределено Тогда
			ДанныеДокумента.СтавкаНДССсылка = ПерваяСтрокаДокумента.СтавкаНДССсылка;
		КонецЕсли;
			
		//Вероятные совпадения номенклатуры
		Для Каждого СтрокаВероятнаяНоменклатура Из ДанныеПортала.potentialNomenclatures Цикл
			
			СтрокаВероятнаяНоменклатура.НоменклатураСсылка = Неопределено;
			
			Если ЗначениеЗаполнено(СтрокаВероятнаяНоменклатура.nomenclatureExternalId) Тогда
				СтрокаВероятнаяНоменклатура.НоменклатураСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаВероятнаяНоменклатура.nomenclatureExternalId,"Номенклатура");
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(СтрокаВероятнаяНоменклатура.НоменклатураСсылка) Тогда
				//+++ Продолжить поиск номенклатуры по заданным для общей номенклатуры алгоритму?
				СтрокаВероятнаяНоменклатура.НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(СтрокаВероятнаяНоменклатура.nomenclatureName,"Номенклатура");
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	//модуль кастомизации: можно переопределить установленные стандартным поиском значение
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ПараметрыПоиска",ПараметрыПоиска);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
	МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ПослеОбработкиВсехОбъектов",ПараметрыМК);
							
КонецПроцедуры

Функция ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(GUID,ОбъектМетаданных,РазделМетаданных = "Справочники")
	
	Результат = Неопределено;
			
	Попытка
		УИ = Новый УникальныйИдентификатор(GUID);
	Исключение
		//Некорректный ГУИД
	КонецПопытки;
	
	Если Метаданные[РазделМетаданных].Найти(ОбъектМетаданных) <> Неопределено Тогда
		Если Нрег(РазделМетаданных) = "справочники" Тогда
			
			Если ЗначениеЗаполнено(УИ) Тогда
				Ссылка = Справочники[ОбъектМетаданных].ПолучитьСсылку(УИ);
			КонецЕсли;
			
			Результат = Справочники[ОбъектМетаданных].ПустаяСсылка();
			
		ИначеЕсли Нрег(РазделМетаданных) = "документы" Тогда
			
			Если ЗначениеЗаполнено(УИ) Тогда
				Ссылка = Документы[ОбъектМетаданных].ПолучитьСсылку(УИ);
			КонецЕсли;
			
			Результат = Документы[ОбъектМетаданных].ПустаяСсылка();
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Ссылка) И Не ОбъектНеНайден(Ссылка) Тогда
			Результат = Ссылка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьСсылку_ОбъектПоРеквизиту(Значение,ТипОбъекта,ИмяРеквизита = "Наименование",РазделМетаданных = "Справочник", ДополнительныйОтбор = Неопределено) Экспорт
	
	//В дополнительном отборе можно передать набор ключей и значений для их указания в параметрах запроса
	Если ДополнительныйОтбор = Неопределено Тогда
		ДополнительныйОтбор = Новый Структура;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Значение) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ИскомыйОбъект.Ссылка КАК Ссылка
		               |ИЗ
		               |	РазделМетаданных.ТипОбъекта КАК ИскомыйОбъект
		               |ГДЕ
		               |	НЕ ИскомыйОбъект.ПометкаУдаления
		               |	И ИскомыйОбъект.ИмяРеквизита = &Значение";
		
		//2022.06.29 ( Если тип искомого значения - строка - зададим ограничение поля строки реквизита,
		//чтобы избежать ошибки сравнения поля неограниченной длины
		Если ТипЗнч(Значение) = Тип("Строка") Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ИскомыйОбъект.ИмяРеквизита","Выразить (ИскомыйОбъект.ИмяРеквизита КАК Строка(1000))");
		// ) 2022.06.29
		
		//E1C-490: Артикул может быть передан коллекцией элементов
		ИначеЕсли ТипЗнч(Значение) = Тип("Массив") Тогда
		    Запрос.Текст = СтрЗаменить(Запрос.Текст,"ИскомыйОбъект.ИмяРеквизита = &Значение","Выразить (ИскомыйОбъект.ИмяРеквизита КАК Строка(1000)) В (&Значение)");
		КонецЕсли;
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"РазделМетаданных",РазделМетаданных);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ТипОбъекта",ТипОбъекта);
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ИмяРеквизита",ИмяРеквизита);
		
		Если РазделМетаданных = "Справочник" И Метаданные.Справочники[ТипОбъекта].Иерархический Тогда
			Запрос.Текст = Запрос.Текст + " И НЕ ИскомыйОбъект.ЭтоГруппа";
		КонецЕсли;
		
		Для Каждого ЭлементСтруктуры Из ДополнительныйОтбор Цикл
			
			//2021.10.05 ( Костыль: нужно "вклинить" возможность поиска ссылки в иерахии,
			//определим это ключем структуры "В_ИЕРАРХИИ" с переданным списком/значением групп иерархии
			Если ЭлементСтруктуры.Ключ = "В_ИЕРАРХИИ" И Не ЭлементСтруктуры.Значение = Неопределено Тогда
				Запрос.Текст = Запрос.Текст + " И ИскомыйОбъект.Ссылка В ИЕРАРХИИ (&Иерархия_Ссылка)";
				Запрос.УстановитьПараметр("Иерархия_Ссылка",ЭлементСтруктуры.Значение);
			Иначе
			// ) 2021.10.05
			
				Запрос.Текст = Запрос.Текст + " И ИскомыйОбъект." + ЭлементСтруктуры.Ключ + " = &" + ЭлементСтруктуры.Ключ;
				Запрос.УстановитьПараметр(ЭлементСтруктуры.Ключ,ЭлементСтруктуры.Значение);
			КонецЕсли;
		КонецЦикла;
		
		Запрос.УстановитьПараметр("Значение",Значение);
		Попытка
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				Результат = Выборка.Ссылка;
			КонецЕсли;
		Исключение
			
		КонецПопытки;
	КонецЕсли;
	
	//Определим тип пустого значения
	Если Результат = Неопределено Тогда
		Попытка
			Если РазделМетаданных = "Справочник" Тогда
				Результат = Справочники[ТипОбъекта].ПустаяСсылка();
			КонецЕсли;
		Исключение
			
		КонецПопытки;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбъектНеНайден(Ссылка) Экспорт
	
	//Комментарий для аудитора: проверка значения может быть выполнена для недоступного пользователю объекта, установим привилегированный режим,
	//разрешение на его использование присутствует в списке запрашиваемых разрешений для публикуемого расширения
	УстановитьПривилегированныйРежим(Истина);
	
	Если Ссылка.Пустая() Тогда
		Возврат Ложь;
	Иначе
		Попытка
			Объект = Ссылка.ПолучитьОбъект();
			Возврат Объект = Неопределено;
		Исключение
			Возврат Ложь;
		КонецПопытки;
	КонецЕсли;
	
КонецФункции


Функция ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП(ИмяСправочника,ПоляПоиска,СтруктураНастроек) Экспорт
	
	Перем ИНН,КПП,ИдентификационныйКодЛичности;
	
	ПоляПоиска.Свойство("ИНН",ИНН);
	ПоляПоиска.Свойство("КПП",КПП);
	ПоляПоиска.Свойство("ИдентификационныйКодЛичности",ИдентификационныйКодЛичности);
	
	Результат = Справочники[ИмяСправочника].ПустаяСсылка();
	
	//E1C-224: Изменить приоритет подстановки контрагента,
	//добавлен пункт для первоначального поиска по сопоставлению, потом по ИНН
	Если СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента = "Наименование,ИНН" Тогда
		Результат = ПолучитьСсылку_КонтрагентОрганизацияПоНаименованию(ИмяСправочника,ПоляПоиска,СтруктураНастроек);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		
		НуженПоискПоНаименованию = СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента = "ИНН,Наименование";
		
		Если ЗначениеЗаполнено(ИНН) Тогда
			
			//В странных отраслевых решениях (БИТСтоматология) у Организации нет ИНН
			Если Результат.Метаданные().Реквизиты.Найти("ИНН") <> Неопределено Тогда
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
				               |	Контрагенты.Ссылка КАК Ссылка
				               |ИЗ
				               |	Справочник.Контрагенты КАК Контрагенты
				               |ГДЕ
				               |	НЕ Контрагенты.ПометкаУдаления
				               |	И Контрагенты.ИНН = &ИНН";
				Запрос.УстановитьПараметр("ИНН", Строка(ИНН));
				
				Если СтруктураНастроек.ЗаполнениеШапки_АлгоритмПоискаКонтрагента = "ИНН+КПП" И ЗначениеЗаполнено(КПП) Тогда
					Запрос.Текст = Запрос.Текст + Символы.ПС
						+ "И Контрагенты.КПП = &КПП";
					Запрос.УстановитьПараметр("КПП",Строка(КПП));
				КонецЕсли;
				
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Контрагенты",ИмяСправочника);
					
				Выборка = Запрос.Выполнить().Выбрать();
				Выборка.Следующий();
				Результат = Выборка.Ссылка;
				
			КонецЕсли;
			
			//Если не нашли - по настройке продолжаем искать по наименованию
			Если Не ЗначениеЗаполнено(Результат) И НуженПоискПоНаименованию Тогда
				Результат = ПолучитьСсылку_КонтрагентОрганизацияПоНаименованию(ИмяСправочника,ПоляПоиска,СтруктураНастроек);
			КонецЕсли;
		
		ИначеЕсли ЗначениеЗаполнено(ИдентификационныйКодЛичности) Тогда
			
			//У Контрагента и Организации этот реквизит называется по-разному: ИдентификационныйНомер и ИдентификационныйКодЛичности
			Если Результат.Метаданные().Реквизиты.Найти("ИдентификационныйКодЛичности") <> Неопределено Тогда
				ИмяРеквизитаИИНБИН  = "ИдентификационныйКодЛичности";
			ИначеЕсли Результат.Метаданные().Реквизиты.Найти("ИдентификационныйНомер") <> Неопределено Тогда
				ИмяРеквизитаИИНБИН  = "ИдентификационныйНомер";	
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ИмяРеквизитаИИНБИН) Тогда
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
				               |	Контрагенты.Ссылка КАК Ссылка
				               |ИЗ
				               |	Справочник.Контрагенты КАК Контрагенты
				               |ГДЕ
				               |	НЕ Контрагенты.ПометкаУдаления
				               |	И Контрагенты.ИдентификационныйКодЛичности = &ИдентификационныйКодЛичности";
				Запрос.УстановитьПараметр("ИдентификационныйКодЛичности", Строка(ИдентификационныйКодЛичности));
				
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"Контрагенты",ИмяСправочника);
				Запрос.Текст = СтрЗаменить(Запрос.Текст,".ИдентификационныйКодЛичности","." + ИмяРеквизитаИИНБИН);
					
				Выборка = Запрос.Выполнить().Выбрать();
				Выборка.Следующий();
				Результат = Выборка.Ссылка;
				
			КонецЕсли;
			
			//Если не нашли - по настройке продолжаем искать по наименованию
			Если Не ЗначениеЗаполнено(Результат) И НуженПоискПоНаименованию Тогда
				Результат = ПолучитьСсылку_КонтрагентОрганизацияПоНаименованию(ИмяСправочника,ПоляПоиска,СтруктураНастроек)
			КонецЕсли;
		
		ИначеЕсли НуженПоискПоНаименованию Тогда
			Результат = ПолучитьСсылку_КонтрагентОрганизацияПоНаименованию(ИмяСправочника,ПоляПоиска,СтруктураНастроек);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьСсылку_КонтрагентОрганизацияПоНаименованию(ИмяСправочника,ПоляПоиска,СтруктураНастроек)
	
	Перем Наименование,НаименованиеПолное;
	
	ПоляПоиска.Свойство("Наименование",Наименование);
	ПоляПоиска.Свойство("НаименованиеПолное",НаименованиеПолное);
	
	Результат = Справочники[ИмяСправочника].ПустаяСсылка();
	
	//Получаем таблицу соответствий
	ИспользоватьРучныеСоответствия = Ложь;
	
	Если ИмяСправочника = "Контрагенты" Тогда
	
		ТаблицаСвязи = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьКонтрагентов");
		Если ТипЗнч(ТаблицаСвязи) = Тип("ТаблицаЗначений")
			И ТаблицаСвязи.Количество() > 0 Тогда
			ИспользоватьРучныеСоответствия = Истина;
		КонецЕсли;
		
	ИначеЕсли ИмяСправочника = "Организации" Тогда
		
		ТаблицаСвязи = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьОрганизаций");
		Если ТипЗнч(ТаблицаСвязи) = Тип("ТаблицаЗначений")
			И ТаблицаСвязи.Количество() > 0 Тогда
			ИспользоватьРучныеСоответствия = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Наименование) Тогда
		
		Если ИспользоватьРучныеСоответствия Тогда
			СтрокиТаблицы = ТаблицаСвязи.НайтиСтроки(Новый Структура("Наименование",Наименование));
			Если СтрокиТаблицы.Количество() > 0 Тогда
				НайденноеЗначение = СтрокиТаблицы[0].Ссылка;
				Если ТипЗнч(НайденноеЗначение) = ТипЗнч(Результат) Тогда
					Результат = НайденноеЗначение;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Результат) Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
			               |	Контрагенты.Ссылка КАК Ссылка
			               |ИЗ
			               |	Справочник.Контрагенты КАК Контрагенты
			               |ГДЕ
			               |	НЕ Контрагенты.ПометкаУдаления
			               |	И Контрагенты.Наименование = &Наименование";
			Запрос.УстановитьПараметр("Наименование", Наименование);
					
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"Контрагенты",ИмяСправочника);
				
			Выборка = Запрос.Выполнить().Выбрать();
		
			Если Выборка.Следующий() Тогда
				Результат = Выборка.Ссылка;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСсылку_Договор(СтрокаДокумент,Направление,СтруктураНастроек) Экспорт
	
	//Модуль кастомизации: можно переопределить установленное стандартным поиском значение
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ДокументИД",СтрокаДокумент.id);
	ПараметрыМК.Вставить("СтрокаДокумент",СтрокаДокумент);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("Направление",Направление);
	ПараметрыМК.Вставить("ДоговорСсылка",СтрокаДокумент.ДоговорСсылка);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
	МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеДоговора",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка <> Истина Тогда
		ДоговорСсылка = ПараметрыМК.ДоговорСсылка;
		
	Иначе
		
		Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
		Лок = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок;
		
		//E1C-484: Сопоставление и создание Договора в 1С по распознанным данным "Основание передачи"
		//Требуется производить поиск похожего Договора в справочнике Договоров между поставщиком и плательщиком по параметрам:
		//1) Искать похожий договор по совпадению "Наименование договора" (если возможно, игнорируя пробелы и символы вида точки, запятой, №).
		//2) Если ничего не найдено, подбирать договор с идентичными реквизитами Дата и номер (игнорировать язык написания символов в номере).
		//3) Если ничего не найдено, то подбирать договор с идентичным реквизитом Дата.
		//4) Если ничего не найдено, то подбирать наиболее похожий договор из базы (как сейчас у нас работает).
		Если СтруктураНастроек.ЗаполнениеШапки_ИспользоватьДанныеОснованияДляДоговора = Истина Тогда
			ДоговорСсылка = ПолучитьСсылку_ДоговорПоРаспознаннымДанным(СтрокаДокумент,Направление,СтруктураНастроек);
			
		Иначе
			
			//Использование общего модуля РаботаВБезопасномРежиме в новых версиях конфигураций больше не поддерживается,
			//используем рекомендуемый ОбщегоНазначения.ВыполнитьВБезопасномРежиме
			Попытка
				МодульРаботыВБезопасномРежиме = _ЗФ_ПолучитьОбщийМодульКонфигурации("ОбщегоНазначения");
			Исключение
				//Не обрабатываем
			КонецПопытки;
			
			//2020.06.29 ( Для старых конфигураций все-таки придется попробовать получить РаботаВБезопасномРежиме на случай,
			//если в ОбщегоНазначения пока еще не перенесены экспортные ВыполнитьВБезопасномРежиме и ВычислитьВБезопасномРежиме
			Если МодульРаботыВБезопасномРежиме <> Неопределено Тогда
				Попытка
					//проверяем наличие экспортной функции ОбщегоНазначения.ВычислитьВБезопасномРежиме()
					МодульРаботыВБезопасномРежиме.ВычислитьВБезопасномРежиме("1 + 1");
				Исключение
					МодульРаботыВБезопасномРежиме = _ЗФ_ПолучитьОбщийМодульКонфигурации("РаботаВБезопасномРежиме");
				КонецПопытки;
			КонецЕсли;
			// ) 2020.06.29
			
			ПараметрыВыполнения = Новый Структура;
			ПараметрыВыполнения.Вставить("ДоговорСсылка");
			
			//БП 3.0
			Если Конф = "БП30" Тогда				
				
				//Заполняем для тех документов, где есть реквизит Договор
				Если ЗначениеЗаполнено(СтрокаДокумент.ТипСоздаваемогоДокумента) Тогда
					Если Метаданные.Документы[СтрокаДокумент.ТипСоздаваемогоДокумента].Реквизиты.Найти("ДоговорКонтрагента") <> Неопределено Тогда
						
						СтрокаДокумент.ДоговорНеТребуется = Ложь;
						
						Если МодульРаботыВБезопасномРежиме <> Неопределено Тогда
							
							МассивВидовДоговоров = Новый Массив;
							
							//E1C-327: Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
							Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
								МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));
												
								ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
								ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
								
							Иначе
							// ) E1C-327
							
								Если Направление = "Входящий" Тогда
									МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
													
									ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
									ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
									
								Иначе
									МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
													
									ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПлательщикСсылка);
									ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПоставщикСсылка);
									
								КонецЕсли;
								
							КонецЕсли;
							
							ПараметрыВыполнения.Вставить("МассивВидовДоговоров",МассивВидовДоговоров);
						
							Попытка
								Если Метаданные.ОбщиеМодули.Найти("РаботаСДоговорамиКонтрагентовБП") <> Неопределено Тогда
									МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("РаботаСДоговорамиКонтрагентовБП.УстановитьДоговорКонтрагента(Параметры.ДоговорСсылка,Параметры.КонтрагентСсылка,Параметры.ОрганизацияСсылка,Параметры.МассивВидовДоговоров)",ПараметрыВыполнения);
								ИначеЕсли Метаданные.ОбщиеМодули.Найти("БухгалтерскийУчетПереопределяемый") <> Неопределено Тогда
									МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("БухгалтерскийУчетПереопределяемый.УстановитьДоговорКонтрагента(Параметры.ДоговорСсылка,Параметры.КонтрагентСсылка,Параметры.ОрганизацияСсылка,Параметры.МассивВидовДоговоров);",ПараметрыВыполнения);
								ИначеЕсли Метаданные.ОбщиеМодули.Найти("РаботаСДоговорамиКонтрагентов") <> Неопределено Тогда
									МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("РаботаСДоговорамиКонтрагентов.УстановитьДоговорКонтрагента(Параметры.ДоговорСсылка,Параметры.КонтрагентСсылка,Параметры.ОрганизацияСсылка,Параметры.МассивВидовДоговоров)",ПараметрыВыполнения);
								КонецЕсли;
							Исключение
								
							КонецПопытки;
							
							//+++ Выполнить поиск подходящего запросом, если договоров вдруг больше одного?
							
						КонецЕсли;
					Иначе
						// Договор не нужно создавать, если этот тип документа не требует наличия договора
						СтрокаДокумент.ДоговорНеТребуется = Истина;
					КонецЕсли;
				КонецЕсли;
				
			//УТ 11
			ИначеЕсли Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
				
				Если МодульРаботыВБезопасномРежиме <> Неопределено Тогда
					
					СтруктураПоискаДоговора = Новый Структура;
					СтруктураПоискаДоговора.Вставить("Партнер",СтрокаДокумент.ПартнерСсылка);
					СтруктураПоискаДоговора.Вставить("Договор");
					
					Если Направление = "Входящий" Тогда
						СтруктураПоискаДоговора.Вставить("Контрагент",СтрокаДокумент.ПоставщикСсылка);
						СтруктураПоискаДоговора.Вставить("Организация",СтрокаДокумент.ПлательщикСсылка);
						
						ПараметрыВыполнения.Вставить("ДокументСсылка",СтруктураПоискаДоговора);
						
						Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ПоступлениеУслугПоАренде" Тогда
							Справочники.ДоговорыАренды.ДоговорПоУмолчанию(СтруктураПоискаДоговора.Организация,
								СтруктураПоискаДоговора.Партнер,СтруктураПоискаДоговора.Контрагент,ПараметрыВыполнения.ДоговорСсылка);
								
							//Дальнейший поиск Договора не имеет смысла, так как для этого типа документа используется другой справочник
							Возврат ПараметрыВыполнения.ДоговорСсылка;
							
						Иначе
							//E1C-337: ( Для документа ОтчетКомиссионераОПродажах ищем в договорах с хозяйственной операцией 
							Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
								ПараметрыВыполнения.Вставить("ХозяйственнаяОперация",ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию"));
							Иначе
							// ) E1C-337
								ПараметрыВыполнения.Вставить("ХозяйственнаяОперация",ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика"));
							КонецЕсли;
							
							Попытка
								МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("Параметры.ДоговорСсылка = ЗакупкиСервер.ПолучитьДоговорПоУмолчанию(Параметры.ДокументСсылка,Параметры.ХозяйственнаяОперация)",ПараметрыВыполнения);
							Исключение
								// если при выполнении будет вызвано исключение продолжим работу
							КонецПопытки;
						КонецЕсли;
						
					Иначе
						СтруктураПоискаДоговора.Вставить("Контрагент",СтрокаДокумент.ПлательщикСсылка);
						СтруктураПоискаДоговора.Вставить("Организация",СтрокаДокумент.ПоставщикСсылка);
						
						ПараметрыВыполнения.Вставить("ДокументСсылка",СтруктураПоискаДоговора);
						ПараметрыВыполнения.Вставить("ХозяйственнаяОперация",ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.РеализацияКлиенту"));
						
						Попытка
							МодульРаботыВБезопасномРежиме.ВыполнитьВБезопасномРежиме("Параметры.ДоговорСсылка = ПродажиСервер.ПолучитьДоговорПоУмолчанию(Параметры.ДокументСсылка,Параметры.ХозяйственнаяОперация)",ПараметрыВыполнения);
						Исключение
							// если при выполнении будет вызвано исключение продолжим работу
						КонецПопытки;
						
					КонецЕсли;
					
					//Если не нашли штатным образом, то либо договора не существует, либо их больше одного.
					//Чтобы не создавать дубль найдем запросом первый подходящий
					Если Не ЗначениеЗаполнено(ПараметрыВыполнения.ДоговорСсылка) Тогда
						
						Запрос = Новый Запрос;
						Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
						               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
						               |ИЗ
						               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
						               |ГДЕ
						               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
						               |	И ДоговорыКонтрагентов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует)
						               |	И ДоговорыКонтрагентов.Партнер = &Партнер
						               |	И ДоговорыКонтрагентов.Контрагент = &Контрагент
						               |	И ДоговорыКонтрагентов.Организация = &Организация
						               |	И ДоговорыКонтрагентов.ХозяйственнаяОперация = &ХозяйственнаяОперация";
						
						Запрос.УстановитьПараметр("Партнер",СтруктураПоискаДоговора.Партнер);
						Запрос.УстановитьПараметр("Контрагент",СтруктураПоискаДоговора.Контрагент);
						Запрос.УстановитьПараметр("Организация",СтруктураПоискаДоговора.Организация);
						Запрос.УстановитьПараметр("ХозяйственнаяОперация",ПараметрыВыполнения.ХозяйственнаяОперация);
						
						Выборка = Запрос.Выполнить().Выбрать();
						Если Выборка.Следующий() Тогда
							ПараметрыВыполнения.ДоговорСсылка = Выборка.Ссылка;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			//УНФ
			ИначеЕсли Конф = "УНФ" Тогда
				
				Если Направление = "Входящий" Тогда
					КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
					ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
					ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
				Иначе
					КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
					ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
					ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю;
				КонецЕсли;
				
				Если КонтрагентСсылка.ВестиРасчетыПоДоговорам = Истина Тогда
					СписокВидовДоговоров = Справочники.ДоговорыКонтрагентов.ПолучитьСписокВидовДоговораДляДокумента(СтрокаДокумент.ДокументСсылка,ВидОперации);
					ПараметрыВыполнения.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПолучитьДоговорПоУмолчаниюПоОрганизацииВидуДоговора(КонтрагентСсылка,ОрганизацияСсылка,СписокВидовДоговоров);
					
				Иначе
					ПараметрыВыполнения.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ДоговорПоУмолчанию(КонтрагентСсылка);
					
				КонецЕсли;				
				
			//БП 2.0
			ИначеЕсли Конф = "БП20" Тогда
				
				Если Лок = "BLR" Тогда
					ПараметрыВыполнения.ДоговорСсылка = Справочники.Договора.ПустаяСсылка();
				Иначе
					ПараметрыВыполнения.ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
				КонецЕсли;
				
				МассивВидовДоговоров = Новый Массив;
				
				Если Направление = "Входящий" Тогда
					
					//E1C-327: Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
					Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
						МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));				
					Иначе
					// ) E1C-327
					
						Если Лок = "BLR" Тогда
							МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговора.Покупки"));
						Иначе
							МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
						КонецЕсли;
					КонецЕсли;
					
					ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
					ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
					
				Иначе
					Если Лок = "BLR" Тогда
						МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговора.Продажи"));
					Иначе
						МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
					КонецЕсли;
									
					ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПлательщикСсылка);
					ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПоставщикСсылка);
					
				КонецЕсли;
				
				ПараметрыВыполнения.Вставить("СписокВидовДоговоров",МассивВидовДоговоров);
				
				Если Лок = "BLR" Тогда
					Если ЗначениеЗаполнено(ПараметрыВыполнения.КонтрагентСсылка) Тогда
						ПараметрыВыполнения.ДоговорСсылка = ПараметрыВыполнения.КонтрагентСсылка.ОсновнойДоговор;
					КонецЕсли;
				Иначе
					ЭтотОбъект._УФ_ВыполнитьВНебезопасномРежиме("УправлениеВзаиморасчетами.УстановитьДоговорКонтрагента(Параметры.ДоговорСсылка,Параметры.КонтрагентСсылка,Параметры.ОрганизацияСсылка,Параметры.СписокВидовДоговоров)",ПараметрыВыполнения);
				КонецЕсли;
				
			//УТ 10
			ИначеЕсли Конф = "УТ10" Или Конф = "КА1" Или Конф = "УПП" Тогда
			
				Если СтрокаДокумент.ТипСоздаваемогоДокумента = "РасходныйОрдерНаТовары" Тогда
					// Договор не нужно создавать, если этот тип документа не требует наличия договора
					СтрокаДокумент.ДоговорНеТребуется = Истина;
					
				Иначе
				
					МассивВидовДоговоров = Новый Массив;
					
					Если Направление = "Входящий" Тогда
						
						//E1C-327: Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
						Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
							МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));				
						Иначе
						// ) E1C-327
						
							МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
						КонецЕсли;
						
						ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
						ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
						
					Иначе
						МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
						
						ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПлательщикСсылка);
						ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПоставщикСсылка);
						
					КонецЕсли;
					
					СтруктураПараметровДляПолученияДоговора = Новый Структура("СписокДопустимыхВидовДоговоров",МассивВидовДоговоров);
					
					
					ПараметрыВыполнения.Вставить("СтруктураПараметровДляПолученияДоговора",СтруктураПараметровДляПолученияДоговора);
					
					ЭтотОбъект._УФ_ВыполнитьВНебезопасномРежиме("ПараметрыВыполнения.ДоговорСсылка = ЗаполнениеДокументов.ПолучитьДоговорПоОрганизацииИКонтрагенту(Параметры.ОрганизацияСсылка,Параметры.КонтрагентСсылка,Параметры.СтруктураПараметровДляПолученияДоговора);",ПараметрыВыполнения);
					
					//Если не нашли штатным образом, то либо договора не существует, либо их больше одного.
					//Чтобы не создавать дубль найдем запросом первый подходящий
					Если Не ЗначениеЗаполнено(ПараметрыВыполнения.ДоговорСсылка) Тогда
						
						Запрос = Новый Запрос;
						Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
						               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
						               |ИЗ
						               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
						               |ГДЕ
						               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
						               |	И ДоговорыКонтрагентов.Владелец = &Контрагент
						               |	И ДоговорыКонтрагентов.Организация = &Организация
									   |	И ДоговорыКонтрагентов.ВидДоговора В (&МассивВидовДоговоров)";
						
						Если ЗначениеЗаполнено(МассивВидовДоговоров) Тогда
							Запрос.УстановитьПараметр("МассивВидовДоговоров",МассивВидовДоговоров);
						Иначе
							Запрос.Текст = СтрЗаменить(Запрос.Текст,"И ДоговорыКонтрагентов.ВидДоговора В (&МассивВидовДоговоров)","");
						КонецЕсли;
						
						Запрос.УстановитьПараметр("Контрагент",ПараметрыВыполнения.КонтрагентСсылка);
						Запрос.УстановитьПараметр("Организация",ПараметрыВыполнения.ОрганизацияСсылка);
						
						Выборка = Запрос.Выполнить().Выбрать();
						Если Выборка.Следующий() Тогда
							ПараметрыВыполнения.ДоговорСсылка = Выборка.Ссылка;
						КонецЕсли;
					КонецЕсли;
					
				КонецЕсли;
				
			ИначеЕсли Конф = "Автосалон" Или Конф = "КомбинатПитания" Или Конф = "УправлениеРестораном" Тогда
				
				МассивВидовДоговоров = Новый Массив;
				
				Если Направление = "Входящий" Тогда
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоров.Покупка"));
					
					ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
					ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
					
				Иначе
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоров.Продажа"));
					
					ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПлательщикСсылка);
					ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПоставщикСсылка);
					
				КонецЕсли;
				
				СтруктураПараметровДляПолученияДоговора = Новый Структура("СписокДопустимыхВидовДоговоров",МассивВидовДоговоров);
				
				
				ПараметрыВыполнения.Вставить("СтруктураПараметровДляПолученияДоговора",СтруктураПараметровДляПолученияДоговора);
				
				ЭтотОбъект._УФ_ВыполнитьВНебезопасномРежиме("Параметры.ДоговорСсылка = ЗаполнениеДокументов.ПолучитьДоговорПоОрганизацииИКонтрагенту(Параметры.ОрганизацияСсылка,Параметры.КонтрагентСсылка,Параметры.СтруктураПараметровДляПолученияДоговора);",ПараметрыВыполнения);
				
				//Если не нашли штатным образом, то либо договора не существует, либо их больше одного.
				//Чтобы не создавать дубль найдем запросом первый подходящий
				Если Не ЗначениеЗаполнено(ПараметрыВыполнения.ДоговорСсылка) Тогда
					
					Запрос = Новый Запрос;
					Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
					               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
					               |ИЗ
					               |	Справочник.ДоговорыВзаиморасчетов КАК ДоговорыКонтрагентов
					               |ГДЕ
					               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
					               |	И ДоговорыКонтрагентов.Владелец = &Контрагент
					               |	И ДоговорыКонтрагентов.Организация = &Организация";
					
					Запрос.УстановитьПараметр("Контрагент",ПараметрыВыполнения.КонтрагентСсылка);
					Запрос.УстановитьПараметр("Организация",ПараметрыВыполнения.ОрганизацияСсылка);
					
					Выборка = Запрос.Выполнить().Выбрать();
					Если Выборка.Следующий() Тогда
						ПараметрыВыполнения.ДоговорСсылка = Выборка.Ссылка;
					КонецЕсли;
				КонецЕсли;
				
			Иначе
				//что-то совсем нетиповое
				
				Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Имя = "МояБухгалтерия" Тогда
					
					Если Направление = "Входящий" Тогда
						ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПоставщикСсылка);
						ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПлательщикСсылка);
						
					Иначе
						ПараметрыВыполнения.Вставить("КонтрагентСсылка",СтрокаДокумент.ПлательщикСсылка);
						ПараметрыВыполнения.Вставить("ОрганизацияСсылка",СтрокаДокумент.ПоставщикСсылка);
						
					КонецЕсли;
						
					Запрос = Новый Запрос;
					Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
					               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
					               |ИЗ
					               |	Справочник.Договора КАК ДоговорыКонтрагентов
					               |ГДЕ
					               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
					               |	И ДоговорыКонтрагентов.Владелец = &Контрагент
					               |	И ДоговорыКонтрагентов.Организация = &Организация";
					
					Запрос.УстановитьПараметр("Контрагент",ПараметрыВыполнения.КонтрагентСсылка);
					Запрос.УстановитьПараметр("Организация",ПараметрыВыполнения.ОрганизацияСсылка);
					
					Выборка = Запрос.Выполнить().Выбрать();
					Если Выборка.Следующий() Тогда
						ПараметрыВыполнения.ДоговорСсылка = Выборка.Ссылка;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			ДоговорСсылка = ПараметрыВыполнения.ДоговорСсылка;
			
		КонецЕсли; //Исходный вариант поиска
		
	КонецЕсли; //Стандартный поиск без кастомизации
	
	Возврат ДоговорСсылка;
	
КонецФункции

Функция ПолучитьСсылку_ДоговорПоРаспознаннымДанным(СтрокаДокумент,Направление,СтруктураНастроек)
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	Лок = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок;
	
	//E1C-484: Сопоставление и создание Договора в 1С по распознанным данным "Основание передачи"
	//Требуется производить поиск похожего Договора в справочнике Договоров между поставщиком и плательщиком по параметрам:
	//1) Искать похожий договор по совпадению "Наименование договора" (если возможно, игнорируя пробелы и символы вида точки, запятой, №).
	//2) Если ничего не найдено, подбирать договор с идентичными реквизитами Дата и номер (игнорировать язык написания символов в номере).
	//3) Если ничего не найдено, то подбирать договор с идентичным реквизитом Дата.
	
	//Поскольку запрашиваемые варианты поиска не зависят явным образом от используемой конфигурации, а оперируют сравнением с распознанными данными,
	//рассматриваем такой порядок работы: получаем определяемую структурой конфигурации коллекцию договоров между Организацией и Контрагентом
	//и выполняем общий обработчик этой выборки для поиска подходящего договора по заданным условиям
	
	//По новым вводным из задачи 305690: дополнительно ищем основной договор: "помеченный в 1С флагом "использовать как основной" в договорах с КА"
	
	//БП30
	Если Конф = "БП30" Тогда
	
		МассивВидовДоговоров = Новый Массив;
								
		//Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
		Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
			МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));
							
			КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
			
		Иначе
		
			Если Направление = "Входящий" Тогда
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
								
				КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
				ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
				
			Иначе
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
								
				КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
				ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
				
			КонецЕсли;
			
		КонецЕсли;
		
		//По новым вводным дополнительно ищем основной договор
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
		               |	ДоговорыКонтрагентов.Наименование КАК Наименование,
		               |	ДоговорыКонтрагентов.Номер КАК Номер,
		               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.Дата, ДЕНЬ) КАК Дата
		               |ИЗ
		               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		               |ГДЕ
		               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
		               |	И ДоговорыКонтрагентов.Организация = &Организация
		               |	И ДоговорыКонтрагентов.Владелец = &Владелец
		               |	И ДоговорыКонтрагентов.ВидДоговора В(&ВидДоговора)
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ОсновныеДоговорыКонтрагента.Договор КАК Договор
		               |ИЗ
		               |	РегистрСведений.ОсновныеДоговорыКонтрагента КАК ОсновныеДоговорыКонтрагента
		               |ГДЕ
		               |	ОсновныеДоговорыКонтрагента.Организация = &Организация
		               |	И ОсновныеДоговорыКонтрагента.Контрагент = &Владелец
		               |	И ОсновныеДоговорыКонтрагента.ВидДоговора В(&ВидДоговора)";
		Запрос.УстановитьПараметр("Организация",ОрганизацияСсылка);
		Запрос.УстановитьПараметр("Владелец",КонтрагентСсылка);
		Запрос.УстановитьПараметр("ВидДоговора",МассивВидовДоговоров);
		
		//В KAZ-версии Бухгалтерии имя реквизита Номер и Дата у договора НомерДоговора и ДатаДоговора
		Если Лок = "KAZ" Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ДоговорыКонтрагентов.Номер","ДоговорыКонтрагентов.НомерДоговора");
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ДоговорыКонтрагентов.Дата","ДоговорыКонтрагентов.ДатаДоговора");
		КонецЕсли;
		
		РезультатЗапроса = Запрос.ВыполнитьПакет();
		Выборка = РезультатЗапроса[0].Выбрать();
		ВыборкаОсновнойДоговор = РезультатЗапроса[1].Выбрать();
		
		Если ВыборкаОсновнойДоговор.Следующий() Тогда
			ОсновнойДоговорСсылка = ВыборкаОсновнойДоговор.Договор;
		КонецЕсли;		
		
	//УТ 11
	ИначеЕсли Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
		
		ПартнерСсылка = СтрокаДокумент.ПартнерСсылка;
							
		Если Направление = "Входящий" Тогда
			КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
						
			//Для документа ОтчетКомиссионераОПродажах ищем в договорах с хозяйственной операцией 
			Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионера" Тогда
				ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию");
			Иначе
				ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ЗакупкаУПоставщика");
			КонецЕсли;
				
		Иначе
			КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
						
			ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.РеализацияКлиенту");
						
		КонецЕсли;
					
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
					   |	ДоговорыКонтрагентов.Наименование КАК Наименование,
		               |	ДоговорыКонтрагентов.Номер КАК Номер,
		               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.Дата, ДЕНЬ) КАК Дата
		               |ИЗ
		               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		               |ГДЕ
		               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
		               |	И ДоговорыКонтрагентов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует)
		               |	И ДоговорыКонтрагентов.Партнер = &Партнер
		               |	И ДоговорыКонтрагентов.Контрагент = &Контрагент
		               |	И ДоговорыКонтрагентов.Организация = &Организация
		               |	И ДоговорыКонтрагентов.ХозяйственнаяОперация = &ХозяйственнаяОперация";
		
		Запрос.УстановитьПараметр("Партнер",ПартнерСсылка);
		Запрос.УстановитьПараметр("Контрагент",КонтрагентСсылка);
		Запрос.УстановитьПараметр("Организация",ОрганизацияСсылка);
		Запрос.УстановитьПараметр("ХозяйственнаяОперация",ХозяйственнаяОперация);
		
		Выборка = Запрос.Выполнить().Выбрать();						
		
		//По новым вводным дополнительно ищем основной договор. В УТ11 нет регистра ОсновныеДоговорыКонтрагентов,
		//просто получим первый из выбранных того же запроса, если договор не будет определен по требуемому алгоритму
		ВыборкаОсновнойДоговор = Запрос.Выполнить().Выбрать();
		
		Если ВыборкаОсновнойДоговор.Следующий() Тогда
			ОсновнойДоговорСсылка = ВыборкаОсновнойДоговор.Ссылка;
		КонецЕсли;		
		
	//УНФ
	ИначеЕсли Конф = "УНФ" Тогда
		
		Если Направление = "Входящий" Тогда
			КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
			ВидОперации = Перечисления.ВидыОперацийПриходнаяНакладная.ПоступлениеОтПоставщика;
		Иначе
			КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
			ВидОперации = Перечисления.ВидыОперацийРасходнаяНакладная.ПродажаПокупателю;
		КонецЕсли;
		
		Если КонтрагентСсылка.ВестиРасчетыПоДоговорам = Истина Тогда
			СписокВидовДоговоров = Справочники.ДоговорыКонтрагентов.ПолучитьСписокВидовДоговораДляДокумента(СтрокаДокумент.ДокументСсылка,ВидОперации);
			ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ПолучитьДоговорПоУмолчаниюПоОрганизацииВидуДоговора(КонтрагентСсылка,ОрганизацияСсылка,СписокВидовДоговоров);
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
			               |	ДоговорыКонтрагентов.Наименование КАК Наименование,
			               |	ДоговорыКонтрагентов.НомерДоговора КАК Номер,
			               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.ДатаДоговора, ДЕНЬ) КАК Дата
			               |ИЗ
			               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
			               |ГДЕ
			               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
			               |	И ДоговорыКонтрагентов.Организация = &Организация
			               |	И ДоговорыКонтрагентов.Владелец = &Владелец
			               |	И ДоговорыКонтрагентов.ВидДоговора В(&ВидДоговора)
			               |;
			               |
			               |////////////////////////////////////////////////////////////////////////////////
			               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ОсновныеДоговорыКонтрагента.Договор КАК Договор
			               |ИЗ
			               |	РегистрСведений.ОсновныеДоговорыКонтрагента КАК ОсновныеДоговорыКонтрагента
			               |ГДЕ
			               |	ОсновныеДоговорыКонтрагента.Организация = &Организация
			               |	И ОсновныеДоговорыКонтрагента.Контрагент = &Владелец
			               |	И ОсновныеДоговорыКонтрагента.ВидДоговора В(&ВидДоговора)";
			Запрос.УстановитьПараметр("Организация",ОрганизацияСсылка);
			Запрос.УстановитьПараметр("Владелец",КонтрагентСсылка);
			Запрос.УстановитьПараметр("ВидДоговора",СписокВидовДоговоров);
			
			РезультатЗапроса = Запрос.ВыполнитьПакет();
			Выборка = РезультатЗапроса[0].Выбрать();
			ВыборкаОсновнойДоговор = РезультатЗапроса[1].Выбрать();
			
			Если ВыборкаОсновнойДоговор.Следующий() Тогда
				ОсновнойДоговорСсылка = ВыборкаОсновнойДоговор.Договор;
			КонецЕсли;
			
		Иначе
			ДоговорСсылка = Справочники.ДоговорыКонтрагентов.ДоговорПоУмолчанию(КонтрагентСсылка);
			
		КонецЕсли;
		
		//БП 2.0
	ИначеЕсли Конф = "БП20" Тогда
		
		МассивВидовДоговоров = Новый Массив;
		
		Если Направление = "Входящий" Тогда
			
			//Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
			Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));				
			Иначе
				Если Лок = "BLR" Тогда
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговора.Покупки"));
				Иначе
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
				КонецЕсли;
			КонецЕсли;
			
			КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
			
		Иначе
			Если Лок = "BLR" Тогда
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговора.Продажи"));
			Иначе
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
			КонецЕсли;
							
			КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
			ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
			
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Организация",ОрганизацияСсылка);
		Запрос.УстановитьПараметр("Владелец",КонтрагентСсылка);
		Запрос.УстановитьПараметр("ВидДоговора",МассивВидовДоговоров);
		
		Если Лок = "BLR" Тогда
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
			               |	ДоговорыКонтрагентов.Наименование КАК Наименование,
			               |	ДоговорыКонтрагентов.НомерДоговора КАК Номер,
			               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.ДатаДоговора, ДЕНЬ) КАК Дата
			               |ИЗ
			               |	Справочник.Договора КАК ДоговорыКонтрагентов
			               |ГДЕ
			               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
			               |	И ДоговорыКонтрагентов.Организация = &Организация
			               |	И ДоговорыКонтрагентов.Владелец = &Владелец
			               |	И ДоговорыКонтрагентов.ВидДоговора В(&ВидДоговора)";
			
			//По новым вводным дополнительно ищем основной договор
			Если ЗначениеЗаполнено(КонтрагентСсылка.ОсновнойДоговор)
				И КонтрагентСсылка.ОсновнойДоговор.Организация = ОрганизацияСсылка Тогда
				ОсновнойДоговорСсылка = КонтрагентСсылка.ОсновнойДоговор;
			КонецЕсли;
			
		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
			               |	ДоговорыКонтрагентов.Наименование КАК Наименование,
			               |	ДоговорыКонтрагентов.Номер КАК Номер,
			               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.Дата, ДЕНЬ) КАК Дата
			               |ИЗ
			               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
			               |ГДЕ
			               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
			               |	И ДоговорыКонтрагентов.Организация = &Организация
			               |	И ДоговорыКонтрагентов.Владелец = &Владелец
			               |	И ДоговорыКонтрагентов.ВидДоговора В(&ВидДоговора)";
			
			//По новым вводным дополнительно ищем основной договор
			Если ЗначениеЗаполнено(КонтрагентСсылка.ОсновнойДоговорКонтрагента)
				И КонтрагентСсылка.ОсновнойДоговорКонтрагента.Организация = ОрганизацияСсылка Тогда
				ОсновнойДоговорСсылка = КонтрагентСсылка.ОсновнойДоговорКонтрагента;
			КонецЕсли;
			
		КонецЕсли;
		
		Выборка = Запрос.Выполнить().Выбрать();
		
	//УТ 10
	ИначеЕсли Конф = "УТ10" Или Конф = "КА1" Или Конф = "УПП" Тогда
	
		Если СтрокаДокумент.ТипСоздаваемогоДокумента = "РасходныйОрдерНаТовары" Тогда
			// Договор не нужно создавать, если этот тип документа не требует наличия договора
			СтрокаДокумент.ДоговорНеТребуется = Истина;
			
		Иначе
		
			МассивВидовДоговоров = Новый Массив;
			
			Если Направление = "Входящий" Тогда
				
				//Для документа ОтчетКомиссионераОПродажах ищем в договорах с видом СКомиссионером
				Если СтрокаДокумент.ТипСоздаваемогоДокумента = "ОтчетКомиссионераОПродажах" Тогда
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СКомиссионером"));				
				Иначе
					МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПоставщиком"));
				КонецЕсли;
				
				КонтрагентСсылка = СтрокаДокумент.ПоставщикСсылка;
				ОрганизацияСсылка = СтрокаДокумент.ПлательщикСсылка;
				
			Иначе
				МассивВидовДоговоров.Добавить(ПредопределенноеЗначение("Перечисление.ВидыДоговоровКонтрагентов.СПокупателем"));
				
				КонтрагентСсылка = СтрокаДокумент.ПлательщикСсылка;
				ОрганизацияСсылка = СтрокаДокумент.ПоставщикСсылка;
				
			КонецЕсли;
			
			СтруктураПараметровДляПолученияДоговора = Новый Структура("СписокДопустимыхВидовДоговоров",МассивВидовДоговоров);
				
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
			               |	ДоговорыКонтрагентов.Наименование КАК Наименование,
			               |	ДоговорыКонтрагентов.Номер КАК Номер,
			               |	НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.Дата, ДЕНЬ) КАК Дата
			               |ИЗ
			               |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
			               |ГДЕ
			               |	НЕ ДоговорыКонтрагентов.ПометкаУдаления
			               |	И ДоговорыКонтрагентов.Владелец = &Контрагент
			               |	И ДоговорыКонтрагентов.Организация = &Организация
			               |	И ДоговорыКонтрагентов.ВидДоговора В(&МассивВидовДоговоров)";
			
			Если ЗначениеЗаполнено(МассивВидовДоговоров) Тогда
				Запрос.УстановитьПараметр("МассивВидовДоговоров",МассивВидовДоговоров);
			Иначе
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"И ДоговорыКонтрагентов.ВидДоговора В (&МассивВидовДоговоров)","");
			КонецЕсли;
				
			Запрос.УстановитьПараметр("Контрагент",КонтрагентСсылка);
			Запрос.УстановитьПараметр("Организация",ОрганизацияСсылка);
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			//По новым вводным дополнительно ищем основной договор
			Если ЗначениеЗаполнено(КонтрагентСсылка.ОсновнойДоговорКонтрагента)
				И КонтрагентСсылка.ОсновнойДоговорКонтрагента.Организация = ОрганизацияСсылка Тогда
				ОсновнойДоговорСсылка = КонтрагентСсылка.ОсновнойДоговорКонтрагента;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Выборка <> Неопределено Тогда
		
		ИскомоеНаименование = СтрокаДокумент.ПредставлениеДоговора;
		ИскомыеНомера = ПолучитьМассивВариантовНаписанияНомера(СтрокаДокумент.transferBaseNumber);
		Если ЗначениеЗаполнено(СтрокаДокумент.transferBaseDate) Тогда
			ИскомаяДата = НачалоДня(СтрокаДокумент.transferBaseDate);
		КонецЕсли;
		
		Пока Выборка.Следующий() Цикл
			
			Если Выборка.Наименование = ИскомоеНаименование Тогда
				СсылкаПоНаименованию = Выборка.Ссылка;
			КонецЕсли;
				
			Если Выборка.Дата = ИскомаяДата И ИскомыеНомера.Найти(Выборка.Номер) <> Неопределено Тогда
				СсылкаПоНомеруДате = Выборка.Ссылка;
			КонецЕсли;
			
			Если ИскомыеНомера.Найти(Выборка.Номер) <> Неопределено Тогда
				СсылкаПоНомеру = Выборка.Ссылка;
			КонецЕсли;
			
			Если Выборка.Дата = ИскомаяДата Тогда
				СсылкаПоДате = Выборка.Ссылка;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(СсылкаПоНаименованию) Тогда
			ДоговорСсылка = СсылкаПоНаименованию;
		ИначеЕсли ЗначениеЗаполнено(СсылкаПоНомеруДате) Тогда
			ДоговорСсылка = СсылкаПоНомеруДате;
		ИначеЕсли ЗначениеЗаполнено(СсылкаПоДате) Тогда
			ДоговорСсылка = СсылкаПоДате;
		ИначеЕсли ЗначениеЗаполнено(СсылкаПоНомеру) Тогда
			ДоговорСсылка = СсылкаПоНомеру;
			
		//По новым вводным дополнительно ищем основной договор
		Иначе
			ДоговорСсылка = ОсновнойДоговорСсылка;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДоговорСсылка;
	
КонецФункции

Функция ПолучитьСсылку_БанковскийСчет(ПоляПоиска,СтруктураНастроек) Экспорт
		
	СведенияОКонфигурации = СтруктураНастроек.СведенияОКонфигурации;
	
	Если ЗначениеЗаполнено(СведенияОКонфигурации.Банк_ИмяСправочникаБанковскиеСчетаКонтрагентов) Тогда
		
		//БГУ
		Если СведенияОКонфигурации.Конфигурация.Крат = "БГУ"
			Или СведенияОКонфигурации.Конфигурация.Крат = "БГУ2" Тогда
			ИмяРеквизита_НомерСчета = "Код";
		Иначе
			ИмяРеквизита_НомерСчета = "НомерСчета";
		КонецЕсли;
		
		//Выполнять поиск по БИК
		ИмяРеквизитаБанк = СведенияОКонфигурации.БанковскийСчет_ИмяРеквизитаБанк;
		ИмяРеквизитаБИК = СведенияОКонфигурации.Банк_ИмяРеквизитаБИК;
		ПоискПоБИК = ЗначениеЗаполнено(ИмяРеквизитаБанк) И ЗначениеЗаполнено(ИмяРеквизитаБИК);
		
		Результат = Справочники[СведенияОКонфигурации.Банк_ИмяСправочникаБанковскиеСчетаКонтрагентов].ПустаяСсылка();
		
		Выборка = Справочники[СведенияОКонфигурации.Банк_ИмяСправочникаБанковскиеСчетаКонтрагентов].Выбрать(,ПоляПоиска.Владелец);
		
		Пока Выборка.Следующий() Цикл
			
			Если СокрЛП(Выборка[ИмяРеквизита_НомерСчета]) = ПоляПоиска.НомерСчета И Не Выборка.ПометкаУдаления Тогда
				
				Если ПоискПоБИК Тогда
					Если Выборка[ИмяРеквизитаБанк][ИмяРеквизитаБИК] = ПоляПоиска.БИК Тогда
						Результат = Выборка.Ссылка;
						Прервать;
					КонецЕсли;
				Иначе
					Результат = Выборка.Ссылка;
					Прервать;
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
		
	Возврат Результат;
КонецФункции

Функция ПолучитьСсылку_НоменклатураПоЗаданномуАлгоритмуПоиска(СтрокаНоменклатура,ДанныеДокумента,СтруктураНастроек) Экспорт
	
	//E1C-79: добавлен поиск по справочнику Номенклатура поставщиков
	Если СтруктураНастроек.Номенклатура_ИспользоватьНоменклатуруПоставщиков = Истина
		И ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ДлинаНаименованияНоменклатуры) Тогда
		ИмяСправочникаДляПоиска = СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяСправочника;
		ДлинаНаименованияНоменклатуры = СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ДлинаНаименованияНоменклатуры;
		ИмяРеквизитаАртикул = СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_ИмяРеквизитаАртикул;
				
		ПоискПоНоменклатуреПоставщиков = Истина;
	Иначе
		ИмяСправочникаДляПоиска = "Номенклатура";	
		ДлинаНаименованияНоменклатуры = СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ДлинаНаименованияНоменклатуры;
		ИмяРеквизитаАртикул = СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаАртикул;
		
		ПоискПоНоменклатуреПоставщиков = Ложь;
	КонецЕсли;
	
	//E1C-490: При поиске сопоставлений по Артикулу игнорировать язык распознанных символов:
	Если Найти(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры,"Артикул") > 0 Тогда
		МассивИскомыхАртикулов = ПолучитьМассивВариантовНаписанияНомера(СтрокаНоменклатура.recognizedGoodCode);
	КонецЕсли;
	
	
	Если ПоискПоНоменклатуреПоставщиков Тогда
		
		//УТ11,KA2,ERP: Дополнительный отбор по владельцу-партнеру, без него поиск не выполняем
		ДополнительныйОтбор = Неопределено;
		
		//2021.12.08 ( БП30: поиск по владельцу-контрагенту для тех, кто включил использование НоменклатурыПоставщика в БП30
		Если СтруктураНастроек.СведенияОКонфигурации.НоменклатураПоставщиков_Владелец = "Контрагент" Тогда
			ДополнительныйОтбор = Новый Структура("Владелец",ДанныеДокумента.ПоставщикСсылка);
		// ) 2021.12.08 
		
		ИначеЕсли ЗначениеЗаполнено(ДанныеДокумента.ПартнерСсылка) Тогда
			ДополнительныйОтбор = Новый Структура("Владелец",ДанныеДокумента.ПартнерСсылка);
			
		КонецЕсли;
		
		Если ДополнительныйОтбор <> Неопределено Тогда
			Если Не ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры)
				Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование" Тогда
				НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
			
			//Поиск по артикулу выполняется только если определили реквизит Артикул номенклатуры при анализе конфигурации	
			ИначеЕсли ЗначениеЗаполнено(ИмяРеквизитаАртикул) Тогда
				
				Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул" Тогда
					НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
					
				ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул,Наименование" Тогда
					НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
					
					Если Не ЗначениеЗаполнено(НоменклатураПоставщикаСсылка) Тогда
						НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
					КонецЕсли;
					
				ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование,Артикул" Тогда
					
					НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
					
					Если Не ЗначениеЗаполнено(НоменклатураПоставщикаСсылка) Тогда
						НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				//оставляем исходный вариант, просто поиск по наименованию
				НоменклатураПоставщикаСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
				
			КонецЕсли;
			
		КонецЕсли;
		
		СтрокаНоменклатура.НоменклатураПоставщикаСсылка = НоменклатураПоставщикаСсылка;
		
		//Нужно вернуть ссылку на номенклатуру
		Если ЗначениеЗаполнено(НоменклатураПоставщикаСсылка) Тогда
			НоменклатураСсылка =  НоменклатураПоставщикаСсылка.Номенклатура;
		КонецЕсли; 
		
	Иначе
		
		ДополнительныйОтбор = Неопределено;
		
		//E1C-271: определим список групп для поиска этой номенклатуры - передадим его в дополнительных параметрах поиска
		СписокГрупп = ПолучитьСписокГруппДляПоискаНоменклатуры(СтрокаНоменклатура,СтруктураНастроек);
		Если СписокГрупп.Количество() > 0 Тогда
			ДополнительныйОтбор = Новый Структура("В_ИЕРАРХИИ",СписокГрупп);
		КонецЕсли;
		
		//УНФ: отбор по реквизиту 
		Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен) Тогда
			КлючОтбора = СтруктураНастроек.СведенияОКонфигурации.Номенклатура_ИмяРеквизитаНедействителен;
			Если ДополнительныйОтбор = Неопределено Тогда
				ДополнительныйОтбор = Новый Структура(КлючОтбора,Ложь);
			Иначе
				ДополнительныйОтбор.Вставить(КлючОтбора,Ложь);
			КонецЕсли;
		КонецЕсли;
		
		
		Если Не ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры)
			Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование" Тогда
			НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
			
		//2022.06.29 ( Поиск по полному наименованию	
		ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование полное" Тогда
			НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(СтрокаНоменклатура.name,ИмяСправочникаДляПоиска,"НаименованиеПолное",,ДополнительныйОтбор);
		// ) 2022.06.29
			
		//Поиск по артикулу выполняется только если определили реквизит Артикул номенклатуры при анализе конфигурации	
		ИначеЕсли ЗначениеЗаполнено(ИмяРеквизитаАртикул) Тогда
			
			Если СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул" Тогда
				НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
				
			ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Артикул,Наименование" Тогда
				НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
				
				Если Не ЗначениеЗаполнено(НоменклатураСсылка) Тогда
					НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
				КонецЕсли;
				
			ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование,Артикул" Тогда
				
				НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
				
				Если Не ЗначениеЗаполнено(НоменклатураСсылка) Тогда
					НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(МассивИскомыхАртикулов,ИмяСправочникаДляПоиска,ИмяРеквизитаАртикул,,ДополнительныйОтбор);
				КонецЕсли;
				
			КонецЕсли;
			
		Иначе
			//оставляем исходный вариант, просто поиск по наименованию
			НоменклатураСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименованияНоменклатуры),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
			
		КонецЕсли;
			
	КонецЕсли;
	
	Возврат НоменклатураСсылка;
		
КонецФункции

Функция ПолучитьСсылку_ОсновноеСредствоПоЗаданномуАлгоритмуПоиска(СтрокаНоменклатура,СтруктураНастроек) Экспорт
	
	ИмяСправочникаДляПоиска = "ОсновныеСредства";
	ДлинаНаименования = Метаданные.Справочники.ОсновныеСредства.ДлинаНаименования;
	
	ДополнительныйОтбор = Неопределено;	
	
	Если Не ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры)
		Или СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование" Тогда
		ОсновноеСредствоСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименования),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
		
	//Поиск по полному наименованию	
	ИначеЕсли СтруктураНастроек.Номенклатура_АлгоритмПоискаНоменклатуры = "Наименование полное" Тогда
		ОсновноеСредствоСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(СтрокаНоменклатура.name,ИмяСправочникаДляПоиска,"НаименованиеПолное",,ДополнительныйОтбор);
		
	Иначе
		//оставляем исходный вариант, просто поиск по наименованию
		ОсновноеСредствоСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(Лев(СтрокаНоменклатура.name,ДлинаНаименования),ИмяСправочникаДляПоиска,,,ДополнительныйОтбор);
		
	КонецЕсли;
	
	Возврат ОсновноеСредствоСсылка;
		
КонецФункции

Функция ПолучитьСсылку_УпаковкаЕдиницаИзмерения(СтрокаНоменклатура,СтруктураНастроек,ПовторныйВызовПоискаПоСинонимам = Ложь) Экспорт
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	Лок = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок;
	
	Если ЗначениеЗаполнено(СтрокаНоменклатура.unitExternalId) Тогда
		Если Конф = "БП30" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"КлассификаторЕдиницИзмерения");
			
		ИначеЕсли Конф = "УНФ" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"КлассификаторЕдиницИзмерения");
			
		ИначеЕсли Конф = "РОЗН3" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"КлассификаторЕдиницИзмерения");
			
		ИначеЕсли Конф = "РОЗН2" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"БазовыеЕдиницыИзмерения");
		
		ИначеЕсли Конф = "ЭДО" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"ЕдиницыИзмерения");
			
		ИначеЕсли Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"УпаковкиЕдиницыИзмерения");
			
		ИначеЕсли Конф = "БП30" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"КлассификаторЕдиницИзмерения");
			
		ИначеЕсли Конф = "УТ10" Или Конф = "КА1" Или Конф = "УПП" Или Конф = "Автосалон" Или Конф = "КомбинатПитания" Или Конф = "УправлениеРестораном" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(СтрокаНоменклатура.unitExternalId,"ЕдиницыИзмерения");
		
		КонецЕсли;
	КонецЕсли;
	
	// Поиск единицы измерения/упаковки по наименованию
	Если Не ЗначениеЗаполнено(ЕдиницаИзмеренияСсылка) Тогда
		
		Если Конф = "БП30" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(СтрокаНоменклатура.userUnitName,"КлассификаторЕдиницИзмерения");
			
		ИначеЕсли Конф = "БГУ2" Тогда
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_ОбъектПоРеквизиту(СтрокаНоменклатура.userUnitName,"КлассификаторЕдиницИзмерения");
			
