Функция ПолучитьСсылку_ДокументПоНомеруДатеВходящегоДокумента(ТипДокумента,Контрагент,Номер,Дата,СуществующийДокумент) Экспорт
	
	//Функция устарела и больше не используется, оставлена для обратной совместимости при вызове из модуля кастомизации.
	//Используется вызов функции ПолучитьСсылку_ДокументПоПараметрамВходящегоДокумента
	
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("Контрагент",Контрагент);
	ПараметрыПоиска.Вставить("Номер",Номер);
	ПараметрыПоиска.Вставить("Дата",Дата);
	
	Результат = ПолучитьСсылку_ДокументПоПараметрамВходящегоДокумента(ТипДокумента,ПараметрыПоиска,СуществующийДокумент);
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСсылку_ДокументПоПараметрамВходящегоДокумента(ТипДокумента,ПараметрыПоиска,СуществующийДокумент) Экспорт
	
	Перем Организация,Контрагент,Номер,Дата,Сумма;
	
	ПараметрыПоиска.Свойство("Организация",Организация);
	ПараметрыПоиска.Свойство("Контрагент",Контрагент);
	ПараметрыПоиска.Свойство("Номер",Номер);
	ПараметрыПоиска.Свойство("Дата",Дата);
	ПараметрыПоиска.Свойство("Сумма",Сумма);	
	
	Если ЗначениеЗаполнено(Номер)
		И ЗначениеЗаполнено(Дата) Тогда
		
		//В КА2, УТ11, ERP нумерация СФП выполняется в номере самого документа, а не НомерВходящегоДокумента/ДатаВходящегоДокумента,
		//+++ чтобы каждый раз не дергать метаданные, можно перенести это условие в форму настроек
		Если ТипДокумента = "СчетФактураПолученный" Тогда
			Если ЗначениеЗаполнено(Контрагент) Тогда
				Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("Контрагент") <> Неопределено Тогда
					ИмяРеквизитаКонтрагент = "Контрагент";
				КонецЕсли;
			КонецЕсли;
			
			Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("НомерВходящегоДокумента") <> Неопределено Тогда
				ИмяРеквизитаНомерВходящегоДокумента = "НомерВходящегоДокумента"
			Иначе
				ИмяРеквизитаНомерВходящегоДокумента = "Номер";
			КонецЕсли;
			
			Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("ДатаВходящегоДокумента") <> Неопределено Тогда
				ИмяРеквизитаДатаВходящегоДокумента = "ДатаВходящегоДокумента"
			Иначе
				ИмяРеквизитаДатаВходящегоДокумента = "Дата";
			КонецЕсли;
			
		Иначе
			Если ПараметрыПоиска.Свойство("Контрагент") Тогда
				Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("Контрагент") <> Неопределено Тогда
					ИмяРеквизитаКонтрагент = "Контрагент";
				КонецЕсли;
			КонецЕсли;
			
			Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("НомерВходящегоДокумента") <> Неопределено Тогда
				ИмяРеквизитаНомерВходящегоДокумента = "НомерВходящегоДокумента";
			ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("НомерПоДаннымПоставщика") <> Неопределено Тогда
				ИмяРеквизитаНомерВходящегоДокумента = "НомерПоДаннымПоставщика";
			ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("ВхДокНомер") <> Неопределено Тогда
				ИмяРеквизитаНомерВходящегоДокумента = "ВхДокНомер";
			КонецЕсли;
			
			Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("ДатаВходящегоДокумента") <> Неопределено Тогда
				ИмяРеквизитаДатаВходящегоДокумента = "ДатаВходящегоДокумента";
			ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("ДатаПоДаннымПоставщика") <> Неопределено Тогда
				ИмяРеквизитаДатаВходящегоДокумента = "ДатаПоДаннымПоставщика";
			ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("ВхДокДата") <> Неопределено Тогда
				ИмяРеквизитаДатаВходящегоДокумента = "ВхДокДата";
			КонецЕсли;
			
			Если ПараметрыПоиска.Свойство("Сумма") Тогда
				Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("СуммаДокумента") <> Неопределено Тогда
					ИмяРеквизитаСуммаДокумента = "СуммаДокумента";
				ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("Сумма") <> Неопределено Тогда
					ИмяРеквизитаСуммаДокумента = "Сумма";
				КонецЕсли;
			КонецЕсли;
			
			Если ПараметрыПоиска.Свойство("Организация") Тогда
				Если Метаданные.Документы[ТипДокумента].Реквизиты.Найти("Организация") <> Неопределено Тогда
					ИмяРеквизитаОрганизация = "Организация";
				ИначеЕсли Метаданные.Документы[ТипДокумента].Реквизиты.Найти("Фирма") <> Неопределено Тогда
					ИмяРеквизитаОрганизация = "Фирма";
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИмяРеквизитаНомерВходящегоДокумента)
			И ЗначениеЗаполнено(ИмяРеквизитаДатаВходящегоДокумента) Тогда
		
			//В тексте запроса ПТиУ при предыдущем поиске мог быть переопределен на другой тип
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	ЗаполняемыйДокумент.Ссылка КАК Ссылка
			               |ИЗ
			               |	Документ.ПоступлениеТоваровУслуг КАК ЗаполняемыйДокумент
			               |ГДЕ
			               |	НЕ ЗаполняемыйДокумент.ПометкаУдаления
			               |	И ЗаполняемыйДокумент.НомерВходящегоДокумента В (&НомерВходящегоДокумента)
			               |	И НАЧАЛОПЕРИОДА(ЗаполняемыйДокумент.ДатаВходящегоДокумента, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ДатаВходящегоДокумента, ДЕНЬ)
						   |	И &Контрагент
						   |	И &Организация
						   |	И &СуммаДокумента
			               |	И НЕ ЗаполняемыйДокумент.Ссылка = &СуществующийДокумент";
			
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ПоступлениеТоваровУслуг", ТипДокумента);
			Запрос.Текст = СтрЗаменить(Запрос.Текст,".НомерВходящегоДокумента", "." + ИмяРеквизитаНомерВходящегоДокумента);
			Запрос.Текст = СтрЗаменить(Запрос.Текст,".ДатаВходящегоДокумента", "." + ИмяРеквизитаДатаВходящегоДокумента);
			
			Если ЗначениеЗаполнено(ИмяРеквизитаКонтрагент) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"&Контрагент", "ЗаполняемыйДокумент." + ИмяРеквизитаКонтрагент + " = &Контрагент");
				Запрос.УстановитьПараметр("Контрагент",Контрагент);
			Иначе
				Запрос.УстановитьПараметр("Контрагент",Истина);
			КонецЕсли;
			
			//Эти переменные заполнены если переданы сумма/организация документа и соответствующий реквизит в документе присутствует
			Если ЗначениеЗаполнено(ИмяРеквизитаСуммаДокумента) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"&СуммаДокумента", "ЗаполняемыйДокумент." + ИмяРеквизитаСуммаДокумента + " = &СуммаДокумента");
				Запрос.УстановитьПараметр("СуммаДокумента",Сумма);
			Иначе
				Запрос.УстановитьПараметр("СуммаДокумента",Истина);
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ИмяРеквизитаОрганизация) Тогда
				Запрос.Текст = СтрЗаменить(Запрос.Текст,"&Организация", "ЗаполняемыйДокумент." + ИмяРеквизитаОрганизация + " = &Организация");
				Запрос.УстановитьПараметр("Организация",Организация);
			Иначе
				Запрос.УстановитьПараметр("Организация",Истина);
			КонецЕсли;
			
			Запрос.УстановитьПараметр("НомерВходящегоДокумента",ПолучитьМассивВариантовНаписанияНомера(Номер));
			Запрос.УстановитьПараметр("ДатаВходящегоДокумента",Дата);
			Запрос.УстановитьПараметр("СуществующийДокумент",СуществующийДокумент);
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				Результат = Выборка.Ссылка;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьСтрокуВТаблицуДубликатов(ТаблицаДубликатов,ДобавляемыйДокумент,ДокументСсылка,ДанныеДокументаПортала) Экспорт
	
	//Связанный документ уже может быть добавлен в таблицу дубликатов, если был отмечен флагом
	Если ТаблицаДубликатов.Найти(ДобавляемыйДокумент.id,"ДокументИД") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = ТаблицаДубликатов.Добавить();
	НоваяСтрока.Пометка = Истина;
	НоваяСтрока.ДокументИД = ДобавляемыйДокумент.id;
	НоваяСтрока.ДокументТип = ДобавляемыйДокумент.type;
	НоваяСтрока.ПредставлениеДокумента = ДобавляемыйДокумент.ПредставлениеДокумента;
	НоваяСтрока.НомерДокумента = ДобавляемыйДокумент.number;
	НоваяСтрока.ДатаДокумента = ДобавляемыйДокумент.date;
	НоваяСтрока.СуммаДокумента = ДобавляемыйДокумент.amount;
	НоваяСтрока.КонтрагентСсылка = ДокументСсылка.Контрагент;
	НоваяСтрока.ДубликатСсылка = ДокументСсылка;
	
	//Снимем флаг у документа-дубликата в списке документов
	НайденнаяСтрока = СписокДокументов.Найти(ДобавляемыйДокумент.id,"ДокументИД");
	Если НайденнаяСтрока <> Неопределено Тогда
		НайденнаяСтрока.Пометка = Ложь;
	КонецЕсли;
	
КонецПроцедуры


Функция ПолучитьМассивВариантовНаписанияНомера(Знач Номер) Экспорт
	
	//Номер с буквами, имеющими одинаковое написание в латинице и кириллице, может быть распознан в раскладке,
	//отличающейся от той, в которой он был введен в 1с, сформируем варинты возможных написаний номера
	Соответствия = ПолучитьСоответствияКириллицыЛатиницы();
	
	//Сам исходный распознанный номер нам тоже нужен
	Результат = Новый Массив;
	Результат.Добавить(Номер);
	
	//E1C-408: При очень длинных строках номера можно словить ошибку "Переполнение стека встроенного языка на сервере",
	//ограничимся длиной строки номера 20 знаков, если больше - ищем только саму строку
	ОграничениеДлиныНомера = 20;
	Если СтрДлина(Номер) <= ОграничениеДлиныНомера Тогда
		//Рекурсивно заполняем различные комбинации номеров с указанными символами
		ДополнитьМассивВариантов(Номер,Результат,Соответствия);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСоответствияКириллицыЛатиницы() Экспорт
	
	//Строка с буквами, имеющими одинаковое написание в латинице и кириллице, может быть распознана в раскладке,
	//отличающейся от той, в которой он был введен в 1с, сформируем варинты возможных написаний номера/артикула:
	//E,T,O,P,A,H,K,X,C,B,M
	//e,y,o,p,a,x,c
	
	Соответствия = Новый Соответствие;
	Соответствия.Вставить("E","Е");
	Соответствия.Вставить("T","Т");
	Соответствия.Вставить("O","О");
	Соответствия.Вставить("P","Р");
	Соответствия.Вставить("A","А");
	Соответствия.Вставить("H","Н");
	Соответствия.Вставить("K","К");
	Соответствия.Вставить("X","Х");
	Соответствия.Вставить("C","С");
	Соответствия.Вставить("B","В");
	Соответствия.Вставить("M","М");
	Соответствия.Вставить("e","е");
	Соответствия.Вставить("y","у");
	Соответствия.Вставить("o","о");
	Соответствия.Вставить("p","р");
	Соответствия.Вставить("a","а");
	Соответствия.Вставить("x","х");
	Соответствия.Вставить("c","с");
	
	//Также предусмотрим обратную ситуацию
	Для Каждого ЭлементСоответствия Из Соответствия Цикл
		Соответствия.Вставить(ЭлементСоответствия.Значение,ЭлементСоответствия.Ключ);
	КонецЦикла;
	
	Возврат Соответствия;
	
КонецФункции

Процедура ДополнитьМассивВариантов(Знач Номер,Массив,Соответствия)
	
	Для Позиция = 1 По СтрДлина(Номер) Цикл		
			
		ТекСимвол = Сред(Номер,Позиция,1);
		Аналог = Соответствия.Получить(ТекСимвол);
		
		Если Аналог <> Неопределено Тогда
			
			НовыйНомер = Лев(Номер,Позиция - 1) + Аналог + Сред(Номер,Позиция + 1);
			
			Если Массив.Найти(НовыйНомер) = Неопределено Тогда
				Массив.Добавить(НовыйНомер);
				ДополнитьМассивВариантов(НовыйНомер,Массив,Соответствия);
			КонецЕсли;			
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры


Функция ЗаполнитьТипыСоздаваемыхДокументовВДанныхПортала(АдресХранилищаДанныхПортала,ДопПараметры,СтруктураНастроек) Экспорт
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	СтрокиДокументов = СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	
	Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
		
		ДанныеДокумента = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
	
		Если ДопПараметры.АвтоопределениеТипа = Истина Тогда
			
			Если СтрокаДокумента.НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			
				Если ДанныеДокумента.type = "OFFER" Тогда
					ТипСоздаваемогоДокумента = СтруктураНастроек.ТипДокумента_Счет;
					
				ИначеЕсли ДанныеДокумента.type = "CERTIFICATE" Тогда
					ТипСоздаваемогоДокумента = СтруктураНастроек.ТипДокумента_Акт;
					
				ИначеЕсли ДанныеДокумента.type = "RECEIPT" Тогда
					ТипСоздаваемогоДокумента = СтруктураНастроек.ТипДокумента_Чек;
					
				Иначе // все остальные документы заполняем как поступление
					ТипСоздаваемогоДокумента = СтруктураНастроек.ТипДокумента_Поступление;
					
				КонецЕсли;
				
			Иначе
				//2019.02.20 ( По описанию задачи кейс заполнения реализации только один:
				//когда покупатель в документе - это Контрагент, поставщик - Организация
				ТипСоздаваемогоДокумента = СтруктураНастроек.СведенияОКонфигурации.ДокументРеализации;
				
			КонецЕсли;
			
		Иначе
			
			//Пользователь сам выбрал тип создаваемого документа
			ТипСоздаваемогоДокумента = ДопПараметры.ТипСоздаваемогоДокумента;
		КонецЕсли;
		
		ДанныеДокумента.ТипСоздаваемогоДокумента = ТипСоздаваемогоДокумента;
		
		//E1C-407: Может быть передан принудительно задаваемый вид операции для документа
		ДопПараметры.Свойство("ВидОперацииПринудительно",ДанныеДокумента.ВидОперацииПринудительно);
		ДопПараметры.Свойство("СправочникТоварныхПозиций",ДанныеДокумента.СправочникТоварныхПозиций);
		
		//+++ Для типов документов, не предполагающих создание номенклатуры заполнить флаг ТребуетсяСозданиеНоменклатуры = Ложь
		
		//2021.08.04 ( Для ряда документов не требуется указание договора
		Если ТипСоздаваемогоДокумента = "ПеремещениеТоваров"
			Или ТипСоздаваемогоДокумента = "ТребованиеНакладная" Тогда
			ДанныеДокумента.ДоговорНеТребуется = Истина;
		КонецЕсли;		
		// ) 2021.08.04
				
	КонецЦикла;
	
	//Помещаем данные документа обратно во временное хранилище
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
КонецФункции

Функция ЗаполнитьТаблицуЗагружаемыхОбъектов(СтруктураНастроек,АдресХранилищаДанныхПортала,ДопПараметры) Экспорт
		
	РезультатЗаполнения = Новый Структура("Успешно,ВсеЭлементыНайдены,ТекстОшибки",Истина,"");
		
	СтрокиДокументов = СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Если ДанныеПортала = Неопределено Тогда
		РезультатЗаполнения.Успешно = Ложь;
		РезультатЗаполнения.ТекстОшибки = "С портала не были получены данные о документах, операция прервана";
		
		Возврат РезультатЗаполнения;
	КонецЕсли;
	
	//2019.09.03 ( Определить выбранное ранее вручную значение единицы измерения коэффицент пересчета
	ИспользуютсяКоэффициентыПересчета = Ложь;
	Если СтруктураНастроек.ЗаполнениеТЧ_ИспользоватьКоэффициентПересчета Тогда
		//таблица хранится по исходной схеме в настройках текущего пользователя
		СвязьЕдиницы = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьЕдиницыИзмерения");
		Если ТипЗнч(СвязьЕдиницы) = Тип("ТаблицаЗначений")
			И СвязьЕдиницы.Количество() > 0 Тогда
			ИспользуютсяКоэффициентыПересчета = Истина;
		КонецЕсли;
	КонецЕсли;
	// ) 2019.09.03
		
	ЗагружаемыеОбъекты.Очистить();
	ВсеЭлементыНайдены = Истина;
	ПервыйЭлемент = Истина;
	ОбщийТекстОшибки = "";
	
	ПараметрыПоиска = Новый Структура;
		
	// Собрать данные по найденным/создаваемым объектам
	Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
		
		НаправлениеСоздаваемогоДокумента = СтрокаДокумента.НаправлениеСоздаваемогоДокумента;
		ПараметрыПоиска.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
		ПараметрыПоиска.Вставить("СправочникТоварныхПозиций",ДопПараметры.СправочникТоварныхПозиций);
		
		//2019.02.20 ( предварительно определяем ссылки Контрагентов/Организаций по направлению создаваемого документа
		ПараметрыПоиска.Вставить("documentId",СтрокаДокумента.ДокументИД);
		ВыполнитьПоискСсылокПоДаннымПортала(СтруктураНастроек,ДанныеПортала,ПараметрыПоиска);
		// ) 2019.02.20
				
		ТекстОшибки = "";
		
		ДанныеДокументаПортала = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
		ДанныеНоменклатурыПортала = ДанныеПортала.documentItems.НайтиСтроки(Новый Структура("documentId",СтрокаДокумента.ДокументИД));
		
		//E1C-292: обозначим первый документ в списке как основной из объединяемых для получения из него данных шапки
		Если ПервыйЭлемент Тогда
			ДанныеДокументаПортала.СодержитДанныеШапкиОбъединенногоДокумента = Истина;
			ПервыйЭлемент = Ложь;
		Иначе
			ДанныеДокументаПортала.СодержитДанныеШапкиОбъединенногоДокумента = Ложь;
		КонецЕсли;
		
		//Самопроверка
		Если ДанныеДокументаПортала = Неопределено Тогда
			ДополнитьТекстОшибки(ТекстОшибки,"- в данных портала не найдены данные шапки документа");
		КонецЕсли;
		Если ДанныеНоменклатурыПортала.Количество() = 0 Тогда
			ДополнитьТекстОшибки(ТекстОшибки,"- в данных портала не найдена номенклатура документа");
		КонецЕсли;
		
		ПараметрыДополнения = Новый Структура;
		ПараметрыДополнения.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыДополнения.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
		ПараметрыДополнения.Вставить("СтрокаДокумента",СтрокаДокумента);
		ПараметрыДополнения.Вставить("ДанныеДокументаПортала",ДанныеДокументаПортала);
		ПараметрыДополнения.Вставить("ДанныеНоменклатурыПортала",ДанныеНоменклатурыПортала);
				
		//E1C-91: реквизиты документа в окно сопоставления
		ДополнитьТаблицуЗагружаемыхОбъектов("Документ","Документ",СтрокаДокумента.ДокументИД,ДанныеДокументаПортала.ПредставлениеДокумента,Неопределено,Неопределено,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
		
		//Поля шапки документа
		Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			ДополнитьТаблицуЗагружаемыхОбъектов("Организации","Плательщик",ДанныеДокументаПортала.customerId,ДанныеДокументаПортала.ПредставлениеПлательщика,ДанныеДокументаПортала.ПлательщикСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
			ДополнитьТаблицуЗагружаемыхОбъектов("Контрагенты","Поставщик",ДанныеДокументаПортала.supplierId,ДанныеДокументаПортала.ПредставлениеПоставщика,ДанныеДокументаПортала.ПоставщикСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
						
			//2019.05.24 ( обрабатываем данные о банковском счете для контрагентов-поставщиков
			Если СтруктураНастроек.ЗаполнениеШапки_СоздаватьБанковскийСчетКонтрагента = Истина Тогда
				Если ЗначениеЗаполнено(ДанныеДокументаПортала.supplierAccountBic) И ЗначениеЗаполнено(ДанныеДокументаПортала.supplierAccountNumber) Тогда
					ПредставлениеБанковскогоСчета = ДанныеДокументаПортала.supplierAccountNumber + ?(ЗначениеЗаполнено(ДанныеДокументаПортала.supplierAccountBankName)," (" + ДанныеДокументаПортала.supplierAccountBankName + ")","");
					ДополнитьТаблицуЗагружаемыхОбъектов("БанковскиеСчета","Банковский счет",ДанныеДокументаПортала.supplierAccountNumber,ПредставлениеБанковскогоСчета,ДанныеДокументаПортала.БанковскийСчетКонтрагентаСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
				КонецЕсли;
			КонецЕсли;
			// ) 2019.05.24
		Иначе
			ДополнитьТаблицуЗагружаемыхОбъектов("Организации","Поставщик",ДанныеДокументаПортала.supplierId,ДанныеДокументаПортала.ПредставлениеПоставщика,ДанныеДокументаПортала.ПоставщикСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
			ДополнитьТаблицуЗагружаемыхОбъектов("Контрагенты","Плательщик",ДанныеДокументаПортала.customerId,ДанныеДокументаПортала.ПредставлениеПлательщика,ДанныеДокументаПортала.ПлательщикСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДанныеДокументаПортала.ПоставщикСсылка)
			Или Не ЗначениеЗаполнено(ДанныеДокументаПортала.ПлательщикСсылка) Тогда
			ВсеЭлементыНайдены = Ложь;
		КонецЕсли;
		
		//2018.12.17 ( Нужно вызвать окно создания объектов, если нужно создавать договор и он не заполнен
		Если СтруктураНастроек.ЗаполнениеШапки_СоздаватьДоговор И ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора)
			И ЗначениеЗаполнено(ДанныеДокументаПортала.ПоставщикСсылка) И Не ЗначениеЗаполнено(ДанныеДокументаПортала.ДоговорСсылка) Тогда
			ВсеЭлементыНайдены = Ложь;
		КонецЕсли;
		// ) 2018.12.17
		
		//Данные договора
		Если СтруктураНастроек.ЗаполнениеШапки_РучноеРедактированиеДоговора = Истина Тогда
			ДополнитьТаблицуЗагружаемыхОбъектов("Договоры","Договор",ДанныеДокументаПортала.id,ДанныеДокументаПортала.ПредставлениеДоговора,ДанныеДокументаПортала.ДоговорСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
		КонецЕсли;
				
		//2019.09.03 ( Определить выбранное ранее вручную значение единицы измерения коэффицент пересчета
		Если ИспользуютсяКоэффициентыПересчета Тогда
			ПараметрыДополнения.Вставить("СвязьЕдиницы",СвязьЕдиницы);
		КонецЕсли;
		// ) 2019.09.03
		
		//2020.09.01 ( добавляем документы без таблицы номенклатуры
		ИспользуетсяНоменклатура = ЗаполняемыйДокумент_ИспользуетсяНоменклатура(ДанныеДокументаПортала.ТипСоздаваемогоДокумента,СтруктураНастроек);
		
		Если ИспользуетсяНоменклатура Тогда
		// ) 2020.09.01
		
		    //2020.10.07 (
			ТребуетсяСозданиеНоменклатуры = ЗаполняемыйДокумент_ТребуетсяСозданиеНоменклатуры(ДанныеДокументаПортала.ТипСоздаваемогоДокумента,СтруктураНастроек);
			ПараметрыДополнения.Вставить("ТребуетсяСозданиеНоменклатуры",ТребуетсяСозданиеНоменклатуры);
			// ) 2020.10.07		
		
			//Поля табличной части
			Для Каждого СтрокаНоменклатуры Из ДанныеНоменклатурыПортала Цикл
				
				ПараметрыДополнения.Вставить("СтрокаНоменклатуры",СтрокаНоменклатуры);
				
				//E1C-407: Основные средства
				Если ДанныеДокументаПортала.СправочникТоварныхПозиций = "ОсновныеСредства" Тогда
					ДополнитьТаблицуЗагружаемыхОбъектов("ОсновныеСредства","Основное средство",СтрокаНоменклатуры.id,СтрокаНоменклатуры.name,СтрокаНоменклатуры.ОсновноеСредствоСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
					
					Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.ОсновноеСредствоСсылка)
						Или Не ЗначениеЗаполнено(СтрокаНоменклатуры.ОсновноеСредствоСсылка) Тогда
						ВсеЭлементыНайдены = Ложь;
					КонецЕсли;
					
				Иначе				
					ДополнитьТаблицуЗагружаемыхОбъектов("Номенклатура","Номенклатура",СтрокаНоменклатуры.id,СтрокаНоменклатуры.name,СтрокаНоменклатуры.НоменклатураСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения); //ИНН дописываем для сохранения связи наименования номенклатуры с поставщиком
					
					Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.НоменклатураСсылка)
						Или Не ЗначениеЗаполнено(СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка) Тогда
						ВсеЭлементыНайдены = Ложь;
					КонецЕсли;
								
					//E1C-477: По включенной настройке используем либо данные "Источника происхождения", либо стандартные данные ГТД
					Если СтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеИсточникПроисхождения = Истина Тогда
												
						//2.1)  Если по номенклатуре  truOriginCode равен значению "6" (оказание работ/услуг), то Источник происхождения не требуется создавать
						Если СтрокаНоменклатуры.esfKzTruOriginCode = "6" Тогда
							//Пропускаем
						Иначе
							//Из постановки: "%ProductDeclaration%/%productNumberInDeclaration%/%UnitCode%/%truOriginCode%"
							ПредставлениеИсточника = Строка(СтрокаНоменклатуры.esfKzProductDeclaration)
								+ "/" + СтрокаНоменклатуры.esfKzProductNumberInDeclaration
								+ "/" + СтрокаНоменклатуры.esfKzUnitCode + "/" + СтрокаНоменклатуры.esfKzTruOriginCode;
							
							ДополнитьТаблицуЗагружаемыхОбъектов("ИсточникиПроисхождения","Источник происхождения",
								СтрокаНоменклатуры.id,ПредставлениеИсточника,СтрокаНоменклатуры.ИсточникПроисхожденияСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
								
							Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.ИсточникПроисхожденияСсылка)
								Или Не ЗначениеЗаполнено(СтрокаНоменклатуры.СтранаПроисхожденияСсылка) Тогда
								ВсеЭлементыНайдены = Ложь;
							КонецЕсли;
							
						КонецЕсли;
						
					Иначе
					
						Если СтруктураНастроек.ЗаполнениеТЧ_ЗаполнятьДанныеГТД Тогда
							Если ЗначениеЗаполнено(СтрокаНоменклатуры.recognizedCustomsDeclaration) Тогда
								
								ПредставлениеСтраны = Строка(СтрокаНоменклатуры.recognizedCountryShortName) + ?(ЗначениеЗаполнено(СтрокаНоменклатуры.recognizedCountryCode)," (" + СтрокаНоменклатуры.recognizedCountryCode + ")","");
								
								ДополнитьТаблицуЗагружаемыхОбъектов("НомераГТД","Номер ГТД",СтрокаНоменклатуры.id,СтрокаНоменклатуры.recognizedCustomsDeclaration,СтрокаНоменклатуры.НомерГТДСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
								
								Если ЗначениеЗаполнено(ПредставлениеСтраны) Тогда
									ДополнитьТаблицуЗагружаемыхОбъектов("СтраныМира","Страна происхождения",СтрокаНоменклатуры.id,ПредставлениеСтраны,СтрокаНоменклатуры.СтранаПроисхожденияСсылка,СтрокаДокумента.ПредставлениеДокумента,СтрокаДокумента.ДокументИД,ПараметрыДополнения);
								КонецЕсли;
									
								Если Не ЗначениеЗаполнено(СтрокаНоменклатуры.НомерГТДСсылка)
									Или Не ЗначениеЗаполнено(СтрокаНоменклатуры.СтранаПроисхожденияСсылка) Тогда
									ВсеЭлементыНайдены = Ложь;
								КонецЕсли;
								
								Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "УТ10"
									И Не ЗначениеЗаполнено(СтрокаНоменклатуры.СерияНоменклатурыСсылка) Тогда
									ВсеЭлементыНайдены = Ложь;
								КонецЕсли;
								
							КонецЕсли;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
			
		Если ТекстОшибки <> "" Тогда
			ОбщийТекстОшибки = "Документ " + СтрокаДокумента.ПредставлениеДокумента + " <id=" + СтрокаДокумента.ДокументИД + ">, ошибки при обработке:" + Символы.ПС + ТекстОшибки;
		КонецЕсли;		
	КонецЦикла;
	
	//2021.02.22 ( Новое событие в МК: "Сопоставление_ПослеЗаполненияТаблицыЗагружаемыхОбъектов"
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
	
	МодульКастомизации_ОбработатьСобытие("Сопоставление_ПослеЗаполненияТаблицыЗагружаемыхОбъектов",ПараметрыМК);	
	// ) 2021.02.22
	
	//Помещаем данные документа обратно во временное хранилище
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
	РезультатЗаполнения.ВсеЭлементыНайдены = ВсеЭлементыНайдены;
	РезультатЗаполнения.ТекстОшибки = ОбщийТекстОшибки;
	
	Возврат РезультатЗаполнения;
КонецФункции

Процедура ДополнитьТаблицуЗагружаемыхОбъектов(ТипОбъекта,ПредставлениеТипаОбъекта,ИдентификаторОбъекта,ПредставлениеОбъекта,Объект1с,
											  ПредставлениеДокумента,ДокументИД,ПараметрыДополнения)
											  
	СтруктураНастроек = ПараметрыДополнения.СтруктураНастроек;										  
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
											  
	ДанныеДокументаПортала = ПараметрыДополнения.ДанныеДокументаПортала;
	ДанныеНоменклатурыПортала = ПараметрыДополнения.ДанныеНоменклатурыПортала;
	СтрокаНоменклатуры = ?(ПараметрыДополнения.Свойство("СтрокаНоменклатуры"),ПараметрыДополнения.СтрокаНоменклатуры,Неопределено);
											  
	НоваяСтрока = ЗагружаемыеОбъекты.Добавить();
	НоваяСтрока.ДокументИД = ДокументИД;
	НоваяСтрока.ДокументТип = ДанныеДокументаПортала.type;
	НоваяСтрока.Документ_Номер = ДанныеДокументаПортала.number;
	НоваяСтрока.Документ_Дата = ДанныеДокументаПортала.date;
	НоваяСтрока.Документ_Направление = ДанныеДокументаПортала.Направление;
	НоваяСтрока.ТипОбъекта = ТипОбъекта;
	НоваяСтрока.ПредставлениеТипаОбъекта = ПредставлениеТипаОбъекта;
	НоваяСтрока.ТипСоздаваемогоДокумента = ДанныеДокументаПортала.ТипСоздаваемогоДокумента;
	НоваяСтрока.ИдентификаторОбъекта = ИдентификаторОбъекта;
	НоваяСтрока.ПредставлениеОбъекта = ПредставлениеОбъекта;
	НоваяСтрока.ПредставлениеДокумента = ПредставлениеДокумента;
	НоваяСтрока.КонтрагентИД = ДанныеДокументаПортала.supplierInn;
	НоваяСтрока.Объект1с = Объект1с;
	НоваяСтрока.СоответствиеУстановлено = ЗначениеЗаполнено(Объект1с);
	НоваяСтрока.АдресХранилищаСканаДокумента = ДанныеДокументаПортала.АдресХранилищаСканаДокумента;
	НоваяСтрока.СканДокумента_ТекущаяСтраница = 1;
	НоваяСтрока.СканДокумента_КоличествоСтраниц = ДанныеДокументаПортала.pagesCount;
	
	//Для комплектов документов будет нужно показывать оба скана из комплекта
	НоваяСтрока.parentId = ДанныеДокументаПортала.parent;
	НоваяСтрока.childrenId = ДанныеДокументаПортала.children;
	
	НоваяСтрока.ОписаниеТипа = СтруктураНастроек.СведенияОКонфигурации.СоответствиеТипов.Получить(ТипОбъекта);
	
	//Определяем специальные реквизиты в зависимости от типа заполняемого объекта
	Если ТипОбъекта = "Документ" Тогда
		НоваяСтрока.СоответствиеУстановлено = Истина;
		НоваяСтрока.Документ_Дата = ДанныеДокументаПортала.date;
		НоваяСтрока.Документ_Номер = ДанныеДокументаПортала.number;
		НоваяСтрока.Документ_Сумма = ДанныеДокументаПортала.amount;
		НоваяСтрока.Документ_СуммаНДС = ДанныеДокументаПортала.vat;
		НоваяСтрока.Документ_Склад = СтруктураНастроек.ЗаполнениеШапки_СкладПоУмолчанию;
		НоваяСтрока.Документ_Подразделение = СтруктураНастроек.ЗаполнениеШапки_ПодразделениеПоУмолчанию;
		НоваяСтрока.Документ_ПодразделениеОрганизации = СтруктураНастроек.ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию;
		НоваяСтрока.Документ_ПодотчетноеЛицо = СтруктураНастроек.ЗаполнениеШапки_ПодотчетноеЛицоПоУмолчанию;
		НоваяСтрока.Документ_ДоговорНеТребуется = ДанныеДокументаПортала.ДоговорНеТребуется = Истина;
		НоваяСтрока.Документ_ОригиналПолучен = СтруктураНастроек.СозданиеДокумента_УстанавливатьФлагОригиналПолучен;
		
		//E1C-375: Услуги аренды. По постановке для реквизита Документ_ВедетсяУчетПредметовАренды
		//должно быть установлено значение <Плата за право пользования предметами аренды(1)>
		НоваяСтрока.Документ_ВедетсяУчетПредметовАренды = 1;
		
		//E1C-407: Вид операции мог быть выбран ранее, фиксируем от изменения
		Если ЗначениеЗаполнено(ДанныеДокументаПортала.ВидОперацииПринудительно) Тогда
			НоваяСтрока.Документ_ВидОперацииЗаданПринудительно = Истина;
			НоваяСтрока.Документ_ВидОперации = ДанныеДокументаПортала.ВидОперацииПринудительно;
		КонецЕсли;
		
		//E1C-191: Дата создаваемого документа теперь редактируется в форме сопоставления
		Если СтруктураНастроек.ЗаполнениеШапки_ИспользоватьДатуВходящегоДокумента И ЗначениеЗаполнено(ДанныеДокументаПортала.date) Тогда
			НоваяСтрока.Документ_ДатаСоздаваемогоДокумента = ДанныеДокументаПортала.date;
		Иначе
			НоваяСтрока.Документ_ДатаСоздаваемогоДокумента = ТекущаяДата();
		КонецЕсли;
		
		//E1C-487: Казахстан: дата оборота для типа документа ЭСФ
		//1) При создании Поступления ТМЗ из распознанного типа документа ЭСФ входящая дата  и дата документа в 1С заполняются значением "turnoverDate".
		Если ДанныеДокументаПортала.ТипСоздаваемогоДокумента = "ПоступлениеТоваровУслуг"
			И ДанныеДокументаПортала.type = "E_VAT_INVOICE" Тогда
			НоваяСтрока.Документ_Дата = ДанныеДокументаПортала.esfKzTurnoverDate;
			НоваяСтрока.Документ_ДатаСоздаваемогоДокумента = ДанныеДокументаПортала.esfKzTurnoverDate;
		КонецЕсли;
		
		//Изначально функция формировала назначение платежа по собранным данным по документу при его заполнении,
		//чтобы не переписывать ее, сформируем структуру, аналогичную исходной и передадим в ту же функцию
		СтруктураЗаполненияДокумента = Новый Структура("document,documentItems",ДанныеДокументаПортала,ДанныеНоменклатурыПортала);

		
		// модуль кастомизации
		ПараметрыМК = Новый Структура;
		ПараметрыМК.Вставить("ДокументИД",ДокументИД);
		ПараметрыМК.Вставить("СтрокаТаблицы",НоваяСтрока);
		ПараметрыМК.Вставить("СтруктураЗаполненияДокумента",СтруктураЗаполненияДокумента);
		ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
		ПараметрыМК.Вставить("НазначениеПлатежа","");		
		ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
					
		МодульКастомизации_ОбработатьСобытие("Сопоставление_ПередФормированиемНазначенияПлатежа",ПараметрыМК);
		
		Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			НоваяСтрока.Документ_НазначениеПлатежа = ЗаполнениеДокумента_ПлатежноеПоручение_СформироватьНазначениеПлатежа(СтруктураНастроек,СтруктураЗаполненияДокумента);
		Иначе
			НоваяСтрока.Документ_НазначениеПлатежа = ПараметрыМК.НазначениеПлатежа;
		КонецЕсли;
		
		//E1C-308: заполним значение Содержание услуги для документа ПоступлениеДопРасходов значением из первой строки номенклатуры
		Если ДанныеНоменклатурыПортала.Количество() > 0 Тогда
			НоваяСтрока.Документ_СодержаниеУслугиДляДопРасходов = ДанныеНоменклатурыПортала[0].name;
		КонецЕсли;
	
	ИначеЕсли ТипОбъекта = "Организации" Тогда
		
