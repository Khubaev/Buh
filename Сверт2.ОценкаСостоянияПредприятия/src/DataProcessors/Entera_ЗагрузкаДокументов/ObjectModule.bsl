					НоваяСтрока.Номенклатура_СчетУчета = МодульПолучениеНСИ.ПолучитьСчетНоменклатурыПоУмолчанию(НоваяСтрока.Объект1с);
				КонецЕсли;
			КонецЕсли;
			// ) 2019.05.21
			
