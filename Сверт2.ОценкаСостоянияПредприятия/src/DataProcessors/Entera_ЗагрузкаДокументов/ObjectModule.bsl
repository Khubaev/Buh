Функция _ЗФ_СведенияОВнешнейОбработке()
	
	ПараметрыРегистрации = Новый Структура("ВерсияБСП,Наименование,Информация,Вид,Версия,БезопасныйРежим,Команды,Разрешения");
	ПараметрыРегистрации.ВерсияБСП = "2.2.2.1";
	
	ПараметрыРегистрации.Наименование = НСтр("ru = 'Entera: Загрузка документов'");
	ПараметрыРегистрации.Информация = НСтр("ru = 'Дополнительная внешняя обработка для обмена документами с порталом Entera.pro'");
	ПараметрыРегистрации.Вид = "ДополнительнаяОбработка";
	ПараметрыРегистрации.Версия = "1." + ВерсияМодуля.Версия;
	ПараметрыРегистрации.БезопасныйРежим = Истина;
		
	// Команды
	ПараметрыРегистрации.Команды = Новый ТаблицаЗначений;
	ПараметрыРегистрации.Команды.Колонки.Добавить("Представление", 			Новый ОписаниеТипов("Строка")); 
	ПараметрыРегистрации.Команды.Колонки.Добавить("Идентификатор", 			Новый ОписаниеТипов("Строка"));
	ПараметрыРегистрации.Команды.Колонки.Добавить("Использование", 			Новый ОписаниеТипов("Строка"));
	ПараметрыРегистрации.Команды.Колонки.Добавить("ПоказыватьОповещение", 	Новый ОписаниеТипов("Булево"));
	ПараметрыРегистрации.Команды.Колонки.Добавить("Модификатор", 			Новый ОписаниеТипов("Строка"));
	
	Команда = ПараметрыРегистрации.Команды.Добавить();
	Команда.Представление = НСтр("ru = 'Entera: Загрузка документов'");
	Команда.Идентификатор = "0";
	Команда.Использование = "ОткрытиеФормы";
	Команда.ПоказыватьОповещение = Ложь;
	
	//Команда отключена, пока нет необходимости в периодической выгрузке номенклатуры
	//// Регламентное задание
	//Команда = ПараметрыРегистрации.Команды.Добавить();
	//Команда.Представление = НСтр("ru = 'Entera: Фоновая выгрузка номенклатуры на портал (Регламентное задание)
	//								   |Серверу 1с должно быть разрешено подключение к порталу entera.pro.'");
	//Команда.Идентификатор = "1";
	//Команда.Использование = "ВызовСерверногоМетода";
	//Команда.ПоказыватьОповещение = Ложь;
	
	// Разрешения
	МассивРазрешений = _УФ_ПолучитьМассивТребуемыхРазрешений();
	ПараметрыРегистрации.Вставить("Разрешения",МассивРазрешений);
	
	Если МассивРазрешений.Количество() = 0 Тогда
		ПараметрыРегистрации.Вставить("БезопасныйРежим", Ложь);
	КонецЕсли;
		
	// В обработке для Фреш СведенияОВнешнейОбработке заполняются с помощью метода конфигурации
	ПараметрыРегистрации.Вставить("НеФреш");
	
