Функция ПолучитьСсылку_УзелОбменаНоменклатурой(СоздатьЕслиНеНайден = Ложь) Экспорт
	
	Результат = Новый Структура("Успешно,ТекстОшибки",Ложь);
	
	ТекстОшибки = "";
	
	//Выбрать план обмена в данной конфигурации
	Если Метаданные.ПланыОбмена.Найти("СинхронизацияДанныхЧерезУниверсальныйФормат") <> Неопределено Тогда
		ПланОбмена = ПланыОбмена.СинхронизацияДанныхЧерезУниверсальныйФормат;
	Иначе
		ТекстОшибки = ТекстОшибки + "В метаданных конфигурации не найден подходящий план обмена." + Символы.ПС;
	КонецЕсли;
	
	// и найти/создать там узел с кодом и именем Entera
	Если ПланОбмена <> Неопределено Тогда
		УзелОбмена = ПланОбмена.НайтиПоКоду("Entera");
		
		Если Не ЗначениеЗаполнено(УзелОбмена) И СоздатьЕслиНеНайден Тогда
			
			УзелОбменаОбъект = ПланОбмена.СоздатьУзел();
			
			СтруктураЗаполнения = Новый Структура("Код,Наименование,ОтправлятьНоменклатуру,РегистрироватьИзменения","Entera","Entera",Истина,Истина);
			ЗаполнитьЗначенияСвойств(УзелОбменаОбъект,СтруктураЗаполнения);
			
			Попытка
				УзелОбменаОбъект.Записать();
				УзелОбмена = УзелОбменаОбъект.Ссылка;
				Результат.Успешно = Истина;
			Исключение
				ТекстОшибки = ТекстОшибки + КраткоеОписаниеОшибки(ОписаниеОшибки()) + Символы.ПС;
			КонецПопытки;
		КонецЕсли;	
	КонецЕсли;
	
	Результат.ТекстОшибки = ТекстОшибки;
	Результат.Вставить("Ссылка",УзелОбмена);	
	
	Возврат Результат;	
	
КонецФункции

Функция ВыполнитьРегламентноеЗадание_ВыгрузкаНоменклатуры()
	
	РезультатВыполнения = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	//Пробуем восстановить сохраненные для регламентного задания настройки
	СохраненныеНастройки = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","ОбщиеНастройки",,"Entera");
	
	Если ТипЗнч(СохраненныеНастройки) = Тип("Структура") Тогда
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("Токен");
		
		//Необходимо сперва авторизоваться и получить токен
		РезультатЗапроса = ВыполнитьЗапрос("Авторизация","POST",,,ПараметрыЗапроса);
		
		Если РезультатЗапроса.Успешно Тогда
			
			//Вставляем в параметры следующих запросов полученный токен
			РезультатЧтения = ПрочитатьОтветПортала("Авторизация",ПараметрыЗапроса,РезультатЗапроса.ПараметрыОтвета);
			
			Если РезультатЧтения.Успешно Тогда
				
				ПараметрыЗапроса.Токен = РезультатЧтения.Токен;
							
				//Получить таблицу номенклатуры
				Таблица = ПолучитьТаблицуНоменклатуры(СохраненныеНастройки.ОбменДанными_УзелОбменаНоменклатурой);
				
				Если Таблица.Количество() > 0 Тогда
											
					//Выгрузить номенклатуру на портал
					МассивНоменклатуры = Таблица.ВыгрузитьКолонку("Номенклатура");
					ВыгрузитьНоменклатуруНаПортал(МассивНоменклатуры,ПараметрыЗапроса,СохраненныеНастройки);
				КонецЕсли;
			Иначе				
				РезультатВыполнения.ТекстОшибки = РезультатЧтения.ТекстОшибки;
			КонецЕсли;
			
		Иначе
			РезультатВыполнения.ТекстОшибки = РезультатЗапроса.ТекстОшибки;
		КонецЕсли;
		
	Иначе
		РезультатВыполнения.ТекстОшибки = "Сохраненные ранее настройки не найдены, или имеют некорректный формат. Создайте и сохраните настройку для регламентного задания заново.";
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьТаблицуНоменклатуры(УзелОбмена = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(УзелОбмена) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	НоменклатураИзменения.Ссылка КАК Номенклатура
		               |ИЗ
		               |	Справочник.Номенклатура.Изменения КАК НоменклатураИзменения
		               |ГДЕ
		               |	НоменклатураИзменения.Узел = &Узел
		               |	И НЕ НоменклатураИзменения.Ссылка.ЭтоГруппа";
		Запрос.УстановитьПараметр("Узел",УзелОбмена);
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	Номенклатура.Ссылка КАК Номенклатура
		               |ИЗ
		               |	Справочник.Номенклатура КАК Номенклатура
		               |ГДЕ
		               |	НЕ Номенклатура.ЭтоГруппа";
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

Функция ВыгрузитьНоменклатуруНаПортал(МассивНоменклатуры,ПараметрыЗапроса,НастройкиВыгрузки) Экспорт
	
	РезультатВыгрузки = Новый Структура("Успешно,ТекстОшибки",Истина);
		
	//Сперва нужно проверить наличие сохраненного идентификатора каталога, при необходимости - создать его и сохранить
	КаталогиПространств = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","КаталогиПространств",,"Entera");
	
	Если ТипЗнч(КаталогиПространств) = Тип("Соответствие") Тогда
		catalogId = КаталогиПространств.Получить(НастройкиВыгрузки.Пространство);
	Иначе
		КаталогиПространств = Новый Соответствие;
	КонецЕсли;
	
		
	//Создаем каталог для текущего пространства
	РезультатСозданияКаталога = СоздатьОбновитьКаталогВТекущемПространстве(ПараметрыЗапроса,НастройкиВыгрузки.Пространство,catalogId);
	
	Если РезультатСозданияКаталога.Успешно Тогда
		
		//Сохраняем соответствие каталога номенклатуры и пространства
		catalogId = РезультатСозданияКаталога.catalogId;
		
		КаталогиПространств.Вставить(НастройкиВыгрузки.Пространство,catalogId);
		ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","КаталогиПространств",КаталогиПространств,,"Entera");
		
	Иначе
		
		Возврат РезультатСозданияКаталога;
	КонецЕсли;
	
	//api/v1/catalogs/{catalogId}/nomenclatures
	МетодAPI = "/api/v1/catalogs/" + catalogId + "/nomenclatures";
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Номенклатура.Ссылка КАК Ссылка,
	               |	Номенклатура.Код КАК Код,
	               |	Номенклатура.Артикул КАК Артикул,
	               |	Номенклатура.Наименование КАК Наименование,
	               |	Номенклатура.НаименованиеПолное КАК НаименованиеПолное,
	               |	Номенклатура.ПометкаУдаления КАК ПометкаУдаления
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	Номенклатура.Ссылка В(&МассивНоменклатуры)";
	Запрос.УстановитьПараметр("МассивНоменклатуры",МассивНоменклатуры);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выгружено = 0;
	Обновлено = 0;
	ТекстОшибки = "";
	
	Пока Выборка.Следующий() Цикл
		
		Назначение = "СозданиеНоменклатуры";
			
		ГУИДНоменклатуры = Выборка.Ссылка.УникальныйИдентификатор();
		
		ТелоЗапроса = "{" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """name"": """ + Выборка.Наименование + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """code"": """ + Выборка.Код + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """externalId"": """ + ГУИДНоменклатуры + """" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + "}";
		
		Если Выборка.ПометкаУдаления Тогда
			//помеченные на удаление позиции удаляем из справочника, чтобы не участвовали в сопоставлении
			РезультатЗапроса = ВыполнитьЗапрос(Назначение,"DELETE",МетодAPI + "/" + ГУИДНоменклатуры + "/externalId?format=xml",,ПараметрыЗапроса);
		Иначе
		
			//Сначала пытаемся обновить существующую номенклатуру PUT                                +++ как обновить по externalId? На 2018.12.25 - никак
			РезультатЗапроса = ВыполнитьЗапрос(Назначение,"PUT",МетодAPI + "/" + ГУИДНоменклатуры + "/externalId?format=xml",ТелоЗапроса,ПараметрыЗапроса);
					
			Если РезультатЗапроса.Успешно Тогда
				Обновлено = Обновлено + 1;
			
			ИначеЕсли РезультатЗапроса.ПараметрыОтвета.КодСостояния = 404 Тогда
				//пытаемся создать новую номенклатуру POST
				РезультатЗапроса = ВыполнитьЗапрос(Назначение,"POST",МетодAPI + "?format=xml",ТелоЗапроса,ПараметрыЗапроса);
				
				Если РезультатЗапроса.Успешно Тогда
					Выгружено = Выгружено + 1;
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		Если РезультатЗапроса.Успешно Тогда
			
			Если ЗначениеЗаполнено(НастройкиВыгрузки.ОбменДанными_УзелОбменаНоменклатурой) Тогда
				ПланыОбмена.УдалитьРегистрациюИзменений(НастройкиВыгрузки.ОбменДанными_УзелОбменаНоменклатурой,Выборка.Ссылка);
			КонецЕсли;
			
		Иначе
			ТекстОшибки = ТекстОшибки + "<" + Выборка.Ссылка + "> ошибка при выгрузке: " + РезультатЗапроса.ТекстОшибки + Символы.ПС;
		КонецЕсли;
		
	КонецЦикла;
	
	РезультатВыгрузки.Вставить("Выгружено",Выгружено);
	РезультатВыгрузки.Вставить("Обновлено",Обновлено);
	
	РезультатВыгрузки.ТекстОшибки = ТекстОшибки;
	
	Возврат РезультатВыгрузки;
	
КонецФункции

Функция СоздатьОбновитьКаталогВТекущемПространстве(ПараметрыЗапроса,Пространство,catalogId)
	
	// 2018.12.28 ( Нужно сформировать список компаний, которым "принадлежит" этот каталог
	//если компания не будет привязана к справочнику, то не будет работать сопоставление номенклатуры для неё
	КомпанииПортала = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","КомпанииПортала",,"Entera");
	
	Если ТипЗнч(КомпанииПортала) <> Тип("Соответствие") Тогда
		КомпанииПортала = Новый Соответствие;
	КонецЕсли;
	
	ТребуетсяОбновлениеКаталога = Ложь;
	МассивИдентификаторов = Новый Массив;
	
	ВыборкаОрганизаций = Справочники.Организации.Выбрать();
	Пока ВыборкаОрганизаций.Следующий() Цикл
		Если ВыборкаОрганизаций.ПометкаУдаления Тогда
			Продолжить;
		ИначеЕсли ВыборкаОрганизаций.ИНН = "" Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторКомпании = КомпанииПортала.Получить(ВыборкаОрганизаций.Ссылка);
		
		Если ИдентификаторКомпании = Неопределено Тогда
			//Нужно получить его с портала: https://app.entera.pro/api/v1/companies?search=:inn
			//Саша [27.12.18 11:52] Компании пока можно только так вытащить. Пока нет одновременного поиска по inn + kpp. Так что после получения по ИНН, надо сматчить по kpp самому.
			РезультатЗапроса = ВыполнитьЗапрос("КомпанииПортала","GET","/api/v1/companies?format=xml&search=" + ВыборкаОрганизаций.ИНН,,ПараметрыЗапроса);
			
			Если РезультатЗапроса.Успешно Тогда
				
				РезультатЧтения = ПрочитатьОтветПортала("КомпанииПортала",ПараметрыЗапроса,РезультатЗапроса.ПараметрыОтвета);
				
				//перебираем, ищем совпадение по КПП
				Если РезультатЧтения.Успешно Тогда
					Если ЗначениеЗаполненоXDTO(РезультатЧтения.Дерево.companies) Тогда
						КоллекцияКомпаний = ПолучитьКоллекциюXDTO(РезультатЧтения.Дерево.companies.company);
						
						//Если нашлась одна компания - вероятно, это она и есть?
						Если КоллекцияКомпаний.Количество() = 1 Тогда
							ИдентификаторКомпании = КоллекцияКомпаний[0].id;
						Иначе
							
							//Перебираем, ищем по КПП
							Для Каждого Компания Из КоллекцияКомпаний Цикл
								Если Компания.КПП = ВыборкаОрганизаций.КПП Тогда
									ИдентификаторКомпании = Компания.id;
									Прервать;
								КонецЕсли;
							КонецЦикла;
							
						КонецЕсли;
						ТребуетсяОбновлениеКаталога = Истина;
					Иначе
						// компания на портале не найдена
						
					КонецЕсли;
				Иначе
					
				КонецЕсли;
			Иначе
				
			КонецЕсли;
		КонецЕсли;
		
		//добавляем значение в тело запроса
		Если ЗначениеЗаполнено(ИдентификаторКомпании) Тогда
			МассивИдентификаторов.Добавить(ИдентификаторКомпании);
			КомпанииПортала.Вставить(ВыборкаОрганизаций.Ссылка,ИдентификаторКомпании);
		КонецЕсли;
	КонецЦикла;
	
	ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов","КомпанииПортала",КомпанииПортала,"Entera");
	
	companies = "";
	ПервыйЭлемент = Истина;
	Для Каждого ИдентификаторКомпании Из МассивИдентификаторов Цикл
		
		Если ПервыйЭлемент Тогда
			ПервыйЭлемент = Ложь;
		Иначе
			companies = companies + "," + Символы.ПС;
		КонецЕсли;
		
		companies = companies + "{""id"": """ + ИдентификаторКомпании + """}";
		
	КонецЦикла;
	// ) 2018.12.28
	
	Назначение = "СозданиеКаталога";
		
	ТелоЗапроса = "{" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """name"": ""Справочник 1С""," + Символы.ПС;
	// 2018.12.28 (
	Если companies <> "" Тогда
		ТелоЗапроса = ТелоЗапроса + """companies"": [" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + companies + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + "]," + Символы.ПС;
	КонецЕсли;
	// ) 2018.12.28
	ТелоЗапроса = ТелоЗапроса + """space"": {" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """id"": """ + Пространство + """" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + "}" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + "}";
	
	Если ЗначениеЗаполнено(catalogId) Тогда
		РезультатЗапроса = ВыполнитьЗапрос(Назначение,"PUT","/api/v1/catalogs/" + catalogId + "?format=xml",ТелоЗапроса,ПараметрыЗапроса);
	Иначе
		РезультатЗапроса = ВыполнитьЗапрос(Назначение,"POST","/api/v1/catalogs?format=xml",ТелоЗапроса,ПараметрыЗапроса);
	КонецЕсли;
	
	Если РезультатЗапроса.Успешно Тогда
		
		//Вытаскиваем идентификатор каталога
		РезультатЗапроса = ПрочитатьОтветПортала(Назначение,ПараметрыЗапроса,РезультатЗапроса.ПараметрыОтвета);
		
		Если РезультатЗапроса.Успешно Тогда
			catalogId = РезультатЗапроса.Дерево.catalog.id;
			РезультатЗапроса.Вставить("catalogId",catalogId);
		КонецЕсли;
		
	КонецЕсли;	
	
	Если РезультатЗапроса.Успешно = Ложь Тогда
		РезультатЗапроса.ТекстОшибки = "Создание каталога номенклатуры на портале: " + РезультатЗапроса.ТекстОшибки;
	КонецЕсли;
	
	Возврат РезультатЗапроса;
	
КонецФункции


// ================= Чтение сохраненных настроек и заполнение дерева настроек ===================

Процедура ЗаполнитьДеревоНастроек(ДеревоНастроек,Пространство,ЗагружаемаяСтруктураНастроек = Неопределено,recognitionSettings = Неопределено) Экспорт
	
	ПолнаяСтруктураНастроек = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","ОбщиеНастройки");
	
	ИзбранныеНастройки = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","ИзбранныеНастройки");
	Если ИзбранныеНастройки = Неопределено Тогда
		ИзбранныеНастройки = Новый Структура;
	КонецЕсли;
	
	Если ЗагружаемаяСтруктураНастроек = Неопределено Тогда
	
		Если ПолнаяСтруктураНастроек = Неопределено Тогда // Настроек не найдено
		
		ИначеЕсли ТипЗнч(ПолнаяСтруктураНастроек) = Тип("Структура") Тогда // сохранен первый вариант настроек, единый для всех пространств. Переходный кейс
			СтруктураНастроек = ПолнаяСтруктураНастроек;
			
		ИначеЕсли ТипЗнч(ПолнаяСтруктураНастроек) = Тип("Соответствие") Тогда // сохранен новый вариант настроек, отдельный для каждого пространства
			
			Если ЗначениеЗаполнено(Пространство) Тогда
				СтруктураНастроек = ПолнаяСтруктураНастроек.Получить(Пространство);
			Иначе
				СтруктураНастроек = ПолнаяСтруктураНастроек.Получить("ПустоеПространство");
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтруктураНастроек = Неопределено Тогда
			СтруктураНастроек = Новый Структура;
		КонецЕсли;
		
	Иначе
		СтруктураНастроек = ЗагружаемаяСтруктураНастроек;
		
	КонецЕсли;
	
	//2019.09.09 ( Настройки для пространства, полученные от портала имеют больший приоритет, предустановим их
	Если ТипЗнч(recognitionSettings) = Тип("ФиксированноеСоответствие")
		Или ТипЗнч(recognitionSettings) = Тип("Соответствие") Тогда
			
		НастройкиПортала = recognitionSettings.Получить(Пространство);
		
		Если НастройкиПортала <> Неопределено Тогда
			СтруктураНастроек.Вставить("ЗаполнениеТЧ_ЗаполнятьДанныеГТД",НастройкиПортала.customsDeclarationParse = "true");
			
			//E1C-484: устанавливаем в качестве значения настройки значение, полученное от портала 
			СтруктураНастроек.Вставить("ЗаполнениеШапки_ИспользоватьДанныеОснованияДляДоговора",НастройкиПортала.hasTransferBase = "true");
		КонецЕсли;
		
	КонецЕсли;
	// ) 2019.09.09
	
	//В процессе развития модуля некоторые настройки при восстановлении нужно привести к новому значению ключа настройки
	ПреобразоватьТипыЗначенийСохраненныхРанееНастроек(СтруктураНастроек);
	
	Иерархия = Новый Соответствие;
	Иерархия.Вставить("",ДеревоНастроек);
	
	Макет = ПолучитьМакет("ШаблонНастроек");
	Область = Макет.ПолучитьОбласть("НастройкиОбщие");
	
	ДоступныеТипыДокументов = ПолучитьСписокЗаполняемыхДокументов();
	Конф = ПолучитьОписаниеКонфигурации();
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		НастройкаИД					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		НастройкаНаименование		=	ПолучитьТекстЯчейкиОбласти(Область,Сч,2);
		ЭтоГруппа					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,3);
		ТекГруппа					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,4);
		ТекТип						=	ПолучитьТекстЯчейкиОбласти(Область,Сч,5);
		ЗначениеПоУмолчанию			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,7);
		Описание					=	ПолучитьТекстЯчейкиОбласти(Область,Сч,8);
		ОтображатьНастройку			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,9);
		СтартовыйПомощник			=	ПолучитьТекстЯчейкиОбласти(Область,Сч,10);
		
		Если ОтображатьНастройку = "0" Тогда
			Продолжить;
		КонецЕсли;
				
		Если ЭтоГруппа = "Истина" Тогда
			
			НоваяСтрока = Иерархия[ТекГруппа].Строки.Добавить();
			НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
			НоваяСтрока.НастройкаИД	= НастройкаИД;
			НоваяСтрока.НастройкаНаименование = НастройкаНаименование;
			НоваяСтрока.Описание = Описание;

			Иерархия.Вставить(НастройкаИД,НоваяСтрока);
		Иначе
			
			НоваяСтрока = Иерархия[ТекГруппа].Строки.Добавить();
			НоваяСтрока.ЭтоГруппа = ЭтоГруппа;
			НоваяСтрока.НастройкаИД				=	НастройкаИД;
