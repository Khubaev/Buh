				ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		ИначеЕсли ТипЗапроса = "PATCH" Тогда
			
			Попытка
				Ответ = Соединение.Изменить(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		ИначеЕсли ТипЗапроса = "DELETE" Тогда
			
			Попытка
				Ответ = Соединение.Удалить(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
			
		Иначе //POST
			Попытка
				Ответ = Соединение.ОтправитьДляОбработки(Запрос);
				Успешно = Истина;
			Исключение
				ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
				
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
		
	Если Успешно Тогда
		
		ПараметрыОтвета = Новый Структура("МетодAPI,КодСостояния,ТипСодержимого,ContentDisposition,Cookie,ТелоОтветаСтрока,ТелоОтветаДвоичныеДанные");
		ПараметрыОтвета.МетодAPI = МетодAPI;
		ПараметрыОтвета.КодСостояния = Ответ.КодСостояния;
		ПараметрыОтвета.ТипСодержимого = Ответ.Заголовки.Получить("Content-Type");
		ПараметрыОтвета.ContentDisposition = Ответ.Заголовки.Получить("Content-Disposition");
		ПараметрыОтвета.Cookie = Ответ.Заголовки.Получить("Set-Cookie");
				
		Если ПараметрыЗапроса.Свойство("ЗапросФайла") Тогда
			
			//разберем xml, возможно, там текст ошибки
			Если ПараметрыОтвета.ТипСодержимого = "text/xml" Тогда
				ПараметрыОтвета.ТелоОтветаСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
			КонецЕсли;
			
			ПараметрыОтвета.ТелоОтветаДвоичныеДанные = ПоместитьВоВременноеХранилище(Ответ.ПолучитьТелоКакДвоичныеДанные(),Новый УникальныйИдентификатор);
			
		Иначе
			ПараметрыОтвета.ТелоОтветаСтрока = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		КонецЕсли;
		
		ОписаниеЗапроса = "[" + ПараметрыОтвета.КодСостояния + "]: " + ПараметрыОтвета.ТипСодержимого
			+ ?(ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаСтрока),Символы.ПС + ПараметрыОтвета.ТелоОтветаСтрока,"")
			+ ?(ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаДвоичныеДанные),Символы.ПС + ПараметрыОтвета.ТелоОтветаДвоичныеДанные,"");
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
		
		ОбработатьОтветПортала(ПараметрыЗапроса,ПараметрыОтвета,РезультатЗапроса);
		
		РезультатЗапроса.Вставить("ПараметрыОтвета",ПараметрыОтвета);
		
	Иначе
		РезультатЗапроса.Вставить("Успешно",Ложь);
		РезультатЗапроса.Вставить("ТекстОшибки",ТекстОшибки);
		
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ТекстОшибки,"Ошибка");
	КонецЕсли;
		
	Возврат РезультатЗапроса;
КонецФункции


Функция ОбработатьОтветПортала(ПараметрыЗапроса,ПараметрыОтвета,РезультатЗапроса) Экспорт
	
	КодСостояния = ПараметрыОтвета.КодСостояния;
	
	РезультатЗапроса.Вставить("Успешно",Ложь);
			
	Если КодСостояния = 200 тогда
		
		РезультатЗапроса.Вставить("Успешно",Истина);
		
		Если ПараметрыЗапроса.Свойство("ЗапросФайла") Тогда
			
			ИмяФайла = "scan";
			КодированноеИмяФайла = "";
			
			//Разберем заголовок Content-disposition для получения имени файла
			Если ЗначениеЗаполненоXDTO(ПараметрыОтвета.ContentDisposition) Тогда
				СодержимоеЗаголовка = Энтера_РазложитьСтрокуВМассивПодстрок(ПараметрыОтвета.ContentDisposition,";");
				Для Каждого ЭлементСодержимогоЗаголовка Из СодержимоеЗаголовка Цикл
					НачалоИмениФайла = Найти(ЭлементСодержимогоЗаголовка,"filename=");
					Если НачалоИмениФайла > 0 Тогда
						
						КодированноеИмяФайла = СтрЗаменить(Сред(ЭлементСодержимогоЗаголовка,11),"""","");
						ИмяФайла = КодированноеИмяФайла;
												
						//немного костылей с encode кириллического имени файла, которые отдает портал
						Если Найти(ИмяФайла,"utf-8") > 0 Тогда
							//определим хотя бы расширение
							НрегИмяФайла = Нрег(ИмяФайла);
							Если Найти(НрегИмяФайла,"pdf") Тогда
								ИмяФайла = "file.pdf";
							ИначеЕсли Найти(НрегИмяФайла,"xlsx") Тогда
								ИмяФайла = "file.xlsx";
							ИначеЕсли Найти(НрегИмяФайла,"xls") Тогда
								ИмяФайла = "file.xls";
							ИначеЕсли Найти(НрегИмяФайла,"docx") Тогда
								ИмяФайла = "file.docx";
							ИначеЕсли Найти(НрегИмяФайла,"doc") Тогда
								ИмяФайла = "file.doc";
							ИначеЕсли Найти(НрегИмяФайла,"jpg") Тогда
								ИмяФайла = "file.jpg";
							ИначеЕсли Найти(НрегИмяФайла,"jpeg") Тогда
								ИмяФайла = "file.jpeg";
							ИначеЕсли Найти(НрегИмяФайла,"png") Тогда
								ИмяФайла = "file.png";
							КонецЕсли;
							
						Иначе
							ИмяФайла = ДекодироватьСтрокуURL(ИмяФайла);
							
						КонецЕсли;
						
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			
			ПараметрыОтвета.Вставить("КодированноеИмяФайла",КодированноеИмяФайла);
			ПараметрыОтвета.Вставить("ИмяФайла",ИмяФайла);
						
			РезультатЗапроса.Вставить("Файл",ПараметрыОтвета.ТелоОтветаДвоичныеДанные);
			РезультатЗапроса.Вставить("ИмяФайла",ИмяФайла);
			
		КонецЕсли;
		
	ИначеЕсли КодСостояния = 201 Тогда //HTTP 201 Created
		
		РезультатЗапроса.Вставить("Успешно",Истина);
		
	//Отдельный обработчик ответа: если выполнялся запрос файла, и портал не смог изготовить печатную форму, то он может вернуть код ошибки
	//в зависимости от него определяем, будет ли готова печатная форма, в этом случае нужно предложить пользователю повторить запрос чуть позже	
	ИначеЕсли КодСостояния = 400 И ПараметрыЗапроса.Свойство("ЗапросФайла") Тогда
		
		Если ПараметрыОтвета.ТипСодержимого = "text/xml"
			И ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаСтрока) Тогда
			
			Если ПараметрыЗапроса.Назначение = "ПолучениеФайлаСкана" Тогда
				
				Попытка
					Чтение = Новый ЧтениеXML;
					Чтение.УстановитьСтроку(ПараметрыОтвета.ТелоОтветаСтрока);
					Дерево = ФабрикаXDTO.ПрочитатьXML(Чтение);
					
					КодОшибки = Дерево.errorCode;
					РезультатЗапроса.Вставить("КодОшибки",КодОшибки);
					
					Если КодОшибки = "40408.40505" Тогда
						//Печатная форма не будет готова никогда, просто выдаем то же сообщение, что и раньше
						ТекстОшибки = "<" + ПараметрыЗапроса.ПредставлениеДокумента + ">: печатная форма не может быть изготовлена для данного документа";
							
					ИначеЕсли КодОшибки = "40408.40504" Тогда
						//Печатная форма еще готовится, нужно предложить подождать, или создать документ без скана
						ТекстОшибки = "<" + ПараметрыЗапроса.ПредставлениеДокумента + ">: печатная форма еще не была сформирована";
							
						//В силу того, что портал в этом случае вернул Bad request, чтобы не анализировать в дальнейшем код состояния ответа портала
						//установим Успешно = Истина и будем проверять в обработчике формы наличие поля в структуре ответа ПредложитьПовторитьЗапрос
						РезультатЗапроса.Вставить("Успешно",Истина);
						
						ПараметрыОтвета.Вставить("ПредложитьПовторитьЗапрос",Истина);
						ПараметрыОтвета.Вставить("ТекстОшибки",ТекстОшибки);
						
					Иначе
						ТекстОшибки = "Ошибка при получении файла документа <" + ПараметрыЗапроса.ПредставлениеДокумента + ">: " + ПрочитатьТекстОшибкиИзОтветаСервера(ПараметрыОтвета.ТелоОтветаСтрока,КодСостояния,ПараметрыОтвета.ТипСодержимого);
						
					КонецЕсли;
					
				Исключение
					ТекстОшибки = "При чтении описания ошибки при получении файла возникла ошибка. Код состояния: " + КодСостояния + ", тип заголовка ответа: " + Строка(ПараметрыОтвета.ТипСодержимого);
				КонецПопытки;
				
			Иначе
				ТекстОшибки = "Печатная форма не была изготовлена. Ответ сервера не содержит кода причины отсутствия печатной формы.";
				
			КонецЕсли;
		Иначе
			ТекстОшибки = ПрочитатьТекстОшибкиИзОтветаСервера(ПараметрыОтвета.ТелоОтветаСтрока,КодСостояния,ПараметрыОтвета.ТипСодержимого);
			
		КонецЕсли;
		
		РезультатЗапроса.Вставить("ТекстОшибки",ТекстОшибки);
		
	Иначе
		Если ПараметрыОтвета.ТипСодержимого = "text/xml" Тогда //можем читать xml
			ТекстОшибки = ПрочитатьТекстОшибкиИзОтветаСервера(ПараметрыОтвета.ТелоОтветаСтрока,КодСостояния,ПараметрыОтвета.ТипСодержимого);
			
		Иначе //не можем читать xml			
			Если КодСостояния = 500 Тогда
				ТекстОшибки = "На сервере произошла ошибка. Пожалуйста, попробуйте позже.";
			ИначеЕсли КодСостояния = 502 Тогда
				ТекстОшибки = "Сервис временно недоступен. Пожалуйста, попробуйте позже.";
			ИначеЕсли КодСостояния = 400 Тогда
				ТекстОшибки = "Сервер обнаружил в запросе клиента синтаксическую ошибку." + ?(ПараметрыОтвета.Свойство("ТелоЗапроса")," Текст запроса для отладки: " + Символы.ПС + ПараметрыОтвета.ТелоЗапроса,"");
				//2019.02.27 (
				Если ПараметрыОтвета.Свойство("ТелоОтветаСтрока") И ЗначениеЗаполнено(ПараметрыОтвета.ТелоОтветаСтрока) Тогда
					ТекстОшибки = ТекстОшибки + Символы.ПС + ПараметрыОтвета.ТелоОтветаСтрока;
				КонецЕсли;
				// ) 2019.02.27
			ИначеЕсли КодСостояния = 401 Тогда
				ТекстОшибки = "Не удалось выполнить запрос из-за ошибки авторизации. Возможно устарела текущая сессия, попробуйте повторно выполнить вход по логину и паролю";
			ИначеЕсли КодСостояния = 403 Тогда
				ТекстОшибки = "Недостаточно прав для получения запрашиваемых данных (403)" + ?(ПараметрыОтвета.Свойство("ТелоЗапроса"), ": " + Символы.ПС + ПараметрыОтвета.ТелоЗапроса,"");
			ИначеЕсли КодСостояния = 404 Тогда
				ТекстОшибки = "'" + ПараметрыОтвета.МетодAPI + "': запрашиваемый ресурс на портале не найден (404).";
			ИначеЕсли КодСостояния = 413 Тогда
				ТекстОшибки = "Сервер сообщил, что выполяемый запрос слишком большой. Попробуйте уменьшить объем передаваемых данных и попробовать снова (413).";
			Иначе
				ТекстОшибки = "При отправке данных возникла ошибка. Код состояния: " + КодСостояния + ", тип содержимого ответа: " + Строка(ПараметрыОтвета.ТипСодержимого);
			КонецЕсли;
		КонецЕсли;
		
		РезультатЗапроса.Вставить("ТекстОшибки",ТекстОшибки);

	КонецЕсли;
		
КонецФункции

Функция ПрочитатьТекстОшибкиИзОтветаСервера(ТелоОтветаСтрока,КодСостояния = Неопределено, ТипСодержимого = Неопределено)
	
	Если ТипЗнч(ТелоОтветаСтрока) = Тип("ОбъектXDTO") Тогда
		Дерево = ТелоОтветаСтрока;
	Иначе
		Попытка
			Чтение = Новый ЧтениеXML;
			Чтение.УстановитьСтроку(ТелоОтветаСтрока);
			Дерево = ФабрикаXDTO.ПрочитатьXML(Чтение);
		Исключение
			ТекстОшибки = "При чтении ответа сервера возникла ошибка. Код состояния: " + КодСостояния + ", тип заголовка ответа: " + Строка(ТипСодержимого);
		КонецПопытки;
	КонецЕсли;
	
	Если Дерево <> Неопределено Тогда
		
		ТекстОшибки = "При обмене данными с порталом возникла ошибка." + ?(ЗначениеЗаполнено(КодСостояния)," Код состояния: " + КодСостояния,"");
		
		Если Дерево.Свойства().Получить("errorMessage") <> Неопределено И ЗначениеЗаполненоXDTO(Дерево.errorMessage) Тогда
			ТекстОшибки = Дерево.errorMessage;
		КонецЕсли;
		
		Если Дерево.Свойства().Получить("errors") <> Неопределено И ЗначениеЗаполненоXDTO(Дерево.errors) Тогда
			СписокОшибок = ПолучитьКоллекциюXDTO(Дерево.errors.error);
			Для Каждого СтрокаОшибки Из СписокОшибок Цикл
				ТекстОшибки = ТекстОшибки + Символы.ПС + СтрокаОшибки.errorMessage;
			КонецЦикла;
			
		ИначеЕсли Дерево.Свойства().Получить("details") <> Неопределено И ЗначениеЗаполненоXDTO(Дерево.details) Тогда
			СписокОшибок = ПолучитьКоллекциюXDTO(Дерево.details.detail);
			Для Каждого СтрокаОшибки Из СписокОшибок Цикл
				ТекстОшибки = ТекстОшибки + Символы.ПС + СтрокаОшибки.errorMessage;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ТекстОшибки;
КонецФункции


// ================= Обработка ответов портала ===================

Функция ПрочитатьОтветПортала(Назначение,ПараметрыЗапроса,ПараметрыОтвета) Экспорт
	
	РезультатЧтения = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	Если Назначение = "Авторизация"
		Или Назначение = "ПодтверждениеТелефонаКод" Тогда
			
		// Только разбираем куку для получения токена ENTERA_JWT
		Если ЗначениеЗаполнено(ПараметрыОтвета.Cookie) Тогда
			КоллекцияКук = Энтера_РазложитьСтрокуВМассивПодстрок(ПараметрыОтвета.Cookie,",");
			Для Каждого ЭлементКоллекцииКук Из КоллекцияКук Цикл
				СодержимоеЗаголовка = Энтера_РазложитьСтрокуВМассивПодстрок(ЭлементКоллекцииКук,";");
				Для Каждого ЭлементСодержимогоЗаголовка Из СодержимоеЗаголовка Цикл
					НачалоИмениФайла = Найти(ЭлементСодержимогоЗаголовка,"ENTERA_JWT=");
					Если НачалоИмениФайла > 0 Тогда
						Токен = СтрЗаменить(Сред(СокрЛП(ЭлементСодержимогоЗаголовка),12),"""","");
						РезультатЧтения.Вставить("Токен",Токен);
						Прервать;
					Иначе
						// 2019.04.18 ( ОТЛАДКА: возможно запуск на тестовом портале
						НачалоИмениФайла = Найти(ЭлементСодержимогоЗаголовка,"ENTERA_JWT_TEST=");
						Если НачалоИмениФайла > 0 Тогда
							Токен = СтрЗаменить(Сред(СокрЛП(ЭлементСодержимогоЗаголовка),17),"""","");
							РезультатЧтения.Вставить("Токен",Токен);
							Прервать;
						КонецЕсли;
						// ) 2019.04.18
					КонецЕсли;
				КонецЦикла;
				
				Если Токен <> Неопределено Тогда
					Прервать;
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
		
	ИначеЕсли Назначение = "bitrix24" Тогда
		
		Если ПараметрыОтвета.КодСостояния <> 200 Тогда
			РезультатЧтения.Вставить("Успешно",Ложь);
			РезультатЧтения.Вставить("ТекстОшибки","От сервера был получен ответ: " + Символы.ПС + ПараметрыОтвета.ТелоОтветаСтрока);
		КонецЕсли;
		
	Иначе
		
		Если ПараметрыЗапроса.Свойство("ЗапросФайла") Тогда
			
			Если ПараметрыОтвета.Свойство("ПредложитьПовторитьЗапрос") Тогда
				РезультатЧтения.Вставить("ПредложитьПовторитьЗапрос",Истина);
				РезультатЧтения.Вставить("ТекстОшибки",ПараметрыОтвета.ТекстОшибки);
				
			Иначе
				РезультатЧтения.Вставить("АдресВХ",ПараметрыОтвета.ТелоОтветаДвоичныеДанные);
				РезультатЧтения.Вставить("ИмяФайла",ПараметрыОтвета.ИмяФайла);
				
			КонецЕсли;
		Иначе
			
			Чтение = Новый ЧтениеXML;
			Чтение.УстановитьСтроку(ПараметрыОтвета.ТелоОтветаСтрока);
			
			Попытка
				РезультатЧтения.Вставить("Дерево",ФабрикаXDTO.ПрочитатьXML(Чтение));
			Исключение
				РезультатЧтения.Вставить("Успешно",Ложь);
				РезультатЧтения.Вставить("ТекстОшибки","Ошибка при чтении ответа портала: XML содержит ошибки формата." + Символы.ПС + КраткоеОписаниеОшибки(ОписаниеОшибки()));
			КонецПопытки;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РезультатЧтения;
КонецФункции

Функция ПрочитатьДанныеПользователя(Дерево) Экспорт
	
	СтруктураДанных = Инициализировать_ДанныеПользователя();
	
	Если СвойствоXDTOСуществует(Дерево,"user") Тогда
		
		user = Дерево.user;
		
		СтруктураДанных.id = ?(СвойствоXDTOСуществует(user,"id"),user.id,Неопределено); //+++ на 2018.11.21 нет в API
		СтруктураДанных.email = user.email;
		СтруктураДанных.phone = user.phone;
		СтруктураДанных.surname = user.surname;
		СтруктураДанных.name = user.name;
		СтруктураДанных.patronymic = user.patronymic;
		СтруктураДанных.lang = user.lang;
		СтруктураДанных.isNew = user.isNew = "true";
		СтруктураДанных.phoneConfirm = user.phoneConfirm = "true";
		
		Если СвойствоXDTOСуществует(user.spaces,"space") Тогда
			spaces = ПолучитьКоллекциюXDTO(user.spaces.space);
			Для Каждого space Из spaces Цикл
				СтруктураДанных.spaces.Добавить(space.id,space.name);
				
				//2019.09.09 ( Теперь space содержит настройки распознавания для этого Пространства
				recognitionSettings = Новый Структура("customsDeclarationParse,kppParse,hasTransferBase");
				Если ЗначениеЗаполненоXDTO(space.recognitionSettings) Тогда
					ЗаполнитьЗначенияСвойств(recognitionSettings,space.recognitionSettings);
					
					//E1C-484: если по пространству для типа УПД hasTransferBase = TRUE, то значение в настройке меняется на "Да".
					//Если hasTransferBase = null или false, то значение в настройке останется "Нет"
					hasTransferBase = Неопределено;
					Если СвойствоXDTOСуществует(space.recognitionSettings,"tableParseByType")
						И ЗначениеЗаполненоXDTO(space.recognitionSettings.tableParseByType)
						И СвойствоXDTOСуществует(space.recognitionSettings.tableParseByType,"UTD")
						И СвойствоXDTOСуществует(space.recognitionSettings.tableParseByType.UTD,"hasTransferBase") Тогда
						hasTransferBase = space.recognitionSettings.tableParseByType.UTD.hasTransferBase;
					КонецЕсли;
					recognitionSettings.Вставить("hasTransferBase",hasTransferBase);
					
				КонецЕсли;
				
				СтруктураДанных.recognitionSettings.Вставить(space.id,recognitionSettings);
				// ) 2019.09.09
				
				//E1C-421: Извлекаем код страны, пока основная цель - определить пространства Казахстана
				Если ЗначениеЗаполненоXDTO(space.country)
					И space.country.alpha3Code = "KAZ" Тогда
					СтруктураДанных.spaceCountries.Вставить(space.id,"KAZ");
				Иначе
				    СтруктураДанных.spaceCountries.Вставить(space.id,"RUS");
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
		
		//E1C-294: Теперь в этом методе прилетает "сториз" broadcastMessages для интерактивного взаимодействия с пользователями
		Если ЗначениеЗаполненоXDTO(user.broadcastMessages) Тогда
			broadcastMessages = ПолучитьКоллекциюXDTO(user.broadcastMessages.broadcastMessage);
			Для Каждого broadcastMessage Из broadcastMessages Цикл
				СтруктураСообщения = Новый Структура("id,title,content,finishDate,startDate");
				ЗаполнитьЗначенияСвойств(СтруктураСообщения,broadcastMessage);
				СтруктураДанных.broadcastMessages.Добавить(СтруктураСообщения);
			КонецЦикла;
		КонецЕсли;
		
		//E1C-353: Отображение Безлимитного тарифа в ui пользователя
		Если ЗначениеЗаполненоXDTO(user.client) Тогда
			client = user.client;
			СтруктураДанных.unlimited = client.unlimited = "true";
			СтруктураДанных.balanceExpirationDate = ПолучитьДатуИзДатыПортала(client.balanceExpirationDate);
		КонецЕсли;
		
		//E1C-385: Изменение интерфейса баланса в модуле Entera в 1С
		МассивТранзакций = Новый Массив;
		
		transactionExpirationDate = Дата(1,1,1);
		Если ЗначениеЗаполненоXDTO(user.clientActiveTransactionList) Тогда
			clientActiveTransactions = ПолучитьКоллекциюXDTO(user.clientActiveTransactionList.clientActiveTransaction);
			Для Каждого clientActiveTransaction Из clientActiveTransactions Цикл
				ДанныеТранзакции = Новый Структура("id,createdDate,deletedDate,expirationDate,expiredDate,price,comment,creatorEmail,delta,unlimited");
				ДанныеТранзакции.id = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"id");
				ДанныеТранзакции.createdDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"createdDate"));
				ДанныеТранзакции.deletedDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"deletedDate"));
				ДанныеТранзакции.expirationDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"expirationDate"));
				ДанныеТранзакции.expiredDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"expiredDate"));
				ДанныеТранзакции.price = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"price");
				ДанныеТранзакции.comment = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"comment");
				ДанныеТранзакции.creatorEmail = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"creatorEmail");
				ДанныеТранзакции.delta = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"delta",Истина);
				ДанныеТранзакции.unlimited = ПолучитьЗначениеПоляXDTO(clientActiveTransaction,"unlimited") = "true";
				
				МассивТранзакций.Добавить(ДанныеТранзакции);
				
				//Определяем максимальный срок доступных транзакций
				transactionExpirationDate = Макс(transactionExpirationDate,ПолучитьДатуИзДатыПортала(clientActiveTransaction.expirationDate));
			КонецЦикла;
		КонецЕсли;
		
		СтруктураДанных.clientActiveTransactionList = МассивТранзакций;
		СтруктураДанных.transactionExpirationDate = transactionExpirationDate;
		
	КонецЕсли;
	
	Возврат СтруктураДанных;
КонецФункции

Функция ПрочитатьДанныеДокументов(Дерево,ДанныеПортала,СправочникиПортала,СтруктураНастроек,ПараметрыЗапроса) Экспорт
	
	РезультатЧтения = Новый Структура("Успешно,ЗагрузкаДанныхЗавершена,ОтветПустой,ТекстОшибки",Истина,Ложь,Ложь,"");
	
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат;
	
	Если ДанныеПортала = Неопределено Тогда
		ДанныеПортала = Инициализировать_ТаблицыДанныхПортала();
	КонецЕсли;
	
	//2021.05.06 ( В каких-то кейсах встречается, что из структуры настроек выпадают соответствия статусов ЭДО-документов.
	//На всякий случай, если этих полей на этом этапе нет в структуре настроек - инициализируем и добавим их туда
	Если Не СтруктураНастроек.Свойство("Диадок_СоответствиеСтатусов") Тогда
		СтруктураНастроек.Вставить("Диадок_СоответствиеСтатусов",Диадок_ИнициализироватьСоответствияСтатусов());
	КонецЕсли;
	
	Если Не СтруктураНастроек.Свойство("СБИС_СоответствиеСтатусов") Тогда
		СтруктураНастроек.Вставить("СБИС_СоответствиеСтатусов",СБИС_ИнициализироватьСоответствияСтатусов());
	КонецЕсли;
	// ) 2021.05.06
	
	//2024.10.08 (
	Если Не СтруктураНастроек.Свойство("КодыТиповДокументов") Тогда
		СтруктураНастроек.Вставить("КодыТиповДокументов",КодыДокументов_ИнициализироватьСоответствияКодовДокументов());
	КонецЕсли;
	// ) 2024.10.08
	
	//E1C-448: Добавить столбец "Источник" с информацией откуда был загружен документ на распознавание
	Если Не СтруктураНастроек.Свойство("ИсточникиДокументов") Тогда
		СтруктураНастроек.Вставить("ИсточникиДокументов",ИсточникиДокументов_ИнициализироватьСоответствияИсточниковДокументов());
	КонецЕсли;
	
	Если СвойствоXDTOСуществует(Дерево,"document")
		И ЗначениеЗаполненоXDTO(Дерево.document) Тогда
		//получен один документ
		enteraDocuments = ПолучитьКоллекциюXDTO(Дерево.document);
	ИначеЕсли СвойствоXDTOСуществует(Дерево,"documents")
		И ЗначениеЗаполненоXDTO(Дерево.documents) Тогда
		//получена коллекция документов
		enteraDocuments = ПолучитьКоллекциюXDTO(Дерево.documents.document);
	Иначе
		ОтветПустой = Истина;
	КонецЕсли;
	
	Если Не ЗначениеЗаполненоXDTO(enteraDocuments) Тогда
		ОтветПустой = Истина;
	Иначе
		КоличествоЭлементов = enteraDocuments.Количество();
		ОтветПустой = КоличествоЭлементов = 0;
	КонецЕсли;
		
	Если ОтветПустой Тогда
		РезультатЧтения.Успешно = Истина;
		РезультатЧтения.ЗагрузкаДанныхЗавершена = Истина;
		РезультатЧтения.ОтветПустой = Истина;
		
		Возврат РезультатЧтения;
	КонецЕсли;
	
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
		
	//Обходим коллекцию документов
	Для Каждого document Из enteraDocuments Цикл
		
		documentId = document.id;
		
		//2019.08.30 ( Проверим, нет ли в таблице уже такого документа
		Если ДанныеПортала.documents.Найти(documentId,"id") <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		// ) 2019.08.30
		
		//E1C-315: Не выводим связанные документы в список, если они удалены на портале
		state = ПолучитьЗначениеПоляXDTO(document,"state");
		Если ПараметрыЗапроса.Свойство("ПолучениеСвязанныхДокументов")
			И ПараметрыЗапроса.ПолучениеСвязанныхДокументов = Истина Тогда
			Если state = "DELETED" Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
						
		НоваяСтрокаДокумент = ДанныеПортала.documents.Добавить();
		
		ПараметрыМК.Вставить("document",document);
		ПараметрыМК.Вставить("НоваяСтрокаДокумент",НоваяСтрокаДокумент);
		
		НоваяСтрокаДокумент.id = documentId;
		НоваяСтрокаДокумент.spaceId = document.space.id;
		НоваяСтрокаДокумент.createdDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(document,"createdDate"),Истина);
		
		//При дальнейшем объединении документов флаг определяет документ, содержащий данные шапки для группы документов
		НоваяСтрокаДокумент.СодержитДанныеШапкиОбъединенногоДокумента = Ложь;
		
		Если ЗначениеЗаполненоXDTO(document.recognitionTask) Тогда
			НоваяСтрокаДокумент.recognitionTaskId = document.recognitionTask.id;
			
			//E1C-448: Добавить столбец "Источник" с информацией откуда был загружен документ на распознавание
			НоваяСтрокаДокумент.source = ПолучитьЗначениеПоляXDTO(document.recognitionTask,"source");
			НоваяСтрокаДокумент.ПредставлениеИсточника = ПолучитьЗначениеСоответствия(СтруктураНастроек.ИсточникиДокументов,НоваяСтрокаДокумент.source);
		КонецЕсли;
		
		//Пока портал ссылку не возвращает - сформируем ссылку сами
		НоваяСтрокаДокумент.url = "https://app.entera.pro/spaces/" + НоваяСтрокаДокумент.spaceId + "/documents/" + НоваяСтрокаДокумент.id;
		
		//E1C-396: отображаем в интерфейсе готовность печатной формы документа
		НоваяСтрокаДокумент.printFormId = ПолучитьЗначениеПоляXDTO(document,"printFormId");
		
		//E1C-466: Отображение в реестре документов замечаний по распознаванию документа
		validationNotificationSeverity = 0;
		validationNotificationTextFull = "";
		
		Если ЗначениеЗаполненоXDTO(document.validationNotifications) Тогда
			validationNotifications = ПолучитьКоллекциюXDTO(document.validationNotifications.validationNotification);
			
			Для Каждого validationNotification Из validationNotifications Цикл
				ДополнитьТекстОшибки(validationNotificationTextFull,validationNotification.fullText);
				
				Если validationNotification.severity = "WARNING" Тогда
					validationNotificationSeverity = 2;
				ИначеЕсли validationNotification.severity = "ERROR" Тогда
					validationNotificationSeverity = 1;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
		НоваяСтрокаДокумент.validationNotificationSeverity = validationNotificationSeverity;
		НоваяСтрокаДокумент.validationNotificationTextFull = validationNotificationTextFull;
		
		
		//2020.09.25 ( Запишем xml-данные XDTO документа для возможности работы
		//в модуле кастомизации с полными данными, полученными от портала
		Если Ложь Тогда //Пока такой потребности нет - не выполняем
		    ЗаписьXML = Новый ЗаписьXML;
		    ЗаписьXML.УстановитьСтроку();
		    ЗаписьXML.ЗаписатьОбъявлениеXML(); 
			XDTO = Новый ФабрикаXDTO;
			XDTO.ЗаписатьXML(ЗаписьXML,document);
		    НоваяСтрокаДокумент.xml = ЗаписьXML.Закрыть();
		КонецЕсли;
		// ) 2020.09.25
		
		Если СвойствоXDTOСуществует(document,"creator") И ЗначениеЗаполненоXDTO(document.creator) Тогда
			НоваяСтрокаДокумент.creatorId = document.creator.Id;
			НоваяСтрокаДокумент.creatorEmail = document.creator.email;
			НоваяСтрокаДокумент.creatorFullName = document.creator.name;
		КонецЕсли;
		
		НоваяСтрокаДокумент.number = ПолучитьЗначениеПоляXDTO(document,"number");
		НоваяСтрокаДокумент.recognizedNumber = ПолучитьЗначениеПоляXDTO(document,"recognizedNumber");
		НоваяСтрокаДокумент.date = ПолучитьДатуИзДатыПортала(document.date);
		НоваяСтрокаДокумент.recognizedDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(document,"recognizedDate"));
		НоваяСтрокаДокумент.paymentOrderId = ПолучитьЗначениеПоляXDTO(document,"paymentOrderId");
		
		НоваяСтрокаДокумент.comment = ПолучитьЗначениеПоляXDTO(document,"comment");
				
		НоваяСтрокаДокумент.type = ПолучитьЗначениеПоляXDTO(document,"type");
		НоваяСтрокаДокумент.state = ПолучитьЗначениеПоляXDTO(document,"state");
		НоваяСтрокаДокумент.receiptState = ПолучитьЗначениеПоляXDTO(document,"receiptState");
		НоваяСтрокаДокумент.verified = ПолучитьЗначениеПоляXDTO(document,"verified") = "true";
		НоваяСтрокаДокумент.uploaded = ПолучитьЗначениеПоляXDTO(document,"uploaded") = "true";
		
		НоваяСтрокаДокумент.documentCreator = ПолучитьЗначениеПоляXDTO(document,"documentCreator");
				
		Если СвойствоXDTOСуществует(document,"parent") И ЗначениеЗаполненоXDTO(document.parent) Тогда
			НоваяСтрокаДокумент.parent = ПолучитьЗначениеПоляXDTO(document.parent,"id");
		КонецЕсли;
		
		//в children допускается коллекция элементов, но ситуация, в которой она может возникнуть пока неизвестна, берем первый элемент коллекции
		Если СвойствоXDTOСуществует(document,"children") И ЗначениеЗаполненоXDTO(document.children) Тогда
			children = ПолучитьКоллекциюXDTO(document.children.children);
			Если children.Количество() > 0 Тогда
				НоваяСтрокаДокумент.children = ПолучитьЗначениеПоляXDTO(children[0],"id");
			КонецЕсли;
		КонецЕсли;
		
		//Сохраняем исходную дату документа, в случае необходимости ее использования при дальнейшем заполнении
		НоваяСтрокаДокумент.sourceDate = НоваяСтрокаДокумент.date;
		
		//E1C-484: Сопоставление и создание Договора в 1С по распознанным данным "Основание передачи"
		//Несмотря на название List основание всегда одно, поэтому в коллекцию его не преобразовываем
		Если ЗначениеЗаполненоXDTO(document.transferBaseList) Тогда
			transferBases = ПолучитьКоллекциюXDTO(document.transferBaseList.transferBase);
			//В соответствии с постановкой продолжаем обрабатывать только первый элемент
			transferBase = transferBases[0];
			НоваяСтрокаДокумент.transferBaseId = ПолучитьЗначениеПоляXDTO(transferBase,"id");
			НоваяСтрокаДокумент.transferBaseDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(transferBase,"date"));
			НоваяСтрокаДокумент.transferBaseName = ПолучитьЗначениеПоляXDTO(transferBase,"name");
			НоваяСтрокаДокумент.transferBaseNumber = ПолучитьЗначениеПоляXDTO(transferBase,"number");
			НоваяСтрокаДокумент.transferBaseAdditionalInfo = ПолучитьЗначениеПоляXDTO(transferBase,"additionalInfo");
			
			НоваяСтрокаДокумент.ОснованиеПередачиЗаполнено = Истина;
			
			НоваяСтрокаДокумент.ПредставлениеДоговора = ЗаполнениеДокумента_Договор_СформироватьПредставление(НоваяСтрокаДокумент,СтруктураНастроек);
			
		Иначе
			//Исходный шаблон, заданный пользователем
			НоваяСтрокаДокумент.ПредставлениеДоговора = СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора;
			НоваяСтрокаДокумент.ОснованиеПередачиЗаполнено = Ложь;
		КонецЕсли;
						
						
		НоваяСтрокаДокумент.amountWithoutVat = ПолучитьЗначениеПоляXDTO(document,"amountWithoutVat",Истина);
		НоваяСтрокаДокумент.recognizedAmountWithoutVat = ПолучитьЗначениеПоляXDTO(document,"recognizedAmountWithoutVat",Истина);
		НоваяСтрокаДокумент.vat = ПолучитьЗначениеПоляXDTO(document,"vat",Истина);
		НоваяСтрокаДокумент.recognizedVat = ПолучитьЗначениеПоляXDTO(document,"recognizedVat",Истина);
		НоваяСтрокаДокумент.amount = ПолучитьЗначениеПоляXDTO(document,"amount",Истина);
		НоваяСтрокаДокумент.recognizedAmount = ПолучитьЗначениеПоляXDTO(document,"recognizedAmount",Истина);
		
		//Пользовательские представления данных портала
		НоваяСтрокаДокумент.ПредставлениеТипа = СправочникиПортала.ТипДокумента.Получить(НоваяСтрокаДокумент.type);
		НоваяСтрокаДокумент.ПредставлениеСтатуса = СправочникиПортала.СтатусДокумента.Получить(НоваяСтрокаДокумент.state);
		НоваяСтрокаДокумент.ПредставлениеДокумента = СформироватьПредставлениеДокументаПортала(НоваяСтрокаДокумент);
		
		//2022.02.07 ( На портале выпилили один из статусов: UPLOADED, теперь это флажок. Статусов осталось 3
		Если НоваяСтрокаДокумент.uploaded Тогда
			НоваяСтрокаДокумент.state = "UPLOADED";
			НоваяСтрокаДокумент.ПредставлениеСтатуса = "Выгружен";
		КонецЕсли;
		// ) 2022.02.07
		
		//E1C-48: статус чека отсутствует в справочниках портала, определим его представление самостоятельно по статусу
		//NOT_CHECKED - чек не проверен в ФНС.
		//INCORRECT - чек не корректен по данным ФНС. Финальное состояние.
		//IN_PROCESSING - чек корректен. Данные из ФНС на обработке, то есть не получены.
		//WITHOUT_DATA - чек корректен. Данные из ФНС не были получены в течени 24 часов. Попыток получения данных больше не будет. Финальное состояние.
		//WITH_DATA - чек корректен. Данные из ФНС были получены. Финальное состояние.
		Если НоваяСтрокаДокумент.state = "UPLOADED" Тогда
			НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = НоваяСтрокаДокумент.ПредставлениеСтатуса;
			
		Иначе
			Если НоваяСтрокаДокумент.receiptState = "NOT_CHECKED" Тогда
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = "Проверка чека";
			ИначеЕсли НоваяСтрокаДокумент.receiptState = "INCORRECT" Тогда
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = "Чек некорректен";
			ИначеЕсли НоваяСтрокаДокумент.receiptState = "IN_PROCESSING" Тогда
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = "Ожидание ОФД";
			ИначеЕсли НоваяСтрокаДокумент.receiptState = "WITHOUT_DATA" Тогда
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = "Нет данных";
			ИначеЕсли НоваяСтрокаДокумент.receiptState = "WITH_DATA" Тогда
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = "Данные получены из ОФД";
			Иначе
				//Покажем статус самого документа
				НоваяСтрокаДокумент.ПредставлениеСтатусаЧека = СправочникиПортала.СтатусДокумента.Получить(НоваяСтрокаДокумент.state);
			КонецЕсли;
			
		КонецЕсли;
		
		//E1C-544: извлекаем данные чека, если они доступны
		Если ЗначениеЗаполненоXDTO(document.receiptData) Тогда
			НоваяСтрокаДокумент.fiscalDocumentNumber = ПолучитьЗначениеПоляXDTO(document.receiptData,"fiscalDocumentNumber");
		КонецЕсли;
		
		//E1C-207: документы, отправленные через ЭДО имеют стандартные статусы распознанных документов,
		//для отбора в форме списка документов установим им статус EDI_SEND
		НоваяСтрокаДокумент.forSendingToEdi = ПолучитьЗначениеПоляXDTO(document,"forSendingToEdi") = "true";
		Если НоваяСтрокаДокумент.forSendingToEdi = Истина Тогда
			НоваяСтрокаДокумент.state = "EDI_SEND";
		КонецЕсли;
		
		ДанныеПортала.ПредставленияДокументов.Вставить(documentId,НоваяСтрокаДокумент.ПредставлениеДокумента);
		
		//Покупатель
		Если ЗначениеЗаполненоXDTO(document.customer) Тогда
			НоваяСтрокаДокумент.customerId = Строка(ПолучитьЗначениеПоляXDTO(document.customer,"id"));
			НоваяСтрокаДокумент.customerName = Строка(ПолучитьЗначениеПоляXDTO(document.customer,"name"));
			НоваяСтрокаДокумент.customerShortName = Строка(ПолучитьЗначениеПоляXDTO(document.customer,"shortName"));
			НоваяСтрокаДокумент.customerInn = ПолучитьЗначениеПоляXDTO(document.customer,"inn");
			НоваяСтрокаДокумент.customerKpp = ПолучитьЗначениеПоляXDTO(document.customer,"kpp");
			
			НоваяСтрокаДокумент.customerTaxId = ПолучитьЗначениеПоляXDTO(document.customer,"taxId");
			НоваяСтрокаДокумент.customerTaxIdPrimary = ПолучитьЗначениеПоляXDTO(document.customer,"taxIdPrimary");
			НоваяСтрокаДокумент.customerTaxIdSecondary = ПолучитьЗначениеПоляXDTO(document.customer,"taxIdSecondary");
			
			//Для Казахстана используем в представлении компании ИИН/БИН
			Если СтруктураНастроек.РегионПространства = "KAZ" Тогда
				НоваяСтрокаДокумент.ПредставлениеПлательщика = НоваяСтрокаДокумент.customerShortName + " (ИИН/БИН" + НоваяСтрокаДокумент.customerTaxId + ")";
			Иначе
				НоваяСтрокаДокумент.ПредставлениеПлательщика = НоваяСтрокаДокумент.customerShortName + " (ИНН" + НоваяСтрокаДокумент.customerInn
					+ ?(ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.customerKpp),"/КПП" + НоваяСтрокаДокумент.customerKpp,"")+ ")";
			КонецЕсли;
		КонецЕсли;
		
		Если ЗначениеЗаполненоXDTO(document.recognizedCustomer) Тогда
			НоваяСтрокаДокумент.recognizedCustomerId = document.recognizedCustomer.id;
			НоваяСтрокаДокумент.recognizedCustomerName = document.recognizedCustomer.name;
			НоваяСтрокаДокумент.recognizedCustomerShortName = ПолучитьЗначениеПоляXDTO(document.recognizedCustomer,"shortName");
			НоваяСтрокаДокумент.recognizedCustomerInn = document.recognizedCustomer.inn;
			НоваяСтрокаДокумент.recognizedCustomerKpp = document.recognizedCustomer.kpp;
			НоваяСтрокаДокумент.recognizedCustomerTaxId = document.recognizedCustomer.taxId;
		КонецЕсли;
		
		//Поставщик
		Если ЗначениеЗаполненоXDTO(document.supplier) Тогда
			НоваяСтрокаДокумент.supplierId = document.supplier.id;
			НоваяСтрокаДокумент.supplierName = Строка(ПолучитьЗначениеПоляXDTO(document.supplier,"name"));
			НоваяСтрокаДокумент.supplierShortName = Строка(ПолучитьЗначениеПоляXDTO(document.supplier,"shortName"));
			НоваяСтрокаДокумент.supplierInn = ПолучитьЗначениеПоляXDTO(document.supplier,"inn");
			НоваяСтрокаДокумент.supplierKpp = ПолучитьЗначениеПоляXDTO(document.supplier,"kpp");
			
			НоваяСтрокаДокумент.supplierTaxId = ПолучитьЗначениеПоляXDTO(document.supplier,"taxId");
			НоваяСтрокаДокумент.supplierTaxIdPrimary = ПолучитьЗначениеПоляXDTO(document.supplier,"taxIdPrimary");
			НоваяСтрокаДокумент.supplierTaxIdSecondary = ПолучитьЗначениеПоляXDTO(document.supplier,"taxIdSecondary");
			
			//Для Казахстана используем в представлении компании ИИН/БИН
			Если СтруктураНастроек.РегионПространства = "KAZ" Тогда
				НоваяСтрокаДокумент.ПредставлениеПоставщика = НоваяСтрокаДокумент.supplierShortName + " (ИИН/БИН" + НоваяСтрокаДокумент.supplierTaxId + ")";
			Иначе
				НоваяСтрокаДокумент.ПредставлениеПоставщика = НоваяСтрокаДокумент.supplierShortName + " (ИНН" + НоваяСтрокаДокумент.supplierInn
					+ ?(ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.supplierKpp),"/КПП" + НоваяСтрокаДокумент.supplierKpp,"")+ ")";
			КонецЕсли;
		КонецЕсли;
				
		Если ЗначениеЗаполненоXDTO(document.recognizedSupplier) Тогда
			НоваяСтрокаДокумент.recognizedSupplierId = document.recognizedSupplier.id;
			НоваяСтрокаДокумент.recognizedSupplierName = document.recognizedSupplier.name;
			НоваяСтрокаДокумент.recognizedSupplierShortName = ПолучитьЗначениеПоляXDTO(document.recognizedSupplier,"shortName");
			НоваяСтрокаДокумент.recognizedSupplierInn = document.recognizedSupplier.inn;
			НоваяСтрокаДокумент.recognizedSupplierKpp = document.recognizedSupplier.kpp;
			НоваяСтрокаДокумент.recognizedSupplierTaxId = document.recognizedSupplier.taxId;
		КонецЕсли;
		
		//Данные о банковском счете поставщика
		Если ЗначениеЗаполненоXDTO(document.recognizedSupplierAccountDetails) Тогда
			AccountDetails = document.recognizedSupplierAccountDetails;
			НоваяСтрокаДокумент.supplierAccountBic = ПолучитьЗначениеПоляXDTO(AccountDetails,"bic");
			НоваяСтрокаДокумент.supplierAccountNumber = ПолучитьЗначениеПоляXDTO(AccountDetails,"account");
			НоваяСтрокаДокумент.supplierAccountBankName = ПолучитьЗначениеПоляXDTO(AccountDetails,"name");
			НоваяСтрокаДокумент.supplierAccountBankIndex = ПолучитьЗначениеПоляXDTO(AccountDetails,"index");
			НоваяСтрокаДокумент.supplierAccountSettlementType = ПолучитьЗначениеПоляXDTO(AccountDetails,"settlementType");
			НоваяСтрокаДокумент.supplierAccountSettlementName = ПолучитьЗначениеПоляXDTO(AccountDetails,"settlementName");
			НоваяСтрокаДокумент.supplierAccountAddress = ПолучитьЗначениеПоляXDTO(AccountDetails,"address");
			НоваяСтрокаДокумент.supplierAccountCorrespondentAccount = ПолучитьЗначениеПоляXDTO(AccountDetails,"correspondentAccount");
			НоваяСтрокаДокумент.supplierAccountFullAddress = ПолучитьЗначениеПоляXDTO(AccountDetails,"fullAddress");
		КонецЕсли;
				
		//Коллекция страниц документа
		НоваяСтрокаДокумент.pagesCount = 0;
		Если ЗначениеЗаполненоXDTO(document.pages) Тогда
			pages = ПолучитьКоллекциюXDTO(document.pages.page);
			НоваяСтрокаДокумент.pagesCount = pages.Количество();
			
			Для Каждого page Из pages Цикл
				НоваяСтрокаСтраница = ДанныеПортала.documentPages.Добавить();
				
				НоваяСтрокаСтраница.documentId = documentId;
				НоваяСтрокаСтраница.number = ПолучитьЗначениеПоляXDTO(page,"number");
				НоваяСтрокаСтраница.rotationAngle = ПолучитьЗначениеПоляXDTO(page,"rotationAngle");
				НоваяСтрокаСтраница.url = ПолучитьЗначениеПоляXDTO(page,"url");
				
				Если ЗначениеЗаполненоXDTO(page.file) Тогда
					НоваяСтрокаСтраница.fileName = page.file.name;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		//E1C-127: источник данных документа для формирования комментария
		Если document.type = "RECEIPT" Тогда
			НоваяСтрокаДокумент.ИсточникДокумента = "QR Сканер чеков";
		Иначе
			НоваяСтрокаДокумент.ИсточникДокумента = "Скан-копия документа";
		КонецЕсли;
		
		//E1C-442: добавлен параметр для формирования комментария/назначения платежа: Код типа документа.
		//Заполняется из макета предварительно захардкоженных соответствий типов документа портала и кодов ФНС
		НоваяСтрокаДокумент.КодТипаДокумента = ПолучитьЗначениеСоответствия(СтруктураНастроек.КодыТиповДокументов,НоваяСтрокаДокумент.type);
		
		//2019.12.14 ( Ответ API содержит массив дополнительной информации в поле externalSystemInfos
		Если ЗначениеЗаполненоXDTO(document.externalSystemInfos) Тогда
			externalSystemInfos = ПолучитьКоллекциюXDTO(document.externalSystemInfos.externalSystemInfo);
			
			Для Каждого info Из externalSystemInfos Цикл
				Если СвойствоXDTOСуществует(info,"type") Тогда
					infoType = info.type;
				
					Если infoType = "ONEC" Тогда
						//+++ Дополнительная информация из 1с о выгруженных документах в базы 1с
						//пока нет необходимости ее разбирать
						
					ИначеЕсли infoType = "DIADOC" Тогда
						
						//Статус документа в Диадок в поле data объекта info
						Если СвойствоXDTOСуществует(info,"data") Тогда
							infoData = info.data;
							Если СвойствоXDTOСуществует(infoData,"attachmentType") И СвойствоXDTOСуществует(infoData,"status") Тогда
								НоваяСтрокаДокумент.Диадок_Статус = Диадок_ПолучитьСтатусДокумента(СтруктураНастроек.Диадок_СоответствиеСтатусов,infoData.attachmentType,infoData.status);
							КонецЕсли;
							
							Если СвойствоXDTOСуществует(info,"url") Тогда
								НоваяСтрокаДокумент.Диадок_url = info.url;
							КонецЕсли;
						КонецЕсли;
						
						НоваяСтрокаДокумент.ИсточникДокумента = "Документ из Диадок";
						
					ИначеЕсли infoType = "SBIS" Тогда
						
						//Статус документа в СБИС в поле data объекта info
						Если СвойствоXDTOСуществует(info,"data") Тогда
							infoData = info.data;
							Если СвойствоXDTOСуществует(infoData,"statusCode") Тогда
								НоваяСтрокаДокумент.Диадок_Статус = СБИС_ПолучитьСтатусДокумента(СтруктураНастроек.СБИС_СоответствиеСтатусов,infoData.statusCode);
							КонецЕсли;
							
							Если СвойствоXDTOСуществует(infoData,"pdfFileLink") Тогда
								НоваяСтрокаДокумент.Диадок_url = infoData.pdfFileLink;
							КонецЕсли;
						КонецЕсли;
						
						НоваяСтрокаДокумент.ИсточникДокумента = "Документ из СБИС";
						
					//2021.03.26 ( в поле ENTERA_EDI могут быть переданы данные об исходном документе,
					//попробуем его найти в этой базе, если найдем - покажем на него ссылку
					ИначеЕсли infoType = "ENTERA_EDI" Тогда
						
						//Идентификатор документа при отправке передается в виде строки, состоящей из типа документа
						//и его GUID-идентификатора, разделенных точкой
						Если СвойствоXDTOСуществует(info,"externalId")
							И ЗначениеЗаполненоXDTO(info.externalId) Тогда
							МассивПолей = Энтера_РазложитьСтрокуВМассивПодстрок(info.externalId,".");
							
							Если МассивПолей.Количество() = 2 Тогда
								ИмяТипа = МассивПолей[0];
								GUID = МассивПолей[1];
								
								НоваяСтрокаДокумент.ДокументСсылка = ПолучитьСсылку_ОбъектПоУникальномуИдентификатору(GUID,ИмяТипа,"Документы");
							КонецЕсли;
						КонецЕсли;
					// ) 2021.03.26
					
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;		
		// ) 2019.12.14
		
		//2020.10.21 ( читаем дополнительную информацию clientData в СтруктураДополнительныхДанных
		//Чтение выполняем в МК, так как структура дополнительной информации персональна
		Если ЗначениеЗаполненоXDTO(document.clientData) Тогда
			ПараметрыМК.Вставить("clientData",document.clientData);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			МодульКастомизации_ОбработатьСобытие("ЧтениеДанныхДокумента_clientData",ПараметрыМК);
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
				//Тут будет штатный обработчик clientData
			КонецЕсли;
			
		КонецЕсли;
		// ) 2020.10.21
		
		//E1C-487: Казахстан: дата оборота для типа документа ЭСФ
		Если СвойствоXDTOСуществует(document,"esfKzDocument") И ЗначениеЗаполненоXDTO(document.esfKzDocument) Тогда
			НоваяСтрокаДокумент.esfKzRegistrationNumber = ПолучитьЗначениеПоляXDTO(document.esfKzDocument,"registrationNumber",Ложь);
			НоваяСтрокаДокумент.esfKzTurnoverDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(document.esfKzDocument,"turnoverDate",Ложь));
			
			//E1C-503: Для распознанного типа документа ЭСФ для заполнения  "Вх номер" = значение берется из deliveryDocNum,
			//Вх. дата = значение берется из deliveryDocDate. Указанные поля в document.esfKzDocument.invoiceData.invoiceBody
			Если СвойствоXDTOСуществует(document.esfKzDocument,"invoiceData") И ЗначениеЗаполненоXDTO(document.esfKzDocument.invoiceData) Тогда
				invoiceData = document.esfKzDocument.invoiceData;
				Если СвойствоXDTOСуществует(invoiceData,"invoiceBody") И ЗначениеЗаполненоXDTO(invoiceData.invoiceBody) Тогда	
					НоваяСтрокаДокумент.esfKzDeliveryDocNum = ПолучитьЗначениеПоляXDTO(invoiceData.invoiceBody,"deliveryDocNum",Ложь);
					НоваяСтрокаДокумент.esfKzDeliveryDocDate = ПолучитьДатуИзДатыПортала(ПолучитьЗначениеПоляXDTO(invoiceData.invoiceBody,"deliveryDocDate",Ложь));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		//В документе может присутствовать набор полей customFields, индивидуальный для разных клиентов
		//согласовано, что имена ключей не будут содержать символов, недопустимых для чтения в структуру
		Если ЗначениеЗаполненоXDTO(document.customFields) Тогда
			Попытка
				customFields = Новый Структура;
				Если ТипЗнч(document.customFields) = Тип("ОбъектXDTO") Тогда
					Для Каждого СвойствоКастомногоПоля Из document.customFields.Свойства() Цикл
						customFields.Вставить(СвойствоКастомногоПоля.ЛокальноеИмя,ПолучитьЗначениеПоляXDTO(document.customFields,СвойствоКастомногоПоля.ЛокальноеИмя));
					КонецЦикла;
				КонецЕсли;
				НоваяСтрокаДокумент.customFields = customFields;
			Исключение
				ТекстОшибки = "Ошибка при чтении значений customFields документа <" + documentId + ">:" + Символы.ПС + ОписаниеОшибки();
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"ЧтениеОтвета",ТекстОшибки,"Ошибка");
				ДополнитьТекстОшибки(РезультатЧтения.ТекстОшибки,ТекстОшибки);
			КонецПопытки;
		КонецЕсли;
		
		
		//Коллекция товарных позиций документа
		Если ЗначениеЗаполненоXDTO(document.items) Тогда
			items = ПолучитьКоллекциюXDTO(document.items.item);
		Иначе
			items = Новый Массив;
		КонецЕсли;
		
		//По умолчанию предполагаем, что номенклатуру для документа нужно создавать
		НоваяСтрокаДокумент.ТребуетсяСозданиеНоменклатуры = Истина;
		
		//E1C-275: Если в настройках ставим "Сворачивание данные табличной части в одну строку",
		//и, при отсутствии распознанной итоговой строки, для создания документа
		//считать все итоговые показатели (amountWithoutVat, vat, amount) по всем позициям.
		Если Не ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.amount)
			Или Не ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.vat)
			Или Не ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.amountWithoutVat) Тогда
			
			amount = 0;
			vat = 0;
			amountWithoutVat = 0;
			
			Для Каждого item Из items Цикл
				Попытка amount = amount + Число(item.amount); Исключение; КонецПопытки;
				Попытка vat = vat + Число(item.vat); Исключение; КонецПопытки;
				Попытка amountWithoutVat = amountWithoutVat + Число(item.amountWithoutVat); Исключение; КонецПопытки;
			КонецЦикла;
			
			НоваяСтрокаДокумент.amount = amount;
			НоваяСтрокаДокумент.vat = vat;
			НоваяСтрокаДокумент.amountWithoutVat = amountWithoutVat;
			
		КонецЕсли;
		
		//2019.11.12 ( В случае использования свернутой ТЧ помещаем в таблицу items только одну строку с предопределенной в настройках номенклатурой
		Если СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку <> "Нет" Тогда
			
			Если СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку = "Да, оставляя количество = 1" Тогда
				quantity = 1;
				recognizedQuantity = 1;
				price = НоваяСтрокаДокумент.amount;
				
			//E1C-555: Добавить новый вариант сворачивания в настройке "Сворачивать данные табличной части в одну строку"
			ИначеЕсли СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧВОднуСтроку = "Да, оставляя цену = 1" Тогда
				quantity = НоваяСтрокаДокумент.amount;
				recognizedQuantity = НоваяСтрокаДокумент.amount;
				price = 1;
				
			Иначе
				quantity = 0;
				recognizedQuantity = 0;
				Для Каждого item Из items Цикл
					Попытка quantity = quantity + Число(item.quantity); Исключение; КонецПопытки;
					Попытка recognizedQuantity = recognizedQuantity + Число(item.recognizedQuantity); Исключение; КонецПопытки;
				КонецЦикла;
				price = ?(quantity = 0,НоваяСтрокаДокумент.amount,НоваяСтрокаДокумент.amount / quantity);
			КонецЕсли;
			
			ВыбраннаяНоменклатура = СтруктураНастроек.ЗаполнениеТЧ_СворачиватьТЧНоменклатура;
						
			НоваяСтрокаНоменклатура = ДанныеПортала.documentItems.Добавить();		
			
			НоваяСтрокаНоменклатура.documentId = documentId;
			НоваяСтрокаНоменклатура.id = Строка(Новый УникальныйИдентификатор);
			НоваяСтрокаНоменклатура.recognizedName = Строка(ВыбраннаяНоменклатура);
			НоваяСтрокаНоменклатура.name = Строка(ВыбраннаяНоменклатура);
			НоваяСтрокаНоменклатура.supplierInn = НоваяСтрокаДокумент.supplierInn;
			НоваяСтрокаНоменклатура.НоменклатураСсылка = ВыбраннаяНоменклатура;
										
			НоваяСтрокаНоменклатура.quantity = quantity;
			НоваяСтрокаНоменклатура.recognizedQuantity = recognizedQuantity;
			НоваяСтрокаНоменклатура.price = price;
			НоваяСтрокаНоменклатура.recognizedPrice = price;
			НоваяСтрокаНоменклатура.vat = НоваяСтрокаДокумент.vat;
			НоваяСтрокаНоменклатура.recognizedVat = НоваяСтрокаДокумент.recognizedVat;
			НоваяСтрокаНоменклатура.amount = НоваяСтрокаДокумент.amount;
			НоваяСтрокаНоменклатура.recognizedAmount = НоваяСтрокаДокумент.recognizedAmount;
			НоваяСтрокаНоменклатура.recognizedAmountWithoutVat = НоваяСтрокаДокумент.recognizedAmountWithoutVat;
			
			//amountWithoutVat может быть не заполнена, расчитаем
			Если ЗначениеЗаполненоXDTO(НоваяСтрокаДокумент.amountWithoutVat) Тогда
				НоваяСтрокаНоменклатура.amountWithoutVat = НоваяСтрокаДокумент.amountWithoutVat;
			Иначе
				Попытка
					//Неявное преобразование к типу Число может вызвать ошибку
					НоваяСтрокаНоменклатура.amountWithoutVat = НоваяСтрокаДокумент.amount - НоваяСтрокаДокумент.vat;
				Исключение
					//не обрабатываем
				КонецПопытки;
			КонецЕсли;
			
			//Далее в зависимости от конфигурации
			
			ЕдиницаИзмеренияСсылка = Неопределено;
			СтавкаНДССсылка = Неопределено;
			
			Если Конф = "БП30" Тогда
				Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
					ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.БазоваяЕдиницаИзмерения;
				Иначе
					ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				КонецЕсли;
				
				//Старая бухня еще может использовать реквизит СтавкаНДС, а не ВидСтавкиНДС
				Если РеквизитСуществует("Справочники","Номенклатура","ВидСтавкиНДС") Тогда
					СтавкаНДССсылка = Перечисления.СтавкиНДС.СтавкаНДС(ВыбраннаяНоменклатура.ВидСтавкиНДС, НоваяСтрокаДокумент.date);
				Иначе
					СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				КонецЕсли;
				
			ИначеЕсли Конф = "УНФ" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				Если РеквизитСуществует("Перечисления","СтавкиНДС") Тогда
					СтавкаНДССсылка = Перечисления.СтавкиНДС.СтавкаНДС(ВыбраннаяНоменклатура.ВидСтавкиНДС, НоваяСтрокаДокумент.date);
				Иначе
					СтавкаНДССсылка = Справочники.СтавкиНДС.СтавкаНДС(ВыбраннаяНоменклатура.ВидСтавкиНДС, НоваяСтрокаДокумент.date);
				КонецЕсли;
				
			ИначеЕсли Конф = "РОЗН2" Или Конф = "РОЗН3" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
			
			ИначеЕсли Конф = "ЭДО" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				
			ИначеЕсли Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				Если РеквизитСуществует("Справочники","Номенклатура","СтавкаНДС") Тогда
					СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				Иначе
					СтавкаНДССсылка = Перечисления.СтавкиНДС.СтавкаНДС(ВыбраннаяНоменклатура.ВидСтавкиНДС, НоваяСтрокаДокумент.date);
				КонецЕсли;
				
			ИначеЕсли Конф = "УТ10" Или Конф = "КА1" Или Конф = "УПП" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаХраненияОстатков;
				СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				
			ИначеЕсли Конф = "Автосалон" Или Конф = "КомбинатПитания" Или Конф = "КомбинатПитания" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ОсновнаяЕдиницаИзмерения;
				СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
			
			ИначеЕсли Конф = "БП20" Тогда
				ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.БазоваяЕдиницаИзмерения;
				СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				
			Иначе //Не определили конфигурацию, пробуем поискать в метаданных Номенклатуры требуемые реквизиты
				Если Метаданные.Справочники.Номенклатура.Реквизиты.Найти("ЕдиницаИзмерения") <> Неопределено Тогда
					ЕдиницаИзмеренияСсылка = ВыбраннаяНоменклатура.ЕдиницаИзмерения;
				КонецЕсли;
				
				Если Метаданные.Справочники.Номенклатура.Реквизиты.Найти("СтавкаНДС") <> Неопределено Тогда
					СтавкаНДССсылка = ВыбраннаяНоменклатура.СтавкаНДС;
				КонецЕсли;
			КонецЕсли;
			
			Если ЕдиницаИзмеренияСсылка <> Неопределено Тогда
				НоваяСтрокаНоменклатура.unitId = Строка(ЕдиницаИзмеренияСсылка.УникальныйИдентификатор());
				НоваяСтрокаНоменклатура.unitName = Строка(ЕдиницаИзмеренияСсылка);
				НоваяСтрокаНоменклатура.unitCode = ЕдиницаИзмеренияСсылка.Код;
				НоваяСтрокаНоменклатура.unitExternalId = ЕдиницаИзмеренияСсылка.УникальныйИдентификатор();
				
				НоваяСтрокаНоменклатура.userUnitName = Строка(ЕдиницаИзмеренияСсылка);
			КонецЕсли;
			
			НоваяСтрокаНоменклатура.ЕдиницаИзмеренияСсылка = ЕдиницаИзмеренияСсылка;
			
			//Ставку НДС придется попробовать расчитать исходя из суммы НДС документа и общей суммы
			Попытка
				Шапка_Сумма = Число(НоваяСтрокаДокумент.amountWithoutVat);
				Шапка_СуммаНДС = Число(НоваяСтрокаДокумент.vat);
				
				vatRate = Неопределено;
				
				Если Шапка_Сумма > 0 И Шапка_СуммаНДС > 0 Тогда
					
					ПроцентНДС = Окр(Шапка_СуммаНДС / Шапка_Сумма,2) * 100;
					
					Если ПроцентНДС = 22 Тогда
						vatRate = "PERCENT_22";
					ИначеЕсли ПроцентНДС = 20 Тогда
						vatRate = "PERCENT_20";
					ИначеЕсли ПроцентНДС = 18 Тогда
						vatRate = "PERCENT_18";
					ИначеЕсли ПроцентНДС = 10 Тогда
						vatRate = "PERCENT_10";
					ИначеЕсли ПроцентНДС = 12 Тогда
						vatRate = "PERCENT_12";
					ИначеЕсли ПроцентНДС = 16 Тогда
						vatRate = "PERCENT_16";
					ИначеЕсли ПроцентНДС = 5 Тогда
						vatRate = "PERCENT_5";
					ИначеЕсли ПроцентНДС = 7 Тогда
						vatRate = "PERCENT_7";
					КонецЕсли;
					
				КонецЕсли;
				
				НоваяСтрокаНоменклатура.СтавкаНДССсылка = ПолучитьСсылку_СтавкаНДС(vatRate,СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС);
				
				//2022.02.21 ( также установим vatRate для данных распознанного документа
				НоваяСтрокаНоменклатура.vatRate = vatRate;
				// ) 2022.02.21
				
				ОписаниеСобытия = "Ставка НДС <" + НоваяСтрокаНоменклатура.СтавкаНДССсылка
					+ "> расчитана для свернутой ТЧ: сумма [" + НоваяСтрокаДокумент.amountWithoutVat + "],"
					+ "сумма НДС [" + НоваяСтрокаДокумент.vat + "], процент НДС [" + ПроцентНДС + "]";
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"ЧтениеОтвета",ОписаниеСобытия,"ЧтениеОтвета");
				
			Исключение
				ОписаниеСобытия = "Ошибка при расчете ставки НДС для свернутой ТЧ: сумма [" + НоваяСтрокаДокумент.amountWithoutVat + "],"
					+ "сумма НДС [" + НоваяСтрокаДокумент.vat + "]." + Символы.ПС + ОписаниеОшибки();
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"ЧтениеОтвета",ОписаниеСобытия,"ЧтениеОтвета");
				
				НоваяСтрокаНоменклатура.СтавкаНДССсылка = СтавкаНДССсылка;
				
			КонецПопытки;
						
		Иначе
		// ) 2019.11.12
		
				
			Для Каждого item Из items Цикл
				НоваяСтрокаНоменклатура = ДанныеПортала.documentItems.Добавить();
				
				НоваяСтрокаНоменклатура.documentId = documentId;
				НоваяСтрокаНоменклатура.id =  ПолучитьЗначениеПоляXDTO(item,"id");
				НоваяСтрокаНоменклатура.serialNumber =  ПолучитьЗначениеПоляXDTO(item,"serialNumber");
				НоваяСтрокаНоменклатура.recognizedSerialNumber = ПолучитьЗначениеПоляXDTO(item,"recognizedSerialNumber");
				НоваяСтрокаНоменклатура.recognizedName = ПолучитьЗначениеПоляXDTO(item,"recognizedName");
				НоваяСтрокаНоменклатура.name = ПолучитьЗначениеПоляXDTO(item,"name");
				НоваяСтрокаНоменклатура.supplierInn = НоваяСтрокаДокумент.supplierInn;
				
				// E1C-45: брать код товара из goodCode а если он пустой, то из recognizedGoodCode
				НоваяСтрокаНоменклатура.recognizedGoodCode = ПолучитьЗначениеПоляXDTO(item,"goodCode");
				Если Не ЗначениеЗаполнено(НоваяСтрокаНоменклатура.recognizedGoodCode) Тогда
					НоваяСтрокаНоменклатура.recognizedGoodCode = ПолучитьЗначениеПоляXDTO(item,"recognizedGoodCode");
				КонецЕсли;
				
				//E1C-103: сохраняем для отправки измененных данных статус goodCodeIsNull
				НоваяСтрокаНоменклатура.goodCodeIsNull = item.goodCode = Неопределено;
				
				//Вероятные совпадения номенклатуры
				Если СвойствоXDTOСуществует(item,"potentialNomenclatures") И ЗначениеЗаполненоXDTO(item.potentialNomenclatures) Тогда
					potentialNomenclatures = ПолучитьКоллекциюXDTO(item.potentialNomenclatures.potentialNomenclature);
					
					Для Каждого potentialNomenclature Из potentialNomenclatures Цикл
						Если СвойствоXDTOСуществует(potentialNomenclature,"nomenclature")
							И ЗначениеЗаполненоXDTO(potentialNomenclature.nomenclature) Тогда
							
							НоваяСтрокаВероятнаяНоменклатура = ДанныеПортала.potentialNomenclatures.Добавить();
							
							НоваяСтрокаВероятнаяНоменклатура.documentId = documentId;
							НоваяСтрокаВероятнаяНоменклатура.documentItemId = item.id;
							НоваяСтрокаВероятнаяНоменклатура.nomenclatureId = potentialNomenclature.nomenclature.id;
							НоваяСтрокаВероятнаяНоменклатура.nomenclatureName = potentialNomenclature.nomenclature.name;
							НоваяСтрокаВероятнаяНоменклатура.nomenclatureCode = potentialNomenclature.nomenclature.code;
							НоваяСтрокаВероятнаяНоменклатура.nomenclatureExternalId = potentialNomenclature.nomenclature.externalId;
							НоваяСтрокаВероятнаяНоменклатура.probability = potentialNomenclature.probability;
							
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
				
				//Установленое соответствие номенклатуры
				Если СвойствоXDTOСуществует(item,"nomenclature") И ЗначениеЗаполненоXDTO(item.nomenclature) Тогда
					НоваяСтрокаНоменклатура.nomenclatureId = item.nomenclature.id;
					НоваяСтрокаНоменклатура.nomenclatureName = item.nomenclature.name;
					НоваяСтрокаНоменклатура.nomenclatureCode = item.nomenclature.code;
					НоваяСтрокаНоменклатура.nomenclatureExternalId = item.nomenclature.externalId;
				КонецЕсли;
								
				НоваяСтрокаНоменклатура.recognizedGoodTypeCode = ПолучитьЗначениеПоляXDTO(item,"recognizedGoodTypeCode");
				НоваяСтрокаНоменклатура.recognizedUnitCode = ПолучитьЗначениеПоляXDTO(item,"recognizedUnitCode");
				НоваяСтрокаНоменклатура.recognizedUnit = ПолучитьЗначениеПоляXDTO(item,"recognizedUnit");
				
				
				//Установленое соответствие единицы измерения
				Если СвойствоXDTOСуществует(item,"unit") И ЗначениеЗаполненоXDTO(item.unit) Тогда
					НоваяСтрокаНоменклатура.unitId = item.unit.id;
					НоваяСтрокаНоменклатура.unitName = item.unit.name;
					НоваяСтрокаНоменклатура.unitCode = item.unit.code;
					НоваяСтрокаНоменклатура.unitExternalId = item.unit.externalId;
				Иначе
					НоваяСтрокаНоменклатура.unitName = ПолучитьЗначениеПоляXDTO(item,"unitName");
				КонецЕсли;
				
				НоваяСтрокаНоменклатура.userUnitName = ПолучитьЗначениеПоляXDTO(item,"unitName");
								
				НоваяСтрокаНоменклатура.quantity =  ПолучитьЗначениеПоляXDTO(item,"quantity",Истина);
				НоваяСтрокаНоменклатура.recognizedQuantity = ПолучитьЗначениеПоляXDTO(item,"recognizedQuantity",Истина);
				НоваяСтрокаНоменклатура.price =  ПолучитьЗначениеПоляXDTO(item,"price",Истина);
				НоваяСтрокаНоменклатура.recognizedPrice = ПолучитьЗначениеПоляXDTO(item,"recognizedPrice",Истина);
				НоваяСтрокаНоменклатура.amountWithoutVat =  ПолучитьЗначениеПоляXDTO(item,"amountWithoutVat",Истина);
				НоваяСтрокаНоменклатура.recognizedAmountWithoutVat = ПолучитьЗначениеПоляXDTO(item,"recognizedAmountWithoutVat",Истина);
				НоваяСтрокаНоменклатура.excise =  ПолучитьЗначениеПоляXDTO(item,"excise");
				НоваяСтрокаНоменклатура.recognizedExcise = ПолучитьЗначениеПоляXDTO(item,"recognizedExcise");
				НоваяСтрокаНоменклатура.vatRate =  ПолучитьЗначениеПоляXDTO(item,"vatRate");
				НоваяСтрокаНоменклатура.recognizedVatRate = ПолучитьЗначениеПоляXDTO(item,"recognizedVatRate");
				НоваяСтрокаНоменклатура.vat =  ПолучитьЗначениеПоляXDTO(item,"vat",Истина);
				НоваяСтрокаНоменклатура.recognizedVat = ПолучитьЗначениеПоляXDTO(item,"recognizedVat",Истина);
				НоваяСтрокаНоменклатура.amount =  ПолучитьЗначениеПоляXDTO(item,"amount",Истина);
				НоваяСтрокаНоменклатура.recognizedAmount = ПолучитьЗначениеПоляXDTO(item,"recognizedAmount",Истина);
				
				НоваяСтрокаНоменклатура.СтавкаНДССсылка = ПолучитьСсылку_СтавкаНДС(НоваяСтрокаНоменклатура.vatRate,СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС);
				
				// данные о номере ГТД и стране происхождения.
				//E1C-366: Изначально выполнялось получение значения из recognizedCustomsDeclaration,
				//теперь - из валидированного customsDeclaration. Поскольку в некоторых модулях кастомизации клиентов идет взаимодействие
				//с полем данных документа recognizedCustomsDeclaration, имя поля в таблице оставляем прежним, только изменяем источник его значения
				recognizedCustomsDeclaration = ПолучитьЗначениеПоляXDTO(item,"customsDeclaration");
				
				// В номере ГТД цифры и знак /, распознанные прочерки и тире пропускаем
				ПрисутствуютДанныеГТД = ЗначениеЗаполнено(recognizedCustomsDeclaration)
					И Найти(recognizedCustomsDeclaration,"-") = 0
					И Найти(recognizedCustomsDeclaration,Символ(8212)) = 0;
					
				Если ПрисутствуютДанныеГТД Тогда
					НоваяСтрокаНоменклатура.recognizedCountryCode = ПолучитьЗначениеПоляXDTO(item,"recognizedCountryCode");
					НоваяСтрокаНоменклатура.recognizedCountryShortName = ПолучитьЗначениеПоляXDTO(item,"recognizedCountryShortName");
					НоваяСтрокаНоменклатура.recognizedCustomsDeclaration = recognizedCustomsDeclaration;					
				КонецЕсли;
				
				//E1C-477: Казахстан: 1С. БП 3.0 для КЗ. Работа с ЭСФ и Источником происхождения
				Если СвойствоXDTOСуществует(item,"esfKzDocumentItem") И ЗначениеЗаполненоXDTO(item.esfKzDocumentItem) Тогда					
					НоваяСтрокаНоменклатура.esfKzAdditional = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"additional",Ложь);
					НоваяСтрокаНоменклатура.esfKzAdditionalUnitNomenclature = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"additionalUnitNomenclature",Ложь);
					НоваяСтрокаНоменклатура.esfKzCatalogTruId = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"catalogTruId",Ложь);
					НоваяСтрокаНоменклатура.esfKzExciseRate = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"exciseRate",Ложь);
					НоваяСтрокаНоменклатура.esfKzKpvedCode = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"kpvedCode",Ложь);
					НоваяСтрокаНоменклатура.esfKzproductDeclaration = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"productDeclaration",Ложь);
					НоваяСтрокаНоменклатура.esfKzproductNumberInDeclaration = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"productNumberInDeclaration",Ложь);
					НоваяСтрокаНоменклатура.esfKzProductNumberInSnt = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"productNumberInSnt",Ложь);
					НоваяСтрокаНоменклатура.esfKzTnvedName = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"tnvedName",Ложь);
					НоваяСтрокаНоменклатура.esfKzTruOriginCode = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"truOriginCode",Ложь);
					НоваяСтрокаНоменклатура.esfKzTurnoverAdjustment = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"turnoverAdjustment",Ложь);
					НоваяСтрокаНоменклатура.esfKzTurnoverCode = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"turnoverCode",Ложь);
					НоваяСтрокаНоменклатура.esfKzTurnoverSize = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"turnoverSize",Ложь);
					НоваяСтрокаНоменклатура.esfKzUnitCode = ПолучитьЗначениеПоляXDTO(item.esfKzDocumentItem,"unitCode",Ложь);
				КонецЕсли;
				
			КонецЦикла;
		КонецЕсли;
		
		//2021.06.07 ( свой обработчик чтения строки документа
		МодульКастомизации_ОбработатьСобытие("ЧтениеДанныхДокумента",ПараметрыМК);
		// ) 2021.06.07
		
		//2021.11.11 ( Попробуем тут в общей функции "сгруппировать" строки комплектов, передвинув child-строки к их parent
		//при последующем заполнении реестров в формах порядок будет соответствовать заданному тут.
		//Пока отключено
		Если Ложь Тогда
			Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина
				И ЗначениеЗаполнено(НоваяСтрокаДокумент.parent) Тогда
				//Ищем строку с документом-родителем, расчитываем смещение и сдвигаем новую строку к нему
				СтрокаДокументаРодителя = ДанныеПортала.documents.Найти(НоваяСтрокаДокумент.parent,"id");
				Если СтрокаДокументаРодителя <> Неопределено Тогда
					Смещение = ДанныеПортала.documents.Индекс(СтрокаДокументаРодителя) - ДанныеПортала.documents.Индекс(НоваяСтрокаДокумент) + 1;
					ДанныеПортала.documents.Сдвинуть(НоваяСтрокаДокумент,Смещение);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		// ) 2021.11.11
		
	КонецЦикла;
	
	//Установим флаг завершения, если количество документов меньше размера запрашиваемой таблицы (100)
	Если КоличествоЭлементов < 100 Тогда
		РезультатЧтения.ЗагрузкаДанныхЗавершена = Истина;
	КонецЕсли;
	
	Возврат РезультатЧтения;
	
КонецФункции

Функция ПрочитатьСправочникПортала(Дерево,Назначение) Экспорт
	
	Результат = Новый Структура("Успешно,ИмяСправочника,Справочник",Ложь);
	
	Если Назначение = "СправочникиПортала_ТипыДокументов" Тогда
		Результат.ИмяСправочника = "ТипДокумента";
		ИмяКоллекции = "documentTypes";
		ИмяЭлементаКоллекции = "documentType";
		
	ИначеЕсли Назначение = "СправочникиПортала_СтатусыДокументов" Тогда
		Результат.ИмяСправочника = "СтатусДокумента";
		ИмяКоллекции = "documentStates";
		ИмяЭлементаКоллекции = "documentState";
		
	Иначе
		Возврат Результат;
		
	КонецЕсли;
	
	Результат.Справочник = Новый Соответствие;
	
	Если ЗначениеЗаполненоXDTO(Дерево[ИмяКоллекции]) Тогда
		elements = ПолучитьКоллекциюXDTO(Дерево[ИмяКоллекции][ИмяЭлементаКоллекции]);
				
		Для каждого element из elements Цикл
			Результат.Справочник.Вставить(element.id,element.name);
		КонецЦикла;
		
		Результат.Успешно = Истина;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПрочитатьСправочникПортала_Компании(Дерево,Назначение) Экспорт
	
	Результат = Новый Структура("Успешно,ИмяСправочника,Справочник",Ложь);
	
	Если Назначение = "СправочникиПортала_Плательщики" Тогда
		Результат.ИмяСправочника = "Плательщики";
		
	ИначеЕсли Назначение = "СправочникиПортала_Поставщики" Тогда
		Результат.ИмяСправочника = "Поставщики";
		
	Иначе
		Возврат Результат;
		
	КонецЕсли;
	
	ИмяКоллекции = "companies";
	ИмяЭлементаКоллекции = "company";		
	
	Результат.Справочник = Новый СписокЗначений;
	
	Если ЗначениеЗаполненоXDTO(Дерево[ИмяКоллекции]) Тогда
		elements = ПолучитьКоллекциюXDTO(Дерево[ИмяКоллекции][ИмяЭлементаКоллекции]);
				
		Для каждого element из elements Цикл
			
			//Эти реквизиты зависимы от другого сервиса, который, как выяснилось, может возвращать null
			shortName = Строка(ПолучитьЗначениеПоляXDTO(element,"shortName"));
			name = Строка(ПолучитьЗначениеПоляXDTO(element,"name"));
			inn = Строка(ПолучитьЗначениеПоляXDTO(element,"inn"));
			kpp = Строка(ПолучитьЗначениеПоляXDTO(element,"kpp"));
			taxId = Строка(ПолучитьЗначениеПоляXDTO(element,"taxId"));
			
			companyName = ?(ЗначениеЗаполнено(shortName),shortName,name);
			
			Если ЗначениеЗаполнено(taxId) Тогда
				companyName = companyName + "(" + taxId + ")";
			Иначе
				 companyName = companyName + ?(ЗначениеЗаполнено(inn),"(" + inn
					 + ?(ЗначениеЗаполнено(kpp),"/" + kpp,"")
					 + ")","");
			КонецЕсли;
				 
			Результат.Справочник.Добавить(element.id,companyName);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Результат.Успешно = Истина;
	
	Возврат Результат;
	
КонецФункции


