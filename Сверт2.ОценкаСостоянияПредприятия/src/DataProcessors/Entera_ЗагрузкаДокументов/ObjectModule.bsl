			Если РеквизитСуществует("Справочники","КОСГУ") Тогда
				НоваяСтрока.Номенклатура_КЭК = Справочники.КОСГУ.ПустаяСсылка();
			КонецЕсли;			
		КонецЕсли;
		
		//E1C-485: БП 3.0 для Казахстана. Предзаполнение реквизита "Вид поступления" в зависимости от ставки НДС по позиции
		//1) Если по позиции "Без НДС", то поле "Вид поступления" предзаполнять значением "Товары, приобретенные без НДС";
		//2) Если по позиции есть НДС , то поле "Вид поступления" предзаполнять значением "Товары, приобретенные с НДС";
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БП30" И СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Лок = "KAZ" Тогда
			Если СтрокаНоменклатуры.СтавкаНДССсылка = СтруктураНастроек.СведенияОКонфигурации.СтавкиНДС.БезНДС Тогда
				НоваяСтрока.Номенклатура_НДСВидПоступления = Справочники.ВидыПоступления.ПриобретениеТМЗБезНДС;
			Иначе
				НоваяСтрока.Номенклатура_НДСВидПоступления = Справочники.ВидыПоступления.ПриобретениеТМЗ;
			КонецЕсли;
		КонецЕсли;
		
		//расшифровка услуги из документа оказанных услуг
		НоваяСтрока.Номенклатура_НаименованиеПолное = ПредставлениеОбъекта;
		
		// 2019.09.03 ( 3659: Возможно есть сохраненное значение единицы измерения и коэффициента пересчета
		Если ПараметрыДополнения.Свойство("СвязьЕдиницы") Тогда
			СвязьЕдиницы = ПараметрыДополнения.СвязьЕдиницы;
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Наименование",НоваяСтрока.Номенклатура_ЕдиницаИзмеренияПредставление);
			СтруктураПоиска.Вставить("КонтрагентИД",НоваяСтрока.КонтрагентИД);
			
			//Если есть ссылка на номенклатуру - ищем по ней, если нет - по наименованию
			Если ЗначениеЗаполнено(НоваяСтрока.Объект1с) Тогда
				СтруктураПоиска.Вставить("НоменклатураСсылка",НоваяСтрока.Объект1с);
			Иначе
				СтруктураПоиска.Вставить("НаименованиеНоменклатуры",НоваяСтрока.Номенклатура_НаименованиеПолное);
			КонецЕсли;
			
			НайденныеСтроки = СвязьЕдиницы.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныеСтроки.Количество() = 0
				И СтруктураПоиска.Свойство("НоменклатураСсылка") Тогда
					//Исключим поиск по ссылке на номенклатуру, оставим поиск по наименованию номенклатуры
					СтруктураПоиска.Удалить("НоменклатураСсылка");
					СтруктураПоиска.Вставить("НаименованиеНоменклатуры",НоваяСтрока.Номенклатура_НаименованиеПолное);
					
					НайденныеСтроки = СвязьЕдиницы.НайтиСтроки(СтруктураПоиска);
			КонецЕсли;
			
			Если НайденныеСтроки.Количество() > 0 Тогда
				
				//2020.10.30 ( УТ10, УПП, КА: Могут быть найдены и установлены ошибочно сохраненные связи с единицей по классификатору,
				//не устанавливаем их вместо значения, только коэффициент
				Если Конф = "УТ10" Или Конф = "КА1" Или Конф = "УПП" Или Конф = "Автосалон" Или Конф = "КомбинатПитания" Или Конф = "УправлениеРестораном" Тогда
					Если ТипЗнч(НайденныеСтроки[0].Ссылка) = Тип("СправочникСсылка.ЕдиницыИзмерения") Тогда
						НоваяСтрока.Номенклатура_ЕдиницаИзмерения = НайденныеСтроки[0].Ссылка;
					КонецЕсли;
				Иначе
				//Иначе исходный вариант
				// ) 2020.10.30
					НоваяСтрока.Номенклатура_ЕдиницаИзмерения = НайденныеСтроки[0].Ссылка;
				КонецЕсли;
				
				НоваяСтрока.Номенклатура_КоэффициентПересчета = НайденныеСтроки[0].КоэффициентПересчета;
				
				Если Конф = "УТ11" Или Конф = "КА2" Или Конф = "ERP" Тогда
					Если Не ЗначениеЗаполнено(НоваяСтрока.Номенклатура_ЕдиницаИзмерения) Тогда
						//Не заполненная единица измерения может предполагать, что выбрана единица хранения номенклатуры,
						//по логике конфигурации ее не заполняем в табличной части. Для спокойствия пользователя отобразим ее в сопоставлении
						НоваяСтрока.Номенклатура_ЕдиницаИзмерения = НоваяСтрока.Объект1с.ЕдиницаИзмерения;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;

		КонецЕсли;
		// ) 2019.09.03
		
	ИначеЕсли ТипОбъекта = "НомераГТД" Тогда
		
		НоваяСтрока.НомераГТД_Код = ПредставлениеОбъекта;
		
	ИначеЕсли ТипОбъекта = "СтраныМира" Тогда
		
		НоваяСтрока.СтраныМира_Код = СтрокаНоменклатуры.recognizedCountryCode;
		НоваяСтрока.СтраныМира_НаименованиеПолное = СтрокаНоменклатуры.recognizedCountryShortName;
		
	ИначеЕсли ТипОбъекта = "ИсточникиПроисхождения" Тогда
		
		НоваяСтрока.ИсточникиПроисхождения_Код = СтрокаНоменклатуры.esfKzproductDeclaration;
		НоваяСтрока.ИсточникиПроисхождения_ПризнакПроисхождения = СтрокаНоменклатуры.esfKzTruOriginCode;
		НоваяСтрока.ИсточникиПроисхождения_НомерСтрокиГТД = СтрокаНоменклатуры.esfKzproductNumberInDeclaration;
		НоваяСтрока.ИсточникиПроисхождения_КодТНВЭД = СтрокаНоменклатуры.esfKzUnitCode;
		
	КонецЕсли;
	
	НоваяСтрока.Пометка = Не НоваяСтрока.СоответствиеУстановлено;
	
	//2020.10.13 (
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("ТипОбъекта",ТипОбъекта);
	ПараметрыМК.Вставить("ДокументИД",ДокументИД);
	ПараметрыМК.Вставить("СтрокаТаблицы",НоваяСтрока);
	ПараметрыМК.Вставить("ДанныеДокументаПортала",ДанныеДокументаПортала);
	ПараметрыМК.Вставить("ДанныеНоменклатурыПортала",ДанныеНоменклатурыПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
				
	МодульКастомизации_ОбработатьСобытие("Сопоставление_ПослеДобавленияСтрокиТаблицыСопоставления",ПараметрыМК);
	// ) 2020.10.13
		
КонецПроцедуры


Процедура ЗаполнитьИдентификаторыОбъединенияДокументов(АдресХранилищаДанныхПортала,ДопПараметры) Экспорт
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	//Пока объединяются только документы с типом Чек / Авансовый отчет, при необходимости можно сделать соответствие с идентификаторами по разным объединяемым типам 
	ИдентификаторОбъединения_Чек = Строка(Новый УникальныйИдентификатор);
	
	// 2019.10.31 ( Исходная логика предполагает, что объединяются только документы с типом RECEIPT. Теперь принято решение
	//объединять документы с любыми типами. Старый механизм на всякий случай оставляю, чтобы не переделывать
	ОбъединятьЛюбыеТипы = Истина;
	// ) 2019.10.31
	
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		//Обрабатываются только строки документов, не задания распознавания
		Если СтрокаДокумента.recognitionTaskId <> "" Тогда
			Продолжить;
		КонецЕсли;
		
		Если СтрокаДокумента.Пометка Тогда
			
			Если ДопПараметры.ОбъединятьДокументы Тогда
			
				Если СтрокаДокумента.ДокументТип = "RECEIPT"
					Или ОбъединятьЛюбыеТипы Тогда
					//у всех чеков в этой порции документов будет один идентификатор
					ТекИдентификатор = ИдентификаторОбъединения_Чек;
					
				Иначе
					//для прочих документов идентификатором объединения будет их идентификатор
					ТекИдентификатор = СтрокаДокумента.ДокументИД;
					
				КонецЕсли;
				
			Иначе
				//для прочих документов идентификатором объединения будет их идентификатор
				ТекИдентификатор = СтрокаДокумента.ДокументИД;
				
			КонецЕсли;
			
		Иначе
			//Снимаем идентификатор объединения у строки
			ТекИдентификатор = "";
			
		КонецЕсли;
		
		СтрокаДокумента.ИдентификаторОбъединения = ТекИдентификатор;
		
		ДанныеДокумента = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
		ДанныеНоменклатуры = ДанныеПортала.documentItems.НайтиСтроки(Новый Структура("documentId",СтрокаДокумента.ДокументИД));
		
		ДанныеДокумента.ИдентификаторОбъединения = ТекИдентификатор;
		
		Для Каждого СтрокаНоменклатуры Из ДанныеНоменклатуры Цикл
			СтрокаНоменклатуры.ИдентификаторОбъединения = ТекИдентификатор;
		КонецЦикла;
			
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
		
КонецПроцедуры

Функция ПолучитьСтруктуруОбъединенныхДанныхЗаполненияДокумента(АдресХранилищаДанныхПортала,ИдентификаторОбъединения,СтруктураНастроек,ДопПараметры) Экспорт
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("ИдентификаторОбъединения",ИдентификаторОбъединения);
	
	МассивИдентификаторовДокументов = Новый Массив;
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	ДанныеДокументов = ДанныеПортала.documents.НайтиСтроки(Новый Структура("ИдентификаторОбъединения",ИдентификаторОбъединения));
	
	//Направление определяем по первому документу из найденной группы
	СтрокаСпискаДокументов = СписокДокументов.Найти(ИдентификаторОбъединения,"ИдентификаторОбъединения");
	Если СтрокаСпискаДокументов = Неопределено Тогда //Самопроверка
		СообщитьСообщение("Внутренняя ошибка модуля: не удалось получить по идентификатору объединения документов строку документа");
		Возврат Неопределено;
	КонецЕсли;
	
	НаправлениеСоздаваемогоДокумента = СтрокаСпискаДокументов.НаправлениеСоздаваемогоДокумента;
	СтруктураДанных.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	
	ДанныеШапки = Инициализировать_Таблица_documents(Истина);
	
	//E1C-292: "первый" документ в списке формы сопоставления был отмечен как основной из объединяемых для получения из него данных шапки
	СтруктураПоискаДанныхШапки = Новый Структура("ИдентификаторОбъединения,СодержитДанныеШапкиОбъединенногоДокумента",ИдентификаторОбъединения,Истина);
	СтрокиШапкиОбъединенногоДокумента = ДанныеПортала.documents.НайтиСтроки(СтруктураПоискаДанныхШапки);
	Если СтрокиШапкиОбъединенногоДокумента.Количество() > 0 Тогда
		ДанныеДокумента = СтрокиШапкиОбъединенногоДокумента[0];
		
	Иначе
	// ) E1C-292
	
		//Для заполнения шапки объединяемых документов берем первый из найденной коллекции
		ДанныеДокумента = ДанныеДокументов[0];
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДанныеШапки,ДанныеДокумента);
	ДанныеШапки.Вставить("НаправлениеСоздаваемогоДокумента",НаправлениеСоздаваемогоДокумента);
	СтруктураДанных.Вставить("document",ДанныеШапки);
	
	//Обходим коллекцию документов, заполняем строки товаров
	documentItems = Новый Массив;
	
	Для Каждого ДанныеДокумента Из ДанныеДокументов Цикл
		
		Если НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
			ОрганизацияСсылка = ДанныеДокумента.ПлательщикСсылка;
			КонтрагентСсылка = ДанныеДокумента.ПоставщикСсылка;
		Иначе
			ОрганизацияСсылка = ДанныеДокумента.ПоставщикСсылка;
			КонтрагентСсылка = ДанныеДокумента.ПлательщикСсылка;
		КонецЕсли;
		
		ДанныеНоменклатуры = ДанныеПортала.documentItems.НайтиСтроки(Новый Структура("documentId",ДанныеДокумента.id));
		
		Для каждого СтрокаНоменклатуры Из ДанныеНоменклатуры Цикл
			ДанныеСтрокиНоменклатуры = Инициализировать_Таблица_documentItems(Истина);
			ЗаполнитьЗначенияСвойств(ДанныеСтрокиНоменклатуры,СтрокаНоменклатуры);
			
			//Добавим необходимые поля шапки документа для заполнения авансового отчета
			ДанныеСтрокиНоменклатуры.Вставить("Организация",ОрганизацияСсылка);
			ДанныеСтрокиНоменклатуры.Вставить("Контрагент",КонтрагентСсылка);
			ДанныеСтрокиНоменклатуры.Вставить("ДоговорКонтрагента",ДанныеДокумента.ДоговорСсылка);
			ДанныеСтрокиНоменклатуры.Вставить("number",ДанныеДокумента.number);
			ДанныеСтрокиНоменклатуры.Вставить("date",ДанныеДокумента.date);
			ДанныеСтрокиНоменклатуры.Вставить("type",ДанныеДокумента.type);
			
			documentItems.Добавить(ДанныеСтрокиНоменклатуры);
		КонецЦикла;
		
		//Определим для этой структуры, где будет храниться связь
		МассивИдентификаторовДокументов.Добавить(ДанныеДокумента.id);
		
	КонецЦикла;
	
	СтруктураДанных.Вставить("documentItems",documentItems);
	СтруктураДанных.Вставить("МассивИдентификаторовДокументов",МассивИдентификаторовДокументов);
	
	//По флагу в настройках загружаем файл скана и прикрепляем его как ПрисоединенныйФайл
	МассивФайлов = Новый Массив;
	
	Если СтруктураНастроек.СозданиеДокумента_ПрисоединятьФайлСканаДокумента = Истина Тогда
		
		//Файлов сканов у конечного документа может быть несколько, если мы объединяем несколько документов в один
		НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("ИдентификаторОбъединения",ИдентификаторОбъединения));
		
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			
			Если ЭтоАдресВременногоХранилища(НайденнаяСтрока.АдресХранилищаСканаДокумента) Тогда
				СтруктураФайла = Новый Структура;
				СтруктураФайла.Вставить("АдресВХ",НайденнаяСтрока.АдресХранилищаСканаДокумента);
				СтруктураФайла.Вставить("ИмяФайла",НайденнаяСтрока.ИмяФайлаСканаДокумента);
				СтруктураФайла.Вставить("ДокументТип",НайденнаяСтрока.ДокументТип);
				
				МассивФайлов.Добавить(СтруктураФайла);
			КонецЕсли;
			
		КонецЦикла;
		
		//Для комплектов документов прикрепляем оба скана к основному документу
		Если СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
			
			Если ЗначениеЗаполнено(СтрокаСпискаДокументов.parentId) Тогда
				
				НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтрокаСпискаДокументов.parentId));
				Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
					
					Если ЭтоАдресВременногоХранилища(НайденнаяСтрока.АдресХранилищаСканаДокумента) Тогда
						СтруктураФайла = Новый Структура;
						СтруктураФайла.Вставить("АдресВХ",НайденнаяСтрока.АдресХранилищаСканаДокумента);
						СтруктураФайла.Вставить("ИмяФайла",НайденнаяСтрока.ИмяФайлаСканаДокумента);
						СтруктураФайла.Вставить("ДокументТип",НайденнаяСтрока.ДокументТип);
						
						//Проверим, нет ли уже в массиве этого файла
						Если МассивФайлов.Найти(СтруктураФайла) = Неопределено Тогда
							МассивФайлов.Добавить(СтруктураФайла);
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
				
			ИначеЕсли ЗначениеЗаполнено(СтрокаСпискаДокументов.childrenId) Тогда
				
				НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("ДокументИД",СтрокаСпискаДокументов.childrenId));
				Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
					
					Если ЭтоАдресВременногоХранилища(НайденнаяСтрока.АдресХранилищаСканаДокумента) Тогда
						СтруктураФайла = Новый Структура;
						СтруктураФайла.Вставить("АдресВХ",НайденнаяСтрока.АдресХранилищаСканаДокумента);
						СтруктураФайла.Вставить("ИмяФайла",НайденнаяСтрока.ИмяФайлаСканаДокумента);
						СтруктураФайла.Вставить("ДокументТип",НайденнаяСтрока.ДокументТип);
						
						//Проверим, нет ли уже в массиве этого файла
						Если МассивФайлов.Найти(СтруктураФайла) = Неопределено Тогда
							МассивФайлов.Добавить(СтруктураФайла);
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	СтруктураДанных.Вставить("МассивФайлов",МассивФайлов);
	
	Возврат СтруктураДанных;
	
КонецФункции

Процедура ЗаполнитьАдресХранилищаСканаДокументаВДанныхПортала(АдресХранилищаДанныхПортала) Экспорт
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		ДанныеДокумента = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
		
		Если ДанныеДокумента <> Неопределено Тогда
			ДанныеДокумента.АдресХранилищаСканаДокумента = СтрокаДокумента.АдресХранилищаСканаДокумента;
			ДанныеДокумента.ИмяФайлаСканаДокумента = СтрокаДокумента.ИмяФайлаСканаДокумента;
		КонецЕсли;
		
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ДанныеПортала,АдресХранилищаДанныхПортала);
	
КонецПроцедуры


Функция СнятьФлагСозданияУСвязанныхДокументов() Экспорт
	
	Результат = Новый Структура("Успешно",Ложь);
	
	НайденныеСтроки = СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	
	Для Каждого Строка Из НайденныеСтроки Цикл
		СвязанныйДокумент = СписокДокументов.Найти(Строка.parentId,"ДокументИД");
		
		Если СвязанныйДокумент <> Неопределено Тогда
			Если СвязанныйДокумент.Пометка = Истина Тогда
				СвязанныйДокумент.Пометка = Ложь;
				Результат.Успешно = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция КонтрольЗаполнения_ФормаСопоставления_Склады() Экспорт
		
	ДокументыБезСклада = "";
	СтруктураПоиска = Новый Структура("ТипОбъекта","Документ");
	СтрокиДокументов = ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	
	Для Каждого СтрокаТаблицы Из СтрокиДокументов Цикл
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Документ_Склад) Тогда
			//Проверяем, есть ли вообще в таком типе заполняемого документа реквизит Склад
			Если РеквизитСуществует("Документы",СтрокаТаблицы.ТипСоздаваемогоДокумента,"Склад")
				Или РеквизитСуществует("Документы",СтрокаТаблицы.ТипСоздаваемогоДокумента,"СкладОрдер") Тогда
				
				//Проверяем, в этом документе выбраны только услуги?				
				СтруктураПоиска = Новый Структура("ТипОбъекта,ДокументИД","Номенклатура",СтрокаТаблицы.ДокументИД);
				СтрокиНоменклатуры = ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
				
				ЕстьТовары = Ложь;
				Для Каждого СтрокаНоменклатуры Из СтрокиНоменклатуры Цикл
											
					Если ЗначениеЗаполнено(СтрокаНоменклатуры.Объект1с) Тогда
						
						//Проверяем признак у заполненной номенклатуры Услуга
						Если СтрокаНоменклатуры.Объект1с.Метаданные().Реквизиты.Найти("Услуга") <> Неопределено Тогда //БП
							Если СтрокаНоменклатуры.Объект1с.Услуга = Ложь Тогда
								ЕстьТовары = Истина;
								Прервать;
							КонецЕсли;
							
						ИначеЕсли СтрокаНоменклатуры.Объект1с.Метаданные().Реквизиты.Найти("ТипНоменклатуры") <> Неопределено
							И РеквизитСуществует("Перечисления","ТипыНоменклатуры","Услуга") Тогда
							Если СтрокаНоменклатуры.Объект1с.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
								ЕстьТовары = Истина;
								Прервать;
							КонецЕсли;
							
						КонецЕсли;
						
					Иначе
						Если СтрокаНоменклатуры.ДополнительноеОписаниеОбъекта = "Товар" Тогда
							ЕстьТовары = Истина;
							Прервать;
						КонецЕсли;
						
					КонецЕсли;
				КонецЦикла;
				
				Если ЕстьТовары Тогда
					ДокументыБезСклада = ДокументыБезСклада + Символы.ПС + СтрокаТаблицы.ПредставлениеОбъекта;
					//Запомним идентификатор первого документа без склада, чтобы вывести сообщение к этой строке
					СтрокаБезСклада = ?(СтрокаБезСклада = Неопределено,ЗагружаемыеОбъекты.Индекс(СтрокаТаблицы),СтрокаБезСклада);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Новый Структура("ДокументыБезСклада,СтрокаБезСклада",ДокументыБезСклада,СтрокаБезСклада);
	
КонецФункции


Функция ИзменитьСтороныДокумента_ПодготовитьДанныеДляПортала(АдресХранилищаДанныхПортала,МассивИдентификаторов) Экспорт
	
	//E1C-273: В реестре документов, в контекстном меню добавить пункт "поменять контрагентов местами"
	//	+ отправить данные о смене сторон на портал
	
	Результат = Новый Структура("Успешно,ТекстОшибки,КоллекцияЗапросов",Истина);
	
	КоллекцияЗапросов = Новый Соответствие;
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Для Каждого ДокументИД Из МассивИдентификаторов Цикл
		ДанныеДокумента = ДанныеПортала.documents.Найти(ДокументИД,"id");
		
		//скопируем данные покупателя
		customer = Новый Структура("customerId,customerInn,customerKpp,customerName,customerShortName");
		ЗаполнитьЗначенияСвойств(customer,ДанныеДокумента);
		
		//Заменим данные покупателя данными поставщика
		ДанныеДокумента.customerId = ДанныеДокумента.supplierId;
		ДанныеДокумента.customerInn = ДанныеДокумента.supplierInn;
		ДанныеДокумента.customerKpp = ДанныеДокумента.supplierKpp;
		ДанныеДокумента.customerName = ДанныеДокумента.supplierName;
		ДанныеДокумента.customerShortName = ДанныеДокумента.supplierShortName;
		
		//Заменим данные поставщика данными покупателя
		ДанныеДокумента.supplierId = customer.customerId;
		ДанныеДокумента.supplierInn = customer.customerInn;
		ДанныеДокумента.supplierKpp = customer.customerKpp;
		ДанныеДокумента.supplierName = customer.customerName;
		ДанныеДокумента.supplierShortName = customer.customerShortName;
		
		
		//Меняем данные в списке документов
		СтрокаДокумента = СписокДокументов.Найти(ДокументИД,"ДокументИД");
		ПредставлениеПлательщика = СтрокаДокумента.ПредставлениеПлательщика;
		СтрокаДокумента.ПредставлениеПлательщика = СтрокаДокумента.ПредставлениеПоставщика;
		СтрокаДокумента.ПредставлениеПоставщика = ПредставлениеПлательщика;
		
		
		//Формируем тело запроса для отправки данных документа порталу
		ТелоЗапроса = ОбновлениеДанныхДокументов_СформироватьТелоЗапроса_suplier_customer(ДанныеДокумента);
		КоллекцияЗапросов.Вставить(ДокументИД,ТелоЗапроса);
		
	КонецЦикла;
	
	Результат.КоллекцияЗапросов = КоллекцияЗапросов;
	
	Возврат Результат;
	
КонецФункции

Функция УстановитьСтатусДокумента_ПодготовитьДанныеДляПортала(АдресХранилищаДанныхПортала,МассивИдентификаторов,Статус) Экспорт
	
	//E1C-309: В реестре документов, в контекстном меню добавить пункт "изменить статус документа"
	//	+ отправить данные о смене сторон на портал
	
	Результат = Новый Структура("Успешно,ТекстОшибки,КоллекцияЗапросов",Истина);
	
	КоллекцияЗапросов = Новый Соответствие;
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Для Каждого ДокументИД Из МассивИдентификаторов Цикл
		ДанныеДокумента = ДанныеПортала.documents.Найти(ДокументИД,"id");
		
		ДанныеДокумента.state = Статус.Статус;
		ДанныеДокумента.ПредставлениеСтатуса = Статус.ПредставлениеСтатуса;
		
		Если Статус.Статус = "UPLOADED" Тогда
			ДанныеДокумента.uploaded = Истина;
		КонецЕсли;
		
		//Меняем данные в списке документов
		СтрокаДокумента = СписокДокументов.Найти(ДокументИД,"ДокументИД");
		СтрокаДокумента.ДокументСтатус = Статус.Статус;
		СтрокаДокумента.ПредставлениеСтатуса = Статус.ПредставлениеСтатуса;
		
		СтрокаДокумента.Счетчик_Загружен = 0;
		СтрокаДокумента.Счетчик_Проверен = 1;
		СтрокаДокумента.Счетчик_Распознан = 0;		
		
		//Формируем тело запроса для отправки данных документа порталу
		ТелоЗапроса = ОбновлениеДанныхДокументов_СформироватьТелоЗапроса_state(ДанныеДокумента);
		КоллекцияЗапросов.Вставить(ДокументИД,ТелоЗапроса);
		
	КонецЦикла;
	
	Результат.КоллекцияЗапросов = КоллекцияЗапросов;
	
	Возврат Результат;
	
КонецФункции


