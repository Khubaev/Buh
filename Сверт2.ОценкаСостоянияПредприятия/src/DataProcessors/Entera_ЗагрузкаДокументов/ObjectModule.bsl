	//2019.05.21 ( БГУ
	Если Конфигурация.Крат = "БГУ" Или Конфигурация.Крат = "БГУ2"
		Или Найти(ИмяКонфигурации,"БухгалтерияГосударственногоУчреждения") > 0 Тогда
		
		ТипыДокументов.Добавить("МЗ_Покупка");
		// 2019.08.06 ( БГУ2
		ТипыДокументов.Добавить("ПоступлениеМЗ");
		ТипыДокументов.Добавить("ПоступлениеУслугРабот");
		ТипыДокументов.Добавить("УслугиСтороннихОрганизаций");
		ТипыДокументов.Добавить("СчетНаОплату");
		// ) 2019.08.06
		
		//2023.07.06 (
		ТипыДокументов.Добавить("РегистрацияОбязательствИСведенийПоДоговорам");
		// ) 2023.07.06
		
		//2024.10.01 (
		ТипыДокументов.Добавить("_ПоступлениеОС");
		// ) 2024.10.01
	КонецЕсли;
	
	//2020.02.21 ( ФитнесКлуб
	Если ИмяКонфигурации = "ФитнесКлуб" Тогда
		ТипыДокументов.Добавить("Поступление");
	КонецЕсли;
	// ) 2020.02.21
	
	//2024.07.17 ( УправлениеЮвелирнымПроизводством
	Если ИмяКонфигурации = "УправлениеЮвелирнымПроизводством" Тогда
		ТипыДокументов.Добавить("ПоступлениеМатериалов");
	КонецЕсли;
	// ) 2024.07.17
	
	//2020.02.21 ( ITОтдел
	Если Конфигурация.Крат = "ITОтдел"
		//2021.12.22 ( еще какое-то нетленное творение "про стоматологию"
		Или Найти(ИмяКонфигурации,"Стоматология") > 0 Тогда
		// ) 2021.12.22
		ТипыДокументов.Добавить("Поступление");
	КонецЕсли;
	// ) 2020.02.21
	
	//Управление торговлей для Казахстана
	Если ИмяКонфигурации = "УправлениеТорговлейДляКазахстана" Тогда
		ТипыДокументов.Добавить("ПеремещениеТоваров");
	КонецЕсли;
	
	//2022.06.28 (
	ТипыДокументов.Добавить("Тренд_ЗаказПоставщику");
	// ) 2022.06.28
	
	//УАТ
	ТипыДокументов.Добавить("уатПоступлениеТоваровУслуг");
	ТипыДокументов.Добавить("уатРеализацияУслуг");
	ТипыДокументов.Добавить("_уатСчетНаОплатуПокупателю");
	
	//ЭлитСтроительство
	ТипыДокументов.Добавить("эсПланРабот");
	
	ДоступныеТипы = Новый СписокЗначений;
	
	Для Каждого Строка Из ТипыДокументов Цикл	
		НайденныйТип = Метаданные.Документы.Найти(Строка.Значение);
		Если НайденныйТип <> Неопределено И ДоступныеТипы.НайтиПоЗначению(Строка.Значение) = Неопределено Тогда
			НовыйЭлемент = ДоступныеТипы.Добавить();
			НовыйЭлемент.Значение = Строка.Значение;
			НовыйЭлемент.Представление = ?(ЗначениеЗаполнено(НайденныйТип.ПредставлениеОбъекта),НайденныйТип.ПредставлениеОбъекта,НайденныйТип.Синоним);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДоступныеТипы;
	
КонецФункции

Функция ПолучитьСписокВидовОперацийЗаполняемыхДокументов(ТипыЗаполняемыхДокументов,Конфигурация) Экспорт
	
	ВидыОпераций = Новый Соответствие;
	
	Для Каждого ТипДокумента Из ТипыЗаполняемыхДокументов Цикл
		
		//выбор вида операции для создаваемого документа
		ДоступныеВиды = Новый Массив;
		СписокВидовОпераций = Новый СписокЗначений;
		
		// "_" - Пока отключено
		
		Если ТипДокумента.Значение = "ПоступлениеТоваровУслуг" Тогда
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","Товары") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Товары);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","Услуги") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Услуги);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ПокупкаКомиссия") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПокупкаКомиссия);
			КонецЕсли;
			
			//2024.08.22 ( БП30 KAZ
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ПокупкаКомисия") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПокупкаКомисия);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","Импорт") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.Импорт);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ПоступлениеОтНерезидента") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПоступлениеОтНерезидента);
			КонецЕсли;
			// ) 2024.08.22
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","ВПереработку") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ВПереработку);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТоваровУслуг","УслугиЛизинга") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТоваровУслуг.УслугиЛизинга);
