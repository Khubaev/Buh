			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	//E1C-162: Поиск по возможным соответствиям ЕИ из списка синонимов портала
	Если Не ЗначениеЗаполнено(ЕдиницаИзмеренияСсылка) И Не ПовторныйВызовПоискаПоСинонимам Тогда
		//Ищем единицу по классификатору в словаре синонимов по userUnitName и unitName
		ДанныеСловаря = СтруктураНастроек.СловарьСинонимовЕИ.Получить(СтрокаНоменклатура.userUnitName);
		Если ДанныеСловаря = Неопределено Тогда
			ДанныеСловаря = СтруктураНастроек.СловарьСинонимовЕИ.Получить(СтрокаНоменклатура.unitName);
		КонецЕсли;
		
		Если ДанныеСловаря <> Неопределено Тогда
			
			//Нужно определиться, будем подменять в данных портала распознанные данные найденными в "классификаторе" портала,
			//или использовать такие данные только для поиска ссылки, а в таблице данных портала оставляем исходные?
			ЗаменяемДанныеПортала = Истина;
			
			Если ЗаменяемДанныеПортала Тогда
				СтруктураПоиска = СтрокаНоменклатура;
			Иначе
				//Чтобы не изменять данные портала, заполняем новую структуру для поиска значениями, найденными в синонимах, и повторяем поиск
				СтруктураПоиска = Инициализировать_Таблица_documentItems(Истина);
				ЗаполнитьЗначенияСвойств(СтруктураПоиска,СтрокаНоменклатура);
			КонецЕсли;
			
			СтруктураПоиска.userUnitName = ДанныеСловаря.Наименование;
			СтруктураПоиска.unitName = ДанныеСловаря.Наименование;
			СтруктураПоиска.unitCode = ДанныеСловаря.Код;
			СтруктураПоиска.recognizedUnitCode = ДанныеСловаря.Код;
			ЕдиницаИзмеренияСсылка = ПолучитьСсылку_УпаковкаЕдиницаИзмерения(СтруктураПоиска,СтруктураНастроек,Истина);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЕдиницаИзмеренияСсылка;
	
КонецФункции

Функция ПолучитьСсылку_СтавкаНДС(Значение,СтавкиНДС)
	
	Результат = СтавкиНДС.БезНДС;
	
	Если Значение = "PERCENT_18" Тогда
		Результат = СтавкиНДС.НДС18;
	ИначеЕсли Значение = "PERCENT_22" Тогда
		Результат = СтавкиНДС.НДС22;
	ИначеЕсли Значение = "PERCENT_20" Тогда
		// НАЧАЛО ВРЕМЕННОГО КОСТЫЛЯ (
		Если Не СтавкиНДС.Свойство("НДС20")
			Или СтавкиНДС.НДС20 = Неопределено Тогда
			Результат = СтавкиНДС.НДС18;
		Иначе
		// ) КОНЕЦ ВРЕМЕННОГО КОСТЫЛЯ
			Результат = СтавкиНДС.НДС20;
		КонецЕсли;			
	ИначеЕсли Значение = "PERCENT_10" Тогда
		Результат = СтавкиНДС.НДС10;
	ИначеЕсли Значение = "PERCENT_12" Тогда
		Результат = СтавкиНДС.НДС12;
	ИначеЕсли Значение = "PERCENT_16" Тогда
		Результат = СтавкиНДС.НДС16;
	ИначеЕсли Значение = "PERCENT_5" Тогда
		Результат = СтавкиНДС.НДС5;
	ИначеЕсли Значение = "PERCENT_7" Тогда
		Результат = СтавкиНДС.НДС7;
	ИначеЕсли Значение = "0"
		Или Значение = "PERCENT_0" Тогда
		Результат = СтавкиНДС.НДС0;
		
	//E1C-509: появились счета-фактуры на аванс
	ИначеЕсли Значение = "PERCENT_18_118" Тогда
		Результат = СтавкиНДС.НДС18_118;
	ИначеЕсли Значение = "PERCENT_20_120" Тогда
		Результат = СтавкиНДС.НДС20_120;
	ИначеЕсли Значение = "PERCENT_22_122" Тогда
		Результат = СтавкиНДС.НДС22_122;
	ИначеЕсли Значение = "PERCENT_10_110" Тогда
		Результат = СтавкиНДС.НДС10_110;
	ИначеЕсли Значение = "PERCENT_7_107" Тогда
		Результат = СтавкиНДС.НДС7_107;
	ИначеЕсли Значение = "PERCENT_5_105" Тогда
		Результат = СтавкиНДС.НДС5_105;
	
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ПолучитьСсылку_СерияНоменклатуры(СтрокаНоменклатура,СтруктураНастроек,ПараметрыПоиска) Экспорт
	
	Результат = Справочники.СерииНоменклатуры.ПустаяСсылка();
	
	//Модуль кастомизации: можно переопределить установленное стандартным поиском значение
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ПараметрыПоиска",ПараметрыПоиска);
	ПараметрыМК.Вставить("СтрокаНоменклатуры",СтрокаНоменклатура);
	ПараметрыМК.Вставить("СерияНоменклатурыСсылка",Результат);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
	МодульКастомизации_ОбработатьСобытие("ПоискСсылок_ОпределениеСерииНоменклатуры",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка <> Истина Тогда
		Результат = ПараметрыМК.СерияНоменклатурыСсылка;
		
	Иначе
	
		Если ЗначениеЗаполнено(СтрокаНоменклатура.НоменклатураСсылка)
			И ЗначениеЗаполнено(СтрокаНоменклатура.НомерГТДСсылка)
			И ЗначениеЗаполнено(СтрокаНоменклатура.СтранаПроисхожденияСсылка) Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	СерииНоменклатуры.Ссылка
			               |ИЗ
			               |	Справочник.СерииНоменклатуры КАК СерииНоменклатуры
			               |ГДЕ
						   |	НЕ СерииНоменклатуры.ПометкаУдаления
						   |	И СерииНоменклатуры.Владелец = &Номенклатура
						   |	И СерииНоменклатуры.НомерГТД = &НомерГТД
			               |	И СерииНоменклатуры.СтранаПроисхождения = &СтранаПроисхождения";
			Запрос.УстановитьПараметр("Номенклатура",ПараметрыПоиска.Номенклатура);
			Запрос.УстановитьПараметр("НомерГТД",ПараметрыПоиска.НомерГТД);
			Запрос.УстановитьПараметр("СтранаПроисхождения",ПараметрыПоиска.СтранаПроисхождения);
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				Результат = Выборка.Ссылка;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСсылку_ИсточникПроисхождения(ПараметрыПоиска) Экспорт
	
	//E1C-477: Поиск Номер ГТД/сертификата, код ТНВЭД, Номер строки ГТД/Заявления
	Результат = Справочники.НомераГТД.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ИсточникиПроисхождения.Ссылка
	               |ИЗ
	               |	Справочник.НомераГТД КАК ИсточникиПроисхождения
	               |ГДЕ
				   |	НЕ ИсточникиПроисхождения.ПометкаУдаления
				   |	И ИсточникиПроисхождения.Код = &Код
				   |	И ИсточникиПроисхождения.КодТНВЭД = &КодТНВЭД
	               |	И ИсточникиПроисхождения.НомерСтрокиГТД = &НомерСтрокиГТД";
	Запрос.УстановитьПараметр("Код",Строка(ПараметрыПоиска.Код));
	Запрос.УстановитьПараметр("КодТНВЭД",Строка(ПараметрыПоиска.КодТНВЭД));
	Запрос.УстановитьПараметр("НомерСтрокиГТД",Строка(ПараметрыПоиска.НомерСтрокиГТД));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Выборка.Ссылка;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьСсылку_ОбъектПоСвойствуИдентификаторуПортала(СтруктураНастроек,Значение)
	
	//2019.05.21 ( БГУ: Измерение Объект регистра ЗначенияСвойствОбъектов не позволяет хранить ссылки на документы,
	//храним связь в своей таблице в ХранилищеОбщихНастроек
	Если СтруктураНастроек.СведенияОКонфигурации.ХранениеСвязиДокументов_СвояТаблица = Истина Тогда
		СвязьДокументов = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СвязьДокументов");
	
		Если ТипЗнч(СвязьДокументов) = Тип("ТаблицаЗначений") Тогда
			СтрокиТаблицы = СвязьДокументов.НайтиСтроки(Новый Структура("documentId",Значение));
			Если СтрокиТаблицы.Количество() > 0 Тогда
				Результат = СтрокиТаблицы[0].Ссылка;
			КонецЕсли;
		КонецЕсли;
		
	Иначе
	
		Свойство = СтруктураНастроек.Свойство_Entera_documentId;
		
		ИмяРегистраСведений = СтруктураНастроек.ИмяРегистраСведений;
		
		Если ИмяРегистраСведений <> Неопределено Тогда
			
			ТекстЗапроса = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			               |	ДополнительныеСведения.Объект КАК Ссылка
			               |ИЗ
			               |	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
			               |ГДЕ
			               |	ДополнительныеСведения.Свойство = &Свойство
						   //2023.05.17 ( Управление Холдингом изменили тип ресурса Значения на неограниченную строку, ограничим
						   |	И Выразить(ДополнительныеСведения.Значение КАК Строка(100)) = &Значение";
						   // ) 2023.05.17
			
			Если ИмяРегистраСведений <> "ДополнительныеСведения" Тогда
				ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"ДополнительныеСведения",ИмяРегистраСведений);
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			Запрос.УстановитьПараметр("Свойство",Свойство);
			Запрос.УстановитьПараметр("Значение",Значение);
			
			Выборка = Запрос.Выполнить().Выбрать();
			
			Если Выборка.Следующий() Тогда
				Результат = Выборка.Ссылка;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		//Связь может также храниться в дополнительной таблице объединенных документов		
		ТаблицаОбъединенныхДокументов = ПолучитьДанныеИзОбщегоХранилища("ОбъединенныеДокументы");
		Если ТипЗнч(ТаблицаОбъединенныхДокументов) = Тип("ТаблицаЗначений") Тогда
			СтрокиДокумента = ТаблицаОбъединенныхДокументов.НайтиСтроки(Новый Структура("documentId",Значение));
			Если СтрокиДокумента.Количество() > 0 Тогда
				Результат = СтрокиДокумента[0].Ссылка;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Результат) И ОбъектНеНайден(Результат) Тогда
		Результат = Неопределено;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОпределитьФлаг_УчитыватьНДС(СтруктураНастроек,Организация,Дата)
		
	Конф = СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат; 
	
	УчитыватьНДС = Истина;	
	
	//2019.06.16 ( флаг Учитывать НДС вынесен в настройки
	Если СтруктураНастроек.ЗаполнениеШапки_УчитыватьНДС = Ложь Тогда
		УчитыватьНДС = Ложь;
	КонецЕсли;
	
	Возврат УчитыватьНДС;
	// ) 2019.06.16
	
	Если Конф = "БП30" Тогда
		
		МодульУчетнаяПолитика = _ЗФ_ПолучитьОбщийМодульКонфигурации("УчетнаяПолитика");
		Если МодульУчетнаяПолитика <> Неопределено Тогда
			Попытка
				ПлательщикНДС = МодульУчетнаяПолитика.ПлательщикНДС(Организация, Дата);
				Если ПлательщикНДС <> Истина Тогда
					УчитыватьНДС = Ложь;
				КонецЕсли;
			Исключение;
				
			КонецПопытки;
		КонецЕсли;
		
	ИначеЕсли Конф = "УТ11" Тогда
		
		МодульУчетнаяПолитика = _ЗФ_ПолучитьОбщийМодульКонфигурации("УчетнаяПолитика");
		Если МодульУчетнаяПолитика <> Неопределено Тогда
			Попытка
				ПлательщикНДС = МодульУчетнаяПолитика.ПлательщикНДС(Организация, Дата);
				Если ПлательщикНДС <> Истина Тогда
					УчитыватьНДС = Ложь;
				КонецЕсли;
			Исключение;
				
			КонецПопытки;
		КонецЕсли;
	
	ИначеЕсли Конф = "УНФ" Тогда
		
		МодульУправлениеНебольшойФирмойСервер = _ЗФ_ПолучитьОбщийМодульКонфигурации("УправлениеНебольшойФирмойСервер");
		Если МодульУправлениеНебольшойФирмойСервер <> Неопределено Тогда
			Попытка
				НалогообложениеНДС = МодульУправлениеНебольшойФирмойСервер.НалогообложениеНДС(Организация,,Дата);
				Если НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.НеОблагаетсяНДС Тогда
					УчитыватьНДС = Ложь;
				КонецЕсли;
			Исключение;
				
			КонецПопытки;
		КонецЕсли; 
		
	КонецЕсли;
	
	Возврат УчитыватьНДС;
	
КонецФункции

Функция ПолучитьСписокГруппДляПоискаНоменклатуры(СтрокаТаблицы,СтруктураНастроек)
	
	//E1C-271: поиск номенклатуры должен выполняться с учетом настроенных групп не только в форме сопоставления, но и до ее открытия.
	//код функции чуть более чем полностью состоит из клиентского кода формы сопоставления для выполнения этого поиска на сервере
	
	СписокГрупп = Новый Массив;

	// Получаем таблицу "маркеров" - подстрок поиска номенклатуры в иерархии группы						
	ДанныеСвязей = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СловаМаркеры");
	Если ТипЗнч(ДанныеСвязей) = Тип("ТаблицаЗначений") Тогда
		Для Каждого СтрокаМаркер Из ДанныеСвязей Цикл
			Если СтрокаМаркер.Маркер <> "" И ЗначениеЗаполнено(СтрокаМаркер.Номенклатура) И СтрокаМаркер.Номенклатура.ЭтоГруппа Тогда
				
				СтрокаДляПоиска = Нрег(СтрокаТаблицы.name);				
				
				Если Найти(СтрокаДляПоиска,Нрег(СтрокаМаркер.Маркер)) > 0 Тогда
					СписокГрупп.Добавить(СтрокаМаркер.Номенклатура);
				КонецЕсли;
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
						
	Если СтруктураНастроек.Свойство("Номенклатура_ГруппаДляПоискаПохожейНоменклатуры")
		И ЗначениеЗаполнено(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры) Тогда
		
		Если ТипЗнч(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры) = Тип("СписокЗначений") Тогда
			Для Каждого ЭлементСписка Из СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры Цикл
				СписокГрупп.Добавить(ЭлементСписка.Значение);
			КонецЦикла;
		Иначе
			СписокГрупп.Добавить(СтруктураНастроек.Номенклатура_ГруппаДляПоискаПохожейНоменклатуры);
		КонецЕсли;
	КонецЕсли;
		
	Возврат СписокГрупп;
	
КонецФункции


