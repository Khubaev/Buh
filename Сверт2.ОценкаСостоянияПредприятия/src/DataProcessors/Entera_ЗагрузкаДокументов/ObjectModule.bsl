			КонецЕсли;
			
		//"Моя бухгалтерия" (Беларусь)
		ИначеЕсли ТипДокумента.Значение = "ПоступлениеТМЦ" Тогда			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТМЦ","Покупка") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТМЦ.Покупка);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийПоступлениеТМЦ","Впереработку") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийПоступлениеТМЦ.Впереработку);
			КонецЕсли;
			
		//2026.01.13 (
		ИначеЕсли ТипДокумента.Значение = "ПоступлениеТоваровОтХранителя" Тогда			
			Если РеквизитСуществует("Перечисления","ХозяйственныеОперации","ВозвратОтКомиссионера") Тогда
				ДоступныеВиды.Добавить(Перечисления.ХозяйственныеОперации.ВозвратОтКомиссионера);
			КонецЕсли;			
		// ) 2026.01.13
		
		КонецЕсли;
		
		Для Каждого ВидОперации Из ДоступныеВиды Цикл
			СписокВидовОпераций.Добавить(ВидОперации);
		КонецЦикла;
		
		ВидыОпераций.Вставить(ТипДокумента.Значение,СписокВидовОпераций);
		
	КонецЦикла;
	
	Возврат ВидыОпераций;
	
КонецФункции

Функция ЗаполняемыйДокумент_ИспользуетсяНоменклатура(ТипДокумента,СтруктураНастроек) Экспорт
	
	ИспользуетсяНоменклатура = Истина;
	
	//Пока захардкожено для Платежного поручения, в дальнейшем можно расширить функционал
	//типом используемого справочника (Номенклатура, Основные средства)
	Если ТипДокумента = "ПлатежноеПоручение"
		Или ТипДокумента = "ПлатежноеПоручениеИсходящее"
		Или ТипДокумента = "ЗаявкаНаРасходованиеСредств"
		Или ТипДокумента = "ЗаявкаНаРасходованиеДенежныхСредств"
		Или ТипДокумента = "СписаниеБезналичныхДенежныхСредств"
		Или ТипДокумента = "ПоступлениеДопРасходов" //E1C-308
		Или ТипДокумента = "СчетФактураПолученный" Тогда //E1C-509
		ИспользуетсяНоменклатура = Ложь;
	КонецЕсли;
	
	Возврат ИспользуетсяНоменклатура;
	
КонецФункции

Функция ЗаполняемыйДокумент_ТребуетсяСозданиеНоменклатуры(ТипДокумента,СтруктураНастроек) Экспорт
	
	ТребуетсяСозданиеНоменклатуры = Истина;
	
	//Пока захардкожено для ПриобретениеУслугПрочихАктивов
	Если ТипДокумента = "ПриобретениеУслугПрочихАктивов" Тогда
		ТребуетсяСозданиеНоменклатуры = Ложь;
		
	ИначеЕсли ТипДокумента = "ПоступлениеУслугПоАренде" Тогда
		ТребуетсяСозданиеНоменклатуры = Ложь;
		
	//E1C-308: При заполнении основного документа ПоступлениеДопРасходов не создаем номенклатуру,
	//заполнение основного документа выполняется по выбранным пользователем документам поступления в форме сопоставления
	ИначеЕсли ТипДокумента = "ПоступлениеДопРасходов" Тогда
		ТребуетсяСозданиеНоменклатуры = Ложь;
		
	//добавлена Бухгалтерия для Казахстана
	ИначеЕсли ТипДокумента = "ПриходныйКассовыйОрдер" Тогда
		ТребуетсяСозданиеНоменклатуры = Ложь;
		
	КонецЕсли;
	
	Возврат ТребуетсяСозданиеНоменклатуры;
	
КонецФункции


