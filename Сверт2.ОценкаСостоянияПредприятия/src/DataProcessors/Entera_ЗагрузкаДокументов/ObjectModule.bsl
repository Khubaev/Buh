КонецФункции


// ================= Интеграция с ЭДО ===================

Функция Диадок_ИнициализироватьСоответствияСтатусов() Экспорт
	//Описание: Все статусы по типам документов, которые мы обрабатываем, кроме внутреннего документооборота.
	//ключ-перевода как type.status, где type - тип документа, то что лежит в поле externalSystemInfos.*.data.attachmentType (Invoice, XmlTorg12,  ...),
	//status - то что лежит в поле externalSystemInfos.*.data.status. Это избыточно, т.к. одинаковый status в разных типах документов
	//всё равно имеет один и тот же перевод, но type в случае чего сможет помочь в разрешении конфликтов,
	//когда один и тот же статус для разных типов будет иметь разный перевод.
	
	СоответствияСтатусов = Новый Соответствие;
	
	Макет = ПолучитьМакет("СтатусыДиадок");
	Область = Макет.ПолучитьОбласть("Статусы");
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		attachmentType = ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		status = ПолучитьТекстЯчейкиОбласти(Область,Сч,2);
		Описание = ПолучитьТекстЯчейкиОбласти(Область,Сч,3);
		
		Если attachmentType = "" Тогда
			Продолжить;
		КонецЕсли;
		
		СоответствиеТип = СоответствияСтатусов.Получить(attachmentType);
		Если СоответствиеТип = Неопределено Тогда
			СоответствиеТип = Новый Соответствие;
		КонецЕсли;
		
		СоответствиеТип.Вставить(status,Описание);
		СоответствияСтатусов.Вставить(attachmentType,СоответствиеТип);
	КонецЦикла;
	
	Возврат СоответствияСтатусов;

КонецФункции

Функция Диадок_ПолучитьСтатусДокумента(СоответствияСтатусов,attachmentType,status)
	
	СоответствиеТип = СоответствияСтатусов.Получить(attachmentType);
	Если СоответствиеТип <> Неопределено Тогда
		Описание = СоответствиеТип.Получить(status);
	КонецЕсли;
	
	Возврат ?(Описание = Неопределено,"Неопределен",Описание);
	
КонецФункции


Функция СБИС_ИнициализироватьСоответствияСтатусов() Экспорт
	
	СоответствияСтатусов = Новый Соответствие;
	
	Макет = ПолучитьМакет("СтатусыСБИС");
	Область = Макет.ПолучитьОбласть("Статусы");
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		status = ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		Описание = ПолучитьТекстЯчейкиОбласти(Область,Сч,2);
		
		СоответствияСтатусов.Вставить(status,Описание);
	КонецЦикла;
	
	Возврат СоответствияСтатусов;
	
КонецФункции

Функция СБИС_ПолучитьСтатусДокумента(СоответствияСтатусов,status)
	Описание = СоответствияСтатусов.Получить(status);	
	Возврат ?(Описание = Неопределено,"Неопределен",Описание);
КонецФункции


// ================= Заполнение табличных частей ===================

Функция ЗаполнитьНаправленияСоздаваемыхДокументов(АдресХранилищаДанныхПортала,СтруктураНастроек) Экспорт
	
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		
	Для Каждого СтрокаДокумента Из СписокДокументов Цикл
		
		//Обрабатываются только строки документов, не задания распознавания
		Если СтрокаДокумента.recognitionTaskId <> "" Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеДокумента = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
		
		СтрокаДокумента.НаправлениеСоздаваемогоДокумента = ОпределитьНаправлениеСоздаваемогоДокумента(ДанныеДокумента,СтруктураНастроек);
		
	КонецЦикла;
	
КонецФункции

Функция ОпределитьНаправлениеСоздаваемогоДокумента(ДанныеДокумента,СтруктураНастроек) Экспорт
	
	Если СтруктураНастроек.СозданиеДокумента_Направление = "Входящий" Тогда
		Результат = "Входящий";
		
	ИначеЕсли СтруктураНастроек.СозданиеДокумента_Направление = "Исходящий" Тогда
		Результат = "Исходящий";
		
	ИначеЕсли СтруктураНастроек.СозданиеДокумента_Направление = "Автоопределение" Тогда
		
		//определяем по вхождению Плательщика или Поставщика в справочник Организации по ИНН
		Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.Организации_ИмяРеквизитаИНН) Тогда
				
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
			               |	""Входящий"" КАК Направление
			               |ИЗ
			               |	Справочник.Организации КАК Организации
			               |ГДЕ
			               |	НЕ Организации.ПометкаУдаления
			               |	И Организации.ИНН = &ИННПлательщика
			               |
			               |ОБЪЕДИНИТЬ ВСЕ
			               |
			               |ВЫБРАТЬ
			               |	""Исходящий""
			               |ИЗ
			               |	Справочник.Организации КАК Организации
			               |ГДЕ
			               |	НЕ Организации.ПометкаУдаления
			               |	И Организации.ИНН = &ИННПоставщика";
			
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"Организации.ИНН","Организации." + СтруктураНастроек.СведенияОКонфигурации.Организации_ИмяРеквизитаИНН);
			
			Если СтруктураНастроек.РегионПространства = "KAZ" Тогда
				Запрос.УстановитьПараметр("ИННПлательщика",ДанныеДокумента.customerTaxId);
				Запрос.УстановитьПараметр("ИННПоставщика",ДанныеДокумента.supplierTaxId);
			Иначе
				Запрос.УстановитьПараметр("ИННПлательщика",ДанныеДокумента.customerInn);
				Запрос.УстановитьПараметр("ИННПоставщика",ДанныеДокумента.supplierInn);
			КонецЕсли;
			
			Выгрузка = Запрос.Выполнить().Выгрузить();
			
			Если Выгрузка.Количество() = 1 Тогда
				Результат = Выгрузка[0].Направление;
				
			Иначе
				//E1C-49: Описание: для автоопределения направления на чеках оно не срабатывает т.к. не распознан покупатель, его в чеке нет,
				//нужно все-равно ставить направление входящий, исходящим при автоопределении делаем если только в качестве поставщика твоя организация
				Если ДанныеДокумента.type = "RECEIPT" Тогда
					Результат = "Входящий";
					
				Иначе			
					//Организация не найдена или обе компании присутствуют как организация в базе, отдаем направление на выбор пользователю
					Результат = Неопределено;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьЗагружаемыеДокументыНаДубли(АдресХранилищаДанныхПортала,СтруктураНастроек,ДопПараметры) Экспорт
	
	//Функция переехала в модуль объекта из модулей форм ОФ и УФ
	РезультатПроверки = Новый Структура("Успешно,ТекстОшибки",Истина);
	
	СтрокиДокументов = СписокДокументов.НайтиСтроки(Новый Структура("Пометка",Истина));
	ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
	
	Если ДанныеПортала = Неопределено Тогда
		РезультатПроверки.Успешно = Ложь;
		РезультатПроверки.ТекстОшибки = "С портала не были получены данные о документах, операция прервана";
		
		Возврат РезультатПроверки;
	КонецЕсли;
	
	СтруктураКолонок = Новый Структура("Пометка,ДокументИД,ДокументТип,ПредставлениеДокумента,НомерДокумента,ДатаДокумента,СуммаДокумента,КонтрагентСсылка,ДубликатСсылка");
	ТаблицаНайденныхДубликатов = ИнициализироватьТаблицуПоСтруктуреКолонок(СтруктураКолонок);
	
	//E1C-227: свой обработчик поиска ссылки на дубликат загружаемого документа
	ПараметрыМК = Новый Структура;
	ПараметрыМК.Вставить("СтрокиДокументов",СтрокиДокументов);
	ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
	ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
	ПараметрыМК.Вставить("ДопПараметры",ДопПараметры);
	ПараметрыМК.Вставить("ТаблицаНайденныхДубликатов",ТаблицаНайденныхДубликатов);
	ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
			
	МодульКастомизации_ОбработатьСобытие("Дубликаты_ПередЗаполнениемТаблицыДубликатов",ПараметрыМК);
	
	Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
	// ) E1C-227
	
		Для Каждого СтрокаДокумента Из СтрокиДокументов Цикл
			
			Если ДопПараметры.АвтоопределениеТипа = Истина Тогда
				Если СтрокаДокумента.ДокументТип = "OFFER" Тогда
					ИмяТипаДокумента = СтруктураНастроек.ТипДокумента_Счет;
					
				ИначеЕсли СтрокаДокумента.ДокументТип = "CERTIFICATE" Тогда
					ИмяТипаДокумента = СтруктураНастроек.ТипДокумента_Акт;
					
				Иначе
					ИмяТипаДокумента = СтруктураНастроек.ТипДокумента_Поступление;
					
				КонецЕсли;
				
			Иначе
				//Теперь у нас тип документа может быть выбран пользователем
				ИмяТипаДокумента = ДопПараметры.ТипСоздаваемогоДокумента;
			КонецЕсли;
			
			ДанныеДокументаПортала = ДанныеПортала.documents.Найти(СтрокаДокумента.ДокументИД,"id");
					
			//Самопроверка
			Если ДанныеДокументаПортала = Неопределено Тогда
				ДополнитьТекстОшибки(РезультатПроверки.ТекстОшибки,"- в данных портала не найдены данные шапки документа (" + СтрокаДокумента.ДокументИД + ")");
				Прервать;
			КонецЕсли;
			
			//E1C-513: Существующий документ может присутствовать в табличной части будучи созданным в текущем сеансе или связанным вручную
			Если ЗначениеЗаполнено(ДанныеДокументаПортала.ДокументСсылка) Тогда
				СуществующийДокумент = ДанныеДокументаПортала.ДокументСсылка;
			ИначеЕсли ЗначениеЗаполнено(СтрокаДокумента.Документ1с) Тогда
				СуществующийДокумент = СтрокаДокумента.Документ1с;
			Иначе
				СуществующийДокумент = Неопределено;
			КонецЕсли;
			
			//E1C-227: свой обработчик поиска ссылки на дубликат загружаемого документа
			ПараметрыМК = Новый Структура;
			ПараметрыМК.Вставить("ДокументИД",СтрокаДокумента.ДокументИД);
			ПараметрыМК.Вставить("ИмяТипаДокумента",ИмяТипаДокумента);
			ПараметрыМК.Вставить("ДанныеПортала",ДанныеПортала);
			ПараметрыМК.Вставить("ДанныеДокументаПортала",ДанныеДокументаПортала);
			ПараметрыМК.Вставить("СуществующийДокумент",СуществующийДокумент);
			ПараметрыМК.Вставить("СтруктураНастроек",СтруктураНастроек);
			ПараметрыМК.Вставить("ДубликатСсылка",Неопределено);
			ПараметрыМК.Вставить("СтандартнаяОбработка",Истина);
					
			МодульКастомизации_ОбработатьСобытие("Дубликаты_УстановкаСсылки",ПараметрыМК);
					
			Если ЗначениеЗаполнено(ПараметрыМК.ДубликатСсылка) Тогда
				ДобавитьСтрокуВТаблицуДубликатов(ТаблицаНайденныхДубликатов,ДанныеДокументаПортала,ПараметрыМК.ДубликатСсылка,ДанныеДокументаПортала);
			КонецЕсли;
			
			Если ПараметрыМК.СтандартнаяОбработка = Истина Тогда
			// ) E1C-227
			
				Если СтрокаДокумента.НаправлениеСоздаваемогоДокумента = "Входящий" Тогда
					//входящие документы предполагают наличие реквизитов Номер/Дата входящего документа, выполняем контроль по ним и контрагенту
					
					//Ссылка на поставщика еще может быть не заполнена
					Если Не ЗначениеЗаполнено(ДанныеДокументаПортала.ПоставщикСсылка) Тогда
						ПоляПоискаПоставщик = Новый Структура("ИНН,КПП,ИдентификационныйКодЛичности,Наименование,НаименованиеПолное",ДанныеДокументаПортала.supplierInn,ДанныеДокументаПортала.supplierKpp,ДанныеДокументаПортала.supplierTaxId,ДанныеДокументаПортала.supplierShortName,ДанныеДокументаПортала.supplierName);
						ДанныеДокументаПортала.ПоставщикСсылка = ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП("Контрагенты",ПоляПоискаПоставщик,СтруктураНастроек);
					КонецЕсли;
					
					//Ссылка на плательщика еще может быть не заполнена
					Если Не ЗначениеЗаполнено(ДанныеДокументаПортала.ПлательщикСсылка) Тогда
						Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию) Тогда
							ДанныеДокументаПортала.ПлательщикСсылка = СтруктураНастроек.ЗаполнениеШапки_ОрганизацияПоУмолчанию;
						Иначе
							ПоляПоискаПлательщик = Новый Структура("ИНН,КПП,ИдентификационныйКодЛичности,Наименование,НаименованиеПолное",ДанныеДокументаПортала.customerInn,ДанныеДокументаПортала.customerKpp,ДанныеДокументаПортала.customerTaxId,ДанныеДокументаПортала.customerShortName,ДанныеДокументаПортала.customerName);
							ДанныеДокументаПортала.ПлательщикСсылка = ПолучитьСсылку_КонтрагентОрганизацияПоИННКПП(СтруктураНастроек.СведенияОКонфигурации.Организации_ИмяСправочника,ПоляПоискаПлательщик,СтруктураНастроек);
						КонецЕсли;
					КонецЕсли;
					
					//Обрабатываем логику связанных комплектов документов
					Если СтруктураНастроек.Свойство("СозданиеДокумента_ИспользоватьПоискКомплектов")
						И СтруктураНастроек.СозданиеДокумента_ИспользоватьПоискКомплектов = Истина Тогда
						
						//Счета-фактуры ищем среди счетов-фактур, их основания - по выбранному типу
						Если СтрокаДокумента.ДокументТип = "VAT_INVOICE" Тогда
							Если ЗначениеЗаполнено(СтруктураНастроек.СведенияОКонфигурации.СчетФактураПолученный) Тогда
													
								ПараметрыПоиска = Новый Структура;
								ПараметрыПоиска.Вставить("Номер",ДанныеДокументаПортала.number);
								ПараметрыПоиска.Вставить("Дата",ДанныеДокументаПортала.date);
								
								//E1C-507: Номер, Дата, Сумма документа
								Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Номер, Дата, Сумма документа" Тогда 
									ПараметрыПоиска.Вставить("Сумма",ДанныеДокументаПортала.amount);
								Иначе
									ПараметрыПоиска.Вставить("Контрагент",ДанныеДокументаПортала.ПоставщикСсылка);
								КонецЕсли;
								
								Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Контрагент, Номер, Дата, Сумма документа" Тогда 
									ПараметрыПоиска.Вставить("Сумма",ДанныеДокументаПортала.amount);
								КонецЕсли;
								
								Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Плательщик, Контрагент, Номер, Дата документа" Тогда 
									ПараметрыПоиска.Вставить("Организация",ДанныеДокументаПортала.ПлательщикСсылка);
								КонецЕсли;
								
								ДубликатСсылка = ПолучитьСсылку_ДокументПоПараметрамВходящегоДокумента(СтруктураНастроек.СведенияОКонфигурации.СчетФактураПолученный,ПараметрыПоиска,СуществующийДокумент);
								
								Если ЗначениеЗаполнено(ДубликатСсылка) Тогда
									ДобавитьСтрокуВТаблицуДубликатов(ТаблицаНайденныхДубликатов,ДанныеДокументаПортала,ДубликатСсылка,ДанныеДокументаПортала);
								КонецЕсли;
								
								//Если у текущего документа есть parent, то используем для поиска его номер и дату
								Если ЗначениеЗаполнено(ДанныеДокументаПортала.parent) Тогда
									СвязанныйДокумент = ДанныеПортала.documents.Найти(ДанныеДокументаПортала.parent,"id");
								
									Если СвязанныйДокумент <> Неопределено Тогда
																	
										ПараметрыПоиска = Новый Структура;
										ПараметрыПоиска.Вставить("Номер",СвязанныйДокумент.number);
										ПараметрыПоиска.Вставить("Дата",СвязанныйДокумент.date);
										
										//E1C-507: Номер, Дата, Сумма документа
										Если СтруктураНастроек.СозданиеДокумента_КонтрольДубликатовДокументов = "Номер, Дата, Сумма документа" Тогда 
											ПараметрыПоиска.Вставить("Сумма",ДанныеДокументаПортала.amount);
										Иначе
											ПараметрыПоиска.Вставить("Контрагент",ДанныеДокументаПортала.ПоставщикСсылка);
