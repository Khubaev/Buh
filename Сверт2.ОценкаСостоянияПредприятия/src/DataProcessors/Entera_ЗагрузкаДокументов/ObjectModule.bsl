				НоваяСтрока.Номенклатура_СчетУчетаЗапасов = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюТовар;
				НоваяСтрока.Номенклатура_СчетУчетаЗатрат = СтруктураНастроек.ЗаполнениеТЧ_СчетУчетаПоУмолчаниюУслуга;
			КонецЕсли;
						
		КонецЕсли;		
		
		//Служебные поля
		НоваяСтрока.Номенклатура_serialNumber = СтрокаНоменклатуры.serialNumber;
		НоваяСтрока.Номенклатура_goodCodeIsNull = СтрокаНоменклатуры.goodCodeIsNull;
		НоваяСтрока.Номенклатура_ТребуетсяСозданиеНоменклатуры = ПараметрыДополнения.ТребуетсяСозданиеНоменклатуры;
		
		//Данные для отображения/изменения пользователем
		НоваяСтрока.Номенклатура_Код = СтрокаНоменклатуры.recognizedGoodCode;
		
		НоваяСтрока.ДополнительноеОписание_СписокВыбора = СтруктураНастроек.Номенклатура_ТипНоменклатурыТоварУслуга_СписокВыбора;		
		НоваяСтрока.Номенклатура_ЕдиницаИзмерения = СтрокаНоменклатуры.ЕдиницаИзмеренияСсылка;
		НоваяСтрока.Номенклатура_ЕдиницаИзмеренияПредставление = СтрокаНоменклатуры.userUnitName;
		НоваяСтрока.Номенклатура_КоэффициентПересчета = 1;
		НоваяСтрока.Номенклатура_Количество = СтрокаНоменклатуры.quantity;
		НоваяСтрока.Номенклатура_Характеристика = СтрокаНоменклатуры.ХарактеристикаСсылка;
		НоваяСтрока.Номенклатура_НоменклатураПоставщика = СтрокаНоменклатуры.НоменклатураПоставщикаСсылка;
		НоваяСтрока.Номенклатура_ПодразделениеЗатрат = СтруктураНастроек.ЗаполнениеШапки_ПодразделениеОрганизацииПоУмолчанию;
		
		Если Не ЗначениеЗаполнено(НоваяСтрока.Номенклатура_СтатьяЗатрат) Тогда
			НоваяСтрока.Номенклатура_СтатьяЗатрат = СтрокаНоменклатуры.СтатьяЗатратСсылка;
		КонецЕсли;
		
		//БГУ
		Если СтруктураНастроек.СведенияОКонфигурации.Конфигурация.Крат = "БГУ2" Тогда
			Если РеквизитСуществует("Справочники","КлассификационныеПризнакиСчетов") Тогда
				НоваяСтрока.Номенклатура_КПС = Справочники.КлассификационныеПризнакиСчетов.ПустаяСсылка();
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","КВД") Тогда
				НоваяСтрока.Номенклатура_КФО = Перечисления.КВД.ПустаяСсылка();
