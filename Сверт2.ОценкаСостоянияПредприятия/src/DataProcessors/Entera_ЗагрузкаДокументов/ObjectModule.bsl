			НоваяСтрока.ОсновныеСредства_КодПоОКОФ = НоваяСтрока.Объект1с.КодПоОКОФ;
			НоваяСтрока.ОсновныеСредства_НаименованиеПолное = НоваяСтрока.Объект1с.НаименованиеПолное;
			
