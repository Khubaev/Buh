Функция ПолучитьДанныеИзОбщегоХранилища(КлючНастроек) Экспорт
	
	Попытка
		//Доступ к настройкам "виртуального пользователя" Entera предполагает наличие у пользователя права АдминистрированиеДанных (устанавливается в правах роли в корне конфигурации)
		СохраненныеДанные = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов",КлючНастроек,,"Entera");
	Исключение
		//при отсутствии этого права созданные пользователем таблицы хранятся для него индивидуально и недоступны другим пользователям
		СохраненныеДанные = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов",КлючНастроек);
	КонецПопытки;
	
	Возврат СохраненныеДанные;
	
КонецФункции

Функция ЗаписатьДанныеВОбщееХранилище(КлючНастроек,Данные) Экспорт
	
	Попытка
		//Доступ к настройкам "виртуального пользователя" Entera предполагает наличие у пользователя права АдминистрированиеДанных (устанавливается в правах роли в корне конфигурации)
		ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов",КлючНастроек,Данные,,"Entera");
	Исключение
		//при отсутствии этого права созданные пользователем таблицы хранятся для него индивидуально и недоступны другим пользователям
		ХранилищеОбщихНастроек.Сохранить("Entera_ЗагрузкаДокументов",КлючНастроек,Данные);
	КонецПопытки;
	
КонецФункции

Функция ДекодироватьСтрокуURL(URL, WindowsFileURI = Истина) Экспорт
	
	//При работе со старыми версиями платформы методы КодироватьСтроку и РаскодироватьСтроку могут быть недоступны,
	//используем программный алгоритм раскодирования имени файла из ContentDisposition: https://infostart.ru/public/101004/
    ДлинаСтроки = СтрДлина(URL);
    Инд = 1;
    Результат = "";
    ПолныйКод = 0;
    ОсталосьСимволов = 0;

    Пока Инд <= ДлинаСтроки Цикл

        Код = КодСимвола(URL, Инд);

        Если Код = 37 Тогда
            // Символ(37) = "%"
            Код = Из16ВЧисло(Сред(URL, Инд+1, 2));
            Инд = Инд + 2;
        ИначеЕсли ОсталосьСимволов = 0 Тогда
            Если (Код = 43) и (не WindowsFileURI) Тогда
                // Символ(43) = "+"
                Код = 32; // Символ(32) = " " (пробел)
            КонецЕсли;
            Результат = Результат + Символ(Код);
            Инд = Инд + 1;
            Продолжить;
        КонецЕсли;

        Если Код <= 127 Тогда
            // Код = 0b0ххххххх
            Результат = Результат + Символ(Код);
        ИначеЕсли Код <= 191 Тогда
            // Код = 0b10хххххх
            ПолныйКод = (ПолныйКод*64) + (Код%64); // shl(ПолныйКод, 6) + (Код & 0x3F)
            ОсталосьСимволов = ОсталосьСимволов - 1;
            Если ОсталосьСимволов = 0 Тогда
                Результат = Результат + Символ(ПолныйКод);
            КонецЕсли;
        ИначеЕсли Код <= 223 Тогда
            // Код = 0b110ххххх
            ПолныйКод = Код % 32; // Код & 0x1F
            ОсталосьСимволов = 1;
        ИначеЕсли Код <= 239 Тогда
            // Код = 0b1110хххх
            ПолныйКод = Код % 16; // Код & 0x0F
            ОсталосьСимволов = 2;
        ИначеЕсли Код <= 247 Тогда
            // Код = 0b11110ххх
            ПолныйКод = Код % 8; // Код & 0x07
            ОсталосьСимволов = 3;
        ИначеЕсли Код <= 251 Тогда
            // Код = 0b111110хх
            ПолныйКод = Код % 4; // Код & 0x03
            ОсталосьСимволов = 4;
        ИначеЕсли Код <= 253 Тогда
            // Код = 0b1111110х
            ПолныйКод = Код % 2; // Код & 0x01
            ОсталосьСимволов = 5;
        КонецЕсли;

        Инд = Инд + 1;
    КонецЦикла;

    Возврат Результат;
	
КонецФункции

Функция Из16ВЧисло(Знач Значение)

    Результат = 0;
    Множитель = 1;
    Пока Значение <> "" Цикл
        Результат = Результат + Множитель * (Найти("0123456789ABCDEF", Прав(Значение,1))-1);
        Множитель = Множитель * 16;
        Значение = Лев(Значение,СтрДлина(Значение)-1);
    КонецЦикла;
    Возврат Результат;

КонецФункции


Процедура ДополнитьТекстОшибки(ОбщийТекстОшибки,ТекстОшибки) Экспорт
	ОбщийТекстОшибки = Строка(ОбщийТекстОшибки) + ТекстОшибки + Символы.ПС;
КонецПроцедуры

Процедура ЗаписатьСобытие(Событие,ТекстОшибки,Объект = Неопределено,Уровень = Неопределено,ВыводитьСообщение = Ложь)
	
	Если Уровень = Неопределено Тогда
		Уровень = УровеньЖурналаРегистрации.Информация;
	КонецЕсли;
		
	ЗаписьЖурналаРегистрации(Событие,Уровень,Объект,,ТекстОшибки);
	
	Если ВыводитьСообщение Тогда
		СообщитьСообщение(?(ЗначениеЗаполнено(Объект),"<" + Объект + "> ","") + ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьСобытиеВПротокол(СтруктураНастроек,Уровень,Событие,Описание,Состояние) Экспорт
	
	Если СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Нет" Тогда
		Возврат;
		
		//Уровень значимости события
		//2 - Ошибки
		//1 - Ошибки+Запросы
		//0 - Полный		
		
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Ошибки" Тогда
		ФиксируемыйУровень = 2;
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Ошибки+Запросы" Тогда
		ФиксируемыйУровень = 1;
	ИначеЕсли СтруктураНастроек.СистемныеНастройки_ВестиПротоколРаботы = "Полный" Тогда
		ФиксируемыйУровень = 0;
	Иначе
		//такого не бывает, но если вдруг бывает - выходим
		Возврат;
	КонецЕсли;
	
	Если ФиксируемыйУровень <= Уровень Тогда
			
		НоваяСтрока = ПротоколРаботы.Добавить();
		НоваяСтрока.Дата = ТекущаяДата();
		НоваяСтрока.Событие = Событие;
		НоваяСтрока.Описание = Описание;
		НоваяСтрока.Состояние = Состояние;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СообщитьСообщение(Текст,Поле = Неопределено,ИдентификаторНазначения = Неопределено) Экспорт
	
	СообщениеПользователю = Новый СообщениеПользователю;
	СообщениеПользователю.Текст = Текст;
	СообщениеПользователю.Поле = Поле;
	
	Если ТипЗнч(ИдентификаторНазначения) = Тип("УникальныйИдентификатор") Тогда
		СообщениеПользователю.ИдентификаторНазначения = ИдентификаторНазначения;
	КонецЕсли;
	
	СообщениеПользователю.Сообщить();
	
КонецПроцедуры

Функция СформироватьПредставлениеРазмераФайла(РазмерДанных) Экспорт
	
	Результат = "";
	
	Если РазмерДанных > 1048576 Тогда
		Результат = "" + Окр(РазмерДанных/1048576,1) + "МБ";
	ИначеЕсли РазмерДанных > 1024 Тогда
		Результат = "" + Окр(РазмерДанных/1024,1) + "КБ";
	ИначеЕсли РазмерДанных = 0 Тогда
		Результат = "0Б";
	Иначе
		Результат = Строка(РазмерДанных) + "Б";
	КонецЕсли;			
	
	Возврат Результат;
	
КонецФункции

