				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийАвансовыйОтчет.Командировка);
			КонецЕсли;
		// ) 2024.03.11
		
		ИначеЕсли ТипДокумента.Значение = "ПриобретениеТоваровУслуг" Тогда			
			Если РеквизитСуществует("Перечисления","ХозяйственныеОперации","ЗакупкаЧерезПодотчетноеЛицо") Тогда
				ДоступныеВиды.Добавить(Перечисления.ХозяйственныеОперации.ЗакупкаЧерезПодотчетноеЛицо);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ХозяйственныеОперации","ЗакупкаУПоставщика") Тогда
				ДоступныеВиды.Добавить(Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика);
			КонецЕсли;
			
		//2025.08.22 ( 
		ИначеЕсли ТипДокумента.Значение = "РеализацияТоваровУслуг" Тогда			
			Если РеквизитСуществует("Перечисления","ВидыОперацийРеализацияТоваров","Товары") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийРеализацияТоваров.Товары);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийРеализацияТоваров","Услуги") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийРеализацияТоваров.Услуги);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийРеализацияТоваров","ПередачаТоваров") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийРеализацияТоваров.ПередачаТоваров);
			КонецЕсли;
		// ) 2025.08.22
		
		//2025.05.12 (
		ИначеЕсли ТипДокумента.Значение = "ОтчетКомиссионераОПродажах" Тогда			
			Если РеквизитСуществует("Перечисления","ВидыОперацийОтчетКомиссионера","ОтчетОПродажах") Тогда
				ДоступныеВиды.Добавить(Перечисления.ВидыОперацийОтчетКомиссионера.ОтчетОПродажах);
			КонецЕсли;
			
			Если РеквизитСуществует("Перечисления","ВидыОперацийОтчетКомиссионера","ОтчетОРозничныхПродажах") Тогда
