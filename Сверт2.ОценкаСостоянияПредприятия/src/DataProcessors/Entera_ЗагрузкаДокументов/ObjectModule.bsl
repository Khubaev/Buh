		МассивВременныхФайлов.Добавить(ИмяФайлаОтправки);

		ЗаголовкиHTTP.Вставить("Content-Type", "multipart/form-data; boundary=" + Boundary); 
		
		Запрос = Новый HTTPЗапрос(МетодAPI,ЗаголовкиHTTP);
		Запрос.УстановитьИмяФайлаТела(ИмяФайлаОтправки);
		
		ОписаниеЗапроса = ТипЗапроса + " " + МетодAPI + " " + СтрокаИменОтправляемыхФайлов;
		ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Запрос",ОписаниеЗапроса,"Запрос");
		
		Попытка
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
			Успешно = Истина;
		Исключение
			ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
			
