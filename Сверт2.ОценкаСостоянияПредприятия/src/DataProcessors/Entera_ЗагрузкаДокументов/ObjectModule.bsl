Функция ЗаполнениеДокумента_ПолучитьПараметрыДляПодстановки(ДанныеДокумента,ДанныеНоменклатуры = Неопределено)
	
	СоответствиеПараметров = Новый Соответствие;
		
	Если ЗначениеЗаполнено(ДанныеДокумента.vat) Тогда
		ТекстНДС = "В т.ч. НДС " + ?(ЗначениеЗаполнено(ДанныеДокумента.СтавкаНДССсылка),"(" + ДанныеДокумента.СтавкаНДССсылка + ") "," ")
			+ Формат(ДанныеДокумента.vat, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ=");
	Иначе
		ТекстНДС = "Без налога (НДС)";
	КонецЕсли;
	
	//Значения шапки документа
	СоответствиеПараметров.Вставить("%ТекущаяДата%",Формат(ТекущаяДата(),"ДФ=dd.MM.yyyy"));
	СоответствиеПараметров.Вставить("%НомерДокумента%",ДанныеДокумента.number);
	СоответствиеПараметров.Вставить("%ДатаДокумента%",Формат(ДанныеДокумента.date,"ДФ=dd.MM.yyyy"));
	СоответствиеПараметров.Вставить("%ИдентификаторДокумента%",ДанныеДокумента.id);
		
	СоответствиеПараметров.Вставить("%Сумма%",Формат(ДанныеДокумента.amount, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ="));
	СоответствиеПараметров.Вставить("%ТекстНДС%",ТекстНДС);	
	
	
	//Значения, зависящие от табличной части документа
	ТоварыТЗ = Новый ТаблицаЗначений;
	ТоварыТЗ.Колонки.Добавить("Наименование");
	ТоварыТЗ.Колонки.Добавить("Количество",Новый ОписаниеТипов("Число"));
	ТоварыТЗ.Колонки.Добавить("Сумма",Новый ОписаниеТипов("Число"));
	
	Если ДанныеНоменклатуры <> Неопределено Тогда
		Для каждого СтрокаНоменклатуры Из ДанныеНоменклатуры Цикл
			СтрокаТовары = ТоварыТЗ.Добавить();
			СтрокаТовары.Наименование = СтрокаНоменклатуры.name;
			СтрокаТовары.Количество = СтрокаНоменклатуры.quantity;			
			СтрокаТовары.Сумма = СтрокаНоменклатуры.amount;
		КонецЦикла;
	КонецЕсли;
	
	ПерваяПозиция = ?(ТоварыТЗ.Количество() > 0, ТоварыТЗ[0].Наименование, "");
	
	ТоварыПоУбываниюСтрокой = "";
	СамаяДорогаяПозиция = "";
	
	//Самая дорогая позиция, товары по убыванию суммы
	Если ТоварыТЗ.Количество() > 0 Тогда
		ТоварыТЗКопия = ТоварыТЗ.Скопировать();
		ТоварыТЗКопия.Свернуть("Наименование","Сумма");	
		ТоварыТЗКопия.Сортировать("Сумма УБЫВ");
		
		СамаяДорогаяПозиция = ТоварыТЗКопия[0].Наименование;
		
		ПервыйЭлемент = Истина;
	
		Для Каждого СтрокаТаблицы Из ТоварыТЗКопия Цикл
			Если ПервыйЭлемент Тогда
				ПервыйЭлемент = Ложь;  
				ТоварыПоУбываниюСтрокой = ТоварыПоУбываниюСтрокой + СтрокаТаблицы.Наименование;
			Иначе
				ТоварыПоУбываниюСтрокой = ТоварыПоУбываниюСтрокой + "," + СтрокаТаблицы.Наименование;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//Все товары строкой
	ТоварыТЗКопия = ТоварыТЗ.Скопировать();
	ТоварыТЗКопия.Свернуть("Наименование");	
	
	ТоварыСтрокой = "";
	
	ПервыйЭлемент = Истина;
	
	Для Каждого СтрокаТаблицы Из ТоварыТЗКопия Цикл
		Если ПервыйЭлемент Тогда
			ПервыйЭлемент = Ложь;
			ТоварыСтрокой = ТоварыСтрокой + СтрокаТаблицы.Наименование;
		Иначе
			ТоварыСтрокой = ТоварыСтрокой + "," + СтрокаТаблицы.Наименование;
		КонецЕсли;
	КонецЦикла;
	
	СоответствиеПараметров.Вставить("%СамаяДорогаяПозиция%",СамаяДорогаяПозиция);
	СоответствиеПараметров.Вставить("%ПерваяПозиция%",ПерваяПозиция);
	СоответствиеПараметров.Вставить("%Товары%",ТоварыСтрокой);
	СоответствиеПараметров.Вставить("%ПоУбываниюТовары%",ТоварыПоУбываниюСтрокой);
	
	СоответствиеПараметров.Вставить("%ТипДокумента%",ДанныеДокумента.type);
	СоответствиеПараметров.Вставить("%ИмяТипаДокумента%",ДанныеДокумента.ПредставлениеТипа);
	
	Возврат СоответствиеПараметров;
	
КонецФункции       


Функция ЗаполнениеДокумента_СформироватьКомментарийСПараметрами(АдресХранилищаДанныхПортала,СтруктураЗаполненияДокумента,СтруктураНастроек) Экспорт
	
	//Исходный комментарий, заданный пользователем
	Комментарий = СтруктураНастроек.ЗаполнениеШапки_КомментарийСозданногоДокумента;
	
	ДанныеДокумента = СтруктураЗаполненияДокумента.document;
	ДанныеНоменклатуры = СтруктураЗаполненияДокумента.documentItems;
	
	ДокументИД = ДанныеДокумента.id;
	
	// %fileName%
	Если Найти(Комментарий,"%fileName%") > 0 Тогда
		
		//Получаем имя файла из таблицы documentPages
		ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		СтрокаДокумента = ДанныеПортала.documentPages.Найти(ДокументИД,"documentId");
		
		Если СтрокаДокумента <> Неопределено Тогда
			//Заменяем "служебный" параметр %fileName% на имя файла скана
			Комментарий = СтрЗаменить(Комментарий,"%fileName%",СтрокаДокумента.fileName);
		КонецЕсли;
	КонецЕсли;
	
	// %source%
	Если Найти(Комментарий,"%source%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%source%",СтруктураЗаполненияДокумента.document.ИсточникДокумента);
	КонецЕсли;
	
	// %currentDate%
	Если Найти(Комментарий,"%currentDate%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%currentDate%",Формат(ТекущаяДата(),"ДФ=dd.MM.yyyy"));
	КонецЕсли;
	
	// %documentNumber%
	Если Найти(Комментарий,"%documentNumber%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentNumber%",ДанныеДокумента.number);
	КонецЕсли;
	
	// %documentDate%
	Если Найти(Комментарий,"%documentDate%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentDate%",Формат(ДанныеДокумента.date,"ДФ=dd.MM.yyyy"));
	КонецЕсли;
	
	// %comment%
	Если Найти(Комментарий,"%comment%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%comment%",ДанныеДокумента.comment);
	КонецЕсли;
	
	//%documentCreator%
	Если Найти(Комментарий,"%documentCreator%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentCreator%",ДанныеДокумента.documentCreator);
	КонецЕсли;
	
	// %items%
	Если Найти(Комментарий,"%items%") > 0 Тогда
		Значение = "";
		Для Каждого СтрокаТоваров Из СтруктураЗаполненияДокумента.documentItems Цикл
			Значение = Значение + ?(ЗначениеЗаполнено(Значение),"; ","") + СтрокаТоваров.name;
		КонецЦикла;
		Комментарий = СтрЗаменить(Комментарий,"%items%",Значение);
	КонецЕсли;
	
	// %item0%
	Если Найти(Комментарий,"%item0%") > 0 Тогда
		Значение = "";
		Если СтруктураЗаполненияДокумента.documentItems.Количество() > 0 Тогда
			Значение = СтруктураЗаполненияДокумента.documentItems[0].name;
		КонецЕсли;
		Комментарий = СтрЗаменить(Комментарий,"%item0%",Значение);
	КонецЕсли;
	
	// %documentType%
	Если Найти(Комментарий,"%documentType%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentType%",ДанныеДокумента.type);
	КонецЕсли;
	
	// %documentTypeRussian%
	Если Найти(Комментарий,"%documentTypeRussian%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentTypeRussian%",ДанныеДокумента.ПредставлениеТипа);
	КонецЕсли;
	
	// %documentTypeCode%
	Если Найти(Комментарий,"%documentTypeCode%") > 0 Тогда
		Комментарий = СтрЗаменить(Комментарий,"%documentTypeCode%",ДанныеДокумента.КодТипаДокумента);
	КонецЕсли;
	
	//Номер договора
	Если Найти(Комментарий,"%НомерДоговора%") > 0 Тогда
		Значение = "";
		Если ЗначениеЗаполнено(ДанныеДокумента.ДоговорСсылка) Тогда
			Если ДанныеДокумента.ДоговорСсылка.Метаданные().Реквизиты.Найти("Номер") <> Неопределено Тогда
				Значение = ДанныеДокумента.ДоговорСсылка.Номер;
			КонецЕсли;
		КонецЕсли;
		Комментарий = СтрЗаменить(Комментарий,"%НомерДоговора%",Значение);
	КонецЕсли;
	
	Возврат Комментарий;
	
КонецФункции

Функция ЗаполнениеДокумента_ПлатежноеПоручение_СформироватьНазначениеПлатежа(СтруктураНастроек,СтруктураЗаполненияДокумента) Экспорт
	
	Если ЗначениеЗаполнено(СтруктураНастроек.ЗаполнениеШапки_ШаблонНазначенияПлатежа) Тогда
		
		СоответствиеПараметров = ЗаполнениеДокумента_ПолучитьПараметрыДляПодстановки(СтруктураЗаполненияДокумента.document,СтруктураЗаполненияДокумента.documentItems);
		
		НазначениеПлатежа = СтруктураНастроек.ЗаполнениеШапки_ШаблонНазначенияПлатежа; 
		
		МассивОбязательныхПарметров = Новый Массив;
		МассивОбязательныхПарметров.Добавить("%НомерДокумента%");
		МассивОбязательныхПарметров.Добавить("%ДатаДокумента%");
		МассивОбязательныхПарметров.Добавить("%Сумма%");
		МассивОбязательныхПарметров.Добавить("%ТекстНДС%");
		
		Для каждого ОбязательныйПараметр Из МассивОбязательныхПарметров Цикл 
			
			Если Найти(НазначениеПлатежа, ОбязательныйПараметр) > 0 Тогда 
				Значение = СоответствиеПараметров.Получить(ОбязательныйПараметр);
				НазначениеПлатежа = СтрЗаменить(НазначениеПлатежа,ОбязательныйПараметр,Значение);
	        КонецЕсли;
		КонецЦикла;	
		  
		КоличествоСимволовВШаблоне = СтрДлина(НазначениеПлатежа);
				
		Для каждого ЭлементСоответствия Из СоответствиеПараметров Цикл 
			
			//Проверяем кол-во символов кажого элемента соответствия. Режем значение превышающие длину свободных символов
			Если Найти(НазначениеПлатежа, ЭлементСоответствия.Ключ) > 0 Тогда  	
				
				//Вычисляем сколько свободных символов есть в строке
				ДоступноСимволов = 210 - КоличествоСимволовВШаблоне + СтрДлина(ЭлементСоответствия.Ключ);
				
				//Следует почистить недопустимые в назначении платежа символы: длинные тире и кавычки-ёлочки
				Значение = ЭлементСоответствия.Значение;
				Значение = СтрЗаменить(Значение,"«","");
				Значение = СтрЗаменить(Значение,"»","");
				Значение = СтрЗаменить(Значение,"—","");
				Значение = СокрЛП(Значение);
				
				//Вычисляем сколько символов в значении
				КоличествоСимволовВЗначении = СтрДлина(Значение);
								
				НовоеЗначение = Лев(Значение, ДоступноСимволов);
				НазначениеПлатежа = СтрЗаменить(НазначениеПлатежа,ЭлементСоответствия.Ключ,НовоеЗначение);
				
				КоличествоСимволовВШаблоне = СтрДлина(НазначениеПлатежа);
				
			КонецЕсли;
		КонецЦикла;
		
	Иначе
	
		ДанныеДокумента = СтруктураЗаполненияДокумента.document;
		
		ТекстНазначение = "Оплата по счету " + ДанныеДокумента.number + ?(ЗначениеЗаполнено(ДанныеДокумента.date)," от " + Формат(ДанныеДокумента.date,"ДФ=dd.MM.yyyy"),"");
		
		Попытка СуммаДокумента = Число(ДанныеДокумента.amount); Исключение; СуммаДокумента = ДанныеДокумента.amount; КонецПопытки;
		
		ТекстСумма = "Сумма " + Формат(СуммаДокумента, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ=");
		ТекСтавка = 0;
		
		Если СтруктураЗаполненияДокумента.documentItems.Количество() > 0 Тогда
			vatRate = СтруктураЗаполненияДокумента.documentItems[0].vatRate;
					
			Если vatRate = "PERCENT_22" Тогда
				ТекСтавка = 22;
			ИначеЕсли vatRate = "PERCENT_20" Тогда
				ТекСтавка = 20;
			ИначеЕсли vatRate = "PERCENT_18" Тогда
				ТекСтавка = 18;
			ИначеЕсли vatRate = "PERCENT_10" Тогда
				ТекСтавка = 10;
			ИначеЕсли vatRate = "PERCENT_12" Тогда
				ТекСтавка = 12;
			ИначеЕсли vatRate = "PERCENT_16" Тогда
				ТекСтавка = 16;
			ИначеЕсли vatRate = "PERCENT_5" Тогда
				ТекСтавка = 5;
			ИначеЕсли vatRate = "PERCENT_7" Тогда
				ТекСтавка = 7;
				
			//E1C-509: появились счета-фактуры на аванс
			ИначеЕсли vatRate = "PERCENT_18_118" Тогда
				ТекСтавка = 18;
			ИначеЕсли vatRate = "PERCENT_20_120" Тогда
				ТекСтавка = 20;
			ИначеЕсли vatRate = "PERCENT_22_122" Тогда
				ТекСтавка = 22;
			ИначеЕсли vatRate = "PERCENT_10_110" Тогда
				ТекСтавка = 10;
			ИначеЕсли vatRate = "PERCENT_7_107" Тогда
				ТекСтавка = 7;
			ИначеЕсли vatRate = "PERCENT_5_105" Тогда
				ТекСтавка = 5;
			КонецЕсли;
			
		КонецЕсли;
		
		Попытка СуммаНДС = Число(ДанныеДокумента.vat); Исключение СуммаНДС = 0; КонецПопытки;
		
		Если ТекСтавка = 0 Тогда
			ТекстНДС = "Без налога (НДС)";
		ИначеЕсли СуммаНДС > 0 Тогда
			ТекстНДС = "В т.ч. НДС "
			+ ?(ЗначениеЗаполнено(ТекСтавка), "(" + ТекСтавка + "%) ", "")
			+ Формат(СуммаНДС, "ЧЦ=15; ЧДЦ=2; ЧРД=-; ЧН=0-00; ЧГ=");
		Иначе
			ТекстНДС = "";
		КонецЕсли;
		
		ТекстСуммаНазначения = ТекстСумма + ?(ТекстСумма = "", "", Символы.ПС) + ТекстНДС;
			
		НазначениеПлатежа = ТекстНазначение + ?(ПустаяСтрока(ТекстСуммаНазначения), "", Символы.ПС + ТекстСуммаНазначения);
		
	КонецЕсли;
	
	Возврат НазначениеПлатежа;
	
КонецФункции

Функция ЗаполнениеДокумента_Договор_СформироватьПредставление(ДанныеДокументаПортала,СтруктураНастроек) Экспорт
	
	//Исходный шаблон, заданный пользователем
	ПредставлениеДоговора = СтруктураНастроек.ЗаполнениеШапки_НаименованиеНовогоДоговора;
	
	//E1C-516: снова нет, строка Распознанные данные формируется как %Name% №%Number% от %Date%.
	//Частицы "№" и "от" используются, если поля Number и Date - не пустые.
	ПредставлениеДоговора = "";
	
	Если ЗначениеЗаполненоXDTO(ДанныеДокументаПортала.transferBaseName) Тогда
		ПредставлениеДоговора = ДанныеДокументаПортала.transferBaseName;
	КонецЕсли;
	
	Если ЗначениеЗаполненоXDTO(ДанныеДокументаПортала.transferBaseNumber) Тогда
		ПредставлениеДоговора = ПредставлениеДоговора + " №" + ДанныеДокументаПортала.transferBaseNumber;
	КонецЕсли;
	
	Если ЗначениеЗаполненоXDTO(ДанныеДокументаПортала.transferBaseDate) Тогда
		ПредставлениеДоговора = ПредставлениеДоговора + " от " + Формат(ДанныеДокументаПортала.transferBaseDate,"ДФ=dd.MM.yyyy");
	КонецЕсли;
	
	Возврат ПредставлениеДоговора;
	
КонецФункции


Функция СформироватьИмяФайлаСканаПоШаблону(АдресХранилищаДанныхПортала,ДанныеПортала,ДокументИД,ИсходноеИмя,СтруктураНастроек) Экспорт
	
	//ИНН контрагента,
	//Тип документа,
	//Номер документа,
	//Дата документа,
	//Сумма по документу,
	//Наименование контрагента.
	//Если шаблон не задан - используется имя файла, полученное от портала.
	
	Если ЗначениеЗаполнено(СтруктураНастроек.СозданиеДокумента_ШаблонИмениФайлаСкана) Тогда
		
		ИмяФайла = СтруктураНастроек.СозданиеДокумента_ШаблонИмениФайлаСкана;
		
		//Определяем расширение исходного файла
		ЧастиИмениФайла = Энтера_РазложитьСтрокуВМассивПодстрок(ИсходноеИмя,".");
		Если ЧастиИмениФайла.Количество() > 1 Тогда
			РасширениеБезТочки = ЧастиИмениФайла[ЧастиИмениФайла.Количество() - 1];
		КонецЕсли;
		
		Если ДанныеПортала = Неопределено Тогда
			ДанныеПортала = ПолучитьИзВременногоХранилища(АдресХранилищаДанныхПортала);
		КонецЕсли;
		
		ДанныеДокумента = ДанныеПортала.documents.НайтиСтроки(Новый Структура("id",ДокументИД))[0];
		
		// %documentType%
		Если Найти(ИмяФайла,"%documentType%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentType%",ДанныеДокумента.type);
		КонецЕсли;
		
		// %documentTypeRussian%
		Если Найти(ИмяФайла,"%documentTypeRussian%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentTypeRussian%",ДанныеДокумента.ПредставлениеТипа);
		КонецЕсли;
		
		// %documentTypeCode%
		Если Найти(ИмяФайла,"%documentTypeCode%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentTypeCode%",ДанныеДокумента.КодТипаДокумента);
		КонецЕсли;
		
		// %documentNumber%
		Если Найти(ИмяФайла,"%documentNumber%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentNumber%",ДанныеДокумента.number);
		КонецЕсли;
		
		// %documentDate%
		Если Найти(ИмяФайла,"%documentDate%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentDate%",Формат(ДанныеДокумента.date,"ДФ=dd.MM.yyyy"));
		КонецЕсли;
		
		// %documentDateReflect%
		Если Найти(ИмяФайла,"%documentDateReflect%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentDateReflect%",Формат(ДанныеДокумента.date,"ДФ=yyyy.MM.dd"));
		КонецЕсли;
		
		// %documentAmount%
		Если Найти(ИмяФайла,"%documentAmount%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%documentAmount%",Формат(ДанныеДокумента.amount,"ЧДЦ=2; ЧРД=-; ЧРГ=; ЧГ=0"));
		КонецЕсли;
		
		// %customerInn%
		Если Найти(ИмяФайла,"%customerInn%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%customerInn%",ДанныеДокумента.customerInn);
		КонецЕсли;
		
		// %customerKpp%
		Если Найти(ИмяФайла,"%customerKpp%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%customerKpp%",ДанныеДокумента.customerKpp);
		КонецЕсли;
		
		// %customerName%
		Если Найти(ИмяФайла,"%customerName%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%customerName%",ДанныеДокумента.customerShortName);
		КонецЕсли;
		
		// %supplierInn%
		Если Найти(ИмяФайла,"%supplierInn%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%supplierInn%",ДанныеДокумента.supplierInn);
		КонецЕсли;
		
		// %supplierKpp%
		Если Найти(ИмяФайла,"%supplierKpp%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%supplierKpp%",ДанныеДокумента.supplierKpp);
		КонецЕсли;
		
		// %supplierName%
		Если Найти(ИмяФайла,"%supplierName%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%supplierName%",ДанныеДокумента.supplierShortName);
		КонецЕсли;
		
		// %currentDate%
		Если Найти(ИмяФайла,"%currentDate%") > 0 Тогда
			ИмяФайла = СтрЗаменить(ИмяФайла,"%currentDate%",Формат(ТекущаяДата(),"ДФ=dd.MM.yyyy"));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(РасширениеБезТочки) Тогда
			ИмяФайла = ИмяФайла + "." + РасширениеБезТочки;
		КонецЕсли;
		
		//Нужно почистить "запрещенные" символы, которые могут присутствовать в получившейся строке и вызывать ошибку
		//при открытии файла в пользовательском режиме: из того, что удалось поймать: кавычки, двоеточия
		ИмяФайла = СтрЗаменить(ИмяФайла,"""","_");
		ИмяФайла = СтрЗаменить(ИмяФайла,":","_");
		
	Иначе
		ИмяФайла = ИсходноеИмя;
		
	КонецЕсли;
	
	Возврат ИмяФайла;
	
КонецФункции


Функция СформироватьПредставлениеДокументаПортала(ДанныеДокументаПортала) Экспорт
	
	ПредставлениеДокумента = Строка(ДанныеДокументаПортала.ПредставлениеТипа)
		+ " №" + ДанныеДокументаПортала.number
		+ " от " + Формат(ДанныеДокументаПортала.date,"ДФ=dd.MM.yyyy");
		
	Возврат ПредставлениеДокумента;
	
КонецФункции


// ================= Модуль кастомизации ===================

Функция МодульКастомизации_ОбработатьСобытие(ИмяСобытия,ПараметрыОбработки) Экспорт
	
	РезультатОбработки = Новый Структура("Успешно,ТекстОшибки",Ложь);
	
	СтруктураНастроек = ПараметрыОбработки.СтруктураНастроек;
	
	//Комментарий для аудитора: Для Фреш не выполняется подключение дополнительной внешней обработки "Модуль кастомизации",
	//реквизит ЭтоФреш определяется в процедуре ПриСозданииНаСервере основной формы обработки УФ_ОсновнаяФорма,
	//после этого он передается в данную структуру настроек в форме настроек УФ_Настройки
	Если СтруктураНастроек.ЭтоФреш Тогда
		РезультатОбработки.Успешно = Истина;
		Возврат РезультатОбработки;
	КонецЕсли;
	
	//Список событий поиска ссылок на объекты
	//ПоискСсылок_ОпределениеНаправления
	//ПоискСсылок_ОпределениеПлательщикаПоставщика
	//ПоискСсылок_ОпределениеДоговора
	//ПоискСсылок_ОпределениеНоменклатуры
	//ПоискСсылок_ОпределениеЕдиницыИзмерения
	//ПоискСсылок_ОпределениеСтавкиНДС
	//ПоискСсылок_ОпределениеНомераГТД
	//ПоискСсылок_ОпределениеСтраныПроисхождения
	//ПоискСсылок_ПослеОбработкиВсехОбъектов
	
	//Дубликаты_ПередПрисоединениемФайлов
	//Дубликаты_УстановкаСсылки	
	
	//Список событий создания/заполнения документа:
	//Документ_ПередЗаполнениемШапки
	//Документ_ПослеЗаполненияШапки
	//Документ_ПередЗаполнениемСтрокиТЧ
	//Документ_ПослеЗаполненияСтрокиТЧ
	//Документ_ПередЗаписьюДокумента
	//Документ_ПередПрисоединениемФайлов
	//СчетФактура_ПередЗаполнениемШапки
	//СчетФактура_ПередЗаписьюДокумента
	//СчетФактура_ПередПрисоединениемФайлов
	//Документ_ПередЗаписьюПоступлениеДопРасходов
	//Документ_ПослеЗаписиПоступлениеДопРасходов
	
	//Список событий создания элементов справочников:
	//Сопоставление_ПередФормированиемНазначенияПлатежа
	//Сопоставление_ПослеДобавленияСтрокиТаблицыСопоставления
	//Сопоставление_ПередСозданиемОбъектов
	//Сопоставление_ПослеПереносаСтрокиДанныхДокумента
	//Сопоставление_Контрагент_ПередЗаписью
	//Сопоставление_Договор_ПередЗаписью
	//Сопоставление_Номенклатура_ПередЗаписью
	//Сопоставление_НоменклатураПоставщика_ПередЗаписью
	//Сопоставление_НомерГТД_ПередЗаписью
	//Сопоставление_СтранаМира_ПередЗаписью
	
	Если ЗначениеЗаполнено(СтруктураНастроек.АдресХранилищаДвоичныхДанныхМодуляКастомизации) Тогда
		
		ПолучениеМК = ЭтотОбъект._УФ_МодульКастомизации_Получить(СтруктураНастроек);
		Если ПолучениеМК.Успешно Тогда
			
			МодульКастомизации = ПолучениеМК.Обработка;
			
			ИдентификаторДокумента = ?(ПараметрыОбработки.Свойство("ДокументИД"),ПараметрыОбработки.ДокументИД,"Неопределено");
			
			ОписаниеОбработчика = ИмяСобытия + ": передача события для обработки в МК (documentId=" + ИдентификаторДокумента + ")";
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"ВыполнениеМК");
			
			//Для обратной совместимости со старыми модулями кастомизации, передаем АдресХранилищаПротоколаРаботы в параметрах
			АдресХранилищаПротоколаРаботы = ПоместитьВоВременноеХранилище(Инициализировать_ПротоколРаботы(),Новый УникальныйИдентификатор);
			ПараметрыОбработки.Вставить("АдресХранилищаПротоколаРаботы",АдресХранилищаПротоколаРаботы);
			
			//и структуре настроек
			СтруктураНастроек.Вставить("АдресХранилищаПротоколаРаботы",АдресХранилищаПротоколаРаботы);
			ПараметрыОбработки.Вставить("СтруктураНастроек",СтруктураНастроек);
			
			//новый вариант предполагает передачу данных для протокола в параметре ПротоколМК
			ПараметрыОбработки.Вставить("ПротоколМК","");
			
			//Для вызова функций и процедур основного модуля
			ПараметрыОбработки.Вставить("ОсновнойМодуль",ЭтотОбъект);
			
			Попытка
				МодульКастомизации.ОбработатьСобытиеОсновногоМодуля(ИмяСобытия,ПараметрыОбработки);
				РезультатОбработки.Успешно = Истина;
				
				//Поскольку протокол работы теперь у нас хранится в табличной части основного модуля,
				//запишем в протокол то, что нам отдал модуль кастомизации
				Если ПараметрыОбработки.Свойство("ПротоколМК") и ЗначениеЗаполнено(ПараметрыОбработки.ПротоколМК) Тогда
					ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль","МК: " + ПараметрыОбработки.ПротоколМК,"ВыполнениеМК");
				КонецЕсли;
				
			Исключение
				ТекстОшибки = КраткоеОписаниеОшибки(ОписаниеОшибки());
				РезультатОбработки.ТекстОшибки = ТекстОшибки;
				
				Если ПараметрыОбработки.Свойство("ТекстОшибки") Тогда
					ПараметрыОбработки.ТекстОшибки = ТекстОшибки;
				КонецЕсли;
				
				ОписаниеОбработчика = ИмяСобытия + ": при обработке события в МК (documentId=" + ИдентификаторДокумента + "): возникла ошибка" + Символы.ПС + ТекстОшибки;
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ОписаниеОбработчика,"Ошибка");
			КонецПопытки;
			
			//для обратной совместимости обработаем также переданную таблицу по адресу АдресХранилищаПротоколаРаботы
			Если ПараметрыОбработки.Свойство("АдресХранилищаПротоколаРаботы")
				И ЭтоАдресВременногоХранилища(ПараметрыОбработки.АдресХранилищаПротоколаРаботы) Тогда
				СтарыйПротокол = ПолучитьИзВременногоХранилища(ПараметрыОбработки.АдресХранилищаПротоколаРаботы);
				Если ТипЗнч(СтарыйПротокол) = Тип("ТаблицаЗначений") И СтарыйПротокол.Количество() > 0 Тогда
					Для Каждого СтрокаПротокола Из СтарыйПротокол Цикл
						ЗаполнитьЗначенияСвойств(ПротоколРаботы.Добавить(),СтрокаПротокола);
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;			
			
			//удалим из структуры параметров основной модуль
			ПараметрыОбработки.Удалить("ОсновнойМодуль");
		Иначе
			РезультатОбработки.ТекстОшибки = ПолучениеМК.ТекстОшибки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат РезультатОбработки;
	
КонецФункции


// ================= Вспомогательные функции ===================

Функция ПолучитьКоллекциюXDTO(ОбъектXDTO) Экспорт
	Если ТипЗнч(ОбъектXDTO) = Тип("ОбъектXDTO") Тогда
		Коллекция = Новый Массив;
		Если ОбъектXDTO.Свойства().Количество() > 0 Тогда
			Коллекция.Добавить(ОбъектXDTO);
		КонецЕсли;
	ИначеЕсли ТипЗнч(ОбъектXDTO) = Тип("СписокXDTO") Тогда
		Коллекция = ОбъектXDTO;
	Иначе
		
	КонецЕсли;
	
	Возврат Коллекция;
КонецФункции

Функция ЗначениеЗаполненоXDTO(Значение) Экспорт
	Если ТипЗнч(Значение) = Тип("ОбъектXDTO") Тогда
		Результат = Значение.Свойства().Количество() > 0;
	Иначе
		Результат = ЗначениеЗаполнено(Значение);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция СвойствоXDTOСуществует(ОбъектXDTO,ИмяСвойства) Экспорт
	Возврат ОбъектXDTO.Свойства().Получить(ИмяСвойства) <> Неопределено;
КонецФункции

Функция ПолучитьЗначениеПоляXDTO(ОбъектXDTO,ИмяСвойства,ЭтоЧисло = Ложь)
	
	Если СвойствоXDTOСуществует(ОбъектXDTO,ИмяСвойства)
		И ЗначениеЗаполненоXDTO(ОбъектXDTO[ИмяСвойства]) Тогда
		Значение = ОбъектXDTO[ИмяСвойства];
	КонецЕсли;
	
	//Добавим приведение к типу число
	Если ЭтоЧисло Тогда
		Если Значение = Неопределено Тогда
			Значение = 0;
		Иначе
			Попытка
				Значение = Число(Значение);
			Исключение
				Значение = 0;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция ПолучитьДатуИзДатыПортала(ДатаПортала,ЭтоМоментВремени = Ложь) Экспорт
	
	Результат = Дата(1,1,1);
	
	Если ЗначениеЗаполненоXDTO(ДатаПортала) Тогда
		
		Если СтрДлина(ДатаПортала) = 10 И Сред(ДатаПортала,3,1) = "." И Сред(ДатаПортала,6,1) = "." Тогда
			//Даты документов ЭДО передаются в формате строки "ДД.ММ.ГГГГ"
			Результат = Дата(Сред(ДатаПортала,7,4) + Сред(ДатаПортала,4,2) + Сред(ДатаПортала,1,2));
			
		ИначеЕсли СтрДлина(ДатаПортала) = 13 Тогда
			//Unix timeStamp в миллисекундах
			Результат = Дата('19700101')+ ДатаПортала/1000;
			
		Иначе
			СокрДата = СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(ДатаПортала,"-",""),".",""),":",""),"T",""),"Z","");
			Если СтрДлина(СокрДата) > 14 Тогда
				СокрДата = Лев(СокрДата,14);
			КонецЕсли;
			Попытка
				Результат = Дата(СокрДата);
			Исключение
				СообщитьСообщение("Ошибка преобразования даты: " + ДатаПортала);
			КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЭтоМоментВремени И ТипЗнч(Результат) = Тип("Дата") Тогда
		//Добавляем к полученному моменту времени поправку часового пояса пользователя
		Результат = Результат + СмещениеСтандартногоВремени(ЧасовойПояс());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭкранироватьСпецсимволыJSON(Знач Строка) Экспорт
	Строка = СтрЗаменить(Строка,"\","\\");
	Строка = СтрЗаменить(Строка,"""","\""");
	Строка = СтрЗаменить(Строка,Символы.Таб," ");
	Строка = СтрЗаменить(Строка,Символы.ПС,"\n");
	Возврат Строка;
КонецФункции

Функция СтрокаJSON(Знач Строка)
	Возврат """" + Строка + """";
КонецФункции

Функция СформироватьJSONСтрокуСтруктуры(ЗаписьТекста, Структура, Ключ,	ИмяПоля = Неопределено, ФорматированноеЗначение = Неопределено, ВыводитьПустые = Ложь, ЭтоЧисло = Ложь, ПервыйЭлемент = Ложь)
	//Старые платформы не умеют в JSON
	Если ПервыйЭлемент Или ВыводитьПустые Или ЗначениеЗаполнено(ФорматированноеЗначение) Или (Структура.Свойство(Ключ) И ЗначениеЗаполнено(Структура[Ключ])) Тогда
		Значение = ?(ФорматированноеЗначение = Неопределено,Структура[Ключ],ФорматированноеЗначение);
		
		ЗаписьТекста.ДобавитьСтроку(?(ПервыйЭлемент,"","," + Символы.ПС) +
		СтрокаJSON(?(ЗначениеЗаполнено(ИмяПоля), ИмяПоля, Ключ)) + ": "
			+ СтрокаJSON(ЭкранироватьСпецсимволыJSON(Значение)));
	КонецЕсли;
КонецФункции

Функция Энтера_РазложитьСтрокуВМассивПодстрок(Знач Строка, Знач Разделитель = ",", Знач ПропускатьПустыеСтроки = Неопределено, СокращатьНепечатаемыеСимволы = Ложь) Экспорт
	
	Результат = Новый Массив;
	
	// Для обеспечения обратной совместимости.
	Если ПропускатьПустыеСтроки = Неопределено Тогда
		ПропускатьПустыеСтроки = ?(Разделитель = " ", Истина, Ложь);
		Если ПустаяСтрока(Строка) Тогда 
			Если Разделитель = " " Тогда
				Результат.Добавить("");
			КонецЕсли;
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	//
	
	Позиция = Найти(Строка, Разделитель);
	Пока Позиция > 0 Цикл
		Подстрока = Лев(Строка, Позиция - 1);
		Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Подстрока) Тогда
			Если СокращатьНепечатаемыеСимволы Тогда
				Результат.Добавить(СокрЛП(Подстрока));
			Иначе
				Результат.Добавить(Подстрока);
			КонецЕсли;
		КонецЕсли;
		Строка = Сред(Строка, Позиция + СтрДлина(Разделитель));
		Позиция = Найти(Строка, Разделитель);
	КонецЦикла;
	
	Если Не ПропускатьПустыеСтроки Или Не ПустаяСтрока(Строка) Тогда
		Если СокращатьНепечатаемыеСимволы Тогда
			Результат.Добавить(СокрЛП(Строка));
		Иначе
			Результат.Добавить(Строка);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 

Функция Энтера_НаименованиеОрганизации(Знач Наименование) Экспорт
	
	Наименование = СокрЛП(Наименование);
	
	ВыделятьНаименованиеКавычками = Истина;
	
	Если Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='ООО'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Общество с ограниченной ответственностью'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ООО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='ОАО'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Открытое акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ОАО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='ЗАО'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Закрытое акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ЗАО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='АО'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='АО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='ИП'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Индивидуальный предприниматель'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ИП'");
		ВыделятьНаименованиеКавычками = Ложь;
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='Общество с ограниченной ответственностью'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Общество с ограниченной ответственностью'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ООО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='Открытое акционерное общество'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Открытое акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ОАО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='Закрытое акционерное общество'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Закрытое акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ЗАО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='Акционерное общество'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Акционерное общество'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='АО'");
	ИначеЕсли Энтера_УбратьИзНаименованияОПФ(Наименование, НСтр("ru='Индивидуальный предприниматель'")) Тогда
		ОрганизационноПравоваяФорма				= НСтр("ru='Индивидуальный предприниматель'");
		ОрганизационноПравоваяФормаСокращенно	= НСтр("ru='ИП'");
		ВыделятьНаименованиеКавычками = Ложь;
	Иначе
		ОрганизационноПравоваяФорма				= "";
		ОрганизационноПравоваяФормаСокращенно	= "";
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ОрганизационноПравоваяФорма) Тогда
		КоличествоКавычек	= СтрЧислоВхождений(Наименование, """");
		Если КоличествоКавычек > 1 Тогда
			// Наименование организации внутри внешних кавычек
			ПозицияПервойКавычки = Найти(Наименование, """");
			ПозицияПоследнейКавычки = 0;
			
			ВремНаименование = Наименование;
			
			ПозицияКавычки = ПозицияПервойКавычки;
			Пока ПозицияКавычки > 0 Цикл
				ПозицияПоследнейКавычки = ПозицияПоследнейКавычки + ПозицияКавычки;
				ВремНаименование = Сред(ВремНаименование, ПозицияКавычки + 1);
				ПозицияКавычки = Найти(ВремНаименование, """");
			КонецЦикла;
			
			Наименование = Сред(Наименование, ПозицияПервойКавычки + 1, ПозицияПоследнейКавычки - ПозицияПервойКавычки - 1);
			Если НЕ КоличествоКавычек%2 = 0 Тогда
				Наименование = Наименование + """";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ОрганизационноПравоваяФорма) Тогда
		ПолноеНаименование = Наименование;
	Иначе
		ШаблонСтроки = ?(ВыделятьНаименованиеКавычками,"%1 ""%2""","%1 %2");
		ПолноеНаименование = Энтера_ПодставитьПараметрыВСтроку(ШаблонСтроки,
			ОрганизационноПравоваяФорма, Наименование);
	КонецЕсли;
	
	СокращенноеНаименование = Наименование + ?(ПустаяСтрока(ОрганизационноПравоваяФормаСокращенно), "", " ")
		+ ОрганизационноПравоваяФормаСокращенно;
	
	СтруктураНаименования = Новый Структура("Наименование, СокращенноеНаименование, ПолноеНаименование",
		Наименование, СокращенноеНаименование, ПолноеНаименование);
	
	Возврат СтруктураНаименования;
	
КонецФункции

Функция Энтера_УбратьИзНаименованияОПФ(Наименование, ИмяОрганизационнойФормы)

	Результат = Ложь;
	
	Наименование = СокрЛП(Наименование);
	
	ДлинаНаименования			= СтрДлина(Наименование);
	ДлинаОрганизационнойФормы	= СтрДлина(ИмяОрганизационнойФормы);
	
	Если Нрег(Лев(Наименование, ДлинаОрганизационнойФормы)) = Нрег(ИмяОрганизационнойФормы) Тогда
		Наименование	= СокрЛ(Сред(Наименование, ДлинаОрганизационнойФормы + 1));
		Результат		= Истина;
	КонецЕсли;	
	
	Если Нрег(Прав(Наименование, ДлинаОрганизационнойФормы)) = Нрег(ИмяОрганизационнойФормы) Тогда
		Наименование	= СокрП(Лев(Наименование, ДлинаНаименования - ДлинаОрганизационнойФормы - 1));
		Результат		= Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Энтера_ПодставитьПараметрыВСтроку(Знач ШаблонСтроки,
	Знач Параметр1, Знач Параметр2 = Неопределено, Знач Параметр3 = Неопределено,
	Знач Параметр4 = Неопределено, Знач Параметр5 = Неопределено, Знач Параметр6 = Неопределено,
	Знач Параметр7 = Неопределено, Знач Параметр8 = Неопределено, Знач Параметр9 = Неопределено) Экспорт
	
	ЕстьПараметрыСПроцентом = Найти(Параметр1, "%")
		Или Найти(Параметр2, "%")
		Или Найти(Параметр3, "%")
		Или Найти(Параметр4, "%")
		Или Найти(Параметр5, "%")
		Или Найти(Параметр6, "%")
		Или Найти(Параметр7, "%")
		Или Найти(Параметр8, "%")
		Или Найти(Параметр9, "%");
		
	Если ЕстьПараметрыСПроцентом Тогда
		Возврат Энтера_ПодставитьПараметрыСПроцентом(ШаблонСтроки, Параметр1,
			Параметр2, Параметр3, Параметр4, Параметр5, Параметр6, Параметр7, Параметр8, Параметр9);
	КонецЕсли;
	
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%1", Параметр1);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%2", Параметр2);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%3", Параметр3);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%4", Параметр4);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%5", Параметр5);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%6", Параметр6);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%7", Параметр7);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%8", Параметр8);
	ШаблонСтроки = СтрЗаменить(ШаблонСтроки, "%9", Параметр9);
	Возврат ШаблонСтроки;
	
КонецФункции

Функция Энтера_ПодставитьПараметрыСПроцентом(Знач СтрокаПодстановки,
	Знач Параметр1, Знач Параметр2 = Неопределено, Знач Параметр3 = Неопределено,
	Знач Параметр4 = Неопределено, Знач Параметр5 = Неопределено, Знач Параметр6 = Неопределено,
	Знач Параметр7 = Неопределено, Знач Параметр8 = Неопределено, Знач Параметр9 = Неопределено)
	
	Результат = "";
	Позиция = Найти(СтрокаПодстановки, "%");
	Пока Позиция > 0 Цикл 
		Результат = Результат + Лев(СтрокаПодстановки, Позиция - 1);
		СимволПослеПроцента = Сред(СтрокаПодстановки, Позиция + 1, 1);
		ПодставляемыйПараметр = Неопределено;
		Если СимволПослеПроцента = "1" Тогда
			ПодставляемыйПараметр = Параметр1;
		ИначеЕсли СимволПослеПроцента = "2" Тогда
			ПодставляемыйПараметр = Параметр2;
		ИначеЕсли СимволПослеПроцента = "3" Тогда
			ПодставляемыйПараметр = Параметр3;
		ИначеЕсли СимволПослеПроцента = "4" Тогда
			ПодставляемыйПараметр = Параметр4;
		ИначеЕсли СимволПослеПроцента = "5" Тогда
			ПодставляемыйПараметр = Параметр5;
		ИначеЕсли СимволПослеПроцента = "6" Тогда
			ПодставляемыйПараметр = Параметр6;
		ИначеЕсли СимволПослеПроцента = "7" Тогда
			ПодставляемыйПараметр = Параметр7
		ИначеЕсли СимволПослеПроцента = "8" Тогда
			ПодставляемыйПараметр = Параметр8;
		ИначеЕсли СимволПослеПроцента = "9" Тогда
			ПодставляемыйПараметр = Параметр9;
		КонецЕсли;
		Если ПодставляемыйПараметр = Неопределено Тогда
			Результат = Результат + "%";
			СтрокаПодстановки = Сред(СтрокаПодстановки, Позиция + 1);
		Иначе
			Результат = Результат + ПодставляемыйПараметр;
			СтрокаПодстановки = Сред(СтрокаПодстановки, Позиция + 2);
		КонецЕсли;
		Позиция = Найти(СтрокаПодстановки, "%");
	КонецЦикла;
	Результат = Результат + СтрокаПодстановки;
	
	Возврат Результат;
КонецФункции


