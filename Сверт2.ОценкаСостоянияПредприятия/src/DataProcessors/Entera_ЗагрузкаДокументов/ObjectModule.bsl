Функция Классификатор_ПолучитьСтрануМира(СтруктураЗаполнения) Экспорт
	
	Результат = Неопределено;
	
	Если СтруктураЗаполнения.Код = "980"
		Или СтруктураЗаполнения.Код = "EU"
		Или СтруктураЗаполнения.Наименование = "EU"
		Или Нрег(СтруктураЗаполнения.Наименование) = "европейский союз" Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Код","980");
		Результат.Вставить("Наименование","Европейский союз");
		Результат.Вставить("НаименованиеПолное","Европейский союз");
		Результат.Вставить("КодАльфа2","EU");
		Результат.Вставить("КодАльфа3","");
		
	ИначеЕсли СтруктураЗаполнения.Код = "981"
		Или Нрег(СтруктураЗаполнения.Наименование) = "евразийский экономический союз" Тогда
		
		Результат = Новый Структура;
		Результат.Вставить("Код","981");
		Результат.Вставить("Наименование","Евразийский экономический союз");
		Результат.Вставить("НаименованиеПолное","Евразийский экономический союз");
		Результат.Вставить("КодАльфа2","");
		Результат.Вставить("КодАльфа3","");
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Классификатор_ИнициализироватьСоответствияСинонимовЕдиницИзмерения() Экспорт
	
	//Читаем макет синонимов единиц измерения в Соответствие
	
	Синонимы = Новый Соответствие;
	
	Макет = ПолучитьМакет("СинонимыЕдиницИзмерения");
	
	Для Сч = 2 По Макет.ВысотаТаблицы Цикл
		name = ПолучитьТекстЯчейкиОбласти(Макет,Сч,1);
		okei_code = ПолучитьТекстЯчейкиОбласти(Макет,Сч,2);
		synonym = ПолучитьТекстЯчейкиОбласти(Макет,Сч,3);
		
		//Разбираем синонимы, ключом будет синоним, значением - структура ЕИ Наименование и Код
		ТекЗначение = Новый Структура("Наименование,Код",name,okei_code);
		
		МассивСинонимов = Энтера_РазложитьСтрокуВМассивПодстрок(synonym,";",Истина,Истина);
		
		Для Каждого Синоним Из МассивСинонимов Цикл
			Синонимы.Вставить(Синоним,ТекЗначение);
		КонецЦикла;
				
	КонецЦикла;
	
	Возврат Синонимы;
	
КонецФункции

Функция СловаМаркерыТипНоменклатуры_ЗначенияПоУмолчанию_ПолучитьДанныеМакета(УникальныйИдентификатор = Неопределено) Экспорт
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ТаблицаЗначений.Колонки.Добавить("Маркер");
	ТаблицаЗначений.Колонки.Добавить("ТипНоменклатуры");
		
	Макет = ПолучитьМакет("СловаМаркерыТипНоменклатуры");
	Область = Макет.ПолучитьОбласть("Услуги");
			
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		Маркер = ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		
		НоваяСтрока = ТаблицаЗначений.Добавить();
		НоваяСтрока.Маркер = Маркер;
		НоваяСтрока.ТипНоменклатуры = "Услуга";
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаЗначений,УникальныйИдентификатор);
	
КонецФункции


Функция КодыДокументов_ИнициализироватьСоответствияКодовДокументов() Экспорт
	
	СоответствияКодов = Новый Соответствие;
	
	Макет = ПолучитьМакет("КодыТиповДокументов");
	Область = Макет.ПолучитьОбласть("КодыТиповДокументов");
	
	Для Сч = 1 По Область.ВысотаТаблицы Цикл
		КодТипаДокумента = ПолучитьТекстЯчейкиОбласти(Область,Сч,1);
		ИмяТипаДокумента = ПолучитьТекстЯчейкиОбласти(Область,Сч,2);
		
		СоответствияКодов.Вставить(ИмяТипаДокумента,КодТипаДокумента);
	КонецЦикла;
	
	Возврат СоответствияКодов;
	
КонецФункции

