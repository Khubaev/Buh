Функция УведомлениеПорталуОСозданииДокументов_СформироватьТелоЗапроса(ЗаданияУведомления) Экспорт
		
	ИдентификаторБазы = ПолучитьНавигационнуюСсылкуИнформационнойБазы(); //будет служить идентификатором базы
	ОписаниеБазы = Метаданные.Синоним;
	
	//формируем тело запроса уведомления об успешном создании документов в текущей базе
	ТелоЗапроса = "{" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + """infos"": [";
	
	ПервыйЭлемент = Истина;
	Для Каждого Задание Из ЗаданияУведомления Цикл
		
		Если ПервыйЭлемент Тогда
			ПервыйЭлемент = Ложь;
		Иначе
			ТелоЗапроса = ТелоЗапроса + "," + Символы.ПС;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Задание.Значение) Тогда
			ГУИДЭлемента = Задание.Значение.УникальныйИдентификатор();
			ТипЭлемента = Задание.Значение.Метаданные().Имя;
			ОписаниеЭлемента = ЭкранироватьСпецсимволыJSON(Строка(Задание.Значение));
		Иначе
			ГУИДЭлемента = "00000000-0000-0000-0000-000000000000";
			ТипЭлемента = "";
			ОписаниеЭлемента = "Ручное изменение статуса на <Выгружен>";
		КонецЕсли;
		
		ТелоЗапроса = ТелоЗапроса + "{" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """documentId"": """ + Задание.Представление + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """externalId"": """ + ГУИДЭлемента + """," + Символы.ПС;
		
		//data
		ТелоЗапроса = ТелоЗапроса + """data"": {" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """type"": """ + ТипЭлемента + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """description"": """ + ОписаниеЭлемента + " <" + Строка(ТекущаяДата()) + ">""," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """dbGuid"": """ + ЭкранироватьСпецсимволыJSON(ИдентификаторБазы) + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """dbDescription"": """ + ЭкранироватьСпецсимволыJSON(ОписаниеБазы) + """" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + "}" + Символы.ПС; //data
		ТелоЗапроса = ТелоЗапроса + "}" + Символы.ПС; //document
	КонецЦикла;
	
	ТелоЗапроса = ТелоЗапроса + "]" + Символы.ПС;
	ТелоЗапроса = ТелоЗапроса + "}";
	
	Возврат ТелоЗапроса;
	
КонецФункции


Функция ОбновлениеДанныхДокументов_СформироватьТелоЗапроса_items(ДокументИД) Экспорт
	
	//Для аудитора: это не закомментированный код, а пример метода и тела запроса, фиксируется для истории разработки.
	//PUT https://app.entera.pro/api/v1/documents/{{documentId}}/accept
	//{
	// "items": [
	// { "id": "{{itemId}}", "serialNumber": 1, "name": "Новое название" }
	// ]
	//}
	
	ТелоЗапроса = "{";
	ТелоЗапроса = ТелоЗапроса + """items"": [" + Символы.ПС;
	ПервыйЭлемент = Истина;
	
	СтруктураПоиска = Новый Структура("ДокументИД,ТипОбъекта,Номенклатура_ПредставлениеИзменено",ДокументИД,"Номенклатура",Истина);
	НайденныеСтроки = ЗагружаемыеОбъекты.НайтиСтроки(СтруктураПоиска);
	
	Для Каждого СтрокаТаблицы Из НайденныеСтроки Цикл
		
		Если ПервыйЭлемент Тогда
			ПервыйЭлемент = Ложь;
		Иначе
			ТелоЗапроса = ТелоЗапроса + "," + Символы.ПС;
		КонецЕсли;
		
		ТелоЗапроса = ТелоЗапроса + "{" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """id"" : """ + СтрокаТаблицы.ИдентификаторОбъекта + """," + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + """serialNumber"" : """ + СтрокаТаблицы.Номенклатура_serialNumber + """," + Символы.ПС;
		
		goodCode = ?(СтрокаТаблицы.Номенклатура_goodCodeIsNull,"",ЭкранироватьСпецсимволыJSON(СтрокаТаблицы.Номенклатура_Код));
		ТелоЗапроса = ТелоЗапроса + """goodCode"" : """ + goodCode + """," + Символы.ПС;
		
		ТелоЗапроса = ТелоЗапроса + """name"" : """ + ЭкранироватьСпецсимволыJSON(СтрокаТаблицы.ПредставлениеОбъекта) + """" + Символы.ПС;
		ТелоЗапроса = ТелоЗапроса + "}";
		
	КонецЦикла;
	
	ТелоЗапроса = ТелоЗапроса + "]" + Символы.ПС + "}";
	
	Возврат ТелоЗапроса;
	
КонецФункции

