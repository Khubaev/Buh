	Иначе
		//Угадываем: большое количество отраслевых решений сделаны на базе БП3.0, но имеют собственное имя метаданных конфигурации,
		//в качестве ориентира возьмем какой-нибудь общий модуль БП, например УправлениеКонтактнойИнформациейБП
		
		Если Метаданные.ОбщиеМодули.Найти("УправлениеКонтактнойИнформациейБП") <> Неопределено Тогда
			Конфигурация = Новый Структура("Крат,Полн,Лок","БП30","БП30");
			
		//Отраслевые решения на базе УНФ
		ИначеЕсли (_ЗФ_ПолучитьОбщийМодульКонфигурации("ЗаполнениеОбъектовУНФ") <> Неопределено
			Или _ЗФ_ПолучитьОбщийМодульКонфигурации("ПроведениеДокументовУНФ") <> Неопределено) Тогда
		
			Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ");
		
			// Вышла УНФ 3.0, по идее логика заполнения счета-фактуры переехала из последних 1.6.
			//Пока определим как последние 1.6, при необходимости определим "персональный" идентификатор конфы
			Если МассивРелизов[0] = "3" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1618");
			Иначе
		
				// Теперь нужно дробить УНФ по версиям, в частности, в 1.6.18 по-новому заполняется счет-фактура на основании Приходной накладной
				Если МассивРелизов[1] = "6" Тогда
					Если МассивРелизов[2] < "18" Тогда
						Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1616");
					Иначе
						Конфигурация = Новый Структура("Крат,Полн,Лок","УНФ","УНФ1618");
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
		ИначеЕсли Метаданные.ОбщиеМодули.Найти("ОбменДаннымиСобытияБП") <> Неопределено Тогда
			Конфигурация = Новый Структура("Крат,Полн,Лок","БП20","БП20");
			
		ИначеЕсли Метаданные.ОбщиеМодули.Найти("ОбщегоНазначенияБГУ") <> Неопределено Тогда
			Если МассивРелизов[0] = "1" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","БГУ","БГУ");
			ИначеЕсли МассивРелизов[0] = "2" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","БГУ2","БГУ2");
			КонецЕсли;
			
		//Предположим, что "БК" = Бухгалтерия Казахстана
		ИначеЕсли Метаданные.Обработки.Найти("ОбновлениеИнформационнойБазыБК") <> Неопределено Тогда
			Если МассивРелизов[0] = "3" Тогда
				Конфигурация = Новый Структура("Крат,Полн,Лок","БП30","БП30","KAZ");
			КонецЕсли;
		КонецЕсли;
			
	КонецЕсли;
	
	//Чтобы не опрашивать метаданные поместим эту информацию в описание
	Конфигурация.Вставить("Имя",Имя);
	Конфигурация.Вставить("Версия",Версия);
	
	Возврат Конфигурация;
	
КонецФункции

Функция ПолучитьТекстовоеОписаниеКонфигурации(СтруктураНастроек = Неопределено) Экспорт
	
	F = Не СведенияОВнешнейОбработке().Свойство("НеФреш");
	ВерсияТекст = "Версия обработки 1." + ВерсияМодуля.Версия + ?(F,"F","") + " " + Формат(ВерсияМодуля.Дата,"ДФ=[yyyy.MM.dd]");
	
	СисИнфо = Новый СистемнаяИнформация;
	Платформа = СисИнфо.ВерсияПриложения;
	
	СтрокаСоединенияСБД = СтрокаСоединенияИнформационнойБазы();
	// в зависимости от того файловый это вариант БД или нет,  по-разному отображается путь в БД 
	ФайловаяСерверная = ?(Найти(Врег(СтрокаСоединенияСБД), "FILE=") > 0,"файловая","серверная");
	
	ОписаниеКонфигурации = "Платформа: " + Платформа + Символы.ПС
		+ "Конфигурация: " + Метаданные.Имя + " (" + Метаданные.Версия + ") (" + ФайловаяСерверная + ")";
		
	//2021.04.09 ( Как модуль определил эту конфигурацию
	СтруктураОписания = ПолучитьОписаниеКонфигурации();
	ОписаниеКонфигурации = ОписаниеКонфигурации + ", определена модулем как <" + СтруктураОписания.Полн + ">"
		+ ?(ЗначениеЗаполнено(СтруктураОписания.Лок)," [" + СтруктураОписания.Лок + "]","");
	// ) 2021.04.09
	
	ОписаниеКонфигурации = ОписаниеКонфигурации + Символы.ПС + ВерсияТекст;
		
	Если ТипЗнч(СтруктураНастроек) = Тип("Структура") Тогда
		Если СтруктураНастроек.Свойство("СистемныеНастройки_ДополнительныйМодульКастомизации")
			И ЗначениеЗаполнено(СтруктураНастроек.СистемныеНастройки_ДополнительныйМодульКастомизации) Тогда
			ИспользованиеМК = "В текущих настройках используется модуль кастомизации";
		Иначе
			ИспользованиеМК = "В текущих настройках НЕ используется модуль кастомизации";
		КонецЕсли;
	Иначе
		ИспользованиеМК = "Использование модуля кастомизации не определено";
	КонецЕсли;
	
	ОписаниеКонфигурации = ОписаниеКонфигурации + Символы.ПС + ИспользованиеМК;
				
	Возврат ОписаниеКонфигурации;
	
КонецФункции

Функция ЗаполнитьСтруктуруПодключения(ТестовыйРежим = 0) Экспорт
	
	СтруктураПодключения = Новый Структура;
	
	СтруктураПодключения.Вставить("Адрес","app.entera.pro");
	СтруктураПодключения.Вставить("АдресСервераАвторизации","id.entera.pro");
	СтруктураПодключения.Вставить("Протокол","https://");
	СтруктураПодключения.Вставить("Порт",Неопределено);
	СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT=");
	СтруктураПодключения.Вставить("SSL",Новый ЗащищенноеСоединениеOpenSSL);
	
	//Отладка
	Если ТестовыйРежим = 1 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-staging1.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-staging1.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	ИначеЕсли ТестовыйРежим = 2 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-test2.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-test2.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	ИначеЕсли ТестовыйРежим = 7 Тогда
		СтруктураПодключения.Вставить("ТестовыйРежим",Истина);
		СтруктураПодключения.Вставить("Адрес","app-test7.entera.pro");
		СтруктураПодключения.Вставить("АдресСервераАвторизации","id-test7.entera.pro");
		СтруктураПодключения.Вставить("Токен_Cookie","ENTERA_JWT_TEST=");
	КонецЕсли;
		
	Возврат СтруктураПодключения;
	
КонецФункции

