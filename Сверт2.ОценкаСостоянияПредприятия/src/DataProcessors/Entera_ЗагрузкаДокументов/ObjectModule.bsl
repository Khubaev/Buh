Функция _ЗФ_ПолучитьHTTPСоединение(СтруктураПодключения,СтруктураНастроек)
	
	//Для серверной базы может быть задана настройка прокси
	МодульПолучениеФайловИзИнтернета = _ЗФ_ПолучитьОбщийМодульКонфигурации("ПолучениеФайловИзИнтернета");
	
	Если МодульПолучениеФайловИзИнтернета <> Неопределено Тогда
		Попытка
			Прокси = МодульПолучениеФайловИзИнтернета.ПолучитьПрокси("HTTPS");
		Исключение
			//Не обрабатываем
		КонецПопытки;
	КонецЕсли;
	
	Таймаут = 120;
	
	Если СтруктураНастроек.Свойство("СистемныеНастройки_СоединениеАутентификацияОС")
		И СтруктураНастроек.СистемныеНастройки_СоединениеАутентификацияОС = Истина Тогда
		//доступно начиная с 8.3.7, для более старых платформ экранируем конструктор от синтаксического контроля
		Соединение = Вычислить("Новый HTTPСоединение(СтруктураПодключения.АдресСервера,СтруктураПодключения.Порт,СтруктураПодключения.АутентификацияИмяПользователя,СтруктураПодключения.АутентификацияПароль,Прокси,Таймаут,СтруктураПодключения.SSL,Истина)");
	Иначе
		Соединение = Новый HTTPСоединение(СтруктураПодключения.АдресСервера, СтруктураПодключения.Порт,СтруктураПодключения.АутентификацияИмяПользователя,СтруктураПодключения.АутентификацияПароль,Прокси,Таймаут,СтруктураПодключения.SSL);
	КонецЕсли;
	
	Возврат Соединение;
	
КонецФункции

Функция _УФ_МодульКастомизации_Получить(СтруктураНастроек) Экспорт
			
	//Описание: в основной обработке описывается базовый алгоритм заполнения тех или иных объектов конфигурации, учесть все пожелания каждого клиента
	//в рамках одной универсальной обработки невозможно, разрабатывать и поддерживать отдельную обработку для всех пользователей основной обработки
	//слишком трудоемко.
	//В качестве расширения функционала этой обработки для конечного пользователя предлагается пустой шаблон второй обработки (есть в макете этой обработки),
	//содержащей процедуры-обработчики событий, возникающих в этой "главной" обработке, например, "ПередЗаписьюДокумента", "ПослеЗаписиДокумента" и т.д.
	//То есть разработчик организации-клиента может самостоятельно при необходимости описать требуемый ему алгоритм заполнения объекта,
	//подключить вторую обработку в справочник внешних обработок базы 1с (в случае FRESH - ему необходимо будет отправить ее на аудит)
	//и выбрать ее использование в настройках этой обработки. Таким образом эта "основная" обработка может быть обновлена без ущерба
	//дополненному алгоритму заполнения.
	
	Результат = Новый Структура("Успешно,ТекстОшибки,Обработка",Ложь,"");
	
	Если Кэш_МодульКастомизации <> Неопределено Тогда
		Результат.Обработка = Кэш_МодульКастомизации;
		Результат.Успешно = Истина;
	Иначе
		
		Попытка
			ИмяФайла = ПолучитьИмяВременногоФайла();
			ДвоичныеДанные = ПолучитьИзВременногоХранилища(СтруктураНастроек.АдресХранилищаДвоичныхДанныхМодуляКастомизации);
			
			Если ДвоичныеДанные = Неопределено Тогда
				ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль","Модуль кастомизации не был получен из временного хранилища","ПолучениеМК");
				
			Иначе
				ДвоичныеДанные.Записать(ИмяФайла);
				
				//в свете вопросов, возникших при прохождении аудита FRESH обращаю внимание аудитора:
				//если проанализировать код, подключение модуля кастомизации выполняется не из макета внешней обработки, как показалось кому-то,
				//а из справочника внешних обработок. Значение используемого ключа СтруктураНастроек.АдресХранилищаДвоичныхДанныхМодуляКастомизации
				//задается в функции МодульКастомизации_ПолучитьДанныеОбработки в форме УФ_Настройки при формировании структуры настроек работы.
				
				//Для НЕ Фреш-конфигураций использование МК может подразумевать выполнение запросов порталу,
				//поэтому подключение МК может быть выполнено не в Безопасном режиме, для таких клиентов в подключаемом МК
				//в описании СведенияОВнешнейОбработки признак БезопасныйРежим при его подключении устанавливается в Ложь
				БезопасныйРежим = Ложь;
				МодульКастомизации = ВнешниеОбработки.Создать(ИмяФайла,БезопасныйРежим);
				Кэш_МодульКастомизации = МодульКастомизации;
			КонецЕсли;
			
		Исключение
			ТекстОшибки = ОписаниеОшибки();
			Результат.ТекстОшибки = "При получении модуля кастомизации произошла ошибка: " + ТекстОшибки;
			
			ЗаписатьСобытиеВПротокол(СтруктураНастроек,1,"Модуль",ТекстОшибки,"Ошибка");
		КонецПопытки;
		
		Если МодульКастомизации <> Неопределено Тогда
			
			Результат.Обработка = МодульКастомизации;
			Результат.Успешно = Истина;
			
			//Прибираемся
			Попытка УдалитьФайлы(ИмяФайла); Исключение; КонецПопытки;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция _УФ_ПолучитьМассивТребуемыхРазрешений()
		
	Если Метаданные.ПакетыXDTO.Найти("ApplicationPermissions_1_0_0_2") <> Неопределено Тогда
		Пакет = Метаданные.ПакетыXDTO.ApplicationPermissions_1_0_0_2.ПространствоИмен;
	ИначеЕсли Метаданные.ПакетыXDTO.Найти("ApplicationPermissions_1_0_0_1") <> Неопределено Тогда
		Пакет = Метаданные.ПакетыXDTO.ApplicationPermissions_1_0_0_1.ПространствоИмен;
	КонецЕсли;
	
	Разрешения = Новый Массив;
	
	Если Пакет <> Неопределено Тогда
						
		//Доступ к каталогу временных файлов
		НовоеРазрешение = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(Пакет, "FileSystemAccess"));
		НовоеРазрешение.Description = "Требуется хранение и обработка временных файлов, создаваемых в процессе работы обработки";
		НовоеРазрешение.Path = "/temp";
		НовоеРазрешение.AllowedRead = Истина;
		НовоеРазрешение.AllowedWrite = Истина;
	
		Разрешения.Добавить(НовоеРазрешение);
		
		//Включение привилегированного режима
		НовоеРазрешение = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(Пакет, "ExternalModulePrivilegedModeAllowed"));
		НовоеРазрешение.Description = "Для успешного выполнения ряда операций с создаваемыми документами может потребоваться включение привилегированного режима";
	
		Разрешения.Добавить(НовоеРазрешение);
		
		Разрешение = _УФ_Разрешение_InternetResourceAccess(Пакет,"HTTPS","id.entera.pro",443,"Ресурс используется для авторизации на портале entera.pro");
		Разрешения.Добавить(Разрешение);
		
		Разрешение = _УФ_Разрешение_InternetResourceAccess(Пакет,"HTTPS","app.entera.pro",443,"Ресурс используется для обмен с порталом данными о распознаваемых документах entera.pro");
		Разрешения.Добавить(Разрешение);
		
	КонецЕсли;
		
	Возврат Разрешения;
	
КонецФункции

Функция _УФ_Разрешение_InternetResourceAccess(Пакет,Protocol,Host,Port,Description) Экспорт
	
	//Использование интернет-ресурса
	НовоеРазрешение = ФабрикаXDTO.Создать(ФабрикаXDTO.Тип(Пакет, "InternetResourceAccess"));
	НовоеРазрешение.Description = Description;
    НовоеРазрешение.Protocol = Protocol;
	НовоеРазрешение.Host = Host;
	НовоеРазрешение.Port = Port;
	
	Возврат НовоеРазрешение;
	
КонецФункции

