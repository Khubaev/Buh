			СловаМаркеры = ХранилищеОбщихНастроек.Загрузить("Entera_ЗагрузкаДокументов","СловаМаркерыТипНоменклатуры");
			Если ТипЗнч(СловаМаркеры) = Тип("ТаблицаЗначений")
				И СловаМаркеры.Количество() > 0 Тогда
				
				СтрокаДляПоиска = Нрег(ПредставлениеОбъекта);
				Для Каждого СтрокаМаркер Из СловаМаркеры Цикл
					Если ЗначениеЗаполнено(СтрокаМаркер.Маркер) И ЗначениеЗаполнено(СтрокаМаркер.ТипНоменклатуры) Тогда
													
						//пробел в маркере разбивает маркер на подстроки поиска, поиск по этим подстрокам
						//должен выполняться по вхождению всех подстрок в наименование номенклатуры поставщика
						МассивПодстрок = Энтера_РазложитьСтрокуВМассивПодстрок(Нрег(СтрокаМаркер.Маркер)," ",Истина,Истина);
						ВсеПодстрокиНайдены = Истина;
						Для Каждого Подстрока Из МассивПодстрок Цикл
							Если Найти(СтрокаДляПоиска,Подстрока) = 0 Тогда
								ВсеПодстрокиНайдены = Ложь;
								Прервать;
							КонецЕсли;
						КонецЦикла;
						
						Если ВсеПодстрокиНайдены Тогда
							НоваяСтрока.ДополнительноеОписаниеОбъекта = СтрокаМаркер.ТипНоменклатуры;
