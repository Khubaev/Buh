
Перем КэшТекстовЯчеек;
Перем КэшСырыхТекстовЯчеек;


#Область ПрограммныйИнтерфейс

// Читает файл Excel в табличный документ.
//
// Параметры:
//  ПутьКФайлу - Строка - полный путь к xls/xlsx.
//
// Возвращаемое значение:
//  ТабличныйДокумент
//
Функция ПрочитатьТабличныйДокументИзФайла(ПутьКФайлу) Экспорт
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.Прочитать(ПутьКФайлу, СпособЧтенияЗначенийТабличногоДокумента.Текст);
	Возврат ТабДок;
	
КонецФункции

// Возвращает табличные документы всех листов Excel-файла.
//
// Параметры:
//  ПутьКФайлу - Строка
//
// Возвращаемое значение:
//  Соответствие - ключ: имя листа, значение: ТабличныйДокумент листа
//
Функция ПолучитьТабличныеДокументыЛистов(ПутьКФайлу) Экспорт
	
	ТабДок = ПрочитатьТабличныйДокументИзФайла(ПутьКФайлу);
	Результат = Новый Соответствие;
	
	Если ТабДок.Области.Количество() = 0 Тогда
		Результат.Вставить("Лист1", ТабДок);
		Возврат Результат;
	КонецЕсли;
	
	Для Каждого ИменованнаяОбласть Из ТабДок.Области Цикл
		ТабДокЛиста = ТабДок.ПолучитьОбласть(ИменованнаяОбласть.Имя);
		Результат.Вставить(ИменованнаяОбласть.Имя, ТабДокЛиста);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Разбирает табличный документ с многоуровневым (сгруппированным) заголовком.
//
// Поддерживает шапку из 2+ строк: верхний уровень — группы (объединённые по горизонтали),
// нижний — подзаголовки колонок. Фиксированные колонки слева (№, ФИО, Должность) определяются
// автоматически по отсутствию подзаголовка во 2-й строке.
//
// Параметры:
//  ТабДок     - ТабличныйДокумент
//  Параметры  - Структура:
//   * КоличествоСтрокЗаголовка - Число, по умолчанию 2
//   * СтрокаНачалаДанных         - Число, 0 = автоопределение
//   * ИменаФиксированныхКолонок  - Массив строк для принудительного сопоставления (необязательно)
//
// Возвращаемое значение:
//  Структура:
//   * ОписаниеКолонок  - ТаблицаЗначений (НомерКолонки, Группа, Подзаголовок, ТипКолонки, ИмяКолонки)
//   * ТаблицаДанных    - ТаблицаЗначений в «широком» формате (одна строка = сотрудник)
//   * ТаблицаОбучения  - ТаблицаЗначений в «длинном» формате (одна строка = программа сотрудника)
//   * СтрокаНачалаДанных
//   * КоличествоСтрокЗаголовка
//
Функция РазобратьТаблицуСГруппированнымЗаголовком(ТабДок, Параметры = Неопределено) Экспорт
	
	Если ТабДок = Неопределено Или ТабДок.ВысотаТаблицы = 0 Тогда
		ВызватьИсключение "Табличный документ пуст.";
	КонецЕсли;
	
	КоличествоСтрокЗаголовка = 2;
	СтрокаНачалаДанных = 0;
	
	Если Параметры <> Неопределено Тогда
		Если Параметры.Свойство("КоличествоСтрокЗаголовка") И Параметры.КоличествоСтрокЗаголовка > 0 Тогда
			КоличествоСтрокЗаголовка = Параметры.КоличествоСтрокЗаголовка;
		КонецЕсли;
		Если Параметры.Свойство("СтрокаНачалаДанных") Тогда
			СтрокаНачалаДанных = Параметры.СтрокаНачалаДанных;
		КонецЕсли;
	КонецЕсли;
	
	ПостроитьКэшТекстовЯчеек(ТабДок);
	
	Попытка
		
		ОписаниеКолонок = ПостроитьОписаниеКолонок(ТабДок, КоличествоСтрокЗаголовка);
		
		Если СтрокаНачалаДанных = 0 Тогда
			СтрокаНачалаДанных = ОпределитьСтрокуНачалаДанных(ТабДок, ОписаниеКолонок, КоличествоСтрокЗаголовка);
		КонецЕсли;
		
		ТаблицаДанных = СформироватьШирокуюТаблицу(ТабДок, ОписаниеКолонок, СтрокаНачалаДанных);
		ТаблицаОбучения = СформироватьДлиннуюТаблицуОбучения(ТабДок, ОписаниеКолонок, СтрокаНачалаДанных, ТаблицаДанных);
		
	Исключение
		ОчиститьКэшТекстовЯчеек();
		ВызватьИсключение;
	КонецПопытки;
	
	ОчиститьКэшТекстовЯчеек();
	
	Возврат Новый Структура(
		"ОписаниеКолонок, ТаблицаДанных, ТаблицаОбучения, СтрокаНачалаДанных, КоличествоСтрокЗаголовка",
		ОписаниеКолонок,
		ТаблицаДанных,
		ТаблицаОбучения,
		СтрокаНачалаДанных,
		КоличествоСтрокЗаголовка);
	
КонецФункции

// Читает Excel из двоичных данных и разбирает таблицу с группированным заголовком (первый лист).
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные
//  Параметры      - см. РазобратьТаблицуСГруппированнымЗаголовком
//
// Возвращаемое значение:
//  Структура - см. РазобратьТаблицуСГруппированнымЗаголовком
//
Функция РазобратьExcelСГруппированнымЗаголовком(ДвоичныеДанные, Параметры = Неопределено) Экспорт
	
	РезультатВсеЛисты = РазобратьExcelВсеЛистыСГруппированнымЗаголовком(ДвоичныеДанные, Параметры);
	
	Если РезультатВсеЛисты.ИменаЛистов.Количество() = 0 Тогда
		ВызватьИсключение "В файле Excel не найдено листов с данными.";
	КонецЕсли;
	
	ИмяПервогоЛиста = РезультатВсеЛисты.ИменаЛистов[0];
	Возврат РезультатВсеЛисты.Листы[ИмяПервогоЛиста];
	
КонецФункции

// Читает все листы Excel и для каждого формирует отдельные таблицы значений.
//
// Параметры:
//  ДвоичныеДанные - ДвоичныеДанные
//  Параметры      - см. РазобратьТаблицуСГруппированнымЗаголовком
//
// Возвращаемое значение:
//  Структура:
//   * Листы       - Соответствие (ИмяЛиста -> Структура разбора листа)
//   * ИменаЛистов - Массив имён листов в порядке файла
//
Функция РазобратьExcelВсеЛистыСГруппированнымЗаголовком(ДвоичныеДанные, Параметры = Неопределено) Экспорт
	
	ПутьКФайлу = ПолучитьИмяВременногоФайла("xlsx");
	ДвоичныеДанные.Записать(ПутьКФайлу);
	
	ЛистыТабДок = ПолучитьТабличныеДокументыЛистов(ПутьКФайлу);
	
	Листы = Новый Соответствие;
	ИменаЛистов = Новый Массив;
	
	Для Каждого ЛистФайла Из ЛистыТабДок Цикл
		
		ИмяЛиста = ЛистФайла.Ключ;
		ТабДокЛиста = ЛистФайла.Значение;
		
		Если ТабДокЛиста.ВысотаТаблицы = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		РазборЛиста = РазобратьТаблицуСГруппированнымЗаголовком(ТабДокЛиста, Параметры);
		РазборЛиста.Вставить("ИмяЛиста", ИмяЛиста);
		
		Листы.Вставить(ИмяЛиста, РазборЛиста);
		ИменаЛистов.Добавить(ИмяЛиста);
		
	КонецЦикла;
	
	Если ИменаЛистов.Количество() = 0 Тогда
		ВызватьИсключение "В файле Excel не найдено листов с данными.";
	КонецЕсли;
	
	Возврат Новый Структура("Листы, ИменаЛистов", Листы, ИменаЛистов);
	
КонецФункции

// Создаёт документы Сертификация по таблице обучения (длинный формат).
//
// Параметры:
//  ТаблицаОбучения - ТаблицаЗначений - ФИО, Программа, ДатаНачала, ДатаОкончания, НомерПротокола, НомерУдостоверения
//
// Возвращаемое значение:
//  Структура - Создано, Пропущено, Ошибки (Массив строк)
//
Функция СоздатьДокументыСертификации(ТаблицаОбучения,ПрограммаОбучения,СрокиОбучения) Экспорт
	
	Результат = Новый Структура("Создано, Пропущено, Ошибки", 0, 0, Новый Массив);
	
	Если ТаблицаОбучения = Неопределено Или ТаблицаОбучения.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Метаданные.Документы.Найти("Сертификация") = Неопределено Тогда
		Результат.Ошибки.Добавить("Документ ""Сертификация"" не найден в конфигурации.");
		Возврат Результат;
	КонецЕсли;
	
	КэшФизическихЛиц = Новый Соответствие;
	
	Для Каждого СтрокаОбучения Из ТаблицаОбучения Цикл
		
		Если ПустаяСтрока(СтрокаОбучения.НомерПротокола)
			И ПустаяСтрока(СтрокаОбучения.НомерУдостоверения)
			И (Не ЗначениеЗаполнено(СтрокаОбучения.ДатаНачала) Или СтрокаОбучения.ДатаНачала = '00010101')
			И (Не ЗначениеЗаполнено(СтрокаОбучения.ДатаОкончания) Или СтрокаОбучения.ДатаОкончания = '00010101')
			И (Не ЗначениеЗаполнено(СтрокаОбучения.ДатаОбучения) Или СтрокаОбучения.ДатаОбучения = '00010101') Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Продолжить;
		КонецЕсли;
		
		ФИО = СокрЛП(СтрокаОбучения.ФИО);
		Если ПустаяСтрока(ФИО) Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Результат.Ошибки.Добавить(СтрШаблон(
				"Строка %1: не заполнено ФИО (программа ""%2"").",
				СтрокаОбучения.НомерПП,
				СтрокаОбучения.Программа));
			Продолжить;
		КонецЕсли;
		
		ФизическоеЛицо = КэшФизическихЛиц.Получить(ФИО);
		Если ФизическоеЛицо = Неопределено Тогда
			ФизическоеЛицо = НайтиФизическоеЛицоПоФИО(ФИО);
			КэшФизическихЛиц.Вставить(ФИО, ФизическоеЛицо);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ФизическоеЛицо) Тогда
			Результат.Пропущено = Результат.Пропущено + 1;
			Результат.Ошибки.Добавить(СтрШаблон(
				"""%1"": физическое лицо не найдено (программа ""%2"").",
				ФИО,
				СтрокаОбучения.Программа));
			Продолжить;
		КонецЕсли;
		
		Попытка
			СоздатьДокументСертификации(СтрокаОбучения, ФизическоеЛицо,ПрограммаОбучения,СрокиОбучения);
			Результат.Создано = Результат.Создано + 1;
		Исключение
			Результат.Пропущено = Результат.Пропущено + 1;
			Результат.Ошибки.Добавить(СтрШаблон(
				"""%1"", программа ""%2"": %3",
				ФИО,
				СтрокаОбучения.Программа,
				ОписаниеОшибки()));
		КонецПопытки;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
// Однократно читает все ячейки табличного документа и разрешает горизонтальные объединения в памяти.
Процедура ПостроитьКэшТекстовЯчеек(ТабДок)
	
	КэшТекстовЯчеек = Новый Массив;
	КэшСырыхТекстовЯчеек = Новый Массив;
	Высота = ТабДок.ВысотаТаблицы;
	Ширина = ТабДок.ШиринаТаблицы;
	
	Если Высота = 0 Или Ширина = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для НомерСтроки = 1 По Высота Цикл
		
		СырыеКолонки = Новый Массив;
		
		Для НомерКолонки = 1 По Ширина Цикл
			СырыеКолонки.Добавить(СокрЛП(ТабДок.Область(НомерСтроки, НомерКолонки).Текст));
		КонецЦикла;
		
		КэшСырыхТекстовЯчеек.Добавить(СырыеКолонки);
		
		РазрешенныеКолонки = Новый Массив;
		
		Для ИндексКолонки = 0 По Ширина - 1 Цикл
			
			Текст = СырыеКолонки[ИндексКолонки];
			
			Если ПустаяСтрока(Текст) Тогда
				СдвигКолонки = ИндексКолонки - 1;
				Пока СдвигКолонки >= 0 Цикл
					ТекстСлева = СырыеКолонки[СдвигКолонки];
					Если Не ПустаяСтрока(ТекстСлева) Тогда
						Текст = ТекстСлева;
						Прервать;
					КонецЕсли;
					СдвигКолонки = СдвигКолонки - 1;
				КонецЦикла;
			КонецЕсли;
			
			РазрешенныеКолонки.Добавить(Текст);
			
		КонецЦикла;
		
		КэшТекстовЯчеек.Добавить(РазрешенныеКолонки);
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает текст ячейки из кэша (индексация строк/колонок с 1).
Функция ТекстЯчейкиИзКэша(НомерСтроки, НомерКолонки)
	
	Если КэшТекстовЯчеек = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если НомерСтроки < 1 Или НомерСтроки > КэшТекстовЯчеек.Количество() Тогда
		Возврат "";
	КонецЕсли;
	
	СтрокаКэша = КэшТекстовЯчеек[НомерСтроки - 1];
	
	Если НомерКолонки < 1 Или НомерКолонки > СтрокаКэша.Количество() Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СтрокаКэша[НомерКолонки - 1];
	
КонецФункции

// Сбрасывает кэш ячеек после разбора листа.
Процедура ОчиститьКэшТекстовЯчеек()
	
	КэшТекстовЯчеек = Неопределено;
	КэшСырыхТекстовЯчеек = Неопределено;
	
КонецПроцедуры

// Возвращает исходный (без объединений) текст ячейки из кэша.
Функция ТекстСыройЯчейкиИзКэша(НомерСтроки, НомерКолонки)
	
	Если КэшСырыхТекстовЯчеек = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если НомерСтроки < 1 Или НомерСтроки > КэшСырыхТекстовЯчеек.Количество() Тогда
		Возврат "";
	КонецЕсли;
	
	СтрокаКэша = КэшСырыхТекстовЯчеек[НомерСтроки - 1];
	
	Если НомерКолонки < 1 Или НомерКолонки > СтрокаКэша.Количество() Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СтрокаКэша[НомерКолонки - 1];
	
КонецФункции

// Возвращает Истина, если в строке листа нет ни одного исходного значения в колонках данных.
Функция СтрокаЛистаНеСодержитИсходныхДанных(НомерСтроки, ОписаниеКолонок)
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		Если Не ПустаяСтрока(ТекстСыройЯчейкиИзКэша(НомерСтроки, СтрокаОписания.НомерКолонки)) Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Возвращает Истина, если в строке есть исходные данные в колонках программ.
Функция СтрокаЛистаСодержитДанныеПрограмм(НомерСтроки, ОписаниеКолонок)
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		
		Если Не ЭтоВидПодколонкиПрограммыОбучения(СтрокаОписания.ВидПодколонки) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ПустаяСтрока(ТекстСыройЯчейкиИзКэша(НомерСтроки, СтрокаОписания.НомерКолонки)) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Возвращает Истина для подколонок программы обучения.
Функция ЭтоВидПодколонкиПрограммыОбучения(ВидПодколонки)
	
	Возврат ВидПодколонки = "Протокол"
		Или ВидПодколонки = "Удостоверение"
		Или ВидПодколонки = "Дата"
		Или ВидПодколонки = "ДатаНачала"
		Или ВидПодколонки = "ДатаОкончания";
	
КонецФункции

// Возвращает Истина, если в строке есть ФИО, должность или данные программ (без номера п/п).
Функция СтрокаЛистаСодержитСодержательныеДанные(НомерСтроки, ОписаниеКолонок, СлужебныеКолонки = Неопределено)
	
	Если СлужебныеКолонки = Неопределено Тогда
		СлужебныеКолонки = ОпределитьНомераСлужебныхКолонок(ОписаниеКолонок);
	КонецЕсли;
	
	Если СлужебныеКолонки.НомерФИО > 0
		И Не ПустаяСтрока(ТекстСыройЯчейкиИзКэша(НомерСтроки, СлужебныеКолонки.НомерФИО)) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СлужебныеКолонки.НомерДолжность > 0
		И Не ПустаяСтрока(ТекстСыройЯчейкиИзКэша(НомерСтроки, СлужебныеКолонки.НомерДолжность)) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат СтрокаЛистаСодержитДанныеПрограмм(НомерСтроки, ОписаниеКолонок);
	
КонецФункции

// Возвращает текст ячейки табличного документа.
Функция ТекстЯчейки(ТабДок, НомерСтроки, НомерКолонки)
	
	Если КэшТекстовЯчеек <> Неопределено Тогда
		Возврат ТекстЯчейкиИзКэша(НомерСтроки, НомерКолонки);
	КонецЕсли;
	
	Возврат СокрЛП(ТабДок.Область(НомерСтроки, НомерКолонки).Текст);
	
КонецФункции

// Возвращает текст ячейки с учётом горизонтального объединения (ищет влево).
Функция ТекстЯчейкиСГоризонтальнымОбъединением(ТабДок, НомерСтроки, НомерКолонки)
	
	Если КэшТекстовЯчеек <> Неопределено Тогда
		Возврат ТекстЯчейкиИзКэша(НомерСтроки, НомерКолонки);
	КонецЕсли;
	
	Текст = ТекстЯчейки(ТабДок, НомерСтроки, НомерКолонки);
	Если Не ПустаяСтрока(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Для Сдвиг = 1 По НомерКолонки - 1 Цикл
		Текст = ТекстЯчейки(ТабДок, НомерСтроки, НомерКолонки - Сдвиг);
		Если Не ПустаяСтрока(Текст) Тогда
			Возврат Текст;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Возвращает текст ячейки с учётом объединённых областей (ищет влево и вверх).
Функция ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, НомерКолонки)
	
	Если КэшТекстовЯчеек <> Неопределено Тогда
		Текст = ТекстЯчейкиИзКэша(НомерСтроки, НомерКолонки);
		Если Не ПустаяСтрока(Текст) Тогда
			Возврат Текст;
		КонецЕсли;
		// Вертикальное объединение только для текущей строки (не из кэша целиком).
		Для Сдвиг = 1 По НомерСтроки - 1 Цикл
			Текст = ТекстСыройЯчейкиИзКэша(НомерСтроки - Сдвиг, НомерКолонки);
			Если Не ПустаяСтрока(Текст) Тогда
				Возврат Текст;
			КонецЕсли;
		КонецЦикла;
		Возврат "";
	КонецЕсли;
	
	Текст = ТекстЯчейки(ТабДок, НомерСтроки, НомерКолонки);
	Если Не ПустаяСтрока(Текст) Тогда
		Возврат Текст;
	КонецЕсли;
	
	Для Сдвиг = 1 По НомерКолонки - 1 Цикл
		Текст = ТекстЯчейки(ТабДок, НомерСтроки, НомерКолонки - Сдвиг);
		Если Не ПустаяСтрока(Текст) Тогда
			Возврат Текст;
		КонецЕсли;
	КонецЦикла;
	
	Для Сдвиг = 1 По НомерСтроки - 1 Цикл
		Текст = ТекстЯчейки(ТабДок, НомерСтроки - Сдвиг, НомерКолонки);
		Если Не ПустаяСтрока(Текст) Тогда
			Возврат Текст;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Строит описание колонок по строкам заголовка.
Функция ПостроитьОписаниеКолонок(ТабДок, КоличествоСтрокЗаголовка)
	
	ОписаниеКолонок = Новый ТаблицаЗначений;
	ОписаниеКолонок.Колонки.Добавить("НомерКолонки", Новый ОписаниеТипов("Число"));
	ОписаниеКолонок.Колонки.Добавить("Группа", Новый ОписаниеТипов("Строка"));
	ОписаниеКолонок.Колонки.Добавить("Подзаголовок", Новый ОписаниеТипов("Строка"));
	ОписаниеКолонок.Колонки.Добавить("ТипКолонки", Новый ОписаниеТипов("Строка"));
	ОписаниеКолонок.Колонки.Добавить("ИмяКолонки", Новый ОписаниеТипов("Строка"));
	ОписаниеКолонок.Колонки.Добавить("ВидПодколонки", Новый ОписаниеТипов("Строка"));
	
	ТекущаяГруппа = "";
	СтрокаВерхнегоЗаголовка = 1;
	СтрокаНижнегоЗаголовка = КоличествоСтрокЗаголовка;
	
	Для НомерКолонки = 1 По ТабДок.ШиринаТаблицы Цикл
		
		Группа = ТекстЯчейкиСГоризонтальнымОбъединением(ТабДок, СтрокаВерхнегоЗаголовка, НомерКолонки);
		Если Не ПустаяСтрока(Группа) Тогда
			ТекущаяГруппа = Группа;
		КонецЕсли;
		
		Подзаголовок = "";
		Если СтрокаНижнегоЗаголовка > СтрокаВерхнегоЗаголовка Тогда
			Подзаголовок = ТекстЯчейкиСГоризонтальнымОбъединением(ТабДок, СтрокаНижнегоЗаголовка, НомерКолонки);
		КонецЕсли;
		
		Если ПустаяСтрока(Группа) И ПустаяСтрока(Подзаголовок) Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаОписания = ОписаниеКолонок.Добавить();
		СтрокаОписания.НомерКолонки = НомерКолонки;
		СтрокаОписания.Группа = ТекущаяГруппа;
		СтрокаОписания.Подзаголовок = Подзаголовок;
		
		Если ПустаяСтрока(Подзаголовок) Тогда
			СтрокаОписания.ТипКолонки = "Фиксированная";
			СтрокаОписания.ИмяКолонки = НормализоватьИмяКолонки(ТекущаяГруппа);
			СтрокаОписания.ВидПодколонки = "";
		Иначе
			СтрокаОписания.ТипКолонки = "Группированная";
			СтрокаОписания.ИмяКолонки = НормализоватьИмяКолонки(ТекущаяГруппа + "_" + Подзаголовок);
			СтрокаОписания.ВидПодколонки = ОпределитьВидПодколонки(Подзаголовок);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ОписаниеКолонок;
	
КонецФункции

// Определяет вид подколонки группы:
// ДатаНачала, ДатаОкончания, Протокол, Удостоверение или Прочее.
Функция ОпределитьВидПодколонки(Подзаголовок)
	
	Если ЭтоКолонкаДатыНачалаОбучения(Подзаголовок) Тогда
		Возврат "ДатаНачала";
	ИначеЕсли ЭтоКолонкаДатыОкончанияОбучения(Подзаголовок) Тогда
		Возврат "ДатаОкончания";
	ИначеЕсли ЭтоКолонкаНомераУдостоверенияОбучения(Подзаголовок) Тогда
		Возврат "Удостоверение";
	ИначеЕсли ЭтоКолонкаНомераДокументаОбучения(Подзаголовок) Тогда
		Возврат "Протокол";
	ИначеЕсли ЭтоКолонкаДатыОбучения(Подзаголовок) Тогда
		// Старый формат: одна колонка "Дата" / "Дата обучения".
		Возврат "ДатаНачала";
	Иначе
		Возврат "Прочее";
	КонецЕсли;
	
КонецФункции

// Приводит текст заголовка к единому виду для поиска фрагментов (протокол, св-во, уд-во).
Функция НормализоватьТекстЗаголовкаДляПоиска(Текст)
	
	Результат = ВРег(СокрЛП(Текст));
	Результат = СтрЗаменить(Результат, "-", "_");
	Результат = СтрЗаменить(Результат, " ", "_");
	
	Возврат Результат;
	
КонецФункции

// Нормализует имя колонки для таблицы значений (допустимый идентификатор 1С).
Функция НормализоватьИмяКолонки(ИсходноеИмя)
	
	Буквы = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"
		+ "АБВГДЕЁЖЗИЙКЛМНОПРСТУФХЦЧШЩЪЫЬЭЮЯабвгдеёжзийклмнопрстуфхцчшщъыьэюя";
	ДопустимыеСимволы = Буквы + "0123456789_";
	
	Результат = СокрЛП(ИсходноеИмя);
	Результат = СтрЗаменить(Результат, "№", "Номер");
	
	НовоеИмя = "";
	ПредыдущийПодчеркивание = Ложь;
	
	Для Позиция = 1 По СтрДлина(Результат) Цикл
		
		Символ = Сред(Результат, Позиция, 1);
		
		Если СтрНайти(ДопустимыеСимволы, Символ) > 0 Тогда
			НовоеИмя = НовоеИмя + Символ;
			ПредыдущийПодчеркивание = (Символ = "_");
		ИначеЕсли Не ПредыдущийПодчеркивание И Не ПустаяСтрока(НовоеИмя) Тогда
			НовоеИмя = НовоеИмя + "_";
			ПредыдущийПодчеркивание = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Пока СтрДлина(НовоеИмя) > 0 И Прав(НовоеИмя, 1) = "_" Цикл
		НовоеИмя = Лев(НовоеИмя, СтрДлина(НовоеИмя) - 1);
	КонецЦикла;
	
	Если ПустаяСтрока(НовоеИмя) Тогда
		Возврат "Колонка";
	КонецЕсли;
	
	Если СтрНайти(Буквы, Лев(НовоеИмя, 1)) = 0 Тогда
		НовоеИмя = "Колонка_" + НовоеИмя;
	КонецЕсли;
	
	Если СтрДлина(НовоеИмя) > 80 Тогда
		НовоеИмя = Лев(НовоеИмя, 80);
	КонецЕсли;
	
	Возврат НовоеИмя;
	
КонецФункции

// Определяет первую строку с данными (после заголовка).
Функция ОпределитьСтрокуНачалаДанных(ТабДок, ОписаниеКолонок, КоличествоСтрокЗаголовка)
	
	СлужебныеКолонки = ОпределитьНомераСлужебныхКолонок(ОписаниеКолонок);
	НомерКолонкиКлюча = НомерКолонкиИдентификатораСтроки(СлужебныеКолонки);
	
	Если НомерКолонкиКлюча = 0 Тогда
		Возврат КоличествоСтрокЗаголовка + 1;
	КонецЕсли;
	
	Для НомерСтроки = КоличествоСтрокЗаголовка + 1 По ТабДок.ВысотаТаблицы Цикл
		
		Если Не ПустаяСтрока(ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, НомерКолонкиКлюча)) Тогда
			Возврат НомерСтроки;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат КоличествоСтрокЗаголовка + 1;
	
КонецФункции

// Возвращает номер колонки по фрагменту имени.
Функция НомерКолонкиПоИмени(ОписаниеКолонок, ФрагментИмени)
	
	ФрагментВРег = ВРег(ФрагментИмени);
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		Если СтрокаОписания.ТипКолонки <> "Фиксированная" Тогда
			Продолжить;
		КонецЕсли;
		Если СтрНайти(ВРег(СтрокаОписания.Группа), ФрагментВРег) > 0
			Или СтрНайти(ВРег(СтрокаОписания.ИмяКолонки), ФрагментВРег) > 0 Тогда
			Возврат СтрокаОписания.НомерКолонки;
		КонецЕсли;
	КонецЦикла;
	
	Возврат 0;
	
КонецФункции

// Определяет, относится ли текст заголовка к колонке ФИО.
Функция ЭтоКолонкаФИО(ТекстГруппы, ТекстИмени)
	
	Возврат СтрНайти(ТекстГруппы, "ФИО") > 0 Или СтрНайти(ТекстИмени, "ФИО") > 0
		Или СтрНайти(ТекстГруппы, "ФАМИЛИ") > 0 Или СтрНайти(ТекстИмени, "ФАМИЛИ") > 0
		Или СтрНайти(ТекстГруппы, "Ф.И.О") > 0 Или СтрНайти(ТекстИмени, "Ф.И.О") > 0
		Или СтрНайти(ТекстГруппы, "ИМЯ_ОТЧЕСТ") > 0 Или СтрНайти(ТекстИмени, "ИМЯ_ОТЧЕСТ") > 0
		Или СтрНайти(ТекстГруппы, "ИМЯ ОТЧЕСТ") > 0 Или СтрНайти(ТекстИмени, "ИМЯ ОТЧЕСТ") > 0;
	
КонецФункции

// Определяет, относится ли текст заголовка к колонке должности.
Функция ЭтоКолонкаДолжность(ТекстГруппы, ТекстИмени)
	
	Возврат СтрНайти(ТекстГруппы, "ДОЛЖНОСТ") > 0 Или СтрНайти(ТекстИмени, "ДОЛЖНОСТ") > 0;
	
КонецФункции

// Возвращает Истина, если колонка не является подколонкой программы обучения.
Функция ЭтоНеКолонкаПрограммыОбучения(СтрокаОписания)
	
	Возврат Не ЭтоВидПодколонкиПрограммыОбучения(СтрокаОписания.ВидПодколонки);
	
КонецФункции

// Проверяет тексты заголовка колонки (группа, подзаголовок, имя) на соответствие виду.
Функция ЗаголовокКолонкиСоответствуетВиду(СтрокаОписания, ВидКолонки)
	
	Если Не ЭтоНеКолонкаПрограммыОбучения(СтрокаОписания) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ТекстыЗаголовка = Новый Массив;
	ИменаПолейЗаголовка = Новый Массив;
	ИменаПолейЗаголовка.Добавить("Группа");
	ИменаПолейЗаголовка.Добавить("Подзаголовок");
	ИменаПолейЗаголовка.Добавить("ИмяКолонки");
	
	Для Каждого ИмяПоля Из ИменаПолейЗаголовка Цикл
		ТекстПоля = ВРег(СокрЛП(СтрокаОписания[ИмяПоля]));
		Если Не ПустаяСтрока(ТекстПоля) Тогда
			ТекстыЗаголовка.Добавить(ТекстПоля);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекстЗаголовка Из ТекстыЗаголовка Цикл
		
		Если ВидКолонки = "ФИО" И ЭтоКолонкаФИО(ТекстЗаголовка, ТекстЗаголовка) Тогда
			Возврат Истина;
		ИначеЕсли ВидКолонки = "Должность" И ЭтоКолонкаДолжность(ТекстЗаголовка, ТекстЗаголовка) Тогда
			Возврат Истина;
		ИначеЕсли ВидКолонки = "НомерПП"
			И (СтрНайти(ТекстЗаголовка, "П/П") > 0
				Или СтрНайти(ТекстЗаголовка, "ИНДЕКС") > 0
				Или СтрНайти(ТекстЗаголовка, "НОМЕРПП") > 0) Тогда
			Возврат Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Ищет имя колонки в широкой таблице по виду служебного поля.
Функция НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, ВидКолонки)
	
	Если ТаблицаДанных = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Для Каждого Колонка Из ТаблицаДанных.Колонки Цикл
		
		ТекстИмени = ВРег(СокрЛП(Колонка.Имя));
		
		Если ВидКолонки = "ФИО" И ЭтоКолонкаФИО(ТекстИмени, ТекстИмени) Тогда
			Возврат Колонка.Имя;
		ИначеЕсли ВидКолонки = "Должность" И ЭтоКолонкаДолжность(ТекстИмени, ТекстИмени) Тогда
			Возврат Колонка.Имя;
		ИначеЕсли ВидКолонки = "НомерПП"
			И (СтрНайти(ТекстИмени, "П/П") > 0
				Или СтрНайти(ТекстИмени, "ИНДЕКС") > 0
				Или СтрНайти(ТекстИмени, "НОМЕРПП") > 0) Тогда
			Возврат Колонка.Имя;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Возвращает Истина для служебных колонок (п/п, ФИО, должность), в т.ч. с двухстрочным заголовком.
Функция ЭтоСлужебнаяКолонкаДляРазбора(СтрокаОписания)
	
	Если СтрокаОписания.ТипКолонки = "Фиксированная" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтрокаОписания.ТипКолонки = "Группированная"
		И Не ЭтоВидПодколонкиПрограммыОбучения(СтрокаОписания.ВидПодколонки) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Определяет номера служебных колонок: п/п, ФИО, Должность.
Функция ОпределитьНомераСлужебныхКолонок(ОписаниеКолонок)
	
	Результат = Новый Структура("НомерПП, НомерФИО, НомерДолжность", 0, 0, 0);
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		
		Если Результат.НомерПП = 0 И ЗаголовокКолонкиСоответствуетВиду(СтрокаОписания, "НомерПП") Тогда
			Результат.НомерПП = СтрокаОписания.НомерКолонки;
		КонецЕсли;
		
		Если Результат.НомерФИО = 0 И ЗаголовокКолонкиСоответствуетВиду(СтрокаОписания, "ФИО") Тогда
			Результат.НомерФИО = СтрокаОписания.НомерКолонки;
		КонецЕсли;
		
		Если Результат.НомерДолжность = 0 И ЗаголовокКолонкиСоответствуетВиду(СтрокаОписания, "Должность") Тогда
			Результат.НомерДолжность = СтрокаОписания.НомерКолонки;
		КонецЕсли;
		
	КонецЦикла;
	
	Если Результат.НомерПП = 0 Тогда
		Результат.НомерПП = 1;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает номер колонки-идентификатора строки (ФИО или должность).
Функция НомерКолонкиИдентификатораСтроки(СлужебныеКолонки)
	
	Если СлужебныеКолонки.НомерФИО > 0 Тогда
		Возврат СлужебныеКолонки.НомерФИО;
	КонецЕсли;
	
	Если СлужебныеКолонки.НомерДолжность > 0 Тогда
		Возврат СлужебныеКолонки.НомерДолжность;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

// Формирует широкую таблицу: одна строка на сотрудника, все колонки — плоский список.
Функция СформироватьШирокуюТаблицу(ТабДок, ОписаниеКолонок, СтрокаНачалаДанных)
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	ИменаКолонок = Новый Соответствие;
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		БазовоеИмя = НормализоватьИмяКолонки(СтрокаОписания.ИмяКолонки);
		Если ПустаяСтрока(БазовоеИмя) Тогда
			БазовоеИмя = "Колонка_" + Формат(СтрокаОписания.НомерКолонки, "ЧГ=0");
		КонецЕсли;
		ИмяКолонки = УникальноеИмяКолонки(ТаблицаДанных, БазовоеИмя);
		ИменаКолонок.Вставить(СтрокаОписания.НомерКолонки, ИмяКолонки);
		
		Если СтрокаОписания.ВидПодколонки = "Дата"
			Или СтрокаОписания.ВидПодколонки = "ДатаНачала"
			Или СтрокаОписания.ВидПодколонки = "ДатаОкончания" Тогда
			ТаблицаДанных.Колонки.Добавить(ИмяКолонки, Новый ОписаниеТипов("Дата"));
		Иначе
			ТаблицаДанных.Колонки.Добавить(ИмяКолонки, Новый ОписаниеТипов("Строка"));
		КонецЕсли;
	КонецЦикла;
	
	СлужебныеКолонки = ОпределитьНомераСлужебныхКолонок(ОписаниеКолонок);
	ИмяКолонкиФИО = "";
	ИмяКолонкиДолжность = "";
	
	Если СлужебныеКолонки.НомерФИО > 0 Тогда
		ИмяКолонкиФИО = ИменаКолонок.Получить(СлужебныеКолонки.НомерФИО);
	КонецЕсли;
	
	Если СлужебныеКолонки.НомерДолжность > 0 Тогда
		ИмяКолонкиДолжность = ИменаКолонок.Получить(СлужебныеКолонки.НомерДолжность);
	КонецЕсли;
	
	ПоследнееФИО = "";
	ПоследняяДолжность = "";
	ПустыхСтрокПодряд = 0;
	
	Для НомерСтроки = СтрокаНачалаДанных По ТабДок.ВысотаТаблицы Цикл
		
		Если Не СтрокаЛистаСодержитСодержательныеДанные(НомерСтроки, ОписаниеКолонок, СлужебныеКолонки) Тогда
			ПустыхСтрокПодряд = ПустыхСтрокПодряд + 1;
			Если ПустыхСтрокПодряд >= 2 Тогда
				Прервать;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		ПустыхСтрокПодряд = 0;
		
		СтрокаДанных = ТаблицаДанных.Добавить();
		
		Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
			ИмяКолонки = ИменаКолонок.Получить(СтрокаОписания.НомерКолонки);
			
			Если СтрокаОписания.ВидПодколонки = "Протокол"
				Или СтрокаОписания.ВидПодколонки = "Удостоверение"
				Или СтрокаОписания.ВидПодколонки = "Дата"
				Или СтрокаОписания.ВидПодколонки = "ДатаНачала"
				Или СтрокаОписания.ВидПодколонки = "ДатаОкончания" Тогда
				ЗначениеЯчейки = ТекстСыройЯчейкиИзКэша(НомерСтроки, СтрокаОписания.НомерКолонки);
			Иначе
				ЗначениеЯчейки = ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, СтрокаОписания.НомерКолонки);
			КонецЕсли;
			
			Если СтрокаОписания.ВидПодколонки = "Дата"
				Или СтрокаОписания.ВидПодколонки = "ДатаНачала"
				Или СтрокаОписания.ВидПодколонки = "ДатаОкончания" Тогда
				СтрокаДанных[ИмяКолонки] = ДатаИзТекстаЯчейки(ЗначениеЯчейки);
			Иначе
				СтрокаДанных[ИмяКолонки] = ЗначениеЯчейки;
			КонецЕсли;
		КонецЦикла;
		
		Если Не ПустаяСтрока(ИмяКолонкиФИО) Тогда
			ФИО = СокрЛП(СтрокаДанных[ИмяКолонкиФИО]);
			Если ПустаяСтрока(ФИО) И Не ПустаяСтрока(ПоследнееФИО) Тогда
				СтрокаДанных[ИмяКолонкиФИО] = ПоследнееФИО;
			ИначеЕсли Не ПустаяСтрока(ФИО) Тогда
				ПоследнееФИО = ФИО;
			КонецЕсли;
		КонецЕсли;
		
		Если Не ПустаяСтрока(ИмяКолонкиДолжность) Тогда
			Должность = СокрЛП(СтрокаДанных[ИмяКолонкиДолжность]);
			Если ПустаяСтрока(Должность) И Не ПустаяСтрока(ПоследняяДолжность) Тогда
				СтрокаДанных[ИмяКолонкиДолжность] = ПоследняяДолжность;
			ИначеЕсли Не ПустаяСтрока(Должность) Тогда
				ПоследняяДолжность = Должность;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТаблицаДанных;
	
КонецФункции

// Формирует длинную таблицу обучения из широкой таблицы (надёжный путь — те же значения, что в ТаблицаДанных).
Функция СформироватьДлиннуюТаблицуОбученияИзТаблицыДанных(ТаблицаДанных)
	
	ТаблицаОбучения = НоваяТаблицаОбучения();
	
	ИмяКолонкиФИО = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "ФИО");
	ИмяКолонкиДолжность = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "Должность");
	ИмяКолонкиПП = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "НомерПП");
	ГруппыПрограмм = НайтиГруппыПрограммВТаблицеДанных(ТаблицаДанных);
	
	ПоследнееФИО = "";
	ПоследняяДолжность = "";
	
	Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
		
		ФИО = "";
		Если Не ПустаяСтрока(ИмяКолонкиФИО) Тогда
			ФИО = СокрЛП(Строка(СтрокаДанных[ИмяКолонкиФИО]));
		КонецЕсли;
		
		Должность = "";
		Если Не ПустаяСтрока(ИмяКолонкиДолжность) Тогда
			Должность = СокрЛП(Строка(СтрокаДанных[ИмяКолонкиДолжность]));
		КонецЕсли;
		
		ЕстьДанныеПрограмм = СтрокаДанныхСодержитДанныеПрограмм(СтрокаДанных, ГруппыПрограмм);
		
		Если ПустаяСтрока(ФИО) И ПустаяСтрока(Должность) И Не ЕстьДанныеПрограмм Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ПустаяСтрока(ФИО) Тогда
			ПоследнееФИО = ФИО;
		ИначеЕсли ЕстьДанныеПрограмм И Не ПустаяСтрока(ПоследнееФИО) Тогда
			ФИО = ПоследнееФИО;
		КонецЕсли;
		
		Если Не ПустаяСтрока(Должность) Тогда
			ПоследняяДолжность = Должность;
		ИначеЕсли ЕстьДанныеПрограмм И Не ПустаяСтрока(ПоследняяДолжность) Тогда
			Должность = ПоследняяДолжность;
		КонецЕсли;
		
		НомерПП = 0;
		Если Не ПустаяСтрока(ИмяКолонкиПП) Тогда
			НомерПП = ЧислоИзТекстаЯчейки(Строка(СтрокаДанных[ИмяКолонкиПП]));
		КонецЕсли;
		
		Для Каждого ГруппаПрограммы Из ГруппыПрограмм Цикл
			
			ДанныеПрограммы = ПрочитатьДанныеПрограммыИзСтрокиДанных(СтрокаДанных, ГруппаПрограммы);
			
			Если Не ЕстьЗаполненныеДанныеПрограммы(ДанныеПрограммы) Тогда
				Продолжить;
			КонецЕсли;
			
			ДобавитьСтрокуТаблицыОбучения(
				ТаблицаОбучения,
				НомерПП,
				ФИО,
				Должность,
				ГруппаПрограммы.Программа,
				ДанныеПрограммы);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаОбучения;
	
КонецФункции

// Создаёт пустую таблицу обучения в длинном формате.
Функция НоваяТаблицаОбучения()
	
	ТаблицаОбучения = Новый ТаблицаЗначений;
	ТаблицаОбучения.Колонки.Добавить("НомерПП", Новый ОписаниеТипов("Число"));
	ТаблицаОбучения.Колонки.Добавить("ФИО", Новый ОписаниеТипов("Строка"));
	ТаблицаОбучения.Колонки.Добавить("Должность", Новый ОписаниеТипов("Строка"));
	ТаблицаОбучения.Колонки.Добавить("Программа", Новый ОписаниеТипов("Строка"));
	ТаблицаОбучения.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	ТаблицаОбучения.Колонки.Добавить("ДатаОкончания", Новый ОписаниеТипов("Дата"));
	ТаблицаОбучения.Колонки.Добавить("НомерПротокола", Новый ОписаниеТипов("Строка"));
	ТаблицаОбучения.Колонки.Добавить("НомерУдостоверения", Новый ОписаниеТипов("Строка"));
	ТаблицаОбучения.Колонки.Добавить("ДатаОбучения", Новый ОписаниеТипов("Дата")); // = ДатаНачала, для совместимости
	
	Возврат ТаблицаОбучения;
	
КонецФункции

// Добавляет строку в таблицу обучения.
Процедура ДобавитьСтрокуТаблицыОбучения(ТаблицаОбучения, НомерПП, ФИО, Должность, Программа, ДанныеПрограммы)
	
	СтрокаОбучения = ТаблицаОбучения.Добавить();
	СтрокаОбучения.НомерПП = НомерПП;
	СтрокаОбучения.ФИО = ФИО;
	СтрокаОбучения.Должность = Должность;
	СтрокаОбучения.Программа = Программа;
	СтрокаОбучения.ДатаНачала = ДанныеПрограммы.ДатаНачала;
	СтрокаОбучения.ДатаОкончания = ДанныеПрограммы.ДатаОкончания;
	СтрокаОбучения.НомерПротокола = ДанныеПрограммы.НомерПротокола;
	СтрокаОбучения.НомерУдостоверения = ДанныеПрограммы.НомерУдостоверения;
	СтрокаОбучения.ДатаОбучения = ДанныеПрограммы.ДатаНачала;
	
КонецПроцедуры

// Возвращает Истина, если в данных программы есть хотя бы одно заполненное поле.
Функция ЕстьЗаполненныеДанныеПрограммы(ДанныеПрограммы)
	
	Возврат Не ПустаяСтрока(ДанныеПрограммы.НомерПротокола)
		Или Не ПустаяСтрока(ДанныеПрограммы.НомерУдостоверения)
		Или (ЗначениеЗаполнено(ДанныеПрограммы.ДатаНачала) И ДанныеПрограммы.ДатаНачала <> '00010101')
		Или (ЗначениеЗаполнено(ДанныеПрограммы.ДатаОкончания) И ДанныеПрограммы.ДатаОкончания <> '00010101');
	
КонецФункции

// Читает поля программы из строки широкой таблицы.
Функция ПрочитатьДанныеПрограммыИзСтрокиДанных(СтрокаДанных, ГруппаПрограммы)
	
	Результат = Новый Структура(
		"ДатаНачала, ДатаОкончания, НомерПротокола, НомерУдостоверения",
		'00010101', '00010101', "", "");
	
	Если Не ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиПротокол) Тогда
		Результат.НомерПротокола = СокрЛП(Строка(СтрокаДанных[ГруппаПрограммы.ИмяКолонкиПротокол]));
	КонецЕсли;
	
	Если Не ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиУдостоверение) Тогда
		Результат.НомерУдостоверения = СокрЛП(Строка(СтрокаДанных[ГруппаПрограммы.ИмяКолонкиУдостоверение]));
	КонецЕсли;
	
	Если Не ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиДатаНачала) Тогда
		Результат.ДатаНачала = ДатаИзЗначенияЯчейки(СтрокаДанных[ГруппаПрограммы.ИмяКолонкиДатаНачала]);
	КонецЕсли;
	
	Если Не ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиДатаОкончания) Тогда
		Результат.ДатаОкончания = ДатаИзЗначенияЯчейки(СтрокаДанных[ГруппаПрограммы.ИмяКолонкиДатаОкончания]);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Преобразует значение ячейки широкой таблицы в дату.
Функция ДатаИзЗначенияЯчейки(ЗначениеДаты)
	
	Если ТипЗнч(ЗначениеДаты) = Тип("Дата") И ЗначениеДаты <> '00010101' Тогда
		Возврат ЗначениеДаты;
	КонецЕсли;
	
	Возврат ДатаИзТекстаЯчейки(ЗначениеДаты);
	
КонецФункции

// Находит группы колонок программ по именам колонок широкой таблицы.
Функция НайтиГруппыПрограммВТаблицеДанных(ТаблицаДанных)
	
	СоответствиеГрупп = Новый Соответствие;
	
	Для Каждого Колонка Из ТаблицаДанных.Колонки Цикл
		
		ТекстИмени = ВРег(СокрЛП(Колонка.Имя));
		
		Если ЭтоКолонкаФИО(ТекстИмени, ТекстИмени)
			Или ЭтоКолонкаДолжность(ТекстИмени, ТекстИмени)
			Или СтрНайти(ТекстИмени, "П/П") > 0
			Или СтрНайти(ТекстИмени, "ИНДЕКС") > 0
			Или СтрНайти(ТекстИмени, "НОМЕРПП") > 0 Тогда
			Продолжить;
		КонецЕсли;
		
		КлючГруппы = ИзвлечьКлючГруппыПрограммыИзИмениКолонки(Колонка.Имя);
		Если ПустаяСтрока(КлючГруппы) Тогда
			Продолжить;
		КонецЕсли;
		
		КодПрограммы = ИзвлечьКодПрограммыИзИмениКолонки(Колонка.Имя);
		
		ГруппаПрограммы = СоответствиеГрупп.Получить(КлючГруппы);
		Если ГруппаПрограммы = Неопределено Тогда
			ГруппаПрограммы = НоваяСтруктураГруппыПрограммыИзИменКолонок(КодПрограммы);
			СоответствиеГрупп.Вставить(КлючГруппы, ГруппаПрограммы);
		КонецЕсли;
		
		Если ЭтоКолонкаНомераУдостоверенияОбучения(ТекстИмени) Тогда
			ГруппаПрограммы.ИмяКолонкиУдостоверение = Колонка.Имя;
		ИначеЕсли ЭтоКолонкаНомераДокументаОбучения(ТекстИмени) Тогда
			ГруппаПрограммы.ИмяКолонкиПротокол = Колонка.Имя;
		ИначеЕсли ЭтоКолонкаДатыНачалаОбучения(ТекстИмени) Тогда
			ГруппаПрограммы.ИмяКолонкиДатаНачала = Колонка.Имя;
		ИначеЕсли ЭтоКолонкаДатыОкончанияОбучения(ТекстИмени) Тогда
			ГруппаПрограммы.ИмяКолонкиДатаОкончания = Колонка.Имя;
		ИначеЕсли ЭтоКолонкаДатыОбучения(ТекстИмени) Тогда
			Если ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиДатаНачала) Тогда
				ГруппаПрограммы.ИмяКолонкиДатаНачала = Колонка.Имя;
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Массив;
	Для Каждого Элемент Из СоответствиеГрупп Цикл
		ГруппаПрограммы = Элемент.Значение;
		Если ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиПротокол)
			И ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиУдостоверение)
			И ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиДатаНачала)
			И ПустаяСтрока(ГруппаПрограммы.ИмяКолонкиДатаОкончания) Тогда
			Продолжить;
		КонецЕсли;
		Результат.Добавить(ГруппаПрограммы);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создаёт структуру группы программы по именам колонок широкой таблицы.
Функция НоваяСтруктураГруппыПрограммыИзИменКолонок(КодПрограммы)
	
	Возврат Новый Структура(
		"Программа, ИмяКолонкиПротокол, ИмяКолонкиУдостоверение, ИмяКолонкиДатаНачала, ИмяКолонкиДатаОкончания",
		КодПрограммы, "", "", "", "");
	
КонецФункции

// Возвращает Истина, если в строке широкой таблицы заполнены данные хотя бы одной программы.
Функция СтрокаДанныхСодержитДанныеПрограмм(СтрокаДанных, ГруппыПрограмм)
	
	Для Каждого ГруппаПрограммы Из ГруппыПрограмм Цикл
		ДанныеПрограммы = ПрочитатьДанныеПрограммыИзСтрокиДанных(СтрокаДанных, ГруппаПрограммы);
		Если ЕстьЗаполненныеДанныеПрограммы(ДанныеПрограммы) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Определяет колонку с номером удостоверения (№ уд-ия).
Функция ЭтоКолонкаНомераУдостоверенияОбучения(ТекстИмени)
	
	Текст = НормализоватьТекстЗаголовкаДляПоиска(ТекстИмени);
	
	Возврат СтрНайти(Текст, "УД_ИЯ") > 0
		Или СтрНайти(Текст, "УДОСТОВ") > 0
		Или СтрНайти(Текст, "УД_ВО") > 0;
	
КонецФункции

// Определяет колонку с номером протокола (не удостоверения).
Функция ЭтоКолонкаНомераДокументаОбучения(ТекстИмени)
	
	Текст = НормализоватьТекстЗаголовкаДляПоиска(ТекстИмени);
	
	Если СтрНайти(Текст, "ДАТА") > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЭтоКолонкаНомераУдостоверенияОбучения(ТекстИмени) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат СтрНайти(Текст, "ПРОТОКОЛ") > 0
		Или СтрНайти(Текст, "СВ_ВА") > 0
		Или СтрНайти(Текст, "СВИДЕТ") > 0;
	
КонецФункции

// Определяет колонку "Дата начала".
Функция ЭтоКолонкаДатыНачалаОбучения(ТекстИмени)
	
	Текст = НормализоватьТекстЗаголовкаДляПоиска(ТекстИмени);
	
	Возврат СтрНайти(Текст, "ДАТА") > 0 И СтрНайти(Текст, "НАЧАЛ") > 0;
	
КонецФункции

// Определяет колонку "Дата окончания".
Функция ЭтоКолонкаДатыОкончанияОбучения(ТекстИмени)
	
	Текст = НормализоватьТекстЗаголовкаДляПоиска(ТекстИмени);
	
	Возврат СтрНайти(Текст, "ДАТА") > 0
		И (СтрНайти(Текст, "ОКОНЧ") > 0 Или СтрНайти(Текст, "КОНЕЦ") > 0);
	
КонецФункции

// Определяет колонку с датой обучения (общий случай, без начала/окончания).
Функция ЭтоКолонкаДатыОбучения(ТекстИмени)
	
	Текст = НормализоватьТекстЗаголовкаДляПоиска(ТекстИмени);
	
	Если СтрНайти(Текст, "ДАТА") = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЭтоКолонкаДатыНачалаОбучения(ТекстИмени)
		Или ЭтоКолонкаДатыОкончанияОбучения(ТекстИмени) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Возвращает ключ группы колонок программы (код + суффикс пары, напр. 000000035_2).
Функция ИзвлечьКлючГруппыПрограммыИзИмениКолонки(ИмяКолонки)
	
	КодПрограммы = ИзвлечьКодПрограммыИзИмениКолонки(ИмяКолонки);
	Если ПустаяСтрока(КодПрограммы) Тогда
		Возврат "";
	КонецЕсли;
	
	СуффиксПары = ИзвлечьСуффиксПарыПрограммыИзИмениКолонки(ИмяКолонки);
	Если ПустаяСтрока(СуффиксПары) Тогда
		Возврат КодПрограммы;
	КонецЕсли;
	
	Возврат КодПрограммы + "_" + СуффиксПары;
	
КонецФункции

// Извлекает суффикс повторной пары колонок (_2, _3) из имени колонки.
Функция ИзвлечьСуффиксПарыПрограммыИзИмениКолонки(ИмяКолонки)
	
	Части = СтрРазделить(ИмяКолонки, "_", Ложь);
	Если Части.Количество() < 2 Тогда
		Возврат "";
	КонецЕсли;
	
	ПоследняяЧасть = Части[Части.Количество() - 1];
	Если СтрДлина(ПоследняяЧасть) <= 2 И ЭтоСтрокаИзЦифр(ПоследняяЧасть) Тогда
		Возврат ПоследняяЧасть;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Извлекает 9-значный код программы из имени колонки широкой таблицы.
Функция ИзвлечьКодПрограммыИзИмениКолонки(ИмяКолонки)
	
	Части = СтрРазделить(ИмяКолонки, "_", Ложь);
	
	Для Каждого Часть Из Части Цикл
		Если СтрДлина(Часть) = 9 И ЭтоСтрокаИзЦифр(Часть) Тогда
			Возврат Часть;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

// Проверяет, что строка состоит только из цифр.
Функция ЭтоСтрокаИзЦифр(Текст)
	
	Если ПустаяСтрока(Текст) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Цифры = "0123456789";
	
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		Если СтрНайти(Цифры, Сред(Текст, Позиция, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Формирует длинную таблицу обучения: одна строка на программу каждого сотрудника.
Функция СформироватьДлиннуюТаблицуОбучения(ТабДок, ОписаниеКолонок, СтрокаНачалаДанных, ТаблицаДанных = Неопределено)
	
	Если ТаблицаДанных <> Неопределено И ТаблицаДанных.Количество() > 0 Тогда
		Возврат СформироватьДлиннуюТаблицуОбученияИзТаблицыДанных(ТаблицаДанных);
	КонецЕсли;
	
	ТаблицаОбучения = НоваяТаблицаОбучения();
	
	СлужебныеКолонки = ОпределитьНомераСлужебныхКолонок(ОписаниеКолонок);
	НомерКолонкиПП = СлужебныеКолонки.НомерПП;
	НомерКолонкиФИО = СлужебныеКолонки.НомерФИО;
	НомерКолонкиДолжность = СлужебныеКолонки.НомерДолжность;
	
	ИмяКолонкиФИОВДанных = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "ФИО");
	ИмяКолонкиДолжностьВДанных = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "Должность");
	ИмяКолонкиППВДанных = НайтиИмяКолонкиВТаблицеДанных(ТаблицаДанных, "НомерПП");
	
	ГруппыПрограмм = СгруппироватьКолонкиПрограмм(ОписаниеКолонок);
	ИндексСтрокиДанных = -1;
	ПоследнееФИО = "";
	ПоследняяДолжность = "";
	ПустыхСтрокПодряд = 0;
	
	Для НомерСтроки = СтрокаНачалаДанных По ТабДок.ВысотаТаблицы Цикл
		
		Если Не СтрокаЛистаСодержитСодержательныеДанные(НомерСтроки, ОписаниеКолонок, СлужебныеКолонки) Тогда
			ПустыхСтрокПодряд = ПустыхСтрокПодряд + 1;
			Если ПустыхСтрокПодряд >= 2 Тогда
				Прервать;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		
		ПустыхСтрокПодряд = 0;
		
		ИндексСтрокиДанных = ИндексСтрокиДанных + 1;
		
		ФИО = "";
		Если НомерКолонкиФИО > 0 Тогда
			ФИО = ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, НомерКолонкиФИО);
		КонецЕсли;
		Если ПустаяСтрока(ФИО) И Не ПустаяСтрока(ИмяКолонкиФИОВДанных)
			И ИндексСтрокиДанных < ТаблицаДанных.Количество() Тогда
			ФИО = СокрЛП(ТаблицаДанных[ИндексСтрокиДанных][ИмяКолонкиФИОВДанных]);
		КонецЕсли;
		
		НомерПП = 0;
		Если НомерКолонкиПП > 0 Тогда
			НомерПП = ЧислоИзТекстаЯчейки(ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, НомерКолонкиПП));
		КонецЕсли;
		Если НомерПП = 0 И Не ПустаяСтрока(ИмяКолонкиППВДанных)
			И ИндексСтрокиДанных < ТаблицаДанных.Количество() Тогда
			НомерПП = ЧислоИзТекстаЯчейки(ТаблицаДанных[ИндексСтрокиДанных][ИмяКолонкиППВДанных]);
		КонецЕсли;
		
		Должность = "";
		Если НомерКолонкиДолжность > 0 Тогда
			Должность = ТекстЯчейкиСУчетомОбъединения(ТабДок, НомерСтроки, НомерКолонкиДолжность);
		КонецЕсли;
		Если ПустаяСтрока(Должность) И Не ПустаяСтрока(ИмяКолонкиДолжностьВДанных)
			И ИндексСтрокиДанных < ТаблицаДанных.Количество() Тогда
			Должность = СокрЛП(ТаблицаДанных[ИндексСтрокиДанных][ИмяКолонкиДолжностьВДанных]);
		КонецЕсли;
		
		Если Не ПустаяСтрока(ФИО) Тогда
			ПоследнееФИО = ФИО;
		ИначеЕсли СтрокаЛистаСодержитДанныеПрограмм(НомерСтроки, ОписаниеКолонок)
			И Не ПустаяСтрока(ПоследнееФИО) Тогда
			ФИО = ПоследнееФИО;
		КонецЕсли;
		
		Если Не ПустаяСтрока(Должность) Тогда
			ПоследняяДолжность = Должность;
		ИначеЕсли СтрокаЛистаСодержитДанныеПрограмм(НомерСтроки, ОписаниеКолонок)
			И Не ПустаяСтрока(ПоследняяДолжность) Тогда
			Должность = ПоследняяДолжность;
		КонецЕсли;
		
		Для Каждого ГруппаПрограммы Из ГруппыПрограмм Цикл
			
			ДанныеПрограммы = ПрочитатьДанныеПрограммыИзСтрокиЛиста(НомерСтроки, ГруппаПрограммы);
			
			Если Не ЕстьЗаполненныеДанныеПрограммы(ДанныеПрограммы) Тогда
				Продолжить;
			КонецЕсли;
			
			ДобавитьСтрокуТаблицыОбучения(
				ТаблицаОбучения,
				НомерПП,
				ФИО,
				Должность,
				ГруппаПрограммы.Программа,
				ДанныеПрограммы);
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТаблицаОбучения;
	
КонецФункции

// Читает поля программы из строки табличного документа по номерам колонок.
Функция ПрочитатьДанныеПрограммыИзСтрокиЛиста(НомерСтроки, ГруппаПрограммы)
	
	Результат = Новый Структура(
		"ДатаНачала, ДатаОкончания, НомерПротокола, НомерУдостоверения",
		'00010101', '00010101', "", "");
	
	Если ГруппаПрограммы.КолонкаПротокол > 0 Тогда
		Результат.НомерПротокола = ТекстСыройЯчейкиИзКэша(НомерСтроки, ГруппаПрограммы.КолонкаПротокол);
	КонецЕсли;
	
	Если ГруппаПрограммы.КолонкаУдостоверение > 0 Тогда
		Результат.НомерУдостоверения = ТекстСыройЯчейкиИзКэша(НомерСтроки, ГруппаПрограммы.КолонкаУдостоверение);
	КонецЕсли;
	
	Если ГруппаПрограммы.КолонкаДатаНачала > 0 Тогда
		Результат.ДатаНачала = ДатаИзТекстаЯчейки(
			ТекстСыройЯчейкиИзКэша(НомерСтроки, ГруппаПрограммы.КолонкаДатаНачала));
	КонецЕсли;
	
	Если ГруппаПрограммы.КолонкаДатаОкончания > 0 Тогда
		Результат.ДатаОкончания = ДатаИзТекстаЯчейки(
			ТекстСыройЯчейкиИзКэша(НомерСтроки, ГруппаПрограммы.КолонкаДатаОкончания));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Группирует колонки программ по имени группы.
Функция СгруппироватьКолонкиПрограмм(ОписаниеКолонок)
	
	СоответствиеГрупп = Новый Соответствие;
	
	Для Каждого СтрокаОписания Из ОписаниеКолонок Цикл
		
		Если СтрокаОписания.ТипКолонки <> "Группированная" Тогда
			Продолжить;
		КонецЕсли;
		
		КлючГруппы = ИзвлечьКлючГруппыПрограммыИзИмениКолонки(СтрокаОписания.ИмяКолонки);
		Если ПустаяСтрока(КлючГруппы) Тогда
			КлючГруппы = СтрокаОписания.Группа;
		КонецЕсли;
		
		КодПрограммы = ИзвлечьКодПрограммыИзИмениКолонки(СтрокаОписания.ИмяКолонки);
		Если ПустаяСтрока(КодПрограммы) Тогда
			КодПрограммы = СтрокаОписания.Группа;
		КонецЕсли;
		
		ГруппаПрограммы = СоответствиеГрупп.Получить(КлючГруппы);
		Если ГруппаПрограммы = Неопределено Тогда
			ГруппаПрограммы = НоваяСтруктураГруппыПрограммыИзНомеровКолонок(КодПрограммы);
			СоответствиеГрупп.Вставить(КлючГруппы, ГруппаПрограммы);
		КонецЕсли;
		
		Если СтрокаОписания.ВидПодколонки = "Протокол" Тогда
			ГруппаПрограммы.КолонкаПротокол = СтрокаОписания.НомерКолонки;
		ИначеЕсли СтрокаОписания.ВидПодколонки = "Удостоверение" Тогда
			ГруппаПрограммы.КолонкаУдостоверение = СтрокаОписания.НомерКолонки;
		ИначеЕсли СтрокаОписания.ВидПодколонки = "ДатаНачала"
			Или СтрокаОписания.ВидПодколонки = "Дата" Тогда
			ГруппаПрограммы.КолонкаДатаНачала = СтрокаОписания.НомерКолонки;
		ИначеЕсли СтрокаОписания.ВидПодколонки = "ДатаОкончания" Тогда
			ГруппаПрограммы.КолонкаДатаОкончания = СтрокаОписания.НомерКолонки;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат = Новый Массив;
	Для Каждого Элемент Из СоответствиеГрупп Цикл
		ГруппаПрограммы = Элемент.Значение;
		Если ГруппаПрограммы.КолонкаПротокол = 0
			И ГруппаПрограммы.КолонкаУдостоверение = 0
			И ГруппаПрограммы.КолонкаДатаНачала = 0
			И ГруппаПрограммы.КолонкаДатаОкончания = 0 Тогда
			Продолжить;
		КонецЕсли;
		Результат.Добавить(ГруппаПрограммы);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Создаёт структуру группы программы по номерам колонок листа.
Функция НоваяСтруктураГруппыПрограммыИзНомеровКолонок(КодПрограммы)
	
	Возврат Новый Структура(
		"Программа, КолонкаПротокол, КолонкаУдостоверение, КолонкаДатаНачала, КолонкаДатаОкончания",
		КодПрограммы, 0, 0, 0, 0);
	
КонецФункции

// Возвращает уникальное имя колонки таблицы значений.
Функция УникальноеИмяКолонки(ТаблицаДанных, БазовоеИмя)
	
	ИмяКолонки = НормализоватьИмяКолонки(БазовоеИмя);
	Счетчик = 1;
	
	Пока ТаблицаДанных.Колонки.Найти(ИмяКолонки) <> Неопределено Цикл
		Счетчик = Счетчик + 1;
		ИмяКолонки = НормализоватьИмяКолонки(БазовоеИмя + "_" + Формат(Счетчик, "ЧГ=0"));
	КонецЦикла;
	
	Возврат ИмяКолонки;
	
КонецФункции

// Преобразует серийный номер даты Excel (1 = 01.01.1900) в дату 1С.
Функция ДатаИзСерийногоНомераExcel(СерийныйНомер)
	
	// База Excel: 30.12.1899, серийный номер 1 = 01.01.1900.
	Возврат Дата(1899, 12, 30) + СерийныйНомер * 86400;
	
КонецФункции

// Преобразует текст ячейки в дату.
Функция ДатаИзТекстаЯчейки(ТекстЯчейки)
	
	Если ТипЗнч(ТекстЯчейки) = Тип("Дата") Тогда
		Возврат ТекстЯчейки;
	КонецЕсли;
	
	ТекстЯчейки = СокрЛП(Строка(ТекстЯчейки));
	Если ПустаяСтрока(ТекстЯчейки) Тогда
		Возврат '00010101';
	КонецЕсли;
	
	Части = СтрРазделить(ТекстЯчейки, ".");
	Если Части.Количество() = 3 Тогда
		Попытка
			Возврат Дата(Число(Части[2]), Число(Части[1]), Число(Части[0]));
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	// Excel часто отдаёт дату числом (45995 = 06.06.2025) при чтении как текст.
	ЧислоДней = ЧислоИзТекстаЯчейки(ТекстЯчейки);
	Если ЧислоДней >= 20000 И ЧислоДней < 1000000 Тогда
		Попытка
			Возврат ДатаИзСерийногоНомераExcel(ЧислоДней);
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		Возврат Дата(ТекстЯчейки);
	Исключение
		Возврат '00010101';
	КонецПопытки;
	
КонецФункции

// Преобразует текст ячейки в число.
Функция ЧислоИзТекстаЯчейки(ТекстЯчейки)
	
	ТекстЯчейки = СокрЛП(ТекстЯчейки);
	Если ПустаяСтрока(ТекстЯчейки) Тогда
		Возврат 0;
	КонецЕсли;
	
	Попытка
		Возврат Число(СтрЗаменить(ТекстЯчейки, " ", ""));
	Исключение
		Возврат 0;
	КонецПопытки;
	
КонецФункции
// Создаёт один документ Сертификация по строке таблицы обучения.
Процедура СоздатьДокументСертификации(СтрокаОбучения, ФизическоеЛицо,ПрограммаОбучения,СрокиОбучения)
	
	ДокументОбъект = Документы.Сертификация.СоздатьДокумент();
	
	ДатаНачала = СтрокаОбучения.ДатаНачала;
	Если Не ЗначениеЗаполнено(ДатаНачала) Или ДатаНачала = '00010101' Тогда
		ДатаНачала = СтрокаОбучения.ДатаОбучения;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДатаНачала) И ДатаНачала <> '00010101' Тогда
		ДокументОбъект.ДатаС = ДатаНачала;
	Иначе
		ДокументОбъект.ДатаС = ТекущаяДатаСеанса();
	КонецЕсли;
	
	ДокументОбъект.Дата = ДокументОбъект.ДатаС;
	ДокументОбъект.Сотрудник = ФизическоеЛицо;
	
	НомерУдостоверения = СокрЛП(СтрокаОбучения.НомерУдостоверения);
	Если ПустаяСтрока(НомерУдостоверения) Тогда
		НомерУдостоверения = СокрЛП(СтрокаОбучения.НомерПротокола);
	КонецЕсли;
	ДокументОбъект.НомерУдостоверения = НомерУдостоверения;
	
	ДокументОбъект.Должность = Справочники.Должности.НайтиПоНаименованию(СтрокаОбучения.Должность, Ложь);
	ДокументОбъект.Программа = ПрограммаОбучения.Получить(СтрокаОбучения.Программа);
	
	ДатаОкончания = СтрокаОбучения.ДатаОкончания;
	Если ЗначениеЗаполнено(ДатаОкончания) И ДатаОкончания <> '00010101' Тогда
		ДокументОбъект.ДатаПо = ДатаОкончания;
	Иначе
		СрокЛет = СрокиОбучения.Получить(СтрокаОбучения.Программа);
		Если ЗначениеЗаполнено(СрокЛет) И ДокументОбъект.ДатаС <> '00010101' Тогда
			ДокументОбъект.ДатаПо = ДобавитьМесяц(ДокументОбъект.ДатаС, 12 * СрокЛет) - 86400;
		Иначе
			ДокументОбъект.ДатаПо = '00010101';
		КонецЕсли;
	КонецЕсли;
	
	ДокументОбъект.Комментарий = "реестр обучение Удостоверение";
	ДокументОбъект.Записать();
	
КонецПроцедуры

// Ищет физическое лицо по строке ФИО из Excel.
Функция НайтиФизическоеЛицоПоФИО(ФИО)
	ФИО = СтрСоединить(
	СтрРазделить(СокрЛП(ФИО), Символы.ПС + Символы.ВК + Символы.Таб, Ложь),
	" ");
	ФИО = СокрЛП(ФИО);
	Если ПустаяСтрока(ФИО) Тогда
		Возврат Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;      
		
	ЧастиФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ФИО);
	Результат = ФизическиеЛицаЗарплатаКадры.ФизическоеЛицоПоСНИЛСИлиФИО(Неопределено,ЧастиФИО.Фамилия,ЧастиФИО.Имя,ЧастиФИО.Отчество);
	Если ЗначениеЗаполнено(Результат.ФизическоеЛицо) тогда
		Возврат Результат.ФизическоеЛицо; 
	Иначе
		Возврат  Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;
	
	
КонецФункции

#КонецОбласти
