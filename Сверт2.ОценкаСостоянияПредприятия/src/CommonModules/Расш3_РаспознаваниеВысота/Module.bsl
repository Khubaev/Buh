// Интеграция с сервисом распознавания Высота (n8n webhook) без использования обработки.

#Область ПрограммныйИнтерфейс

// Возвращает ссылки на файлы, прикреплённые к объекту (документу и т.п.).
//
Функция ПолучитьСсылкиПрисоединенныхФайловОбъекта(ВладелецФайла) Экспорт
	
	Результат = Новый Массив;
	
	Если Не ЗначениеЗаполнено(ВладелецФайла) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ИмяСправочника = "";
	Попытка
		ИмяСправочника = РаботаСФайламиСлужебный.ИмяСправочникаХраненияФайлов(ВладелецФайла);
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Если ПустаяСтрока(ИмяСправочника) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрШаблон(
		"ВЫБРАТЬ
		|	Файлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.%1 КАК Файлы
		|ГДЕ
		|	Файлы.ВладелецФайла = &Владелец
		|	И НЕ Файлы.ПометкаУдаления",
		ИмяСправочника);
	Запрос.УстановитьПараметр("Владелец", ВладелецФайла);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает адрес и токен API распознавания.
//
Функция ПолучитьПараметрыПодключенияAPIРаспознавания() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("АдресAPI", "");
	Результат.Вставить("АдресAPIСтатуса", "");
	Результат.Вставить("ТокенAPI", "");
	
	Если ИспользоватьВшитыеПараметрыAPIРаспознавания() Тогда
		Результат.АдресAPI = ВшитыйАдресAPIРаспознавания();
		Результат.ТокенAPI = ВшитыйТокенAPIРаспознавания();
		Результат.АдресAPIСтатуса = ВшитыйАдресAPIСтатусаРаспознавания();
		Возврат Результат;
	КонецЕсли;
	
	КлючОбъекта = "Обработка.Распознавание_Высота.Форма.Форма";
	
	ЗаполнитьПараметрыAPIИзСохраненныхДанныхФормы(Результат, ХранилищеОбщихНастроек.Загрузить(КлючОбъекта));
	
	Если Не ЗначениеЗаполнено(Результат.АдресAPI) Тогда
		ЗаполнитьПараметрыAPIИзСохраненныхДанныхФормы(Результат, ХранилищеСистемныхНастроек.Загрузить(КлючОбъекта));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает UUID ссылки владельца файлов для передачи в API.
//
Функция ИдентификаторВладельцаФайловДляAPI(ВладелецФайла) Экспорт
	
	Если Не ЗначениеЗаполнено(ВладелецФайла) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат XMLСтрока(ВладелецФайла);
	
КонецФункции

// Отправляет все прикреплённые к объекту файлы на распознавание без открытия формы обработки.
//
Функция ОтправитьПрисоединенныеФайлыОбъектаНаРаспознавание(ВладелецФайла, ИдентификаторФормы = Неопределено) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("ТекстСообщения", "");
	Результат.Вставить("КоличествоУспешных", 0);
	Результат.Вставить("КоличествоОшибок", 0);
	Результат.Вставить("РезультатыФайлов", Новый Массив);
	Результат.Вставить("JobId", "");
	
	Если Не ЗначениеЗаполнено(ВладелецФайла) Тогда
		Результат.ТекстСообщения = НСтр("ru = 'Не указан объект для отправки файлов.'");
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыAPI = ПолучитьПараметрыПодключенияAPIРаспознавания();
	Если Не ЗначениеЗаполнено(ПараметрыAPI.АдресAPI) Тогда
		Результат.ТекстСообщения = НСтр(
			"ru = 'Не указан адрес API распознавания. Укажите настройки подключения к сервису распознавания.'");
		Возврат Результат;
	КонецЕсли;
	
	ИдентификаторХранилища = ИдентификаторФормы;
	Если ИдентификаторХранилища = Неопределено Тогда
		ИдентификаторХранилища = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	МассивФайлов = ПодготовитьПрисоединенныеФайлыДляРаспознавания(ВладелецФайла, ИдентификаторХранилища);
	Если МассивФайлов.Количество() = 0 Тогда
		Результат.ТекстСообщения = НСтр("ru = 'К объекту не прикреплены файлы для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаФайлов = ТаблицаФайловДляРаспознаванияИзМассива(МассивФайлов, ВладелецФайла);
	Если ТаблицаФайлов.Количество() = 0 Тогда
		Результат.ТекстСообщения = НСтр("ru = 'Не удалось подготовить файлы для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ПараметрыЗапроса = СформироватьПараметрыЗапросаРаспознаванияДляОбъекта(ВладелецФайла);
	
	АдресОтправки = ПараметрыAPI.АдресAPI;
	ВОчередь = ЗначениеЗаполнено(ПараметрыAPI.АдресAPIСтатуса);
	Если ВОчередь Тогда
		АдресОтправки = ПараметрыAPI.АдресAPIСтатуса;
	КонецЕсли;
	
	// Каждый файл — отдельный POST по очереди.
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		
		ТаблицаОдногоФайла = ТаблицаФайлов.СкопироватьКолонки();
		НоваяСтрока = ТаблицаОдногоФайла.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаФайла);
		
		ОписаниеРезультата = Новый Структура;
		ОписаниеРезультата.Вставить("ИмяФайла", СтрокаФайла.ИмяФайла);
		ОписаниеРезультата.Вставить("Успех", Ложь);
		ОписаниеРезультата.Вставить("ТекстСообщения", "");
		
		Если ВОчередь Тогда
			РезультатОтправки = ПоставитьВОчередьРаспознавание(
				АдресОтправки,
				ПараметрыAPI.ТокенAPI,
				ТаблицаОдногоФайла,
				ПараметрыЗапроса);
			Если РезультатОтправки.Успех Тогда
				ОписаниеРезультата.Успех = Истина;
				ОписаниеРезультата.ТекстСообщения = НСтр("ru = 'Поставлен в очередь'");
				Если ЗначениеЗаполнено(РезультатОтправки.JobId) Тогда
					Результат.JobId = РезультатОтправки.JobId;
				КонецЕсли;
			Иначе
				ОписаниеРезультата.ТекстСообщения = ?(
					ЗначениеЗаполнено(РезультатОтправки.ОписаниеОшибки),
					РезультатОтправки.ОписаниеОшибки,
					НСтр("ru = 'Не удалось поставить в очередь.'"));
			КонецЕсли;
		Иначе
			РезультатОтправки = ОтправитьОдинФайлНаРаспознавание(
				АдресОтправки,
				ПараметрыAPI.ТокенAPI,
				ТаблицаОдногоФайла,
				ПараметрыЗапроса);
			Если РезультатОтправки.Успех Тогда
				ОписаниеРезультата.Успех = Истина;
				ОписаниеРезультата.ТекстСообщения = НСтр("ru = 'Отправлен'");
			Иначе
				ОписаниеРезультата.ТекстСообщения = ?(
					ЗначениеЗаполнено(РезультатОтправки.ОписаниеОшибки),
					РезультатОтправки.ОписаниеОшибки,
					НСтр("ru = 'Не удалось отправить файл.'"));
			КонецЕсли;
		КонецЕсли;
		
		Результат.РезультатыФайлов.Добавить(ОписаниеРезультата);
		
		Если ОписаниеРезультата.Успех Тогда
			Результат.КоличествоУспешных = Результат.КоличествоУспешных + 1;
		Иначе
			Результат.КоличествоОшибок = Результат.КоличествоОшибок + 1;
		КонецЕсли;
		
	КонецЦикла;
	
	Результат.Успех = (Результат.КоличествоУспешных > 0) И (Результат.КоличествоОшибок = 0);
	
	Если Результат.КоличествоОшибок = 0 Тогда
		Если ВОчередь Тогда
			Результат.ТекстСообщения = СтрШаблон(
				НСтр("ru = 'Файлы (%1 шт.) поставлены в очередь распознавания по очереди.'"),
				Формат(Результат.КоличествоУспешных, "ЧГ=0"));
		Иначе
			Результат.ТекстСообщения = СтрШаблон(
				НСтр("ru = 'На распознавание отправлено файлов: %1 (по очереди).'"),
				Формат(Результат.КоличествоУспешных, "ЧГ=0"));
		КонецЕсли;
	ИначеЕсли Результат.КоличествоУспешных > 0 Тогда
		Результат.ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Отправлено успешно: %1, с ошибкой: %2.'"),
			Формат(Результат.КоличествоУспешных, "ЧГ=0"),
			Формат(Результат.КоличествоОшибок, "ЧГ=0"));
	Иначе
		Результат.ТекстСообщения = НСтр("ru = 'Не удалось отправить файлы на распознавание.'");
		Для Каждого ОписаниеРезультата Из Результат.РезультатыФайлов Цикл
			Если ЗначениеЗаполнено(ОписаниеРезультата.ТекстСообщения) Тогда
				Результат.ТекстСообщения = ОписаниеРезультата.ТекстСообщения;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Отправляет один файл (таблица из одной строки) на сервис распознавания одним POST.
// Тело: {"files":[{"filename":"...","content":"<base64>"}], "source":"1c_ttn", ...}
//
Функция ОтправитьОдинФайлНаРаспознавание(АдресAPI, ТокенAPI, ТаблицаОдногоФайла, ПараметрыЗапроса = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТелоОтвета", "");
	Результат.Вставить("ОписаниеОшибки", "");
	
	Если Не ЗначениеЗаполнено(АдресAPI) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Не указан адрес API распознавания.'");
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаОдногоФайла = Неопределено Или ТаблицаОдногоФайла.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Нет файлов для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	ИмяФайла = "";
	Если ТаблицаОдногоФайла.Колонки.Найти("ИмяФайла") <> Неопределено Тогда
		ИмяФайла = Строка(ТаблицаОдногоФайла[0].ИмяФайла);
	КонецЕсли;
	
	ЗаписатьСобытиеРаспознавания(
		"Отправка",
		СтрШаблон(
			НСтр("ru = 'Отправка файла «%1», endpoint: %2'"),
			ИмяФайла,
			АдресAPI));
	
	Попытка
		ПараметрыHTTP = РазобратьАдресAPI(АдресAPI);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецПопытки;
	
	ТелоЗапроса = СформироватьТелоЗапросаРаспознавания(ТаблицаОдногоФайла, Результат, ПараметрыЗапроса);
	Если Не ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(ПараметрыHTTP.Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	
	Если ЗначениеЗаполнено(ТокенAPI) Тогда
		Запрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенAPI);
	КонецЕсли;
	
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Попытка
		Ответ = ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, 600);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписатьСобытиеРаспознавания("Ошибка", Результат.ОписаниеОшибки, УровеньЖурналаРегистрации.Ошибка);
		Возврат Результат;
	КонецПопытки;
	
	Результат.КодОтвета = Ответ.КодСостояния;
	Результат.ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
	КодОтветаУспешен = (Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300);
	Результат.Успех = КодОтветаУспешен;
	
	Если Не Результат.Успех Тогда
		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Сервер вернул код %1.'"),
			Формат(Ответ.КодСостояния, "ЧГ=0"));
	КонецЕсли;
	
	ЗаписатьСобытиеРаспознавания(
		"Ответ",
		СтрШаблон(
			НСтр("ru = 'Файл «%1»: HTTP %2, принято: %3'"),
			ИмяФайла,
			Формат(Ответ.КодСостояния, "ЧГ=0"),
			?(Результат.Успех, "Да", "Нет")),
		?(Результат.Успех, УровеньЖурналаРегистрации.Информация, УровеньЖурналаРегистрации.Ошибка));
	
	Возврат Результат;
	
КонецФункции

// Ставит файлы в очередь распознавания (двухфазная схема: submit -> status).
// Ожидаемый ответ: { job_id: "...", accepted: true } (поля могут отличаться).
//
Функция ПоставитьВОчередьРаспознавание(АдресAPI, ТокенAPI, ТаблицаФайлов, ПараметрыЗапроса = Неопределено)
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("КодОтвета", 0);
	Результат.Вставить("ТелоОтвета", "");
	Результат.Вставить("ОписаниеОшибки", "");
	Результат.Вставить("JobId", "");
	
	Если ТаблицаФайлов = Неопределено Или ТаблицаФайлов.Количество() = 0 Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Нет файлов для отправки.'");
		Возврат Результат;
	КонецЕсли;
	
	Параметры = Новый Структура;
	Если ПараметрыЗапроса <> Неопределено И ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		Для Каждого Параметр Из ПараметрыЗапроса Цикл
			Параметры.Вставить(Параметр.Ключ, Параметр.Значение);
		КонецЦикла;
	КонецЕсли;
	Параметры.Вставить("action", "submit");
	
	ТелоЗапроса = СформироватьТелоЗапросаРаспознавания(ТаблицаФайлов, Результат, Параметры);
	Если Не ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		Возврат Результат;
	КонецЕсли;
	
	HTTP = ВыполнитьHTTPPostJSON(АдресAPI, ТокенAPI, ТелоЗапроса);
	Результат.КодОтвета = HTTP.КодОтвета;
	Результат.ТелоОтвета = HTTP.ТелоОтвета;
	Результат.ОписаниеОшибки = HTTP.ОписаниеОшибки;
	
	Если Не HTTP.Успех Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат.JobId = ИзвлечьJobIdИзОтвета(HTTP.ТелоОтвета);
	Если Не ЗначениеЗаполнено(Результат.JobId) Тогда
		Результат.ОписаниеОшибки = НСтр("ru = 'Сервис не вернул job_id.'");
		Возврат Результат;
	КонецЕсли;
	
	Результат.Успех = Истина;
	Возврат Результат;
	
КонецФункции

// Читает JSON из строки в структуру/массив.
Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Возврат ПрочитатьJSON(ЧтениеJSON);
	
КонецФункции

Функция ИзвлечьJobIdИзОтвета(ТелоОтвета)
	
	Если Не ЗначениеЗаполнено(ТелоОтвета) Тогда
		Возврат "";
	КонецЕсли;
	
	Попытка
		Корень = ПрочитатьJSONИзСтроки(ТелоОтвета);
	Исключение
		Возврат "";
	КонецПопытки;
	
	Если ТипЗнч(Корень) = Тип("Массив") Тогда
		Если Корень.Количество() > 0 Тогда
			Корень = Корень[0];
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Корень) <> Тип("Структура") Тогда
		Возврат "";
	КонецЕсли;
	
	Если Корень.Свойство("job_id") Тогда
		Возврат Строка(Корень.job_id);
	ИначеЕсли Корень.Свойство("jobId") Тогда
		Возврат Строка(Корень.jobId);
	ИначеЕсли Корень.Свойство("id") Тогда
		Возврат Строка(Корень.id);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция ВыполнитьHTTPPostJSON(АдресAPI, ТокенAPI, ТелоЗапроса)
	
	Результат = Новый Структура("Успех, КодОтвета, ТелоОтвета, ОписаниеОшибки", Ложь, 0, "", "");
	
	Попытка
		ПараметрыHTTP = РазобратьАдресAPI(АдресAPI);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Запрос = Новый HTTPЗапрос(ПараметрыHTTP.Путь);
	Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Запрос.Заголовки.Вставить("Accept", "application/json");
	Если ЗначениеЗаполнено(ТокенAPI) Тогда
		Запрос.Заголовки.Вставить("Authorization", "Bearer " + ТокенAPI);
	КонецЕсли;
	Запрос.УстановитьТелоИзСтроки(ТелоЗапроса, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Попытка
		Ответ = ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, 60);
	Исключение
		Результат.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат Результат;
	КонецПопытки;
	
	Результат.КодОтвета = Ответ.КодСостояния;
	Результат.ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	Результат.Успех = (Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300);
	
	Если Не Результат.Успех И ПустаяСтрока(Результат.ОписаниеОшибки) Тогда
		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru='Сервер вернул код %1.'"), Формат(Ответ.КодСостояния, "ЧГ=0"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция РазобратьАдресAPI(АдресAPI)
	
	АдресСтрокой = СокрЛП(АдресAPI);
	
	Попытка
		СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(АдресСтрокой);
		Хост = СтруктураURI.Хост;
		Если Не ЗначениеЗаполнено(Хост) И СтруктураURI.Свойство("ИмяСервера") Тогда
			Хост = СтруктураURI.ИмяСервера;
		КонецЕсли;
		Путь = "/";
		Если СтруктураURI.Свойство("ПутьНаСервере") И ЗначениеЗаполнено(СтруктураURI.ПутьНаСервере) Тогда
			Путь = СтруктураURI.ПутьНаСервере;
		ИначеЕсли СтруктураURI.Свойство("Путь") И ЗначениеЗаполнено(СтруктураURI.Путь) Тогда
			Путь = СтруктураURI.Путь;
		КонецЕсли;
		Схема = "http";
		Если СтруктураURI.Свойство("Схема") Тогда
			Схема = СтруктураURI.Схема;
		КонецЕсли;
		Защищенное = (НРег(Схема) = "https");
		Порт = 0;
		Если СтруктураURI.Свойство("Порт") И ЗначениеЗаполнено(СтруктураURI.Порт) Тогда
			Порт = Число(СтруктураURI.Порт);
		КонецЕсли;
		Если Порт = 0 Тогда
			Порт = ?(Защищенное, 443, 80);
		КонецЕсли;
	Исключение
		ВызватьИсключение НСтр("ru = 'Некорректный адрес API. Укажите полный URL, например https://api.example.com/v1/recognize'");
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(Хост) Тогда
		ВызватьИсключение НСтр("ru = 'В адресе API не определён хост.'");
	КонецЕсли;
	
	Возврат Новый Структура("Хост, Порт, Путь, Схема, ЗащищенноеСоединение", Хост, Порт, Путь, Схема, Защищенное);
	
КонецФункции

// Прокси из настроек 1С; при отсутствии — прямое подключение (без системного прокси Windows).
//
Функция ПолучитьПроксиДляHTTPРаспознавания(Схема)
	
	Попытка
		Прокси = ПолучениеФайловИзИнтернета.ПолучитьПрокси(Схема);
	Исключение
		Прокси = Новый ИнтернетПрокси(Ложь);
	КонецПопытки;
	
	// Неопределено заставляет платформу брать системный прокси ОС — частая причина «Couldn't resolve proxy name».
	Если Прокси = Неопределено Тогда
		Прокси = Новый ИнтернетПрокси(Ложь);
	КонецЕсли;
	
	Возврат Прокси;
	
КонецФункции

// Создаёт HTTP-соединение с учётом прокси из настроек 1С.
//
Функция СоздатьHTTPСоединениеДляРаспознавания(ПараметрыHTTP, Таймаут, Прокси = Неопределено)
	
	Схема = "https";
	Если ПараметрыHTTP.Свойство("Схема") И ЗначениеЗаполнено(ПараметрыHTTP.Схема) Тогда
		Схема = ПараметрыHTTP.Схема;
	ИначеЕсли ПараметрыHTTP.ЗащищенноеСоединение Тогда
		Схема = "https";
	Иначе
		Схема = "http";
	КонецЕсли;
	
	Если Прокси = Неопределено Тогда
		Прокси = ПолучитьПроксиДляHTTPРаспознавания(Схема);
	КонецЕсли;
	
	Возврат Новый HTTPСоединение(
		ПараметрыHTTP.Хост,
		ПараметрыHTTP.Порт,
		,
		,
		Прокси,
		Таймаут,
		ПараметрыHTTP.ЗащищенноеСоединение);
	
КонецФункции

// Отправляет HTTP-запрос; при ошибке разрешения прокси повторяет без прокси.
//
Функция ОтправитьHTTPЗапросРаспознавания(ПараметрыHTTP, Запрос, Таймаут)
	
	Попытка
		Соединение = СоздатьHTTPСоединениеДляРаспознавания(ПараметрыHTTP, Таймаут);
		Возврат Соединение.ОтправитьДляОбработки(Запрос);
	Исключение
		ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Если ЭтоОшибкаРазрешенияПрокси(ТекстОшибки) Тогда
			Соединение = СоздатьHTTPСоединениеДляРаспознавания(
				ПараметрыHTTP,
				Таймаут,
				Новый ИнтернетПрокси(Ложь));
			Возврат Соединение.ОтправитьДляОбработки(Запрос);
		КонецЕсли;
		ВызватьИсключение;
	КонецПопытки;
	
КонецФункции

Функция ЭтоОшибкаРазрешенияПрокси(ТекстОшибки)
	
	ТекстВерхРег = ВРег(ТекстОшибки);
	Возврат СтрНайти(ТекстВерхРег, "PROXY") > 0
		Или СтрНайти(ТекстВерхРег, "ПРОКСИ") > 0;
	
КонецФункции

Функция СформироватьТелоЗапросаРаспознавания(ТаблицаФайлов, РезультатОтправки, ПараметрыЗапроса = Неопределено)
	
	МассивФайлов = Новый Массив;
	ИдентификаторВладельцаПоУмолчанию = ИдентификаторВладельцаИзПараметровЗапроса(ПараметрыЗапроса);
	
	Для Каждого СтрокаФайла Из ТаблицаФайлов Цикл
		
		Если Не ЗначениеЗаполнено(СтрокаФайла.АдресХранилища) Тогда
			Продолжить;
		КонецЕсли;
		
		ДвоичныеДанные = ПолучитьИзВременногоХранилища(СтрокаФайла.АдресХранилища);
		Если ДвоичныеДанные = Неопределено Тогда
			РезультатОтправки.ОписаниеОшибки = СтрШаблон(
				НСтр("ru = 'Не удалось прочитать файл ""%1"" из временного хранилища.'"),
				СтрокаФайла.ИмяФайла);
			Возврат "";
		КонецЕсли;
		
		ОписаниеФайла = Новый Структура;
		// ключ для сопоставления результата с файлом в 1С
		Если ТаблицаФайлов.Колонки.Найти("ИдентификаторФайла") <> Неопределено Тогда
			ОписаниеФайла.Вставить("key", СтрокаФайла.ИдентификаторФайла);
		ИначеЕсли ТаблицаФайлов.Колонки.Найти("АдресХранилища") <> Неопределено Тогда
			ОписаниеФайла.Вставить("key", СтрокаФайла.АдресХранилища);
		КонецЕсли;
		
		ИдентификаторВладельца = ИдентификаторВладельцаФайлаИзСтрокиТаблицы(
			СтрокаФайла,
			ТаблицаФайлов,
			ИдентификаторВладельцаПоУмолчанию);
		Если ЗначениеЗаполнено(ИдентификаторВладельца) Тогда
			ОписаниеФайла.Вставить("document_id", ИдентификаторВладельца);
		КонецЕсли;
		
		ОписаниеФайла.Вставить("filename", СтрокаФайла.ИмяФайла);
		ОписаниеФайла.Вставить("extension", РасширениеФайлаДляAPI(СтрокаФайла, ТаблицаФайлов));
		ОписаниеФайла.Вставить("content", Base64Строка(ДвоичныеДанные));
		МассивФайлов.Добавить(ОписаниеФайла);
		
	КонецЦикла;
	
	Если МассивФайлов.Количество() = 0 Тогда
		РезультатОтправки.ОписаниеОшибки = НСтр("ru = 'Нет доступных для отправки файлов.'");
		Возврат "";
	КонецЕсли;
	
	Тело = Новый Структура;
	Тело.Вставить("files", МассивФайлов);
	Тело.Вставить("source", "1c_ttn");
	
	Если ПараметрыЗапроса <> Неопределено
		И ТипЗнч(ПараметрыЗапроса) = Тип("Структура") Тогда
		
		Для Каждого Параметр Из ПараметрыЗапроса Цикл
			Тело.Вставить(Параметр.Ключ, Параметр.Значение);
		КонецЦикла;
		
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Тело);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

//
Функция ПодготовитьПрисоединенныеФайлыДляРаспознавания(ВладелецФайла, ИдентификаторФормы)
	
	Результат = Новый Массив;
	МассивСсылок = ПолучитьСсылкиПрисоединенныхФайловОбъекта(ВладелецФайла);
	
	Для Каждого СсылкаНаФайл Из МассивСсылок Цикл
		
		Попытка
			ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(СсылкаНаФайл);
		Исключение
			Продолжить;
		КонецПопытки;
		
		Если ДвоичныеДанные = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИмяФайла = ИмяПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл);
		РасширениеФайла = РасширениеПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл, ИмяФайла);
		АдресХранилища = ПоместитьВоВременноеХранилище(ДвоичныеДанные, ИдентификаторФормы);
		
		ОписаниеФайла = Новый Структура;
		ОписаниеФайла.Вставить("ИмяФайла", ИмяФайла);
		ОписаниеФайла.Вставить("Расширение", РасширениеФайла);
		ОписаниеФайла.Вставить("АдресХранилища", АдресХранилища);
		ОписаниеФайла.Вставить("ИдентификаторВладельца", ИдентификаторВладельцаФайловДляAPI(ВладелецФайла));
		ОписаниеФайла.Вставить("РазмерБайт", ДвоичныеДанные.Размер());
		Результат.Добавить(ОписаниеФайла);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает полное имя присоединённого файла.
Функция ИмяПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл)
	
	Попытка
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(СсылкаНаФайл);
		ИмяФайла = СокрЛП(ДанныеФайла.ИмяБезРасширения);
		Если ЗначениеЗаполнено(ДанныеФайла.Расширение) Тогда
			ИмяФайла = ИмяФайла + "." + СокрЛП(ДанныеФайла.Расширение);
		КонецЕсли;
		Если ЗначениеЗаполнено(ИмяФайла) Тогда
			Возврат ИмяФайла;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Строка(СсылкаНаФайл);
	
КонецФункции

// Возвращает расширение файла без точки (pdf, xlsx и т.п.).
Функция РасширениеПрисоединенногоФайлаДляРаспознавания(СсылкаНаФайл, ИмяФайла = "")
	
	Попытка
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(СсылкаНаФайл);
		Если ЗначениеЗаполнено(ДанныеФайла.Расширение) Тогда
			Возврат НормализоватьРасширениеФайла(ДанныеФайла.Расширение);
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат РасширениеИзИмениФайла(ИмяФайла);
	
КонецФункции

// Берёт расширение из строки таблицы или из имени файла.
Функция РасширениеФайлаДляAPI(СтрокаФайла, ТаблицаФайлов)
	
	Если ТаблицаФайлов.Колонки.Найти("Расширение") <> Неопределено
		И ЗначениеЗаполнено(СтрокаФайла.Расширение) Тогда
		Возврат НормализоватьРасширениеФайла(СтрокаФайла.Расширение);
	КонецЕсли;
	
	ИмяФайла = "";
	Если ТаблицаФайлов.Колонки.Найти("ИмяФайла") <> Неопределено Тогда
		ИмяФайла = СтрокаФайла.ИмяФайла;
	КонецЕсли;
	
	Возврат РасширениеИзИмениФайла(ИмяФайла);
	
КонецФункции

Функция РасширениеИзИмениФайла(ИмяФайла)
	
	ИмяФайла = СокрЛП(Строка(ИмяФайла));
	Если Не ЗначениеЗаполнено(ИмяФайла) Тогда
		Возврат "";
	КонецЕсли;
	
	ПозицияТочки = СтрНайти(ИмяФайла, ".", НаправлениеПоиска.СКонца);
	Если ПозицияТочки = 0 Или ПозицияТочки = СтрДлина(ИмяФайла) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат НормализоватьРасширениеФайла(Сред(ИмяФайла, ПозицияТочки + 1));
	
КонецФункции

Функция НормализоватьРасширениеФайла(Расширение)
	
	Результат = НРег(СокрЛП(Строка(Расширение)));
	Пока СтрНачинаетсяС(Результат, ".") Цикл
		Результат = Сред(Результат, 2);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

