	ОбластьЛегенды.Текст =
		"Как читать отчёт:" + Символы.ПС
		+ "• Значение — фактическая рентабельность в процентах из бизнес-аналитики." + Символы.ПС
		+ "• Цветная шкала — зелёная зона: норма, ▼ маркер: факт (оранжевый — ниже нормы, синий — в/выше нормы)." + Символы.ПС
		+ "• Оценка БА — шкала 0–5: 4,5+ Отлично | 3,5+ Хорошо | 2,5+ Удовлетворительно | 1,5+ Низкая | ниже — Критично.";
	ОбластьЛегенды.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьЛегенды.ЦветТекста = Новый Цвет(71, 85, 105);
	ОбластьЛегенды.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ПрименитьРамку(ОбластьЛегенды);
	
КонецПроцедуры

Процедура ВывестиРезюмеДляРуководителя(ДокументРезультат, НомерСтроки, СводкаПоказателей, ОбщаяОценка)
	
	ОбластьЗаголовка = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Текст = "Резюме для руководителя";
	ОбластьЗаголовка.Шрифт = Новый Шрифт(, 13, Истина);
	ОбластьЗаголовка.ЦветФона = Новый Цвет(22, 78, 56);
	ОбластьЗаголовка.ЦветТекста = Новый Цвет(255, 255, 255);
	ПрименитьРамку(ОбластьЗаголовка);
	
	НомерСтроки = НомерСтроки + 1;
	ТекстРезюме = СформироватьТекстРезюме(СводкаПоказателей, ОбщаяОценка);
	ОбластьРезюме = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки + 8, ПоследняяКолонка());
	ОбластьРезюме.Объединить();
	ОбластьРезюме.Текст = ТекстРезюме;
	ОбластьРезюме.ЦветФона = Новый Цвет(255, 255, 255);
	ОбластьРезюме.ЦветТекста = Новый Цвет(30, 41, 59);
	ОбластьРезюме.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьРезюме.Шрифт = Новый Шрифт(, 10);
	ПрименитьРамку(ОбластьРезюме);
	
КонецПроцедуры

Функция СформироватьТекстРезюме(СводкаПоказателей, ОбщаяОценка)
	
	Сильные = Новый Массив;
	Слабые = Новый Массив;
	Критичные = Новый Массив;
	
	Для Каждого СтрокаСводки Из СводкаПоказателей Цикл
		Если СтрокаСводки.Уровень = "Критично" Или СтрокаСводки.Уровень = "Низкая" Тогда
			Критичные.Добавить(СтрокаСводки);
		ИначеЕсли СтрокаСводки.Уровень = "Удовлетворительно" Тогда
			Слабые.Добавить(СтрокаСводки);
		Иначе
			Сильные.Добавить(СтрокаСводки);
		КонецЕсли;
	КонецЦикла;
	
	Текст = "";
	
	Если ОбщаяОценка <> Неопределено Тогда
		ИнтерпретацияОбщая = ИнтерпретацияОценки(ОбщаяОценка);
		Текст = Текст + СтрШаблон(
			"Общий вывод: оценка рентабельности %1 из 5 (%2). %3",
			Формат(ОбщаяОценка, "ЧДЦ=2"),
			ИнтерпретацияОбщая.Уровень,
			ИнтерпретацияОбщая.Описание) + Символы.ПС + Символы.ПС;
	Иначе
		Текст = Текст + "Общий вывод: интегральная оценка рентабельности не загружена — ориентируйтесь на детальные показатели ниже." + Символы.ПС + Символы.ПС;
	КонецЕсли;
	
	Если Сильные.Количество() > 0 Тогда
		Текст = Текст + "Сильные стороны:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Сильные Цикл
			Текст = Текст + "  + " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Если Критичные.Количество() > 0 Тогда
		Текст = Текст + "Зоны критического внимания:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Критичные Цикл
			Текст = Текст + "  ! " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Если Слабые.Количество() > 0 Тогда
		Текст = Текст + "Показатели, требующие контроля:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Слабые Цикл
			Текст = Текст + "  - " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Текст = Текст + "Рекомендуемые управленческие действия:" + Символы.ПС;
	Если Критичные.Количество() > 0 Или Слабые.Количество() > 0 Тогда
		Текст = Текст
			+ "  1. Проведите детальный анализ затрат по проблемным направлениям (себестоимость, ФОТ, коммунальные и прочие расходы)." + Символы.ПС
			+ "  2. Сопоставьте рентабельность с планом и прошлым периодом — выявите причины отклонений." + Символы.ПС
			+ "  3. Сфокусируйтесь на повышении маржинальности ключевых услуг и загрузке мощностей." + Символы.ПС;
	Иначе
		Текст = Текст
			+ "  1. Закрепите текущую эффективность: зафиксируйте лучшие практики в ценообразовании и управлении затратами." + Символы.ПС
			+ "  2. Рассмотрите точечные инвестиции в направления с наивысшей отдачей." + Символы.ПС
			+ "  3. Установите контрольные KPI на следующий период, чтобы не допустить снижения рентабельности." + Символы.ПС;
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Процедура НарисоватьЦветнуюШкалу(ДокументРезультат, НомерСтроки, Доля, Описание)
	
	ДлинаШкалы = ШиринаШкалыСегментов();
	МаксШкалы = Описание.МаксШкалы;
	ЦветТрека = Новый Цвет(203, 213, 225);
	ЦветНорма = Новый Цвет(74, 222, 128);
	ЦветМаркер = Новый Цвет(29, 78, 216);
	ЦветНижеНормы = Новый Цвет(249, 115, 22);
	ЦветВышеНормы = Новый Цвет(59, 130, 246);
	ЛинияСегмента = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	
	ПозицияЗначения = 0;
	Если Доля <> Неопределено Тогда
		ПозицияЗначения = Цел(Мин(ДлинаШкалы, Макс(1, Доля / МаксШкалы * ДлинаШкалы)));
	КонецЕсли;
	
	НачалоНормы = Цел(Мин(ДлинаШкалы, Макс(1, Описание.МинНорма / МаксШкалы * ДлинаШкалы)));
	КонецНормы = Цел(Мин(ДлинаШкалы, Макс(1, Описание.МаксНорма / МаксШкалы * ДлинаШкалы)));
	
	Для Индекс = 1 По ДлинаШкалы Цикл
		ОбластьСегмента = ДокументРезультат.Область(НомерСтроки, КолонкаШкалаНачало() + Индекс - 1);
		
		Если Индекс = ПозицияЗначения И Доля <> Неопределено Тогда
			Если Доля < Описание.МинНорма Тогда
				ОбластьСегмента.ЦветФона = ЦветНижеНормы;
			ИначеЕсли Доля > Описание.МаксНорма Тогда
				ОбластьСегмента.ЦветФона = ЦветВышеНормы;
			Иначе
				ОбластьСегмента.ЦветФона = ЦветМаркер;
			КонецЕсли;
			ОбластьСегмента.Текст = "▼";
			ОбластьСегмента.ЦветТекста = Новый Цвет(255, 255, 255);
			ОбластьСегмента.Шрифт = Новый Шрифт(, 9, Истина);
		ИначеЕсли Индекс >= НачалоНормы И Индекс <= КонецНормы Тогда
			ОбластьСегмента.ЦветФона = ЦветНорма;
		Иначе
			ОбластьСегмента.ЦветФона = ЦветТрека;
		КонецЕсли;
		
		ОбластьСегмента.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
		ОбластьСегмента.ВертикальноеПоложение = ВертикальноеПоложение.Центр;
		ОбластьСегмента.Обвести(ЛинияСегмента, ЛинияСегмента, ЛинияСегмента, ЛинияСегмента);
	КонецЦикла;
	
КонецПроцедуры

Функция НормализоватьДолю(Значение)
	
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// В регистре значения в процентах: 1 = 1%, 15 = 15% (как в справке БА).
	Возврат Значение / 100;
	
КонецФункции

Функция ПредставлениеПроцента(Доля)
	
	Если Доля = Неопределено Тогда
		Возврат "—";
	КонецЕсли;
	
	Возврат Формат(Доля * 100, "ЧДЦ=2") + "%";
	
КонецФункции

Функция РассчитатьОценкуПоЗначению(Значение, Описание)
	
	Доля = НормализоватьДолю(Значение);
	Если Доля = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	МинНорма = Описание.МинНорма;
	МаксНорма = Описание.МаксНорма;
	
	Если Доля >= МинНорма И Доля <= МаксНорма Тогда
		Возврат 5;
	КонецЕсли;
	
	Если Доля > МаксНорма Тогда
		Если Доля > МаксНорма * 1.5 Тогда
			Возврат 5;
		Иначе
			Возврат 4.5;
		КонецЕсли;
	КонецЕсли;
	
	Если Доля < МинНорма * 0.3 Тогда
		Возврат 0;
	ИначеЕсли Доля < МинНорма * 0.6 Тогда
		Возврат 1;
	ИначеЕсли Доля < МинНорма * 0.85 Тогда
		Возврат 2;
	Иначе
		Возврат 3;
	КонецЕсли;
	
КонецФункции

Функция ИтоговаяОценкаПоказателя(ЗначениеПоказателя, ОценкаБА, Описание)
	
	ОценкаПоЗначению = РассчитатьОценкуПоЗначению(ЗначениеПоказателя, Описание);
	
	Если ОценкаБА = Неопределено Тогда
		Возврат ОценкаПоЗначению;
	КонецЕсли;
	
	Если ОценкаПоЗначению = Неопределено Тогда
		Возврат ОценкаБА;
	КонецЕсли;
	
	// Уровень — по худшей из оценки БА и расчёта по фактическому %
	Возврат Мин(ОценкаБА, ОценкаПоЗначению);
	
КонецФункции

Функция НормализованнаяОценка(Оценка)
	
	Если Оценка = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	// Оценка БА всегда в шкале 0–5 (0,78 = 15,6%, а не 78%)
	Возврат Мин(1, Макс(0, Оценка / 5));
	
КонецФункции

Функция ИнтерпретацияОценки(Оценка)
	
	Результат = Новый Структура("Уровень, Описание, ЦветФона, ЦветТекста");
	НормОценка = НормализованнаяОценка(Оценка);
	
	Если НормОценка >= 0.9 Тогда
		Результат.Уровень = "Отлично";
		Результат.Описание = "Рентабельность на высоком уровне, предприятие эффективно генерирует прибыль";
		Результат.ЦветФона = Новый Цвет(187, 247, 208);
		Результат.ЦветТекста = Новый Цвет(22, 78, 56);
	ИначеЕсли НормОценка >= 0.7 Тогда
		Результат.Уровень = "Хорошо";
		Результат.Описание = "Рентабельность приемлемая, большинство показателей в рабочем диапазоне";
		Результат.ЦветФона = Новый Цвет(209, 250, 229);
		Результат.ЦветТекста = Новый Цвет(22, 78, 56);
	ИначеЕсли НормОценка >= 0.5 Тогда
		Результат.Уровень = "Удовлетворительно";
		Результат.Описание = "Рентабельность неоднородна — отдельные направления требуют усиления контроля";
		Результат.ЦветФона = Новый Цвет(254, 243, 199);
		Результат.ЦветТекста = Новый Цвет(120, 83, 14);
	ИначеЕсли НормОценка >= 0.3 Тогда
		Результат.Уровень = "Низкая";
		Результат.Описание = "Рентабельность слабая — прибыльность бизнеса под угрозой";
		Результат.ЦветФона = Новый Цвет(254, 215, 170);
		Результат.ЦветТекста = Новый Цвет(154, 52, 18);
	Иначе
		Результат.Уровень = "Критично";
		Результат.Описание = "Критически низкая рентабельность — необходимы срочные меры";
		Результат.ЦветФона = Новый Цвет(254, 202, 202);
		Результат.ЦветТекста = Новый Цвет(153, 27, 27);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтерпретацияПоказателя(Значение, Оценка, Описание)
	
	Интерпретация = ИнтерпретацияОценки(?(Оценка = Неопределено, 0, Оценка));
	Доля = НормализоватьДолю(Значение);
	Рекомендация = "";
	
	Если Доля <> Неопределено Тогда
		Если Доля < Описание.МинНорма Тогда
			Интерпретация.Описание = Описание.ТекстНизко;
			Рекомендация = Описание.РекомендацияНизко;
		ИначеЕсли Доля > Описание.МаксНорма Тогда
			Интерпретация.Описание = Описание.ТекстВысоко;
			Рекомендация = Описание.РекомендацияВысоко;
		Иначе
			Интерпретация.Описание = Описание.ТекстВНорме;
		КонецЕсли;
	КонецЕсли;
	
	Интерпретация.Вставить("ПолныйТекст", Интерпретация.Описание);
	Если ЗначениеЗаполнено(Рекомендация) Тогда
		Интерпретация.ПолныйТекст = Интерпретация.Описание + Символы.ПС + "→ " + Рекомендация;
	КонецЕсли;
	
	Возврат Интерпретация;
	
КонецФункции

Процедура ПрименитьРамку(Область, Толщина = 1)
	
	Линия = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, Толщина);
	Область.Обвести(Линия, Линия, Линия, Линия);
	
КонецПроцедуры

Процедура УстановитьВысотуСтроки(Область, Высота)
	
	Область.ВысотаСтроки = Высота;
	
КонецПроцедуры

Процедура УстановитьШиринуКолонки(ДокументРезультат, НомерКолонки, Ширина)
	
	ДокументРезультат.Область(1, НомерКолонки).ШиринаКолонки = Ширина;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
