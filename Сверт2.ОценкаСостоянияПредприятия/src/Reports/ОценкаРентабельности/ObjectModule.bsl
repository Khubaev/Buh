Функция ПолучитьЗначенияПоказателей(Организация, ПериодМесяца)
	
	Коды = Новый Массив;
	Коды.Добавить("146");
	Коды.Добавить("147");
	Коды.Добавить("149");
	Коды.Добавить("150");
	Коды.Добавить("151");
	Коды.Добавить("152");
	Коды.Добавить("153");
	Коды.Добавить("172");
	Коды.Добавить("173");
	Коды.Добавить("176");
	Коды.Добавить("179");
	Коды.Добавить("182");
	Коды.Добавить("185");
	Коды.Добавить("188");
	Коды.Добавить("191");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоказателиДляОтчета.Показатель.Код КАК Код,
	|	ПоказателиДляОтчета.Оценка КАК Оценка
	|ИЗ
	|	РегистрСведений.ПоказателиДляОтчета КАК ПоказателиДляОтчета
	|ГДЕ
	|	ПоказателиДляОтчета.Период = &ПериодМесяца
	|	И ПоказателиДляОтчета.Организация = &Организация
	|	И ПоказателиДляОтчета.Показатель.Код В (&Коды)";
	
	Запрос.УстановитьПараметр("ПериодМесяца", НачалоМесяца(ПериодМесяца));
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Коды", Коды);
	
	Результат = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Код, Выборка.Оценка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура СформироватьОтчет(ДокументРезультат, ПериодОтчета, Организация)
	
	ДокументРезультат.Очистить();
	НастроитьКолонки(ДокументРезультат);
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ДокументРезультат.Область(1, 1).Текст = "Укажите организацию в настройках отчёта";
		ДокументРезультат.ТолькоПросмотр = Истина;
		Возврат;
	КонецЕсли;
	
	ПериодМесяца = НачалоМесяца(ПериодОтчета.ДатаОкончания);
	ЗначенияПоказателей = ПолучитьЗначенияПоказателей(Организация, ПериодМесяца);
	ОписанияПоказателей = ОписаниеПоказателейРентабельности();
	СводкаПоказателей = Новый Массив;
	
	НомерСтроки = 1;
	НомерСтроки = ВывестиШапкуОтчета(ДокументРезультат, НомерСтроки, Организация, ПериодМесяца);
	
	ОбщаяОценка = ЗначенияПоказателей.Получить("146");
	Если ОбщаяОценка <> Неопределено Тогда
		НомерСтроки = НомерСтроки + 1;
		НомерСтроки = ВывестиБлокОбщейОценки(ДокументРезультат, НомерСтроки, ОбщаяОценка);
	КонецЕсли;
	
	НомерСтроки = НомерСтроки + 2;
	НомерСтрокиШапки = НомерСтроки;
	НомерСтроки = ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки);
	
	ЕстьДанные = Ложь;
	НомерКарточки = 0;
	
	Для Каждого Описание Из ОписанияПоказателей Цикл
		ЗначениеПоказателя = ЗначенияПоказателей.Получить(Описание.КодКоэффициента);
		ОценкаБА = ЗначенияПоказателей.Получить(Описание.КодОценки);
		
		Если ЗначениеПоказателя = Неопределено И ОценкаБА = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьДанные = Истина;
		НомерКарточки = НомерКарточки + 1;
		ИтоговаяОценка = ИтоговаяОценкаПоказателя(ЗначениеПоказателя, ОценкаБА, Описание);
		ОценкаДляОтображения = ?(ОценкаБА <> Неопределено, ОценкаБА, ИтоговаяОценка);
		Интерпретация = ИнтерпретацияПоказателя(ЗначениеПоказателя, ИтоговаяОценка, Описание);
		
		СводкаПоказателей.Добавить(Новый Структура(
			"Наименование, Уровень, Описание, Значение, НормализованноеЗначение",
			Описание.Наименование,
			Интерпретация.Уровень,
			Интерпретация.Описание,
			ЗначениеПоказателя,
			НормализоватьДолю(ЗначениеПоказателя)));
		
		НомерСтроки = ВывестиКарточкуПоказателя(
			ДокументРезультат,
			НомерСтроки,
			Описание,
			ЗначениеПоказателя,
			ИтоговаяОценка,
			Интерпретация,
			НомерКарточки,
			ОценкаДляОтображения);
	КонецЦикла;
	
	Если Не ЕстьДанные Тогда
		ДокументРезультат.Очистить();
		ДокументРезультат.Область(1, 1).Текст = СтрШаблон(
			"Нет данных по рентабельности за %1.%2 Загрузите оценки через «Интеграция бизнес аналитик».",
			Формат(ПериодМесяца, "ДФ=MMMM"),
			Символы.ПС);
		ДокументРезультат.ТолькоПросмотр = Истина;
		Возврат;
	КонецЕсли;
	
	НомерСтроки = НомерСтроки + 1;
	ВывестиЛегенду(ДокументРезультат, НомерСтроки);
	
	НомерСтроки = НомерСтроки + 5;
	ВывестиРезюмеДляРуководителя(ДокументРезультат, НомерСтроки, СводкаПоказателей, ОбщаяОценка);
	
	ДокументРезультат.ФиксацияСверху = НомерСтрокиШапки;
	ДокументРезультат.ФиксацияСлева = 1;
	ДокументРезультат.ТолькоПросмотр = Истина;
	ДокументРезультат.ОтображатьСетку = Ложь;
	ДокументРезультат.ОтображатьЗаголовки = Ложь;
	
КонецПроцедуры

Процедура НастроитьКолонки(ДокументРезультат)
	
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаПоказатель(), 30);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаЗначение(), 11);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаНорма(), 13);
	
	Для НомерСегмента = 0 По ШиринаШкалыСегментов() - 1 Цикл
		УстановитьШиринуКолонки(ДокументРезультат, КолонкаШкалаНачало() + НомерСегмента, 3.5);
	КонецЦикла;
	
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаОценкаБА(), 11);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаУровень(), 16);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаИнтерпретация(), 44);
	
КонецПроцедуры

Функция ВывестиШапкуОтчета(ДокументРезультат, НомерСтроки, Организация, ПериодМесяца)
	
	ОбластьЗаголовка = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Текст = "Оценка рентабельности предприятия";
	ОбластьЗаголовка.Шрифт = Новый Шрифт(, 16, Истина);
	ОбластьЗаголовка.ЦветФона = Новый Цвет(22, 78, 56);
	ОбластьЗаголовка.ЦветТекста = Новый Цвет(255, 255, 255);
	УстановитьВысотуСтроки(ОбластьЗаголовка, 30);
	ПрименитьРамку(ОбластьЗаголовка);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьОрганизации = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьОрганизации.Объединить();
	ОбластьОрганизации.Текст = СтрШаблон("Организация: %1", Организация);
	ОбластьОрганизации.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьОрганизации.Шрифт = Новый Шрифт(, 10, Истина);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьПериода = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьПериода.Объединить();
	ОбластьПериода.Текст = СтрШаблон("Период: %1", Формат(ПериодМесяца, "ДФ='MMMM yyyy'"));
	ОбластьПериода.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьПериода.ЦветТекста = Новый Цвет(71, 85, 105);
	ПрименитьРамку(ОбластьПериода);
	
	Возврат НомерСтроки;
	
КонецФункции

Функция ВывестиБлокОбщейОценки(ДокументРезультат, НомерСтроки, ОбщаяОценка)
	
	ИнтерпретацияОбщая = ИнтерпретацияОценки(ОбщаяОценка);
	ОбластьИтога = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьИтога.Объединить();
	ОбластьИтога.Текст = СтрШаблон(
		"Общая оценка рентабельности: %1 из 5  |  %2  |  %3",
		Формат(ОбщаяОценка, "ЧДЦ=2"),
		ИнтерпретацияОбщая.Уровень,
		ИнтерпретацияОбщая.Описание);
	ОбластьИтога.ЦветФона = ИнтерпретацияОбщая.ЦветФона;
	ОбластьИтога.ЦветТекста = ИнтерпретацияОбщая.ЦветТекста;
	ОбластьИтога.Шрифт = Новый Шрифт(, 11, Истина);
	ОбластьИтога.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	УстановитьВысотуСтроки(ОбластьИтога, 28);
	ПрименитьРамку(ОбластьИтога, 2);
	
	Возврат НомерСтроки;
	
КонецФункции

Функция ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки)
	
	ОбластьШкалы = ДокументРезультат.Область(
		НомерСтроки,
		КолонкаШкалаНачало(),
		НомерСтроки,
		КолонкаШкалаНачало() + ШиринаШкалыСегментов() - 1);
	ОбластьШкалы.Объединить();
	ОбластьШкалы.Текст = "Положение показателя";
	
	ДокументРезультат.Область(НомерСтроки, КолонкаПоказатель()).Текст = "Показатель";
	ДокументРезультат.Область(НомерСтроки, КолонкаЗначение()).Текст = "Значение";
	ДокументРезультат.Область(НомерСтроки, КолонкаНорма()).Текст = "Норма";
	ДокументРезультат.Область(НомерСтроки, КолонкаОценкаБА()).Текст = "Оценка БА";
	ДокументРезультат.Область(НомерСтроки, КолонкаУровень()).Текст = "Уровень";
	ДокументРезультат.Область(НомерСтроки, КолонкаИнтерпретация()).Текст = "Интерпретация и рекомендации";
	
	ОбластьШапки = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьШапки.Шрифт = Новый Шрифт(, , Истина);
	ОбластьШапки.ЦветФона = Новый Цвет(22, 78, 56);
	ОбластьШапки.ЦветТекста = Новый Цвет(255, 255, 255);
	ОбластьШапки.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	УстановитьВысотуСтроки(ОбластьШапки, 22);
	ПрименитьРамку(ОбластьШапки);
	
	Возврат НомерСтроки + 1;
	
КонецФункции

Функция ВывестиКарточкуПоказателя(ДокументРезультат, НомерСтроки, Описание, ЗначениеПоказателя, ИтоговаяОценка, Интерпретация, НомерКарточки, ОценкаДляОтображения)
	
	НомерСтрокиДанных = НомерСтроки;
	ЦветКарточки = ?(НомерКарточки % 2 = 0, Новый Цвет(248, 250, 252), Новый Цвет(255, 255, 255));
	Доля = НормализоватьДолю(ЗначениеПоказателя);
	
	ОбластьПоказателя = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаПоказатель());
	ОбластьПоказателя.Текст = Описание.Наименование;
	ОбластьПоказателя.Шрифт = Новый Шрифт(, 10, Истина);
	ОбластьПоказателя.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	
	ОбластьЗначения = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаЗначение());
	Если Доля <> Неопределено Тогда
		ОбластьЗначения.Текст = ПредставлениеПроцента(Доля);
		ОбластьЗначения.Шрифт = Новый Шрифт(, 11, Истина);
	Иначе
		ОбластьЗначения.Текст = "—";
	КонецЕсли;
	ОбластьЗначения.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьНормы = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаНорма());
	ОбластьНормы.Текст = СтрШаблон("%1 – %2",
		ПредставлениеПроцента(Описание.МинНорма),
		ПредставлениеПроцента(Описание.МаксНорма));
	ОбластьНормы.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьОценки = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаОценкаБА());
	Если ОценкаДляОтображения <> Неопределено Тогда
		ОбластьОценки.Текст = Формат(ОценкаДляОтображения, "ЧДЦ=2");
		ОбластьОценки.Шрифт = Новый Шрифт(, 11, Истина);
	Иначе
		ОбластьОценки.Текст = "—";
	КонецЕсли;
	ОбластьОценки.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьУровня = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаУровень());
	ОбластьУровня.Текст = Интерпретация.Уровень;
	ОбластьУровня.ЦветФона = Интерпретация.ЦветФона;
	ОбластьУровня.ЦветТекста = Интерпретация.ЦветТекста;
	ОбластьУровня.Шрифт = Новый Шрифт(, , Истина);
	ОбластьУровня.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьИнтерпретации = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаИнтерпретация());
	ОбластьИнтерпретации.Текст = Интерпретация.ПолныйТекст;
	ОбластьИнтерпретации.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьИнтерпретации.ЦветТекста = Новый Цвет(51, 65, 85);
	
	ОбластьДанных = ДокументРезультат.Область(НомерСтрокиДанных, 1, НомерСтрокиДанных, ПоследняяКолонка());
	ОбластьДанных.ЦветФона = ЦветКарточки;
	УстановитьВысотуСтроки(ОбластьДанных, 30);
	ПрименитьРамку(ОбластьДанных);
	
	НарисоватьЦветнуюШкалу(ДокументРезультат, НомерСтрокиДанных, Доля, Описание);
	ОбластьУровня.ЦветФона = Интерпретация.ЦветФона;
	ОбластьУровня.ЦветТекста = Интерпретация.ЦветТекста;
	
	НомерСтроки = НомерСтрокиДанных + 1;
	ОбластьПодписиШкалы = ДокументРезультат.Область(НомерСтроки, КолонкаШкалаНачало(), НомерСтроки, КолонкаШкалаНачало() + ШиринаШкалыСегментов() - 1);
	ОбластьПодписиШкалы.Объединить();
	ОбластьПодписиШкалы.Текст = СтрШаблон(
		"0%% — %1   |   норма %2 – %3",
		ПредставлениеПроцента(Описание.МаксШкалы),
		ПредставлениеПроцента(Описание.МинНорма),
		ПредставлениеПроцента(Описание.МаксНорма));
	ОбластьПодписиШкалы.ЦветТекста = Новый Цвет(100, 116, 139);
	ОбластьПодписиШкалы.Шрифт = Новый Шрифт(, 8);
	ОбластьПодписиШкалы.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	ОбластьПодписиШкалы.ЦветФона = Новый Цвет(248, 250, 252);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьПодсказки = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьПодсказки.Объединить();
	ОбластьПодсказки.Текст = Описание.ТекстНормы;
	ОбластьПодсказки.ЦветФона = Новый Цвет(248, 250, 252);
	ОбластьПодсказки.ЦветТекста = Новый Цвет(100, 116, 139);
	ОбластьПодсказки.Шрифт = Новый Шрифт(, 8);
	ОбластьПодсказки.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ПрименитьРамку(ОбластьПодсказки);
	
	Возврат НомерСтроки + 1;
	
КонецФункции

Процедура ВывестиЛегенду(ДокументРезультат, НомерСтроки)
	
	ОбластьЛегенды = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки + 3, ПоследняяКолонка());
