#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Возвращает признаки обработчиков, которые общая форма отчетов вызывает при формировании.
//
Функция ПолучитьПараметрыИсполненияОтчета() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("ИспользоватьПередКомпоновкойМакета", Истина);
	
	Возврат Результат;
	
КонецФункции

// Перед построением макета СКД подставляет служебные параметры запроса.
//
Процедура ПередКомпоновкойМакета(ПараметрыОтчета, Схема, КомпоновщикНастроек) Экспорт
	
	Организация = ПолучитьЗначениеПараметраКомпоновки(КомпоновщикНастроек, "Организация");
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	КонецЕсли;
	
	КонецПериода = ГраницаКонцаПериодаОтчета(ПараметрыОтчета, КомпоновщикНастроек);
	Склады = ПолучитьЗначениеПараметраКомпоновки(КомпоновщикНастроек, "Склады");
	
	УстановитьПараметрыКомпоновки(КомпоновщикНастроек, Организация, КонецПериода, Склады);
	
КонецПроцедуры

// Сверка остатков ОСВ по счёту 10 (номенклатура + склад) с регистром бит_стр_ТоварыНаСкладах.
//
Функция ПолучитьДанныеСверки(Организация, ДатаОстатков, Склады = Неопределено) Экспорт
	
	ГраницаОстатков = ГраницаДатыОстатков(ДатаОстатков);
	ОтборПоСкладу = ЕстьОтборПоСкладам(Склады);
	СтруктураСчетов = СтруктураСчетовУчетаНаСкладах(СчетаУчетаМатериалов());
	
	ИтогиОСВ = ПолучитьИтогиОСВПоСчету10(Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады);
	ИтогиРН = ПолучитьИтогиБитСтрТоварыНаСкладах(ГраницаОстатков, ОтборПоСкладу, Склады);
	Расхождение = Новый Структура("Количество", ИтогиОСВ.Количество - ИтогиРН.Количество);
	
	ДетализацияПоНоменклатуреИСкладам = ПолучитьДетализациюПоНоменклатуреИСкладам(
		Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады);
	
	Возврат Новый Структура("ИтогиОСВ, ИтогиМПЗ, Расхождение, ДетализацияПоНоменклатуреИСкладам",
		ИтогиОСВ, ИтогиРН, Расхождение, ДетализацияПоНоменклатуреИСкладам);
	
КонецФункции

// Подставляет в настройки СКД параметры запроса.
//
Процедура УстановитьПараметрыКомпоновки(КомпоновщикНастроек, Организация, КонецПериода, Склады) Экспорт
	
	МассивСкладов = МассивСкладовОтбора(Склады);
	
	УстановитьПараметрКомпоновки(КомпоновщикНастроек, "Организация", Организация);
	УстановитьПараметрКомпоновки(КомпоновщикНастроек, "КонецПериода", КонецПериода);
	УстановитьПараметрКомпоновки(КомпоновщикНастроек, "ОтборПоСкладу", МассивСкладов.Количество() > 0);
	УстановитьПараметрКомпоновки(КомпоновщикНастроек, "МассивСкладов", МассивСкладов);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура УстановитьПараметрКомпоновки(КомпоновщикНастроек, ИмяПараметра, Значение)
	
	БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, ИмяПараметра, Значение);
	КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(ИмяПараметра, Значение);
	
КонецПроцедуры

Функция ПолучитьЗначениеПараметраКомпоновки(КомпоновщикНастроек, ИмяПараметра)
	
	ЗначениеПараметра = БухгалтерскиеОтчетыКлиентСервер.ПолучитьПараметр(КомпоновщикНастроек, ИмяПараметра);
	
	Если ЗначениеПараметра = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ЗначениеПараметра.Значение;
	
КонецФункции

Функция ГраницаКонцаПериодаОтчета(ПараметрыОтчета, КомпоновщикНастроек)
	
	КонецПериода = Неопределено;
	Если ПараметрыОтчета.Свойство("КонецПериода", КонецПериода)
		И ЗначениеЗаполнено(КонецПериода) Тогда
		Возврат Новый Граница(КонецДня(КонецПериода), ВидГраницы.Включая);
	КонецЕсли;
	
	Период = ПолучитьЗначениеПараметраКомпоновки(КомпоновщикНастроек, "Период");
	Если ТипЗнч(Период) = Тип("СтандартныйПериод")
		И ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
		Возврат Новый Граница(КонецДня(Период.ДатаОкончания), ВидГраницы.Включая);
	КонецЕсли;
	
	Возврат Новый Граница(КонецДня(ТекущаяДата()), ВидГраницы.Включая);
	
КонецФункции

Функция ГраницаДатыОстатков(ДатаОстатков)
	
	Если ТипЗнч(ДатаОстатков) = Тип("Граница") Тогда
		Возврат ДатаОстатков;
	КонецЕсли;
	
	Возврат Новый Граница(КонецДня(ДатаОстатков), ВидГраницы.Включая);
	
КонецФункции

Функция МассивСкладовОтбора(Склады) Экспорт
	
	МассивСкладов = Новый Массив;
	
	Если Склады = Неопределено Тогда
		Возврат МассивСкладов;
	КонецЕсли;
	
	Если ТипЗнч(Склады) = Тип("Массив") Или ТипЗнч(Склады) = Тип("ФиксированныйМассив") Тогда
		
		Для Каждого Склад Из Склады Цикл
			Если ЗначениеЗаполнено(Склад) Тогда
				МассивСкладов.Добавить(Склад);
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(Склады) = Тип("СписокЗначений") Тогда
		
		ЕстьОтмеченные = Ложь;
		Для Каждого ЭлементСписка Из Склады Цикл
			Если ЭлементСписка.Пометка Тогда
				ЕстьОтмеченные = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого ЭлементСписка Из Склады Цикл
			Если ЗначениеЗаполнено(ЭлементСписка.Значение)
				И (Не ЕстьОтмеченные Или ЭлементСписка.Пометка) Тогда
				МассивСкладов.Добавить(ЭлементСписка.Значение);
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли ЗначениеЗаполнено(Склады) Тогда
		
		Попытка
			Для Каждого Элемент Из Склады Цикл
				Склад = СсылкаСкладаИзЭлементаОтбора(Элемент);
				Если ЗначениеЗаполнено(Склад) Тогда
					МассивСкладов.Добавить(Склад);
				КонецЕсли;
			КонецЦикла;
		Исключение
			МассивСкладов.Добавить(Склады);
		КонецПопытки;
		
	КонецЕсли;
	
	Возврат МассивСкладов;
	
КонецФункции

Функция СсылкаСкладаИзЭлементаОтбора(Элемент)
	
	Если ТипЗнч(Элемент) = Тип("СправочникСсылка.Склады") Тогда
		Возврат Элемент;
	КонецЕсли;
	
	Если ТипЗнч(Элемент) = Тип("ЭлементСпискаЗначений") Тогда
		Возврат Элемент.Значение;
	КонецЕсли;
	
	Возврат Элемент;
	
КонецФункции

Функция ЕстьОтборПоСкладам(Склады) Экспорт
	Возврат МассивСкладовОтбора(Склады).Количество() > 0;
КонецФункции

Процедура УстановитьПараметрыЗапросаСверки(Запрос, Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады)
	
	Запрос.УстановитьПараметр("ДатаОстатков", ГраницаОстатков);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ОтборПоСкладу", ОтборПоСкладу);
	Запрос.УстановитьПараметр("Склады", МассивСкладовОтбора(Склады));
	Запрос.УстановитьПараметр("СубконтоНоменклатураИСклад", МассивСубконтоНоменклатураИСклад());
	Запрос.УстановитьПараметр("СчетаУчетаСкладИНоменклатура", СтруктураСчетов.СчетаУчетаСкладИНоменклатура);
	Запрос.УстановитьПараметр("СчетаУчетаСкладТолькоКоличествоИНоменклатура", СтруктураСчетов.СчетаУчетаСкладТолькоКоличествоИНоменклатура);
	
КонецПроцедуры

Функция МассивСубконтоНоменклатураИСклад()
	
	Субконто = Новый Массив;
	Субконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура);
	Субконто.Добавить(ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	
	Возврат Субконто;
	
КонецФункции

Функция ТекстПустыхОстатковОСВ(ИмяВременнойТаблицы = "")
	
	Поместить = ?(ПустаяСтрока(ИмяВременнойТаблицы), "", "
	|ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
	
	Возврат
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка) КАК Номенклатура,
	|	ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка) КАК Склад,
	|	0 КАК Сумма,
	|	0 КАК Количество
	|" + Поместить + "
	|ГДЕ
	|	ЛОЖЬ";
	
КонецФункции

Функция СчетаУчетаМатериалов()
	
	СчетаВсеМПЗ = БухгалтерскиеОтчеты.СчетаУчетаТоваров();
	Счета10 = Новый Массив;
	
	Для Каждого Счет Из СчетаВсеМПЗ Цикл
		Если БухгалтерскийУчетПовтИсп.СчетВИерархии(Счет, ПланыСчетов.Хозрасчетный.Материалы) Тогда
			Счета10.Добавить(Счет);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Счета10;
	
КонецФункции

// Классификация счетов 10 по наличию складского субконто (как в отчёте «Остатки товаров»).
//
Функция СтруктураСчетовУчетаНаСкладах(СчетаУчетаТоваров)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ХозрасчетныйВидыСубконто.Ссылка КАК Счет,
	|	ХозрасчетныйВидыСубконто.Суммовой КАК Суммовой
	|ПОМЕСТИТЬ ВидыСубконто
	|ИЗ
	|	ПланСчетов.Хозрасчетный.ВидыСубконто КАК ХозрасчетныйВидыСубконто
	|ГДЕ
	|	ХозрасчетныйВидыСубконто.Ссылка В(&СчетаУчетаТоваров)
	|	И ХозрасчетныйВидыСубконто.ВидСубконто = &ВидСубконтоСклады
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Счет
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыСубконто.Счет КАК Счет
	|ИЗ
	|	ВидыСубконто КАК ВидыСубконто
	|ГДЕ
	|	ВидыСубконто.Суммовой = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВидыСубконто.Счет КАК Счет
	|ИЗ
	|	ВидыСубконто КАК ВидыСубконто
	|ГДЕ
	|	ВидыСубконто.Суммовой = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("СчетаУчетаТоваров", СчетаУчетаТоваров);
	Запрос.УстановитьПараметр("ВидСубконтоСклады", ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Склады);
	
	Результат = Запрос.ВыполнитьПакет();
	
	СтруктураСчетов = Новый Структура;
	СтруктураСчетов.Вставить("СчетаУчетаСкладИНоменклатура", Результат[1].Выгрузить().ВыгрузитьКолонку("Счет"));
	СтруктураСчетов.Вставить("СчетаУчетаСкладТолькоКоличествоИНоменклатура", Результат[2].Выгрузить().ВыгрузитьКолонку("Счет"));
	
	Возврат СтруктураСчетов;
	
КонецФункции

Функция УсловиеОтбораПоСкладуОСВ(ОтборПоСкладу)
	
	Если ОтборПоСкладу Тогда
		Возврат "
		|	И ХозрасчетныйОстатки.Субконто2 В (&Склады)";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция УсловиеОтбораПоСкладуРН(ОтборПоСкладу)
	
	Если ОтборПоСкладу Тогда
		Возврат ", Склад В (&Склады)";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Функция РазделительЗапросовПакета()
	Возврат ";
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
КонецФункции

// Одна часть остатков ОСВ по счетам с аналитикой «номенклатура + склад».
//
Функция ТекстЗапросаЧастьОСВПоСчетам(ИмяПараметраСчетов, УсловиеСклад)
	
	Возврат
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Субконто1 КАК Номенклатура,
	|	ХозрасчетныйОстатки.Субконто2 КАК Склад,
	|	ХозрасчетныйОстатки.СуммаОстаток КАК Сумма,
	|	ХозрасчетныйОстатки.КоличествоОстаток КАК Количество
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&ДатаОстатков,
	|			Счет В (&" + ИмяПараметраСчетов + "),
	|			&СубконтоНоменклатураИСклад,
	|			Организация = &Организация) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ЗНАЧЕНИЕЗАПОЛНЕНО(ХозрасчетныйОстатки.Субконто2)" + УсловиеСклад;
	
КонецФункции

// Запасной вариант: вся иерархия счёта 10, если классификация счетов вернула пустые массивы.
//
Функция ТекстЗапросаОСВИерархияМатериалы(УсловиеСклад, ИмяВременнойТаблицы = "")
	
	Поместить = ?(ПустаяСтрока(ИмяВременнойТаблицы), "", "
	|ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
	
	Возврат
	"ВЫБРАТЬ
	|	ХозрасчетныйОстатки.Субконто1 КАК Номенклатура,
	|	ХозрасчетныйОстатки.Субконто2 КАК Склад,
	|	СУММА(ХозрасчетныйОстатки.СуммаОстаток) КАК Сумма,
	|	СУММА(ХозрасчетныйОстатки.КоличествоОстаток) КАК Количество
	|" + Поместить + "
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.Остатки(
	|			&ДатаОстатков,
	|			Счет В ИЕРАРХИИ (ЗНАЧЕНИЕ(ПланСчетов.Хозрасчетный.Материалы)),
	|			&СубконтоНоменклатураИСклад,
	|			Организация = &Организация) КАК ХозрасчетныйОстатки
	|ГДЕ
	|	ЗНАЧЕНИЕЗАПОЛНЕНО(ХозрасчетныйОстатки.Субконто2)" + УсловиеСклад + "
	|СГРУППИРОВАТЬ ПО
	|	ХозрасчетныйОстатки.Субконто1,
	|	ХозрасчетныйОстатки.Субконто2";
	
КонецФункции

// Остатки ОСВ по счёту 10 с аналитикой номенклатура + склад (обе группы складских счетов).
//
Функция ТекстЗапросаОстаткиОСВПоСчету10(СтруктураСчетов, ОтборПоСкладу, ИмяВременнойТаблицы = "")
	
	УсловиеСклад = УсловиеОтбораПоСкладуОСВ(ОтборПоСкладу);
	ЧастиЗапроса = Новый Массив;
	
	Если СтруктураСчетов.СчетаУчетаСкладИНоменклатура.Количество() > 0 Тогда
		ЧастиЗапроса.Добавить(ТекстЗапросаЧастьОСВПоСчетам("СчетаУчетаСкладИНоменклатура", УсловиеСклад));
	КонецЕсли;
	
	Если СтруктураСчетов.СчетаУчетаСкладТолькоКоличествоИНоменклатура.Количество() > 0 Тогда
		ЧастиЗапроса.Добавить(ТекстЗапросаЧастьОСВПоСчетам("СчетаУчетаСкладТолькоКоличествоИНоменклатура", УсловиеСклад));
	КонецЕсли;
	
	Если ЧастиЗапроса.Количество() = 0 Тогда
		Возврат ТекстЗапросаОСВИерархияМатериалы(УсловиеСклад, ИмяВременнойТаблицы);
	КонецЕсли;
	
	ТекстОбъединения = ЧастиЗапроса[0];
	Для Индекс = 1 По ЧастиЗапроса.ВГраница() Цикл
		ТекстОбъединения = ТекстОбъединения + "
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|" + ЧастиЗапроса[Индекс];
	КонецЦикла;
	
	Поместить = ?(ПустаяСтрока(ИмяВременнойТаблицы), "", "
	|ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
	
	Возврат
	"ВЫБРАТЬ
	|	ОстаткиСтроки.Номенклатура КАК Номенклатура,
	|	ОстаткиСтроки.Склад КАК Склад,
	|	СУММА(ОстаткиСтроки.Сумма) КАК Сумма,
	|	СУММА(ОстаткиСтроки.Количество) КАК Количество
	|" + Поместить + "
	|ИЗ
	|	(" + ТекстОбъединения + ") КАК ОстаткиСтроки
	|СГРУППИРОВАТЬ ПО
	|	ОстаткиСтроки.Номенклатура,
	|	ОстаткиСтроки.Склад";
	
КонецФункции

// Остатки регистра бит_стр_ТоварыНаСкладах по номенклатуре и складу.
//
Функция ТекстЗапросаОстаткиБитСтрТоварыНаСкладах(ОтборПоСкладу, ИмяВременнойТаблицы = "")
	
	УсловиеСклад = УсловиеОтбораПоСкладуРН(ОтборПоСкладу);
	Поместить = ?(ПустаяСтрока(ИмяВременнойТаблицы), "", "
	|ПОМЕСТИТЬ " + ИмяВременнойТаблицы);
	
	Возврат
	"ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыНаСкладахОстатки.Склад КАК Склад,
	|	СУММА(ТоварыНаСкладахОстатки.КоличествоОстаток) КАК Количество
	|" + Поместить + "
	|ИЗ
	|	РегистрНакопления.бит_стр_ТоварыНаСкладах.Остатки(
	|			&ДатаОстатков" + УсловиеСклад + ") КАК ТоварыНаСкладахОстатки
	|СГРУППИРОВАТЬ ПО
	|	ТоварыНаСкладахОстатки.Номенклатура,
	|	ТоварыНаСкладахОстатки.Склад";
	
КонецФункции

Функция ТекстЗапросаДетализацииПоНоменклатуреИСкладам(СтруктураСчетов, ОтборПоСкладу)
	
	Разделитель = РазделительЗапросовПакета();
	
	Возврат ТекстЗапросаОстаткиОСВПоСчету10(СтруктураСчетов, ОтборПоСкладу, "ОстаткиОСВ") + Разделитель
		+ ТекстЗапросаОстаткиБитСтрТоварыНаСкладах(ОтборПоСкладу, "ОстаткиРН") + Разделитель + "
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ОстаткиОСВ.Номенклатура, ОстаткиРН.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ОстаткиОСВ.Номенклатура, ОстаткиРН.Номенклатура) КАК Справочник.Номенклатура).Код КАК КодНоменклатуры,
	|	ЕСТЬNULL(ОстаткиОСВ.Склад, ОстаткиРН.Склад) КАК Склад,
	|	ЕСТЬNULL(ОстаткиОСВ.Сумма, 0) КАК СуммаОСВ,
	|	ЕСТЬNULL(ОстаткиОСВ.Количество, 0) КАК КоличествоОСВ,
	|	ЕСТЬNULL(ОстаткиРН.Количество, 0) КАК КоличествоМПЗ,
	|	ЕСТЬNULL(ОстаткиОСВ.Количество, 0) - ЕСТЬNULL(ОстаткиРН.Количество, 0) КАК РасхождениеКоличество
	|ИЗ
	|	ОстаткиОСВ КАК ОстаткиОСВ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ОстаткиРН КАК ОстаткиРН
	|		ПО ОстаткиОСВ.Номенклатура = ОстаткиРН.Номенклатура
	|			И ОстаткиОСВ.Склад = ОстаткиРН.Склад
	|ГДЕ
	|	ЕСТЬNULL(ОстаткиОСВ.Сумма, 0) <> 0
	|		ИЛИ ЕСТЬNULL(ОстаткиОСВ.Количество, 0) <> 0
	|		ИЛИ ЕСТЬNULL(ОстаткиРН.Количество, 0) <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	Склад,
	|	КодНоменклатуры,
	|	Номенклатура";
	
КонецФункции

Функция ПолучитьИтогиОСВПоСчету10(Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(ОстаткиОСВ.Сумма) КАК Сумма,
	|	СУММА(ОстаткиОСВ.Количество) КАК Количество
	|ИЗ
	|	(" + ТекстЗапросаОстаткиОСВПоСчету10(СтруктураСчетов, ОтборПоСкладу) + ") КАК ОстаткиОСВ";
	
	УстановитьПараметрыЗапросаСверки(Запрос, Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Новый Структура("Сумма, Количество", Выборка.Сумма, Выборка.Количество);
	
КонецФункции

Функция ПолучитьИтогиБитСтрТоварыНаСкладах(ГраницаОстатков, ОтборПоСкладу, Склады)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	СУММА(ОстаткиРН.Количество) КАК Количество
	|ИЗ
	|	(" + ТекстЗапросаОстаткиБитСтрТоварыНаСкладах(ОтборПоСкладу) + ") КАК ОстаткиРН";
	
	Запрос.УстановитьПараметр("ДатаОстатков", ГраницаОстатков);
	Запрос.УстановитьПараметр("ОтборПоСкладу", ОтборПоСкладу);
	Запрос.УстановитьПараметр("Склады", МассивСкладовОтбора(Склады));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Возврат Новый Структура("Сумма, Количество", 0, Выборка.Количество);
	
КонецФункции

Функция ПолучитьДетализациюПоНоменклатуреИСкладам(Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаДетализацииПоНоменклатуреИСкладам(СтруктураСчетов, ОтборПоСкладу);
	УстановитьПараметрыЗапросаСверки(Запрос, Организация, ГраницаОстатков, СтруктураСчетов, ОтборПоСкладу, Склады);
	
	РезультатПакета = Запрос.ВыполнитьПакет();
	Возврат РезультатПакета[РезультатПакета.ВГраница()].Выгрузить();
	
КонецФункции

