#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Формирует отчет без стандартного набора данных СКД, чтобы исключить ошибку типа первого параметра Остатки().
//
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Организация = ПолучитьЗначениеПараметра("Организация");
	Если Не ЗначениеЗаполнено(Организация) Тогда
		Организация = Справочники.Организации.ОрганизацияПоУмолчанию();
	КонецЕсли;
	
	Период = ПолучитьЗначениеПараметра("Период");
	Если ТипЗнч(Период) <> Тип("СтандартныйПериод") Или Не ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
		Период = Новый СтандартныйПериод(ВариантСтандартногоПериода.ЭтотМесяц);
		БухгалтерскиеОтчетыКлиентСервер.УстановитьПараметр(КомпоновщикНастроек, "Период", Период);
	КонецЕсли;
	
	Склады = ПолучитьЗначениеПараметраСклады();
	ДанныеСверки = Отчеты.СверкаОСВ10ИМПЗНаСкладах.ПолучитьДанныеСверки(
		Организация, Период.ДатаОкончания, Склады);
	
	ВывестиДанныеСверки(ДокументРезультат, Организация, Период, ДанныеСверки);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выводит строки сверки с группировкой по складу.
//
Процедура ВывестиДанныеСверки(ДокументРезультат, Организация, Период, ДанныеСверки)
	
	ДокументРезультат.Очистить();
	
	НомерСтроки = 1;
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Сверка ОСВ по счёту 10 и бит_стр_ТоварыНаСкладах", Истина);
	НомерСтроки = НомерСтроки + 1;
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Организация: " + Строка(Организация));
	НомерСтроки = НомерСтроки + 1;
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Период: " + Формат(Период.ДатаНачала, "ДЛФ=Д") + " - " + Формат(Период.ДатаОкончания, "ДЛФ=Д"));
	НомерСтроки = НомерСтроки + 2;
	
	ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки);
	НомерСтроки = НомерСтроки + 1;
	
	ТаблицаДетализации = ДанныеСверки.ДетализацияПоНоменклатуреИСкладам;
	ТаблицаДетализации.Сортировать("Склад, КодНоменклатуры, Номенклатура");
	
	ТекущийСклад = Неопределено;
	ПервыйСклад = Истина;
	ИтогиСклада = Новый Структура("СуммаОСВ, КоличествоОСВ, КоличествоМПЗ, РасхождениеКоличество", 0, 0, 0, 0);
	
	Для Каждого СтрокаДетализации Из ТаблицаДетализации Цикл
		
		Если ПервыйСклад Или СтрокаДетализации.Склад <> ТекущийСклад Тогда
			
			Если Не ПервыйСклад Тогда
				ВывестиИтогСклада(ДокументРезультат, НомерСтроки, ИтогиСклада);
				НомерСтроки = НомерСтроки + 1;
			КонецЕсли;
			
			ТекущийСклад = СтрокаДетализации.Склад;
			ПервыйСклад = Ложь;
			ИтогиСклада = Новый Структура("СуммаОСВ, КоличествоОСВ, КоличествоМПЗ, РасхождениеКоличество", 0, 0, 0, 0);
			
			ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Склад", Истина);
			ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 3, ПредставлениеСклада(ТекущийСклад), Истина);
			НомерСтроки = НомерСтроки + 1;
			
		КонецЕсли;
		
		ВывестиСтрокуДетализации(ДокументРезультат, НомерСтроки, СтрокаДетализации);
		ДобавитьКИтогамСклада(ИтогиСклада, СтрокаДетализации);
		НомерСтроки = НомерСтроки + 1;
		
	КонецЦикла;
	
	Если Не ПервыйСклад Тогда
		ВывестиИтогСклада(ДокументРезультат, НомерСтроки, ИтогиСклада);
		НомерСтроки = НомерСтроки + 2;
	КонецЕсли;
	
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Итого", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 4, ДанныеСверки.ИтогиОСВ.Сумма, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 5, ДанныеСверки.ИтогиОСВ.Количество, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 6, ДанныеСверки.ИтогиМПЗ.Количество, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 7, ДанныеСверки.Расхождение.Количество, Истина);
	
	УстановитьШиринуКолонок(ДокументРезультат);
	
КонецПроцедуры

// Выводит заголовки колонок результата.
//
Процедура ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки)
	
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Код", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 2, "Номенклатура", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 3, "Склад", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 4, "Бух. сумма", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 5, "Бух. кол-во", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 6, "бит_стр кол-во", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 7, "Δ кол-во", Истина);
	
КонецПроцедуры

// Выводит одну строку детализации.
//
Процедура ВывестиСтрокуДетализации(ДокументРезультат, НомерСтроки, СтрокаДетализации)
	
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, СтрокаДетализации.КодНоменклатуры);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 2, СтрокаДетализации.Номенклатура);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 3, "");
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 4, СтрокаДетализации.СуммаОСВ);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 5, СтрокаДетализации.КоличествоОСВ);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 6, СтрокаДетализации.КоличествоМПЗ);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 7, СтрокаДетализации.РасхождениеКоличество);
	
КонецПроцедуры

// Накапливает итоги группы склада.
//
Процедура ДобавитьКИтогамСклада(ИтогиСклада, СтрокаДетализации)
	
	ИтогиСклада.СуммаОСВ = ИтогиСклада.СуммаОСВ + СтрокаДетализации.СуммаОСВ;
	ИтогиСклада.КоличествоОСВ = ИтогиСклада.КоличествоОСВ + СтрокаДетализации.КоличествоОСВ;
	ИтогиСклада.КоличествоМПЗ = ИтогиСклада.КоличествоМПЗ + СтрокаДетализации.КоличествоМПЗ;
	ИтогиСклада.РасхождениеКоличество = ИтогиСклада.РасхождениеКоличество + СтрокаДетализации.РасхождениеКоличество;
	
КонецПроцедуры

// Выводит итоговую строку склада.
//
Процедура ВывестиИтогСклада(ДокументРезультат, НомерСтроки, ИтогиСклада)
	
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 1, "Итого по складу", Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 4, ИтогиСклада.СуммаОСВ, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 5, ИтогиСклада.КоличествоОСВ, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 6, ИтогиСклада.КоличествоМПЗ, Истина);
	ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, 7, ИтогиСклада.РасхождениеКоличество, Истина);
	
КонецПроцедуры

// Заполняет ячейку табличного документа значением и базовым оформлением.
//
Процедура ЗаполнитьЯчейку(ДокументРезультат, НомерСтроки, НомерКолонки, Значение, Жирный = Ложь)
	
	Область = ДокументРезультат.Область(НомерСтроки, НомерКолонки);
	Область.Значение = Значение;
	
	Если Жирный Тогда
		Область.Шрифт = Новый Шрифт(Область.Шрифт, , , Истина);
	КонецЕсли;
	
КонецПроцедуры

// Возвращает представление склада для строки группы.
//
Функция ПредставлениеСклада(Склад)
	
	Если ЗначениеЗаполнено(Склад) Тогда
		Возврат Строка(Склад);
	КонецЕсли;
	
	Возврат "Без склада";
	
КонецФункции

// Настраивает ширину колонок результата.
//
Процедура УстановитьШиринуКолонок(ДокументРезультат)
	
	ДокументРезультат.Область(1, 1).ШиринаКолонки = 12;
	ДокументРезультат.Область(1, 2).ШиринаКолонки = 45;
	ДокументРезультат.Область(1, 3).ШиринаКолонки = 30;
	ДокументРезультат.Область(1, 4).ШиринаКолонки = 15;
	ДокументРезультат.Область(1, 5).ШиринаКолонки = 15;
	ДокументРезультат.Область(1, 6).ШиринаКолонки = 15;
	ДокументРезультат.Область(1, 7).ШиринаКолонки = 15;
	
КонецПроцедуры

Функция ПолучитьЗначениеПараметра(ИмяПараметра)
	
	ЗначениеПараметра = БухгалтерскиеОтчетыКлиентСервер.ПолучитьПараметр(КомпоновщикНастроек, ИмяПараметра);
	
	Если ЗначениеПараметра = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ЗначениеПараметра.Значение;
	
КонецФункции

// Возвращает значение параметра «Склады»; при заполненном списке включает использование параметра.
//
Функция ПолучитьЗначениеПараметраСклады()
	
	ЗначениеПараметра = БухгалтерскиеОтчетыКлиентСервер.ПолучитьПараметр(КомпоновщикНастроек, "Склады");
	
	Если ЗначениеПараметра = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Склады = ЗначениеПараметра.Значение;
	
	Если Отчеты.СверкаОСВ10ИМПЗНаСкладах.ЕстьОтборПоСкладам(Склады) Тогда
		ЗначениеПараметра.Использование = Истина;
		Возврат Склады;
	КонецЕсли;
	
	Если ЗначениеПараметра.Использование Тогда
		Возврат Склады;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

#КонецОбласти

#КонецЕсли
