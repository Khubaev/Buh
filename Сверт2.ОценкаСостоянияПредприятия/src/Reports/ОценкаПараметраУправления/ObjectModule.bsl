КонецФункции

Функция ПолучитьЗначенияПоказателей(Организация, ПериодМесяца)
	
	Коды = Новый Массив;
	Коды.Добавить("194");
	Коды.Добавить("195");
	Коды.Добавить("196");
	Коды.Добавить("197");
	Коды.Добавить("198");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоказателиДляОтчета.Показатель.Код КАК Код,
	|	ПоказателиДляОтчета.Оценка КАК Оценка
	|ИЗ
	|	РегистрСведений.ПоказателиДляОтчета КАК ПоказателиДляОтчета
	|ГДЕ
	|	ПоказателиДляОтчета.Период = &ПериодМесяца
	|	И ПоказателиДляОтчета.Организация = &Организация
	|	И ПоказателиДляОтчета.Показатель.Код В (&Коды)";
	
	Запрос.УстановитьПараметр("ПериодМесяца", НачалоМесяца(ПериодМесяца));
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Коды", Коды);
	
	Результат = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Результат.Вставить(Выборка.Код, Выборка.Оценка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура СформироватьОтчет(ДокументРезультат, ПериодОтчета, Организация)
	
	ДокументРезультат.Очистить();
	НастроитьКолонки(ДокументРезультат);
	
	Если Не ЗначениеЗаполнено(Организация) Тогда
		ДокументРезультат.Область(1, 1).Текст = "Укажите организацию в настройках отчёта";
		ДокументРезультат.ТолькоПросмотр = Истина;
		Возврат;
	КонецЕсли;
	
	ПериодМесяца = НачалоМесяца(ПериодОтчета.ДатаОкончания);
	ЗначенияПоказателей = ПолучитьЗначенияПоказателей(Организация, ПериодМесяца);
	ОписанияПоказателей = ОписаниеПоказателейУправления();
	СводкаПоказателей = Новый Массив;
	
	НомерСтроки = 1;
	НомерСтроки = ВывестиШапкуОтчета(ДокументРезультат, НомерСтроки, Организация, ПериодМесяца);
	
	ОбщаяОценка = ЗначенияПоказателей.Получить("194");
	Если ОбщаяОценка <> Неопределено Тогда
		НомерСтроки = НомерСтроки + 1;
		НомерСтроки = ВывестиБлокОбщейОценки(ДокументРезультат, НомерСтроки, ОбщаяОценка);
	КонецЕсли;
	
	НомерСтроки = НомерСтроки + 2;
	НомерСтрокиШапки = НомерСтроки;
	НомерСтроки = ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки);
	
	ЕстьДанные = Ложь;
	НомерКарточки = 0;
	
	Для Каждого Описание Из ОписанияПоказателей Цикл
		ЗначениеПоказателя = ЗначенияПоказателей.Получить(Описание.КодЗначения);
		
		Если ЗначениеПоказателя = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьДанные = Истина;
		НомерКарточки = НомерКарточки + 1;
		РассчитаннаяОценка = РассчитатьОценкуПоЗначению(ЗначениеПоказателя, Описание);
		Интерпретация = ИнтерпретацияПоказателя(ЗначениеПоказателя, РассчитаннаяОценка, Описание);
		
		СводкаПоказателей.Добавить(Новый Структура(
			"Наименование, Уровень, Описание, Значение, Рекомендация",
			Описание.Наименование,
			Интерпретация.Уровень,
			Интерпретация.Описание,
			ЗначениеПоказателя,
			Интерпретация.Рекомендация));
		
		НомерСтроки = ВывестиКарточкуПоказателя(
			ДокументРезультат,
			НомерСтроки,
			Описание,
			ЗначениеПоказателя,
			РассчитаннаяОценка,
			Интерпретация,
			НомерКарточки);
	КонецЦикла;
	
	Если Не ЕстьДанные Тогда
		ДокументРезультат.Очистить();
		ДокументРезультат.Область(1, 1).Текст = СтрШаблон(
			"Нет данных по параметрам управления за %1.%2 Загрузите показатели через «Интеграция бизнес аналитик».",
			Формат(ПериодМесяца, "ДФ=MMMM"),
			Символы.ПС);
		ДокументРезультат.ТолькоПросмотр = Истина;
		Возврат;
	КонецЕсли;
	
	НомерСтроки = НомерСтроки + 1;
	ВывестиБлокЗонУлучшения(ДокументРезультат, НомерСтроки, СводкаПоказателей);
	
	НомерСтроки = НомерСтроки + 3;
	ВывестиЛегенду(ДокументРезультат, НомерСтроки);
	
	НомерСтроки = НомерСтроки + 5;
	ВывестиРезюмеДляРуководителя(ДокументРезультат, НомерСтроки, СводкаПоказателей, ОбщаяОценка);
	
	ДокументРезультат.ФиксацияСверху = НомерСтрокиШапки;
	ДокументРезультат.ФиксацияСлева = 1;
	ДокументРезультат.ТолькоПросмотр = Истина;
	ДокументРезультат.ОтображатьСетку = Ложь;
	ДокументРезультат.ОтображатьЗаголовки = Ложь;
	
КонецПроцедуры

Процедура НастроитьКолонки(ДокументРезультат)
	
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаПоказатель(), 30);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаЗначение(), 11);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаНорма(), 13);
	
	Для НомерСегмента = 0 По ШиринаШкалыСегментов() - 1 Цикл
		УстановитьШиринуКолонки(ДокументРезультат, КолонкаШкалаНачало() + НомерСегмента, 3.5);
	КонецЦикла;
	
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаОценка(), 11);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаУровень(), 16);
	УстановитьШиринуКолонки(ДокументРезультат, КолонкаИнтерпретация(), 44);
	
КонецПроцедуры

Функция ВывестиШапкуОтчета(ДокументРезультат, НомерСтроки, Организация, ПериодМесяца)
	
	ОбластьЗаголовка = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Текст = "Оценка параметра управления (EGS)";
	ОбластьЗаголовка.Шрифт = Новый Шрифт(, 16, Истина);
	ОбластьЗаголовка.ЦветФона = ЦветЗаголовка();
	ОбластьЗаголовка.ЦветТекста = Новый Цвет(255, 255, 255);
	УстановитьВысотуСтроки(ОбластьЗаголовка, 30);
	ПрименитьРамку(ОбластьЗаголовка);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьОрганизации = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьОрганизации.Объединить();
	ОбластьОрганизации.Текст = СтрШаблон("Организация: %1", Организация);
	ОбластьОрганизации.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьОрганизации.Шрифт = Новый Шрифт(, 10, Истина);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьПериода = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьПериода.Объединить();
	ОбластьПериода.Текст = СтрШаблон("Период: %1", Формат(ПериодМесяца, "ДФ='MMMM yyyy'"));
	ОбластьПериода.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьПериода.ЦветТекста = Новый Цвет(71, 85, 105);
	ПрименитьРамку(ОбластьПериода);
	
	Возврат НомерСтроки;
	
КонецФункции

Функция ВывестиБлокОбщейОценки(ДокументРезультат, НомерСтроки, ОбщаяОценка)
	
	ИнтерпретацияОбщая = ИнтерпретацияОценки(ОбщаяОценка);
	ОбластьИтога = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьИтога.Объединить();
	ОбластьИтога.Текст = СтрШаблон(
		"Интегральная оценка EGS: %1 из 5  |  %2  |  %3",
		Формат(ОбщаяОценка, "ЧДЦ=2"),
		ИнтерпретацияОбщая.Уровень,
		ИнтерпретацияОбщая.Описание);
	ОбластьИтога.ЦветФона = ИнтерпретацияОбщая.ЦветФона;
	ОбластьИтога.ЦветТекста = ИнтерпретацияОбщая.ЦветТекста;
	ОбластьИтога.Шрифт = Новый Шрифт(, 11, Истина);
	ОбластьИтога.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	УстановитьВысотуСтроки(ОбластьИтога, 28);
	ПрименитьРамку(ОбластьИтога, 2);
	
	Возврат НомерСтроки;
	
КонецФункции

Функция ВывестиШапкуТаблицы(ДокументРезультат, НомерСтроки)
	
	ОбластьШкалы = ДокументРезультат.Область(
		НомерСтроки,
		КолонкаШкалаНачало(),
		НомерСтроки,
		КолонкаШкалаНачало() + ШиринаШкалыСегментов() - 1);
	ОбластьШкалы.Объединить();
	ОбластьШкалы.Текст = "Положение показателя";
	
	ДокументРезультат.Область(НомерСтроки, КолонкаПоказатель()).Текст = "Показатель";
	ДокументРезультат.Область(НомерСтроки, КолонкаЗначение()).Текст = "Значение";
	ДокументРезультат.Область(НомерСтроки, КолонкаНорма()).Текст = "Норма";
	ДокументРезультат.Область(НомерСтроки, КолонкаОценка()).Текст = "Оценка";
	ДокументРезультат.Область(НомерСтроки, КолонкаУровень()).Текст = "Уровень";
	ДокументРезультат.Область(НомерСтроки, КолонкаИнтерпретация()).Текст = "Интерпретация и рекомендации";
	
	ОбластьШапки = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьШапки.Шрифт = Новый Шрифт(, , Истина);
	ОбластьШапки.ЦветФона = ЦветЗаголовка();
	ОбластьШапки.ЦветТекста = Новый Цвет(255, 255, 255);
	ОбластьШапки.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	УстановитьВысотуСтроки(ОбластьШапки, 22);
	ПрименитьРамку(ОбластьШапки);
	
	Возврат НомерСтроки + 1;
	
КонецФункции

Функция ВывестиКарточкуПоказателя(ДокументРезультат, НомерСтроки, Описание, ЗначениеПоказателя, РассчитаннаяОценка, Интерпретация, НомерКарточки)
	
	НомерСтрокиДанных = НомерСтроки;
	ЦветКарточки = ?(НомерКарточки % 2 = 0, Новый Цвет(248, 250, 252), Новый Цвет(255, 255, 255));
	
	ОбластьПоказателя = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаПоказатель());
	ОбластьПоказателя.Текст = Описание.Наименование;
	ОбластьПоказателя.Шрифт = Новый Шрифт(, 10, Истина);
	ОбластьПоказателя.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	
	ОбластьЗначения = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаЗначение());
	ОбластьЗначения.Текст = ПредставлениеЗначения(ЗначениеПоказателя, Описание.ТипЗначения);
	ОбластьЗначения.Шрифт = Новый Шрифт(, 11, Истина);
	ОбластьЗначения.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьНормы = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаНорма());
	ОбластьНормы.Текст = ПредставлениеНормы(Описание);
	ОбластьНормы.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьОценки = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаОценка());
	Если РассчитаннаяОценка <> Неопределено Тогда
		ОбластьОценки.Текст = Формат(РассчитаннаяОценка, "ЧДЦ=2");
		ОбластьОценки.Шрифт = Новый Шрифт(, 11, Истина);
	Иначе
		ОбластьОценки.Текст = "—";
	КонецЕсли;
	ОбластьОценки.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьУровня = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаУровень());
	ОбластьУровня.Текст = Интерпретация.Уровень;
	ОбластьУровня.ЦветФона = Интерпретация.ЦветФона;
	ОбластьУровня.ЦветТекста = Интерпретация.ЦветТекста;
	ОбластьУровня.Шрифт = Новый Шрифт(, , Истина);
	ОбластьУровня.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	
	ОбластьИнтерпретации = ДокументРезультат.Область(НомерСтрокиДанных, КолонкаИнтерпретация());
	ОбластьИнтерпретации.Текст = Интерпретация.ПолныйТекст;
	ОбластьИнтерпретации.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьИнтерпретации.ЦветТекста = Новый Цвет(51, 65, 85);
	
	ОбластьДанных = ДокументРезультат.Область(НомерСтрокиДанных, 1, НомерСтрокиДанных, ПоследняяКолонка());
	ОбластьДанных.ЦветФона = ЦветКарточки;
	УстановитьВысотуСтроки(ОбластьДанных, 30);
	ПрименитьРамку(ОбластьДанных);
	
	НарисоватьЦветнуюШкалу(ДокументРезультат, НомерСтрокиДанных, ЗначениеПоказателя, Описание);
	ОбластьУровня.ЦветФона = Интерпретация.ЦветФона;
	ОбластьУровня.ЦветТекста = Интерпретация.ЦветТекста;
	
	НомерСтроки = НомерСтрокиДанных + 1;
	ОбластьПодписиШкалы = ДокументРезультат.Область(НомерСтроки, КолонкаШкалаНачало(), НомерСтроки, КолонкаШкалаНачало() + ШиринаШкалыСегментов() - 1);
	ОбластьПодписиШкалы.Объединить();
	ОбластьПодписиШкалы.Текст = ПодписьШкалы(Описание);
	ОбластьПодписиШкалы.ЦветТекста = Новый Цвет(100, 116, 139);
	ОбластьПодписиШкалы.Шрифт = Новый Шрифт(, 8);
	ОбластьПодписиШкалы.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
	ОбластьПодписиШкалы.ЦветФона = Новый Цвет(248, 250, 252);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьПодсказки = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьПодсказки.Объединить();
	ОбластьПодсказки.Текст = Описание.ТекстНормы;
	ОбластьПодсказки.ЦветФона = Новый Цвет(248, 250, 252);
	ОбластьПодсказки.ЦветТекста = Новый Цвет(100, 116, 139);
	ОбластьПодсказки.Шрифт = Новый Шрифт(, 8);
	ОбластьПодсказки.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ПрименитьРамку(ОбластьПодсказки);
	
	Возврат НомерСтроки + 1;
	
КонецФункции

Процедура ВывестиБлокЗонУлучшения(ДокументРезультат, НомерСтроки, СводкаПоказателей)
	
	Проблемные = Новый Массив;
	Для Каждого СтрокаСводки Из СводкаПоказателей Цикл
		Если СтрокаСводки.Уровень = "Критично"
			Или СтрокаСводки.Уровень = "Низкая"
			Или СтрокаСводки.Уровень = "Удовлетворительно" Тогда
			Проблемные.Добавить(СтрокаСводки);
		КонецЕсли;
	КонецЦикла;
	
	ОбластьЗаголовка = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Текст = "Зоны, требующие внимания руководителя";
	ОбластьЗаголовка.Шрифт = Новый Шрифт(, 12, Истина);
	ОбластьЗаголовка.ЦветФона = Новый Цвет(254, 243, 199);
	ОбластьЗаголовка.ЦветТекста = Новый Цвет(120, 83, 14);
	ПрименитьРамку(ОбластьЗаголовка);
	
	НомерСтроки = НомерСтроки + 1;
	ОбластьСодержимого = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки + 4, ПоследняяКолонка());
	ОбластьСодержимого.Объединить();
	
	Если Проблемные.Количество() = 0 Тогда
		ОбластьСодержимого.Текст = "Все показатели в зоне «Хорошо» или «Отлично». Поддерживайте текущую стратегию и контролируйте динамику.";
		ОбластьСодержимого.ЦветФона = Новый Цвет(209, 250, 229);
		ОбластьСодержимого.ЦветТекста = Новый Цвет(22, 78, 56);
	Иначе
		ТекстБлока = "";
		Для Каждого СтрокаСводки Из Проблемные Цикл
			Маркер = ?(СтрокаСводки.Уровень = "Критично" Или СтрокаСводки.Уровень = "Низкая", "●", "○");
			ТекстБлока = ТекстБлока + Маркер + " " + СтрокаСводки.Наименование
				+ " (" + СтрокаСводки.Уровень + "): "
				+ СтрокаСводки.Описание;
			Если ЗначениеЗаполнено(СтрокаСводки.Рекомендация) Тогда
				ТекстБлока = ТекстБлока + " → " + СтрокаСводки.Рекомендация;
			КонецЕсли;
			ТекстБлока = ТекстБлока + Символы.ПС;
		КонецЦикла;
		ОбластьСодержимого.Текст = ТекстБлока;
		ОбластьСодержимого.ЦветФона = Новый Цвет(255, 247, 237);
		ОбластьСодержимого.ЦветТекста = Новый Цвет(154, 52, 18);
	КонецЕсли;
	
	ОбластьСодержимого.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьСодержимого.Шрифт = Новый Шрифт(, 10);
	ПрименитьРамку(ОбластьСодержимого);
	
КонецПроцедуры

Процедура ВывестиЛегенду(ДокументРезультат, НомерСтроки)
	
	ОбластьЛегенды = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки + 3, ПоследняяКолонка());
	ОбластьЛегенды.Объединить();
	ОбластьЛегенды.Текст =
		"Как читать отчёт:" + Символы.ПС
		+ "• Значение — фактический показатель из бизнес-аналитики (загрузка %%, ночи, ₽)." + Символы.ПС
		+ "• Цветная шкала — зелёная зона: норма, ▼ маркер: факт (оранжевый — ниже нормы, синий — в/выше нормы)." + Символы.ПС
		+ "• Оценка — шкала 0–5: 4,5+ Отлично | 3,5+ Хорошо | 2,5+ Удовлетворительно | 1,5+ Низкая | ниже — Критично.";
	ОбластьЛегенды.ЦветФона = Новый Цвет(241, 245, 249);
	ОбластьЛегенды.ЦветТекста = Новый Цвет(71, 85, 105);
	ОбластьЛегенды.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ПрименитьРамку(ОбластьЛегенды);
	
КонецПроцедуры

Процедура ВывестиРезюмеДляРуководителя(ДокументРезультат, НомерСтроки, СводкаПоказателей, ОбщаяОценка)
	
	ОбластьЗаголовка = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки, ПоследняяКолонка());
	ОбластьЗаголовка.Объединить();
	ОбластьЗаголовка.Текст = "Резюме для руководителя";
	ОбластьЗаголовка.Шрифт = Новый Шрифт(, 13, Истина);
	ОбластьЗаголовка.ЦветФона = ЦветЗаголовка();
	ОбластьЗаголовка.ЦветТекста = Новый Цвет(255, 255, 255);
	ПрименитьРамку(ОбластьЗаголовка);
	
	НомерСтроки = НомерСтроки + 1;
	ТекстРезюме = СформироватьТекстРезюме(СводкаПоказателей, ОбщаяОценка);
	ОбластьРезюме = ДокументРезультат.Область(НомерСтроки, 1, НомерСтроки + 8, ПоследняяКолонка());
	ОбластьРезюме.Объединить();
	ОбластьРезюме.Текст = ТекстРезюме;
	ОбластьРезюме.ЦветФона = Новый Цвет(255, 255, 255);
	ОбластьРезюме.ЦветТекста = Новый Цвет(30, 41, 59);
	ОбластьРезюме.РазмещениеТекста = ТипРазмещенияТекстаТабличногоДокумента.Переносить;
	ОбластьРезюме.Шрифт = Новый Шрифт(, 10);
	ПрименитьРамку(ОбластьРезюме);
	
КонецПроцедуры

Функция СформироватьТекстРезюме(СводкаПоказателей, ОбщаяОценка)
	
	Сильные = Новый Массив;
	Слабые = Новый Массив;
	Критичные = Новый Массив;
	
	Для Каждого СтрокаСводки Из СводкаПоказателей Цикл
		Если СтрокаСводки.Уровень = "Критично" Или СтрокаСводки.Уровень = "Низкая" Тогда
			Критичные.Добавить(СтрокаСводки);
		ИначеЕсли СтрокаСводки.Уровень = "Удовлетворительно" Тогда
			Слабые.Добавить(СтрокаСводки);
		Иначе
			Сильные.Добавить(СтрокаСводки);
		КонецЕсли;
	КонецЦикла;
	
	Текст = "";
	
	Если ОбщаяОценка <> Неопределено Тогда
		ИнтерпретацияОбщая = ИнтерпретацияОценки(ОбщаяОценка);
		Текст = Текст + СтрШаблон(
			"Общий вывод: интегральная оценка EGS %1 из 5 (%2). %3",
			Формат(ОбщаяОценка, "ЧДЦ=2"),
			ИнтерпретацияОбщая.Уровень,
			ИнтерпретацияОбщая.Описание) + Символы.ПС + Символы.ПС;
	Иначе
		Текст = Текст + "Общий вывод: интегральная оценка EGS не загружена — ориентируйтесь на детальные показатели ниже." + Символы.ПС + Символы.ПС;
	КонецЕсли;
	
	Если Сильные.Количество() > 0 Тогда
		Текст = Текст + "Сильные стороны:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Сильные Цикл
			Текст = Текст + "  + " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Если Критичные.Количество() > 0 Тогда
		Текст = Текст + "Зоны критического внимания:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Критичные Цикл
			Текст = Текст + "  ! " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Если Слабые.Количество() > 0 Тогда
		Текст = Текст + "Показатели, требующие контроля:" + Символы.ПС;
		Для Каждого СтрокаСводки Из Слабые Цикл
			Текст = Текст + "  - " + СтрокаСводки.Наименование + ": " + СтрокаСводки.Описание + Символы.ПС;
		КонецЦикла;
		Текст = Текст + Символы.ПС;
	КонецЕсли;
	
	Текст = Текст + "Рекомендуемые управленческие действия:" + Символы.ПС;
	Если Критичные.Количество() > 0 Или Слабые.Количество() > 0 Тогда
		Текст = Текст
			+ "  1. Сфокусируйтесь на показателях с низкой оценкой: загрузка, ADR, RevPAG и длительность пребывания взаимосвязаны." + Символы.ПС
			+ "  2. Пересмотрите тарифную политику и каналы продаж (OTA vs прямые бронирования)." + Символы.ПС
			+ "  3. Разработайте пакетные предложения и программы upsell для роста RevPAG и ALOS." + Символы.ПС;
	Иначе
		Текст = Текст
			+ "  1. Закрепите текущую эффективность: зафиксируйте лучшие практики в ценообразовании и сервисе." + Символы.ПС
			+ "  2. Инвестируйте в направления с наивысшей отдачей (допуслуги, F&B, SPA)." + Символы.ПС
			+ "  3. Установите контрольные KPI на следующий период, чтобы не допустить снижения показателей." + Символы.ПС;
	КонецЕсли;
	
	Возврат Текст;
	
КонецФункции

Процедура НарисоватьЦветнуюШкалу(ДокументРезультат, НомерСтроки, Значение, Описание)
	
	ДлинаШкалы = ШиринаШкалыСегментов();
	МаксШкалы = Описание.МаксШкалы;
	ЦветТрека = Новый Цвет(203, 213, 225);
	ЦветНорма = Новый Цвет(74, 222, 128);
	ЦветМаркер = Новый Цвет(29, 78, 216);
	ЦветНижеНормы = Новый Цвет(249, 115, 22);
	ЦветВышеНормы = Новый Цвет(59, 130, 246);
	ЛинияСегмента = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	
	ПозицияЗначения = 0;
	Если Значение <> Неопределено Тогда
		ПозицияЗначения = Цел(Мин(ДлинаШкалы, Макс(1, Значение / МаксШкалы * ДлинаШкалы)));
	КонецЕсли;
	
	НачалоНормы = Цел(Мин(ДлинаШкалы, Макс(1, Описание.МинНорма / МаксШкалы * ДлинаШкалы)));
	Если Описание.ТолькоМинимум Тогда
		КонецНормы = ДлинаШкалы;
	Иначе
		КонецНормы = Цел(Мин(ДлинаШкалы, Макс(1, Описание.МаксНорма / МаксШкалы * ДлинаШкалы)));
	КонецЕсли;
	
	Для Индекс = 1 По ДлинаШкалы Цикл
		ОбластьСегмента = ДокументРезультат.Область(НомерСтроки, КолонкаШкалаНачало() + Индекс - 1);
		
		Если Индекс = ПозицияЗначения И Значение <> Неопределено Тогда
			Если Значение < Описание.МинНорма Тогда
				ОбластьСегмента.ЦветФона = ЦветНижеНормы;
			ИначеЕсли Не Описание.ТолькоМинимум И Значение > Описание.МаксНорма Тогда
				ОбластьСегмента.ЦветФона = ЦветВышеНормы;
			Иначе
				ОбластьСегмента.ЦветФона = ЦветМаркер;
			КонецЕсли;
			ОбластьСегмента.Текст = "▼";
			ОбластьСегмента.ЦветТекста = Новый Цвет(255, 255, 255);
			ОбластьСегмента.Шрифт = Новый Шрифт(, 9, Истина);
		ИначеЕсли Индекс >= НачалоНормы И Индекс <= КонецНормы Тогда
			ОбластьСегмента.ЦветФона = ЦветНорма;
		Иначе
			ОбластьСегмента.ЦветФона = ЦветТрека;
		КонецЕсли;
		
		ОбластьСегмента.ГоризонтальноеПоложение = ГоризонтальноеПоложение.Центр;
		ОбластьСегмента.ВертикальноеПоложение = ВертикальноеПоложение.Центр;
		ОбластьСегмента.Обвести(ЛинияСегмента, ЛинияСегмента, ЛинияСегмента, ЛинияСегмента);
	КонецЦикла;
	
КонецПроцедуры

Функция ПредставлениеЗначения(Значение, ТипЗначения)
	
	Если Значение = Неопределено Тогда
		Возврат "—";
	КонецЕсли;
	
	Если ТипЗначения = "Процент" Тогда
		Возврат Формат(Значение, "ЧДЦ=1") + "%";
	ИначеЕсли ТипЗначения = "Ночи" Или ТипЗначения = "ALOS" Тогда
		Возврат Формат(Значение, "ЧДЦ=1") + " ноч.";
	Иначе
		Возврат Формат(Значение, "ЧДЦ=0") + " ₽";
	КонецЕсли;
	
КонецФункции

Функция ПредставлениеНормы(Описание)
	
	Если Описание.ТипЗначения = "Процент" Тогда
		Возврат СтрШаблон("%1%% – %2%%",
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	ИначеЕсли Описание.ТипЗначения = "ALOS" Или Описание.ТипЗначения = "Ночи" Тогда
		Возврат СтрШаблон("%1 – %2 ноч.",
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	ИначеЕсли Описание.ТолькоМинимум Тогда
		Возврат СтрШаблон("от %1 ₽",
			Формат(Описание.МинНорма, "ЧДЦ=0"));
	Иначе
		Возврат СтрШаблон("%1 – %2 ₽",
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	КонецЕсли;
	
КонецФункции

Функция ПодписьШкалы(Описание)
	
	Если Описание.ТипЗначения = "Процент" Тогда
		Возврат СтрШаблон(
			"0%% — %1%%   |   норма %2%% – %3%%",
			Формат(Описание.МаксШкалы, "ЧДЦ=0"),
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	ИначеЕсли Описание.ТипЗначения = "ALOS" Или Описание.ТипЗначения = "Ночи" Тогда
		Возврат СтрШаблон(
			"0 — %1 ноч.   |   норма %2 – %3",
			Формат(Описание.МаксШкалы, "ЧДЦ=0"),
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	ИначеЕсли Описание.ТолькоМинимум Тогда
		Возврат СтрШаблон(
			"0 — %1 ₽   |   норма от %2 ₽",
			Формат(Описание.МаксШкалы, "ЧДЦ=0"),
			Формат(Описание.МинНорма, "ЧДЦ=0"));
	Иначе
		Возврат СтрШаблон(
			"0 — %1 ₽   |   норма %2 – %3 ₽",
			Формат(Описание.МаксШкалы, "ЧДЦ=0"),
			Формат(Описание.МинНорма, "ЧДЦ=0"),
			Формат(Описание.МаксНорма, "ЧДЦ=0"));
	КонецЕсли;
	
КонецФункции

Функция РассчитатьОценкуALOS(Значение)
	
	// Логика из справки БА: курортная модель, оптимум 5–7 ночей.
	НормОценка = 0.15;
	
	Если Значение >= 5 И Значение <= 7 Тогда
		НормОценка = 0.85;
	ИначеЕсли Значение > 7 И Значение <= 9 Тогда
		НормОценка = 0.70;
	ИначеЕсли Значение >= 4 И Значение < 5 Тогда
		НормОценка = 0.55;
	ИначеЕсли Значение >= 3 И Значение < 4 Тогда
		НормОценка = 0.45;
	ИначеЕсли Значение >= 2 И Значение < 3 Тогда
		НормОценка = 0.30;
	ИначеЕсли Значение >= 1 И Значение < 2 Тогда
		НормОценка = 0.20;
	ИначеЕсли Значение > 9 И Значение <= 14 Тогда
		НормОценка = 0.60;
	ИначеЕсли Значение > 14 Тогда
		НормОценка = 0.50;
	КонецЕсли;
	
	Возврат НормОценка * 5;
	
КонецФункции

Функция РассчитатьОценкуПоЗначению(Значение, Описание)
	
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если Описание.ТипЗначения = "ALOS" Тогда
		Возврат РассчитатьОценкуALOS(Значение);
	КонецЕсли;
	
	МинНорма = Описание.МинНорма;
	МаксНорма = Описание.МаксНорма;
	НормОценка = 0.5;
	
	Если Описание.ТолькоМинимум И Значение >= МинНорма Тогда
		НормОценка = 1.0;
	ИначеЕсли Не Описание.ТолькоМинимум И Значение >= МинНорма И Значение <= МаксНорма Тогда
		НормОценка = 1.0;
	ИначеЕсли Значение < МинНорма Тогда
		Если Значение < МинНорма * 0.5 Тогда
			НормОценка = 0;
		ИначеЕсли Значение < МинНорма * 0.7 Тогда
			НормОценка = 0.25;
		Иначе
			НормОценка = 0.5;
		КонецЕсли;
	Иначе
		КритМакс = МаксНорма * 1.5;
		Если Значение > КритМакс * 1.3 Тогда
			НормОценка = 0.25;
		ИначеЕсли Значение > КритМакс Тогда
			НормОценка = 0.5;
		Иначе
			НормОценка = 0.75;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НормОценка * 5;
	
КонецФункции

Функция НормализованнаяОценка(Оценка)
	
	Если Оценка = Неопределено Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Мин(1, Макс(0, Оценка / 5));
	
КонецФункции

Функция ИнтерпретацияОценки(Оценка)
	
	Результат = Новый Структура("Уровень, Описание, ЦветФона, ЦветТекста");
	НормОценка = НормализованнаяОценка(Оценка);
	
	Если НормОценка >= 0.9 Тогда
		Результат.Уровень = "Отлично";
		Результат.Описание = "Параметры управления на высоком уровне — отель работает эффективно";
		Результат.ЦветФона = Новый Цвет(187, 247, 208);
		Результат.ЦветТекста = Новый Цвет(22, 78, 56);
	ИначеЕсли НормОценка >= 0.7 Тогда
		Результат.Уровень = "Хорошо";
		Результат.Описание = "Большинство показателей в рабочем диапазоне";
		Результат.ЦветФона = Новый Цвет(209, 250, 229);
		Результат.ЦветТекста = Новый Цвет(22, 78, 56);
	ИначеЕсли НормОценка >= 0.5 Тогда
		Результат.Уровень = "Удовлетворительно";
		Результат.Описание = "Есть отдельные направления, требующие усиления контроля";
		Результат.ЦветФона = Новый Цвет(254, 243, 199);
		Результат.ЦветТекста = Новый Цвет(120, 83, 14);
	ИначеЕсли НормОценка >= 0.3 Тогда
		Результат.Уровень = "Низкая";
		Результат.Описание = "Операционная эффективность ниже целевой — требуется корректировка стратегии";
		Результат.ЦветФона = Новый Цвет(254, 215, 170);
		Результат.ЦветТекста = Новый Цвет(154, 52, 18);
	Иначе
		Результат.Уровень = "Критично";
		Результат.Описание = "Критически низкие показатели — необходимы срочные управленческие меры";
		Результат.ЦветФона = Новый Цвет(254, 202, 202);
		Результат.ЦветТекста = Новый Цвет(153, 27, 27);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтерпретацияПоказателя(Значение, Оценка, Описание)
	
	Интерпретация = ИнтерпретацияОценки(?(Оценка = Неопределено, 0, Оценка));
	Рекомендация = "";
	
	Если Значение <> Неопределено Тогда
		Если Значение < Описание.МинНорма Тогда
			Интерпретация.Описание = Описание.ТекстНизко;
			Рекомендация = Описание.РекомендацияНизко;
		ИначеЕсли Описание.ТолькоМинимум Тогда
			Интерпретация.Описание = Описание.ТекстВНорме;
		ИначеЕсли Значение > Описание.МаксНорма Тогда
			Интерпретация.Описание = Описание.ТекстВысоко;
			Рекомендация = Описание.РекомендацияВысоко;
		Иначе
			Интерпретация.Описание = Описание.ТекстВНорме;
		КонецЕсли;
	КонецЕсли;
	
	// Для ALOS текст по положению относительно нормы может не совпадать с оценкой — уточняем по оценке.
	Если Описание.ТипЗначения = "ALOS" И Оценка <> Неопределено Тогда
		Если Оценка < 2.5 Тогда
			Интерпретация.Описание = Описание.ТекстНизко;
			Рекомендация = Описание.РекомендацияНизко;
		ИначеЕсли Оценка >= 4.5 Тогда
			Интерпретация.Описание = Описание.ТекстВНорме;
		КонецЕсли;
	КонецЕсли;
	
	Интерпретация.Вставить("ПолныйТекст", Интерпретация.Описание);
	Если ЗначениеЗаполнено(Рекомендация) Тогда
		Интерпретация.ПолныйТекст = Интерпретация.Описание + Символы.ПС + "→ " + Рекомендация;
	КонецЕсли;
	Интерпретация.Вставить("Рекомендация", Рекомендация);
	
	Возврат Интерпретация;
	
КонецФункции

Процедура ПрименитьРамку(Область, Толщина = 1)
	
	Линия = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, Толщина);
	Область.Обвести(Линия, Линия, Линия, Линия);
	
КонецПроцедуры

Процедура УстановитьВысотуСтроки(Область, Высота)
	
	Область.ВысотаСтроки = Высота;
	
КонецПроцедуры

Процедура УстановитьШиринуКолонки(ДокументРезультат, НомерКолонки, Ширина)
	
	ДокументРезультат.Область(1, НомерКолонки).ШиринаКолонки = Ширина;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
