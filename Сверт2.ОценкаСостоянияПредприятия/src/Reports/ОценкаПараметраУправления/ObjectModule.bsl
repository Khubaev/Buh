#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

// Отчёт EGS: гостиничные KPI, цветная шкала, оценка, резюме для руководителя.
//
Процедура ПриКомпоновкеРезультата(ДокументРезультат, ДанныеРасшифровки, СтандартнаяОбработка)
	
	ПериодОтчета = ПолучитьПериодОтчета();
	Организация = ПолучитьОрганизацию();
	СтандартнаяОбработка = Ложь;
	СформироватьОтчет(ДокументРезультат, ПериодОтчета, Организация);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область КонстантыОформления

Функция КолонкаПоказатель()
	Возврат 1;
КонецФункции

Функция КолонкаЗначение()
	Возврат 2;
КонецФункции

Функция КолонкаНорма()
	Возврат 3;
КонецФункции

Функция КолонкаШкалаНачало()
	Возврат 4;
КонецФункции

Функция ШиринаШкалыСегментов()
	Возврат 16;
КонецФункции

Функция КолонкаОценка()
	Возврат КолонкаШкалаНачало() + ШиринаШкалыСегментов();
КонецФункции

Функция КолонкаУровень()
	Возврат КолонкаОценка() + 1;
КонецФункции

Функция КолонкаИнтерпретация()
	Возврат КолонкаУровень() + 1;
КонецФункции

Функция ПоследняяКолонка()
	Возврат КолонкаИнтерпретация();
КонецФункции

Функция ЦветЗаголовка()
	Возврат Новый Цвет(30, 58, 138);
КонецФункции

#КонецОбласти

Функция ПолучитьПериодОтчета()
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	ЗначениеПараметра = Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Период"));
	
	Если ЗначениеПараметра <> Неопределено И ЗначениеПараметра.Использование Тогда
		Период = ЗначениеПараметра.Значение;
		Если ТипЗнч(Период) = Тип("СтандартныйПериод")
			И ЗначениеЗаполнено(Период.ДатаНачала)
			И ЗначениеЗаполнено(Период.ДатаОкончания) Тогда
			Возврат Период;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Новый СтандартныйПериод(ВариантСтандартногоПериода.ЭтотМесяц);
	
КонецФункции

Функция ПолучитьОрганизацию()
	
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	ЗначениеПараметра = Настройки.ПараметрыДанных.НайтиЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Организация"));
	
	Если ЗначениеПараметра <> Неопределено И ЗначениеПараметра.Использование
		И ЗначениеЗаполнено(ЗначениеПараметра.Значение) Тогда
		Возврат ЗначениеПараметра.Значение;
	КонецЕсли;
	
	Возврат Справочники.Организации.ОрганизацияПоУмолчанию();
	
КонецФункции

